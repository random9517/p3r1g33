{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……やっと、二人きりになれた。あなたはいつも、こんなところに隠れてい\nたんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00024201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ここって、お仕置き部屋って呼ばれているところだよね。噂を聞いたことが\nある。あなたは、私に今からおしおきをするの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00024201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んっ……。全然嫌そうじゃないって？　そう……かも。おしおきって、えっ\nちなことなんだよね。ここ、すごくいやらしい匂いがするから……わかるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00024201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「じゃあどうして逃げないのかって？　えっと……。わたしはあなたと、えっ\nちなことがしたい……んだと思う。したかったから、来た」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00024201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あのね。いやじゃないから……して？　あなたが考えるえっちなおしおきに\n興味がある。今ならなんだって受け入れる……って、わっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「こういう格好でおしおきするの……？　これは……すこしびっくりした……\n。まつばくずし……？　ううん、それは知らないけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024201_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「へえ……。あなたが興奮するのはこういうポーズなんだ……。また１つ、あ\nなたのことがわかってうれしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「それで、どんなおしおきがしたいの？　わたし……あまりこういう知識がな\nいから、やり方がわからないけど……。ん？　胸……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ふぁっ……！　胸に触りたいの？　あっ……くすぐったいよ……っ。むにむ\nにしないで……。や、やわらかくて気持ちいい……？　そうなの……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あ、力強いよ……。ぐにぐに揉んだら形変わっちゃう……！　んん……！　\n前戯……？　えっちの前の下準備……？　おっぱいで遊ぶのが……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「っひゃ……！　今度はふともも……？　あなたって、いろんなところを撫で\n回すのがすきなの？　つついたり……んんんっ、くすぐったり……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「っはぁっ……はぁ、なんか……体温が上がってくる……。あなたの手にまさ\nぐられて……あなたが近くにいると……頭がとろんとしてきて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……ンッ！？　い、今ちゅうした……？　キス……。ファーストキス……。\nちゅ……ちゅ、んん……。キスしながら、またおっぱいと脚触ってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ぷぁ……。も、もういいでしょ……？　わたしのいろんなところ、これ以上\nいじりまわさないで……。いいから、もうちゃんと濡れてる……から」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「だから、いつでも入れていいけど……。一つだけ。わたし……こういうこと\n、するの初めてだから……。ちょっとだけ手加減して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わっ……！　ど、どうして？　どうして今ので硬くなるの？　いいよ……い\nいけど……ちょっとヘン……。あなた、もしかしてヘンタイさん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「っぁ……っ！　ふぁ……あぁ、んぁあああ……！　は、話してる途中で入れ\nるのズルい……ぃ！　あっ、す、ごい……ズブって奥まで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「硬い……んんっ！？　あ、熱いぃ……！　お腹の中でドクドク脈打ってる…\n…。あ……っ。そうなんだ、これがえっち……。んく……んぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わたしの……わたしの中にぶっといおちんちんが埋まってる……！　あ、す\nごい……すごい、未知の感覚……っ。あ、う、動くなら……少しずつ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ゆっくり動いて……。あっ……、あなた、のこれ……。これの形を覚えてお\nきたいから……形がわかるように入れたり出したりして……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「は、ぁ……うぅっ……。あっ……ぁ……あぁ……っ。そ、そう……そんなか\nんじ……。あっ……おちんちんって、すご……い。こんな感じなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「お腹の奥、つんつんってつつかれて……身体が勝手にびくびくしちゃうし…\n…。太いところが、ひっかかって……おまんこが拡がるの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「こ、れ……。あぁっ……！　これって普通の大きさ？　ふつうよりおっきい\n気がする……すっごく拡がってる、中……にゅるにゅるって拡げられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「はぁっ！？　う……！？　にちゅにちゅってやらしい音が……する、わたし\nのおまんこの中、なんかニュルニュルのネトネトで……あっ、ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「こんな風になるの……！？　あっ……！　おちんちん、包み込んじゃって…\n…からみついて、……ぁっ……ねちゃねちゃで……。あふ……、んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「思いっきりしがみついてるかんじ……。あ、あ、あ……あっ、おちんちんと\nおまんこが仲良くなりたがってるみたい……密着してる。すご、い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「こん、ななんだ……っ。えっちって……あっ、こんな風で……。はぁっ……\n。この体勢のせい……？　ものすごく深く刺さってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「こんなに深く繋がって……粘膜、全部絡みつかせて……するんだ……。あっ\n、胸……？　また胸ぐにぐにするの……？　揉みながら、……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「腰……腰動かして……？　あっ！？　あっ……。えっ？　えっえっえっ？　\n思ってたのとちがう……えっちって、……えっ？　ここまですごい、のっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「や……やぁああ……！　全身ガクガク痙攣して、頭がばかになる……！　え\nっ？　えっ？　気持ち良すぎる？　なにこれっ……え？　えっ？　え！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「はぅっ！？　あぁああ……！　だめっ……だめ、おっぱい揉みながら腰っ…\n…腰激しく突き上げたら、あっ、あっ……身体が浮いちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んぁあっ……あぁ！　おまんこの中っ……どちゅどちゅ突かれて……めちゃ\nくちゃで！　いやっ……でも、でも……やめるのもいや……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「や、めないで……このまま……このままして……っ。あっ……はぁっ……は\nぁっ、はぁ……えっち、すごい……すごい、きもちいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わたし、女の子にうまれてきた理由……わかった。えっち……！　あなたと\nえっちするため……っ、あぁ……今だけは使命もどうでも、いい……あうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「えっち、えっちしたい……ずっとしたい、もっとしたい……！　あっ……あ\nっ、あっ……あっ、あっあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「どうしたの……？　突くスピードどんどん速くなって……っ！　ん！？　し\nゃせいしそう？　射精って……あの射精？　せ、精液……えっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ん……！　あっ！？　ふぁああっ！？　うそ……ウソ……！　こんなっ……\nこんな勢いで中に入ってくるなんて……っ。やぁああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「やだっ……やだ、やだよぉ……！　あぁ、中に……中にびゅるびゅるってせ\nーし入ってきてる……！　赤ちゃんできちゃう……ぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ひに、ん……避妊のことなんて全然考えてなかった……。あっ……！　えっ\nちしたくて、初めてで、精一杯で……ふぁああん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「精液が、せーしがこんなに入ってくるのぉ……っ？　わたしの中、すぐにい\nっぱいになる、溢れちゃうくらい……限界いっぱい入って……あぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「も……もう無理……っ。そんなにたくさん入らない……！　あっ……まだ出\nすの……っ。壊れちゃう、おまんこ破裂しちゃ……んーっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「っふぁ……！　やっと……やっとおさまってき、た……。それでも精液の量\n……すごくて……。うぷ、口から出ちゃいそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁ……！　全部出た……？　よ、良かった……。それな\nらすぐにおまんこ洗わないと……。って、ひぅ！　な、なに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「えっ……？　こ、このまま、またするの……？　抜いてよぉ……！　おまた\nがヌルヌルしてきもちわるいよ……それに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「精液いっぱい入ったままでえっちし続けたら……本当にできるよ、赤ちゃん\n……。ぁっ……わたし、初めてで赤ちゃん……できちゃうの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んっ……？　気持ちいい……けど、それはそうだけど……。え？　赤ちゃん\nできちゃってもいい？　なにいってるの……産んでほしい？　えっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「そうなの……？　わたし、あなたと……。……えっと……。わ……わかった\n。あなたがそう思ってるなら……。ん……このままでいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……続けて。でも本当に知らないから……。わたしたち、パパとママになっ\nちゃうんだよ……？　ぅっ……うっ……♪　いいなら……いいけど……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「っぁ……！　なんで……赤ちゃんできるって言ったらおっきくなるの？　悪\nいおちんちん……。でも、これ……これに逆らえない……。はぁ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「このおちんちん、魔法がかかってるみたいに……おまんこにぴったりくっつ\nいて……全然離れてくれない、それで……それで……。あぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わたし、も離れたくないって思ってて……。あぁあ……もう論理的な反論と\nか、意見とか……おもいつかない。ただ……したいだけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「おねが、い……。おねがい、いっぱい突いて……！　あっ、あなたの精液と\nわたしのヌルヌルでぐちゃぐちゃのトロトロになったここ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ここ、かきまわして……！　んっ、うん……っ。あぅっ……んぅっ……うう\nっ！　あなたって……えっちが上手すぎる……どうかしてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わたし……おしっこ、おもらししてるみたいにあそこがびしょびしょで……\n！　もう全然ぎゅぅっておまたに力も入れられないのに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「そんなことおかまいなしに、太い、ので突き上げてくる……。あっ……おま\nたゆるめても……関係ないくらい太いのが、ズンズンくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わ……わぁっ、ぁ……あっぁっ、そんなに奥まで入るの……っ。突かれてる\n、わたし……わたし、あなたのモノになってる……あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ねえ……！　ま、た……またおちんちんがおかしい……！　硬くなってる、\nいまにも爆発しそうなくらい……また射精するの……！？　ほんとに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「い……いいよ、わかったぁ……！　あなたがまた、わたしのおまんこでぴゅ\nっぴゅしたいなら……もう止めない、していいから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「だから……ひんっ、あぁう……！　優しくして、強くしちゃだめぇ……！　\nあぁっ、は、激しすぎるから……！　あっ！　揺さぶられて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わたし、わたしもおかしくなるっ……ヘンになっちゃうよぉ！　何っ？　な\nに……？　こわい、ヘンになる、ヘンになるぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ……ひぃいいっ！　んひっ……はぅううっ……！　ビリビリっ…\n…おまたがビリビリして……痺れてく……ぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「きゃ……あぁ、あぁっ……あああ……！　知らない……こんなの知らないっ\n……あっ！　ゾクゾクする、頭が真っ白になる……ぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「イってる……？　これがイッてるってことなの？　ふぁ……！　ああっ、あ\nぁああ……！　おまんこイッてる、ずっとイッてる、イッちゃってるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「ひっ……ひぃっ♪　あぁ……ううううっ……！　はじめてで、はじめてでイ\nくことなんてないと思ってたのに……簡単に……あぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わたし……どうかしちゃう、あっ……！　いっぱい、いっぱい……おまんこ\nの奥からヌルヌルがあふれだしてきて……あっ！　あ、だめ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「精液、押し戻しちゃう……！　やだ……！　おねがい、栓してて……おちん\nちんでふさいでて……！　きゃふ……！　んふっ……んんんぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「どれだけ中に注いでもいいから……ぁ！　あぁああ……！　っんっ……。は\nぁっ……はぁ、はぁ……おなか、おなかが重たい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あ……あ……。すごい……息、止まっちゃうかと思った……。それくらい、\nあなたのえっちって……究極……。絶対世界一……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……わたし、これからも……たくさん戦わなきゃいけないのに……こんなえ\nっちなこと、知っちゃったら……気が散っちゃいそう……。だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「そうなったら……またおしおき、してね？　おしおきのわりに……わたしが\n気持ちいいばっかりだったけど……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んぁぅうッ！？　いきなり抜かないでよぉッ……！　あっ……ぽかぽかした\nのが胸に……降り注いで……あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマえ" ]},
		{"command":[ "SETTEXT", "「なんっ……で、なんでおっぱいにかけるの……っ？　ぁ……、これ、精液…\n…？　精液……飛んでくる、次から次に……避けられないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「んっぅうぅう……！　だめ……！　今、胸は敏感だからだめ……！　ひゃっ\n……乳首にかけないで……。熱い、あついから……。んぅっ！　んん、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「マ……マーキング……？　ケモノのオスがメスにする臭いつけ……？　わた\nし……わたしの胸とおまんこは両方あなたのもの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00024201_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、どっちかじゃなくて……。胸もあそこも俺のだ～って言ってる\nの……？　そんな強欲なこと、ないよ……あぁっ、ベトベトヌルヌルする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「くさいよぉ……！　なのに……なのに、ちっともやじゃない……。あなたの\n匂いだと思ったら……なんだか愛しくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「あ……あなたがヘンだから、わたしも影響受けてヘンになっちゃった……。\nどう……？　わたしにマーキングして……気持ち良かった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「わたしは……きもちよかった。でも、もう一度、身体の奥であなたを感じた\nかった気持ちもある……。内緒だけど……。ねえ、あなたは胸に出したら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「これで俺のものだーって嬉しくなった……？　だったら……いい。でも、今\n度はちゃんと教えてから出したり、かけたりしてほしいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エスティマ" ]},
		{"command":[ "SETTEXT", "「……どうせえっちしてヘンになるなら……２人で同じだけ、ヘンになりたい\n。わたし……おかしなこと言ってるかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
