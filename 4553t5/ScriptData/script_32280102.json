		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ヤバっ、頭……おかしくなるっ！　感じすぎてぇっ……おっ、ほぉおっ！　\nとぶっ……意識とんじゃうっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あっああっ！　あっ、あっ、あっ！　くるっ！　さっきより、ヤバいの……\nくりゅっ！　きちゃっ……うぅっ！　ひぃいいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「イ、イクぅっ！　ああっ！　マンコがぁ、熱いぃっ……！　チンポで、突き\nまくられてぇ……ひっ、ひぃおっ！　おひっ！　ひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んぉおっ！　おっ、おぉっ……おほぉぉぉぉっ！　イクっ！　マンコイクッ\n！　チンポに負ける……チンポぉっ……おっ、おおっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ま、負けたくない、のにっ……おっ、おおおぉぉっ！　もぉダメっ……！　\nイクッ、イクイクイクイクイクイク～～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104220" ]},
		{"command":[ "WAITINPUT" ]},

