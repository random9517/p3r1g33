		{"command":[ "SETIMAGE", "0", "still_00022801_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ひゃっ！　あひぃぃっ！　あんっ！　ザーメン……かかってっ！　あひっ！\n　ひんっ！　あっ……あぁぁっ！　はぁぁぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ひぅんっ……はっ、ひぃあぁっ！　やめっ……なにやってんの……！　んぁ\nぁっ！　あーしに……かけんなぁっ！　ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ひぃいんっ、はひっ……ひぐぅっ！　ザーメン、熱いっ……んぁっ……ザー\nメン、くさくて……頭おかしくなるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あぁあんっ！　イクっ……！　ザーメンぶっかけられながら、イクぅううう\nっ！　んっ、あぁっ……変態アクメしちゃうぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はぁあ、はっ……はぁはぁ……あんっ……どんだけ、出してんの……ひうっ\n……！　か、顔にまで……飛んできてるじゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あー、もう……身体中ドロドロになってるしぃ……しかも、マジくさい……\nうぅっ……むせそう……なにこれ、ヤバぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ……あーしの身体……おまえのザーメンくさくなっちゃった…\n…じゃん……どーしてくれんの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あーしたち……ハメまくってたの、絶対に匂いでバレちゃうし……でも、\nま、いいや……気持ちよかったし……」", "NORMAL" ]},
