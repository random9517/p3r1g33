{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「こらっ！　動くなって……ジッとしてなって……！　なに暴れてんだよ……\n大人しく、しろ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「いーじゃん、おまえも女共とヤリまくってんだから……あーしともヤろうよ\n。もしかして……あーしとはイヤとか言うわけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「じゃあ、問題ないじゃん。ほら……チンポはヤリたがってるし……見て、\nこれー、ギンギンになってるしー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、ふぅうっ……あーしの、オマンコにハメたいっしょ？　\nココ……ワレメにずぼずぼ～～～て、さー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「どうしたって……ムラムラしてんの。わかるっしょ？　おまえのせいで……\nなんか身体が火照って堪んないんだって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はあ？　ナめんなし！　まあ……ち、地球人とヤるのはー、初めて……だけ\nど……ま、よゆーっしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あーしにしゃぶられて、すぐイッちゃうような雑魚チンポだしさー。ハメた\n瞬間にしゃせーすんなよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ひぐっ！　な、なんスか……今、また大きくなったスよ……くっ、ふうっ…\n…もう中、いっぱいになってるのにぃ……くひぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……やばぁ……マンコ、擦りるけてるだけで、結構気持ちいい\nんだけど……はっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「これ、中に挿入ってきたら……マジで、どうなんの……超すごそう……んっ\n……あぁ、どんどんアソコが熱くなってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「おまえも、早くハメたくて……堪んない、よな……？　早く、この雑魚チン\nポ、ハメたいって……おねだりしてみ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「は、はぁあ～～～？　なんで、あーしがおねだりしなきゃいけないわけ？　\nそっちがおねだりしなよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「そもそも、こんな雑魚チンポ……ヤろうと思えば……いつだって……！　\nんっ……！　ハメれる……ん、だから……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あっ、ぐっ……！　んんぅぅっ！　だ、大丈夫だって……こんなチンポ、\nらくしょー……んひっ、ひっあっ……くひぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んっ！　あっ、ああっ！　はいって……くるぅ……チンポっ……硬いの、\nがぁ……はぁあっ、あっあっ……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はーっ、はぁっ……はぁ、はぁ……は、はいっ、た……ほらぁ……全部、\nはいったし……んっくっ……おまえも……うくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「だ、だからぁ……よゆーだって、言ってる、じゃん……てか、おまえはどう\n？　あーしのマンコ……気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「キツキツで、ヤバい……？　で、でしょー？　あーしのマンコ、最高っしょ\n……地球人なんかに、負けない……から……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あと、知ってんだよねー……腰、動かした方が……お互いに、感じるって…\n…だから、動いて……やる、から……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あっ、はっ……んんっ、くひぃいっ！　はぁ……ああっ、だーかーらー……\n無理とか、してない……しぃ……んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「でも、隊長の役に立てて……そう言ってもらえて……嬉しくて、胸があった\nかくなってくるっス……本当っスよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「おっぱいで、挟んでるときは……まあ、普通かなーとか思ってたけど……\nおまえのチンポ……結構、おっきぃ……あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「出っ張ってるとこ、がぁ……中、ゴリゴリ擦ってるっ……くっ、ううっ、\nあはぁ……すごいっ、アソコが……焼けそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あひっ、ひぃあぁっ！　べ、つに……チンポが、すごいってわけじゃなくて\n……すごく擦れてるって、言っただけでぇ……ひぃいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あんっ！　あんっ！　か、勝手に腰が……動いちゃって……\nマンコかき回されちゃうぅぅ……んんぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁんっ……！　あ、あーしも……なんか、気持ちよくなってきて…\n…んっ、あぁっ、あっ……頭が、ボーっとしてきてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ヤ、ヤバっ……あーしだけ、感じてちゃ……ダメ、だから……おまえは？　\nおまえも気持ちよくなってんの？　ねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「腰の、動き……これくらいで……いい？　んっ、あっ……し、知ってるけど\n……！　そ、そうっ、好みとかあるじゃん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あぁっ……そ、そうでしょ……あーし、優しいっしょ……？　んっ……じゃ\n、このまま……する、から……はっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ひっ！　ひぃいっ、んっ！　お、奥まで……届いてるっ……！　チンポの\n先が……めっちゃ、奥までぇえぇ……んひぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ね、ねえ……おまえ、の……チンポ、中で……おっきくなってない？　え？\n　イキそう？　しゃせぇ？　しゃせーしそうなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あっあぁっ！　あんっ！　わかっ……くっあぁっ！　あーし……もっ……\n膝に力、はいんなくて……あっ、あんっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「出していーから……っ！　はぁはぁ、はっ……あっあっ、あはぁんっ！　\nヤバいっ……イッ、イクっ！　んんうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ……！　マジっ？　出るっ？　んっ、んはぁぁぁっ！　あっあ\nぁぁ……んっはあぁぁああぁぁ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいっ～～～！　出てっ、るっ……！　ザーメンっ……んっ！　\nザーメンどくどく出てるぅぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「くっはぁぁ……あぁぁっ……！　あ、熱いぃっ……！　おなか、パンパンに\nなるっ……ひっ、くひいいっ！　いぃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あっ、あふぅっ……はぁ、はぁ、はぁ……ヤバ……これが、セックス……\n意識、飛んじゃうかと思った……あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「え？　あっ……！　な、中に出されたのは……あんまなかった、から……\n衝撃的すぎて、ちょっと驚いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「て、てか……！　おまえ、結局そっこーで、出しちゃったじゃん？　そんな\nにあーしのマンコよかったんだ？　へ～～～？？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はあ？　このまま続けんの……？　いや、ま、まー……よゆーだけど？　\nそんなにヤリたいなら、好きにすれば？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はっ！　あぁああんっ！　んっ、な、なにっ……？　いきなり……こしっ…\n…ひっ、ひぃっ！　あっはぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「下から、突き上げられ……てぇっ……！　奥っ、ゴリゴリって……ひんっ、\nひあっ！　あはっ！　あんっ！　あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ま、待ってぇ……ひぐっ！　はげ、しすぎっ……くぅんっ、くふっ、くぅん\nっ……！　か、軽く？　これが……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「痛く、は……ないけど……あぁんっ！　か、感じすぎっ……てっ……！　\nひはっ！　はっ、くひっ！　ひぃああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「べつに……動いてもいい……けど……ちょっとは、あぁんっ！　そ、そう\n雑魚チンポ……くらい、よゆーで……ひっ、ひいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あ、あんっ！　あはぁあっ、ああっ……！　い、言うっ……！　言うから…\n…ちょっと待って……ああっ、くひいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「いい、気持ちいいっ……！　おまえの、チンポぉ……おっ、おおっ……！　\n気持ちいいっ……！　ひぃうっ、んんぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「くっはっ、ああぁぁっ……！　だって、おまえが激しくするから……あーし\n、動けない……んっ！　んっはぁぁっ！　あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「チンポで、好き勝手しやがってぇ……！　ひっ、ひんっ！　あんっ！　あっ\nあんっ！　動ける、わけない……じゃん……こんなのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はひぃっ！　あぁっ……聞こえるっ……オマンコ、ぐちゅぐちゅいってるっ\n……ヤらしい音、してるぅ……んぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はっ、はっあっ……はんっ！　そ、そうっ……おまえのぉ……チンポっ！　\nチンポすごっ！　チンポぉっ、チンポチンポぉおぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ひぃぐうっ！　もうわかんないっ……！　あぁっ……悔しいとか、そんな\nこと……あっあんっ！　考えてる暇ないっ……いぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「おっ、おぅうっ！　おっ、ほっ、ほぉぉっ……！　おぉっ！　そんなにマン\nコ、突き上げられたら……声、出ちゃう……からぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あはぁんっ！　い、いく？　もうイク？　んっあぁぁ……！　また、しゃせ\nぇ……しそうなの？　んひっ……！　ひっひいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「い、いいっ……出していいっ！　ひぃはっ、はっ、はんっ！　おほっ！　\nおっ、おっ……おおっ！　おおっ、おっほぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104215" ]},
