		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んっあぁぁぁぁぁぁぁ～～～っ！　ああっ！　あっはっ……！　ひっひぐっ\n！　出てっ……出てるぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「おっおおっ……！　おぉっ、んぉっ……で、出てるっ……！　中に……また\n出てるっスぅ……んっ、んひぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ひぃいぃぃっ！　あっ、あついっ……！　ザーメン熱いぃぃっ！　んっひぃ\nっ！　はっ、あっ、ああっ……あはぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「マンコが、ザーメンで溺れちゃうっ……んっ！　あぁっ……どんどんっ、\n奥まで流れ込んできてるぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ひっ、はひっ……はぁあっ、あふっ！　あっ、あんっ……すご、ひぃ……\nあひっ……まだ、中でドクドクいってるぅ……んぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「はーっ……はぁ、はぁ……ヤバぁ……中に出されるの、堪んない……クセに\nなりそう……んっ……はぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「お、おまえも……気持ちよかった……？　うん……あーしも、よかった……\nてか、セックスって……マジヤバくない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00022801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「思ってたより、全然すごかったんだけど……え？　ああ、おまえのチンポが\n予想外によかったって意味で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「うっ……まー、雑魚チンポだと思ってたけど……すごかった、てか……ぶっ\nちゃけ、めっちゃよかったし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「てことでー、これからもいっぱいハメまくってよ。いいだろ～？　な？　\nお前のチンポなら、いつでも大歓迎してやるからさー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「んあっ、あぁぁっ！！　抜けっ、抜けるっ……！　そんな激しく動いたら、\nチンポ抜けちゃうって……！　ひぃぃぃぃぃいぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_0104401" ]},
