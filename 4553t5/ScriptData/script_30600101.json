{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0004" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "060_0103101" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「あの……灯りを消して頂けませんでしょうか……？　どうして、って……分\nからない訳でもあるまいに。隊長、意地悪ですね……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00006001_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103102" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「確かに、真っ暗にすると何も見えないので……色々不都合がありますね。\n……納得の理由過ぎてぐうの音もでません。……ぐぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103103" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「しかし私は見えない方が嬉しい。……何故って、分からないのですか？　で\nは分からないままでいいです。まったく……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103104" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「それにしても隊長が気持ちよくなることがパワーアップに繋がるとは……物\n事には犠牲がつきものです」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006001_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103105" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「……え？　柔らかくて気持ちいい？　ほう、そうか。それは……良かった、\nです。あの、もっと気持ちよくするには……どうすればいいんです？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103106" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「なるほど、こんな風に乳房を上下させて……コレを……。んっしょ……んっ\nしょ……どうですか？　ちゃんと、気持ちよくなってます……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103107" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「んぅぅ……なんか、変な臭い、します。私の汗かな？　クンクン……違う、\nこれ……隊長の……あ、あぁ……コレはこんな臭いが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103108" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「ん……乳房の谷間が、熱い……。これ、なんか……すっごくエッチな臭いで\n……頭が、クラクラしてきました。ふぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006001_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103109" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「はぁぁ……隊長……私の胸がドキドキしてるの……その……この、えっと…\n…ペニス、に……感じていたり、するのです……か？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103110" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「ああぁ、最初の時よりも……ペニスに血管がいっぱい浮き出てる感じ……し\nます。最初よりも……あれです。怖いオチンチンになっている」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103111" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「……怖い。その形、怖いから……私、ナデナデしてあげますからご機嫌治し\nて下さい。その、舌で……ナデナデって……しますから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103112" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「じゅろぉぉぉ……れろれろぉぉぉ……ちゅぅぅう……じゅぽっじゅぽっ……\nはぁ、れろれろっ……ちゅぅぅ……はぁ、ペニス、熱くて硬い……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103113" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「ペロペロペロ……じゅるるぅ。あぁ、ペニスの先に……舌で撫でると透明な\nお汁が……じゅるぅ……さっきよりも出てきて、あ、零れる！　じゅるるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103114" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「んっじゅるぅぅううぅぅ……ちゅっぱちゅぱぁ……れろれろれろぉ……はぁ\n、ぺろぺろぺろぉぉ……じゅぷぅぅ……じゅぼじゅぼぉ、はぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103115" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「れろれろれろぉ……はぁ……ううぅ、エッチな液が……後から後から出てき\nて……変です。この味……嫌いじゃなくなってきてる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103116" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「わ、私……いやらしくなってしまってるんでしょうか？　コレの臭いも味も\n……じゅるるぅ……好き、かも……。そんな、恥ずかしい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103117" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「好きじゃ、ない……です。好きな、訳……じゅっぽじゅっぽじゅっぽ……れ\nろれろれろぉぉ……ちゅぅううぅ……ちゅばちゅばぁ……じゅるるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103118" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「あぁぁ……ますます硬く……！　お、落ち着いて……えっと、もっと乳房で\nむぎゅむぎゅすればいい？　それとも、ペロペロする？　ふわぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006001_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103119" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……ペニスから汁が垂れて……乳房に、零れた……！　こ、こ\nんなのどうすれば……あっ、ああぁぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103120" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「胸がいやらしい臭いになってしまう……。あの、どうしてくれるんですか？\n　……で、でもこれって隊長の臭い、なのか。……じゃ、いいのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103121" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「んううぅぅ……じゅるぅ、隊長の臭い……これ、隊長の臭いなのですね。は\nぁぁ……どうしよう、胸がきゅぅぅってなる。……隊長、好きです」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103122" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「じゅるるぅ……れろれろれろぉ……ちゅぱぁぁ……ちゅううぅぅ……はぁん\n……隊長の味、好き好き、大好きです……あはぁ……ちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103123" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「じゅっぽじゅっぽ……好き……隊長。このエッチな臭いで、エッチな味の…\n…ちょっと怖い形のペニスも、好きぃ……じゅるるぅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103124" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「じゅぷぅ、れろぉ……隊長……私の乳房に……あ、触ってしまうのです、か\n？　……んうぅ。嫌ではないですが……れろぉれろぉ……んぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103125" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「あ、駄目です……！　今は隊長が気持ちよくなる時間ですから……私が、私\nが乳房を揉まれて気持ちよくなったら駄目なんです。んぅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103126" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「じゅぽぉぉぉ……じゅぽ、ちゅぅううぅ……あはぁ、隊長……乳房だけでな\nく、んううぅぅ……乳首までぇ……あはぁ、れろれろぉぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103127" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「駄目、です……はぁ、乳首を、こねるのはぁ……はぁ……頭が、ぼぉって…\n…んじゅるぅぅ……ちゅぅちゅぅ……あぁぁ、気持ちぃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006001_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103128" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「ほ、奉仕に……集中、出来ません……れろぉ、はぁ……。隊長、もう許して\n……ちゅぷぅ……れろれろ……はぁ、もぉ……おかしくなるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103129" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「じゅるる、じゅるるぅぅ……触られてる乳首だけじゃなくて、身体の奥が…\n…熱い。変です、ああぁ……助けて下さい、隊長……はぁん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103130" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「む、ムズムズするぅ……こんな、ううぅ……。じゅぽぉぉ……れろれろぉ、\nちゅぅぅ……じゅるるるぅ、んちゅぅ、ちゅぱぁ……れろぉ、ちゅぱぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103131" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「じゅるぅぅ……ちゅぅぅ……れろれろぉ……んぅ、隊長……私の口の中で、\nペニス……んぅぅ……ビクビク震えてます、じゅろろぉぉ……あはぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103132" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「んふぅぅ、ますます……ペニスが大きく、んうぅぅ……はぁ、じゅっぽじゅ\nっぽじゅっぽ……射精……する？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103133" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「んぐぅぅううぅ……はぁぁ、いいです……よぉ？　精液、私の口で……はぁ\n、思い切り出して……下さい、ね……んちゅぅううぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103134" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「ぐっぽぐっぽぐっぽ……じゅるるぅぅ……れろれろれろっ……ちゅぅうぅ…\n…はぁ、ちゅぱぁ……じゅるるっ……じゅろろぉぉ……んんぅ、んぐぐっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103135" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「んぼぼぼぉおおぉぉっ！　んふぅ……で、出たぁ……精液ぃぃ……！　んぶ\nぅううぅう……んごぉぉ、止まらな……ああぁ……んぐっ！　んぐっ」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006001_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103136" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「はぁぁ……す、すっごい味……さっきの、はぁ……透明な汁の……んぅぅ…\n…ひゃ、百倍くらい……濃い……んぐぅ、まだ、口の中に、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103137" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「ん……んぐっ……んぐぅ……ぷはぁ！　はぁ、はぁ……はぁ……全部、飲み\nました。んぅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103138" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「隊長、あの……射精されましたが……私は、隊長を……しっかり気持ち良く\n出来たのでしょうか……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006001_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103139" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「……あぁ、それならば良かった。私は、役目を……果たせた……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "060_0103140" ]},
		{"command":[ "SETNAME", "白瀬隊員" ]},
		{"command":[ "SETTEXT", "「また何かありましたら声をかけて下さい。……眠ってなければ、すぐに参上\nしますので。……それでは隊長、おやすみなさい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}