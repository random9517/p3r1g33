{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "時間帝国での会合から数日。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "メガデスは世を忍ぶ姿、貴子となりＥＤＯの事務員として働いていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「隊長、書類の代筆終わりましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420001" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお、悪いな……そこに置いておいてくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「いえ、構いませんわ。次はなにをしましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420002" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだな、長官のアポイントメントの調整をお願いできるか？　確かいくつ\nか立て続けに来ていたはずだから、時間がかぶらないように頼む」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでもハロウィン当日の警備を頼まれたとかなんとかで面会も多いんだよ\n……おかげでこっちも普段よりも仕事が山積みだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「わかりましたわ。調整できましたら一旦隊長のＰＣに送信いたしますわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420003" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「助かる……いやマジで。こういった雑務をしてくれる人間がいなくてな。貴\n子がいるだけでありがたいぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「いえいえ。それじゃあ、また後で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420004" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう。悪いな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "(ＥＤＯに来たら運よく事務員アルバイト募集があったから、応募して即日採\n用即日勤務でもう数日になるけれど)", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420005" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "(なんなんですのこの忙しさは！！　休む暇もないですわ！！　それにこれで\n隊長の仕事の１割とか……あの人、そのうち過労死するんじゃないかしら)", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420006" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "(でも……おかげで内部のＰＣからシステムとセキリュティは掌握できました\nわ。とりあえず第１段階はクリアしましたわね)", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420007" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "(だというのに……なんでエファナティカと通信が繋がらないんですの！？　\nメッセージを送っても既読にすらならないし！！)", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420008" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "宅配人" ]},
		{"command":[ "SETTEXT", "「ＥＤＯさん、お届けものでーす！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023420001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「あ、はいはい。今行きますわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420009" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "宅配人" ]},
		{"command":[ "SETTEXT", "「代引きですので代金と、受け取りのサインをお願いします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023420002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「はい……確かに。って重っ！！　やたらと大きいですし……な、なんですの\nこれは……？　しかも取扱注意って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420010" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「ええと……届け先は実験室？　そんなものが本部にあるなんて……とりあえ\nず場所を確認してから持っていかなきゃいけませんわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420011" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「あう、電話まで……ていうかなんでこの規模の組織なのに、受付すら雇って\nないんですのＥＤＯは！！　荷物は一旦ここに置いておきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420012" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "(そしてやっぱり既読もついていませんわ……本当にハロウィンの日に来るん\nでしょうね……！！)", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420013" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「はいはい、今出ます、今出ます！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023420014" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「おお……これはこれは、よい！！　よいぞ！！　余の召喚術士としての姿を\n存分に現しておる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「私のもいいな。いつもと違うけど、動きやすいし、身体に馴染む……実によ\nく馴染むっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「でしょうでしょう～？　張り切って作った甲斐がありましたよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023420001" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そういうお主の衣装も似合っておるではないか。何やら部屋にこもっている\nと思えば、こんなものを作っているとはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023420002" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「うふふふふ～。木を隠すなら森の中ってやつですね～。仮装イベント中に仮\n装した私たちが潜りこめば、顔が割れていても露見する可能性が低くなるって\nことですよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023420002" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「うむ、その通りだ。元より完璧な計画だったが、この仮装でさらに十全なも\nのとなった！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023420003" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「この衣装自体もすっげーしっくりくるしな！！　なんか、いつもとは違う技\nとか出せそうだぜ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023420002" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「えへへへへ、そんなに褒めても笑顔しか出ませんよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023420003" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「謙遜することはない。余もこの衣装を気に入っておる。セレーナの言うとお\nり、普段とは違う力がわいてくるようじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023420004" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「この状況ならば、万が一、億が一にも失敗はないじゃろう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023420005" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ハロウィンの日が楽しみじゃのう！！　浮かれている奴らを、地の底にたた\nき落としてくれる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023420006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふはは、はははははははっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023420007" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}