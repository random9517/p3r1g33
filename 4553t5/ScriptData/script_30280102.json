		{"command":[ "PLAYVOICE", "v2_028_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「もっと精子出してっ！　全部出してぇ！　溜まってるの全部頂戴！　あたし\nに、容赦なく注ぎ込んでえぇぇぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
