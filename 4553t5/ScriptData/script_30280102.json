		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「くあああぁ！？　ま、また熱いの膣内に出て……はああぁ！　いっぱい、ど\nぴゅどぴゅ出されてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
