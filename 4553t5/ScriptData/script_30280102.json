		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「精子の感覚でイッちゃうっ！　こんなのおかしいのに……あっ、ふぎゅっ、\nはああぁ！　オマンコ感じちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ！　はふっ、あっ、はああぁ！　ね、ねえ！　もっとかけてっ\n！　あたしのこと、精子で染め上げてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あたしはあんたのモノだって……オマンコだけじゃなくて、身体にも刻み込\nんで……！　あうっ、ああっ、はああぁぁぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ、んくっ……イキすぎちゃったせいか、脚にチカラが入らな\nいわ……」", "NORMAL" ]},
