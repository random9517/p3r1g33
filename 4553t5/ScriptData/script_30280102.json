		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「これ、絶対に妊娠してるっ！　はじめてのセックスで、赤ちゃん孕んでるか\nらぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「やっ、ああっ！　ダメっ！　ダメえええぇ！　嬉しくて、またイッちゃうっ\n！　オマンコイクうぅぅぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
