		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふふっ……あたしのために、こんなに出してくれたのね……すっごく嬉しい\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「これ、絶対妊娠してるけど……ちゃんと責任取ってくれるのよね？」", "NORMAL" ]},
