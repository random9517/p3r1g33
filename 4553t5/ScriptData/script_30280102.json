		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「それに、お尻から精子の濃いニオイもしてきて……はああぁ……嗅いでると\n、脚だけじゃなくて、腕のチカラも抜けちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はじめてなのに……こんなエッチな身体にされちゃったら……もう、あんた\nのことしか考えられなくなっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ねえ……もっとシて……？　オマンコでも、お尻でも……なんだったら、口\nでもいいから……」", "NORMAL" ]},
