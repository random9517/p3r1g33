{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「くたばれ、変態っ！　桃文字斬りぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふん……弱いくせに、よく『処女のクセに生意気だ』なんてセリフが吐ける\nわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「そもそも、あたしは処女じゃないわ。とっくの昔に、大人のオンナになって\nるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あたしの処女を奪った相手は誰かって？　それをあんたに教える義理なんて\nないわよ！　死ねっ！　桃文字斬りぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「それにしても、処女を奪った相手、か……ふふっ。あいつ、元気にしてるか\nしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ほ、本当にこの体勢でするの……？　こんな……お、お尻の穴まで丸見えな\n恰好で……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002801_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あんたのオチンチン……すごく大きくなってるのね……あたしのオマンコを\n見て、興奮しちゃったの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「すごく綺麗で、いやらしいオマンコって……！　そ、そんなこといちいち言\nわなくていいからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ、ああんっ！　そうやってオマンコにオチンチン擦り付けて、誤魔化し\nてもムダなんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あふっ……！　あっ、あっ……！　そんなに動かされたら……お、オマンコ\n感じるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ああっ！　くっ、あっ、はああぁん！　え、エッチな汁が溢れてきちゃうか\nらぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「やっ……あっ！　ぐちゃぐちゃに濡れてきちゃってるっ……！　あたしのオ\nマンコ、オチンチン欲しがってるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ね、ねえ……早く挿れて……！　あたし、準備も覚悟も……出来てるから…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　オマンコの入り口に、オチンチンの先端が当たってるの感\nじるっ……！　あたし、本当に大人になるのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「うん……そのまま一気に……！　奥まで突き入れて……！　あたしの処女、\n貰って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「っああああぁ……！？　きっ、きたぁ……！　太くてカタいオチンチン、奥\nまで届いてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はああぁ、ああっ……！　オマンコがいっぱい押し広げられて……はああっ\n……！　お腹の奥、変な感じがするっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「え？　ああ、うん……思ってたより痛くないから、心配しなくていいわ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「でも、オチンチン挿れられたのは本当にはじめてだから……動くなら、ゆっ\nくり動いてくれない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ……あっ……！　そ、そう……そんな感じで、ゆっくり腰を引いて……\nあっ、あっ！　オマンコ、めくれてくっ……はあああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ、あぐっ……！　ふっ、あはああぁ……！　気持ちいいっ……！　オチ\nンチン出し入れされるの、すごく感じるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「自分の指でオマンコを弄るのとは……全然違うっ……！　お腹の中、気持ち\nいいので満たされてっ……あっ、はああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はっ、あああっ……！　あぐっ、うっ、んくっ……！　あっ、あっ！　その\nＧスポットのあたり、気持ちいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「そこ……感じるから、もっといっぱいオチンチンで擦って……！　突き上げ\nながら、叩くみたいに……！　あっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ぐっ、んっ、んんっ！　こんな……動物みたいな恰好で、はじめてのセック\nスしてるのに……オマンコから、エッチな汁が止まらない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「これじゃ、あたし……変態って思われちゃう……！　エッチなこと大好きな\n、いやらしい子って……あっ、あっ！　んふうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「エッチで淫乱なあたしも可愛い……？　かっ、かっ……！　可愛いだなんて\n……！　やっ、やめてよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「それに、あたしより可愛い子なんてたくさんいるし……！　はじめてオチン\nチン挿れられて、こんなに悦ぶ子なんて……くううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あたしだから、セックスしたいし……エッチな声も、姿も見たいの……？　\nも、もう……！　そんなこと言って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「でも……ほんとに？　あたし、ほんとに可愛い……？　エッチな姿、もっと\n見たい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あああっ！　オチンチンを突いて誤魔化さないでっ！　ちゃ、ちゃんと口で\n返事してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あはあぁ……あっ、はああ……！　も、もう！　バカぁ！　そんなに可愛い\nって連呼しながら、奥をトントンしないでっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「そんなこと言われ続けたら……オマンコも心も満たされて……嬉しくて、イ\nッ、イッちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　あんたもイキそうなの……！？　いいよ……出して……！　\nあたしの膣内に出して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はじめてのセックスで、妊娠させてっ……！　オマンコの奥に出して……赤\nちゃん、孕ませてっ……！　あっ、あっ！　ふあああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ひああぁ！？　あっ、んあっ！　ふあああぁ！？　でっ、出てるぅ！　精子\n、いっぱい膣内に出されてるうううぅ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「いっぱい、ドプドプ入ってくるっ……！　お腹の奥まで、熱いので満たされ\nて……んくうううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んふっ……はああぁ、あっ、あああっ……！　し、幸せっ……！　これが膣\n内出しされる快感なのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「オチンチンの奥に残ってる精子も、全部出してっ……！　一滴残らず、あた\nしに注ぎ込んでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　ダメっ……！　幸せすぎて、またイクッ……！　あっ、ん\nんっ！　イクッ！　イクぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ああぁん……オマンコから垂れてくるぐらい、たくさん出してくれたのね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「子宮があんたの精子でいっぱいになって……ふふっ。ちょっと苦しいかも…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「でも、イヤな苦しさじゃないわ……なんか、こう……全身が満たされるよう\nな、温かい感じがしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ねえ……もっと精子出せたり、する……？　その……出せるなら、もう一回\nシて欲しいなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……！　もう準備万端って感じだね……うん、いいよ……また好\nきに動いて……いっぱい、オマンコ感じさせてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んはあぁ！　またオチンチンが、オマンコの膣内をいっぱい擦って……！　\nはぁ、あっ、ふぐぅ……！　んんっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あ、あたしも動くから……！　タイミングを合わせて、腰を動かしてっ……\n！　奥、トントンしてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっあっ！　んひっ、はあああぁん！　自分で動くと、もっとオチンチン感\nじるっ！　カリの太いところが、オマンコ抉ってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あたしのお尻から、パンパンってエッチな音が鳴ってるし……お、オマンコ\nからも汁がかき回される音がして……！　あっ、あっ、やああぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「こんなの、エッチすぎるよぉ！　あたしの身体、本当にいやらしくなってる\nっ！　エッチ大好きな身体になってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あひいっ！？　あっ、やっ……！　いきなり子宮を突き上げないでよっ！　\nそんなことされたら、お、お腹が……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「子宮がきゅんってして、もっと突いて欲しくなっちゃうっ！　ズポズポして\n、いっぱいエッチなこと教えて欲しくなっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ひぐっ！？　あっ、あっ！　ひやあぁん！　はあ、あふっ！　あひっ、んん\nっ！　あっ、くふっ……！　んふううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「子宮の入り口、オチンチンの先端でトントンされると、頭がおかしくなっち\nゃうっ！　感じすぎて、バカになっちゃうからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「勝手に腰が動いちゃう……！　オチンチンが潰れるくらい、ぎゅううぅって\n締めつけちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「オマンコが締まれば締まるほど、オチンチンのカタチがわかるぅ！　あたし\nのオマンコ、もうオチンチンのカタチ憶えちゃってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　やああぁ！　そんなにオチンチンビクビクさせてっ……！　\nイッ、イキそうなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00002801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はっ、あんんっ！　あひっ、ふぐっ、んんん～～～……！　あ、あたしもイ\nキそうだから……いっ、一緒にイッて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
