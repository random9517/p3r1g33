		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「来てっ！　来てえっ！　一緒に、イッて……！　あっ、あっ！　イクッ！　\nイクッ！　イクううううんっ！！」", "NORMAL" ]},
