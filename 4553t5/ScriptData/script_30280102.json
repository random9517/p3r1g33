		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あああっ！　イッ、イッてる最中にオチンチン抜くなんて……！　なっ、な\nに考えて……きゃあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「熱い精子、いっぱい身体にかけられてるっ！　やっ、ああっ！　ぶっかけら\nれてるのに、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
