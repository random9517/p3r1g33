		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「んっ、嬉しい……あたし、いい奥さんになるから……これからもいっぱい愛\nしてね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「あっ、勿論……あたしだけじゃなくて、産まれて来る赤ちゃんも、ちゃんと\n愛してあげてね」", "NORMAL" ]},
