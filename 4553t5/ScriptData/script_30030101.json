		{"command":[ "PLAYVOICE", "003_0103302" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぷあっ！　口の中に、精液が、入って……んぶふぅっ、んぶぅっ、んんぅ\nぅ～～～～っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103303" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぐぅぅっ、出しすぎだよっ、もう口の中に、入らない……んぶうっ！！　\nザーメンで、溺れちまうよっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103304" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅぅっ……！　くっ、んぐっ、ぐっ……ごくっ、んぐふっ、ぐぅぅぅっ…\n…ごくっ……ごくっ……ごくっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103305" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぷあっ、このあたしに、精液を飲ませるなんて……んぶぅっ、まだ出るのか\nいっ……多すぎるっ、んぶぶぅっ！　ん、ぐっ、ごくっ、ごくっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103306" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ、ぷあっ、はぁっ、はぁっ、くっ、口の中のあちこちにチ〇ポの味がこび\nりついて、げふぅっ、くぅっ、身体の中まで精液臭くなっちまったよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103307" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「命令されてチ〇ポ奉仕をさせられた挙げ句に、ふぅ、ふぅぅっ、無理やり精\n液を飲まされるだなんて、こんな屈辱は生まれて初めてだよっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103308" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なのに、くぅぅっ、どうしてこんなに身体が熱くなるんだい……！　はぁ、\nはぁ、あんたみたいなゲス男に、あたしの女の部分が疼くなんて……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103309" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くっ、調子に乗るんじゃないよ……！　このあたしが、あんたみたいな雑魚\nのチ〇ポを欲しがるわけがないんだよ……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103310" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「覚えておくんだね……！　次ヤル時は、あんたのチ〇ポを搾り取って、泣き\nながら許しを請わせてやるからねっ……！　覚悟しておきな！」", "NORMAL" ]},
