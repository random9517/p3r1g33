		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぁああああっ！？　あっ、あぁっ！　また、こんなに……！？　んあぁっ\n、あぁっ、精液が、ふりかかって……！」", "NORMAL" ]},
