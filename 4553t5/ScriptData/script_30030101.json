		{"command":[ "PLAYVOICE", "003_0103402" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、あっ、あたしの顔や、おっぱいに、ビチャビチャと貼りつい\nて……くぁっ、またっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103403" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポがぶるんぶるん震えながら、んぁぁっ、割れ目からびゅうびゅうとザ\nーメンを吐き出してくるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103404" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっ、あぁっ……熱くて、ドロドロで……ひどいニオイの、イヤ\nらしい汁が……ま、まだ出るのかいっ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103405" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅぅ……まさか、こんなに出すとはね……顔もおっぱいも、あんたの精液\nでベチャベチャになっちまったよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103406" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「二回目だってのに、どうしてこんなに濃くって、量も多いんだい……！？　\nこんなにかけられたら、本当に臭いがとれなくなっちまうじゃないか……」", "NORMAL" ]},
