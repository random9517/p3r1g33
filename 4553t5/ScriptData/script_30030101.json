{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "003_0103101" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「このあたしを呼びつけるなんて、あんたもいつの間にか偉くなったもんだね\nぇ？　えぇ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103102" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それでいったい、何の用事だって言うんだい？　これでもし、たいした話じ\nゃなかったら……ただじゃおかないよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103103" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ、それとも、それが目的かい？　こんなおあつらえ向きの部屋に呼び出\nして……このあたしに躾けて欲しかったってわけかい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103104" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それとも、まさか……このあたしの身体を好きにしようなんて、思ってない\nだろうねぇ？　物欲しそうな目であたしのおっぱいばかり見てるじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103105" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「イヤらしいことがシたくてしょうがないって顔だ。あたしに筆下ろしでもし\nてほしかったのかい？　……クズ男が調子に乗るじゃないよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103106" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく……女王陛下があんたに任せるとおっしゃたから、仕方なく遊んで\nやってるんだ……そこのところを勘違いしないことだね！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103107" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「でなかったら、あんたみたいなヘタレで情けない男を誰が相手にするって言\nうんだい？　身の程を知りな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103108" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……なんだって？　今、なんて言った？　……ビビってるだって？　このあ\nたしが？　あんたみたいな雑魚を相手に？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103109" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「へぇ……たいした度胸じゃないか。このあたしに向かって、そんな口を利く\nなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103110" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いいさ、そんなに言うなら、ちょっと遊んでやろうじゃないか。童貞小僧は\n一体、あたしにどんなことをさせたかったんだい……言ってみな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103111" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……ほら、これでどうだい？　あんたはあたしにこうして欲しかったん\nだろう？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103112" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「みっともなくチ〇ポをおっ立てて……ん……このあたしに、おっぱいで奉仕\nをさせようと思ってただなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103113" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく、ナマイキな童貞坊やだよ……あたしにこんなことをさせた男なん\nて、そうはいないよ？　光栄に思うんだね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103114" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほら、ほら……どうだい？　プリプリのおっぱいに挟まれて、オチ〇ポの根\n本から先端まで擦られる気分は？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103115" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ、情けない顔をして、まさかちょっとおっぱいで擦られただけで、ぴゅ\nっぴゅと漏らしちまうんじゃないだろうねぇ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103116" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「モノだけは無駄に立派なくせして、みっともない。ほらほら、三こすり半で\nイっちまうのかい？　使い物にならない早漏クズチ〇ポだねぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103117" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふんっ、なんだいその顔は？　悔しいのかい？　だったらちょっとは根性を\n見せてみな。こんなのはまだまだ、序の口だよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103118" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まぁ、あたしのテクニックにかかれば、男なんてどいつここいつも、あっけ\nなくイっちまうんだけどねぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103119" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こうやってチ〇ポをおっぱいで挟みながら、両側からた～っぷりと擦ってや\nれば、ほら、みんなそうやってマヌケ面をさらすのさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103120" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「その中でもあんたはダントツで雑魚だけどねぇ……もうそろそろいいだろう\n？　ほら、さっさとイっちまいな。あたしも暇じゃないんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103121" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……なんだい、まだ粘る気かい？　しょうがないねぇ。それならもう少しだ\nけ、サービスしてあげようか……んっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103122" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「れりゅれろれろっ……どうだい、おっぱいで竿をシゴかれながら、れりゅり\nゅ、ガチガチに固くなった亀頭をたっぷりと舐め回されるのは……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103123" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「敏感な雁首に舌を絡めて、れろぉっ、れろぉっ、裏筋は舌で包みこみながら\n舐めて、れりゅれりゅりゅっ、鈴口も舌先で、れるれる、ほじくってやるよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103124" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、先っぽからイヤらしい汁が出てきたねぇ、ぴちゃ、ちゅるるっ、気持\nちいい、気持ちいいって、チ〇ポが泣いてるじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103125" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ほぉら、これはどうだい？　先走りの汁を亀頭に塗りたくって、ぴちゃ、れ\nろ、れろぉっ、ヌルヌルにしながら舐め回されて、気持ちいいかい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103126" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく……立場を利用して、れろれろれろぉっ、女にチ〇ポをシゴかせて\n、ナメさせようなんて、れりゅりゅりゅ、あんたは見下げたゲス野郎だよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103127" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はんっ、鈴口がパクパク、イヤらしくおねだりしてるじゃないか、れりゅれ\nりゅう～っ、もしかして、罵倒されてイっちまいそうなのかい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103128" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなに亀頭を固くして、れろっ、れろれろぉっ、切なげにチ〇ポを震わせ\nるなんて、れるぅっ～、みっともないったらありゃしないよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103129" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「もういいだろ？　ほら、さっさと出しちまいな、れりゅりゅりゅっ、腰を突\nき出して、おっぱいにチ〇ポを擦り付けながら、イっちまいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103130" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポをおっぱいで擦られて、ずちゅるるるるっ、亀頭を舐め回されて、精\n液を漏らしちまいなよ、ほら、イきな、イけ、イけ……イけっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103131" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ぷああっ！？　なんだい、こんなに出して……！　んああっ、あっ、あっ…\n…くっ、どれだけ出すんだい……！？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103132" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポの先っぽから、びゅうびゅうと、くぁっ、また……！　小汚いザーメ\nンを、こんなに出して……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103133" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くあぁっ、熱いっ……！　ドロドロに濃くて、臭い精液が、あくぅっ、あた\nしの身体に、ふりかかって……くっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103134" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁっ！？　くぁっ、まだ出るのかい、しかたないねぇ……ほらっ、ほらっ\n！　おっぱいでシゴいててやるから、全部吐き出しちまいなっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_01_04" ]},		
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103135" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「射精中のチ〇ポをおっぱいでシゴかれて、くぁっ、金玉が空っぽになるまで\n、だらしなく精液を垂れ流すんだよっ！　そら、そら……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103136" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふぅぅ……ちっ、まったく、なんて量だい……ずいぶんと遠慮なく出してく\nれたじゃないか、えぇ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103137" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「こんなにザーメンを撒き散らして……おっぱいから、顔から、あんたの精液\nでベタベタじゃないか……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103138" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしの自慢のお肌に、ネバネバした汚らしい精液が、べったりとはりつい\nちまってるよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103139" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「お肌に染み付いてとれなくなったらどうしてくれるんだい……それに、くぅ\nぅっ、なんて臭いだい、クサいったらありゃしないよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103140" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたの精液の臭いが、ぷんぷんと漂ってきて……っ、はぁ、はぁ……あん\nまり臭いから、頭がクラクラしてきちまったじゃないか……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103201" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おまけに、チ〇ポはまだ固いまんまだなんて……もしかして、まだ出し足り\nないって言うのかい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103202" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「せっそうのないオチ〇ポだよ、まったく……こんなところばっかり男らしく\nって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103203" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んあぁっ！？　なんだい、ちょっと……！　勝手にチ〇ポを動かすんじゃな\nいよ！　みっともなくおっぱいに擦りつけて……くぅんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103204" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「わかったよ、もう一回してやるから、少し落ち着きな！　ったく、これだか\nら童貞小僧はみっともないんだよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103205" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ほら、どうだい……ふぅぅっ、こうやってまた、オチ〇ポをおっぱい\nで挟んで、んふぅっ……擦ってほしかったんだろう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103206" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くふぅっ、あんたの汚らしい精液でおっぱいとチ〇ポの間がヌルヌルと擦れ\nて、んふぁっ、チ〇ポの形がはっきりとわかっちまうよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103207" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さっきよりもガチガチに固くなって、んくぅっ、亀頭のエラがこんなにせり\n出して、ふぁっ、血管まで浮き上がらせて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103208" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポが擦れる度に、ザーメンがニチャニチャと鳴って、んくぁっ、青臭く\nて、生臭くて、んふぅぅっ、オス臭いニオイが、ぷんぷんしてくる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103209" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「くふぅぅ、まるで、精液まみれのあんたのチ〇ポに、んふぁぁっ、おっぱい\nの間が、マ〇コみたいに犯されてる気分だよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103210" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、まったく、んふぅぅっ、臭くって、汚らしくって、そのくせナ\nリばっかり立派なもんだから、くふぅぅっ、始末に悪いチ〇ポだね……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103211" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……なんだって？　あんたこのあたしに、臭くて汚い精液まみれのチ〇ポを\nナメろって言うのかいっ……！　んくっ……調子に乗るんじゃないよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103212" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたみたいなゲス男に命令されて、はぁ、はぁ、このあたしが精液臭いチ\n〇ポをナメさせられるだなんて……そんなこと……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103213" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふぅぅっ……いいかい、今回だけだからね……！　あんまり図に乗る\nんじゃないよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103214" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ……れるっ、れろ、れろぉっ、ちゅるっ、じゅるるっ、くぅっ、ネバつ\nいた精液が、舌に絡みついて、ふぅ、ふぅっ、れろれろ、れろぉっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000301_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103215" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんてひどい味なんだい、れる、れろぉっ、くぅっ、生臭くて、青臭いニオ\nイが鼻に抜けて、んはぁぁぁっ、頭がクラクラしちまう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103216" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「このエファナティカ様が、こんなクズに命令されて、れる、れろぉっ、れろ\nぉっ、チ〇ポにこびりついた、ザーメン掃除をさせられるだなんて……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103217" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、こんなこと、屈辱以外の何物でもないのに、れりゅれりゅ、じ\nゅるるっ、どうして、こんなにも身体が熱くなるんだい……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103218" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んふぁぁっ……！　チ〇ポの先っぽから、精液臭い先走り汁があふれてきて\n、ちゅうっ、じゅるるっ、頭がおかしくなっちまいそうだよ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103219" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「早く、イけ、イくんだよ……！　おっぱいでヌルヌル、チ〇ポをシゴかれな\nがら、亀頭を舐め回されて、れりゅりゅりゅっ、イっちまいな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103220" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ガチガチに勃起したチ〇ポで、れるれるぅっ、おっぱいマ〇コを犯して、ん\nぢゅううっ、チ〇ポ掃除されながら、イけ、イけ……くぁぁ、イけ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "003_0103301" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んぶううぅぅぅっ！？　んぶっ、ぷあっ、ちょっと、まっ……んぶっ、んぶ\nぅううううっ！！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
