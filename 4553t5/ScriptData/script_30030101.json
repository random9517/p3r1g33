		{"command":[ "PLAYVOICE", "003_0103409" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんてチ〇ポなんだい、まったく……ごくっ……しょうがないね、もう少し\nだけつきあってやるよ……どうせまた、命令する気なんだろう？」", "NORMAL" ]},
