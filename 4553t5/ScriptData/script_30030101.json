		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103407" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「しかも、なんだいそれは……はぁ、あんたのチ〇ポはどうして相変わらず、\nガチガチに固いままなんだい……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "003_0103408" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「玉の方もずっしりと重くって……ふぅぅ、まだまだ、たっぷりと精液がつま\nっていそうじゃないかい……？」", "NORMAL" ]},
