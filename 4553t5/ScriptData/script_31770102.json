		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あんっ、隊長さんも……私のおっぱいを触りたいんですか？　もう……仕方\nありませんね……程々でお願いしますわ……んっ、ふっ……」", "NORMAL" ]},
