		{"command":[ "PLAYVOICE", "v2_177_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、んふぅぅ……射精……落ち着きましたね。溢れない\nように、しっかりオマンコに力を入れませんと……」", "NORMAL" ]},
