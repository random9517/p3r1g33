		{"command":[ "SETIMAGE", "0", "still_00017701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「うんっ、ふぐっ、くぅぅんっ、あぁっ、オチンポがいいっ、硬いのが弱い所\nに当たってぇ……は、ひっ！　腰が抜けちゃいますぅっ！」", "NORMAL" ]},
