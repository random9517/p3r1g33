		{"command":[ "SETIMAGE", "0", "still_00017701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「もう、私のオマンコは……すっかり思い出してしまったんです……いえ……\nそれよりも、もっと違う何かに目覚めさせられたんです……」", "NORMAL" ]},
