		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あ……んんっ……もう休憩はよろしいですか？　はい……私も、もう続きを\nしたくて……ずっと疼いておりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104201" ]},
