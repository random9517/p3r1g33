		{"command":[ "SETIMAGE", "0", "still_00017701_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ふふ……んっ、あぁ、身体は起こさずに、楽になさっていて下さい。まだお\n疲れではないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104139" ]},
