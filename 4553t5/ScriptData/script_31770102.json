		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁっ、こんなのすぐにイッちゃいますっ……ダメ……ちゃんと隊長さんを\nイカせてからじゃないとっ……どうっ、ですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「もうすぐっ、あぁっ、はいっ、もっと腰を振って……ぐちゅぐちゅってっ、\nあっ、オチンポっ……もうすぐですねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104133" ]},
		{"command":[ "WAITINPUT" ]},

