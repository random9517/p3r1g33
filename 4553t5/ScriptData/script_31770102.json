		{"command":[ "SETIMAGE", "0", "still_00017701_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ふっ、んんっ、あぁっ、ぐちゅぐちゅっ……精液の混ざる音っ……恥ずかし\nいけど、もっとさせてしまいますねぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んふっ、はふっ、うんっ、あっ、あぁっ、いいっ、オチンポっ……とっても\nいいですっ、二回目からが……本番ですよねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「一度出して……次が出るまでの間……長く楽しめますし……硬さも、脈動も\n……直接感じてっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……やっぱり生オチンポが最高ですっ……道具なんかじゃ絶対に味わえ\nない、本物のチンポッ、あぁっ、チンポっ……これぇっ！」", "NORMAL" ]},
