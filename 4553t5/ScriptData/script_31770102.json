		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁっ、今度も中にっ……もう一発っ……中出しっ、膣内射精っ……お願い\nしますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「隊長さんの、強い子種でっ……ふしだらな私のオマンコを征服なさってっ、\n全部っ……全部出してぇっ！」", "NORMAL" ]},
