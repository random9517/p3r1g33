		{"command":[ "SETTEXT", "「あっ、子宮が……開いていくっ……オチンポとキスしてっ……くうぅぅぅん\nっ！　これぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……こつんって当たると……腰が抜けそうになっちゃいますっ……も、\nもう、我慢……出来なくっ……隊長さんもっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はいっ、大丈夫ですっ……んんっ、続けて下さいっ……このまま一気にっ、\n二人で……一緒に限界までっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、オマンコしますからっ、オチンポッ……感じてっ……出して……\n下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104220" ]},
