		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「んはぁぁ……太い……んくぅ、オマンコのヒダが……全部伸ばされてるよう\nな感じが……しますぅ……」", "NORMAL" ]},
