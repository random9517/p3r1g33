		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「もう私の準備は万全になっています……いつでも、隊長さんをお迎えできる\nように……あぁ……中も、じゅくって濡れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ですが、まだ……隊長さんの方が万全ではないのですね……分かりました。\n拙いですが、その気になって頂けるよう精一杯ご奉仕致します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ぺろ……ちゅぷ……んっ、男の方でも……おっぱい……乳首は、立派な性感\n帯になるんですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「もちろん隊長さんはご存知だと思いますが……んちゅぷっ、でも、こうして\n……舐められながら……ぎゅっと……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「いかがですか？　舐められながら……反対側の乳首も転がされるご気分は…\n…ふふ、小さくてもちゃんと硬くなっていきますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……隊長さんの乳首……思った以上に敏感みたいです。んちゅぷっ、\nちゅぱ……れろ……んっ、れろぉぉぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ふふ……舌がくすぐったいですか？　でも、このムズムズした感触……慣れ\nてくれば、きっと喜んで頂けると思います……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んっ、あら……どんどん大きくなって来てますわ……オチンポ、\nやっぱり逞しい……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「もっとですね？　はい、お任せ下さい……れろ、ぴちゃ……乳首から胸周り\n……首筋……んちゅぷ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あん、いけませんよ……じっとしてて下さい。全身……その気になって頂く\n為にしていますから……は……んっ、あっ、お触りは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁん……隊長さん……悪戯がお好きですのね……そんな風に、んっく……\n弱い所を弄られたら……あん、は、ぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……本当に……我慢出来なくなりますぅ……あぁ……切ないです…\n…こんなの、続けられたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……ダメ……もうダメです……私……ご奉仕だけじゃ……もう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あぁ……お願いします、隊長さん……私……もう待ちきれ\nません……私のオマンコ……もう限界なんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「隊長さんに開発されて、発情しきったオマンコは……一刻も早く隊長さんの\nオチンポを咥え込みたくて堪らないんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「どうか……お慈悲を、ご許可を下さい……このカチカチのオチンポを……オ\nマンコにハメて頂くことを……お許し願います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「ほら……この淫らに潤みきった……恥ずかしいオマンコぉ……こ、ここにぃ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あぁ……ありがとうございますっ……ではっ、早速失礼致しますっ……はっ\n、あぁっ、んっ、んくぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……ずっと、あぁ……これを待っていました……やっぱり太いです…\n…んくぅ……広がっていくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00017701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
		{"command":[ "SETTEXT", "「あ……んんっ、ずっと忘れていて……もう、私には必要ないと思っていたの\nに……やっぱりダメです……こんなオチンポ入れてしまったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_177_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミセス・ウィドウ" ]},
