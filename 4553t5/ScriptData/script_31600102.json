		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ……あぁ……ふっ、んくっ……いきなり……こんな状態で…\n…済まない……んっ、ふっ、くう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「我ながら情けない話だが……また……身体を持て余して……しまってな……\n胸も、ズキズキ疼いて……乳首……はしたなく勃たせてしまっているんだ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「いつもなら……指で摘んで……押し潰して……そういう、オナニーで……何\nとかして来たが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「今日は……もう、それ以上に……こ、ここが……疼いて仕方ないんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そ、そうだ……オ、オマンコ……だ。う……改めて口にすると、恥ずかしい\n……な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だが、もうキミの前で気取っても意味はない……どうか、私の身体の疼きを\n鎮めて……欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あっ……んんっ、チンポ……擦れてる……んふっ、そうだ、そのまま一気に\nオマンコに……入れて、欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んんっ……ま、まだ……？　どういうことだ……何か、理由があるのか……\n？　あっ、んふっ、くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「まだ気取りが残ってる……そんな、つもりは……はっ、うんっ……あっ、入\nり口……なぞられてる……じ、焦らすつもりなのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「も、もっと……しっかりオナニーして……ハメ乞いアピールを……わ、分か\nった……キミが、そうしろと言うなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、ふっ……あぁ……見られながら……乳首……弄るっ……チンポ\nがすぐそこにあるのに……届かないっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、先端が痺れて……オマンコ……じわっと疼いて来てる……あぁ、頼\nむ……どうか、キミのチンポをハメて欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ほら……ここだ……もう、ヌルヌルに濡れてるのが見える筈だ……発情して\n、オスのチンポを咥えたがっているオマンコ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「お願いだから……チンポ、ハメてくれ……そ、そうだ……オマンコして欲し\nい……チンポでっ、オマンコして欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あくっ、んんぅぅぅんっ！　あっ……はぁぁぁぁっ……チンポっ……中にっ\n……来るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……むっ……チンポ太い……のに……あぁ……こんなに簡単に入\nってしまった……んぅ、ゆ、緩く……ないだろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そうか……確かに、ずっと愛液が溢れ出して……止まらないからな……それ\nで、チンポを難なく咥えこんでしまったんだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んくっ……だが、無論簡単に抜けてしまうようにはしない……チンポにも、\n楽しんで貰わないと……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「どうかな……あふっ、オマンコ、締め付けるから……チンポ……遠慮なく、\n突いてくれ……んぁぁっ！　そ、そうだっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、んっ、くっ、ふっ、あっ……あぁっ、一番奥まで……一気に\n届いてしまってる……あぁ、チンポでいっぱいにされている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「くぅぅ……身体の内側から、全体に……痺れる感じが広がっていく……んく\nぁぁ……オマンコ……擦れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あぁっ……カリが、あぁっ……中で引っ掻いてっ……っくぅ…\n…続けて擦られると……は、ひぁっ、か、感じるっ、くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ、はっ……わ、分かった……あっ、乳首も……するっ、あぁ\nっ、ここもっ……尖って……今、触ったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んひぁっ！　あひっ、あっ、あぁっ……声がっ……抑え、切れないっ……ま\nたっ、キミの前でっ……浅ましい姿をっ、晒してしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「もっと……声を聞きたい……それ、はっ……んっ、わ、分かったっ……がっ\n……はっ、うんっ、あっ、あぁっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、どの道……声……出てしまうっ、こんな太いチンポでっ、奥をっ…\n…かき回されてっ……くぅぅっ……子宮を突かれてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ひぁっ、あっ、悦ぶっ……オマンコが悦んでるっ……これが欲しくてっ……\nあぁっ、今のとこっ、も、もう一回っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅんっ……！　あぁっ、それがいいんだっ……くひぃっ、もっと強く\n押し込んでっ……あぁっ、チンポでいっぱいにしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……胸もっ……おっぱいも好きにしてくれていいっ、はんっ、\nあっ、くぁっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「もっと、激しくしていいっ、あぁっ、そうだっ！　あひっ、チンポっ、激し\nいっ！　あぁっ、オマンコっ……ズンズンされてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んはっ、あぉっ、おぉぅんっ！　汁が掻き出されるっ……！　オマンコが恥\nずかしい音をさせてっ、あぉっ、チンポっ、すごいっ、チンポいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、震えてっ……あぁっ、出そうなのかっ？　んくっ、あぁっ、射精\n……しそうなんだなっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁっ、出していいっ、出して欲しいっ！　キミのっ……一番濃いのをっ、\n中にっ……オマンコに射精してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んぁっ、も、もうっ、私もイクッ……！　頼むっ……は、早くぅっ、じゃな\nいとっ、あっ、本当にっ……あっ、んぁぁぁぁぁーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「は……んぁぁぁ……出てっ、来たっ……中に……出てる……どくどく……オ\nマンコ満たしていくのが分かる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁ……まだ出てる……んっ、いっぱいになった感じがあるのに、まだ……\n熱いのが溢れて来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ……はぁぁぁ……こんなイキ方は初めてだ……あっ、チンポ引き抜くの\nはまだ……もう少し待っててくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「この繋がってる感じ……堪能したいんだ……んく……あぁ……は、ふっ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あ……また、自然に指が乳首を撫でていた……ここも、まだ気持ちいいまま\nなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「本当に……鮮烈な体験だった……これは、病みつきになってしまうかもしれ\nないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……中でチンポが、また……膨らんでいるような……私の気の\nせいでは、ない……よな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そ、そうか……私のエロい姿がまた欲望に火を付けてしまったと……そうい\nうことだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「もちろん責任は取る……いや、違う……私がもっとして欲しいんだ……身体\nが、オマンコが……キミのチンポをもっと欲しいと訴えて来ている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「このまま続けて犯して……私のオマンコを……もっとメチャクチャにっ、何\n度もかき回して欲しいっ、あっ、はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はっ、んくっ、んぁっ、あっ、あひぁっ、くぅっ、はぁっ、んぅぅぅんっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あぁっ……中に出された精液がっ……オマンコの中でっ……混ぜられてる…\n…んくっ、はぁっ、んふぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「まぐわいの音……こ、これを聞かされると……それだけで、また……発情が\n深まっていく……チンポに蕩けていくんだ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「なんて下品で……淫猥で……はしたなくて……それを意識するほど……乳首\nがしこって……オマンコが痺れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、あぁっ、チンポいいっ……んくぅっ、ずっとこうしていたい…\n…ぶっすり挿し込まれてる感覚が……たまらないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぁっ、キミは……どうだ？　私のオマンコっ……感じてくれてい\nるかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、あぁっ、もっと感じて欲しいっ、こんなに……くぅんっ、よく\nしてくれる……チンポにっ、ちゃんと気持ちよくなって欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はっ、んくっ、構わない……胸も好きにしてくれていいっ、ビンビンの乳首\nっ……押し潰してっ、転がしてっ……またオマンコかき回してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ……ダメだっ、我慢出来ないっ、またすぐイッてしまうっ、ひっ\n、イクっ……チンポっ、ぉぉっ、チンポでイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「あへぁ……また……続けてイッた……くふぅ……キミと一緒が良かったのに\n……済まない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だが、ちゃんと務めは果たす……キミがまた射精するまで……頑張ってオマ\nンコを締め付けるから……ぅんっ！　そうだ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「続けてして……はぁっ、多分……私もまたイクだろうが、遠慮しないで……\nオマンコっ……何度でも突き回してくれっ……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00016001_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ、あっ、んぁっ、いいっ、太くて硬いっ……逞しいチンポがっ…\n…オマンコいっぱいにしてくれるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_0104217" ]},
