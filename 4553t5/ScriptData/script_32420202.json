{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0184" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……おつかれさま。うん、ここであなたを待ってた。統制局内を通るって聞\nいて……。それで、どうしても会いたくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00024202_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「めずらしい？　……むぅ……わかってるくせに。そうやって焦らすの、ズル\nい……。ねえ、こっちにきて……。誰もいないほう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00024202_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んっ……ここでなら、少しくらい声をあげても大丈夫だから。わかるでしょ\n？　わたしのきもち……逃げないで受け止めて。えいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00024202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「こうっ……。ずっと……こうしたかった。ああ……あなたの身体、あったか\nい。おちつく……。こうやってもっともっとくっついてたいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、ってあなたの息も荒くなってる……。うん。そうだよ。わたし\n、えっちしたい。そのつもりで待ってたし、こうして誘惑してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……あなたは……どう？　興奮してるわたしとえっちしたいって思う？　い\n、いやでもしてもらう……ほら。おっぱい。いくらでも触っていいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「おまんこだってお尻だって好きにしていいし……太ももとか、おなかとか…\n…。っふぅうっ……ふーっ♪　想像するだけで、わたし……わたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「さわって……全部。んッ……そ、そう……。お尻をなでなでして……。伝わ\nる？　わたし……発情してる、ずっとえっちしたくてたまらないの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「おっぱいも、ずっと熱くて……どきどきしてて……。こうやってっ……あっ\n♪　あなたの胸板にこすりつけたい、重ねたいってずっと考えてた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んっ……どうしたらしたく、なるの？　わたし……なんでもするから……お\nねがい。はぁっ、はぁ……こうやってオチンポの上で、腰を揺らして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「刺激して、ムード作って……って、んぁんんっ！？　おっきい……ガチガチ\nに硬くなってるよ。したくなってきた？　わたしはずっとしたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、お股のところが濡れてるの……わかる、よね？　ずっとこうな\nの。ぬるぬるしちゃって……んっ、一人じゃなんにもできない……だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ねえ……しようよ。えっち♪　したい……もう我慢できない。正義のヒロイ\nンだって、お休みの日くらいは自分に正直になってもいいよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ほら……あとちょっとだけ、つぷってここに差し込めばいいんだよ……♪　\nわたしのおまんこ……あなた専用のおまんこを、思いっきり掻き回して？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「一気に……わたしを串刺しにするみたいに、一番深いところまで突いて……\n。はぁ、はぁ……おねがい……おちんちん、ほしい。そう、そのまま……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「はぁっうっ……♪　んぁあああ……！　き、た……一気に奥まで来たああ…\n…っ♪　あなたのおちんちん、スゴい！　すごいよ、大きいぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わ、かる？　わたしの中……全部いっぱいになっちゃった……♪　あぁっ…\n…これ……♪　これしたかったの……動いて、もっとしてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「いいのっ……わたし背は低い、けど……あっ♪　身体はちゃんと大人だから\n……！　はぁっ♪　あなたが大人にしてくれたから……！　っんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「鍛えてるから頑丈だし、うんと激しくしても平気……。だから……だから、\nこのヌルヌルしてるところっ……わたしのえっちなところ突いて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「力まかせに……あっぁっあっ♪　ぐちゅぐちゅってしてっ……はぁんんっ！\n　うん、うん、気持ちいい……！　めちゃくちゃに揺らしてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ぎゅーって、ぎゅーって抱きしめながら……！　ラブラブいちゃいちゃで思\nいっきりするの、えっち……えっちする、おかしくなるくらい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んっ、あああっ……あぁっ……！　あなたの腰の動かし方、すき……！　大\n好き……！　あっ……んんっ、やわらかいところ、かきまぜて……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「大きなおちんちんの形、熱さ、太さ……ぜんぶわたしのおまんこに教えて、\nなじませてから……ひぅんんっ！　そうやって、突くの……かっこいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「はぁっ……あぁあっ……！　すごい、すごいよぉ……！　あっ、ぁっ、んん\n、意識飛んじゃう……！　あっ、こんな強いおちんちん……あっぁっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「かっこいいおちんちんでズプズプされたら、……はぁっ、わたしもお尻、動\nかしちゃう……もじもじしちゃう……あぁっ、いやらしくてごめんね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっ、んんっ、はぅうっ……！　あぁっ……♪　あっ、ぁっ、今\nのっ……今のところこすってっ……！　あぁっ、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「おっぱい♪　おっぱいなすりつけたくなるっ……あなたの身体に押しつけて\n、……あぁっ！　ずりずりずりって乳首刺激したくなっちゃうよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んっ……ふぁあ……♪　二人でリズムを合わせ、て……ぬっちゅぬちゅする\nのすごくイイ……！　はぁっ、わたしが合わせるから、自由に突いてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んっ！？　今のクるぅ……！　あっ……あっぁっ！　いやらしいお汁がお股\nから溢れ出して……はぁっ、床にポタポタ落ちてく……あっ、うううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「えっちに積極的な女の子って……いや？　普段のイメージと違う？　でも、\n……でもっ！　あんっ、これがほんとうのわたし、なの……んっんっんぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「えっちなのがわたし、なのっ……！　わたしの身体、全部知って欲しい……\n！　あなたにだっこしてほしい、抱きしめられたまま犯されたいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あぅっ！　んっ……んんっ！　わたしはえっちなの、えっちが好きなの……\nだから！　しあわ、せ……もっと動かすね、もっと……もっとぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ん、ふ……！？　なに……？　あなたのコレ、わたしの中で……おまんこの\n中でもっと硬くなってる……。やぁあ、あつい……太いよぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ふ、ぁ、あっンンっ……。奥……一番奥をぐちゅぐちゅノックしてる……。\nあっ！？　やっ……少しつよ、い……ピストンつよいぃい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……赤くなった顔……あっ、荒い息、力強いピストンん……！　あなた、出\nしたいの？　わたしの中に……？　いいよ、きて……きてきてぇ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んはぁううっ！？　んぁああっ……！　ああああ……！　じ、自分でも知ら\nない声……出ちゃってる、とめられない……何これ、なにこれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「どぴゅっどぴゅってあなたのお汁……赤ちゃんのお汁注がれてるよお……！\n　あっ！　そんなに！？　んんんっ、も、もう入らない……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「無理、なのに……おまんこの奥、子宮……精子でいっぱいになってる、のに\nぃ……まだ出すの？　あっ！　すごい、すごいすごい……あなたって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「これの天才……だったんだ。……ふぁっ！　あっついの、ドクッ……ドクッ\n、て流れこんでくるよ……。あなたも気持ちいいんだね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「うん、嫌じゃない……うれしい。だから落ち着いて、最後まで注いで……。\nあ……♪　これ、好き……あったかぁい……♪　んぁあ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んふ……っ。たくさん出してくれた……うれしいな。お腹の中、ポカポカし\nてる……満たされて……ちょっと酔ってるかもしれない……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あっ！　ま、まだ抜かないで。このまま……。今おちんちんを抜かれたら、\n精子が溢れちゃう……。それに……ん、は、はずかしいけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたし、明日も任務……お休みだから。まだ、してたいな。ダメ……？　ん\nん……ッ、おまんこ、まだまだ元気だし……精液ももっと入るよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「だから……。ね？　しよ……したいな♪　明日の朝、足がガクガクになって\n腰が痛くなっちゃうくらい……したい。っていうか、もう逃がさない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「おまんこをぎゅぅうう～って締めて……んっ……♪　少し、ずつ……お尻を\n動かして……ゆっくり、ゆっくりおちんちんにお願いするの……。ぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしのこと、犯してくださいって……んんっ♪　ご奉仕したい……。……\nぁ……♪　おちんちん、ピクピクって痙攣した。これって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あなたもこのまましたい……ってことだよね？　えへへっ……嬉しい。うん\n、いいよ……あなたが一番気持ち良くなれるくらいまで、がんばるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「えっち、しよ♪　あぁっ……んぁああっ♪　わたしにご奉仕させてね……♪\n　はあっ♪　あぁッ……！　いいっ、激しいえっち、気持ちいい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　あなたの腰に足を絡めて、あなたの身体、全力で抱きしめ\nながら……するととろけそう……♪　はぁっ、あぁ、すごくいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「おちんちん、どんどん硬くなって……。はぁぁっ♪　角度上がってきた、お\nまんこを貫いてるぅ……っ！　あっ、もうこんなに……！　ありがと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしも本気出してる、から……っ！　あんっ、あんッ……一緒に気持ち良\nくなりたいっ……！　あっ♪　あっ、おんなじ気持ち共有したい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あっ♪　わたしは今こんなに気持ちいいんだよって……！　知らせたい♪　\nはぁっ……あぅうっ♪　頭の中、トロトロになってく……溶けちゃうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　ふぁあっ♪　あぁああ……あぁ……！　あぁあっ……！　\nおまんことろけちゃう……あっ♪　おちんぽすごく気持ちいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ね、え……イッてもいい？　あなたのこれ……おちんちんぎゅううって締め\nつけるから……！　気持ち良くするからイッてもいい？　んっあっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あはぁあっ♪　イクぅ……！　んんん……！　あああっ、イッちゃう……！\n　あぁああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んぁっ……♪　い、今……軽く気を失いかけちゃった……。はぁっ……♪　\nおまんこ、ぎゅーって締まった？　うん……♪　もっと締めつけるね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「はぁっ……あっぁっ♪　んあああっ……あぁ……♪　あなたの体温を感じ、\nながらするのって心地いい……何をしてる時よりしあわせ……♪　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ここっ……一番奥にもう一度、精子注いでね……♪　はぁあっ、あっ……ん\nんぅう……♪　えっちが終わっちゃうのはいやだ、けど……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしの身体で、おまんこであなたのことイかせたい……っ。や、ぁ、わた\nしも……もっといっぱいイク、から……イカせて……！　っん～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「ああっ♪　ふぁああっ……！　ああっ、一番奥……！　おまんこの奥に出し\nて……！　欲しい、欲しいよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　ああああっ……出てるっ……！　出てるぅう……！　んっ……離\nれないで、思いっきり抱きしめて……！　あっ……♪　あっ、きてるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしの赤ちゃんのおへや、に……あなたの精液がどぴゅっ、どぴゅってか\nかってる……。ふぁああ……♪　身体の芯から温められて……あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「こんなのっ、誰だってイカされちゃうに決まってる……！　はぁああっ♪　\nだ、め……♪　わたし、これに弱いの……あっ、あぁ……いい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「これ、中出し……っていうんだよ、ね……♪　いいの？　わたしに二回も中\n出ししちゃって……。赤ちゃんできちゃうよぉ、パパとママになっちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……ふふふっ、あなたがやめたくてもやめてあげない……♪　精液、ぜーん\nぶ絞りつくしちゃう……。はぁあ♪　今、ぎゅうって締まった、でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「うん♪　びゅるって入ってきた……♪　わたしのおまんこの中、駆けあがっ\nてきて……クセになりそう……♪　んんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「はぁぁあ……♪　おなかがタプタプになるまで中出し、してもらっちゃった\n……。わたしたちが統制局の中でこんなことしてるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「誰も知らないんだよね。そう思うと、なんだかゾクゾクしちゃう……。あは\n……♪　このまま、ずーっと繋がってたら、誰かに見つかるかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「そうしたらもう、言い訳なんてできないよね……♪　……って、そんなに心\n配しなくていいよ。冗談だから。でも……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あと少しだけ、こうしてぎゅー、されていたいのは本当……。誰かが来るま\nでは、甘えていてもいい？　ちょっとだけ。ほんの少しの時間だけだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「きてぇ……！　……んっ！？　あ、あれっ……？　おっぱい……！？　おっ\nぱいの方に出したかったの……っ？　んっ、んん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あなたって……！　たまに突拍子もないことして、わたしをいつも驚かせて\n……！　っああああっ……！　おまんこが、せつないよぉ……んあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「だけど……だけど、おっぱいに……身体にびゅるびゅるしてもらうのも、…\n…あっ♪　あったかくて、安心する……いいよ、もっと、もっと出して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00024202_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あなたのだったら浴びても平気……っ。あああ……！　わたしの身体、ぜん\nぶあなたのものにしていいから……あったかいミルクかけて……ぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んんんん……！　んふ……！　ん～～～～っ、んんんん……！　っふはぁあ\nああ……♪　くさい……♪　本当にイカのニオイ、するんだぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「んぅっ……おなかにも……足にもいっぱいかかってる……。えへへ……♪　\nこうやって、精液が目に見えるのも……いいのかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「わたしでこんなに気持ち良くなってくれたんだ、って量でわかるし……。ネ\nバネバだって、おまんこの奥で感じるより、肌につくほうがよくわかる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……ん？　どうしたの？　不思議そうな顔をして……。え……？　わたしが\nいやらしいことを平気で言うようになったからびっくりした……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「……そ、それは……。えっと……あなたと２人だけだから、安心して言った\nだけ……。他の人には言わないし、こんな顔も、裸も見せないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_242_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レン" ]},
		{"command":[ "SETTEXT", "「あなたにだけとくべつなんだから……。信じてくれる？　ふふ、だったら許\nす。わたしのえっちなところは、あなただけのものにしててね……♪」", "NORMAL" ]},
