		{"command":[ "PLAYVOICE", "v2_064_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、ああ……っ！　隊長、隊長、隊長隊長ぉおおっ！　イクッ\n、イク、イクイク……イッくぅうううぅぅぅっ！！」", "NORMAL" ]},
