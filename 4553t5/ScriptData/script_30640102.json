{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長、今度はここで……私のおまんこで、隊長のおちんぽの威力を味わわせ\nて欲しいんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「意外ときれい……って、失礼しちゃいますね。ここは大事な武器ですからケ\nアは念入りに行っているんですー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「だから隊長……おちんぽ、ください……。はぁ、はぁ……。隊長のおちんぽ\n立派だから……はやく……欲しくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おまんこ、もうこんなに……。エッチなお汁がいっぱい……溢れてきちゃっ\nているんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぅ……お尻、おまんこ、じっくり見られているの感じますー……。隊長の\nやらしい視線……はぁ、はぁ、ぞくぞくしちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あんっ、おちんぽそこ……そこぉ……っ！　さきっぽがワレメにこすれて…\n…んっ、ああ、熱いの……ああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「やだもう、隊長ったら焦らして……はぁ、はぁ……はやくおちんぽハメて欲\nしいです……もう……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_01" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ぬれぬれおまんこにおちんぽ……おちんぽ……っ！　んっ、お……おおぉ…\n…っ！　はぁ、はいって……っ！　んんぅううう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、すっごい太いぃ……っ！　隊長のおちんぽ、熱いのが中に\nどんどん入ってきます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おまんこが、おっきなさきっぽに押し広げられる……っ！　はぁ、はぁ、は\nぁ、はぁ……っ！　勃起……すっごぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ふはぁー……っ！　隊長、全部……入っちゃいました……？　私のおまんこ\nに、おちんぽ……全部……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おまんこが、入り口から一番奥まで、おちんぽでいっぱいいっぱいになっち\nゃってます……こんなにおっきいんですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……隊長……。このまま……後ろからぁ……。いっぱい、突い\nてください……おちんぽ味わわせてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、ああっ、はぁっ、ああっ！　隊長、すっごぉ……っ！　おちん\nぽ、ずんずんって、んぁあっ、激しくぅっ！　あっ、ああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ぶっといのが、んっ、んぁっ、はぁっ、はぁあっ！　おまんこ、ごりごりっ\nて。んひゅぅっ！　抉ってぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、おちんぽの先っぽが、何度も、何度もぉ……おおっ、おお\n……奥ぅ……っ！　んくっ、んふぅっ、あふぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「子宮の入り口まで届いちゃってるのわかりますーっ！　んぁっ、隊長のおち\nんぽ、想像よりはるかに気持ちよくって、んぁっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「こんな、私の方が、余裕なくなっちゃうなんて……ああっ、ああ……んくぅ\n……思いませんでしたぁっ、ひゃはっ、んひゃぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んへっ、隊長も、余裕ない感じです？　私のおまんこ……ンッ、き、気持ち\nいい……んですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「気持ちよくて、腰が止まらない……？　最高のエロまんこだ……？　や、や\nだ……いまはそういうこと言わないでくださいよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「なんだか余計に、おまんこを意識しちゃいます……。おまんこの中のおちん\nぽを意識しちゃいますから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぁあっ、中でいっぱい暴れて、出たり、入ったり……ああっ、ああ……っ\n！　やらしいお汁も、どんどん溢れちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「カリ高おちんぽに、エッチなお汁がどんどんかき出されちゃってます！　あ\nあっ、じゅぽじゅぽいやらしい音までしちゃいますからーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、ああっ、ああ……ああぁああっ！　んっ、んっ、んぅっ、\nんひぃ……くぅっ、くひぃ……はぁ、はぁああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おちんぽ、隊長のおちんぽ、気持ちいいですーっ！　ひゃはぁっ！　ああっ\n、ああっ、ああっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「マン汁いっぱいでちゃってますーっ！　ぐちょぐちょになったおまんこ、め\nちゃくちゃにじゅぽじゅぽって、んひいっ、気持ちいいですーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぁっ、おちんぽ膨らんで……っ！　おまんこの中で、ビクビクって震えて\nきて……んっ、射精……近づいてるんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「私のおまんこに……スケベまんこに……っ！　精液、どびゅどびゅって、だ\nしちゃうって……ああっ、宣言、しちゃって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「くひぃっ！　逃がさないように、私の身体をしっかり支えて、おちんぽ、私\nの一番奥に狙いを定めて……っ！　ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「何度も、何度も何度も、何度も……っ！　先っぽ、子宮口にどっちゅんどっ\nちゅんぶつけて……ああっ、ああ……んひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おまんこ、私のおまんこ勝手に動いちゃうっ！　隊長に気持ちよく射精して\n欲しいって、勝手に締まっちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ぐちょぐちょエロまんこ、頑張っておちんぽ気持ちよくなるように締めます\nから！　だから、隊長、遠慮無くどぴゅっとしてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「今度は私のおまんこに、子宮に……っ！　ああっ、中出しっ！　隊長のねば\nっこい精液を、ぴゅっぴゅーっとしてーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んぁあああぁぁぁああぁぁ～～～っ！　はぁっ、はぁっ、はぁああぁぁぁっ\n！　ああっ、あああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「熱いのきてますっ！　きてますぅううううぅぅぅつ！　どぴゅどぴゅおまん\nこに注がれちゃってますぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おまんこの中で、びっくんびっくん暴れながら、精液の塊を何回も何回も…\n…撃ちだしてる……っ！　ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「これすごい……おまんこで食らうと、その強烈さが何倍にも増しているよう\nに感じますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ドロドロした濃い精液が、私の一番奥に注がれちゃいました……。はぁ……\nはぁ……隊長……お疲れさまです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふ……。隊長のおちんぽを味わうことができて、私、とーっても嬉しい\nですよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「それに……この精液の温かさも、なんだかとっても、心地よい気持ちにさせ\nてくれますね……不思議な気分です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「……んっ、まだまだ隊長は射精したりないようですね？　ええ、一発じゃ収\nまらないってのはしってますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「もっともっと、私に隊長のおちんぽを味わわせてくれますか？　あ、それと\nも今度は私が動きましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「私から……んふぅっ、はぁ、はぁ……ああ……っ。腰を、動かして……んん\nぅっ、隊長の、おちんぽ……気持ちよくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、んっ、ああ……。まだまだぶっといおちんぽ……んく\nぅ、中出しまんこかきまぜて……んひぃっ、あっ、ん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「やっぱり、さっきイッたから、おまんこが敏感に……。はぁ、はぁ……。ガ\nチガチの勃起ちんぽ……すごく、感じるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「おちんぽ……おちんぽ……ぉ……。はぁ、はぁ……んふぅ……。やばぁ……\nちょっとこすれるだけで、ビリビリきちゃいますよー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んやぁっ！？　隊長、また動いちゃいますか！？　ああっ、イッたばかりの\nおまんこなのでお手柔らかにぃ……っ！　ひぃいいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、ああっ！　んぁっ、そんなぁっ！　二回目なのに、激し\nすぎますよぉっ！　おっ、おほぉおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「敏感まんこに、また容赦なくずぼずぼって！　アクメまんこにおいうちピス\nトンはやばいですってぇえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「そんなっ、そんなぁっ！　くひぃいいっ！　頭が真っ白になっちゃう！　お\nちんぽ、隊長のおちんぽよすぎるんですからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ひゃっ、ひゃめぇええっ！　じゅぽじゅぽってぇっ！　んひぃっ！　ひっ、\nひひゃぁっ！　あっ、あっ、あああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ひっ、ひっ、また、ぶっといのにおまんこ抉られてる！　ごりゅんごりゅん\nされちゃってる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長のおちんぽで、おまんこ、みーんな気持ちよくされちゃいますー……っ\n！　ああっ、ああ……ああ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んひっ、さ、さっきみたいに腰を？　ああっ、わかりましたっ。隊長のおち\nんぽのために、腰を振りますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104214" ]},
