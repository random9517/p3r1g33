		{"command":[ "PLAYVOICE", "v2_064_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「子宮の中にまで、満タンになるまでぇええっ！　おおつ、おおっ、おちんぽ\nから……精液びゅーびゅーすっごぉおいぃいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「ひぃ……ひぃ……。ふひぃ……。こんなに……まだ……おちんぽビクつかせ\nながら……射精……続けて……」", "NORMAL" ]},
