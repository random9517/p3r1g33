		{"command":[ "PLAYVOICE", "v2_064_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「隊長……私のおまんこ、気持ちよかったですか？　んふふ……こーんなに射\n精してくれちゃって、妊娠でもしたらどうするんです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00006401_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んふふ、そのときは責任とってくださいよね？　私は、隊長のおちんぽだっ\nたら、生涯お世話してあげてもいいですよ？」", "NORMAL" ]},
