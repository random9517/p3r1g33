		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「し、子宮……入っちゃいけないところにまで……おちんぽ来ちゃってるかも\n……ああっ、隊長のおちんぽすごい……すごすぎぃ……っ！」", "NORMAL" ]},
