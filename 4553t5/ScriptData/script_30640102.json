		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「んひぃいっ、ひぃいいっ！　さっきよりも深いぃいいっ！　おっ、おっ、奥\nまで届く……おちんぽ届いちゃってる……っ！」", "NORMAL" ]},
