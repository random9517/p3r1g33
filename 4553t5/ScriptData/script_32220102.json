		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、なんて……勢いで……ンッ、ドロドロ……ネバネバだ……\nナ……」", "NORMAL" ]},
