		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「イクッ、ああっ、イッてる……中出しされてイク……ッ！　ああっ、ああっ\n、オマエの……注がれて……ル……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ああ……また……熱いのが……アタシの中にたっぷりだ……。んふぅ……こ\nんなにたくさん……オマエ……凄い、ナ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アア……マンコから、溢れるくらいに、たくさんの子種ぇ……。んふぅ……\nはぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「まだ、オマエのチンポ……中で脈打って、射精、してる、ゾ……。んっ、ビ\nクつくたびに、アタシ、また、イッて……んっくぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。やっと射精が終わったようだ、ナ……。まったく……オ\nマエ、人間なのが惜しいくらい、ダ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アタシと同じ種族だった、ラ。アタシ、オマエのことを絶対にオヨメサンに\nしてた、ゾ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「……ん？　アタシがメスだから、オヨメサンはアタシの方だって？　アア、\nソウカ、人間は、逆、なのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「クク、だが、これだけ射精されたら、もしかしたらアタシはオマエの子を孕\nむかもしれない、ナ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104309" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「その時は……アア、この次元で家族を養うのも、悪く、ナイ、かもしれない\n……」", "NORMAL" ]},
