		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。すごく、たくさん出る、もんなんだ、ナ……。なんだか\n……ウレシイ、ゾ……」", "NORMAL" ]},
