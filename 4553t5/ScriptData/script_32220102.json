{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「オマエ、油断しすぎ、ダゾ。どうした？　アタシがここにいることに、驚い\nているみたいだ、ナ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「オマエ、ここはビーチ、ダゾ？　サメが、現れるのは、当然、ダロ？　なに\nを言ってる、ンダ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「というわけ、だから、オマエは、今から、アタシに襲われる、ゾ。アア、食\nべるのはオマエの、チンポ、ダ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ン……ッ。オマエのチンポ……もう勃起してる、ナ。バケモノに襲われてる\nのに、興奮してる、ノカ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んぅっ！？　アタシだから、興奮する、ダッテ？　……人間、というか、オ\nマエはたまに、よくワカラナイことを、イウ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ダガ、チンポが勃起してるのは、好都合……。ンッ、アタシのマンコに、チ\nンポ……ハメる、ナ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んふっ、く……ぅ……。これガ、チンポが、マンコにはいる……感覚ぅ……\n。実際にハメると、全然違う、ナ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「はぁ……ああ……。マンコが、オマエのチンポで、いっぱいになっているの\nを、感じる、ゾ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「オマエは、ドウ、なんだ？　アタシの、サメの、マンコ……。んふっ、気持\nちいい、カ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アア、気持ちよくなれるように……これから、腰を振って、やる、から、ナ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んっ、アアッ、んふぅ……んっ、くぅ……っ！　コウ、ダロ？　んっ、ああ\nっ、腰を……ぐりぐりと……んっ、んふぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「水の中を泳ぐように、んっ、んっ、腰を……くねらせれ……んぁあっ！　あ\nっ、コレ……アタシも、気持ちいい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「チンポが、ンッ、こすれる……はぁっ、ああっ、アタシのナカを……ごりっ\n、ごりって……んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ぶっといチンポが……ああっ、マンコの中、暴れまわって……る……！　ん\nっ、んふぅっ！　か、感じる、ゾ……んぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「これガ……ああっ、人間の、交尾……。いや、そんな立派なものじゃ、ない\n、ナ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んふっ、そうだ、ゾ……。ただ、気持ちよくなるために、ヤッてる行為、だ\nから、ナ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「人間は、ンッ、子孫を増やすわけでもなく、交尾する……んっ、ダロ？　ん\nくっ、んふっ、ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「実は、アタシたちの種族も、そう、なんダ。遊びで、こうして……んっ、チ\nンポを、マンコに……ハメる……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「そうして、妊娠してしまったら……晴れて、つがいになる、んダ。んっ、な\nんだかチンポが、ビクついた、ゾ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アタシが孕むと思った、カ？　んっ、アタシはサメだぞ？　人間の弱い子種\nで孕むはずない、ダロ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んふっ、だからこうして、アンッ！　気兼ねなく、チンポ、ハメられる……\nんっ、ああっ、あはぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「オマエのチンポ、んっ、すごく……イイ……ッ！　あっ、アア……ハジメテ\nなのに、腰……止まらない……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「もう、何度もっ、んくっ、マンコのナカが、痺れてぇ……っ！　んっ、んあ\nっ！　身体、飛ぶような……感覚……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ア、アア……。そうだ、ナ。多分、イッてる……。アタシ、このチンポでイ\nキまくって、ル。ああっ、ンッ、はぁっ、はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ああっ、またクるっ！　んっ、んっ、イク、感覚……っ！　あっ、ああ……\nんぁっ、あはぁ……ああぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んふっ、オマエ、ガマンしてる、のカ？　んっ、さっきから、チンポ、ビク\nンビクンしてる、のに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「チンポ、膨らんで……ビクついて……。んっ、ああっ、オマエが射精したが\nってるの……伝わる、ゾ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んふぅっ！　ああっ、ああっ！　アタシ、オマエのこと、イかせたい、ゾ。\nんっ、このマンコで、オマエの子種、搾りたい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、もっと激しくっ！　んっ、んんっ、腰を振れば、いい、カ？\n　んぁあっ、こう、上下に……んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アア、マンコ、すっごく濡れてる……っ！　あっ、溢れてきてる、マンコの\n中から……汁ぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んぁあっ、オマエっ、オマエぇっ！　イけっ、んっ、チンポからっ、子種っ\n、出せっ！　んぅっ、出せっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、出せっ、出せ……っ！　んんっ、んっ、んぁあっ、あはぁ\nあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　出て……出てるぅううっ！　子種っ、お前の子種っ、ああ\nっ、あああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アッ、アッ、イクッ、イクッ！　アタシのマンコもイッくぅうううっ！　あ\nあっ、なにかっ、一緒に……出る……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ふぁあっ、ああっ、潮……潮という、ヤツ、カ……。アア、サメなのに、潮\n噴きしてしまう、なんて、ナ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ふ……クク……。オマエのカラダ……。アタシの潮で、びしょびしょだ、ナ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ン……？　どうし、タ？　もう満足したか、だって？　アア？　なにを言っ\nてるん、ダ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「オマエ、チンポがまだ、勃起している、ゾ？　人間は、勃たなくなるまでメ\nスとヤりまくるって聞いた、ゾ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「それに、アタシがまだ満足して、ナイ。オマエのチンポ、気に入った。気持\nちいい、カラ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アア、だから、オマエのチンポ、カラ、子種、出させるから、ナ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、ああ……っ！　また、腰、動かす、ゾ……！　んっ、んくっ\n、はぁっ、はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「さっき、イッたから、アア、マンコ……すっごく感じる、ゾ……！　んっ、\nんっ、気持ちいい……チンポ、擦れるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んふっ、あんなに、中出しした、ノニ。アア、チンポ、まだまだ元気だ、ナ\n？　んっ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アア、ンン、アタシのマンコも凄く、反応して、ル……！　チンポ、ンッ、\n締めてっ、アア、太いの、感じる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「オマエも、腰っ、ンッ、動かさないの、カ？　ンッ、このまま、アタシに好\nき放題されて、いいの、カ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んぁっ！　そ、そう、突き上げぇっ！　あっ、アアッ！　凄いっ、一人で動\nくより、奥にっ、チンポぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「おっ、おおっ、おおぉ……っ！　身体っ、打ち上げられるよう、ダッ！　あ\nっ、チンポがっ、アタシの一番深くぅ……届く……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、凄い、ナ！　こんな風に、ンッ、マンコ、ずぼずぼされる\nのっ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00022201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アア、頭っ、真っ白になりそうなくらい……っ！　んっ、んっ、感じまくっ\nてる……アア、イクッ、イッてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「あああっ！　チンポで突き上げられながらっ、んっ、アタシまた、イかされ\nてっ、んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「マンコから、汁……んっ、ダラダラ、止まらない……アア、腰も止まらない\n……オマエと一緒に、動くぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、ああっ、んっくぅっ！　んひぃっ、はぁっ、はぁ……チンポ…\n…チンポ……イイ……ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「人間チンポにぃ……っ！　ああっ、ああっ、マンコ、めちゃくちゃにぃ……\nんっ、されるの……気持ち、いい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、イッてるマンコ……よく締まる、ダロ……？　んくっ、オ\nマエ、また……チンポ、ビクビク、だゾ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「アア、アア、オマエもイキたくなったら、イッて、イイ、から……。あっ、\nんはぁっ！　アタシもまた、オマエの子種ほしいから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「また、出そうなん、ダロ？　んっ、チンポから、また……真っ白くて、ドロ\nドロの子種……出すんだ、ロ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、腰っ、激しくなってっ！　んっ、んんっ！　オマエのイ\nキそうな気持ち、伝わって、クル……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「いっ、いい、ゾ！　んぅっ、イイ……イイ……ッ！　ああっ、ああっ、オマ\nエ……オマエぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_222_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「出せっ、出せっ！　んぁっ、あっくぅっ！　はぁっ、はぁ……チンポから…\n…いっぱいぃ……っ！」", "NORMAL" ]},
