		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デッドシャーク" ]},
		{"command":[ "SETTEXT", "「ヌタウナギの、汁のヨウ、ダ……。はぁ……はぁ……ダガ、この臭いは……\nンぅ……マンコを、疼かせる……ナ……」", "NORMAL" ]},
