{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「やあやあ、よくきたね。それじゃあさっそくだけど、服を脱いでもらえるか\nな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そりゃあ、これからキミの身体のことをいろいろと調べさせてもらうからね\n。ほら、脱いで脱いで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「むぅ。なんだいその不満そうな顔は。この天才科学者の実験台になれるなん\nて、とても名誉なことだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「その気がないなら、その気にさせるしかないようだね。ふふふ、覚悟したま\nえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「こうやって押し倒してしまえば抵抗も出来ないだろう？　服もぱぱぱーっと\n脱がせちゃうからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ついでにおっぱいを見せてあげようか？　天才のボクがここまでしているん\nだよ？　もう断る理由なんかないよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ふふっ、さっそくキミの身体を拝見……。ふむふむ……なるほどね……これ\nが男の身体……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002203_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そしてここが……へぇ、キミのオチンポはもう硬くなっているじゃないか。\nビンビンだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ボクに押し倒されて、裸に剥かれて、もしかしてこのボクにエッチなことを\nしてもらえるって期待しちゃったのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「それじゃあこのまま、キミの身体を調べていこうかな。キミの勃起オチンポ\nを握ってね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そして、手を上下させて……手コキ、してあげよう……。んっ、これくらい\nの強さがいいのかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「それとも、もっと強く握って、しっかりと竿の部分をしごいてあげようか？\n　ふふっ、どっちがいいのかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「しこしこ、しこしこっと……んっ、キミのオチンポ熱いね……手がやけどし\nてしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「興奮しているから、こんなにオチンポを勃起させてしまっているんだろう？\n　しごかれて、感じているから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「まあ、ボクの天才的な手コキにかかれば、キミがどんなに我慢しようともオ\nチンポはフル勃起しちゃうよね、仕方ないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ガッチガチになったオチンポを刺激しまくるうちに……キミの乳首も硬くな\nってきているじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ふぅん、男の身体も、こんなに乳首を勃起させるんだね……。どうかな？　\nこうやってコリコリといじるのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「勃起したオス乳首を指先で転がして……弾いて……。ふふっ、腰が震えてい\nるよ、気持ちいいんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「気持ちよくなっているんだろう？　隠そうとしても無駄だよ、さっきから呼\n吸が乱れているようだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミの鼓動が高鳴っているのが、ボクのおっぱいに伝わってくるよ……。そ\nうだ、もっとおしつけてあげようか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「おっぱいをぎゅうぎゅうおしつけながら、ンッ、オチンポを、もっともっと\n気持ちよくしてあげよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ペースをあげて、シコシコシコシコ、シコシコシコシコって。ああ、声が出\nそうになっているのをこらえているね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そんな無駄な抵抗をしなくたっていいんだよ？　キミの身体の反応を、正直\nに見せてもらわないと困るなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ほら、もっとボクのおっぱいを感じてくれたまえ。ほら、ンッ、ボクの乳首\n……硬くなっているの、わかるだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ボクだって、キミにこういうことをしながら興奮してしまっているんだよ…\n…んっ、んふぅ……ああ、乳首擦れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んふっ、キミもだんだんと余裕がなくなってきたみたいだね。射精までもう\n一押しかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そうそう、キミがどういう顔で射精をするのかに興味があるのさ。このオチ\nンポから、精液を放つ瞬間を見たいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「もっと近くで、キミの顔を見つめていてあげる。キミだって嬉しいだろう？\n　美少女天才科学者に見つめられての射精だよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ふふふっ、ボクの身体を押しのけようと腰が動いてるけど、ボクは負けない\nからね？　この好奇心を満たすまでは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「オチンポがビクビクって、手の中で震えている……。ふふふ、もしかして精\n液がこみあげてきているのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「指先にぬるぬるしたものも感じるし……これって先走り汁だよね？　へぇ、\nこんなふうに垂れてくるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ほらほら、ここまできたらあとは精液をだすだけだよね？　観念して射精し\nちゃいなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「全部観察していてあげるから、射精しちゃえ、射精しちゃえってば。ほら、\nほら、もう限界だろう？　イッちゃえ、イッちゃえ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、ああぁっ！　オチンポが、ビクンって跳ねて……あっ、ああ\n、すごい……勢いよく、精液が噴きでてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ははっ、すごいね、こんなに射精するものなんだ。もう、手がドロドロのネ\nバネバじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303135" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「それに……んんっ、なるほどね……。キミの精液はこんな臭いがするんだ…\n…ふふっ、ひどい臭いだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「でも、これがメスの興奮を煽るんだろう？　にわかには信じがたい話ではあ\nるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んんー……でもまあ、不思議と不快な臭いって感じもないから、あながち資\n料のとおりなのかも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「……それにしても、いつまでオチンポをビクつかせているんだか。まだまだ\n精液が垂れてきているようだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「まあ、ボクの手コキが気持ちよかったっていうのならしかたないか。なぜな\nらボクは天才だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「というわけで、もっともっとキミが精液をだすところをみせてもらおうかな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ん？　誰も一度きりでおしまいなんて言ってないだろう？　それに、キミの\nオチンポはまだこんなに硬いじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ほら、さっきの精液をローション代わりにして、もっとシコシコってしごい\nていくから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んんっ、ああ、すごい……手のがぬるぬるして、オチンポが逃げていきそう\nだよ……んっ、ああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「それにこうやってしごいていると、ンッ、ぐちゅぐちゅっていやらしい音が\n聞こえてきて……んふっ、興奮しちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ボクは……さっきよりかは興奮しているかもしれないな……。んふぅ、こう\nして胸が擦れるたびに、声がでそうになる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「だって、天才のボクにだって性欲はあるからね。いやらしい気持ちになるこ\nとくらいあるってこと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「まあ、こうしてキミ相手に欲情するなんて、思わなかったけど……んっ、ん\nふぅ……ああ、乳首、いいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ボクの乳首が、んぁっ、キミの身体に擦れるたびに、身体に電気が走るみた\nいな感じで……んっ、ああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「なんだかボクの方が興奮してる？　それより、キミのことも気持ちよくして\nあげないとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ほら、もっとぬるぬるのオチンポをしごいて、キミのこと射精させてあげる\nから……んんっ、あっ、こら、オチンポ暴れるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「しっかり、ザーメンまみれのオチンポにぎって、しごいて……んっ、んくぅ\n、ああっ、どうかな、これで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ああ、さっきよりもオチンポが膨らんできているじゃないか……んっ、ああ\nっ、またこみあげてきただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「腰を震わせて、ふふっ、ほら、射精したくなってきた……ふふっ、ほらほら\n、またオチンポからでてしまうだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「さっきのように、ネバネバドロドロのザーメンを、また、ボクにむかって射\n精してしまっていいんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「さっきは手だったからね。ねえ、どこに射精したい？　顔？　身体？　ほら\n、キミに選択権をあげようじゃないか。サービスだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ボクの顔に精液をぶっかけたい？　それとも身体にぶっかけてボクをドロド\nロによごしたい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ほら、ほら、早く決めないと。もう限界が近いんだろう？　こんなにオチン\nポをビクンビクンさせちゃってるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「もっと、もっと激しく、搾りだすようにオチンポしごいて……んっ、ああっ\n、ボクももう、限界かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミと一緒に……キミに射精されながら、ボクも……なにか、こみあげてき\nて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んふぅうううっ！　んんっ、あっ、ああっ、んはぁあああぁぁぁああぁぁっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「す、すごい……。こんなに……２回目の射精なのに、こんなに、勢いよく出\nるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「すごいね……精液ってこんなに飛ぶんだ……。んふぅ、ふぅ……オチンポか\nら、勢いよく飛び出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303303" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ボクの顔が……んぅ……ベトベトになるくらいに……。濃厚なザーメンを\n、ひっかけて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んはぁ……んふぅ……。たまらない臭い……。頭の中が、真っ白になっちゃ\nいそうだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……。こんなに射精できるってことは、もしかしてまだまだ余\n裕があるんじゃないかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「なんだか興味がわいてきたよ……。キミはこの調子で、何回ボクに射精でき\nるのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ふふっ、いいじゃないか。最初に行ったけど、このボクの実験台に選ばれる\nのはとても名誉なことなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「そして……好奇心を満たすためには、多少の犠牲は生じるものなんだよ。し\nかたないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「というわけだから、キミにはもっともっと、ボクに付き合ってもらうからね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、ああ……んふぅうううぅぅぅっ！　すごい、熱いのが……か\nけられて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ！　２回目なのに、こんなに濃度が高いザーメン……あ\nあ、臭いも……んっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミの臭いザーメンに……ああ……全身が、包まれている……っ！　んっ、\nああっ、なんだこの感覚ぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ！　身体が……すごく昂ってしまってる……！　ドロド\nロにされて、興奮しているなんてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303404" ]},
		{"command":[ "SETIMAGE", "0", "still_00002203_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ふむ……これが、オスの精液に含まれる成分によるもの……？　青臭くて、\nたまらないこの臭いが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ボクの頭の中を、これのことしか考えられなくなるくらいに夢中にさせる…\n…！　ああ、ザーメンすごい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。それにしても、キミのオチンポはまだまだ硬いままじゃ\nないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「もしかして、こんなに射精しても、まだまだ射精できてしまうってことなの\nかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「だったら、もっとキミには協力してもらわないといけないな。ボクも、この\n精液をもっと知りたくなったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「ふふっ。ボクみたいな美少女科学者に搾られるなら、キミだって本望だろう\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}