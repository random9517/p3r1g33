{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015101_01_03" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "151_0103101" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「あのさーダーリン？　あたしとダーリンがパワーアップする為に必要だって\n聞いたけど……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103102" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「それ、絶対にウソだよね。分かるよー。それぐらい言われなくたって分かる\nってば」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103103" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「え？　じゃあ、どうしてこうしてるのかって？　んふふ、それはもちろん…\n…」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103104" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「ダーリンがせっ……かくエッチなお誘いしてくれてるのに、断るって手はな\nいじゃない？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103105" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「パイズリフェラしろだなんて、もぅ……囁かれてドキドキしちゃったんだか\nら」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103106" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「経験……？　ないよ。あたし誰とも付き合ったことないし、レイプされたこ\nともないもん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103107" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「けど……ダーリンになら、ひどいことされちゃってもいいかなって思ってる\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103108" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「だ、か、らっ、おっぱいで挟んで……んふっ。こうやって揉んで、オチンポ\nしごいて……あはぁっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103109" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「すっごい大きいんだから、ダーリンのオチンチン……！　熱くて、硬くて、\nんんぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103110" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「これぞオスって感じ。孕ませるつもりなんでしょ？　いったい何人のオンナ\nにスペルマ注ぎ込んできたの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103111" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「ふふっ……いーよ、答えなくても。こんなの聞いちゃ野暮だよね……じゃあ\n、咥えるよ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015101_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103112" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「上手くないかもだけど、見てて……あむっ、ちゅるる、ちゅむ、ちゅむむ…\n…んんぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015101_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103113" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「もう我慢汁が出てるぅ……！　ちゅぱっ、ごくっ……！　変な味……んふふ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103114" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「もっと奥まで咥えて欲しいの？　へぇーもしかして、喉奥までレイプしちゃ\nいたいんじゃない？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103115" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「やっぱりそうなんだ……？　ダーリンってばもしかしてドＳだったりして。\nあたしはね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103116" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「んふふ、見てたら分かるでしょ？　あむっ。ちゅむむむ……んんぅ～！　ぢ\nゅむみゅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103117" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ！　じゅっぽ！　じゅぽっ！！　けふぉ！　苦しいけど、これがイ\nイの……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103118" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「しっかり喉まで咥えてオチンポしごいちゃうからぁ……頬でぎゅっぎゅって\nオチンポ締め付けて……んんぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103119" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「ダーリンのオチンポ汁ぅお口の中にいっぱい……いぃっぱい出されて、お口\nから孕ませて欲しいの……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103120" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「んみゅうぅ、じゅぷぷ、じゅぽ、じゅっぷ、じゅぷぷぷ！　き、気ぃなんて\n遣っちゃダメ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103121" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「命令して？　もっと咥えろって、気持ち良くしろって、あたしにどうして欲\nしいのか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103122" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「んんぅ、そうなの……！　いまのあたしはダーリン専用の口オナホなんだか\nら、じゅぷぷ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103123" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「おっぱいだってそうなの、ダーリン用に作られたラブドールなんだもん、じ\nゅむむ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103124" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「じゅぷっ！　じゅぷっ……んあぁ、しゃぶってるだけでオマンコ濡れてきち\nゃう……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103125" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「ふああぁん、オチンポがビクビクしてるぅ……！　イクの？　イッちゃうの\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103126" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「ダーリン命令してぇ、もっと乱暴に、あたしに命じて欲しいの……んあぁん\n、そう……そうなのっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103127" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「い、いまからあたし……ドーラ・イズリはご主人様のたくましいオチンポを\nしゃぶらせて頂いて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103128" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「喉奥に貴重な子種汁をめぐんで貰います……どうかお口オマンコに種付けし\nて下さい……んうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103129" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「じゅぷ！　じゅっぷ！　んみゅぅぅ！　来てっ、来て来て来てぇ……！　じ\nゅぷぷ！　じゅぽ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103130" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「んぅっ！？　んんっ、んあああぁぁ～～～！！？　んぎゅっ……じゅる！　\nじゅむむ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015101_01_08" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103131" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「スペルマで溺れちゃうぅ……ごきゅっ、ご主人様のザーメン、ネバネバして\nぇあたしの喉を可愛がってるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103132" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「ごきゅっ、ごく……んふぅ、すごぉいよぉ……！　鼻の奥までザーメン臭の\nぼってきて、頭の奥まで犯されてる……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015101_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103133" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「ふあぁ、ごきゅっ、ごくっ……ん、んふぅ。あはぁ、またオチンポ元気にな\nったよ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015101_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103134" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「ご主人様、こ……今度はわたくしめのはしたないオマンコにオチンポめぐん\nで下さい……えっ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103135" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「それを決めるのは俺だ？　はあぁ、そうでした。ど、どうぞ、この発情した\nラブドールに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103136" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「穴という穴、ご主人様のオチンポでほじくって、支配して、あなたなしじゃ\n生きられないって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103137" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「思わせて、征服して下さい……ご主人様のものになりたいの……んっ、んん\n！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103138" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「えっ、そっちはお尻……んっ！　んあああぁぁん！　こなれてないところ拡\nげちゃうの……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103139" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「い、いいよぉ……ますます興奮してきちゃったぁ、初アナルもヴァージンも\n奪って……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "151_0103140" ]},
		{"command":[ "SETNAME", "戦闘員Ｄ" ]},
		{"command":[ "SETTEXT", "「どうかわたくしめにお慈悲を……あっ、ああああ……あああぁぁ～～～！！\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}