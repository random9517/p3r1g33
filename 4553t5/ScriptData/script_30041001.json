{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ん……なんか、まだ少し落ち着かないよな。このカッコ自体には慣れてきた\nけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003101" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「分かってるよ……ちゃんとご奉仕ってのをすればいいんだろ？　え、何だよ\n、何が分かってないって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「言葉遣い……メイドなんだから、それっぽく……あ、そ、そっか……えっと\n、何だっけ……ご主人さま……だっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ちゃ、ちゃんと出来るって！　えっと……それじゃ、最初から……うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003104" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「その、本日は……ようこそ、おいで下さい……ました。ご、ご主人さま……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003105" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「今日は……日頃のお疲れを……私の、おっぱいで……癒やして……みます。\nえっと、どうか……お楽しみ下さい……こ、こんな感じでどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「け、敬語な！　分かってる！　じゃない……分かってますっ。それじゃ……\nするぞ……じゃない、します……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003107" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んんっ……！　はぁっ……あっ、チンチン……も、もうこんなになってる…\n…んっ、すごく……熱くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000410_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「えと……このビンビンで……はちきれそうなチンチンを……私のおっぱいが\n……優しく……シコシコ……します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、えっと……こんな風で……大丈夫……かな……ですか？　気\n持ち……いい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「なら、よかった……えっと、い、一生懸命するから……楽しんで、下さい…\n…えっ、なんか堅苦しいって……どうすりゃいいんだよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「分かった……ご主人さまだけ忘れないで……後は普通に……うん、じゃあ…\n…ちゃんとするな……んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ど、どうかな……あっ、ご主人さまの……チンチンが……おっぱいの中で…\n…もぞもぞしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「まず、上下に動かしてくから……んっ、はっ、あっ、んふっ、はっ、んぁっ\n……くっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んふ……柔らかいかな……？　でも、それだけじゃないぞ……ちゃんと、硬\nい部分もあるんだからな……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ほら……分かるだろ……？　私の乳首……どんな風になってるか……んっ、\nはっ、あ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「コリコリした感じが……チンチンに直接伝わって……んっ、んふっ……いい\n感じになってるんじゃないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ここの……んっ、おっぱいの柔らかいところで……ずりずりって……チンチ\nン……擦って……はふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「先っぽの、一番弱いところ……乳首で……ツンツンって……つついてやって\n……んんっ、ふふっ、跳ねてる跳ねてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うん、ご主人さまのチンチン……可愛いな……もっとしてあげたくなっちゃ\nうな……んっ、あっ、ふっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「このメイド服ってさ……んっ、結構……おっぱいのところ……目立つように\nなってるじゃん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「だから、普通に視線を感じることも多かったりするんだけどさ……んっ、ふ\nっ……はぁっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「でも、こんな風に……ご主人さまのチンチンを挟むことになるなんて……思\nわなかった……んっ、ふふっ……特別だぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……先っぽからオスのにおいがしてる……んっ、すぅぅ……ん\nふ……はぁぁぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んふふ……服の中がご主人さまのにおいでいっぱいになりそうだ……んっ、\nはぁぁ……あふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「まだまだ……続けるぞ……こんな風に服の中でおっぱい……揉みくちゃにさ\nれるの……気持ちいいのかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「初めて味わう気持ちよさ……？　ふふっ……まーた、調子のいいこと言っち\nゃってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そんな欲張りなご主人さまには、もっとサービスしてあげないとだねぇ……\nんっ、ふっ、は……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ほぉら、チンチンの皮……ずりゅずりゅって何度もめくれ返って……んっ、\nあぁ……もっと強くしてやるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、あふっ……ヌルヌルしてきた……これ、先っぽから……汁が\n滲んで来てるんだな……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「分かるよ……私の汗だけじゃない……チンチンから出てる我慢汁でしょ……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「チンチン自体も……ビクビクって震えて……これ、出したくなって来てるん\nだよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んふっ……いいですよぉ……ご主人さまぁ……我慢しないで……びゅびゅっ\nて……このままおっぱいに出しちゃおう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「我慢してるチンチンにぎゅぅぅぅって押し込んでぇ……あぁっ、ほら……腰\nが浮き上がって……んっ、出るっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「きゃふっ……！　あはっ、びゅくびゅく出てきたっ……中にっ……おっぱい\nに……精液……いっぱい出てるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んんっ、あったかいの……流れ込んでくる……はぁぁ……ご主人さまのドロ\nドロ……おっぱいにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んくぅ……相変わらず……すごい量……はぁぁ……もう谷間から、溢れて来\nてるぅ……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んふっ……落ち着いた……？　いっぱい出しましたねぇ……ご主人さま？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そんなに私のおっぱいで癒やされたんだ……ふふっ、やっぱりスケベなご主\n人さまだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「でも、喜んでくれたんなら……嬉しいな。な、何だよー。別にメイドだから\nって訳じゃないぞ。私は私なんだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……それにしても……私のおっぱいの中で……またムクムクさせ\nてるのは……何だ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「一回出しただけじゃ、まだまだ全然足りないって？　さーて、どうしようか\nなー。なーんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「分かってるよ……今日の私は、ご主人さまだけのメイドさんなんだから……\n満足するまで、しっかりご奉仕しないとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「だから、んっ、また……おっぱい……しっかり楽しんで欲しいぞ……んんっ\n、はっ、んふっ、あっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うぁ……さっきの精液がぐちゅぐちゅしてる……中で……めちゃくちゃ滑る\nようになってる……はぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「今度は……上下だけじゃなくて……横にもしてみよっか……んっ、あっ、ん\nんっ、んふっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、くちゅくちゅって……音してる……はぁ……んっ、この音…\n…やらしーな……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おっぱいの中で……チンチンが何度も擦れて……こんな感じになるんだ……\nは、んんっ、あ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ほーら、ご主人さまぁ……もっとして欲しいところ……ありますかー？　ん\nー？　乳首……もっと当てて欲しい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ふふっ、しょうがないなぁ……ご主人さまは。今日は……特別なんだからな\n……んっ、んんっ、あっ、はっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ほぉら……ここ……チンチンの弱いところと……乳首……ぎゅうって……ん\nんっ！　ああっ……ヌルヌルと一緒に来るぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっふ、直接中でどうなってるか分かんないけど……でも、ご主人さまのチ\nンチンが……おっぱいの中で暴れてる感じ……する……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ヌルヌルの中……まるでオマンコみたいになってる……そう……おっぱいマ\nンコみたいに……あっ、はぁんっ、んっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっ！　んっ、あぁっ……そんな急に張り切って腰を振って……んっ、私の\nおっぱいマンコに興奮しちゃったのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、んくっ……いいよ……いっぱい……感じさせて……また、気持\nちいいの出させちゃうからな……んっ、はっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、おっぱいのお肉で……ぎゅっとチンチン押し潰して……乳首\n……両方……横から当ててぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「このまま、ずりずりって擦ってあげると……あっ、んぁっ、あぁっ……私も\n……これ……すごく……感じるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んふっ、あぁっ……このまま……もっと激しく動かしてっ、あっ、んっ、一\n気に最後まで行っちゃうからっ……んっ、はっ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ご主人さまのチンチンっ……また気持ちよくっ……びゅーって精液出せるま\nでっ、はっ、んんっ、後……ちょっとぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、チンチン震えてっ……出ちゃうっ……？　精液っ、はぁんっ\n、出してっ、来てぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んくぁぁぁっ、はぁっ、またっ……中にっ……いっぱい……出てるっ……び\nゅくびゅくっ……気持ちいいのっ、出てるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁんっ……溢れて来るっ……ドレスにも精液……あぁっ、掛かっ\nちゃってる……んっ、ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「っていうか、まだ出てるのか……んっ、ホントに……どれだけ気持ちよかっ\nたんだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「しょうがないな……ほら……残ってる分も、全部出しちゃえ……おっぱい…\n…ぎゅぅぅうって……んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、やっと……チンチン……収まってきたみたいだな。おっぱいの\n中が……ドロドロだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「さ、ご主人さま……バレンタインの特別ご奉仕……どうだった？　メイド服\nで……興奮しちゃった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「そりゃあさ……もっと、ちゃんとメイドらしくって出来ればいいかもしんな\nいけどさ……私なりの精一杯っていうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「こういうメイドも悪くない……？　えへへ……そっか、まあ……それならよ\nかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「また特別サービスして欲しい時？　んー、そうだなぁ、どうしよっかなー。\n気が向いたら、かな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「その時は、もっともっと気持ちいいご奉仕しちゃうからな。ご主人さまっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ひぁぅっ！　あぁっ……か、顔にっ……精液っ、あっ、いっぱい……飛んで\nるぅっ、んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はぁぁん……濃いの……びゅるって……思いっきり掛かってる……ちゅぷっ\n、あぁ……精液のにおい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んふぅっ、あぁっ……クラクラする……こんなの浴びたら……もう何も分か\nんなくなっちゃう……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、射精……やっと落ち着いてきた……残さないで、全部出しちゃってく\nれ……精液、直接塗っていいからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んふぁ……終わり……？　んっ、はふぁ……沢山出したな……ホントに……\nいっぱい気持ちよくなってくれたのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「どうだったかな……やっぱり、もうちょっと本物のメイドらしく出来た方が\nよかったかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「敬語とか……あんまり上手くないし……まぁ、ご主人さまっていう位は出来\nるけど……それ以上はよく分かんなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「それはそれで、私らしい……？　そういうメイドがいても……いいってこと\nかな……そっか。えへへ、ならよかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ん……？　またして欲しい時？　そうだなー、どうしようかなー。うん、ま\nぁ、時々ならいいかもな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「その時は、もっともっと気持ちいいご奉仕しちゃうからな。ご主人さまっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1003410" ]},
		{"command":[ "WAITINPUT" ]},
