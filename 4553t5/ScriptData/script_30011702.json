		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……こんな、押し倒すような形になって……申し訳ありません\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ですが……私も、もう限界なんです……貴方に色々なことをされてから、ず\nっとそのことばかり頭にちらつくようになって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「一人で何とかしようとも思ったんですけど……やっぱりダメで……そうした\nら、ちょうどいいタイミングで貴方がいらしてくれたから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「この貴重なチャンス……絶対に逃すわけにはいかないって……んふぅっ……\nあぁ、こんないやらしい女で申し訳ありません……私、こんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ……もうダメ……しちゃいます……あ、じっとしていて下さい。全部\n、私の方で致しますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンポ、入れちゃいます……失礼します……んっ、んふぅぅぅぅ\n……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、あぁっ……入って行きます……んくぅぅぅ……あぁっ、オチン\nポっ、オマンコの中にめり込んで……行きますぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁぁ……熱い……ずぶって、全部……飲み込んじゃう……くぅぅ\nっ……すごく太いの、あぁっ、感じますぅぅ……んはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ま、待って下さいね……すぐ、動きますから……でも、その前にちょっとだ\nけ、オチンポの感じ……確かめさせて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、ありがとうございます……んくぅぅ……あぁ、太い……オマンコのヒ\nダ……広がっていく感じ……して、ますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ぬ、濡れ濡れ……ですか……は、はい……恥ずかしいですけど……ずっと、\nこのオチンポのことを考えてて、下着も染みて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「スーツの色も変わっちゃうんじゃないかって……ビクビクして、いました…\n…今も、あぁ……内側からどんどんお汁が溢れてる感じ、してます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、そ、そろそろ……動き、ますね……楽になさっていて下さい\n……今日は、オマンコでご奉仕させて頂きますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あっ、はんっ、あっ、はっ、あっ、はぁぁぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、やだ……ぐちゅぐちゅっ……すごくっ、いやらしい音……しちゃっ\nてますっ、んふっ、あっ、んふぅっ……んっく、んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「中でっ、んぁぁっ、かき混ぜるとっ……亀頭の出っ張った部分がっ……グリ\nって、感じる場所にっ……こすれてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あひぁっ、もっと欲しいって……オマンコが言ってますっ、んんっ、腰が勝\n手に……グリグリ……欲しがっちゃいますぅっ、んぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、これです……これがずっと欲しかったんですっ、夢にまで見\nたオチンポぉっ……逞しいオチンポいっぱいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、オマンコが頬張って……はむって……咥えてしまってますっ……ん\nんっ、カリが当たるのっ……気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あひっ、はぁっ、いかがですかっ……？　私ばっかり感じてませんかっ？　\nちゃんと……んっ、オマンコ……味わって頂けてますかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はひっ、んっ、よかったっ……もっともっとご奉仕致しますからっ……たっ\nぷり、オマンコ……楽しんで下さい……はぁぁっ、あぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「いつもより……んっ、積極的……？　んふっ、そうですね……確かに、自分\nでも……大胆になっているような感じがします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「レイジョーモモの……スーツのせいでしょうか……あぁっ、演劇の為の大切\nな衣装なのに……こんな使い方をしてしまうなんて……はっ、ひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、でも……もっとしたいって思っちゃうんですっ……オチンポ求めて\nっ、腰が……跳ねてしまってっ……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁ、でもっ……戦士には休息が必要ですよねっ、ですからっ……\nこれもっ、あひんっ、大切な……任務と思えばっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あひぁっ、そうですっ……こうしてっ、体育倉庫の陰で……見つからないよ\nうにして……セックスするっ……それも大切な使命なんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁんっ、だからっ……腰振っちゃいますっ……もっと、大胆に……オマン\nコしてっ、喜んでもらいますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、んぁっ、あぁんっ……また、お汁……溢れて来ました……\n垂れてこぼれちゃうのっ……止まらないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、やぁぁんっ、見られてますっ……お尻を振ってる所もっ……繋がっ\nてるオマンコも……全部丸見えになってるのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁんっ、い、いやらしいですよねっ……？　こんなパクパクさせて……欲\n張ってるところっ……はしたないですよねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁんっ……でもっ、貴方になら……私のいやらしい姿も……見てほしいん\nですっ……これが……私のもう一つの本性っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、くぅんっ……オチンポにもっともっと喜んで貰えるようにっ……いや\nらしく腰を振ってる所っ……見てっ……下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ……オチンポ……ビクビク来てますっ……もうすぐ射精ですね……？\n　ちゃんと……オマンコで感じますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はいっ、このまま中に……奥に下さいっ……生で直接っ……オマンコに精液\n浴びせて……イカせて……下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はんっ、いっぱい締め付けますからっ……奥にっ……ビュクって元気いっぱ\nいっ……射精っ……してぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁっ！　出てますっ……精液っ……はぁぁんっ、イクっ……んぁ\nぁぁんっ、中出しされてっ、イッてますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はぁ……あふっ……いっぱいになってる……あぁぁ、中にとぷんって来る感\n触……凄い……頭……真っ白になって行きますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……はぁ……ぁぁ……イキました……凄い感覚でした……こんな\n感触……味わったことありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……射精……終わりましたね……んっ、あふっ……オマンコ、喜んで頂\nけましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はい、私は……もうこれ以上ない位に堪能させて頂きました……感謝です…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あの……それで、ですね……これから、なのですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「やっぱり、まだ……これで終わってしまうのは……どうにも消化不良と言い\nますか……中途半端と言いますか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「つまり、も、もう一回しても、よろしいでしょうか……？　その……私のオ\nマンコも、まだ……したいと……疼いてまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「は、はいっ、ありがとうございますっ……では、改めて……続き、させて頂\nきますね……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はふっ、あぁ……今度は、まず……いっぱい出して頂いた精液を……中で馴\n染ませていく動きから……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あっ、くんっ、うんっ、あふっ、うんっ……ぐちゅぐちゅっ……鳴りますっ\n……あぁ……オマンコの中で……精液……混ぜられてますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁ……これで、膣壁が……よく滑ってぇ……あふんっ、あぁっ、より……\nオチンポのことを……はっきり感じることが出来ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んんっ、こうして……ぐりゅって……強めに擦れる時……ジーンって痺れる\nような感じが……心地よくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「こうしてっ、あっ、あんっ、何度も……何度もしたくなっちゃうんですっ…\n…はぁんっ、お尻……振る格好なのっ……は、恥ずかしいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、ピッチリしたスーツ……興奮しますかっ？　貴方に、そういう……\n趣味があって……良かったような……複雑なような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「でも、んっ、せっかくですから……楽しんで頂きたいですっ、もっと……あ\nっ、もっと……感じて下さいっ、あひんっ、ひんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁぁっ！　下からの突き上げが……また、強くっ！」　んぅんっ\n、オチンポがっ、グリグリ……来ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、そこはっ、続けてされたらっ……弱くてっ、はぁんっ、からだっ…\n…力……抜けちゃいますっ、あぁっ、んぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「ダメ……また、オマンコダメになっちゃいますっ、もう少しだけ我慢してっ\n……一緒にイキたいですっ、んくぅっ、あっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「もう、出ます……よねっ？　射精っ……しますよねっ？　そこまでっ……頑\n張りますからっ……あぁっ、貴方も……イッて下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000117_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「はんっ、あひんっ、あぃっ……ああっ、でもっ……私っ……あぁっ、もうっ\n、限界……ですっ、気持ち……良すぎてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「あぁっ、入り口のところもっ……奥の方もっ……じわってしてっ……あはぁ\nんっ、本当にっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「出るっ……射精っ……しますっ？　はいっ、どこでもいいですっ、お好きな\n所にっ……貴方の欲望をっ……ぶつけて下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1704218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
