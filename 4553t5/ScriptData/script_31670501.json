		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふぅ……ようやく客足も落ち着いて一段落したな。主殿、手伝ってくれて本 \n当に助かった。一息入れよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00016705_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ほら、水分補給をしないとな。お茶で申し訳ないが飲んでくれ。私も、ずっ \nと喉が乾いていてな……んぐっ、んぐっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503102" ]},
		{"command":[ "SETCHARA", "0", "char_00016705_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふはぁっ、生き返る！　んーっ、身体に染み渡る感じがたまらないな！　こ \nの一杯の為に生きているという感じだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00016705_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふぅ……また汗が出てしまうな……ん？　どうした、主殿。そんなに前を押 \nさえて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503104" ]},
		{"command":[ "SETCHARA", "0", "char_00016705_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私の格好が際どい……？　む……そうか……つまり……主殿は、私の姿に興 \n奮してしまったと……確かにちょっと胸の部分は開きすぎか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503105" ]},
		{"command":[ "SETCHARA", "0", "char_00016705_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが、そんなに大きくさせてしまったなら、何とかしないとな……手伝って \nもらったお返しもしなくてはならないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503106" ]},
		{"command":[ "SETCHARA", "0", "char_00016705_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふふ……では、主殿……そこの岩陰に……ああ、私にさせてほしいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503107" ]},
		{"command":[ "SETCHARA", "0", "char_00016705_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ……オチンポがこんなに張り詰めて……もしかして、仕事中少し動きが \nぎこちなかったのは、このせいだったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503108" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうか……それは申し訳ないことをしていたな……ならば、すぐにでも楽に \nしてあげないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「身体を寄せていくぞ……おっぱいの中に……熱いのがみっちり詰まっていく \n……んんっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ、全部……入ったな……んっ、どうだ……？　主殿……気持ちいいか… \n…？　んんっ、ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふふ、そうか……私のおっぱいの中……熱くて……いい感じか……あぁ…… \n主殿のオチンポも、すごく熱くなっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ、汗が……どんどん滲んで来る……ちょうど潤滑油の代わりになって \nいい感じだ……はぁ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「上下に動かしていくからな……はっ、ふっ、くっ、んんっ、あぁっ……はふ \nっ、あっ、んく、ふっ、んぅぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……熱い……ぬるぬるの肌を……擦れば擦るほど……熱くなっていく… \n…オチンポ、ビクビクして……元気だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふ……こんなに興奮してくれているんだな……こうして、中でズリズリと \n擦り上げていくと……私も発情してしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、あぁ……おっぱいをぐにゃりと歪ませて……オチンポに…… \n絡ませて……はぁっ、くぅぅっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「何度も何度もパイズリするっ……んんっ、私のおっぱいが……オナホールに \nなって……主殿のオチンポとオマンコしているようだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あんっ、あぁっ、ダメだ……これは、私が責任を持ってご奉 \n仕して、主殿を気持ちよくさせるパイズリなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ、はっ、こうして……汗のぬめりの中で……オチンポを擦っていると \n……私も……気持ちよくなってしまう……あっ、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「気持ちよくなって構わない……？　んっ、私の表情で……興奮する……うぅ \nっ、そ、そんなに改まって言われるとかなり恥ずかしいのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503121" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが、んっ、分かった……変な遠慮はしないで……もっとオチンポに重ねて \nいこう……んっ、乳首も、こつんと……あっ、当てて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ……あぁっ、いやらしく尖った先端が……オチンポに当たるう……んっ \n、乳輪も広がっているような感じがする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ……水着から、乳輪が……はみ出ていた……？　や、やはり……ちょ \nっとビキニが小さすぎただろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「改まって指摘されると……は、恥ずかしさが増していくが……今は、もう… \n…全部見せてしまっているんだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「思い切って……んっ、ふっ、直接乳首を……あっ、んんっ、押し付けていく \n……くぅんっ、熱くて硬いのが……グリグリされて……いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁん……こんな海辺の開けた場所で……おっぱいを丸出しにして……主殿 \nのオチンポを扱くなんて……んんっ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……ますます乳首が硬くなっていく……んんっ、おっぱい感じる……く \nぅん……気持ちいい……おっぱい気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、今の私は……さぞかし、いやらしい顔をしているんだろうな \n……自分で口元が緩んでしまっているのが分かる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが……仕方ないんだ……オチンポを何度も何度も擦って……んんっ、おっ \nぱいがどんどん疼きを増していく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁん……陽射しの熱と……オチンポの熱を同時に感じて……あぁ、身体が \n火照ってたまらない……おっぱいが気持ち良すぎるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503131" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、あぁっ、もっといやらしくおっぱいをひしゃげさせるっ……オ \nチンポ……喜んでもらうようにシコシコするっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……主殿のオチンポ……震えてきた……もうそろそろ射精したくなって \nいるんだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、もちろん主殿のオチンポのことはよく分かっているつもりだ……んっ \n、このまま……中に……おっぱいマンコの中に出して欲しいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503134" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ああ、もっと激しく扱いていくっ、はっ、んふっ、オチンポ……ドピュドピ \nュ出して欲しいっ……行くぞっ、はっ、ふっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503135" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ、んぁっ、ビクビクしてっ……もう少しっ……中にっ、あっ、 \nあひっ、いっぱいっ、出してっ……くれぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503136" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ひゃぁうっ！　あぁっ……出てきたっ……新鮮なザーメンミルクっ……どぷ \nどぷっ、出てるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……すごい……こんなにたくさん……いっぱい溢れて……んんっ、 \n止まらない……ドロドロだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁんっ……おっぱいの中……気持ちいい……本当に中出しされたみたいに \nなってる……あぁ、いやらしい気分になってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、収まった……たっぷり出してくれて感謝する、主殿… \n…私のおっぱいで感じてくれたなら、こんなに嬉しいことはない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503140" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ……さて、これで満足してくれれば……と言いたいところだったが、お \nっぱいの中のやんちゃ棒は、まだまだ元気いっぱいだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「大丈夫だ……このまま任せて欲しい。私も、もっと主殿のオチンポにご奉仕 \nしたいんだ……この精液も快感に繋げていくからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はふっ、にちゃにちゃする……んんっ、ちょっと縦に擦るだけで……精液の \nぬめった音が……いっぱい響いてくるな……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「この、滑りやすくなった状態でのパイズリ……あぁ……本当にゾクゾクする \n……肌が、すごく敏感になっていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「黒光りするオチンポと何度も交わらせて……くふぅ……んんっ、ぬめりと熱 \nを感じるのが……たまらなく好きなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ、んふっ……おっぱいの中で、ピクピクしている……この可愛らしい \n感じがとても愛おしい……あ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「オチンポの方にして欲しいところはあるか？　できる限りのことはしてあげ \nたいと思っているが……今の感じで大丈夫か……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「もう少し、強く挟んで欲しい？　ふふ……お安い御用だ……もっともっとオ \nチンポに圧を掛けていくぞ……んんっ、くぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「左右から……ぎゅっと押し付けて……揉みくちゃにしながら、亀頭を擦り上 \nげてやる……んっ、ふっ、はっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503209" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……オチンポが……おっぱいの中であっちこっちに当たっている……は \nぁぁっ……ビクビクして……すごく反応してくれている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふふ……気持ちよさそうな表情だな……主殿……そんな顔をされたら、もっ \nともっとしてあげたくなるじゃないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、お互い様……？　あぁ、そうだな……私のおっぱいも……オチ \nンポを挟んで、ピリピリと心地いい痺れが広がっている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「くちゅくちゅ鳴る音も……この陽射しで滲む汗も……いろいろ入り混じって \n……あぁ……身体が溶けてしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、は、ふっ……あぁ……ずっとこうしていたい……大好きな主殿にご奉 \n仕をする悦びを……おっぱいで堪能して……私は幸せだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、だが、そうも言っていられないな……この震え……んっ、もう \nそろそろ……次の射精が近いだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「分かるさ……んっ、ここから私にできることは、もっと大胆におっぱいを擦 \nり上げて……気持ちよく射精してもらうしかない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、あぁ……私も……このペースで続けたら、おっぱいだけで \nイッてしまいそうだ……また、主殿にいやらしい顔を見せてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503217" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「けど、もう止まらない……んっ、はぁっ、主殿っ……あぁっ、いっぱい出し \nてくれっ、オチンポミルクっ……残ってる分……全部っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、また中出しでもいいっ……顔にぶっ掛けてくれても構わな \nいっ……主殿のザーメンが欲しいっ、はぅっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、イきそうだっ……私も……イクっ……主殿っ、出してくれっ……ミ \nルクいっぱいっ、んぁぁっ、出してぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503220" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぅっ……！　んんっ……あぁっ……また、おっぱいに……熱いの……どぷ \nどぷっ……出てきてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……さっきより多くないか……？　たっぷり出した筈なのに、まだこん \nなに……よっぽど興奮していたんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふぅ……あぁ……主殿にご奉仕をする女として、本当に名誉なことだ…… \nおっぱいも嬉しくて……軽くイッてしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ、後もう少し残ってそうだな……分かっている……根元の方から搾り出 \nすようにして押し込んでいくから……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふっ……溢れてきた……少し味わわせてもらおうかな……んちゅっ、ちゅ \nぷっ、ぴちゃっ、ちゅぱっ、んちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、主殿の精液の味……はふぅ……ちゅぷっ、この味だ……こ \nれが、私を蕩けさせていく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503306" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふふ……ようやくオチンポも落ち着いたようだな。これで、少しは私も責任 \nを果たせただろうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ああ、喜んでくれたようで何よりだ。私もすっかり楽しんでしまった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「後は、たっぷり汗もかいてしまったし……海で一泳ぎして、いろいろ洗い流 \nしてしまおうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿も一緒にどうだ？　え……また、催してしまう？　ふふっ、その時はま \nた……ご奉仕させてもらうさ……さあ、いこう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふぅっ……！　あぷっ……顔にっ……あぁっ、濃いのが……いっぱい出て \nるっ……はぁ、顔面シャワーされてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……もっと掛けて欲しい……主殿の濃いので、私の顔をドロドロにして \nくれ……こんなに興奮してくれたんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、はぁ……んっ、そうそう……この味……んんっ、今日も身体の方 \nは健康そのもののようで何よりだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「れろっ、ぴちゃ……後は奥に残ってる分を少し吸い出そう……んちゅっ、ち \nゅうぅぅっ……あふっ……また元気に飛んできた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、あふ……ヌルヌルがいい気持ちだ……んっ、全部出し \n切ってくれたようだな……お疲れ様だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503405" ]},
		{"command":[ "SETIMAGE", "0", "still_00016705_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふふ、礼には及ばない。私がムラムラさせてしまったのだからな……自分で \n責任を取るのは当たり前のことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私のおっぱいも、すっかり喜んでしまった……本当は主殿をもっと喜ばせる \nことが目的のはずだったのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私が喜ぶと主殿も嬉しい……？　ふふっ、そうか……そう言ってもらえるな \nら、ご奉仕をしてよかったと思えるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それにしても暑いな……もう一泳ぎして、汗や精液も洗い流してしまおう。 \nほら、主殿も一緒に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0503409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「大丈夫、この辺まで人が来ることはないからな。もし、また催したら喜んで \nご奉仕させてもらうさ……」", "NORMAL" ]},
