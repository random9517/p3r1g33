{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0004" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_015" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "123_0104101" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「お呼びですか、隊長さん。って、もう脱いでる～！？　おちんちん、むちゃ\nくちゃ反り返ってますよ～！？」", "NORMAL" ]},
        {"command":[ "SETCHARA", "0", "char_00012301_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104102" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あ、あの、呼び出された時点で、エッチなことするんだろうなって予感はあ\nりましたけど、さすがにそう来るとは思ってませんでした」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104103" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あのですねえ、わたしも一応女の子なんですから、もう少しムードというか\n、雰囲気というか、そういうのが欲しいなーって思うんですよね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104104" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「プロレスの試合もそうじゃないですか。相手と一緒になって盛り上げるから\n、お客さんも喜んでくれるわけで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104105" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「はあ！？　ちちち、違いますよ！　見られたいとかそういうことじゃないで\nすって！　あ、あの……隊長さん！？　きゃあああ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00012301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104106" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ひう！？　ま、窓に、押しつけられて、おっぱい、ぺったんってぇ！？　見\nえちゃう！？　外から見えちゃいますよ、これ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104107" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ひあ！？　うそ、おちんちんがあそこに！？　駄目駄目駄目～！　隊長さん\n、駄目！　あ、あああ！？　んあああああああ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104108" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あ、あうぅ……入っちゃった。入って、来ちゃいました。こんな、状況で、\nおちんちん、入れられちゃいましたぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104109" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「めちゃくちゃ恥ずかしいに決まってるじゃないですか！？　もし誰かに見ら\nれたらどうするんですか！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104110" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「観客はいらないですって！　夜のプロレスに観客はいらないです～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104111" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ひあ！？　馬鹿なこと言いながら、腰が、動いたぁ！？　ん、んあ、あ！？\n　ひあ、あああああ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104112" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ひう、あ、あ、あ！？　そん、な！？　わたしの、あそこ、もう、濡れてる\nぅ。ひうう！？　恥ずかしいです～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104113" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「こ、こういうの、好きなのかって、聞かれても……うぅ、確かに、無理矢理\nなの、嫌いじゃない、です」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104114" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「でもそれは、隊長さんだからで、他の人は違いますからね！　絶対の絶対に\n嫌ですからね！　隊長さんだからこそですからね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104115" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「いいですね？　それだけは絶対に間違えないでくださいね！　って、んんん\nん！　返事が、適当すぎる～！　しかも、腰、振りながら～！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104116" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ひう、ひ、あ、あ、あ！？　奥に……くぅぅ！　おちんちんが、奥に、当た\nってますぅ！　この体勢、奥にまでぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104117" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「しかも、後ろからだから、隊長さんの顔、見られなくてぇ……うぅ、ちょ、\nちょっと、怖い、ですぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104118" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あ、ふあぁ……後ろから、ぎゅって、抱きしめてる。あぁ。それ、嬉しいで\nす、隊長さん。安心、しますぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104119" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あ、あの、抱きしめられるのは、売れしいんですけど、わたしの身体、ふ、\n太く、ないですか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104120" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「いいんです、正直に言ってくれて！　ぽっちゃりって言うか、むっちりして\nる自覚はありますから～！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104121" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「そ、それに、最近はトレーニングのせいで、お腹が空いて、ご飯が美味しく\nて、余計に体重がぁ……うぅぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104122" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「揉みごたえがあるって、いやぁ、お腹揉まないでください～！　ひ～！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104123" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「はふぅ！？　お、お腹、ぐにぐにしながら、いっぱい、いっぱい、おちんち\nんが、中を、擦ってぇぇぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104124" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あ、ふあぁ、また、抱きしめるみたいに、ぎゅって……ああ、それ、好きぃ\n。好きです、それぇ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104125" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「はう、あ、あ、ふあぁ……ぎゅってされたまま、わたしの、中、ヴァギナ、\nいっぱいいっぱい、突かれて、るぅぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104126" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「くぅぅぅ。奥まで、ずんって、入って来てぇ……その後、出っぱった部分で\n、引っ掻かれてぇ……ひゃうう、ん、あんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104127" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ひあああ！？　い、今、ぞくぞくって、来ました！？　身体の奥から……お\n腹の、裏側から、なにか、来てますぅ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104128" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ひうああ！？　痺れる……身体中が、ぞくぞくって、痺れてるぅ。足、段々\n、力、入らないぃぃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104129" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「それに、隊長さんの、おちんちんも、びく、びくってぇ……ふ、震えてる。\n震えてる度に、わたし、ぞくって、痺れるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104130" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「い、イクんですね？　はひ！　わたしも、イキます！　隊長さんと、いっし\nょに、このまま、イキたいですぅ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104131" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「だから、このまま、思いっきり……はうう！　あ、ひあ！　ひんんんん！　\nひあああああ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104132" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「そうです！　もっと、もっと、強く……あ、あ、あ、ああ！？　奥ぅぅ！　\n一番奥、何度も、突かれて、るぅぅぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104133" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「イク！　イキます！　イクイクイクイクイク！　イッちゃいますぅぅぅ！　\n隊長、さん！　あああああ！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104134" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ひゃううううううう！　熱いぃ！　熱いの、中にぃ！　んんん！　精液、ど\nくどく、来てるぅ！　妊娠しちゃいますぅぅぅ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104135" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「あ、ふあぁ……す、ごい。凄かった、です。頭、真っ白になって、身体が、\nふわふわってぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104136" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「夜のプロレス、凄い……初めてプロレス見たときと同じくらい、凄かったで\nす。身体、痺れちゃってますぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104137" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「それに、お腹の奥、まだ、ズキズキしてます。暖かいのが染み込んで来て、\nそれが身体中に広がってくみたいですぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104138" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「ふえ？　このまま二回戦、ですか？　の、望むところです。でも次は、乱暴\nなエッチじゃなくて、もっと優しい感じで、お願いします」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104139" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「って言ってるのに！？　このままの体勢で始めちゃった！？　せめて、窓、\nカーテンして～！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012301_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "123_0104140" ]},
		{"command":[ "SETNAME", "フロール" ]},
		{"command":[ "SETTEXT", "「だから、夜のプロレスに観客はいりませんてば～！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}