{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0108" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよ！　なーんだよ、あのザマは！　展示であれだけ絶好調なら、本番\nでも絶対イケると思ったのに！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「だからご主人は見方が甘いのですぞ。たしかに展示では調子よさげに見えま\nしたが、あのモーターで好調が持続するとはとてもとても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114860001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うるへー！　まだ次のレースがあらぁ！　見てろよ、最終までには負け分を\n取り戻して――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。食べるかしゃべるか、どちらかにされては？牛もつ煮込みライスが\n飛び散っておりますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114860002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いた！　カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114860001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「やっぱりここに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114860001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわっ！　なんだ、なんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おや。思ったよりお早いお着きで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114860003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「へー、ここが競艇場かー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114860001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「私も、来たのは初めてだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114860001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、なんでおまえらまで来てんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だってカツマさん、いかにも探してほしそうな書き置きを残していくんだも\nん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114860001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「書き置き？　なんだそれ……あ！　さてはジュンジローてめえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さーて、なんのことですかな。犬であるワタクシが字を書くどころか、筆跡\nの偽造までできるとでもお思いですかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114860004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「てめ、悪事をごまかすときだけ犬を前面に出しやがって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ね、カツマ。帰ろう。いつまでもいじけてちゃダメ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114860002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「以前みたいにハズレ舟券を拾ってないだけ、マシと言えばマシですけど。で\nも、みんなのためにも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114860002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふーんだ！　どうせ連れて帰って、延々とクレーム対応させる気なんだろ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私たちも手伝いますから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114860003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お願い、カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114860003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふーんだ。どうせ最初の１、２本だけだろ。それにな、俺は悟ったんだよ。\nどうせ俺は刻の女王の息子だと思われて、世間じゃ悪役扱いなんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そんなこと……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114860004" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなことあるだろうよ！　ネットじゃその噂で持ち切りなんだろ！？　競\n艇場の売店にならんだ、スポーツ新聞にまで載ってたぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんなの気にしちゃダメです！　カツマさんの件なんか、チュパカブラの婚\n約発表と同じ枠なんですから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114860004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんと！？　チュパカブラが婚約したのですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114860005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこ食いつくとこじゃねえだろ！　とにかく俺はもう、隊長なんかまっぴら\nだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「また！？　またなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114860005" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そもそも俺は、地球侵略が目的のＧ・ルナリアムの幹部なんですー！　それ\nが地球防衛とか、そもそも無理があったんですよーだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん……！　私たちの隊長でいてくれると思ってたのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114860005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマがまたこんなことを言い出すなんて……カツマの……カツマの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114860006" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お！？　なんだ！？　なんだ！？　そんな迫力のある顔で詰め寄ってきても\n――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマの馬鹿！　意気地なし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114860007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はうっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カグヤのビンタが、俺の頬に炸裂した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はっ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマなんか……カツマなんか―っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114860008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！？　カグヤ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0108" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "走り去るカグヤを呆然と見送りながら、俺は、前にもこんなことがあったのを\n思い出していた。そう、具体的にはシーズン１第３話を……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだった、あのときもこんな風にカグヤとまりあに……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん……！　そうです！　立ち直ってくれたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114860006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だ、だけど、あのときとはまだ事情が違うだろ！？　いくらなんでも今回は\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんの馬鹿！　意気地なし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114860007" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はふぅっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なるほど……そうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114860002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「カツマさんをビンタすると、立ち直るのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114860002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「そういうことなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114860002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待て！？　お前らちょっと待て！？　落ち着いて話し合わないか！？　事と\n次第によっては――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「カツマさんの馬鹿！　根性なし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114860003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おふぅっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「カツマの馬鹿！　甲斐性なし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114860003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「げふぅっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「カツマの馬鹿！　能無し！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010114860003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひぎいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「カツマのアホ！　ボケナスビ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114860001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでお前までっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あれ？　ほむらさん、なんでここに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114860004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おう、正義（まさよし）が来週のイベントで、ここに出店を出すんだよ。そ\nの下見にな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114860002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「下見ついでに殴るんじゃ……ねぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うるせえ！　隊長のくせに口答えすんじゃねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020114860003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぅうううううん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}