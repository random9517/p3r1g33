{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0023" ]},
        {"command":[ "DISPIMAGE", "0", "TRUE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_020" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……良く来たな！　待ちくたびれたぞ！」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_010021030001" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "街外れ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "人気がなく、さびれた古い洋館の前でルナテミスは威風堂々と二人に言い放っ \nた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「やれやれ。何事なんだい？　わざわざこんなところに呼び出して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私とて暇ではないのだがな。他者には聞かれたくない用件……ということか \n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、そうだ。極秘裏も極秘裏……貴様らにしか頼めぬ用件だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「組織の中でもトップクラスに優れた女傑……血桜お七、冴島長官」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030003" ]},		
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様らも気づいているだろう？　アナザー・ルナテミスの暗躍に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030004" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「暗躍……というと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「別の世界のもう一人の私……といえば聞こえはいいが、結局は私のまがいも \nの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そんなヤツにしてやられっぱなしのこの現状……もう我慢できん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私はどうにかして、ヤツをギャフンと言わせてやりたいのだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「つまり、経験豊富なあたしらに助言を求めてる……ってことでいいのかい？ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そういうことだ。何か良い案はないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「出来るだけ早く、可能なら今日中に！　奴を懲らしめるとっておきの方法を \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そうだねえ……下剋上は私も好きさ。だから、考えられる案はいくつかある \nけれど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、何っ！？　本当か！？　ならすぐに教えろ、今すぐ教えろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030010" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「どれも、今日今すぐにってぇ即効性のあるもんじゃないからねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030005" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そんなぁ……。なんとかならないのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030011" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「己より秀でたものに対抗する術。それも楽に容易にとなると、選択肢は絞ら \nれて当然だろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「それこそ、ルナルバース陛下にお言葉をいただくわけにはいかないのかい？ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030006" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ。それが最も効率のいいやり方だと思うが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うぐっ……そ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030012" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、この件は……グレート・ルナリアムの皆には知られたくないのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030013" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「へえ。どうしてだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030007" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「私は彼女らの前では偉大なる女王でなければならない……それに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030014" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ……私にもプライドというものがある！　偉大なる、超大なるこの私がっ \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030015" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザー・ルナテミスなんて愚物にやすやすと屈するわけにはいかんのだ！ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030016" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なるほど……。だから極秘裏に、というわけか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ほとんどプライドが理由みたいな気もするが……。まぁ、意地を貫くのも悪 \nかぁないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030008" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ルナテミスさん。私らだって野暮じゃない。アンタのその気持ちはよくわか \nる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030009" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「な、ならば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030017" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ああ、その話……ノったよ。でも、それはアンタの実力ってやつを見せても \nらってからだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030010" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私もそれには賛同する。一度、実力を見せてもらいたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「油断せず、全力でかかってくるといい。それから話をはじめるとしようか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ。もとよりそのつもりだ。私より弱い相手に教えを乞うつもりもない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030018" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「存分に私の力を測るといい。その間、私も貴様らの力を確かめさせてもらう \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030019" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「いいねえいいねえ。燃えてきたよ……かかってきな、お姫さん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030011" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}