{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0189" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さて……ここが、惑星ビキニか……ったく、陽の光が眩しいぜ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ、実にいい天気だ！　どれ、さっそくひと泳ぎ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022570001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「いや、任務だろう、そこは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022570001" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「長官もご一緒にいらしてますし、羽を伸ばすのは少し気が早いのではないか\nと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022570001" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「そうなんだよねー。あたし達だけかと思ったのに、なんで長官も来たんだろ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022570001" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さあ……なんでだろうな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「完全に便乗バカンスだと思われますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022570001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しっ、滅多なことは言うもんじゃねぇ。あの水着のチラシは見なかった方が\nいいかも知れないやつだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「何をブツブツ言っている？　すぐに遺跡のある場所へ向かうぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010022570001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は、はいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0191" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「遺跡の入り口……なかなか雰囲気のある場所ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022570002" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「確かに、これなら何かすごいお宝が眠っているような……そんないかにもな\n気配がするな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022570002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「とにかく、ここからは慎重に進んだ方がよさそうだ。何が待っているかも分\nからないからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022570002" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「それにしても……入り口は随分狭いのですね。一人分が通れるかどうか……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022570003" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「一人通れるなら余裕っしょ。とりあえず一番乗り～っと……あ、あれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022570002" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「どうした、ミラ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022570003" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「おっかしいなー、何か見えない壁みたいなのがあって……んっ、先に進めな\nいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022570003" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「見えない壁？　何を言ってる……そんなことがあるわけ……むっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022570004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「ほら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022570004" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「うむ、確かに何の変哲もない入り口のようなのに、この岩壁の奥から先に進\nめないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022570005" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「もしかして……古の遺跡らしく、何らかの封印が施されているとかでしょう\nか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022570004" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「汝たちに告ぐ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何だ……？　どこからか声が……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「ビキニ以外……これを禁ず……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「今……何だって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022570005" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「ビキニ以外……これを禁ず……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ビキニ以外……禁ずと言うのは……ビキニに関係していないものは入れない\nということではないでしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022570005" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この惑星の現地民じゃないとダメってことか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「案外、ビキニ着てたらなんでもオッケーだったりして、あははっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022570006" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ビキニか……まぁ、私の装備も似たようなもの……ん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022570003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「は、入れた……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022570006" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うむ……入れたな。出るのも……問題ないようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022570004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マジか……まさか本当にビキニじゃないとダメとはな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「しかし……だとすると困ったな……ルナテミス殿はともかく、私たちは……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022570007" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「そういうときは、私達にお任せくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010022570001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古館隊員" ]},
		{"command":[ "SETTEXT", "「私達っ……ビキニバズーカ隊なら、きっとお供出来ると思います！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010022570001" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「ビキニバズーカ隊の皆さん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022570006" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「こんなこともあろうかと、万全な装備で来てあげたのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_010022570001" ]},
		{"command":[ "SETCHARA", "0", "char_00006702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何か、完全に遊びに来た感じにしか見えないんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ごちゃごちゃうるさいな。中に入れるならいいだろ？　お先に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010022570001" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「失礼しますっ……あっ……あれ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010022570002" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「むぅ……通れないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010022570002" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古館隊員" ]},
		{"command":[ "SETTEXT", "「えぇぇー、ビキニなのにぃ！　んくっ……だ、ダメだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010022570002" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「鎧は通す……水着は通さない」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「今……また声が上から……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022570007" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「鎧は通す……水着は……通さない」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どういうことだ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ビキニ以外は禁じられているのは間違いありませんし……その上で、鎧は通\nし、水着は通さないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022570002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「むぅ……すると、ルナテミスはビキニアーマーだから通れる……ビキニバズ\nーカ隊はビキニアーマーではないからダメだと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022570008" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "声" ]},
		{"command":[ "SETTEXT", "「鎧は通す……水着は……通さない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわ……意外に面倒くさいぞ、ここ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「けど、マジで当たってるかも、それ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022570007" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、私は問題ないんだろう？　ならば、私だけでも中に入って調べてくれ\nば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010022570005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「いや、さすがに一人でというのは危険過ぎるだろう。何が起こるか分からな\nいし、他に誰か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022570009" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「要はビキニとアーマーを備えていればいいということですよね。ということ\nは、ビキニである程度戦闘態勢が整っていれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_010022570008" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「なるほど。ふむ……となれば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010022570010" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022570008" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は？　待て、待て待て待て。何で、急にこっちを見るんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「とりあえず、脱いでみよっか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022570009" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おいっ、待てっ……ズボンに手をかけるなっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「みんなも手伝ってー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_010022570010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「こいつは面白そうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010022570003" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「さあ、大人しくして」", "NORMAL" ]},
