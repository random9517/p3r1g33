{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んひゃっ！？　た、隊長先輩っ……？　こ、これは一体、どういう状況なの\nでしょうか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「お、お、押し倒された……のは理解できますが、問題なのはですね、私の胸\nを……おっぱいを鷲掴みにされていることと、揉まれていることと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「デッ……デカすぎるおチンポが、お腹に……当たってまして……っ。この大\nきさを思いっきり見せつけられている状態だということなんですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「もしかして……なんですけど。まさか、この超巨大おチンポを……わ、わ、\n私に入れる……。つまり、挿入するつもりではありませんよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「えっ！？　い、入れるんですか！？　そのために、前戯として胸を揉んでい\nるんですか！？　あっ、あのっ……確かに……おっぱいを揉まれると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「私はすごく気持ちいい、のですが……。い、いくら濡れてもですね……。こ\nのサイズは入らないと思います。私……初めてですし……はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「……確かに！　隊長先輩のデカいおチンポを見せてほしいってお願いしたの\nは私です！　実際、すごくすごく見たかったので見られて嬉しいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「隊長先輩のおチンポ……おっきいおっきいって言いながら、つんつん指でつ\nついたり、撫で回したりしましたよ？　で、でも……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「こんな予定ではなかったんです！　た、ただ一方的に、巨大なモノを愛でた\nり観察したかっただけで！　ですので一旦落ち着いていただいて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ま、待ってもらえませんかっ……！　このおチンポのサイズは、歴戦の戦士\nでもキビシいですよっ！　プロでも受け入れられるかってサイズです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「よって、エッチ超素人の、おっぱいがおっきいだけのラヴリエータちゃんに\nは荷が重く……！　デカすぎるおチンポは観賞用だと主張したいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「……な、なんですか？　待てない？　えっ！？　待てないって、本当に入れ\nるつもりなんですか！？　心の準備がまだなので……って、ああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ！？　うぅうううっ！？　んぅうううっ……！？　超ドデカおチンポぉ\nおおっ……！　一気に一番奥、まで、入っちゃいましたけどぉおおっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「うっ……うぁああっ？　あっ？　な、なんですか？　これ、この気持ち良さ\n……身体がヘンです、お、お、おかしくなっちゃいましたぁあ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「い、いきなりデカすぎるおチンポが入ってきた衝撃で……！　んぁああっ♪\n　痛みなんかより快感がすさまじくっ……！　あああああ、う、ウソですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「私っ、初めてなのにっ！　しょ、処女なのにイッちゃいますっ！　ッあああ\nああああっ？　ああああああ～っ！？　イクっ、これ絶頂ですよねぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ああああっ、すっごいぃいっ！　隊長先輩のおチンポ、おっきいだけじゃな\nいぃいっ……！　いき、なり、イカされました、えっえっ怖すぎますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あ～っ、ああああっ……あぁっ、これぇ……！　絶対ヤバいやつです、私っ\n、おチンポ入れたらダメなタイプのエルフみたいですぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ですからっ……。あっ！　う、動こうとしないでくださいぃっ！　ダ、ダメ\nッ……！　だめですっ、ピストンは本当に……あっ♪　ダッメッ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んあああああっ♪　そ、そうですよねぇえっ！　私がお願いしたくらいでぇ\nっ、あはぁんっ♪　止めてくれる隊長先輩じゃないですよねぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ♪　んぅうっ♪　なにっ……？　なんでですっ！？　あっ♪　おチンポ\nが奥ぅうっ……！　私の子宮を突くたび、イクんですけれどもぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっうううっ！？　イッ……♪　ああああっ♪　イクイクイクっ……！　あ\nっあっあっ！　ふ、普通処女ってこんなイキ、ませんよねぇっ、んああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「それ、なのにぃいっ……！　隊長先輩にもみくちゃにされてっ！　ぶっとい\nでっかいおチンポ動かされるだけで、む、無限にイクっ、のですがっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「うっ♪　んふぅっ♪　うぁああっ♪　イクぅううっ♪　あ、あのぉっ、初心\n者に対する手加減、とかはっ……！？　無いですか、あぁイクぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ♪　ううぅうっ……♪　あんっ、んん……！　隊長先輩のお\nチンポぉおお……！　やっぱり中に入れてもデッカいですぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「動いてると、カ、カタチ、がはっきりくっきりわかって……んぁああっ♪　\n大きすぎて苦しい、のに……オマンコがよろこんでるのがわかりま、すぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ♪　愛液いっぱい出ちゃいます、隊長先輩のおチンポに、オマンコうご\nめいて……勝手に絡みついちゃってますぅううっ……ふぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「経験、なくても本能でオマンコっ……！　イッたりうねったりするんですね\nぇえっ……♪　んあぁっ♪　じゅっぽじゅっぽ水音がしてますうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んぁうううっ！　イクぅっ！　おチンポ好きになっていきますぅうっ……！\n　い、いえ、最初からわりと好きでした、けどぉ……っ！　んぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「こんなにどっちゅんどっちゅん子宮突かれたらっ♪　こ、恋しちゃいます、\n愛しちゃいますぅうっ！　隊長先輩のデカおチンポぉおおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　突いて、突いて突きまくってくださぁいいいぃい……ッ♪\n　ひぁんんっ♪　あひぃっ、おっきい……っ、おっきぃいっ……！　って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あれっ？　中でまたおっきく？　えっ！？　精液放出までするんですか！？\n　ま、まずいですよ……！　このままぁっ、生で中に出したらぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「わ……私と隊長先輩の赤ちゃん、できちゃいますよぉ……！　んぅっ♪　い\n、いやではありませんが……初めてで妊娠なんて……。っんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「こ、ここまで言っても動くのをやめない、なんてっ……隊長先輩はおチンポ\nだけじゃなく、う、器もデカすぎますぅっ！　あっ……あっ、ひぁんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「出す、んですね……！　私のオマンコに精液、出して……赤ちゃん作っちゃ\nうんですねっ！　あっ、来るっ……すごいのきちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あッ♪　あっぁっあっ、本当に中に出てますぅうううっ……！　はひぃいい\nっ♪　ひぃいんっ！　あんっ、あぁんんっ、赤ちゃんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんできちゃいますぅうっ……！　ああああっ♪　ドピュッ、ドピュッ\nてデッカいおチンポから、精液発射されてるのわかり、ますぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ひぃいんんっ！　こんなに生々しく、中でビクビクするなんてぇええっ……\n！　あああっ、エッチってすごいです、クラクラしますぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あひぃっ♪　中に出されて、私もイッちゃいますっ！　っあぁああっ♪　ご\nめんなさいっ、初めてでイキまくるヘンタイエルフでごめんなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっああっ！　イキますううっ！　イクぅううっ！　中でびゅるびゅるされ\nながらイクぅうううっ……！　あぁああんっ、幸せぇえええっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「……はひぃいい……♪　とんでもない量、オマンコに容赦なく注入されてし\nまいました……。精液までたっぷりサイズだなんて……驚きですぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、もうくたくたです……。くたくたのクラクラで、目が回りそう\nです……。でも、こんなことでヘバってなんかいられませんよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんを作ってしまったからには、私っ……！　隊長先輩の生涯の伴侶と\nして、これから頑張っていくつもりで、す……って、あっ！？　ふぁあっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「だ、大事な話をしている途中におチンポ動かすのやめてくださいぃいいっ…\n…！　あうっ♪　ど、どうして精液をたっぷり出したのに……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「おチンポが巨大なままなんですか！？　あっ♪　だ、ダメ、ダメれひゅっ…\n…♪　子宮に精液入ったばっかりなのにっ、あっ♪　刺激しちゃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「オマンコの中っ♪　もう精液でいっぱいですからっ……こ、これ以上注入し\nなくても……っ。んんんんッ？　わ、私がおチンポを欲しがっている？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「おかわりしたくて、オマンコがおねだりしていたから？　ほ、本当ですかっ\n……？　あっ♪　そ、そんなに私ってば、巨大おチンポの虜にぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ、あああああっ……♪　ああああッ……♪　は、はいっ、そうです！　\n気持ちいいですっ！　おチンポに突かれるの、突き上げられるの好きですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「でも体力がもたな、い……ですっ！　んぁんんんっ！　隊長先輩ってば強引\nすぎ……！　でも、でもぉおお……オマンコぐちゅぐちゅされるとぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「何も考えられなくなって……！　んんぁっ！　ふぁんんっ♪　ひぃんっ、あ\nひぃっ♪　エッチしたくなっちゃいます、エッチ最高に気持ちいいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ♪　あああああっ♪　わ、わかりまひた♪　突いてくだひゃい\n、突きまくってくだひゃいぃいっ♪　あっあっ気持ちよひゅぎまひゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「もう♪　どうなってもいいのでオマンコ突いてくだひゃいぃいっ……あうぅ\nううっ♪　イキまひゅっ、何度でもイキましゅからぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ん、ぁっ……あっあぁっ♪　あっ……んぁあああっ……♪　隊長先輩……！\n　隊長先輩の巨大なおチンポ、がっちりオマンコにハマってますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「私がいくら濡らしてもっ……、はぅうっ♪　中にヌルヌルの精液が入ってい\nても、すべって抜けたりしないで、ずっぷり奥まで入っていますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あッ♪　んぁああっ……！　激しい突きっ……♪　大きな武器が、私のオマ\nンコを出たり入ったりしているなんて……はぁっ、はぁ、興奮しますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「隊長先輩のおチンポにメロメロにされちゃってます……っ♪　もうこれ無し\nじゃ生きていけません、このおチンポじゃなくちゃ嫌ですぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ああっ、ぁっあっ、んはぁああっ♪　ああああっ……！　イクぅっ、イクっ\n……！　何度もイッたって、まったく止められる気がしませんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んっ、あぅっ……うううっ♪　ま、また……おチンポが太くなってますぅう\nう……！　精液、出すんですね……私のオマンコにぃっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「いいですよっ、ください……思いっきり出しちゃってくださいぃ……♪　だ\nってもう、既に一回出しちゃってるんですから！　何回出しても同じです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ですから気兼ねなくっ……！　全、力でこのおっきなおチンポから……精液\nびゅーびゅー放ってください！　お願いします、精液くださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「はぁうっ！？　あうっ、ううぅっ！　ひゅ、ひゅごいでひゅっ♪　隊長先輩\nの精液っ……！　中にいっぱい出てます、あっ、上がってき、ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ああああっ、お腹の中で精液が爆発している、みたいぃい……っ♪　デカい\nおチンポってこんなに早く、精液が充填されるんですねぇっ、ひゅごいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　いっぱいになっていた子宮に、またっ……。新鮮な精液が注入\nされていきます……！　あっ、こんなのイクに決まってます、あっ、イクっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「赤ちゃん造りながらイッちゃうママでごめんなさぁいいい……っ♪　でも気\n持ち良すぎるんです、オマンコに出してもらうの気持ち良すぎますぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んはぁああっ♪　これっ、もう溢れちゃいますよぉ……！　受け止めきれま\nせ、んん……♪　それなのに……ビュクビュクッってずっと出てて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「わかりました！　ママになりましゅっ♪　ママになりまひゅからっ♪　あっ\n♪　これ以上注がれたら……ママぁ、おかしくなっちゃいますよぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ふぅううっ……、はぁあああ……。ふぅううっ、はぁあああ……。す、すみ\nません、あまりに怒涛の精液ラッシュで、呼吸するのを忘れていました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「隊長先輩はスゴいですね……♪　普通、赤ちゃんできちゃいます、なんて言\nわれたらびっくりしてエッチやめちゃうものだと思ってましたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「そこから更に攻めてきて、きっちり二度目の精液をぶちこんでくるんですも\nん……。性豪っていうか、豪傑っていうか……おみそれしました……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「こ、こうなったら私も……その、か、覚悟を決めますので！　もし、そうな\nったら……これからよろしくお願いしますね……♪　頼りにしてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ひゃぁんんっ！？　デカいおチンポが！　オマンコからずるんって抜けて制\n御不可能にぃいっ……！　あッ、待って、どこにいくのぉっ……あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「熱ッ……！？　ひぅっ！？　精液が、オマンコじゃなくて身体に放出されて\nますけどぉっ……。い、いいんですかっ、あっ、かかってますけどぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あうっ♪　んぅううっ、ん～～っ、んんんッ……♪　強烈な量の精液が、私\nの肌に……胸に、いたるところに着弾して……！　あぁうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「隊長先輩ぃ……っ。私、どんどんドロドロになっていってしまっているんで\nすが……っ！　あっ！　こ、これでいいんですよねぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふぅうっ……♪　隊長先輩の精液、粘り気がすごくて……肌にくっ\nついても垂れてきませんよ、相当スゴい粘着力ですぅううう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あぁっ……♪　隊長先輩のデカいおチンポから出た精液を浴びちゃってるぅ\n……！　こんなに出してくれてありがとうございますうぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「あうぅ、はぁ、はぁ、はぁ……♪　身体の中も、外も、ぜーんぶ隊長先輩の\n臭いでいっぱいです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00027101_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「隊長先輩って、もしかして独占欲が強いタイプですか？　それとも、強い武\n器はフルで活用したい暴れん坊？　だって、おチンポ暴れすぎですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「中に出してくれると思って油断していた私も私ですが……、すっごくびっく\nりしました。まさか、身体にヌルヌルをぶっかけられてしまうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「でも、それくらい思いきりのあるニンゲンじゃないと、巨大な武器は扱えな\nいのかもしれませんね。大変勉強になりました……。ふぅ、ふぅ……♪」", "NORMAL" ]},
