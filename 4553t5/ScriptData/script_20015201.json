{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……ん、来たか。わざわざ悪いな、主ら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「別にいいですよ～。やることもなかったし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023410001" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「エファナティカ様のお願いなら構わないさ。けど、わざわざ内密にってのは\nどういうことだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主らも承知のことと思うが、先だって我々のファウンデーションがＥＤＯ\nの奴らに壊滅させられた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「女王陛下は勝敗は兵家の常とおっしゃられたし、しばらくは動くなともおっ\nしゃられたが、我らからすれば業腹であることには違いない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ゆえに、我々は陛下に内密でＥＤＯへの反抗を仕掛ける。ところでラケシス\n、お前の姉妹はどうした？　あやつらにも招集をかけていたはずだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「おねえさまは別件で出払っています。妹は……なんか１８年振りのアレが起\nきたからドートンボリ銀河に飛び込みに行くって宇宙船で飛んでいきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023410002" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「なんでもアレが起きたりめでたいときはそうするんだって～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023410003" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なんだそりゃ？　土着の奇祭か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……まぁいい。お主らがいればなんとかなるだろう。計画は単純だ。ＥＤＯ\nの本部を呪いで汚染して、使えなくする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410005" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「へぇ、大胆じゃないか。でもいいね。敵の本陣を奇襲で落とすってのがいい\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「しかし、どうやってするんですか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023410004" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まず、我々のスパイをＥＤＯ本部に潜入させる。そして、スパイにＥＤＯの\nシステムをハッキングして掌握してもらう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410006" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そして我々が潜入するタイミングでセキリュティをハッキングして無効化し\n、本部の中心で余が怨霊を呼び出して呪いで汚染する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410007" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あとは放っておいても呪いが蓄積し、誰も近づけない場所になるという寸法\nだね。お主らには、召喚している余の護衛を頼みたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「大胆な作戦だな。ますます気に入った……けど、誰がスパイになって潜入す\nるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410004" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「私たちは顔が割れているから不可能ですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023410005" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「案ずるな。そこもしっかりと手配している。入ってきてくれ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410009" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はじめまして、メガデスですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023410001" ]},
		{"command":[ "SETCHARA", "0", "char_00012501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こいつが？　なんか頼りなさそうだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410005" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「聞いたことのない名前ですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023410006" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「最近名を轟かせている武装組織ジョーカーは知っているじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410010" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あぁ。報酬次第で破壊工作やゲリラ戦、暗殺までやってのけるっていうグル\nープだろ？　こっちまで噂は伝わってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410006" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そのジョーカーのリーダーことカーネル、その正体こそが彼女、メガデスじ\nゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410011" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「彼女は潜入任務に破壊工作、暗殺すらこなせる工作員のエキスパート。この\n作戦にうってつけじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410012" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「へぇ、あのジョーカーの……お前がリーダーだったのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410007" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、以後お見知りおきをお願いしますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023410002" ]},
		{"command":[ "SETCHARA", "0", "char_00012501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ジョーカーのリーダーであれば異存はありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023410007" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「難しい任務だろうが、仕込みはよろしく頼むぞ。報酬はたんまり弾もう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410013" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「お任せくださいな。引き受けたからには、やり遂げてみせますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023410003" ]},
		{"command":[ "SETCHARA", "0", "char_00012501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「頼もしい返事じゃねえか！！　よし、それじゃ今すぐ出撃だ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410008" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まぁ待て。まずはメガデスにシステム把握の仕込みをしてもらう時間が必要\nじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410014" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それに……計画を実行するのに１番適した日がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410015" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「適した日って……いつなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410009" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「地球にはハロウィンという日があってな。今はリア充どもが騒ぐだけの日に\nなっているらしいが、元は現世に妖精から霊までが迷い込む日だったらしいの\nじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410016" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余が死霊を呼ぶのにも、そういう縁があればやりやすい。ゆえに７日後の深\n夜、その日に潜入する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410017" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なるほど……完璧な計画じゃねえか。さすがはエファナティカ様だぜ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410010" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふ、そう褒めるでない。まぁ、穴はあるまいて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410018" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あの……最低限の警備員は排除するとして、深夜に基地に残っている人がい\nるということはないんですの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023410004" ]},
		{"command":[ "SETCHARA", "0", "char_00012501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「心配するな、その点も調査済みじゃ。先ほども言ったとおり、ハロウィンは\nすでに形骸化しているらしくてな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410019" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「今はなにやらその死霊や妖精の仮装をして騒ぎ立てて飲めや歌えやの宴にな\nっているとのことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410020" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そんな日に深夜まで人員を労働させるような組織などあるまいよ。ふははは\nはは！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023410021" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そこまで考えてるなんて……やっぱりエファナティカ様の計画に間違いはな\nいな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023410011" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "(……そううまくいくのかしら)", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023410005" ]},
		{"command":[ "SETCHARA", "0", "char_00012501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ハロウィン……仮装……潜入……ふふ、いいこと考えた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023410008" ]},
		{"command":[ "SETCHARA", "0", "char_00019501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}