		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「美味しいジェラート屋さんができたんだって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030115410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「いいわねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040115410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まだまだ暑い日が続くものね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060115410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "３人は珍しく非番だった。そこで、セレインの提案でジェラート屋へ向かって\nいた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それにしても、本当に原住民に溶け込めているのかのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「さっきからこっちをジロジロ見てきやがって。やんのかゴラァ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こら、セレーナ。女王様を探すために来ているのじゃから、無駄な問題を起\nこそうとするでない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「まあ……そうだけど……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030115410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「てめぇ、こんなところでなにしてやがる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うわっ、なんで私の偽物がこんなとこにいんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030115410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ええっ、アナザーセレーナ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040115410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「てことは、その隣にいるのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060115410002" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余の存在に気づくとは。ん？　お主、肌の色が違うではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「こ、これは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060115410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「せっかく禁呪の力を手に入れたというのに、なぜ隠しておるのじゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115410004" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「うぐ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060115410004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「え、エファちゃんにはエファちゃんの事情があるのよぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040115410003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そんなことより、なにしに来たの？　ディアナちゃんたちはこれからジェラ\nートを食べに行くんだから！　邪魔しないでよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040115410004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115410004" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「“ジェラート”……だと？　つえーのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115410005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「強いっていうか、美味いだな。食い物だぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030115410004" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……“ゴクリ”」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115410006" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「セレーナ、いまはそんなことより女王様を見つけるほうが先じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115410005" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「女王様って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040115410005" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まさか、刻の女王が地球に来ているの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060115410005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「貴様ら、なぜそれを知っている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115410006" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「エファナティカ様が自分で言っていたような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115410007" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「我らがここに来た目的を知られたからには、生かして帰すわけにはいかぬ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115410007" ]},
		{"command":[ "SETCHARA", "0", "char_00000314_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ちょっ、こんなところでやる気か！？」", "NORMAL" ]},
