		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ど、どこかで変身しないと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060115410006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あいつら逃げたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115410008" ]},
		{"command":[ "SETCHARA", "0", "char_00000411_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「逃がさぬぞ！」", "NORMAL" ]},
