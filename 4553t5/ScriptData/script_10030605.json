		{"command":[ "SETNAME", "トキノ" ]},
		{"command":[ "SETTEXT", "しかし……この肌を刺すような魔力、まちがいなくあやつらも地球に来ておる\nな……", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010115410003" ]},
