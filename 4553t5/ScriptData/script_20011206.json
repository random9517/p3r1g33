{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「地球が襲来者（インベーダー）から攻撃を受けて以来、戦いはもう数か月も\n続いている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021410001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はじめは局地戦が続いていたが、最近は戦線が拡大し、地球に存在するいく\nつもの悪の組織と正義のグループが、戦火に巻き込まれていった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021410002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「戦いは長引くばかりで、終わりが見えない。私は疲れた。誰もかれもが疲れ\nていた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021410003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そんな中、新たに編成されたＥＤＯの『ビキニバズーカ隊』、略称『ＢＢ隊\n』は、ジャングルへの降下作戦に投入されることになる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021410004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「降下地点が違う！？　どういうことだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「風で流されたんです。東に１５Ｋｍほどずれてしまったようで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010021410001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなに！？　とにかく、長官と連絡を取ろう。無線は使えるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「それが……降下したときに無線機が故障してしまって……交換部品もなくっ\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021410001" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでそんなことに……なんとか、使えるようにはできねえか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「やってみます！　でも、時間がかかると思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021410002" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか……どうしたもんかな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、作戦にはトラブルがつきものですぞ。いつものことではありません\nか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021410001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、な……とにかく、目的地まで歩くしかねえか……無線機のほうは、い\nろいろ試してみてくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「はいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010021410003" ]},
		{"command":[ "SETCHARA", "0", "char_00006302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「ちょっと待ちな。あたしが先頭に立つ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021410001" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それがよさそうだ。悪ぃけど頼――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エフュサス隊員" ]},
		{"command":[ "SETTEXT", "「伏せろ！　敵襲！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_058_010021410002" ]},
		{"command":[ "SETCHARA", "0", "char_00005802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さっそくかよーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「いくよ、バズ太郎きゅーん！　奴らを石器時代に戻してやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010021410001" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ジャングルに降り立ったカツマたちを待っていたのは、戦いの地獄だった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021410005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「侵略の後に住み着いた欲望と暴力。次元間闘争が生み出した、迷いの密林」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021410006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「パロディと行き当たりばったり、お色気とご都合主義とをフードプロセッサ\nーにかけてブチまけた、ここはＦＡＮＺＡ　ＧＡＭＥＳの闇市」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021410007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「次回、『ほら出たー！』。来週も、カツマたちと地獄に付き合ってもらう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010021410008" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}