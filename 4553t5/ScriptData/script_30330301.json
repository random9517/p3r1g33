{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あら……隊長さま。こんなところで、涼んでらっしゃったんですねぇ……。\n皆さん探してらしたみたいですけれど……フフ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「モテる男は大変ですねぇ。とはいえ、偶然にしてもこの機会……。天が私に\n与えてくれたチャンスだと思って、アプローチさせていただきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「うふふふ……♪　大胆すぎましたか？　でも……せっかくの浜辺、せっかく\nの二人きりなんです。ここで退いたら極道の女失格。勝負所でしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっ……どうですか？　この水着……。破廉恥すぎるんじゃないかって、す\nこーしだけ迷ったんですけど……隊長さまは好きですよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00003303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「胸を強調した、いやーらしい水着……。露わになった谷間でギュゥッとオチ\nンチン……オチンポ掴んで離さない、淫らなデザイン……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私に時間くれるんでしたら……。日焼けオイルを塗りたくって……まぁるい\n乳房でご奉仕しますけど……？　ふふ、それでよろしかったでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっ……ふぅっ……ふぅっ、ふぅうう……♪　パイズリだなんて下品なコト\n……。少女の頃には思い付きもしませんでしたけど……。っふぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00003303_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまに教えていただいて……。随分うまくなったと自負してるんですよ\n？　っん……っ、いつもはサラシで締めつけとる胸を……。っあぁ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「解放して……、こうしてガッチガチになったオチンポを包みこむ……。気持\nち良くして、白濁汁をピュッピュ出していただく……。んっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「それが私の、何より大事な仕事なんやって理解できたんは……。あっ♪　や\nっぱり隊長さまへの想いからなんです。それを、わかって欲しいので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ややこしい言葉を連ねるより……。ん……ッ♪　パイズリ一本でお伝えしよ\nうと思います。どうぞ、快楽に溺れてくださいまし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっ……はぁっ、はぁ、はぁあ……♪　あぁっ……あっ、ぁっ、あぁっ……\nふぅう……んんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「た、隊長さまぁ……？　私、また胸が大きくなったんですよ……わかります\n？　重みもズッシリ増してしまって……あっ、揺らすのが大変です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ですから……コレ……。ローション、いいですよねぇ……。んぁっ……♪　\nんん……っ、勝手にニュルニュル動いてくれて……楽できますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「貴方も……、っん……こういうの、お好きでしょう……？　たっぷんたっぷ\nん、おっきく胸が上下左右して……んっ、見事ですし……。んぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「このヌルヌルヌルぅ～、ヌルヌルヌルぅ～って感覚……すごく昂りますよね\nぇ♪　ふふ、オチンポさんも喜んで顔出してますし……そうだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……ふぅううう～～♪　って息を吹きかけてみたり……ふふふ♪　敏感な先\nっちょがピクピクして……可愛いわぁ……。っふぅうう～～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……感じてるお顔を見るの、好きなんですよ。だからもっと……もっと気持\nち良くしてさしあげたい……。え？　いつもより圧迫感がすごい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「それは……んふっ……。よぉ見てください♪　手で……乳房を動かしてるか\nらです。あっ……こうやって力をこめて、オチンポに絡ませて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまの反応を見ながら……操ってる……。圧力を操作しているんですよ\n……。こう……ぎゅぅっ、むぎゅうっ、ぎゅううって……。ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「左右、から……手のひらで胸を潰すと……んぅっ……♪　ギュム、ギュプ、\nぐちゅっ……ぐちゅって音がして……んっ、興奮しますねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「粘っこいオイルが、二人の体温であたたまって……。トロットロのニッチャ\nニチャ……♪　オチンポもテラテラに輝いて……ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「すごく……美味しそうに見えてしまう……♪　あぁっ、はぁ、はぁ……オイ\nルがなかったら、今すぐお口でむしゃぶりつきたいくらい……。あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「そうやって、いつも私を誘惑する悪ぅいオチンポさんには……ケジメつけて\nもらわないとなりませんなぁ……♪　ほら、そちらも動いてください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「下から谷間を突き上げられるの……たまらないんです♪　あっ……♪　私も\n……私もめいっぱい、胸を動かして、こすりつけますから……あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ♪　そ、そぉ……そうです、それっ……それですぅっ……！　あっ♪　\nおっぱいピストンされとる時に、こっちもやり返して……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっあっ、んぅうう♪　胸でセックスしているみたいに……♪　んぁあっ♪\n　本気で腰ぃ振ってくださ、い♪　あっ、気持ちいい……気持ちいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんっ……♪　隊長さま……またオチンポが強くなったんじゃあありません\n……！？　やっ……ズリュズリュ胸が貫かれて……腰が砕けそう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あぁっ……♪　はぁっあぁっ、あっ、ぁっ、あぁああ……♪　オイルでネチ\nャネチャになった乳房とオチンポがぶつかると、っあぁああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「身体の奥っ♪　貫かれるような甘い衝撃がはしりますぅ……♪　んぁあっ…\n…い、いやだ♪　私はご奉仕する側なのに、っああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「胸が蕩けてしまいそうっ……！　あっ♪　だって、だって隊長さまのっ、隊\n長さまのがスゴすぎるからいけないんです、……はぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私の胸……大きいって評判ですのに、それでもオチンポ全部を包みこめない\n……♪　なんて女泣かせな逞しいオチンポなんでしょう、んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……ん？　どうしはりました？　ふふ、出したくなってきましたか……？　\nいいですよ、何度でも好きなだけ出してください……貴方のモンです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私の胸、は……隊長さま専用のシゴき穴……。んっ、精液をいつでも搾り出\nすための、射精穴……。ヌキ穴じゃあございませんか……遠慮なく♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私も……。ぁっ……扱き出すお手伝い、させてもらいます……。さぁ……さ\nぁ、ビュビュッと景気よく……どうぞ、どうぞ……。んぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んはっ……♪　はぁああっ、あぁ……あああっ♪　出ました……あっついの\nが……私の胸に……！　ッぁ……なんて勢い……すごいぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「爆発したみたいに、ドビュドビュ出てきますっ……♪　ふぁあ……、精液の\n臭いが胸いっぱいに広がって……。頭がクラクラして……んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ♪　またビュルビュルぅって……！　打ち上げ花火みたいです……っ…\n…。あぁああ……オイルが全部流されるくらい、えげつない量を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「こんなに出されてしまったら、胸が重くて重くて辛抱たまりません……♪　\nあぁ……ブルッブルドロドロのゼリーみたいな濃いぃ精液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「いつもながらに、元気すぎて度肝抜かれてしまいます……。んぁあ……べっ\nたり乳房に貼りついて……。っはぁっ、はぁっ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「だめです、私……完全に火ィついてしまいました。私の中に棲むメスが……\n発情して、疼いて……もうオチンポ様から離れられん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ねぇっ……ねぇ、ねぇ……♪　隊長さまぁ……もう一度、もう一度パイズリ\n……させてくださいっ……もっとオチンポ様にお尽くししたいのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ほらっ……あああっ♪　真っ白に濁った精液ごと……♪　オイルと、私の汗\nと、混ぜ合わせて……これを油に絡みつかせたいんです、……ンッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「わかります？　胸と胸の間……！　あっ♪　谷間に糸引く精液の粘着力……\n♪　こんなの、アソコじゃなくて胸でも孕んでしまいそう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「っはぁっ……♪　はぁっ、あぁっ、あぁ……♪　優れたオスの、搾りたての\n生精液……。それを胸のいたるところに塗りたくって……あぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「強い殿方の、強い肉棒にお仕えする……♪　これが女の悦びなんですぅ……\nっ……！　どこまでも、どこまでもついていきたくなる……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……うふふふっ♪　隊長さまも、同じ気持ちでしょう？　オチンポがまた硬\nぁく、太く……大きくそそり勃ってきました……。素敵なご馳走……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「絶対に、他の女には渡しません……。私の、私のモンです……コレは♪　は\nぁっ……ニチャニチャと胸で刺激すればするほど強くなるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ドタプンッ、タプンッと乳房の全てをぶつけても、ビクともせぇへん……♪\n　むしろ弾き返してくるくらい……。んぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「好きっ……好きぃ……♪　隊長さまの猛々しいペニス、オチンポ、オチンチ\nンが私は何より好きなんですう……！　もっと、もっと揉みしだきたい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私の胸をぜーんぶ堪能してください……♪　ッぁ……ンン♪　乳首も、ええ\n具合に勃起してコリコリです……。乳輪も、ぷっくり盛り上がって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私の女という女が、母性という母性が……隊長さまに、一途に反応している\nのがわかりますか……っ。はぁっ、はぁ、こすりたい、絡めたいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「まとわりつかせて……グニュグニュしたい……♪　あぁっ……、胸の鼓動が\n速くなって、体温が上がってきて……もう夢中です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっ……あぁんっ、パイズリ、パイズリ好きなの……っ。ご奉仕気持ちいい\n……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私の純情……隊長さまにお伝えしたい……。っぁっ……♪　隊長さま……、\n私……私、果ててしまいそうです。胸、だけで……んぁあぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「一緒に……一緒に達していただけませんか……っ。一緒に、どこまでも昇り\nつめたいんですっ……はぁっ、はぁ……このぶっといオチンポで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「チンポで、男根でっ……私のはしたない、デカ乳を昇天させてくださいまし\n……！　っあぁっ……♪　隊長さまのチンポ、チンポ、好き、好きぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「愛してるんです……っ！　だからもっと、精子をかけて汚してほしい……♪\n　はぁっ、あぁっ、肌という肌を純白に染め上げていただきたい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「この胸が隊長さまのモンだって証をください♪　外でだって、ハマでだって\n、いつでもどこでも受け止める覚悟は既にキめていますからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「だから……だからくださいぃっ♪　ブリュッブリュの濃い精液ぃ……！　私\nのパイズリ穴にぶちまけて、支配してくださ……い、あぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んぁふぅうううううう♪　ふぁあああああ♪　んぉおおおっ♪　おぉおおっ\n、んふぅうううう～～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「コレっ……♪　これこれぇっ、これです私が欲しかったのはぁああ～～～♪\n　隊長さまのっ、あっつい精液、抜かずの二発目ェ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303302" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「極道のオンナが一番欲しがる、強い男の強い精液ィ……っ！　ああっ、二発\n目やのに胸がっ、内側から揺れるくらいビュービュー撃ちこまれてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あっあああああああ～♪　こんなんイクっ、イクに決まってるぅうう♪　あ\nぁああっ、こってり射精にイかされるぅ……あああっ、イクイクイクっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「至福の時です……ッ♪　んぁおっ♪　おぉっ、おぉおおんんっ♪　心臓の一\n番近くでっ、たっぷたぷの脂肪の塊に……ザーメンかけていただいてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「腰も膝もガクガクいわせて絶頂中ですぅ……♪　んぁああっ♪　嘘みたいに\nドクドクっ、ドプドプ……。しつこくて長くて最高ぉおお……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ンふぅうううううっ♪　ふぅっあっあっあっあっ……♪　あひっ、ひぃっ…\n…ひぃ……っ♪　す、すみませんっ……イキすぎてっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303307" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「わ……我を失ってました……。はぁっ……はぁ、ご、ごめんなさい……。仕\n事でも、こんなにわけがわからなくなることはないのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「いつも隊長さまだけが、私をここまで狂わすんです……。……ふぅううっ…\n…。スッキリしましたか？　これで当分、抜かずに済みますね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303309" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「え？　他の女の子たちに嫉妬してヤキモチで抜いたのか？　……ふふふ、そ\nうですよ。何も卑怯じゃあありません。策士といって欲しいですねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ッぁっ……♪　イッく……って、あっ！　た、隊長さま！？　どうしたんで\nすか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「急にオチンポ抜いてしまって……、っんんんんっ！？　ま、待ってください\nっ、……あっ♪　顔っ……顔、に……んぷっ！？　ぷぅうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んぁっ♪　んぉぁあっ♪　あぁ……ッ♪　か、顔に、顔に出すなら……狙っ\nて全部、かけてください……こぼさずに……。んぁふぅうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あつっ……あっついっ……！　あは……っ♪　んぁああ……♪　何ですのん\n……、あっ♪　大サービスの大盤振る舞い……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ♪　私が精液を欲していたから……あんっ♪　こうして顔に、一\n番臭いがキッツくわかる鼻のあたりにかけてくだすったんでしょう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「いきなり、強引だったから驚きましたけど……。んっ……♪　確かに濃厚な\nザーメン臭……高価なパックよりも効きそうなドロドロの子種♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「これほどイイものをいただいて、文句を言うのも野暮ってもんです……♪　\nはぁっ、はぁ、はぁ……ヌルヌルしていて色も真っ白ぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、二回目の方が勢いも量も凄まじいって……一体どういうことなんです\n？　一発ごとに強くならはるから……全然目ェ離せません……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303408" ]},
		{"command":[ "SETIMAGE", "0", "still_00003303_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「……私の水着が刺激的すぎたからたくさん出た？　あらあらあら……。そん\nなこと言われたら、ずっとこの姿でいたくなってしまいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「たまには……違う服装でスるのもいいかもしれませんねェ……。ふふふ、覚\nえておきますから……。また、別の服でもお願いしますね……♪」", "NORMAL" ]},
