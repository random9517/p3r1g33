		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あら……どうしたんですか？　森の奥に来るなんて……。えっ？　こっち？ \n　こっちってどちらですか？　あっ……ま、待ってください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「もうっ……。いきなり走り出すから、何かあったのかと思ったじゃないです \nか。えっ？　二人きりになりたかったから？　ま、まぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それならそう言ってくだされば、私はいつでも……。でも、そうですね。私 \nも……その、あなたとは二人きりになりたかったです。お話をしたり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00017202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「木々のざわめきに心を和ませたり……。静かな時間を一緒に、とひそかに思 \nっていましたけど……。って、きゃっ！？　な、なんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「た、た、た、隊長さん……！？　い、いきなり胸を鷲掴みにして、襲いかか \nってくるなんて……一体どういうつもりですか、……あっ、あっあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「こ、困ります……！　ここは……私たちエルフの住まう場所……！　つ、つ \nまり……こんなところで淫らなことをしていたら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「だ、誰かに見られてしまいます……っ。あっ……！　お、大きくなったちん \nぽを、私のお尻にくっつけるのはやめて、ください……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「わ……わかりました、あなたがしたいのなら、私はかまいません……！　で \nすから、どうかここではなく別の場所で……、っひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「む、胸をこねまわさないでくださぁいいい……っ！　あぁっ、ち、違うんで \nす、私の乳首は……あっ、も、元々大きくて、ですから……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「隊長さんの愛撫で勃起しているわけ、では……！　あっ！　あっぁっあっ、 \nい、いけません……聖なる森で、エルフの森でこんな、……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「だ……めぇ、あっ、乳首、クリクリしないでくださ……あんっ！　ちんぽを \n押しつけ、ないで……あっ、ま、まさかここで入れるつもりですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁっ……ううっ♪　あまり感じさせないでくださ、いぃ……！　まんこが \n湿って……あああ、濡れて、しまうので……入っちゃいます、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「だめっ……だめ、だめですっ、本当に入ってしまいますっ……ああああっ！ \n　ニュルニュルちんぽ、まんこになすりつけられて……！　っあふぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んッ……はぁっあああっ……！？　あ……嘘です、本当に入って……んぁあ \nああっ！　まんこに、ちんぽ入っちゃいました……！　っあっあっあんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ん、くぅううっ……！　大きい……！　隊長さんのちんぽ、熱くて、太くて \n……長い、です……！　あっ、あ、う、動かさないでくださ、いぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「いやらしい声が漏れてしまって……っ、うっ♪　本当に、誰か来ます……！ \n　こん、な姿、誰かに見られたら……っ！　あ……ッ、あ、ぁ、あ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ど……どうしてちんぽを抜いてくれないんですか……っ？　んぅっ、む、む \nしろ奥まで突き入れて……はぅっ、ずるんと引き抜いて……あっ、くっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私の中……まんこをずぽずぽ、ちんぽが出入りしています……っ。んん…… \nっ。あぁ、なんて強引な……っ。あっ、ぅ……うぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「いやいや言いながらものすごく濡れている、ですか……？　そ、それは…… \nっ。さ、最近あなたに会えていなかったから……！　それ、にぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「心の準備が出来る前に、突然襲われて……か、身体が勘違いしているんです \nっ……。あっ……今日はセックスをする日、だって……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ちんぽがまんこに入ってきた、から……っ、このままするんだって、期待し \nて……！　まんこがヌルヌルに、なって……！　っふぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「な、なぜ説明の途中、で、激しく腰を動かすんですか……っ♪　んぁあっ、 \nこのままでは感じてしまいます、……いいえ、もう感じているのにぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「やめてくださいと言えなくなって、しまいますっ……。あうっ♪　だって、 \nこれっ……セックス気持ち良くて……ひ、久しぶりでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私だって……私だってずっとしたいって思ってました、あっ♪　でも森でこ \nんなことぉおっ！　はぅうっ！　あっ、い、いけません、速く動かないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんっ、あんっ！　声が抑えられないぃい……！　ちんぽっ、ち \nんぽが私のまんこをずっぽずっぽ突いて、貫いて……んはぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「メガネが揺れる、くらいぃいっ♪　んはぁんんんっ♪　頭がヘン、になるく \nらい……ああああっ、ものすごい勢いでセックスされてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっぁっあっ♪　こんなっ、高速で腰を振られたらっ……おかしく \nなってしまいます、あぁっ、ひぃんっ！　まんこが反応してるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あなたのちんぽを歓迎して、うごめいてしまってますっ……！　あああああ \n……！　は、恥ずかしい……っ、まんこ気持ちいい、まんこすごいぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっあっ、ちんぽ、ちんぽを入れられると私……身体が熱くなって、勝手に \n腰が揺れて、しまいます……あっ、あっ、森で、森でするなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「いけないのに、絶対にいけないことなのに……っ、あぁあっ、も、もうやめ \nてほしくありません、ちんぽしてください、まんこにちんぽしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んっあっぁっあっぁっあっあっ……！　呼吸、すらしている余裕がない、く \nらいぃっ！　ちんぽが、まんこにこすれてっ、ふぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私の一番奥っ、じゅぷっ！　ぐちゅって突いて、ますぅっ！　あぁっ！　あ \nっ、あぁっ、声ぇええっ、声、まったく我慢できま、せんんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ッああああああああっ……！　お願い、です、隊長さん……！　このまま私 \nのまんこに出してください……あっ、ニンゲンの精液が……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「森の中に落ちて、いたら……！　こぼれていたら見つかりますっ、ですから \n全て私のっ、まんこ、まんこの中に、注入して、こぼれないようにぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「大丈夫です、今なら私のまんこっ……精液を一滴残らず吸い上げられそうな \nんですっ、ですから出して……出してください、出して、ぇ、えええっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あぅううううっ♪　あぅあああああああっ♪　精液っ、ニンゲンの精液っ… \n…隊長さんの……あなたの精液がまんこにぃいいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああああっ、精液注がれてイッてしまいます……っ、あぁああっ、イキます \nっ……！　はひぃっ♪　ひぃんっ、あんっ、んんんんん～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっ……はぁっ♪　だ、め……♪　イッている場合ではありませんんっ…… \n、精液、こぼさないように吸い上げ、ないと……いけないのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あぅううっ！　熱い精液を直接まんこで感じてしまったら……またイキます \nっ！　あっ、ごめんなさい……気持ち良すぎて精子こぼれて……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「溢れてしまいますぅうううっ……！　ああああっ、それなのにイキますっ… \n…まだイクぅっ……！　射精されるの気持ち良すぎますぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっあっあっぁっ……♪　しゅ、しゅごいぃいい……♪　あぁっ……♪　あ \nなたの精液が、私のまんこいっぱいに満ちていきますぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……♪　いつ出されても、ニンゲンの精液はすごいです……っ。熱 \nくて、粘り気が強くって……まんこの一番奥にたっぷり溜まりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「と、うっとりしている場合ではありません……っ。この森でエルフである私 \nを抱く……。子作りをするだなんて……なんて大胆で怖い者知らずな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ま、まあ、それであなたがスッキリできたのでしたらいいのですが……。っ \nて、あらっ？　どうしてまんこの中で、ちんぽがまだ硬いのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「むしろ精液を出す前より……？　っあっ？　ま、待ってください……！　う \n、動いてはいけませんっ、動いたら……精液があふれて……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ、い、一度出しただけでは全然満足できなかったんですね…… \n！？　そ、それならば仕方ありませんが……。んぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あ、あまり激しいのはだめ、です、精子がこぼれます……！　それ、にっ… \n…ふぁっ♪　精液でぬめりが大きくなって……んぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あなたのっ……ちんぽが私のまんこをめちゃくちゃに掻き回して、います… \n…！　あっ……これでは私も気持ち良くなってしまって……っ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あ、愛液まで土の上に落ちてっ、つたってしまいますっ……。ですからする \nのなら、そーっと優しく……！　っんんんっ！　だめ、だめですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あぁ♪　セックス、セックス気持ち良すぎて私の理性まで、なくなってきて \nますぅっ……！　あはぁっ、ちんぽ、ちんぽおっきい……っ、太いぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ひぃんんっ♪　もう……どうなってもいい、いいですぅっ……！　あっ！　 \nぐちゅぐちゅすごい水音がしてます、私も声を抑えられませんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んっ、ぉおおっ♪　こんなのバレてますっ！　森中に私たちのセックスっ、 \n種付け、子作りバレてますっ！　んぉぉっ♪　ほぉっ♪　おほぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「イグッ……！？　イクぅっ……！　んぁおおおっ♪　い、いけませんっ…… \n♪　叡智を司るエルフっ、エルフがこんな雄叫びをあげてっ、イグぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「肉欲に負けっ……、んぉおおおっ♪　イグぅううっ、イグの止まらないぃい \nいい……！　ちんぽっ、ちんぽ、セックス気持ちいぃいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「も……もう我慢できません、私もっ、私もお尻を揺すってっ……腰を動かし \nてちんぽ味わいます！　おっ♪　おぉおっ、精液まみれのちんぽっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んはぁああっ♪　イグぅうっ……！　突き上げられるたびにっ、簡単にイク \nぅうっ……！　んふぁああっ♪　あぁっ、み……見てくださぁいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私とっ、隊長さんが繋がっているところぉっ♪　二人で協力してっ、赤ちゃ \nんを作っているところ、見て……見てぇええっ♪　んほぉっ、おっほっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「隊長さんっ！　隊長さんのちんぽ、逞しいこのちんぽから、もう一度精液を \n注入してくださいっ！　もう、もうこぼれてしまってもいいですのでっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「少しでもたくさん……私のまんこに出してくださいぃいっ♪　んぁあっ♪　 \nあっぁっああああっ……！　イグ……何度でもイキますぅううう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私がイクのに合わせてっ、まんこ締めつけますからっ！　ちんぽから精液っ \n、精液くださぁいっ！　ああああ……、イクイクイクぅうう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んんんんんぁああああああっ♪　ふぁあああああッ……！　ありがとうござ \nいます、ありがとうございますぅううう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「届きましたぁっ、あなたの精液っ……！　私のまんこに到着しましたぁっ… \n…♪　んぉおおっ♪　おぉっ♪　出てます、出てます出てますぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「絶頂しながら、大好きな森の中でっ……！　精液ドクドク注がれるのって気 \n持ちいいんですね……！　あああっ、今までまったく知りませんでした！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私の中にっ……♪　んぁ、おまんこにこぞって集まってくる、愛しい愛しい \nあなたの精子……♪　二回目なのにこんな量をくれるなんてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あなたはすごいですっ……！　あぁあっ、あなたとセックスして良かったで \nす、あなたとしか、したくない……！　あなただけでいいっ……あ～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んっぉっ♪　ふぉっ……♪　まだ出ています……！　尽きることのない精の \n濁流……全身が痺れるようで……！　あああっ、もうだめですぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「……ん……。はっ！？　あ……ご、ごめんなさい……。あまりに気持ちが良 \nすぎて、その……軽く失神してしまっていたみたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あぁ……。結局、精液も愛液もだらだらと、森の土に……。私たちの足元に \n垂れ流してしまいました……。でも、仕方ありませんよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「こんなにすさまじい量の精液……。いくら私のまんこが努力をしたところで \n、全て受け止めきることは難しかったのですから……。ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「え？　仲間にバレてしまうのはいいのか、ですか？　もちろん良くありませ \nんよ。でも、そうなってしまったからには受け入れることにしました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あひぃいいいっ♪　な、なぜ私の身体にっ……あぁあっ♪　精液をかけてい \nらっしゃるんですか……！？　あっ、ぁっ、熱いです、んああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「いやぁ……っ♪　森の中に、ニンゲンの精液の香りが広がって……！　そ、 \nそれにまんこがとても寂しがっています！　あっ、もう一度中に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「んぅううっ！　だ、だめです、精液で滑って……中に入ってくれません！　 \nあっ……！　す、すごい量……！　こんな量を撒き散らしたら……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あなたのすごさに仲間たちが気付いてしまうぅ……！　あぁ、いやらしい臭 \nい……っ！　あっ、ぁっ、ネバネバが身体に付着して……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あっぁっ♪　川の水で洗っても、こんな強い臭い……とりきれません！　あ \nっ、私がしていたことが明るみに出てしまいます、それなのに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「浴びたいです！　もっと浴びたいっ……。私のあらゆるところに、あなたの \n臭いをつけてください……！　あぁっ、あたたかい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「はぁああ……♪　はぁ、はぁ、はぁ……♪　すみません、幸せで、ぼーっと \nしてしまってぇ……♪　エルフの森で精液を浴びるなんて経験……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00017202_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「絶対に、他の子たちはしたことないと思います……。それなのに、私……♪ \n　まんこにも身体にも、こーんなにたくさん浴びさせていただいて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ふぁああ……♪　息をするたびに、濃厚な性の香りが鼻をつきます……。私 \n、どうやら悪い子になってしまったみたい……。嫌じゃないんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_0204409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「あなたが教えてくれるたくさんのいやらしいこと……。それを楽しみにして \nいる自分がいて……どうなってしまうのか、少し怖いです……ふふふ♪」", "NORMAL" ]},
