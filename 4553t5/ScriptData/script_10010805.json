{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はあ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「すごいねカツマちゃん！　あのセレーナ先生を一撃で！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「本当に。惚れ直……んっ、ごほん！　改めて、感服致しましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……うん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "廊下でのひと悶着をなんとか抑え込んで、促されるまま入ってみれば……これ\nが、教室？　ホントどうなってんだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、さっきから元気ないね。大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「朝からお疲れなのでしょう。私、疲労に良く効くハーブティーなど持参して\nおりますので、よろしければお飲みになります？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや……せっかくだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "喉は渇いているが、ルナテミスに茶など振る舞われても、却って疲れそうだ…\n…。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかしずっとついてきやがるなこのふたり。クラスメイトって設定なのか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「また騒ぎを起こしていたのですか。この教室にまで喧噪が聞こえていたので\nすよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おっと……おまえもご登場かよ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「これだから体育会系はやかましくて嫌いなのです。もっと知的に生きられな\nいのですか？　ここは神聖なる学び舎なのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……こいつは、基本的な性格はそのままみたいだな。\nさしずめ「口うるさい委員長」ってところかあ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オボロさん？　カツマさんは悪くありませんのよ、悪いのは私――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ううん、先生が悪いんだよ、カツマちゃんが来る途中、私を守ってくれたの\nがまずきっかけだっただけで――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あなたたちも、いつもいつも飽きもせず、この男に肩入れしすぎです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こんな、根性だけはあって機転も効いていざという時だけは頼りになるよう\nな男の、一体どこが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「本当に。よく観察していらっしゃるのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うぐ。それは……その……こ、この男が悪目立ちしているだけです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108080005" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……なんか、散々な言われようもされているが。まあ、それが平常運転か。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "にしても皆、やっぱり役回りがおかしい。揃ってなんか、おかしな物でも食っ\nたのか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ！　チャイム！　先生来ちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ん？　そりゃ、来るだろうが……なんだ？　それだけじゃないみたいな驚き方\nだな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマさん、宿題はやってきましたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108080005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いつものように忘れたというのであれば、仕方ないのでウチのを写させてや\nっても――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108080006" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「それなら私が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108080005" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いえ私が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108080006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そしてなぜこうも好意的なんだ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつも馬鹿にされている幹部たちに囲まれて、チヤホヤされてもなあ……うー\nん。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はーいみんな席に着いてー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010108080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ああ、エファが教師役かあ？　それはまあ、合っている気もしなくもないが。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「間に合わなかったようですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108080007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あーあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108080006" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマさん……ご武運をお祈りします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108080007" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ん？　ご武運……？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかもなんだ？　周囲の席に慌てて座った連中からの、同情の眼差しは。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はーい、まずは宿題を提出してもらうわよー。机の上に出して頂戴」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010108080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、言われてもな。俺の場合、宿題ってなんだ？　ってところからだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「んー？　カツマくん、また宿題を忘れたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010108080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はあ……まあ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そういうことにならざるを得ない、よな？　で、だとしたらどうなるってんだ\n？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「宿題を忘れた子にはお仕置きが必要よねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010108080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、お仕置き部隊のみなさーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010108080005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「はっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030108080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あー……なんだ。またこれか。こいつらか。このパターンなのか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「宿題を忘れた悪い子に、お仕置きしちゃってくださーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010108080006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「はっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040108080001" ]},
		{"command":[ "SETCHARA", "1", "char_00000803_01", "3", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＣ" ]},
		{"command":[ "SETTEXT", "「お任せ下さい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_050108080001" ]},
		{"command":[ "SETCHARA", "2", "char_00000803_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "周りの連中……さりげなく距離を置いてるし。クソ、さっきの眼差しはこうい\nう理由かよ！！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}