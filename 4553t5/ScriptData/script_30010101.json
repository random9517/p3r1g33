{
    "scriptCommands" :  [
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0004" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_015" ]},
        {"command":[ "PLAYVOICE", "001_0103101" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「……ふん、き、来てやったぞ。それで、私を呼び出して……何をさせるつも \nりだ？」", "NORMAL" ]},
        {"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
        {"command":[ "DISPNAME", "TRUE" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103102" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「な、なに？　ご奉仕をしてほしい、だと……？　奉仕とは……あれか？　部 \n屋の掃除とか肩もみとか、そういうことか……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103103" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「確かに、パーフェクト・メイデンたるこの私がするようなことではないが… \n…貴様は特別だ。してやってもいいぞ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103104" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「な、なに？　違う？　口でするご奉仕だと……？　ま、まさか、手を使わず \nに口で掃除しろと！？　そんな屈辱的なことをさせるつもりか！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103105" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「だ、黙れ！　誰がバカだ！　貴様の説明が悪いせいだろう！　私にもわかる \nように具体的に言え！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103106" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ふむふむ……口での奉仕、とは……貴様のアレを、口で……舐め……たり、 \n吸った、り……って……なっ、ばっ、バババババ、バカ！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103107" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「このバカ！　変態！　鬼畜！　何がご奉仕だ！　そそそんな破廉恥なこと… \n…出来るわけないだろう！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103108" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「……なにっ！？　ほかの女幹部どもはできている、だと……？　まさか…… \nぐむむむ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "2", "CENTER", "0" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103109" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「バ、バカにするな！　私は断じて、他の女幹部に負けはしない！　パーフェ \nクト・メイデンたるこの私に出来ないことは何一つないのだ！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103110" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「あ、ああぁ……なんて、破廉恥なんだ……んちゅっ……うぅっ……き、貴様 \n、ちゃんとこれを風呂で洗っているんだろうな！？」", "NORMAL" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00000101_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103111" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「はあぁ……ほ、本当に他の女幹部は皆、こんな奉仕を貴様にしているのだろ \nうな……んんっ、ちゅ……ぺろ……ううっ……んちゅ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103112" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ええっ！？　も、もっと他の場所も舐めろだと！？　き、貴様ぁ、私に指示 \nをするつもりか！」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103113" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「く、くぅ……わ、わかっている！　決めたからには、ちゃんと奉仕してやる \n！　だ、だから急かすなっ！」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103114" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「れるぅ……くふぅ……ああ、すごい匂い……これが、男の匂いなのか……く \n、くぅっ……はぁ……くふぅ……ぺろぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_02" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103115" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「んちゅぅ、こ、こんなに硬くなるなんて……き、貴様のモノ……血管が浮き \n出して……はちきれそうではないか……んむっ……はあぁ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103116" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ちゃ、ちゃんと言えとはなんだ！　こんなモノを舐めてやっているだけでも \n光栄だろうが！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_01" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103117" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「な、何……他の女幹部はみんな言っている、だと……くうううっ……バカに \nするなよ……そんな言葉を言うことぐらい、私だってできるっ！」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103118" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「すぅ～、はぁ～……えっと……ち、ち……ちちちち、チン、ポ……だ。貴様 \nのチンポに血管が浮き出して、はちきれそうだと、言うんだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_02" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103119" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「え！？　こ、これは気持ちいいという証拠なのか……！？　こ、こんな状態 \nなのに……チンポというのは、不思議なものなのだな……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103120" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ば、馬鹿を言え！　ち、チンポに興味があって見ているのではない！　ああ \nっ、また卑猥な言葉を言ってしまったではないかっ……恥ずかしいっ……！」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103121" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「それよりも、まだこの口での奉仕は終わらないのか？　ず、ずっと舐めてい \nると、おかしくなりそうだ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103122" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「な、何っ、このチンポを咥え込めば早くおわるだと！？　き、貴様、私に舐 \nめさせるだけではなく、口につっこもうと言うのか！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_01" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103123" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「できないなら、って……貴様、なんだその言い方は！　私に出来ないことな \nどないと、何度も言っているだろうっ……！」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103124" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「んぐっ、んむうぅぅぅ～～～！　ん、んん……んふ、じゅぷっ……ちゅるっ \n……ど、どうだ？　チンポを咥えるくらい、わけない、ことだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_06" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103125" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「んくんく……ちゅっ、ちゅっちゅっ……ちゅぱちゅぱ……っうふぅぅぅ～～ \n……んん、んんんっ、んん……ちゅぷっ……はぶっ……んんっ……おえぇ」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103126" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ふぐっ、むぐううぅぅ～～～……っちゅぽ、ちゅぽ……んぷ、んむ……ちゅ \nっちゅっ……ぅく、ふっ……けほっ、かふっ……ん、んむ、んむぅ……っ」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103127" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ち、チンポが舌に当たって気持ちいいとか、いちいち言わなくていい！　恥 \nずかしくなってしまうだろうがっ……ふっ……かふっ……んむぅ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_05" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103128" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「んっく、んくぅぅ……ふ～、ふ～……うぐ、ふぁ、終わりは、まだなのか？ \n　んぼぁ、あぶぶっ……ふぅ……ぶばあぁっ……んふぅっ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103129" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「んぶぅあっ、んんん、うあああ……な、なんだこれは……。ち、チンポが、 \nドクドクって脈打って、ますます固くなって……なにか、くるっ……！」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103130" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ふもぶぅぅうぅ！　ああああ……ふぼぁあああ、んんんん、んうぅ……んぐ \n、んぐっ……あぐぅっ」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103131" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ん、ぷぅっ……く、口の中がすごい匂いだ……鼻に抜けてくるイヤらしい匂 \nいで、どうにかなりそう……はぁっ、はぁっ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103132" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「んんんんぐ……んく、んく、んく、んん……くふぁああ……んっ、ちゅばぁ \n……あああああん！」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103133" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「はぁ、はぁ、はぁ、はぁっ、ああぁ……い、いまの粘っこくてどろどろした \nのは……もしかして、せ……精液、じゃないだろうな！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_03" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103134" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「あ、当たっても嬉しくない！　き、貴様っ、私になんてものを飲ませたんだ \n！」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103135" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「せ、精液は、その……あ、赤ちゃんを……作るためのもので、飲みものでは \nない……だろう……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_01" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103136" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「何！？　だからこその奉仕だと！？　み、みんなこの、せ、精液を飲んでい \nるというのか……く、くぅううっ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103137" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「な、なに……チンポが気持ちいいと沢山、出るというのか……わ、私の奉仕 \nが良かったから、だと……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103138" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ま、まぁ……と、当然のことだな。パーフェクト・メイデンであるこの私が \n奉仕したのだから……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_02" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103139" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「そういうことなら、貴様が精液をたっぷり吐き出してしまうのも仕方ない。 \n許してやろう……ふふん」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103140" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「な、なんだ！　急に頭を撫でて、何のつもりだ？　い、いや！　その、イヤ \nというわけではない……ちょ、ちょっと、驚いただけだ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103201" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ああっ！？　な、なんだ……終わったはずなのに、ち、チンポがまた大きく \nなってくるぞ……す、すごい……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103202" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「赤く……大きく膨れて……はぁ……んんっ……なんて、破廉恥なんだ……く \nぅ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103203" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「こ、これでは苦しいのだろう？　き、貴様がよければ……また、奉仕をして \nやってもいいのだぞ？」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103204" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「そ、そこまで頼まれては仕方ないな……貴様には特別だ、光栄に思え」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103205" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「んむぅっ……ほ、ほら、また咥えてやったぞ……せ、精液をだせ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_05" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103206" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「んちゅ……れろ……んんくっ……んむっ……はあぁ、臭い……んんっ……ヌ \nルヌルしてぇ……いやぁ」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103207" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「はあぁ、ちゅぶぶぶっ……んんっ……あぁ、さ、先っぽから汁が……いやら \nしい汁が……うぅ、はあぁ……ああぁ……ちゅるるっ」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103208" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「んんん、んぐうぅ……んんっ！　きゅ、急に腰を動かすなっ……んんん、ん \nんうぅ、んぐああっ、んんんあっ、あああああ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103209" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「うぐっ、ううう！　んぶ、んんっ……うう、はぶるぅ！　ち、チンポが頬に \nあたるぅっ……んん、ああぅ、ひあっああ、あぐ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_06" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103210" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「い、いや……わたしは、ぱーふぇくと、めいでん……だ……できない、こと \nは、ないっ……んんんんんでゅる……うっ、ぐっ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103211" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「はぁん……ああん……んく……はむぅっ……んんっ、ちゅっ……ちゅぶぶっ \n……れろれろっ……はあぁ……あむっ、じゅぶぶっ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103212" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「ち、チンポが美味しいなんて、そんな馬鹿なこと……あるわけ、ないだろう \n……ふざけたことを言うな……じゅるる……じゅぶぶ、はぁはぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_04" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103213" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「んんっ……そんなことっ……れろっ……あるわけが……ないっ……れろれろ \nっ、貴様のチンポが美味しいなんてぇ……くはぁ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103214" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「はぁ……凄い匂いだ……き、貴様の精液の匂いが、まだ……こびりついてい \nるみたいで……んちゅるぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000101_01_05" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103215" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「え、エロい表情なんてしていないっ……！　こ、この部屋が暑いんだろうっ \n……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103216" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「バカを言ってないで、精液をだしたら、どうだ？　じゅるる……じゅぶぶ、 \nはぁはぁ……れろれろ、はあぁ……んんっ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103217" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
        {"command":[ "SETTEXT", "「こ、この私が奉仕しているのだから、我慢、しなくていいのだぞ……」", "NORMAL" ]},
        {"command":[ "WAITINPUT" ]},
        {"command":[ "PLAYVOICE", "001_0103218" ]},
        {"command":[ "SETNAME", "ルナテミス" ]},
