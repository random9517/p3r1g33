{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "095_0104101" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「……テメー、マジで悪趣味だな。普通、こんなサメ臭い女とこんな真似しよ\nうだなんて、思わねーだろ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104102" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ああ？　だってよ～～……この肌だぜ？　青い、ザラザラのクソみてーな肌\nの女なんてよぉ……御免こうむるってなもんだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104103" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「……チッ、テメー、クソ野郎なのに優しいからムカつくぜ……ったくよぉ…\n…マジで、趣味悪ぃな……ああ、もう……クソ……クソ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104104" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「クソクソうるせーだとぉ？　うっせーな……心の準備が出来てねーんだよぉ\n！　ああ、もう、マジでクソったれだぜ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104105" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「や、やめろよ、そんなに見るんじゃねーって……恥ずかしいんだよっ！　お\nいっ、いい加減にしろってーの」」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104106" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「や……止めてくれ……ああ、身体がジンジンする……テメーに今までさんざ\nん弄ばれちまったからな……身体が勝手に反応しちまう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104107" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「胸、触んなよ……あっ、ああ……変な声でちまうじゃねーか……クソッ、恥\nずかしい……恥ずかしくて、死にそうだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104108" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ん……んん、触られたところが、あ、ああ、熱い……はぁ、ふぅ……汗が、\nこんなに溢れてる……んん、あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104109" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「股間も汗かいてる、だって？　そんなこと、いちいち教えてくれなくてもわ\nかってる……テメーのせいで濡れやすくなっちまったんだよっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104110" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……もういいだろう？　か、かまわねーから、挿れてくれ……\nさ、さあ、早く……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104111" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ふぐぅ！　あうぅく……はぁ、はぁ……すげぇ、こ、これが……チンポなの\nか……。マンコで味わうのは、初めてだぜぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104112" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「少し、痛ぇけど……でも、全然平気だ。ミュータントをナメんじゃねーって\nの……はぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104113" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ってかよぉ、これが人類のセックスなのか……はぁ、ふぅ、ま、まさか立っ\nたままブチこまれるとは思ってなかったぜぇ……ん、んん……ひふぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104114" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「クジラや、アシカ、ジュゴンなんかの哺乳類の交尾は見たこと、あったんだ\nけどよぉ……やっぱ水中と地上じゃ、全然違ぇんだなぁ……はぁ、ふぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104115" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「サメの交尾も、そんなに変わんねーよ……軟骨魚類だからな。チンポを体内\nにぶち込んで射精するんだ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104116" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「けど、ん、んん、こんな風に、腰を叩き付けられるなんて……はぁ、んん、\n思っても、見なかったぜぇ……あっ、ああ、はぁあぁん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104117" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ、い、痛く、ない……ってか、気持ちいいぜぇ……ああ、クソ\n……テメーにこれまで可愛がられた結果だな……ちくしょう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104118" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「あ、あああ……腹の中を、チンポがえぐってる……ぐぅ、ひうぅう……小さ\nな隙間が、こじ開けられてる……ふぐぅ、ひゃうぅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104119" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……濡れてる……マンコが、ドロドロだ……へへへ、アタイ、ヤ\nベーな……旧人類に、こんなに感じさせられちまうだなんて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104120" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ったくよぉ～～……いやらしい身体にされちまったもんだぜぇ……このアタ\nイが……泣く子も黙る、この『シャークガール』様がよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104121" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はー……あはぁぁ……ヤベぇ……身体が、クソ熱いぜぇ……はぁ、はぁ……\n身体が溶けちまいそうだぁ……んん、あはぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104122" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「チンポが……ん、んぐぅ……中でスルスル動いてる……マンコが、ドロドロ\nだぜぇ……はぁ、あひぃ……クソ……気持ちいい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104123" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ああ、ケツに腰がぶち当たって、尻叩きされてるみてーだ……やべぇ……濡\nれるぅ……あ、アタイ、そんな趣味無ェのによぉ～～～……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104124" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「お、おい、何笑ってんだよぉ……くそっ、あとで、テメーの尻に噛み付いて\n歯型付けてやっからなぁ……はぁ、ふぅ……んんぅん……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104125" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ふぐぅ！　あうぅぅぅ……へ、へへへ……すげぇな……チンポって……はぁ\n、ふぅ……交尾がこんなに気持ちいいだなんてよぉ……知らなかったぜ」」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104126" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……旧人類が繁栄したのも、セックスがクソ気持ちいいからな\nんだな……へへへ、上手く考えたもんだぜぇ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104127" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ふっぐ！　ひやぁぁぁ……奥に、先っちょが当たるぅ～～……やべぇぇ……\nこれ、たまんねぇ……はぁ、はぁ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104128" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ンだよぉ～～……テメー、そんな目で見るんじゃねぇよぉ……恥ずかしいけ\nど、気持ちいいだろ……？　ふぐぅ、あふぅ……んくぅぅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104129" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ああああ、アタイも、腰が動いちまう……ダメぇ……ああ、クソッタレぇ…\n…腰、止まんねーよぉ……はぁ、はぁ……あぁぁぁあん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104130" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……お、おい、チンポ、震えてるぞ……精液、アタイの中にぶ\nちまけるってのか？　はぁ、はぁ……ま、マジかよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104131" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「チッ……しゃあねーな……い、いいぜ……出せよオラァ……アタイ、腹くく\nったぜ……はぁ、はぁ、あ、あああ……あはぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104132" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ひぃ！　ヤベぇ！　て、テメー、そんなに激しくされたら……あっ、あっ、\nダメぇ……ひっ、ひやぁぁ！　はぁ、あぐぅぅぅく……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104133" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「い、いいぜ……出して……アタイの中に、テメーのドロドロ。ぶちまけ……\nんぎひぃぃ！？　あぐっ！　ひやぁぁぁぁぁぁ～～～！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104134" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ぁ…………ぁ…………ぁぁぁぁぁ……ンだァぁ……これぇぇ……め、目の前\nが、真っ白に……ひぐぅ、はへぇぇぇ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104135" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ア、アタイも、イッた……ってのかぁ……？　はー……はー……マジ、すげ\nーな……ハンパねぇ……アタマん中まで、腑抜けちまったぜ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104136" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はー……はぁぁぁ……ヤベ、これ……マジ、気持ちいい……身体がクラゲみ\nたいにプカプカ浮いてるみてーだ……はー……んひぃ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104137" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「精液が……腹ん中、染み込んでくる……こ、これで、ガキが生まれる……か\nもしれねーんだな？　はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104138" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ミュータントのアタイと、テメーとのガキって、いったいどんなになっちま\nうんだぁ……？　そもそも妊娠、すんのか……？　わかんねー……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104139" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「ダメだぁ……今、アタイ、アタマがバカになってる……まあ、普段から相当\nバカなんだけどよぉ……へへへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "095_0104140" ]},
		{"command":[ "SETNAME", "シャークガール" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……と、とにかくよぉ……サイコーだったぜ、隊長さんよぉ…\n…へへへ……ま、また呼べや……いつでもマンコ貸すからよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00009501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}