		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「あなた女医の眼鏡に……んッ♪　アンダーリム、シルバーフレームにびゅる\nびゅる射精するのが好きなのぉ……？　本当にいやらしいんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんん～……♪　熱い雫が、次々に顔にかかってくる……。ぷぁ…\n…、とんでもない量ね、溺れてしまいそう……♪　あっ、ぁっ、あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「この濃さ……。れろっ、濃い味……♪　はぁんん♪　健康そのもので、大変\nよろしいっ……♪　ね～え、いつもこんなにたくさん出るの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「それとも～……わたしのおっぱいと、ペロペロが気持ち良かったから？　う\nふふっ、もしそうだったら嬉しいなぁ……。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「……ん～、ぁっ♪　あっ……♪　すごぉい……♪　息を吸っても吐いても、\n精液の臭いでクラクラしちゃう……。上手に出せて偉かったね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「先生は……、わたしは、いつでもこうしてあなたのおちんちんを楽に、健康\nにしてあげますからね。なんなら今度も眼鏡にかけていいし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「唇や、口の中……。あん♪　首や胸元……。どこに出しても受け止めてあげ\nられるから……イライラしたらすぐに呼びなさい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「おちんちんがよ。この、立派で精子のたっぷり詰まったおちんちんが、イラ\nイラしたらわたしにおねだりよ♪　ふふ、覚えておいてね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「わたしは、みんなの健康のために頑張るけど……。これはあなただけの特別\nサービス。せっかくなんだから、甘えて欲しいわ。ずうっと、ね♪」", "NORMAL" ]},
