		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「はぁい♪　お休み中にごめんなさいねぇ～？　ホズミ先生の定期健診よ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00020402_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「あなたったらなかなか忙しくって、わたしの医務室に来てくれないんですも\nの……。心配になって来ちゃった。迷惑じゃなければ嬉しいんだけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「ええ。そうよ。あなただけに特別。……だってあなたって、ダメっコで放っ\nてなんておけないわ。……ふふ、けなしているんじゃないのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「わたし……ダメな子にお願いされるのが好きなの。ダメな子ほど可愛くなっ\nちゃう。もう養いたい！　って思っちゃうくらい……うふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00020402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「さ、身体を見せて……。うん、うんうん。特に病気はしていないし、健康そ\nうね……。熱もないし。怪我もしてない。となると、後はあれかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00020402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「よりよい健康のために。女医のわたしがいいことを教えてあげる。最近論文\nで発表されたんだけどね？　男のコが元気でいるためには～……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「そぉーれ♪　こうやって、女の人と肌と肌で直接触れ合うの。知ってる？　\nスキンシップは精神的にも肉体的にもすごくイイのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020402_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「ふふ、どうしておっぱいを乗せたのかって？　それはもちろん、あなたがい\nつもコレを見てたからよ。どうせなら好きな部分がいいじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「……いつも激務のあなたには、身も心もうーんとトロトロに、ダメになっち\nゃう時間が必要。そして、定期的な射精が効果的……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「こうやってね？　身体に溜まった毒を搾り出すの。最初はやさしく……。っ\nふっ……ふぅっ……包み込んで、胸全体ですりすり撫でていって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「すこーしずつ、すこーしずつ、力を込めていくの……。もちろん、あなたの\n反応を見ながら、一番感じるところを探っていくわ♪　んッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「あなたはどれくらいの強さで挟まれるのが好きかなぁ？　……これくらい？\n　ふふ、もっと強く？　それとも、おっぱいでフニフニするくらい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「んんっ……。どこを攻められるのが好きかも知っておかなくちゃ。ええ、カ\nルテに記入するわ。そうして次回にしっかり役立てていくの……ふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「わたし、理系だから……。んっ、ぁんっ……♪　論理的にあなたの健康に奉\n仕したいのよね……♪　はぁ、はぁ、他のコには出来ないやり方で♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「体調管理も……。んっ……射精管理もしてあげたいの。あなたはね、わたし\nの言う通りにしていれば大丈夫よ。これは医学的なパイズリだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「けん、こうの為なのよ……♪　っふぅっ……、ふッ……んん♪　身体にいい\nからしているの♪　邪心なんてないわよ、……ほんとうよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「んっ……。ん、はぁっ……、はぁっ、はぁ……♪　ふぅんんっ……♪　はん\nっ♪　ンンっ、んん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「ね～え？　隊長さんのおちんちんって……いつもこんなに大きいの？　あっ\n、日常って意味じゃなくて……えっちな気分の時♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「医療的ご奉仕をしていて気づいたのだけれど……あなたのコレって、いわゆ\nる平均よりもずっと大きく思えるの。太さも、長さもすごい……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「ち、ぶさで……わたしの乳房で測ったところによると、硬さもおそらくトッ\nプ、クラスのはず……。女が見るだけで感じる名器だわ……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「こんなものを見せつけられて♪　……はんんっ♪　おっぱいの中から今にも\n飛び出しちゃいそうな力強さを体感しちゃったら……もう大変よ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「おんなのこなら誰だってキュンとしちゃうに決まってる……っ。はぁっ♪\n　胸の谷間にもおさまらない、こんな凶悪なおちんちん……。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「おまんこに入れられたら死んじゃう～って♪　でも入れてみたいなぁって。\nちょっと怖いサイズだけれど、経験しないともったいない～って……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「それ、で……♪　んっ、んっ♪　きっと一度で虜にされちゃうでしょうねぇ\n……♪　こんなの覚えたら、これ以外じゃ嫌って思うのは普通だわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「生物学的に女の子ってメス、だから……っ。あんっ♪　こういうつよ～いお\nちんちんにはやっぱり従っちゃうし、好きになっちゃうものなのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「医学の知識のあるわたしですら……興味深くて目が離せない♪　こう、やっ\nて……っ、ぁっ♪　胸でいじくりまわすのやめられないっ……あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「ここまで健康的でオスの臭いをぷんぷんさせたおちんちんからは、やっぱり\n優秀な遺伝子が放出……射精されるのかしらって期待しちゃうのね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「素敵な形……。んっ、熱々に燃える肉棒……ペニス♪　あっ……あぁ、そう\n、このペニス……肌にすいつくような特上の男性器♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「あッ、あぁ、ああっ、あぁ……見たいの♪　あなたの優秀な精子が見たい♪\n　このカリ高おちんぽの、逞しい亀頭の穴から出る白濁液が欲しい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「はむっ……れろっ、ぴちゃっ、レロ……ぴちゃっ……！　ンン……♪　急に\n何をひゅるのかって？　亀頭舐めよ……尿道口を刺激しているの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「ここには敏感な神経が集まっているからぁ……、ちゅぱっ♪　舌先でほじほ\nじしてあげるとドクドク精子が作られるのよ……。ちろ、ちろ、ちろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……ぺちゃっ、ぴちゃ……フフ♪　そして全力のパイズリぃ……♪\n　あっあっ、おちんちん喜んでピクピクしてるわよ、何秒もつかしら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「ん、ふ……ふふ♪　んぅう♪　ホズミせんせーのズリズリパイズリぃ……♪\n　おっぱい全部でおちんぽムニュムニュ搾り上げながら……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「お口は絶え間なく先端を舐め回して、強制的に精子を引きずり出～す♪　ぢ\nゅるっ、ぢゅるぢゅるっ、ほらほら、あがってきたあがってきた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「出したいねぇ？　せんせーが作った精子、せんせーに思いっきりぶちまけち\nゃいたいわよねぇ？　れろれろれろ……ちゅぅううう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203135" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「……きゃっ♪　ちょっとちょっとぉ～♪　予告も無しにいきなり出しちゃダ\nメでしょう～？　あっ♪　あんっ、もう、イタズラっ子ぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　そう……わたしの眼鏡が気に入ったの？　ドピュドピュ射精し\nてるじゃない……♪　んふっ……顔中にへばりつく粘液……いいわね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「何日も出してなかったのかしら？　ゼリーみたいにプルップル……。あぁん\n♪　もうっ……レンズでは受け止めきれないくらい……。すごい量♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「力強くて素敵だけれど……。んっ、こんなに出すんじゃ、とても子宮や膣に\nは収まりきらないわよ……！　んぅっ、絶対に溢れちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「妊孕力の強すぎる、パワーのある精子……ふふふっ♪　ここまで完璧な精液\nが出せるなら、健康診断なんて必要なかったかも……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「発射する力も、飛ばした距離も……同じ年代の人の何倍もスゴいのね。天才\n的なおちんちんだわ。才能があって羨ましいな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「それで、ここからどうする？　せんせーのチェックは終わったけど……。ま\nだまだおちんちんには余力が残っているみたい。続けてもいいかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「え？　今度はもっといやらしく、卑猥な言葉を言いながらおちんちんをナメ\nナメしてほしい？　んもぉ……ダメなコねぇ♪　だから好きなんだけど♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとだけ驚いちゃったかな……。ん、そっかぁ。えっちな言葉、\n卑猥な言葉……言葉責め……。悪くないかも。はじめるわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「優秀な精液まみれのヌルヌルおちんぽを、わたしが……ホズミがぺろぺろレ\nロレロさせていただきます♪　もちろん、パイズリも加速させるわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「あむっ……ぴちゃっ、ぺちゃっ、ちゅく……くっちゅっ♪　まずはこの、真\nっ赤な亀頭……プルプルで柔らかいおちんちんの先っちょね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203206" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「あなたの亀頭の穴からは、ニュルニュルカウパーが滲み出してきて……。ん\nむっ、尿道口がテラッテラね。お漏らししたのかと思うくらい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「んっ……味はよくわからない、けど……。舌が滑って舐めやすい……れろっ\n、れろ、れろ……とってもえっちなおちんちんで最高よ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「それに、このボリュームのある肉竿ぉ……♪　結構臭くて、こんなに逞しい\nのに……舌を這わせると、とーっても反応がいいの♪　性欲の塊だわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「んっ♪　舐めても舐めても全然足りてない……あっ♪　わたしのおっぱいか\nらはみだす凶器……すごくかっこいい♪　れろっ、れろっ、れろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「血管が浮き出たおちんちんって……ぴちゃっ♪　女を従順にさせてしまう威\n力があるわよね、あなたのコレはその最たるもの……国宝級おちんぽよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「女医が言うんだから間違いないわ……♪　孕ませることに特化した、えっち\n専用生おちんぽ♪　ぴちゃっ、ぴちゃ、芸術の域よ……誇っていいわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「睾丸も、う～んといやらしい形だし……んれろっ、シワシワの一本一本まで\n舐め舐めの刑よ……うふふっ、なーめなめ♪　ぺーろぺろ……ちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「ふふふっ……胸で玉袋をもみくちゃにれるのも良いでしょう？　はぁっ♪　\n亀頭はお口で、肉棒と陰嚢は胸で……んっ、三点責め……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「一度に攻められるとぉ……何もわからなくなるくらい気持ちいいでしょう？\n　おちんちん全部がまるごと愛撫されて……性感が爆発するのっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「わたしの胸をたっぷんたっぷん揺らしてもらいながらオチンポ舐められるの\nが好きなの？　変態……ヘンタイ♪　ああ、可愛い……れろれろれろ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「お望みどおり頭を真っ白にしてあげる……♪　っちゅっ……ぢゅっ♪　くち\nゅっ、ぺろっ……れろっ、れろぉ……れるっ、れる……ぢゅるんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「くっちゅっ、ぐちゅっ！　ぐちゅぐちゅぐちゅっ……！　んふっ、また尿道\n口に舌をねじこんで……くちゅくちゅくちゅくちゅ♪　ぐっちゅっくちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00020402_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「あらっ？　あらあらあら……？　また我慢できなくなってきた？　さっきピ\nュッピュさせたのに♪　絶倫チンポね……れろっ、羨ましい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「あらぁ？　出すの？　出しちゃうの？　まぁたわたしにイかされちゃうのね\nぇ？　うふふふっ、上手に射精できるかしら、見ていてあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203220" ]},
