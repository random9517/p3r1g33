		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「誰に見せたって褒められるわよ♪　れろ……、もちろんわたしにも。丈夫で\n元気いっぱいな、素晴らしいおちんちん……。ふふふ、キスしちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_204_0203407" ]},
		{"command":[ "WAITINPUT" ]},

