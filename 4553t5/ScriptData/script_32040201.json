		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ホズミ" ]},
		{"command":[ "SETTEXT", "「はぁい、ぴゅっぴゅっ♪　ぴゅっぴゅっ♪　頑張れ頑張れぇ……♪　んふっ\n……！　まぁた眼鏡……？　好きねぇ～……♪」", "NORMAL" ]},
