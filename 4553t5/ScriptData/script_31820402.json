		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ぎゅうぎゅうぅって、オチンポを吸いこむように、蠢かせたりぃ \n……んっ、くぅ……っ」", "NORMAL" ]},
