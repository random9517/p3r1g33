		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「人妻だったころより、オマンコを自由に動かせちゃうんですぅ……♪　サキ \nュバスって、すごいですねぇ♪」", "NORMAL" ]},
