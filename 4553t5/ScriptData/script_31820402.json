		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「うふっ、あなたの精液が欲しくて、我慢できなくなっちゃったんですよね～ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ついでに、寝ているあなたの身体をいろいろ調べちゃいました♪　たとえば \nこことか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふふっ、乳首が弱いんですか？　寝ている間も、ここを優しぃく触ってあげ \nたらビクビクしてましたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「乳首を責められながら、いやらしい夢でも見ていたんですかね？　オチンポ \nなんか、ビクンビクンしちゃってて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「先走り汁をトロトロ～っと、垂れ流しにしていたんですよ？　んふっ、オチ \nンポがぬらぬらいやらしくなってます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「かく言うわたしのオマンコも、あなたのオチンポをいますぐハメたくて、疼 \nきっぱなしの濡れっぱなしなんですけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふっ、逃がしませんよ♪　お腹を空かせたサキュバスから、逃げられるわ \nけないですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっくぅうう～～～～っ！　ほ、ほら、ずっぽりとオチンポが、わたしのナ \nカにはいっちゃいましたよ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404109" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぁ～……。す……っごい。乳首責めで焦らしまくったオチンポ、 \nぶっとくて、オマンコいっぱいになってます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふふぅ……どうです、サキュバスのオマンコ……んふっ、気持ちいい…… \nですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404111" ]},
		{"command":[ "SETIMAGE", "0", "still_00018204_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「これだけじゃないんですよ……？　たとえば……こうやって……んっ、んん \nっ、オマンコのお肉……動かして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
