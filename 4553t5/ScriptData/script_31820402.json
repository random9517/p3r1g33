		{"command":[ "SETIMAGE", "0", "still_00018204_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「せっかくですから、わたしのオマンコもっと味わってくださいね♪　んっ、 \nんふっ、腰を動かしちゃいますよ」", "NORMAL" ]},
