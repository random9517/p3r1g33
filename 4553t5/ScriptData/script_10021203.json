		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「お願いですから、どっちも痛いこととか恥ずかしいことしないでぇええええ\n～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114500001" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「だいじょぶだいじょぶ。今日は、あなたたちいい子だったから～！」", "NORMAL" ]},
