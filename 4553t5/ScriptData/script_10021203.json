		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「あひっ！　ごめんなさいごめんなさいごめんなさいっ！　あの二人に逆らっ\nたら、どうなるかわからなかったので！」", "NORMAL" ]},
