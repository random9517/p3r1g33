		{"command":[ "SETCHARA", "0", "char_00015601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「あんた、私たちを裏切って、ＥＤＯをここに連れてきちゃったんだもんね\nえ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114500004" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「でも、ざーんねん！　部下の子たちが知らせてくれたから、ワームホールは\nきれいさっぱり、お掃除しちゃった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114500004" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「もう二度とワープできないねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114500005" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「ふっ、ふふふふっ……ふふふふふふ！　はーっはっはっは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114500004" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「あれあれ～？　この子、どうしちゃったの～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114500006" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「リ、リーダー……？　おかしくなられた……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010114500002" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「おまえたち！　私がなにも知らずに、だまされてると思ったのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114500005" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「え？　え！？　どゆこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114500007" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「なに言い出しちゃってんの？　この人！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114500005" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「部下を脅して裏切らせ、先回りして希望を潰し、こっちの絶望する顔を見た\nくてわざわざ目の前に来る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114500006" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「おまえらのやりそうなことなんか、全部お見通しなんだよーだ！　こっちは\nその裏をかいただけですー！　ざまーみろお尻ぺんぺーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114500007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「なにいってんの！？　わけわかんない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_010114500008" ]},
		{"command":[ "SETCHARA", "0", "char_00016201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「頭よわよわリーダーに、そんなことできるわけないじゃん！」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114500006" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「できますー！　だいたい私、あんたらに長いことパワハラモラハラついでに\nセクハラと、ハラの限りを尽くされてんだからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114500008" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「あんたらのやり口なんか、まるっと全部お見通しだ！　ってわけで、冴島長\n官！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114500009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「こちら冴島だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114500001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「どんぶりの下に残したメモは読んだか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114500010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ！　読んだ！　この座標に、足の速い連中を向かわせればいいんだな！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114500002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「そこにいけば円盤女たちの宇宙船があるはずだ！　それをぶんどれば、時間\n帝国に行ける！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114500011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「了解だ！　Ｍ.Ｏ.Ｅ！　Ｍ.Ａ.Ｍ.Ａ！　フルスロットルでぶっ飛ばせ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114500003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＭＯＥ＆ＭＡＭＡ" ]},
