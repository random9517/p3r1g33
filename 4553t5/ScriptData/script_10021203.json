		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「でも、リーダーはどうかな？　うそつきリーダーは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114500003" ]},
		{"command":[ "SETCHARA", "0", "char_00016301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
