		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者リーダー" ]},
		{"command":[ "SETTEXT", "「と、いうわけだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_010114500012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "円盤少女Ａ" ]},
		{"command":[ "SETTEXT", "「なにそれ……なんなの、それーっ！」", "NORMAL" ]},
