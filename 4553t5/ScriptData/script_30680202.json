		{"command":[ "PLAYVOICE", "v2_068_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
