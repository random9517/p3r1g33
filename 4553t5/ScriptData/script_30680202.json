		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はうっ、はっひっ！　あぁっ……ちんぽで、えぐるたびに……おまんこが痺\nれてぇ……あぁあっ……おかしくなっちゃうっ！」", "NORMAL" ]},
