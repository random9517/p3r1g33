		{"command":[ "PLAYVOICE", "v2_068_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あぁっ、おかしくなるっ……感じすぎて、おまんこおかしくなっちゃうっ！\n　んっああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
