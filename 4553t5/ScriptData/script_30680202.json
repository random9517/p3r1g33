		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　そこっ、そこぉ……！　そこ弱い、からぁ……んんんっ！　強\nく、擦られると……らめ、なんれすぅぅうっ！」", "NORMAL" ]},
