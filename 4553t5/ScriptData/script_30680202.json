		{"command":[ "SETIMAGE", "0", "still_00006802_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ああっ！　あぁんっ！　き、気持ちいい……ですっ……私も、気持ちいい、\nですけどぉ……はぁっ、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて……！　私だけ、いっちゃうっ……はぁあっ……が、我慢、\nできない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「隊長は……まだ射精、しそうには……あんっ……ならないですか？　んっ、\nんんっ……もうすぐ？　本当ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ひぃいっ、ひうっ……！　でしたら、このまま中にっ……な、中で射精して\nくださいっ……！　隊長ぉっ……！」", "NORMAL" ]},
