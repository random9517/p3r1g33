		{"command":[ "PLAYVOICE", "v2_068_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あぁ……すごぉい……た、隊長ぉ……気持ちよすぎてぇ……あはっ、私の身\n体、おかしくなっちゃいましたぁ……んっ、あぁっ……」", "NORMAL" ]},
