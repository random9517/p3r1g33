		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「も、もっとですか？　はっ、はひっ……頑張ります、からぁ……いっぱい突\nいてください……隊長のちんぽを、もっとくださいっ……！」", "NORMAL" ]},
