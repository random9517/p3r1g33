		{"command":[ "SETTEXT", "「はひっ、ほしいっ！　ほしっ、くてぇっ！　もう我慢できないっ……ですぅ\nっ！　ザーメン……隊長の特濃ザーメンくださいぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ああっ！　あっあっ、んっあっ！　いくっ……いっちゃうっ……！　もうっ\n……もぉおっ！　らめぇえぇぇっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ひぃいぃぃっ！　はひっ、ひぃああぁああぁっ！　ちんぽっ……ちんぽぉ！\n　隊長のちんぽでイかされちゃうっ！　んっんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ザーメンっ！　ザーメン出してぇっ！　い、一緒っ……あっあっあっ、イク\nっ！　イクイクイクイクぅぅぅぅ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204220" ]},
		{"command":[ "WAITINPUT" ]},

