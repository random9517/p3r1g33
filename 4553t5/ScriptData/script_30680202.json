		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ひぃあああああああ～～～っ！　んっあっ！　はっあっ、ああっ……んっあ\nぁぁぁぁぁぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あっあふぅっ！　で、出てっ……出てるぅぅぅっ！　あぁぁんっ！　ザーメ\nン……おまんこの奥にいっぱいぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はっ、んっあぁぁっ！　子宮に……また子宮にザーメンがっ……ひぃうっ…\n…流れ込んできてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、熱いっ……！　あっあぁ……あふぅうっ……！　ちんぽすごいっ\n……んあっ、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「に、二回目なのに……連続で、してるのにぃ……あはぁぁっ……まだ、出て\nるぅ……んっ、あぁ……おまんこいっぱいになっちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……んっ、あぁ……あふぅ……た、隊長ぉ……気持ちよか\nった、ですか？　私はすごく、よかったですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「んんっ……そ、そうですね……このザーメンの量、が……答えですよね……\nふふ、嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「水着もよかったですか？　そうですね、とても興奮してましたよね。気に入\nってもらえて、よかったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「また水着でエッチしたいんですか？　もちろんいいですよ。水着だけじゃな\nくて、隊長のリクエストなら何でも着ます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「え？　もっと過激な水着でもいいかって……そ、そうですね……恥ずかしい\nですけど、頑張ります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁぁっ！　抜けちゃっ、ううぅぅぅっ！　はっあっ！　あひぃいぃ\nぃぃぃぃぃぃ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ！　ひぃんっ！　あぁぁっ、熱いぃっ！　あつ、熱いっ、いぃ\nんっ！　んっ、んんっ……ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁぁ……！　ザーメンが……ひぐっ！　飛び散ってぇ……あっ、\nあふっ……んんっ……かかっちゃう……あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「もっとぉ……もっといっぱいかけてください……隊長のザーメンで、マーキ\nングしてください……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ひぃあぁぁっ……！　あっ、あんっ……あったかい……んっ……蒸せるよう\nな匂いが、ここまできてぇ……はぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、あんっ……あぁっ……ザーメン、すごい……まだ、出てるぅ…\n…あぁっ……はぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204406" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「肌にべっとり張り付いて……ドロドロになって、ますぅ……水着もザーメン\nまみれでぇ……あぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長は……どうでしたか……満足して、もらえましたか……？」", "NORMAL" ]},
