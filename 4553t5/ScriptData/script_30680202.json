		{"command":[ "SETIMAGE", "0", "still_00006802_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……！　嬉しいっ……はっ、はっ……くはっあぁぁぁっ！　ん\nっ、ああっ……い、いいっ……はぁぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00006802_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「すごい、ですっ……隊長のちんぽぉ……たくましくて、おまんこにぴったり\nハマってて……気持ちよすぎですぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、あんっ……おまんこが、隊長専用の形になっちゃってる気がして……\nすごく興奮しちゃいます……あぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「だ、だってぇ、さっきから……子宮がきゅんきゅんしてて……おまんこが、\nちんぽに吸い付いてるんです……」", "NORMAL" ]},
