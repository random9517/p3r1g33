		{"command":[ "PLAYVOICE", "v2_068_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あああっ！　隊長の腰使いも、どんどん強くなってきて……あ\nっはぁぁっ！　はひぃぃぃっ！」", "NORMAL" ]},
