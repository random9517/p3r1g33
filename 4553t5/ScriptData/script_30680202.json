		{"command":[ "PLAYVOICE", "v2_068_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「はぁあっ、あっ、あんっ！　後ろから……ズンズンって、ちんぽで突かれて\n……し、子宮が押しつぶされちゃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「だ、だめっ、本当に……身体中が痺れてきてぇ……変になっちゃうっ……あ\nっ、あふっ……あふぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「ど、どうして……今日はこんなに激しい……んっ、あぁっ……ですか……あ\nひぃっ……はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「み、水着ですか？　そんなに違う、もの……ですか？　ひうっ……あっ、ひ\nぃいっ……！　あぁっ……ひぃあぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
