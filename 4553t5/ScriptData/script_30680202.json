		{"command":[ "PLAYVOICE", "v2_068_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「た、隊長ぉ……も、もっとっ！　もっとぉっ……強く、してくださいっ……\n！　このままイかせてくださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「んっ、はっはひっ！　んほっ、ほっおおっ……おっおおっ！　そ、それっ、\nすごいっ……！　奥、ズンズン響いてるぅぅっ！」", "NORMAL" ]},
