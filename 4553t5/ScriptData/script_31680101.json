{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_03" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「よっと……へへっ、どうだ主……自慢のチンポが、全部アタシのオッパイの\n中に埋もれちまったぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「おー、分かりやすくビクビクさせてまあ。くくっ、まぁ事あるごとに、アタ\nシのオッパイチラ見してたもんな、そりゃあ喜んでくれるとは思ったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「まさか、バレないで見てると思ったのか？　頼むぜ、主ぃ。それなら、もう\n少し上手くやれよ、な？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ま、今日はそんなまだるっこしいコトは考えなくていいって訳だ。すっかり\nその気の主の、ビッキビキのチンポ……気持ちよくさせてやるからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んふふっ、行くぜ……んっ、そら……しっかり左右から挟み込んでやる……\nんふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ほぉら……柔らかいのが、ぎゅうっと……チンポにめり込んでいくぞ？　ん\nんっ……んっく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「へへっ、いいねぇ。主のチンポ、正直に反応してくれるじゃんか……それで\nこそ、パイズリのしがいがあるってもんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「主はどういう風にされるのが好きなんだ？　どうせ、色んな女にパイズリや\nらせまくってんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あははっ、人聞きが悪いって？　でも、実際そうなんだろ？　いいよ、他の\n奴に負けない、アタシのパイズリを味わわせてやるさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「まずはオーソドックスに、左右から挟んで……オッパイ全体を揉み込んでや\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んふっ、あっ、んっ……ふっ……あぁ……硬いな……芯がしっかり通って、\nこれがオスのチンポってやつか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「何だよ？　別に触ったことないのがそんなにおかしいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「手慣れてると思ったから？　ははっ、こんなのは雰囲気だよ、後はやってく\nうちに慣れりゃいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「第一、アタシの身体には主以外の男が触れない淫紋（スティグマ）があるん\nだ。浮気のしようがないのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ま……そんな訳で……経験はこれから積んでいくから、そこは長い目で見て\nくれよな……すぐに、感じは掴んでいくから、さっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……もう少し、滑りがいいといいんだよな……それなら……んっ\n、れろぉ……えろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「確か……んりゅ……唾液を垂らすと……いい感じになるって話だったけど…\n…んっ、おっ……おぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「確かに……さっきより滑りやすくなって……あっ……オッパイも、気持ちい\nい感じになって来た……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「主はどうなんだ？　んっ、ちゃんと……チンポ……いい感じになってるのか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「っと……くくっ、チンポが震えて代わりに返事をしてくれたぞ？　そうか、\nそうか、この感じがチンポも嬉しいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「よし……なら、もっとするぜ……今度は縦にこうして……ズリズリ……擦っ\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、ふっ……やべぇ……アタシの乳首もギチギチになって来た…\n…これ、チンポと……重ねてやったら……んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あふっ……やっぱり……痺れて……いい、感じだ……はぁ……もっとチンポ\nとキスさせるぅ……乳首、グリグリしてやるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、やべ……んんっ、これ、アタシの方が気持ちよくなってないか\n……？　んっ、せっかく主の為にしてんのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あぁ……主もちゃんとチンポいいって？　それに……アタシが感じてるのも\n嬉しいのか……ふふっ、そうか、そうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「まあ、それでこそアタシの主だ。いいよ、もっとチンポ感じさせてやる……\nほらっ、ひたすらプレスしてやるからな……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、すげぇ……くちゅくちゅ音がして……これは……もう、アタ\nシのオッパイ……オマンコみたいになってるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ、アタシのオッパイマンコで……チンポ感じて……アタシも……はふっ\n、身体……気持ちよくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、止まらねぇ……オッパイ……自然に動いちまう……あぁ、も\nっとチンポと擦り合わせたくなって来るっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んふっ……主は楽しんでくれてるか……？　ふふっ、チンポは正直だけど、\nやっぱり直接聞きたいじゃんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「へへ……そっかそっかぁ、アタシのオッパイマンコ……そんなにいいのか。\nオッケー、もっとしっぽりサービスしてやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ほうら……プレスしたまま……先端を乳首ズリだっ……うりっ、うりうりっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あぁ……やべぇ……気持ちいい……はぁんっ、チンポズリだけでも、こんな\nになっちまうなんて……はっ、ふっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、主も……んっ、出そうなのかっ？　あぁっ……当然、このまま\n中出しだよなっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「いいぜ……出してっ、このまま……アタシのオッパイマンコにっ……全部っ\n……ほらっ、チンポ……イケっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ！　出たっ……あははっ、めっちゃ出てるっ……んっ、濃いザ\nーメン、どんどん出てくるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、ふっ……やべぇ……オッパイで受け切れないぞ……こぼれ\nて来ちまってる……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ちゃんと寄せてくから……しっかり中出ししてくれよ……そうそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ……ふぅぅ……ようやく落ち着いたか。景気よく出してくれたな、マジ\nでオッパイがドロドロだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「でも、こうでなくっちゃな……ふふ、アタシのパイズリで感じてくれたなら\n、何よりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「おっと……だが、まだ一発じゃ物足りないって顔してるな。ああ、言わなく\nていいぜ、出したがりの主は、まだして欲しいよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「もうコツはバッチリ掴んだし、もっとチンポをトロトロに蕩けさせてやるぜ\n、そら……第２ラウンドだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ……さっきのザーメンが、ちょうどいい感じに滑らせてくれるな……は\nっ、んっ、ふっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あぁ……このヌルヌル感たまんねぇな……よし……アタシのツバも、もうち\nょっと足してやるぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ、えろぉ……れるぅ……うわぁ、マジでヌルヌルだ……これでチンポ扱\nくぞ……んっ、ふっ、んくっ……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あ、んんっ、はぁっ、縦に……横に……後はぎゅぅって押し込んで……また\n、離すっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「グチュグチュ言ってるよ……本当にこれ、オマンコみたいになってるな……\n主……ちょっと腰を振ってみてくれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ、そ、そうそうっ……あっ、マジで……オッパイ犯されてる\nっ、主のチンポがっ……アタシのオッパイマンコ、レイプしてるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「アタシがやれって言ったって？　ははっ、こまけーことはいいんだよ。もっ\nと、オッパイしてくれっ、アタシもマジでシコシコするからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、ふっ、んくっ、んんっ……！　そうそう、息もピッタリじゃ\nんか……やっぱり、アタシと主の相性は抜群だなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、チンポの先が……乳首に当たって……っくんっ！　これ…\n…めちゃ気持ちいいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、マジで一人だと……全然イケないけど……主がいると、普通\nにオッパイだけでイケちゃいそうだっ……あっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あぁ……ダメだダメだ……まだ、もう少しぃ……どうせなら、主の射精に合\nわせて飛びたいもんな……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「まだだ……んっ、はっ、ふっ……あぁっ……けど、ヤバい……乳首……ジン\nジンしやがるぅ……スイッチ入っちまってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「こ、こうして……クニクニって押し込むと……あっ、あぁっ……チンポの震\nえが伝わって来るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ、あぁ……主もそろそろなのか？　んんっ、あぁっ、我慢…\n…しないでくれよっ？　アタシもすぐなんだからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「分かってる……このチンポの震えっ……さっきと同じ……もうすぐなんだろ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……ラストスパートだ……このままノンストップで、チンポ…\n…扱いてやるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、ギュッと……挟んで……グリグリさせてっ……さあ\nっ……あと、少しだろっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ、どうしたいんだっ？　主の言う通りにするからっ……何でも……言っ\nてくれっ……あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「なるほど……また、オッパイに中出ししたいんだな？　いいぜ……アタシの\nオッパイはいつでも準備出来てるからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「アタシも一緒だっ……んぁっ、はぁぁぁんっ、オッパイッ……イクぅぅぅぅ\nぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あはぁっ……出てるな……また、こんなにたっぷり……絶倫主のザーメンシ\nャワーだ……んふぅぅぅ……」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「アタシのパイズリで、これだけ気持ちよく射精してくれるなんて……これだ\nから、主は最高なんだよなぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ？　まだもう少し残ってるのか？　あぁ、任せてくれ。ちゃんと、最後\nまでビュビュッとさせるさ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ふふっ、滲んで来た……んっ、ちゅぷっ、んんぅー、味も濃厚で言うことな\nしだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ……これで、おしまいかな？　ふふっ、アタシのオッパイがドロドロだ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「どうだった？　後半は慣れてきたし、アタシとしては上手く出来たんじゃな\nいかと思ってるけどさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「へへ、そりゃあよかった。主が満足してくれたんなら、それが何より一番だ\nからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「さて……後は、チンポの後始末もしないとだ。じっとしててくれ、主。最後\nまで面倒見させてくれよ、な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んっ……ぁっ……顔にぶっ掛けたいのかっ？　いいぜ……好きなだけぶち撒\nけてくれっ、あぁっ、出るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「んぷぁっ！　あぁっ……出てるっ……んっ、また……顔がベトベトになって\nく……んふぅ……やば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……へばりついて来る……新鮮でパワーに溢れたエキスだ……ん\nちゅぷっ、んんーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「へへっ、クセはあるけど、この味はキライじゃない。いや……ちゅぷっ、む\nしろ好きな味って言えるかもな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あと、もう少し出そうなのか？　ああ、ちゃんと責任を持って搾り取るさ。\nそれが、このオッパイの務めだからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「おっ……出た出た……んんっ……ちゅぱっ、ぴちゃ……んっ……垂れる前に\n……ちゃんと舐め取らないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「どれ……そろそろ終わりかな。はぁぁ……オッパイだけじゃなくて、顔もす\nっかりザーメンまみれだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「で……どうだった？　コツを掴んだ後は、そんなに苦労はしなかったけど主\nの感想が聞きたいところだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00016801_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「へへ、大満足か。それが聞ければ、やった甲斐もあったってもんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「さて……後は、チンポの後始末もしないとな。じっとしててくれ、主。最後\nまで面倒見させてくれよ、な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}