{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あら。カツマ様じゃありませんか。車両基地に来てくださるなんて、どうか\nされまして？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「もしかして、私に会いに来てくださったのですか？　えっ、あ、あらっ……\n！　その通りなんですのね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「しかも会いに来ていただいただけでなく、煙室のお掃除までしていただけま\nすの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「勿論、イヤなわけありませんわっ！　カツマ様がお掃除してくださるなんて\n、夢みたいですものっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「それでは、煙室の扉を開けますので、足元に気を付けてお入りくださいませ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ……！　カツマ様が私の中に入られてますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「すすで汚れるところに、嫌がられる様子もなく入っていただけるだなんて…\n…私、最高に幸せですわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「えっ、あっ……！　お、お掃除のやり方を教えて欲しいんですの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「か、かしこまりました。では、簡単にですがご説明させていただきますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「まずは煙室の内部をタオルでゴシゴシと拭いてくださいませ。その際、タオ\nルにオイルを染み込ませていただくと、凄く綺麗になりますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ……んんっ……！　そ、そうです……そのような感じで、煙室の内部を\n拭いていってくださいませ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はあぁ……カツマ様の手つき、とても素敵です……！　優しく車体を撫でら\nれているような感じがして、気持ちいいですわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あ、あら……カツマ様……？　急に手が止まりましたけど、どうかされまし\nて……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「……なるほど。蒸気機関車だからもっと汚れているとお思いでしたけど、想\n像していたよりも汚れておらず、驚いているのですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「確かにカツマ様のおっしゃる通り、蒸気機関車と言えば火室で石炭を燃やし\n、燃焼ガスの熱エネルギーでお水を沸騰させるというのが一般的ですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「沸騰したお水から出る高温高圧の蒸気を用いて、往復運動のエネルギーに変\nえる……だからこそ、この煙室はすす汚れが多くなるものです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ですが今はエコの時代ですから、環境汚染につながる燃焼ガスが出ない仕組\nみになっておりまして、石炭を用いることはありませんの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「とはいえ、私は最新技術を用いて造られておりますので、疑似的な煙を吐き\n出すことが可能となっておりますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「当然ですが煙に燃焼ガスは発生しておりませんので、環境に優しいクリーン\nな車両となっておりますの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ただ、いくら燃焼ガスが発生しないとはいえ、やはり私も機械ですので、動\nいているとオイルが付着したり、サビついたりしてしまいますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「サビついて動かなくなってしまわないためにも、隅々までお手入れしていた\nだけますと嬉しいのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「うふふっ。やる気になっていただいて何よりです。では引き続き、煙室の中\nを拭いていただけますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ……！　今、カツマ様が触られているのが煙管……高温の燃焼\nガスを通す管ですわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「先ほども申し上げた通り、今は燃焼ガスが発生しない造りになっております\nので、安心して拭いてくださいませ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ、くっ、ああぁっ……！　オイルと共にカツマ様の指先が配管に当たっ\nてきてますわっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ふっ、あぐっ、あんんっ……！　この指とタオルの感覚だけ\nで、煙が噴き出しそうになってしまいます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁっ……！　か、カツマ様っ……！　配管を拭き終えまし\nたら、今度は煙室の内側を磨いてくださいませっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁんっ！　そこ、凄く気持ちいいですわっ！　身体の内側からゴ\nシゴシされる感覚……た、たまりませんのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ボルトも１本１本、しっかりと磨かれてますわっ……！　こんなに丁寧なお\n掃除は、生まれて初めてですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「しかもそのお相手がカツマ様だなんてっ……！　あっ、あんんっ！　発情し\nて、蒸気が止まらなくなってしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「だ、ダメですわっ……！　カツマ様が煙室にいらっしゃるのに、煙を吐くだ\nなんてっ……！　そんな粗相は……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あああぁんっ！　煙管の奥の奥まで手が届いてますわっ！　そ、そこは大事\nなところなんですのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「普段手の届かないところに付着した埃やオイルが、綺麗に拭われてますっ…\n…！　こんなに丁寧にお掃除されたら、我慢できませんわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「申し訳ありません、カツマ様っ！　今から粗相をしてしまうこと、お許しく\nださいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ！　イクッ！　イキますわっ！　煙と一緒に気持ちいいのが、どんどん\n上ってきますのぉぉぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「いあああぁぁぁっ！　私のはしたない排煙の音が、煙室に響いておりますぅ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「こんなにもエッチな音を響かせるだけでなく、カツマ様に間近で聞かれるだ\nなんてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「恥ずかしくてたまらないのに、煙突から煙が止まりませんのっ！　あああぁ\nんっ！　お願いですから、もう止まってくださいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　今煙を吐いている最中なのに、煙管を触られたら……んん\nっ！　震えがさらに強くなってしまいますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「やっ、ああぁっ！　ダメですわっ！　またイッてしまいますっ！　イキなが\nら、煙を噴き出してしまいますぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ……はあぁ……も、申し訳ございませんでした……こんなにもはしたな\nい声で喘ぐなど、蒸気機関車としてお恥ずかしい限りですわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「煙がたくさん出てましたが、大丈夫ですかって……？　は、はい……まった\nく問題ありませんわっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「これは石炭による燃焼ガスではありませんので、カツマ様にお掃除いただい\nた個所が汚れるようなことはございません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「煙たくはありますが、あくまでも煙を疑似的に再現しているだけですので…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「問題ないようでしたら、拭き掃除の続きをしたいのですか……？　は、はい\n……！　勿論ですわっ……！　是非ともお願いいたしますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぐっ……！　カツマ様の手が再び煙室の中を行き来してますわっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「それに煙室の壁だけでなく、お足元まで丁寧にお掃除されるだなんて……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「身体の中がオイルでスベスベになって、とてもリフレッシュできますわ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はあぁ……カツマ様のおかげで、煙室がピカピカになっていってます。本当\nにありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「えっ……？　煙室の扉の内側を拭いていないので、まだお掃除は終わってな\nい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待ってくださいませっ！　扉の内側は私の一番敏感なところ\nですのっ！　ですから、触らないでください……あはぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！　扉の内側が力強くゴシゴシされてますわっ！　私の弱いとこ\nろを何度もオイル塗れのタオルが擦れてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ああああっ！　ダメっ！　ダメですわぁっ！　いくらカツマ様と言えど、扉\nの内側だけは……あっ、あっ！　あんっ！　ひっ、んぐぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ひぎっ、あひぃっ！？　配管を撫でまわされるのとはまた違った快感が、車\n体全体を駆け巡っていきますのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「このままでは、また火室に熱がこもってしまいますっ！　またボーボーとは\nしたない煙を吐き出してしまいますわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「お、お願いですわ、カツマ様っ！　早く煙室から出てくださいませっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「そうでないと、また粗相を……んっ、あっ！　やああっ！　ダメですわっ！\n　火室の熱を抑えきれませんわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「熱を持った空気がボイラーを通ってますっ……！　あと少しで、煙が煙突の\n方に吐き出されてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ！　ひっ、んぐぅ！　も、もう我慢できませんっ！　私、このま\nまイッてしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ですからどうか、早く煙室から退避をっ……！　イッ、イクッ！　イッてし\nまいますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま","LABEL1","外して","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ひぃぃぃっ！？　ど、どうして急に煙突の中を拭き始めるんですのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ！　ダメですっ！　煙が止められませんっ！　私の排煙、煙突からどん\nどん溢れていきますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「やあああっ！　カツマ様っ！　どうか嗅がないでくださいませっ！　私の汚\nい煙、吸い込まないでくださいませぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「け、健康被害はないから問題ないということではございませんわっ！　エッ\nチな香りを嗅がれるのが、恥ずかしいんですのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「やあああっ！　恥ずかしさで、また煙が立ち上ってきますぅ！　どんどん溢\nれて、止まりませんのぉぉぉっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふっ、んんっ……！　か、カツマ様っ……！　煙まみれになられま\nしたが、大丈夫ですかっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「燃焼ガスじゃないから問題ないのですね……ああっ、よかったですわっ……\n！　もうお掃除は終わりましたし、煙室から出てくださいませ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あ、あら……？　どうしてまだ煙室の中で作業をされているんですの……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「まだ煙突をしっかりとお掃除できていないと……？　そ、そんなっ……！　\nもう本当に十分ですのでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んひぃ！？　また敏感なところにカツマ様の手が入ってきてますぅ！　こん\nなの、また煙を噴き出してしまいますぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「きゃあああぁっ！？　な、なんですのっ！？　急にお水が車両にかかってま\nすわっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024901_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「火室に熱がこもっていたので、急いで冷却をされたのですか……！？　お、\nお心遣い感謝いたします……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「ですが火照った車体を急激に冷やされますと……蒸気がさらに発生して、も\nっと熱く……あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「あっ、んひっ！　くっ、あぁんっ！　だ、ダメですわっ！　蒸気エネルギー\nがシリンダーに伝わってきてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「このままだと、動き出してしまいますわっ！　急いでブレーキをかけないと\n……んっ、んんっ！　んふぅぅぅっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ……何とか動き出さないよう、制御することができましたわ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「それにしても、いきなりお水をかけてくるだなんて、思ってもみませんでし\nたわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「い、いえっ……！　不快だとかそういう意味ではありませんのっ……！　た\nだ少し、驚いただけでして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「私のためにしてくださった行動だというのは、重々理解しております。カツ\nマ様。ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソラ" ]},
		{"command":[ "SETTEXT", "「また機会がありましたら、是非カツマ様の手でお掃除していただきたいです\nわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_249_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}