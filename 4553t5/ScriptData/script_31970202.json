{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ふぅ～～～♪　いっち、に♪　いっち、に♪　がんばれ♪　がんばれ♪　勝\nて勝て～♪　わん、つー♪　がんばれ～♪　えいえい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……うひゃああ！？　な、なんでそんなところにいるわけぇっ！　わ、我に\n気配すら感じさせないなんて……な、なんて男なの～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「何をしていたか？　ふふふん♪　決まってるでしょ。我は今、チアリーダー\nなんだから応援の練習をしていたってワケ。……なによ。……えっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「コスチュームとポーズがエッチすぎて目が離せなかった？　ふ、ふぅーん。\nそーなんだ。ちっちゃい子に欲情するヘンタイなんだ～？　んふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ま、我は勝手に応援の練習してるだけだしぃ♪　エロい目で見られてるとか\n知らないし♪　がんばれ♪　がんばれ♪　……って、きゃああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204105" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「い、いきなりなにするのよぉおおお！　びっくりしたぁ！！　我にこんなこ\nとするなんて不敬……って、あっ？　あああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019702_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「い、いくら我の……ファンタズマちゃんのチアコスが魅力的だからってぇ！\n　許可もなくお触りしていいわけないでしょぉ！　あっ、あっ、やぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「くすぐったいぃ……！　すっごいやらしい触り方してくるぅう……！　あう\nっ♪　ひぅ♪　ヘンシツシャぁ！　おまわりさぁん、ここです～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あぅっ♪　うぅ、そうやって誘惑する方が悪い？　あっ、ち、違うもんんっ\n！　我は真面目にチアの練習をぉお……！　あっ、持ち上げないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「はうぅうっ！？　……えっ？　な、なんでおちんぽ入れた、の……？　あっ\n♪　ヤだぁ、油断してたから快感が制御できない……んぅうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　んああああっ♪　不意打ちでロリロリおまんこにぶっといおちん\nぽ挿入されてイクぅううっ……！　あぁっ！　な、なによ、なによぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちっちゃい女の子はぁっ♪　突然かよわいおまんこにおちんぽっ、挿入され\nたら自動でイッちゃうのにぃいい♪　っんぁおおお♪　おほぉおおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「この体勢ッ……！　いっちばん奥まで入ってるっ♪　ずぶずぶズボォオオッ\nておまんこ串刺しにされちゃってるっ、あっ♪　あっ、なにするのぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ちょっと！　う、動かすとかありえなさすぎるからぁああ！　……おっ♪　\nおぉっ♪　んぉおおっ♪　ドチュドチュ高速ピストンしない、でぇえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あうっ！　ううっ♪　ま、まずいからぁっ！　こんなっ……あっあっあっ♪\n　カワイイカワイイファンタズマちゃんのロリぷにおまんこがぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「極太ちんぽで掻き回されて……んんんっ！　イグぅっ！　あぅっ！　き、汚\nい声出ちゃうじゃないぃ！　……おぉっ♪　おほっ♪　んほっ、おぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んぅうう……ッ！　う、後ろから急にだっこしてズプズプなんて……あぁう\nうううっ♪　なんかっ、恥ずかしい格好させられて顔熱くなっちゃうし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「し、知らない間におまんこっ、おまんこ突かれて唐突に気持ちよくされてる\nしっ……あっあっ！　あ、ありえないぃい、どういう状況よぉおお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「チアっ……チアリーダーしてあげたらっ、あ、あんたが喜ぶと思って練習し\nてたのに……！　あんっ！？　お、おまんこ目当てだったなんてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「い、いいけど……！　ダメじゃないけど卑劣ぅうう……！　っあっ♪　んぁ\nっ♪　べ、別に土下座して頼めば挿入くらいさせて、あげる、のにっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「最凶の堕神であるファンタズマちゃんをっ♪　お、犯してオナホ扱いするな\nんて……ばかぁっ♪　あっ♪　やだ、そこやだ、気持ちいい、やだぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んっ、あっあっあっあっあっ♪　んんんん～っ、はううぅうう……♪　え？\n　めちゃくちゃ感じてる？　わ、我が？　愛液でびちゃびちゃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「こ、これは違うしぃい……！　あんっ♪　あんたのカウパーだしっ、……あ\nっ♪　カウパー、おまんこに塗り広げられてるだけ、らしぃっ♪　んおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「イッてない、しぃ！　……おぉおっ♪　やめっ、やめ、れぇ！　やめなひゃ\nいぃい！　ファンタズマちゃんを犯すとかダメだからぁっ、抜いてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んぁ♪　あぁ♪　……ち、違うから！　おちんぽ締めつけてないし、全然こ\nのまましてほしいとか思って、ないし、……あっ♪　うううううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「おまんこうねってるのはっ、おちんぽにぐちゅぐちゅされてビクビクしてる\nのはっ！　ち、違う～！　感じてるんじゃなくてぇ……！　……あうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「な、なんでやめろって言われてピストンっ、早くするのぉ！　あッあッあッ\n、無理ぃ♪　無理無理ぃっ♪　全身っ、全部使われてりゅっ、おぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「オットセイみたいな声、喘ぎ声垂れ流しながらイカされちゃううっ♪　我、\n我は最凶にゃのにっ、あっ、おちんぽ入れられた、だけでぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「イクぅ……イクぅっ！　んぁああっ♪　だからダメ、にゃのぉっ♪　チアリ\nーダーに触ったり、エッチなことするのはダメ、なのっ♪　んぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あうぅっ！　激しく揺らさないでぇえ……♪　わかったからぁっ、気持ちい\nい、から！　ずっとイッてるからぁ！　やめ……ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あううっ♪　んぅううっ！　ずぼ、ずぼ、気持ちいい……！　気持ちいいぃ\nっ♪　あっあっあっ、ああああああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「どんどん腰の動きが早く、なって♪　我の中にドクドク精液を注ぎ込もうと\nしてるのがわかりゅぅううっ♪　おっ！？　おっぉっ、んぉおおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ず、ずっとイッてるのに、もっとイカされりゅっ♪　あっ♪　おっ♪　ご、\nごめんなひゃい、エッチなコスチューム着てごめんなひゃいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そうです、ゆ、誘惑してたんですぅうっ！　チアリーダーの衣装、エッチだ\nってわかってて、おちんぽ欲しくて誘惑してました！　謝りますぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あうっ、こ、このままではわからされちゃうぅっ♪　だ、だめ、このまま精\n液出すのはだめっ♪　あぁっ、出すなぁ、出したら……！　ああああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んふぅううううっ！？　イクぅうっ！　今までで一番おっきくイッてるぅう\nううう～っ！　あああああっ♪　イクっ！　イク～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ふぁあああ♪　もうわけ、わかんにゃいぃい……！　おまんこの中にあっつ\nい精液が流れこんでくる、あっ♪　あっ、上がってくるぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「なんっ、で……！？　しゅごい、子宮口に直接精子、精液がかかってる……\n届いてりゅぅうう……！　おちんぽの先っちょと密着して……あっああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「びゅるっ、びゅるっ♪　どぴゅっ、どぴゅっ♪　あっ♪　もうお腹いっぱい\nだから……！　それ以上出されたら、我……我ぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「頭の中真っ白になるぅうう……♪　あっ♪　またドクドクってぇ！　いじわ\nる……いっぱいイッたのに、その上精液も注入し続けて……どすけべぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んっ、う……♪　ファンタズマちゃんのちっちゃいお腹が、精液でぽんぽん\nになっちゃったじゃないぃい……♪　んんんん……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「な、なんか、呼吸するだけで精液の臭いがあがってくる気がするぅ……。は\nぁあ……、なんってことしでかしてくれたのよぉ、頭がぼーっとするぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、これだけ出したら満足した……よね？　お、下ろしてよぉ……\n。我の衣装、汚れちゃったらいやだし、足ガクガクしてるし……。えっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んはぁああっ！？　んおっ！？　うそぉ！？　な、なんで我のお尻の穴にお\nちんぽ、ギンギンのままのチンポ入れてくる、の、入らないからぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっ……！　あう、うう、おちんぽ……？　なんで？　我のお尻にずぶずぶ\nって……？　……あ！　せ、精子！　精子をローションにしたの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そんなの反則じゃないぃ！　くふぅううう……！　く、くるしぃ……っ！　\n意識はハッキリしたけど、し、信じられなぁい！　そんなとこ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「お尻におちんぽ入れるなんて、……んぅっ。心の準備もさせてくれないし、\n……あ♪　ちょ、ちょっと、話の途中で動かない、で、あっ♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「さっきおまんこでいっぱいイッたのに、お尻でも連続でイカされたら困るぅ\nう！　ファンタズマちゃん、堕神なんだよ！？　エライのっ、なのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、うぅ♪　ズンッ、ずぶっ、ずぶっずぶって出し入れしないで\nぇ♪　あっ！　おまんこでイッて敏感になってるのに、あっ♪　お尻っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「お尻ほりほりされたら……んくぅううっ♪　お尻でもイッちゃうからぁああ\n！　……あっ♪　ヘンっ、お尻の中ヘンっ、か、感じるぅ、感じるう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ッんんんん～～～！　やだ～～～♪　お尻でイクぅっ、……おッ♪　おほっ\n♪　ヘンタイになっちゃった、我、お尻でイカされて……♪　んんぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……ふぇ？　エッチな格好で挑発したお詫びがまだ……？　い、一回おまん\nこの時に言ったもん！　あれじゃ足りない？　……わ、わかったからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「も、もうイカせないれぇ！　う、うぅう♪　さ、最凶の堕神ぃ、ファンタズ\nマちゃんは！　わ……我はエッチな服でエッチなポーズ、してっ♪　あう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「おまんこもお尻も犯されたいって思ってました、悪い堕神さまれひゅ♪　お\nっ♪　謝りますっ♪　謝るから……おぅっ♪　うう♪　もう終わりぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「お尻こわれちゃうぅ、もうお尻でずぬずぬするの終わりっ！　……あぁっ♪\n　ま、またどんどん腰が早くなってきたぁ、なんで謝ると興奮するのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んぉ♪　んぉ♪　んぅう♪　おちんぽ膨らんできてるっ、お尻にも出すつも\nりぃ……っ♪　あぉっ♪　おぉっ♪　だめ、だめ、だめぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ごめんなひゃい！　ごめんなひゃいい！　あっ♪　お尻で気持ち良くなっち\nゃうダメな堕神でごめんなさいぃ！　……あああああぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204217" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「うぅうう♪　そん、な、小刻みにぃっ……動かない、で♪　おちんぽ太すぎ\nて♪　お尻っ……ミチミチに広がってる、拡張されてりゅからぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「おしりっ……！　我のお尻、おちんぽの形に広がっちゃうぅ……！　あぁっ\n！　突き上げないで、響く、お尻に響くよぉ……！　あっぁっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……んぅうう！？　う、そ……。我、このままじゃお尻ですっごい絶頂しち\nゃう！　あっ♪　すっごくおっきくイッちゃう、んんんっ、イクぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んぅうううううっ♪　んふぅうううっ♪　くぅううううううん♪　あッぁっ\n♪　ああっ、んぁああっ、出てる、お尻の穴に出てるぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あああっ、おまんこにもお尻にも、どっちにも精液流しこまれて♪　我があ\nんたのモノだってはっきり刻みつけられちゃってるぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「うれしいっ、嬉しいぃ……♪　もっと、もっと出して、一番奥に出して……\nビュッビュしてぇ♪　あぁっ♪　あぁ、絞り上げるからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「だからタマタマに残ってる分もぜんぶちょうだいぃい……！　っあああああ\nっ！　イクぅうっ♪　お尻もわからせられちゃうううぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「っんぉっ♪　んぉほっ♪　ほぉぉおお……ッ♪　すごいぃ、何度も何度も脈\n打ってる、我のお尻……真っ白に染まってくぅうう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204305" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……はーっ♪　はーっ♪　お腹が……お腹がくるしい……♪　こんなにお尻\nの中に出されたら、もう認めるしかないよぉ……負けだって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「わ、我は……ぜんぶあんたのモノですぅう……♪　それでいいです、ううん\n……それがいいの、あんたのモノでいさせてほしい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あ、あは♪　しゅごいぃ、足がガクガク、腰がブルブル……♪　こんなの、\nイケる限度をはるかに超えてるから、身体おかしくなっちゃうよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「で……でも、やじゃない……♪　こういうの、興奮したかもぉ……♪　え？\n　我のエッチな衣装でギンギンになったからできたこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「だったら……チアーリーダーになって良かったぁ♪　また着るから、いつで\nも襲ってね……ファンタズマちゃんはあんた専用チアリーダーだもん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んぉおおっ♪　お尻でイクぅうううっ……！　って、ふぁあ！？　あれっ！\n？　あれぇっ！？　おちんぽ抜けて……あぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「かかってる！　ぶびゅっ、ぶびゅって精子身体に……ファンタズマちゃんの\n全身にぶっかかってるぅっ！　な、何これ……熱いぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「溺れ、りゅぅ……♪　あっあっ！　や、やだ、精液のクラクラするニオイ…\n…っ♪　くっさい精液浴びながらイクなんてぇええっ！　はぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「イクッ……♪　イクぅうう……っ♪　あっ♪　見てぇ♪　コスチュームに精\n子かけられて、興奮して絶頂してる我を見て、もっとかけてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっぁっあっあっ……♪　ぷーんって、我の身体からイカくさい臭\nいがするぅ……♪　ヌルヌルで、ベトベトで……すごすぎる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204405" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ねえっ……♪　こんなに濃いのが出るなんて、チアリーダーコスチュームの\nファンタズマちゃんに、我に魅了されたってことでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっ♪　だからこんなに……♪　ダラダラ流れ落ちるくらいにいっぱい精子\n♪　精子出してくれたんだよねぇ……♪　しあわせぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ッん……♪　衣装がダメになっちゃったんじゃないかって、心配……？　ん\nふふふ、いいの。元々これはあんたのために着てたんだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あんたが喜んで、元気になってくれて……。使ってくれたのなら本望だし…\n…♪　はぁああっ♪　それにしてもゼリーみたいな精液ぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あんたってば我のこと好きすぎ……♪　でもいーの♪　我も……ちゅき♪　\nあんたのこと、だーいちゅき♪　んふふふふ……♪」", "NORMAL" ]},
