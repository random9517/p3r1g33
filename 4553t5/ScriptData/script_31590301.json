{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふぅ……こんなに泳いだのは久しぶり……ふふっ、貴方も意外に泳げたのね\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あら、心外だったかしら？　でも、見直したわ。やっぱり男はある程度、逞\nしさを感じさせてくれなきゃ……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「さて……疲れたでしょう？　ちょっと休みましょうか……ほら、あの岩陰の\n方……ふふ……来て……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そんな訳で……んっ……お疲れ様……ここからはリラックスして、ゆっくり\n身体を休めてちょうだい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303104" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「もっとも、気分的には休まらないかもしれないけど……でも、ちゃんとオチ\nンチンはその気になってくれてるみたいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ……そうね、一緒に泳いでる時も、何となく意識はしていたの……水着\nの中のモノ……気になるなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「でも、貴方だって……私の水着……それも、胸元のところをずっとチラチラ\n見ていたでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「もちろん気づいてたわよ。だから、ちゃあんと期待に応えてあげなくちゃっ\nてね……んっ、えろっ、れろぉぉん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んふっ……あぁ、少し……塩気が強めなのは……海で泳いだせい\nかしら？　でも、それだけじゃないわね……ちゅぷっ、この汗の感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ぴちゃ……んりゅ……れろ……れろぉっ……もう、これだけで催\n淫成分が入ってるんじゃないかって思うほど……濃厚な匂いなの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「すぅぅっ……んんっ……あぁ……臭いわ……そう分かっているのに、鼻を近\nづけちゃうの……ふふっ、魔女も人間も変わらないものよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、えろ……れろっ、ぴちゃ……んちゅぷ……ちゅぱ……んっちゅ、れる\n……れりゅぅ……んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふ……たっぷり精液を飲ませてもらわないとね……今のうちから……ここ\n……キンタマを、やさしーくマッサージしてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ここをぎゅっと握って……くにくに揉んで……んっ、柔らかいわね……男の\n人の弱点……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ほら、気持ちいいんでしょ？　そんなに鼻の穴をぷっくり膨らませて……我\n慢してるの、丸分かりじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「こんなに無防備に弱いところを晒して……でも、見てるだけで……私も……\n吸い寄せられちゃうの……んっ、れろ……れりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あぁ……んちゅぱっ、美味しい……んっ、オチンチンの味……貴方のにおい\nがこびりついてるの……舌が止まらない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「れろぉ……んっ、えるっ、れるっ……ちゅぱっ……んふっ、亀頭がよだれま\nみれになっちゃってる……ちゅぱっ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「このドロドロの感じ……んっ、変な気分になっていくのよね……ちゅぱっ、\nぴちゃ……んちゅぱぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、れろ、れる……オチンチンどう……？　気持ちいい……？　ちゅぱっ\n、もっとして欲しい場所とかある……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、そう……タマを直接舐めて欲しいのね？　分かったわ……れろっ\n、えろっ、れろぉぉぉぉんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んふっ、力が抜けていく感じ……？　そうなのね……ふにゃっとしちゃって\n可愛いわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「でも、オチンチンの方は全く逆……ずっとビンビンになっちゃって……あぁ\n、もっともっとしゃぶってあげたいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「れろ、んれる……れろぉっ……もういいわよね……咥えちゃうわ……オチン\nチン……はぷっ、んむっ、りゅぷっ、くぽぉぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んぁぷっ、ちゅぽっ、くぷっ、りゅぷっ、んりゅっ……れろっ、じゅぽっ、\nくぽぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんっ、口に余る位……太いわ……かぽっ、んふぅっ、ちゅぱっ、頬張りき\nれない位……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「れも……くぽっ、じゅぱっ、ちゃんと脈打ってるのは感じる……んくぷっ、\nれるっ……私のフェラが……効いてるのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふっ、よかった……んちゅぷっ、んふぅっ……もっともっと……お口マン\nコでのご奉仕……たっぷり味わって……んくぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んりゅっ、じゅぽっ、ちゅぱっ、んふっ……太ももの所……気になるかしら\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷっ、おしゃぶりしているうちに……いつの間にか、乳首が……\nしこって来ちゃったみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「でも、こうして擦れると、快感もどんどん増幅されてくるでしょう……？　\nんっ、くぷっ、りゅぱっ……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「乳首の感触を楽しみながら……んっ、唇で……柔らかく挟んで……はむっ、\nあむっ、んむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んふぅ……この甘噛み……気持ちいいみたいね……あむっ、あむぅ……亀頭\nが震えてきたわ……ちゅぷっ、んぱっ、くぱっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「どう……？　出したくなって来たんじゃない？　いいわ……飲ませて……精\n液……んくぷっ、ちゅぷっ、んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303134" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「喉に直接味わいたいの……んっ、くぷっ、貴方の……特濃ミルク……んんっ\n、りゅぷっ、いっぱい……飲ませへっ……ちゅぷっ、んじゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんんんっ！　ふぐっ、んんっ、んくっ、んふっ……あぷっ、んんっ、ふご\nい……れてるっ……んんっ、こくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁ、んぷっ……飲ませてとは言ったけど……こんなに出すなんて……んち\nゅぷっ、口から溢れちゃうわ……ちゅぷ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はふぁ、んんっ……あぁ、喉に残ってる……んふぅ、でも……この感じ……\n癖になりそう……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んぱっ……はぁ、射精落ち着いたわね……待ってね、先っぽ舐めて綺麗にし\nちゃうから……れろ、んっ、えろっ、れろっ……れろぉぉぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁ……ちゅぱ……んっ……ごちそうさま……れろっ、とっても美味しかっ\nたわ……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「れろ……んふ……ところで、まだ……オチンチンは元気が有り余ってるみた\nいね？　勃起も、全然収まってないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「泳ぎ疲れてなんて心配は全くなかったみたい。どう……続き……する？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふっ、そう言うと思ったわ。まぁ、いらないって言われたとしてもしちゃ\nうんだけど……ちゅぷっ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「だって、私がもっと欲しくて堪らないんだもの……このオチンチン……まだ\nしゃぶっていたくて仕方ないの……んちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「精液の味……すごく残ってる……んちゅぱっ、はぁ……不思議よね、最初は\nただ生臭いだけで美味しくも何ともなかったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「今は、身体がこれに慣らされちゃった……ちゅぱっ……オチンチンの味も…\n…精液の味も……大好物になっちゃったの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あ……もちろん、誰のでもってことはないわよ？　欲しいのは、貴方のオチ\nンチンだけ……ぴちゃ……んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「もうすっかり形も覚えちゃった……ちゅぷっ、このくびれのちょっとだけ曲\nがってる所とか……皮の付け根の所……少し汚れやすいのよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふ、大丈夫、今日は綺麗よ。もう私が何度も舐め上げたところだから。ん\nちゅぷ……ぴちゃ……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「キンタマも、またマッサージをご所望かしら？　ふふっ、優しく握ってあげ\nる……このくにゅって握れる感触……面白いわよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「また、咥えるわね？　はぁんむ……くぽっ、んちゅぷっ、おふっ、んむっ、\nじゅぽっ、くぽっ、りゅぽっ、んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あぁむ……んっ、じゅるぅぅっ……んぱっ、あぁ……オチンチン、跳ね回っ\nてる……んふっ、もう……大人しくしきれないんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そんなに尿道口を吸われるのが気持ちいいの？　普段の態度より、ずっと素\n直で分かりやすいんだから……んちゅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、また新しいお汁……じわじわって滲んできてる……んちゅっ、ちゅぅ\nぅ……またイキそうなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「いいわ……周りからじっくり蕩けさせてあげる……ほら、またおっぱいも…\n…こうして……んんっ、押しつぶして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「弱いキンタマも……ぎゅうっと握って……ちゅぱっ、このまま……吸い上げ\nて……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ね……んちゅぷっ、気持ちいい……んっ、オチンチンの震えが大きくなって\nる……んちゅるっ、限界でしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んふっ、腰が引けてるわ……ダメよ……逃がさないんだから。射精するまで\n、身体は絶対離れないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はむ……ちゅぷっ……ふぉら……もう無理しないで……楽にして……じゅる\nっ、んじゅるるっ、ちゅぷっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「飲ませても……顔に掛けても……好きにしていいんだから……さあ……ちゅ\nぷっ、んちゅうぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、口に……？　いいわ……んちゅぷっ、そのまま、気持ちよく……びゅ\nって出してっ……んじゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんんっ！　ふぐっ、んっ、れた……んんっ、こくっ……精液……またいっ\nぱい……んくっ……こくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「はぁんむ……ちゅぱっ、んふっ……いいわね、まだまだこんなに残してたな\nんて……じゅぷっ、んちゅっ、ちゅるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303303" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んっ、美味しいわ……濃厚なザーメンミルク……飲むだけで若返りそう……\nこくっ、んくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んふんっ……まだ残ってるわよね？　待ってね……本気のバキュームで吸い\n出してあげる……じゅぽっ、じゅぽぉぉぉぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んふっ……♪　れてきた……んっ……こくっ、こくんっ……んっ、ちゅぷっ\n、んふっ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふふ、ごちそうさま……堪能させて貰ったわ。後は、オチンチン綺麗にさせ\nてね……ちゅるっ……んちゅぅぅぅ……ちゅぱっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ふぅ……こんなものかしら。んっ、疲れた体にはちょうどいい栄養補給にな\nったわ。どうもありがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303308" ]},
		{"command":[ "SETIMAGE", "0", "still_00015903_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「それにしても……やっぱり夏の海は魔物ね。自分でも、こんなに積極的にな\nるなんて思わなかったもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「そうね、続きはまたの機会……案外、すぐ……かも知れないわね？」", "NORMAL" ]},
