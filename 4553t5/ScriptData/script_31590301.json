		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……ちゅぷっ、んちゅっ……ちゅぅぅ……んふっ……これでいいわ、\nいっぱい飲ませて貰ってありがとう」", "NORMAL" ]},
