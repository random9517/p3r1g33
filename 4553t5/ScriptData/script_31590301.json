		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「え……顔に掛けたいの……？　ふふ……いいわ……貴方の好きなようにして\n……んっ……ちゅぱぁっ……ちゅぷっ、んちゅぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あんっ！　あぁっ……出てるわ……いっぱいのザーメンミルク……顔に……\nいっぱい掛かってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303402" ]},
