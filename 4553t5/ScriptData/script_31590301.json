		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんっ……すごい量……全然出し切ってなかったのね……んんっ、本当にシ\nャワーを浴びてるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303403" ]},
