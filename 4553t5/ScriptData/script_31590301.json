		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……あぁ……薄くなってない……粘っこいのがこんなに……んふぅ\n……にちゃって指で広げられるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「あ……もう少し出そうなの……？　分かったわ、残ってる分も、ちゃんと吸\nい出してあげるから……ちゅぽっ、じゅぽっ、じゅぽぉぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_159_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラー・サイアム" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あぁ……またピュって出てきたわね……んっ、今度こそ……\nこれで全部かしら……？」", "NORMAL" ]},
