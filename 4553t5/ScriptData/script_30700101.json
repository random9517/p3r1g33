{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007001_01_03" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},		
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "070_0103101" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「えーっと……あー……これは、任務の一環……なのか？　まぁ、隊長君がこ\nれで元気になってくれるなら、ボクはどっちでもいいんだけどさ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103102" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「まぁ、仕方ないさねぇ。隊長君は男の子だからなぁ……。男の子は女の子の\nおっぱい大好き。保健の教科書にも載ってることだわな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103103" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「……でも、ちょっと恥ずかしくはあるよ？　胸とか男の人に見られるのは、\n子供の頃風邪ひいた時に小児科の先生に診てもらった以来だからさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103104" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「だから、あんまりジロジロ見んなよー。その辺は宜しく頼むぜ。……え？　\n触るのは……もう。優しく、だぞ？　摘まんだら怒るからね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103105" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「よーし、じゃあこのボクの柔らかおっぱいで、ピュピュっと射精しちゃおう\nか？　隊長君、気持ちよくなーれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103106" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「え？　これってパワーアップに繋がんの？　適当言ってね？　……はー、マ\nジか！　じゃあこっちも真剣にやらないとなぁ、ごめんごめん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103107" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「そんなことなら、胸だけじゃなくて口も使うか。よーし、隊長君のオチンポ\n、いっただっきまーす！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103108" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「はぁむ……じゅるるるぅ……ちゅぅぅ……はぁ、独特な味だなぁ。うーん、\n別に、褒めては……ないかな？　フフッ、れろれろれろぉぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007001_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103109" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「色んなとこ舐めるからさー、ちゅぱぁ……どこが気持ちぃか、教えてねー。\nじゅろぉぉ……ちゅぱちゅぱぁ……んじゅるるるるぅぅ……ちゅぱぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103110" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「オチンポって……こんなに熱くなんだね。胸の谷間に、じんじん伝わってる\nよ？　ボクのおっぱいも、熱くなっちゃう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103111" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「ほらほら、どこが好きなんだ？　ちゃんと言いなさーい。れろれろれろぉぉ\n……じゅるぅ、ちゅぱぁ……ちゅぷぅぅ……じゅっぽじゅっぽ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103112" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「じゅるるぅ、はぁ……オチンポの臭いが……んううぅ……強く、なってる。\n先っぽから、カウパーが……アハ、これ、気持ちのいい証拠だろう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103113" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「つまり、隊長君は……オチンポの先っぽが好きってことかなぁ？　この穴を\nれろれろするとぉ……んふぅ、可愛い顔になってる、フフッ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103114" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「んぅ？　ボクの顔も……可愛いだって？　こんな時に何言ってんだよ、全く\n。じゅるるぅぅ……れろぉれろぉぉぉ……はぁ、もっと言え」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007001_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103115" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「んうぅ……カウパーの味が濃くなった。生臭くって……はぁ……美味しくは\nない。でも、隊長君のだからな、全部舐めるよ、じゅるぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007001_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103116" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「うわわ、最初に胸に挟んだ時よりも……オチンポ大きくなってないか？　い\nや、絶対なってるよ！　……ほ、ほらぁ、やっぱりぃ……成長期かよ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007001_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103117" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「じゅるるぅぅ……れろぉぉ……ちゅぱぁぁ……んふぅ、顎痛い。隊長君のが\n、でっかくてさぁー……れろれろれろぉぉ……仕方ないなーもぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103118" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「んううぅ……喉の奥まで、オチンポの先っぽが……はふぅ、ちょい、苦しい\n、かな？　じゅぽぉぉ……れろれろぉ……んじゅるるぅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103119" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「フフッ、もっと気持ち良く……してあげんね？　次は、カリのとこ舐めよっ\nか？　れろれろれろぉ……どぉ？　ここも好きだろう？　白状しろー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103120" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「ちゅぅぅ、ちゅぅぅぅ……裏筋にも、はぁ……熱烈なちゅうだ！　んちゅぅ\nううぅぅう……れろれろれろぉ……アハ、気持ち良さそうじゃん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103121" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「ふわ……隊長君のオチンポ……おっぱいの中でビクンビクンって脈打ってる\n。なんか生命力感じちゃうなぁ……ドキドキしちゃうぜ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103122" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「んぅ、おっぱいそんな優しく撫でられたら……はぁぁ……おっぱいが、喜ん\nじゃうだろぉ。もっと撫でて欲しくなるぅ……くぅん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103123" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、隊長君！　そんなおっぱいを……はぁぁ……も、揉んじゃうのかぁ？\n　あはぁぁ……胸の形がおもちみたいにぐにぐに……これはエッチだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103124" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「んん？　隊長君、笑ってないか？　楽しんじゃってる？　はぁ……そんな風\nにおっぱい揉むの、楽しいのかよー。じゃあ仕方ないね……ちゅぱぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007001_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103125" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「ボクのおっぱい、熱いだろう？　……隊長君のオチンポと同じ位。ハハハッ\n、隊長君におっぱいもみもみされたからだぞ？　んじゅるぅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103126" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「じゅぽぉ……じゅぽぉぉ……はぁ、まだ揉むのかぁ？　オチンポの快感に、\nじゅるぅ……集中したまえよ？　欲張りな隊長君だなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103127" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……隊長君の指が……ボクのおっぱいの先っぽをくすぐって……ん\nふぅ、そこ、あはぁ……痺れちゃう。先っぽは弱いんだ、止めろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103128" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「ああぁ、隊長君が弄るからぁ……乳首がエッチな形になっちゃったぁ。バカ\nバカ、見るなよぉ。……あはぁ……恥ずかしいんだから、なぁ……んぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103129" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……責任、取れよぉ？　……硬くなった乳首もぉ、ぷっくり膨れた\n乳輪もぉ……全部全部隊長君の手で可愛がってぇ……！　あはぁぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103130" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「おほぉぉ……だ、ダメぇ。おっぱいの快感に流されるぅ……はぁ。ぼ、ボク\nの任務は……オチンポしゃぶりなんだからぁ！　んぶぅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007001_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103131" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「んじゅるぅ……じゅっぱじゅっぱ……れろぉ……はぁ、隊長君のオチンポに\n、集中！　はぁ……オチンポ奉仕にぃ……集中、しなきゃぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103132" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「れろれろれろぉぉ……じゅぷぅ……じゅっぽっ……じゅぽぉぉぉ……はぁ、\nんじゅるうぅぅうぅぅ……ちゅばぁちゅばぁ……れろっ、れろぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103133" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……オチンポのビクビクが……はぁ……さっきよりも、大きくて\n、激しい……！　おっぱいが谷間から揺らされるぅぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00007001_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103134" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「イきそうなんだろぉ、隊長君？　はぁ……いいよぉ、ボクのおっぱいで、お\n口でぇ……たぁーぷりザーメン出しなさい？　じゅぽっ……じゅぽっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103135" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「んぐうううぅうぅ！　き、来たぁ……！　んぼぉおおぉぉ……んぶぅぅ……\nはぁぁ、んぐぅううぅぅ……じゅるるるぅぅ、じゅるぅぅ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00007001_01_07" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103136" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「ふわぁ、熱い。じゅるりっ……それに、重くて……はぁ、さっきのカウパー\nと……比べ物にならない程……生臭い、んじゅるるぅぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103137" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「んぐぅぅ……んぐんぐっ……！　はぁ、はぁ、はぁ……。ぜーんぶ飲んだぞ\n？　ほら、あーん？　口の中空っぽだろぉ？　フフフッ……」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00007001_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103138" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「何で君が顔を赤くするんだ？　まったく、隊長君は……。こういう時は、褒\nめてくれよ、ボクを。頭とか、撫でちゃってくれよ？」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00007001_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103139" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「そうそうそうやって……ザーメン全部飲めてえらいぞーってさ。そういうの\nで、結構嬉しくなっちゃうんだぜ？　ボクなんてさ、アハハ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "070_0103140" ]},
		{"command":[ "SETNAME", "芽能隊員" ]},
		{"command":[ "SETTEXT", "「だからさ、またパワーアップしたくなったらボクを呼ぶがいいさ。……あぁ\n、ただ気持ち良くなりたい時も……お気軽に、な？　フフフッ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}