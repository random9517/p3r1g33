		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁっ、お尻にっ……？　はいっ、掛けてっ……どこでもっ、主様のっ……\nお好きな場所にぃっ、精液っ、掛けて下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁぁんっ！　熱いのっ……掛かってますぅっ、あはぁぁぁんっ、\nウチもっ、またっ、イクっ、イキますぅぅぅぅっ！」", "NORMAL" ]},
