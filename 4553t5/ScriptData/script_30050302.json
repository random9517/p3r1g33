{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あ……ぅ……これで……いい、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「も、もちろん恥ずかしいです……こんなにも無防備に……貴方に恥ずかしい\n姿を晒しているんですから……身体が燃え上がりそうな位です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304102" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ですが、ウチはもう覚悟を決めていますから……貴方でしたら、ウチはどう\nされてもいいと……そういう気持ちでいるんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……は、はい……お尻でも、どこでも……好きなように触って頂\nいて構いません……今のウチは、貴方のモノですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁ……さすられてる……ひゃぅぅぅ……ゾクゾクしますっ、んく\nぅ……はぁぁっ、あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「これは……んっ、入れる……準備をなさってるんですよね？　あぁ……指先\nの感触を……いつもより、はっきり感じます……んぁ……ふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「は、はい……指も……いいです、よ……んんっ！　あぁっ、中……カリカリ\n……引っ掻いて……あっ、い、いいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぅ……はい、濡れてしまってます……今日一日、ずっとこうなるって思っ\nて……そうすると自然にじゅくって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……音させて……んくぅ……あ、あんまり……遊ばないで下さ\nいっ、ウチはっ……ずっと切ないのですっ、あぁっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「も、もう……意地悪はイヤです……貴方のオチンチンも、カチカチになって\n……おへそまで反り返ってるじゃないですかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチも同じです……はぁ……んっ、オマンコ……待ちきれないんですからぁ\n……早く……中っ、熱くて太いのぉっ……深くにお願いっ、しますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁーーーーっ！　あっ、来たっ……はひぁっ、入って来まし\nたっ……オチンチンがウチのオマンコっ……広げてっ、ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……そんな、ずぶって……い、一気に奥……までぇっ……こ、こん\nなぁ……は、ひぁぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅ……あぁ……ぜ、全部……入ったんですか？　は、はひぃ……オ\nマンコいっぱいになってるの……感じ、ますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あ、あの、動くのは……後ちょっとだけ待って……下さい……んんっ、オマ\nンコ……敏感になり過ぎて……あ、危ないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぅぅぅ……はぁぁぁ……はい、これで……大丈夫です。む、無理してませ\nん！　ちょっと準備時間が欲しかっただけですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はい……もう気にせずに動いて……あっ、んひぃっ！　あぁっ、はっ、あっ\n、んぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ……オチンチンがっ、ぐぶってっ……ウチのオマンコっ……かき混ぜ\nてますっ、く……ぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「きゃうっ、はぅっ、あっ、んぁぁっ！　作り変えられてっ……いきますっ、\nウチのオマンコがっ……オチンチンの形にさせられるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁんっ！　ずりゅって……抜けていくのっ……ビクってなりますっ…\n…くぅぅぅんっ……あっ、はぁっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ま、また……入って来てっ……くぅぅぅっ！　あぁっ、体重乗せてっ……め\nり込ませてぇっ……はひっ、これっ、あへぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……不思議な気分です。少し前までは、このように……抑え込まれるな\nんて……屈辱でしかなかった筈なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「今は……あぁっ、こうされることが……んんっ、はぁっ、嬉しくて……あぁ\nっ、オチンチンっ……当たるっ、あひぁっ、あっ、あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ、これっ、もっ、イクっ……あぁっ、オチンチンでっ、オマンコイカ\nされちゃいますっ、はひっ、あっ、もうっ、おっ、おぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「イッてっ、いいですかっ！？　はひっ、ありがとうございますっ、あっ、イ\nキますっ、ウチのオマンコっ、もうイクぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぁっ……はぁっ……はぁっ……あぁぅ……すごい、れふ……頭が真っ白\nになりますぅ……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「獣の姿は……本能の感覚が……研ぎ澄まされて……より、刺激を……敏感に\n感じるようになるんれふ……だから、すごく……感じてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁっ！　あっ、あぁっ、またっ……んっ、はっ、オチンチンっ……動き始\nめてっ、あっ、ぐちゅって……ひぁっ、あっ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ、溢れてくるっ……ウチのエッチなお汁がっ……どんどん、漏れてっ\n……止まらないですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁぁっ、はひっ、じゅくじゅくしてるのっ、オチンチンで掻き出\nして下さいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチのオマンコっ……オチンチンに絶対服従しますっ、全部っ……全部っ、\n主様のモノですぅっ、んはぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はっ、もふもふの所っ……撫でられるのいいっ、あっ！　あぁっ！\n　そんなっ、ここで優しくされたらっ、ウチはっ、またっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はひぁっ、イクッ……イッちゃいますっ！　オマンコっ、し、幸せになりま\nすぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁっ……あぁっ……ま、まだ……イッてるのにっ、オチンチン止\nまらないっ、は、ひっ、いひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ、ビクってしてっ……出るんですねっ？　あはぅっ、はいっ、中にっ\n……出して下さいっ！　オマンコに中出しっ……お願いしますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんぅぅぅぅぅーーーっ！　あぁっ……どぷって……来て、ますっ、せーえ\nきっ、はひゅっ、ドロって……バカに、なるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んはぁぁっ、ぴゅっぴゅって……お潮……出てるぅ……ひゃ、ふっ、出され\nてるの……止まらにゃい……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……は、ふぁ……ひゅみまへん……取り乱し……まひたぁ……あぁ……\nんっ、ふっ……は、へぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「大丈夫……です……んっ、オチンチンが良すぎて……今は……その余韻を味\nわっているところ……ですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふう……素敵でした……主様ぁ……ウチは……ずっと、ついて……いきま\nすぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はふ……落ち着きました。まだ、少しクラクラしますけど……でも、平気で\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「貴方のオチンチンが満足しきっていないことは承知の上です。ですから、ウ\nチはお務めを果たさなくてはなりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いえ……その言い方は正確ではありませんね。ウチが……ウチのオマンコが\n、まだしたいと……そう思っているんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ですから、どうか……もっと遠慮なく、欲望を満たして下さい……あぁっ！\n　はひっ、またっ……奥にっ……来てっ、ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んはぁぁぁぁぁ……後ろから貫かれるの……あぁっ……すごい……ウチの本\n能が悦んでしまってますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ゆっくりオチンチンが抜けていく時に……カリのところが……あっ、引っか\nかるのが、す、好きぃ……ひゃ、うぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ……でもっ、その後のっ……ずぶって……は、入って行くときもいい\nですっ、全部……オチンチンっ、何でもいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、ウチも……ちゃんとご奉仕します……オチンチンに満足して頂け\nるように……んんっ、んふぅっ、オマンコ……ヒクヒクさせますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んんっ、くぅぅぅんっ……お尻っ、持ち上げてぇ……プルプル……\nさせてぇっ、あっ、あぁっ、んっ、はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ど、どうですか？　ウチのオマンコ……ちゃんと、オチンチンにご奉仕出来\nてますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、くぅぅ……よかった……んっ、嬉しいですっ、主様に……喜んで頂け\nるのが……ウチの喜びでもあるのですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あ、あの……も、もし……よかったら……頭を……ナデナデしてもらっても\n……いい、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ふみゅぅぅぅぅっ……これぇ……あぁっ、好きぃ……主様にナデナデされる\nのぉ……嬉しくてぇ……あっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、オチンチンもっ、また跳ねてっ……中をっ、グリグリって、あひぁっ\n、ダメですっ、こんなのっ、何も考えられなくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁーっ、またイクッ……はっ、ひぃぃぃっ！　オマンコまたっ、\nイキますぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁぁぁ……からだ……震えが止まらない……あぁぁ……まだオチン\nチン動いて、あひぁ……メロメロになりますう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あっ、ラストスパートですかっ？　はひっ、大丈夫ですっ……い\nっぱいっ、ウチのことっ、して下さいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「この逞しいオチンチンを満足させるのはっ、ウチのオマンコだけですからぁ\nっ、あっ、あぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁっ、また……中でっ、ビクってしてっ、主様も出ますかっ？　\nオチンチンっ……イキそうですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いいですよっ、全部……全部出しきっちゃって下さいっ……ウチのオマンコ\n……好きなように使ってっ、射精して下さいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あひぁっ！　はいっ、中にっ……もう一回中出しっ……お願いっ、んひっ、\nしますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁーっ！　出てるっ……またっ、熱いの出されてっ……ウチ\nもまたイクぅぅぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅん……あぁぁぁ……ぎゅって抱き締めて下さい……んぁぁ、中出し\nされながらくっついているの……素敵ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あふっ、子宮がトロトロにされてます……はぁぁ、これは……赤ちゃん出来\nてるかも知れません……ウチ……ママになっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、全部搾り出して下さいね……ウチの中に余らせずに……ぴゅっ……\nですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……あぁ……終わりましたか。はい……オチンチン、たくさん頑張\nって頂きました……感謝します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……それにしても、絶倫です……やはり、獣化状態の方が主様\nの欲望を受けとめやすいかも知れませんね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「主様はこの姿……お嫌いではありませんか？　もし、お気に召さないのなら\nウチは……元に戻っても……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000503_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
