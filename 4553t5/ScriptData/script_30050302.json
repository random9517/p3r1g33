		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……むわっとした精液の匂いが広がりますぅ……すんっ、すんすんっ…\n…あぁ、これぇ……ウチが病みつきになるやつぅ……」", "NORMAL" ]},
