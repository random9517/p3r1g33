{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ここが襲来者（インベーダー）の本拠地がある場所だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530014" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「なんだか、ひんやりして静かなところだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530021" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「確かにちょっと肌寒いかも……水着で来たのは失敗だったかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530015" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「そうでもないと思うなぁ。ビキニって布地が少ないから音が立ちにくいし、\n潜入に向いてるかも～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530016" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「別に服装なんて関係ねぇだろ。邪魔なヤツは、シノビ・サッポウで倒すまで\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530017" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「しっ……！　お前たち、おしゃべりはそこまでだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530015" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ふあああぁ……退屈だな。どうせ原住民は入って来ないんだし、見張りなん\nていらないだろ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「まったくだ。それに他の同胞たちは各地で暴れ回ってるのに、不公平にもほ\nどがあるぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ふむ……どうやら見張りが居るみたいだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530016" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「先生。ここは僕たちに任せてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530022" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ウタ、ゲン。僕とシャラで左の見張りを倒すから、右の見張りをお願い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「おう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530018" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「りょーかい。ウタ姉に合わせるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530016" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あーしも準備オーケーだよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530017" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、行くよ……スクールガール・ミュータント・ニンジャ・ラビッ\nツ！　いざカマクラ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530024" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「ラビットパワー！　イェーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530019" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "-370" ]},
		{"command":[ "SETCHARA", "1", "char_00009702_01", "8", "CENTER", "-20" ]},
		{"command":[ "SETCHARA", "2", "char_00009902_01", "8", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「んっ！？　なっ、なんだ貴様たち……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「遅い！　ウタマロ・ストライク！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530020" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「グエーーーーー……！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「不意を突いたとはいえ、随分と楽勝だったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530021" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「さっすがウタ姉。僕の援護なんて必要なかったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530018" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「こっちも片付いたよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530019" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「みんな。まだ見張りを倒しただけなんだから慎重にね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021530025" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「そうだぞお前たち。まだ入り口を見つけたわけではないし、油断するでない\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530017" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ここから先は敵の懐の中……地の利は向こうにあるし、なにが起こるかわか\nらん。気を引き締めておけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「先生は心配性だな。この程度の襲来者（インベーダー）、今のオレたちには\nブレックファースト前……いや、時間的にはランチ前か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021530022" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そうそう。早くミッションを終わらせて、残りの時間は海で遊ぼうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021530019" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「いいね。あーしもっと海で泳ぎた～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021530020" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「浮かれよって……痛い目を見てもしらんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021530019" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}