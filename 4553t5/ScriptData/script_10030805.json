		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「でも、まだお昼前なのにめちゃくちゃ腹が減って……。ああ、さっさと片付\nけたいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115690002" ]},
