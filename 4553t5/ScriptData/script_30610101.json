{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "061_0103101" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「お疲れ様です！　古舘飛空、入ります！　……隊長、どうなさいましたか？\n」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103102" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ん？　……パワーアップの相談？　……これはこれは！　自分でお役に立て\nるなら、いくらでもお手伝いするっス！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103103" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はい、何でもっスよ！　何でもやります！　……だって、隊長が強くなる為\nでしょう？　喜んでやらせて頂きます！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103104" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「……で？　何をすればいいんっスか？　……ふんふん……ふんふん……んぅ\n？　んんんんんんん？　……は？　それ、は……ええぇええぇええぇー？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103105" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「そ、それは……え？　何でそんな……ちょ、冗談きついっスよ。隊長、そう\nいう感じの冗談、自分マジで苦手で……本当に、あの……あのっ……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103106" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「え？　え？　冗談じゃ……ないんスかぁ？　そんな……いや、何でもするっ\nて言いましたし、本当に隊長のお手伝いならしたいんですが……ううぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103107" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あの、これ……自分が断ったら、他の先輩方が……お手伝いすることに、な\nるんスよ、ね……？　そっか、やっぱそう……なんだ。ぐぬぬぬ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103108" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「わ、分かったっス。やるっス。……が、頑張らせて、頂きます！　え、えー\nっとぉ……おっぱい、ですよね？　わ、分かってます。おっぱい……うぅぅ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103109" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ああぁーっと！　隊長！　あの……あっち！　あっち、向いてて下さい。\n……な、何でって……そりゃー、あれっスよ。恥ずかしいんだもん……」　", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00006101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103110" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「うんうん……そう、そんな感じで……。ほら、誰か来たら大変なんで……ド\nアの方とか、見張っててほしいっス。どうも。では……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103111" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「えーっと、おっぱいに……こ、これを……挟む……。な、なんてエッチな…\n…うぐぐぐ……そ、そうだ。深呼吸！　すぅー……はぁー……よし、いざ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103112" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ひっ！　あ、熱っ……！　な、嘘ぉ？　あ、あの……男の人のアレって……\nこんなに熱いんっスか？　うぇぇ、ちょっと……ベタベタもしてる……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103113" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「これを、口で……。ううぅ、や、やるっス！　やります！　出来ますって！\n　よ、余裕っスよ！　うぁ……なんか、生臭い……んうぅうぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103114" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「せーのぉ……はむぅ！　んんっ！　んうぅううぅぅ……んじゅるぅ……れろ\nっ、んぐぅううぅぅう……じゅるっ、じゅるるぅ……はぁ、ぷはぁっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103115" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ふぇ？　あ、こうじゃなく……舐め、る？　はぁ……れろぉ……ぺろっ、ぺ\nろぉ……れろれろぉ……んちゅぅぅ……ちゅぱちゅぱぁ……こうっスか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103116" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「じょ、上手？　ほぇ、そ、それは……それは、なんか……ヘヘッ。ちょっと\n、嬉しい……うん。ちゅぱぁ、れろれろぉ……じゅるるぅ……あはぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103117" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んふぅ……れろっれろれろぉ……はぁ、隊長……。ひょっとして、ここ……\nはぁ、ほら……この、括れたところ……気持ち良かったりするんスか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103118" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「え？　だって……じゅるるぅ……れろぉ……はぁ……ここを舌の先っぽでな\nぞると……れろれろっ！　あはっ、ほらぁ……ここがビクビクって、ね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103119" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「大きく震えるからぁ……んぅ？ここって、その……えぇ？　あー……言わな\nきゃ駄目っスか？　んうぅぅ……何でそんなエッチな……嫌ですよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103120" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「えぇ？　こ、これも……パワーアップの為？　う、嘘だぁ！　隊長、嘘は駄\n目っス！　そーゆーのはズルいっスよぉ！　れろれろれろぉ、はぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103121" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「……わ、分かりまし、た……。うぅ……言いますよ。嘘じゃないなら、言い\nます。えーっと……隊長の、お……お、おおお……オチンチン……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103122" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁ……隊長のオチンチンの括れたところを舐めたら、ビクビクって震えた\nからぁ……気持ちがいいのかな？　って、思ったんですぅ……ううぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103123" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「お？　な、何ですか、隊長？　頭、撫でてくれるなんて……。あ、本当に気\n持ちが、いいと……ん……なんか、その……隊長は知らないかもですが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103124" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「自分、隊長に褒めてもらえると……無茶苦茶嬉しくて……今、なんか……胸\nが、ドキドキして……あ、あっと……えっと……ぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103125" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「な、舐めます！　オチンチン、舐める！　隊長が喜んでくれること、いっぱ\nいしたいっス！　隊長、気持ち良くなってください！　いっぱいいっぱい！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103126" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んじゅるるぅぅ……れろれろぉぉぉ……ちゅぱぁぁ……じゅるぅ……んちゅ\nぅぅ……はぁ、れろれろっ、ちゅぱぁぁ……んじゅるぅぅ……あはぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103127" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「じゅっぽじゅっぽじゅっぽぉおおぉぉ……はぁ、オチンチンの先っぽから、\nんううぅぅ……お汁出てきたぁ……はぁ、これも……生臭い、んじゅるぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103128" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ずっと溢れて……んふぅ、口の中に……溜まるぅぅ……はぁ\n。こ、これぇ……いっぱい出てきて……え？　違うのが……出るぅ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103129" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「え、えっと……舐めたままで……はぁ、いいんっスね？　んじゅるるぅぅ…\n…れろれろっ、んじゅるぅ……じゅっぽじゅっぽ……れろれろぉぉおぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103130" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「じゅるるぅぅ……あはぁ……お、オチンチンが！　んじゅるるぅぅ……舌の\n上で、あはぁ……は、跳ねるぅ！　んぶぅぅ……ちゅぱちゅぱぁぁぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103131" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んぐぅぅ……んぐぅううぅう、んぼっ？　んじゅるるぅぅ、じゅるるぅ！　\nんぐうううぅぅ！　じゅるるぅぅう！　んぶぅううぅぅううぅう！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103132" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んああぁ……お、オチンチンがぁ……ブルブル暴れて……はぁ……た、隊長\nぉ……口の中に、はぁ……あったかいお汁がぁ……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103133" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「ふぇ？　これ……飲む、の？　わ、分かりました……飲むっス。んううぅぅ\n……ごくんっ！　はぁ……すっげー苦いっス。美味しくは、ないよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103134" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「れろれろぉ……じゅるるぅぅ……ちゅぱぁぁ！　はぁ、はぁ……これで、オ\nチンチン……綺麗になったっスね。はぁ……隊長、にこにこ……してる？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103135" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「何で？　……あ、これが出たのは……気持ち良かったから、なんだ……。は\nぁ、はぁ……なんか、隊長が嬉しそうなのは、自分も嬉しいっス。ヘヘッ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103136" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「んぅ？　あぁ、顔にもさっきの零れてましたか？　うへぇ、みっともないな\nぁ。れろぉ、じゅるぅ……はぁ、これで……自分の顔も綺麗になりました？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103137" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「あの、ちなみに……さっきの液って……何なんっスか？　その、苦いやつ。\n……ふぇ？　あ、精液……はぁ。これが精液かぁ……。ふぇ、飲んじゃった」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00006101_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103138" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「今日という日は、忘れられなそうっス。初めて、精液飲んだ日……。うぅ、\nちょっとエッチな日っスね。ヘヘッ、まぁ隊長のだからいっかぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103139" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「どうっスか？　パワーアップ……したっスか？　そっか、良かったぁ。自分\n、隊長のお役に立てるの、やっぱり無茶苦茶に嬉しいっス。エヘヘ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "061_0103140" ]},
		{"command":[ "SETNAME", "古舘隊員" ]},
		{"command":[ "SETTEXT", "「また、呼んでくれたら……すぐ来るっス。オチンチンの舐め方も、分かった\nし。……なんかほら、隊長だけじゃなくて、自分もパワーアップした気分！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}