{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「どうしました、ご主人様？　こんな物陰になんて呼び出して、楽しそーなも\nのでも見つけました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304101" ]},
		{"command":[ "SETCHARA", "0", "char_00015703_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おー……ご主人様の海パンがパンパンに膨れ上がってて……なるほど、たま\nってる……ってやつかな？　なーんて、にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いいですよ、ご主人様が望むなら、見るだけじゃなくて私の身体をいくらで\nもお使いくださいな♪　水着であろうと私は貴方のメイドです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……それに、ちょっとこの格好のまま可愛がってほしいなって思ってもいま\nしたからね、にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「この岩に手をつけばいいんですね――水着は脱がないまま？　にゃふふ、さ\nっすがご主人様、わかってますねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015703_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いいですよ、ご主人様、いつでも来てください。私のオマンコで、たっくさ\nん気持ちよくなってくださいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んにゃうぅ……！　来たぁ、ご主人様の熱々おちんちん、一気に奥ま\nで、あっ、んうぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人様のおちんちん、相変わらず大きくて、逞しくてっ、んぁぁんっ\n……！　にゃふふ、お腹いっぱいになっちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「最初からおまんこも濡れ濡れで驚きました？　機能的に愛液を出そうと思え\nばいくらでも調整できますからね、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それに、ほらっ……んぁんっ……！　分かりますか？　私のおまんこが、ご\n主人様のおちんちんにピッタリ吸い付く感覚」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、こーゆーこともあるかと思い、おまんこのパーツはご主人様のお\nちんちんにフィットするものを搭載してるんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それに、言ったじゃないですか……んっ、んぁんっ……私だってご主人様に\nかわいがってほしかったって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「相手の水着姿を見て、駆動炉が高まったのは、ご主人様だけじゃないんです\nよ？　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁんっ……！　い、一気に激しくなって、あぁんっ！　この体勢\nで突かれると、おちんちんが本当に奥まで届いてっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人様、折角ですから、おっぱいも一緒にっ……んにゃぁんっ！　そ\nうです、もっとぎゅ～って、乳首までさわってください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんんっ！　ご主人様の指がおっぱいに沈み込んできます……！　\nぐにぐにって揉みこんで、引っ張られてっ、んあぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、こうして力強くご主人様に可愛がられるの、やっぱり好きかも、\nんあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――私が何も反撃せずにされるがままになってるのは珍しい、ですか？　に\nゃふふ、今日はそーゆー気分なんです。こんなロッテは、お嫌いですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、ありがとうございます、ご主人様。もちろん、私もだいだい\nだい、だ～い好きですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁんんっ！　あっ、んあぁんんっ！　ご主人様のおちんちん、ズドン\nって身体の芯まで響いてっ、んふぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それに、これは水着のせいでしょうか……？　変に解放感があって、いつも\nより声出ちゃう、かもっ、あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「誰か見に来るかもしれない太陽の下でえっちするのって、こんなに気持ちい\nいんだ、んあぁんっ……！　にゃふふ、癖になっちゃうかも♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁん……！　激しすぎて、水着からおっぱいがこぼれ落ちちゃいそ\nう……ご主人様の手で、支えてくれますよね？　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私の方からも、腰を前後に振らせていただきますね……♪　あっ、んぁんっ\n……！　子宮パーツの入口に亀頭をこすりつけて、ぐりぐ～り♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「締め付けも、もっと強くっ、んんんっ……！　オマンコの中をグネグネ駆動\nさせ続けて、搾り取って上げちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様のおちんちん、相変わらず大きくて、がちがちに固くてっ、んにゃ\nぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「先っぽもぴくぴくし始めましたね～♪　――もちろんです、ぜーんぶおまん\nこの中で受け止めて差し上げます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んひゃっ、んあぁんんっ♪　また、一気に激しくなってっ、あぁんん\nっ！　おまんこの壁ぐりぐり削られてっ、んひゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こ、こんなに大声を出してたら、誰か覗きにきちゃうかもしれませんね？　\n――いえ、恥ずかしくはありますが、それはそれで……にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様だって、そーゆーアブノーマルなの、意外と嫌いじゃないでしょう\n？　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――えっちなメイドにはお仕置き、ですか？　んひゃぁんっ！　そんないい\n訳しなくても、責めを緩める気なんてないくせに、あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、んふぅんっ！　んにゃぁんっ！　おまんこの中、全部かき出す\n勢いで抉られてっ、おっぱいも乱暴に揉まれてっ、んふぅんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「わ、私だって、やられっぱなしじゃありませんよ！　膣内を締め付ける機構\nをこうして、んんんっ！　にゃふふ、凄い締め付けでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「竿の部分を圧迫して、離して……んにゃぁんっ♪　奥にぶつかる亀頭も、子\n宮口でちゅーちゅーしちゃいます♪　んあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ノイズ来ました、えっちなノイズが増えてっ、んにゃぁんっ！　出してくだ\nさいご主人様！　そのまま私の中に、精液を出してくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃあぁあぁ～～っ♪　ご主人様の精液、すごい勢いっ！　内部機構が全\n部ドロドロになってっ、あっ、んにゃあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「来た、このノイズ、あっ、あぁあぁんっ♪　ドクドクって精液の動きに合わ\nせて、私もイっちゃうっ、んにゃぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁんっ♪　いつもより気持ちいいのは、やっぱり外でしちゃって\nるからですかね？　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……もちろん、一回だけでお終いなんてことは、ないですよね？　――にゃ\nふ♪　それでこそ、私のご主人様です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「まだまだ本番はここからです♪　水着姿のロッテを、心行くまでご堪能くだ\nさいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ♪　やっぱりこの体勢だと、おちんちんが簡単に奥まで入ってき\nますね～♪　あっ、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「さっきはご主人様にいっぱい動いてもらっちゃいましたから、こーゆーのは\nいかがですか？　……んにゃぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、驚いてますね～♪　子宮パーツの振動機能……ようはバイブ\n機能ですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「射精したばかりの敏感おちんちん、こうしてっ、んんんっ！　微弱ではあり\nますけど、亀頭がぶるぶるって震えるの、気持ちいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「子宮口におちんちんを押し付けた状態でぐりぐりってしてあげれば……あっ\n、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もちろん、腰を動かすのも止めませんよ♪　じっくりねっとり、おちんちん\nを抜いて、飲み込んで、あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「根元から先端まで、ゆ～っくりズボズボしてあげちゃいます、んあぁんっ♪\n　にゃふふ、括れ部分も狙って締め付けて、んにゃぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様も、もっと激しくっ、んひゃぁんんっ……！　さっき出した精液を\n全部かき出すぐらい、おちんちんズボズボしてください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ああぁんっ♪　おっぱいにも、まだ指が食い込んでっ、んにゃぁんっ！　乳\n首ぐりぐり、すごいっ、んあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様の手が、おっぱいを持ち上げてっ、あっ、んふぅんっ！　にゃふふ\n、そうやってタプタプされるの、結構好きかもです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、んあぁんんっ！　んにゃぁんっ！　さ、流石はご主人様、私の\n弱い所、ぜーんぶ知られちゃってますね、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そこ、おへその裏側っ、あぁんんっ！　お腹のスキンがぼっこりするぐらい\n強く突かれるの好き♪　あっ、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「また来た、気持ちいいノイズが増えてきました！　あぁんっ！　ご主人様は\nどうですか、私の身体、楽しんでくれてますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――って、にゃふふ、聞くまでもなかったみたいですね♪　ご主人様のおち\nんちん、おまんこの中でどんどん膨らんできて、んにゃぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私も、もっともっと腰を振りますから、ご主人様もいっぱい私を可愛がって\nくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んひゃあんっ！　あっ、あぁんんっ！　括れの部分が、おまんこの壁ぐりぐ\nり削ってっ、あっ、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「また、子宮パーツもガンガン突かれちゃう♪　あぁんんっ！　おちんちんで\nかき回されるの、気持ちいい！　んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「す、すごいエラーの量……！　ノイズも気持ちよくて、あっ、んひゃぁんっ\n！　ご主人様のおちんちん、パンパンに膨らんできたぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私もイクからっ、ご主人様の精液を受け止めていっしょにイきますからぁっ\n、ふあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「好きなところにぶちまけてください！　ご主人様と一緒にっ、あっ、ああっ\n、んひゃぁあぁぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃあぁぁんんっ♪　あっ、ふああぁんっ！　ま、また、お腹の奥に精液\nびゅーびゅーきてっ、イクっ、イクゥゥゥっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様、腰の動き止めないでください！　射精中のおちんちんで、私の中\nをもっとかき回して、あっ、あひゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おっぱいもぎゅ～って、強く揉んでください！　あっ、んにゃぁんっ！　ご\n主人様の手でもみもみされるの大好きっ♪　あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「頭の中エラーだらけになっちゃう♪　んにゃぁんっ♪　おまんこの中、熱す\nぎて蕩けちゃいそうでっ、あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「やっぱり外でえっちするのすごいっ！　こんな解放感、データにありません\n♪　んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んぁんっ、んんっ……誰かに見られるかもしれない岩陰で……太陽の下です\nるのがここまで気持ちいいだなんて……にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「露出プレイってのにもちょっと興味が出てきちゃうかも……なーんて♪　ご\n主人様はどー思います？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――おお、凄い勢いで頷かれた……まったくもー、私のご主人様は相も変わ\nらずどーしよーもない変態さんなんですから～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私には言われたくないって？　――にゃふふ♪　仕方ありません、だって私\nは、そんな変態ご主人様の所有物なんですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「さ～て、ちょっと休憩したらまた海に遊びに行きましょうか！　にゃふふ、\n今日はまだまだ付き合ってもらいますよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ふにゃあぁぁぁんっ♪　おまんこからおちんちんが抜けて、あぁんっ♪　ご\n主人様の精液、すごい勢い♪　んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「中に出されるのもいいですけど、こうしてボディを汚されるのも大好きです\n♪　どんどん身体に降り注いで、あっ、にゃあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「精液が付着したパーツから熱が伝わって、あっ、んふっ、あぁんっ♪　いつ\nものノイズ来ました♪　エラーが心地よくてっ、んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「外でえっちするのが、こんなに気持ちよかったなんて知りませんでした！　\nデータベースに書き加えておかないと……んにゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んんんっ！　射精が全然止まらない、あぁんっ♪　ご、ご主人様、な\nんだかいつもより精液の量多くありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――え？　私の水着姿が魅力的すぎるのが悪い？　もっともっと汚してやり\nたくなる、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふ、にゃふふふ♪　こーゆー時ばっかり褒め上手になるんですから、私\nのご主人様は♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「その……実はこの水着も、ご主人様がこーゆーの好きだろうなって選んだり\n……したんですよ？　にゃふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃぁんっ♪　またおちんちんがビクンって跳ねましたねぇ♪　海で遊ぶの\nもいいですが……もう一回、いっちゃいます？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、ではでは、水着で着飾った貴方のメイドを、心行くまでご賞味く\nださいな♪　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}