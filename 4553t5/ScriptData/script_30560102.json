{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "056_0104101" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「お疲れ様です、隊長。……あの、呼んで頂けて本当に嬉しいです。……本当\nに、本当に。え？　何で嬉しいのか、って……それは……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104102" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「隊長と二人きりになれるのが嬉しいからに決まってるじゃないですか。大好\nきな隊長を独り占め出来ることが、とってもとーっても嬉しいんです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104103" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「え？　……エッチなこと？　違いますよ！　隊長が好きなんです！　エッチ\nなことが好きって訳ではないですよ、そんな風に誤解してたんですか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104104" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ひ、酷いです。……え？　じゃあ今日はエッチなことしないんですか？　そ\n、それは……いや、全然構いませんけど、でも……えぇ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104105" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「冗談、なんですか？　……もう隊長は本当に意地悪ですね。……好きですよ\n。エッチ、好きです。ただ、隊長とするエッチが好きなんです……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104106" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「これ、重要ですから……。是非に忘れないで下さい。では、早速……エッチ\nなこと、しましょう？　……隊長、大好きです。この瞬間待ち遠しかった」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104107" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ううぅ……隊長のこと好きだけど……やっぱりこの格好は、恥ずかしいです\n。いやらしいところ、全部見えてる。おっぱいも、おまんこも……はぅん」", "NORMAL" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_02_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104108" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「え？　もう乳首……勃ってますか？　や、やだぁ……そんなとこじっくり見\nないで下さいよ、恥ずかしい……。仕方ないんです、期待してるから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104109" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「私の身体は今この瞬間全部……隊長のことだけをドキドキして待ってます。\nこれは、緊張じゃなくて……期待です。私はエッチになってしまいました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104110" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ほら、オマンコが濡れているでしょう？　割れ目が滲んで、お汁が溢れちゃ\nってる……。これだって、期待してる証拠です。隊長が欲しいんです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104111" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ね？　だから隊長……私に下さい。隊長の、その……はぁ……バッキバキに\n勃起してるオチンポ。隊長だって、私の中に入れたいって思ってるくせに」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104112" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んぅ……私のオマンコが濡れてるみたいに、隊長のオチンポの先っぽからも\n我慢汁漏れてる。……ねぇ？　早く。オチンポとオマンコでキスしましょ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104113" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んぁぁ……隊長のオチンポ、熱い。私のクリトリスよりも熱いです。ああぁ\n、もっと擦って下さい。隊長のチンポくらい、クリ、熱くしてぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104114" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「くぅん、濡れるぅ……。オチンポの先っぽでクリいじめられると、オマンコ\nの奥がじゅんじゅん濡れるの分かるぅ。あはぁ、隊長……気持ちいいですぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104115" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「気持ちいいよぉ、気持ちいいのにぃ……はぁ、じれったいですぅ。クリだけ\nじゃなくて、早くオマンコに……オマンコの奥をチンポの先で、早くぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104116" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ああぁ、隊長のオチンポと私のオマンコから溢れたエッチなお汁で、グチュ\nグチュ音がしてる。あぁん、こんなのもっとエッチな気分になるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104117" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「もう！　もう耐えきれない、隊長！　早くぅ、私のオマンコの奥を……隊長\nのオチンポでグルグル掻き回してぇ！　私のオマンコを思いきり虐めてぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104118" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んああぁああぁあぁぁぁぁ！　お、オチンポぉおぉぉお！　んくぅぅ、入っ\nてきたぁぁあぁ！　隊長のオチンポ、私のオマンコにぃ、くぅううぅぅん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104119" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あ、熱いぃいいぃ！　隊長のオチンポの熱で、私のオマンコがトロトロに溶\nかされちゃうぅぅ。ま、ますます……オマンコが濡れるぅううぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104120" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ああぁ、簡単に入っちゃうぅぅ！　恥ずかしいよぉ……こんなにゆるゆるの\nオマンコ、違うんですぅ！　隊長が好きだから受け入れちゃうだけでぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104121" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「いやぁ……もっときつく隊長のオチンポを締め付けたいのにぃ……私のオマ\nンコすぐに涎垂らして隊長を受け入れちゃうぅ。恥ずかしいよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104122" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んぅ？　隊長……私のオマンコ、気持ちぃんですか？　柔らかくってふわふ\nわ……？　くぅん、ああぁ……お、奥のトロトロが……好きなのぉ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104123" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「嬉しいよぉ……隊長にオマンコに褒められて嬉しい……！　任務で褒められ\nた時よりも、嬉しいのぉ。最高のオマンコって言われるの嬉しいよぉおぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104124" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「おほぉぉお！　隊長、気持ち良くなってぇ！　私のオマンコ使って……いっ\nぱいいっぱい気持ち良くなってぇ！　私のマンコでシコシコしてぇ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104125" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「好きぃぃ……！　好きなんですぅ！　隊長がぁ……隊長とのセックスがぁ…\n…隊長のオチンポがぁ……！　大好きぃいぃ！　もっと深く繋がりたいぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104126" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「おおぉおおぉおお！　腰をもっと叩きつけてぇええぇ！　私のオマンコ、ゴ\nリゴリ削ってぇえぇ！　隊長チンポで私のマンコをドロドロにしてぇえぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104127" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んひぃいぃ！　んひぃいいぃいぃぃ！　子宮が震えてるの分かるぅううぅ！\n　隊長チンポでマンコが揺すぶられてるのぉおぉ！　んほぉおおぉおぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104128" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あはぁ、隊長のオチンポ……大好きぃ！　硬くて熱くて大きくてぇ……血管\nが浮いてボコボコの形なところも、大好きぃい！　全部マンコに馴染むのぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104129" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「おほぉおぉ！　おほぉおおぉぉ！　一突きされる度に、頭が……真っ白にな\nるぅうぅ！　全身で感じちゃうぅ！　わ、私……全部マンコになるぅぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104130" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「隊長のオチンポで……気持ちよくなりすぎるぅうぅ！　もぉ、全部……全部\n気持ちいぃ……！　手も足も胸もお腹も、全部マンコぉ！　オマンコぉおぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104131" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ああぁ……隊長も、感じてくれてるんですか……？　う、嬉しい！　私のオ\nマンコで気持ち良くなってくれてるの、嬉しいよぉおぉ……！　くぅううん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104132" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ねぇ、隊長……オチンポが、ビクビクしてます。……イきそう、なんですか\n？　はぁ……いいですよ？　私の中で、オマンコで……イってほしいなぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104133" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「そう、です……。奥で……オマンコの一番奥……あはぁ、子宮口にオチンポ\nの先っぽでキスしながら……イって下さい。オチンポ汁出して下さいぃぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104134" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ああぁぁあぁ、隊長のオチンポがぁああぁ！　暴れてるぅう！　ビックンビ\nックンしてるぅうぅ！　こ、こんなの私も……子宮が痙攣するぅううぅ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_02_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104135" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んぼおおおぉおぉおお！　き、来たぁああぁぁ！　隊長の精液……！　私の\n子宮に……ああぁああぁ、凄い！　流れ込んでくるうううぅうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104136" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んひいいいぃいい！　た、溜まるの分かるぅうぅ！　隊長のオチンポ汁がぁ\nああぁ……私の子宮を満たしていくの、分かるよぉおぉ！　んぼおおおぉ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104137" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「な、中出し好きぃいいぃ！　隊長の精液が子宮に塗り込められて……イくの\nが止まらないぃいぃ！　何度も……何度もイくぅうぅ！　中出しでイくぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104138" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ああぁあぁ……好きですぅ、隊長……。身体の一番奥で、隊長を感じること\nが出来て……嬉しいよぉ、嬉しいんです……！　大好き、だからぁ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104139" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「だから、お願いします。……ぎゅって、抱き締めて欲しいんです。お互いに\nイきまくった身体で……きつく抱き締め合いたいんです……駄目ですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0104140" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁ……隊長、そんなにきつく抱き締めてくれるなんて……嬉しい。……私\n、これからも頑張りますね。誰よりも、隊長のお役に立ちたい。……大好き」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}