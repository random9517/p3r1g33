		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "（急にハチ乙女じゃなくてタコ乙女として登場しろだなんて。しかも……こん \nな恥ずかしい格好で……！）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023220002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「タコ乙女様出番です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010023220001" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「今回は、一瞬でやられないようがんばりましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010023220001" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「そうですね。……それにしても、みなさんは普通の衣装なんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023220003" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "5", "CENTER", "0" ]},		
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「えっと……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023220001" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「夏だし、海だし、油断していたわけじゃないんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_010023220002" ]},
		{"command":[ "SETCHARA", "0", "char_00018301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｈ" ]},
		{"command":[ "SETTEXT", "「水着になるにはお腹のお肉とか……ムダ毛とかが……ねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_010023220002" ]},
		{"command":[ "SETCHARA", "0", "char_00018201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「人妻の水着姿に、需要があればいいんですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_010023220002" ]},
		{"command":[ "SETCHARA", "0", "char_00018401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「……そうですか。と、とにかく行きましょう。隊長さんが、助っ人を用意し \nていると言ってくれたので！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023220004" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "7", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETTEXT", "ステージにタコ乙女が戦闘員を引き連れて現れる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ターコタコタコー！　このビーチは怪人派遣組合のタコ乙女が占拠したタコ \nー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023220005" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "7", "CENTER", "0" ]},	
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「抵抗するなら、必殺のタコ墨で真っ黒にしてやるタコー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023220006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「お気に入りの水着を台無しにされたくなかったら、大人しく言うことを聞く \nタコー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023220007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「うぅ……あんまり激しく見栄を切ると、いろいろ見えちゃいそうです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023220008" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "5", "CENTER", "0" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ、みんながバカンスを楽しんでいるビーチに怪人が現れるなんて！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そうですね。まったく、懲りない方たちです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020023220001" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00005002_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「みんなの楽しい夏休みを台無しにされてたまるか！　なあ、氷華！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ええ、許せませんね。成敗しましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020023220002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "こいつ……めちゃくちゃ芝居が下手だ……！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "変身前の氷華の出番を増やすようシナリオを調整してもらったが、氷華の演技 \n力を計算に入れてなかった……！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく頼むぞ氷華。いや、マスク・ザ・ブルー！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ええ、また一瞬で片付けてあげましょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020023220003" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ちょぉっと待ちなぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220001" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そう、このタイミングで奈羅苦とアルスラが登場する！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あなたたちは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020023220004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そう……その通り……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220002" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「西の奈羅苦！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「南のアルスラ・マグナス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023220001" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦＆アルスラ" ]},
		{"command":[ "SETTEXT", "「我らオーヴァーハング四天王！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220004" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00019902_01", "0", "CENTER", "-300" ]},
		{"command":[ "SETCHARA", "1", "char_00020002_01", "0", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "エロい水着の怪人がさらに追加で登場して、客席が湧いている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ほ、本物の怪人！？　助っ人を呼ぶとは聞いてましたけど、こんなのアリで \nすか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_030023220009" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00021903_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「悪いな。ブルーの相手をして、倒すのはこのアタシなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220005" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「独り占めはいけないわ。マスカレードは、私たち四天王共通の宿敵なんだか \nら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023220003" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「で、お前がブルーに変身するんだな……って、あああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220006" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ステージの上で奈羅苦が声をあげた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「お前、前に居酒屋であったよな？　お前がブルーだったのか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ええ、そうですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020023220005" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「なんでそんとき言わねぇんだよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220008" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あのときはプライベートだったので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020023220006" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「そ、そうだったのか……。まあ、プライベートは大事だよな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220009" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「あんまり無駄話をしてないで、台本通りいくわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010023220004" ]},
		{"command":[ "SETCHARA", "0", "char_00020002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「ああ。くく……やっとまたブルーと戦える……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220010" ]},
		{"command":[ "SETCHARA", "0", "char_00019902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「２年待ったぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010023220011" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「ふたりがかりだろうとかまいません。相手をしましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020023220007" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "宿敵を前にしたからか、氷華の台詞に熱が入る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとまて氷華！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "変身しようとする氷華を慌てて止める。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これを使え！　パワーアップアイテムだ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「なんですか？　そんな小道具を使うなんて、台本に書いてありました……？ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020023220008" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「変身シーンを見せるために、アイテムを使うんだよ！　ショーなんだから。 \nこれも仕事のうちだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "というのは嘘。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "これは、ブルーに恥ずかしい格好をさせるために用意した偽の変身アイテムだ \n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「……そうですか。仕方ありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020023220009" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "アイテムを受け取った氷華は、奈羅苦たちの方を向く。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「変身！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020023220010" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "威勢のいい声とともに、ステージに登場したのは……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「な……っ、これは……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010023220001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00005004_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "全裸よりも恥ずかしい、肌をほとんど隠せていないきわどすぎるスーツを纏っ \nたマスク・ザ・ブルーだった！", "NORMAL" ]},
