{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0184" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "ある日、俺たちは朝から次元管理統制局にやってきていた。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……眠い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115490001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おいルナテミス、もっとしゃきっとしろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115490001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だいたい、今日は日曜日だぞ！　それなのにこんな朝早くから呼び出して…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115490002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんもねむたーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115490001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「すぅ……すぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115490001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ちょっと、立ったまま寝てる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115490001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「んぁっ、寝てないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115490002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「やれやれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115490001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あ、レディ・ホープさんが来ましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115490001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「お待たせして申し訳ありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだ！　待ったぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115490003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ホープちゃん、今度はなんの用なのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115490002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ええ、まずはこちらの資料をみてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490002" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちに配られた資料、それはとある惑星の観光資料だった！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「秘境の惑星？　『ヒ＝ホーカン』？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010115490001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「皆さんには、こちらの惑星に行っていただき、秘宝を探して欲しいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490003" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「秘宝？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115490004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「つまり、お宝ってこと？　なんだか汚い星だけど……いったいどんなお宝が\nあるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010115490003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「このヒ＝ホーカンには、『ヒ＝ホーカンの秘宝』と呼ばれる秘宝が眠ってい\nるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490004" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「そのまんまの名前だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115490002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「その秘宝を見つけた者には『銀河を揺るがす大いなる力を与える』という伝\n説があります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490005" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そんなの、本当にあるのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115490003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なんだか胡散臭い話だねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115490002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そう思うのも無理はありません。ですが、我々の調査でヒ＝ホーカンの赤道\n付近に巨大地下空洞が発見されました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490006" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「おそらくここに、ヒ＝ホーカンの秘宝が眠っているでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「わたしたちは、それを見つけてくればいいんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115490002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「今度は宝探しかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115490003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやぁ、お前たちも大変だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "見つかるかどうかわからない宝を探しに行くことになるなんて、まあ俺は今回\nも統制局で留守番をすることになるだろう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いやぁ、困ったなぁ、軟禁状態だもんなぁ。美味しいケーキを食べながら吉報\nを待つことにするかぁ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「あと、今回はカツマさんも同行してくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490008" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、わかってるって。俺も同行……ええぇっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、俺は統制局に人質じゃないのか！？　いつもならそうだろ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「自分だけ楽できると思うなよ、このボケナスビ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115490005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマも同行していいなら、ついてきてもらおう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115490002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当にいいのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「今回はそこまでする必要はないでしょう。みなさんがきちんと依頼を果たす\nことを信じています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490009" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そ……そうか……。俺も行くのか……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETTEXT", "というわけで、俺たちは本部へと戻ってきた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「お前たち、レディ・ホープから話は聞いてきたな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「秘宝だ！　宝だ！　なんとしてでも宝を見つけるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、長官、どうしたんですか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "出迎えてくれた長官は、妙にノリノリだった。まさか、あのうさん臭い話を信\nじているのか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「でも長官、そのヒ＝ホーカンまではどうやって行くの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115490004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「宇宙船なんてありましたっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010115490003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「それなら問題ない！　現地まではダイアンサスが運んでくれることになった\nからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイアンサスって、あの巨乳艦隊か。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんでも、襲来者と敵対状態にある俺たちと協力関係を結んでいるらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺もクルーを見たときには驚いた。巨乳艦隊と呼ばれるのも納得のバストがそ\nろっていたからなぁ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「さあ行くのだお前たち！　船はもう来ているぞ！　宇宙の果てでロマンを追\nい求めてくるのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はーっはっはっはー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "長官のノリがおかしいのが気がかりだが、俺たちはダイアンサスの戦艦に乗り\n込んで、秘境の惑星へと向かったのだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……行ったか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふふ……ふふふ……。ヒ＝ホーカンの秘宝か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「こちらを探すのに協力して欲しいのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490010" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「これはいったい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490008" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0203" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ヒ＝ホーカンの古代文明の遺産。日本の貨幣価値に換算すれば、およそ５０\n００兆円です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「５０００兆円！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なるほど、協力して探索し、この５０００兆円を山分けしようということか\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「いえ、この５０００兆円相当の遺物は副産物です。我々の目的はこれではあ\nりませんので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「もし秘宝が見つかれば、こちらは差し上げます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「なっ！　５０００兆円もらっていいのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010115490011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「ええ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090115490014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
