{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0137" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、はぁ、はぁ……片付いたか！？」", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、敵の影は見えん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「車酔いのほうは……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おさまった！　問題ない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大暴れしたせいで、吐き気も吹っ飛んだらしい。単細胞な王女さんで助かった\n。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あとは宇宙港まで一直線だが……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「問題はそちらだな。長官の情報では、先ほどとは比べものにならない勢力が\n、既に集結しているはずだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……美味しいサンドイッチ屋さんに寄る時間……ないわよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あるわけないでしょう、まったく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010107040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、お腹すいてしょんぼり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010107040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わたしも腹ペコだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107040001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「がまんしろよ！　オレだって結局カップラーメン食い損ねたんだ。ほら、み\nんな乗れ！　行くぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0130" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_006" ]},
		{"command":[ "SETTEXT", "すきっ腹を抱え、ひたすら道路を走り続けること数十分。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見えてきたぞ！　あれが……宇宙港か！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスが指さす先に、ＥＤＯの宇宙港が見えてくる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……な、なんだか想像していたものとは違うが……。で、でもまあ、自然も\n広がっているしな！　……海ではないが……うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ルナテミス、なに言ってるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107040001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「宇宙港を、普通の港のようなところと勘違いしていたのではないだろうか…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあどっちでもいいや！　とにかく、警備隊は管制塔に立てこもってるはず\nだ。連絡をとれるか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……はい、やってます！　あ！　いま、通信がつながりました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107040001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まりあがそう言うと、車に積まれた通信機から管制官のものらしき声が聞こえ\nてくる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "管制官" ]},
		{"command":[ "SETTEXT", "「こちら管制室……敵襲に合い……発射準備を進めていた小型ロケットが占拠\nされ……」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「小型ロケット！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107040003" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "管制官" ]},
		{"command":[ "SETTEXT", "「ロケットを奪還してくださ……発着地点、は……宇宙港の東、見ればすぐに\nわかりま……ザザ、ザザ、ザザザ……」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ま、待て！　まだ何も聞いていないぞ！　通信を切るな！　まだだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……ダメです！　通信、途切れました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010107040003" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どう考えても緊急事態のようだ。港の東に発射場があるのだな！？　すぐに\n向かうぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107040006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「管制室はどうするの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107040002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そちらも気にはなるが……おそらく、敵の主力はロケットの方にいるはずだ\n。まずはそちらを叩こう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107040004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「まずはロケット、次に管制室だね！　だったら急がないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010107040003" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうことだな！　行こう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0131" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そして、俺たちがロケットに駆け付けると……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「やはり、敵の狙いはここか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010107040007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「かんべんしてくれよ……ここにも敵がこんなに……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ！　ボヤいている場合ではない！　敵はロケットの内部まで侵入して\nいる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090107040005" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だったら、私らも突っ込むしかない！　突入だーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010107040002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}