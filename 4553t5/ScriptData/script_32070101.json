{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あなた。ねえ、あなた。……そうよ、そこで暇そうにしているあなたを呼ん\nでいるの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「今日も今日とて、くだらない仕事ばかりしているんでしょう？　そんなの放\nり出してしまって、わたくしにめいっぱい尽くすというのはどうかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……フフフッ♪　ここまで言ってもわからないなんて、あなたは本当におバ\nカさんね。この、スーヤチカ……宇宙海賊団滅棲俄鬼の姫たるわたくしが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あなたを気に入って、特別にとりたててやろうというのです。さ、ぬぎぬぎ\nして裸になりなさい。気持ちいいことをしてさしあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「それが気に入ったなら……あなたもこのわたくしの従順なる部下の一人にな\nることね。そーれ、それそれ……脱ぎなさい脱ぎなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んふっ……♪　わたくしの魅力でメロンメロンにしてさしあげますから……\nせいぜい楽しみにしていることね？　ほら、はじめましょう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わ……♪　これがあなたのおちんぽ……？　すごぉい……。大きいのね。色\nツヤもいいし……すんすん、蒸れた臭いも卑猥でイイわ……すんすんすん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020701_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「え？　これから何をするつもりか……ですって？　決まっているでしょう。\nフェラチオよ。なあに？　本当の、本番エッチがしたかったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んふっ……♪　わたくしに欲情してしまう気持ちはわかるけれど……それは\nまだ早いわ。それに、これはあくまであなたを籠絡するための行為だもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わたくしが♪　一方的に♪　あなたを気持ち良くしてアヘアヘさせなければ\n意味がないじゃない！　わかっていないのね……って、あん、やぁだぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「おちんぽ……ピクピク痙攣してますわ♪　なんて貪欲な……。極太のちんぽ\n……くさーいムレムレのオスちんぽ……ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「これはおしゃぶりしがいがありそうだわ……。わたくしのお口の技に、いつ\nまで耐えられるか見せてもらうわよ？　ん？　フェラの経験……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「無いけれど、舌でぺろぺろして口に咥えてじゅぽじゅぽすれば、男は簡単に\n堕ちるんでしょう？　カンタンよ。わたくしを誰だと思っているの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「宇宙海賊団滅棲俄鬼の名において、素晴らしいテクニックを披露できるに決\nまっているじゃない……って、んむっ！？　きゃっ、きゃああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ごちゃごちゃ言っていないで早くしろ……ですってぇ？　わ、わかっている\nわよ……。ん……チュ。……んっ？　な、なぁに、この味……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「先走り汁は透明で、味はないと聞いていたのに……。ん、ちゅ……ちゅ、ち\nゅぴ……ぺろっ、ぴちゃ……。な、なんだか薄くしょっぱい気が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「なにかしら、これ……おしっこの味？　それともおちんぽの味って元からこ\nうなのかしら……？　ま、まあいいわ……ナメナメしゃぶしゃぶするわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……ん……ぴちゃ……ぴちゃ、んむっ……。ぺろっ……ぺろ……くちゅ、ち\nゅっ、ちゅ……んん……。亀頭が大きすぎてちっとも咥えられないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「大きいのも不便なものね……。っぴちゃっ……んむ……。れろ……れろ、れ\nろ……。ふぁ、ベトベトしてきた……。か、感じてはいそうだけど……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「れろ……れろ、れろ……くちゅ……。ちゅぅ……ちゅ、ちゅむ、ぷっちゅっ\n……。え？　もっと深くしゃぶれ？　大きく早く舌を動かせ？　んもう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わたくしに指図しないで！　今、必死にやっているでしょう！？　……れろ\n……うう……。ネチョネチョがネバネバして難しい……。ぴちゃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「こ……これで本当に、あなたをわたくしの虜に出来るのかしら……。んっ、\nな、なにかが……違う、ような……。えぅ……おちんぽ大きすぎるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「全然たくさん舐められない……。ぴちゃ、ぴちゃ……。ん……やっぱりフェ\nラはやめようかしら……って、今度はなにっ！？　やっ、あッああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んぷぅっ！？　にゃ……にゃにをするのっ、いきなりぃい……っ！　んぷっ\n！　く、くるひい……！　おちんぽいきなり喉奥まで入ってき、たぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……イラマチオ……？　いらまひおってなに、よ……？　んん！？　おえっ\n！？　あっ……んぷぅううっ！　やめっ……やめへっ、やめ……うう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あっ！？　うぷっ……んぢゅっ……ぐちゅっ、ぁ、あ、あ……！　頭……無\n理やり押さえつけないれぇ……。くるひい……ぐちゅっ、ぐっちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ん、んっ……！　よろこんでるみたいに見える……？　そんなぁ……！　あ\nっ！　あぷっ……ぐちゅっ、わたくひ、わたくひよろこんでなんか……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　おひんぽ……！　ぶっといおひんぽがお口の中で暴れ\nふぇ……！　んっ、んぐっ、んむぅうっ……息、息もできないのに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「どうしてぇ……♪　頭がぼーっとひて……だんだん気持ひ良くなっれきた…\n…。んじゅっ……ぐちゅっ！　じゅっぽっじゅぽっ、あっ、あぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「いらまひお……っ！　ぢゅるっ、イ、イラマチオ、気持ひいい……怖いぃ…\n…！　無理やりされて、……んむっ、か、感じるだなんれぇ……ずちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あっんっんっんっ……！　んぷっ……んん！　らめ……らめれひゅう……！\n　おひんぽ、太いおひんぽお口にねじこまないれ……んっうっんっんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「酸素、足りな……ひ、……んむっ！　先走りのお汁ネバネバ……んぢゅっ！\n　ぐちゅぷっ、ぐちゅっ……あぷ……お汁で溺れひゃいまひゅぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んっんっんくっ、んん……んぷぅうっ！　……え？　わたくひのお口……ち\nっちゃくてキツくて、ヌルヌルでイッちゃいそうでひゅ、か……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「らめ……！　こんなっ……！　わたくひがあなたをイかせてもてあそぶ予定\nだったのに！　わたひのお口で勝手に気持ち良くなるのはらめれひゅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あふっ！？　んぐっ！　ずちゅずちゅしないれ、……んぅっ！　んっんっん\nっ！　出しちゃらめ、らめ……！　っぐちゅっ、ずっちゅっずちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ん～～～～～～～っ！？　んぷぅううっ！　んむぅううう～～～～！　んぅ\n！　んぅ！　んぷぅっ！？　んん～～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んぷぁあ……ッ♪　ちょ、ちょっとぉお！　ダメだと言ったじゃないでひゅ\nかぁ！　……っあぅっ！　盛大に口の中に精液が……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「にが、いぃい……！　ドロドロして舌の上が気持ちわるいぃい～～……！　\nうぅっ……。な、なんれ……！　途中まで上手くいっていたのにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「こんなあっつい大量の精子……いつのまにかドクドク注がれて……うううう\n～！　……んえふっ、こほっ……けほっ、けほ……んぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……な、なんですか……？　わからせ？　わがまま放題のわたくしに、主導\n権を握らせず……イラマチオで口を犯すことが教育ぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「む、むかーっ……！　せ、せっかくあなたを気に入って、一番の部下にして\nさしあげようと思っていたのにぃ……裏切り！　愚か！　信じられないぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んっ……見てよぉ……。口の中からダラダラ精子が溢れてきてるぅ……。け\nほっ、こほっ……。次は飲んで欲しい？　って、ま、まだするの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「いやですわいやですわ！　あっ……！　お、押さえつけないでぇ……！　あ\nっ、やっ、おちんぽ！　おちんぽを唇になすりつけて……んぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んッむ……！　あぷぅうっ……！　も、もう一度イラマチオぉお……！？　\nんむっ……んぐっ……！　ふぁ……！？　あああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ぐちゅっ！　ぐっちゅっ、ぬっちゅっぬちゅっ！　やぁああ……っ♪　精液\nっ……ぬぐっていないのにお口におちんぽ入れる、からぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「口の中のドロドロとおちんぽについたまんまのネチョネチョで……んむ！　\nわたくひ、わたくひのお口の中が精子でいっぱいに……んっんっんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「い……一体ぜんたいなんでこんな目にぃいぃいい！　はぷ……！　ぬちゅっ\n！　ぐちゅぅううう……！　ぷちゅっ！　ずっちゅっずっちゅっにゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んぁっ、んく……！　ずちゅっ！　ずっちゅっぶちゅっぶちゅっ……！　は\nぁっ……はぁ、はぁあっ！　ぬちゅっ！　ぬぷぷぷっ、ぐっちゅっぢゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わ……わかりまひた、もうわかりまひたぁああ……！　わたくひが間違って\nおりまひた！　んぢゅっ……籠絡ぅ、籠絡をくわだて、て……ぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あなた、を……！　あなたをわたくひの支配下に置こうとひまひた、わたく\nひは悪いメスガキれふっ……！　んぁっ、あっ、イラマチオも当然れひゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わたくひは……悪い子な上に、太いおちんぽでお口っ……塞がれてズポズポ\nされて……！　むぅっ！　ずちゅっ！　顎まで精子まみれにされてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ガチガチでビキビキのおちんぽ様にお仕置きっ……してもらうと感じる変態\nれひゅ、あっ！　ううっ……ぐちゅっ、ぐっちゅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んぷぇ……っ！　こ、これからっ……これからは良い子にひまひゅ、おちん\nぽ様の言うことをききまひゅ……！　だから許ひてくだひゃいいぃい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ゆるっ……ゆるひて……！　うぁっ、あっぁっあっ……んん！　はい……！\n　言われたとおり、ピストンしてくるおちんぽをナメナメしまひゅ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅされてる間……いっしょおけんめいおしゃぶり、しまひゅ、…\n…れろっ！　にゅる……にゅるっ、れるっ、れる、れろっ、れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ン……っ、んん、んんん！　な、舐めれば舐めるほどおちんぽ、硬くなって\n……反り返ってゴチゴチで……お口、麻痺してきたぁ……うぁっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ひゃ、ひゃい！　しゃぶりまひゅ！　心を込めてひゃぶりまひゅ！　……ぐ\nちゅっ！　ぐちゅぐちゅっ！　れろれろれろっ、じゅぷっじゅっぷっぐちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「どうぞ……どうぞわたくひの、躾のなっていないメスガキマウスに、わたく\nひのお口に喉に、あっつい最高の精子、精液をくだひゃい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「飲みましゅ、今度はちゃんと飲みまひゅぅううう！　ぢゅるっ……ぢゅるる\nるっ！　こうやって！　すすって飲みましゅ！　ぢゅるっ、ぢゅっぢゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「欲しい、れひゅ……頑張って飲みまひゅ、だから……！　だかりゃくだひゃ\nい、あなたのせーし飲ませてくだひゃい！　どうぞ！　すぐくだひゃい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ん～～～～～～っ！　ぢゅぢゅぢゅぢゅぢゅぢゅっ……ずぢゅぢゅぢゅぢゅ\nっ！　ま、まだまだ飲めまひゅ……もっと！　もっとぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んっうううっ！　す、すごい量ぉおお……なんでぇ、出すのは二回目なのに\nぃ……！　絶対一度目より多い、です……んん、ごくっ……ごくっごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あ……待って、待ってください……。んぁ……っ、んぷ……！　量が多すぎ\nて、一度には飲めなくて……ゆっくり、ゆっくり飲み干します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……れろ……れるぅうう……♪　お口の中の精子、舌先で集め、て……んっ\n……ごくっ♪　ごきゅっ……ごきゅ……ん、まだいっぱいあるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「んくっ……んく……ごくっ……ごくっ……ごく……。っぷはぁっ……！　ま\nだ、口のまわりがベタベタですが……これは致しかたありません……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁああ……♪　まさかあなたに、お口をめちゃくちゃに\n犯されてしまうなんて……全く想定外でした。虚を突かれました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「強引に口全体を使われて……。喉を鳴らして飲むくらいたくさんの精液を詰\nめ込まれて……。んっ、ヒドイことをされたはず、なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ドキドキして、フワフワして……。あぁ、言うことを聞かされるってこんな\nにイイんだって、知ってしまいました。性的嗜好が歪んでしまいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「大勢の部下を従えるわたくしが、あなた……あなた一人に翻弄されてしまう\nだなんて……くやしいです！　なのに……なのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「もっとヒドい目にあわされてみたいと思ってしまって……！　こ、これは二\n人だけの秘密ですからね！　誰かに言ったりしないでください、お願い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あっ……！　精子……精子が上がってきて……って、うきゃぁっ！？　あっ\n！？　や、やだぁ……！　なんで、なんで顔にかけているんですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020701_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「あッ……あっあっ！　だ、ダメですっ……！　イラマチオをした上にわたく\nしのお顔に精液をかけるなんて！　げ、下品ですしお行儀が悪いですよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……と言っているのにぃ！　ああああっ……ドクドク脈打った立派なおちん\nぽから、次々に白いお汁がびゅるびゅる飛び出して……いやぁ……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「も、もぉ……！　ダメだと言っているのにぃ……あうっ！　うう、んふっ…\n…！　う～～～！　しっかり全部ぶっかけるのはおよしなさいぃい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「こちらは必死に飲もうとしているのにっ……あっ！　勢いが激しすぎて、舌\nを伸ばしても届きませんのぉ！　っあっ、いじわる……！　やっ、ううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「自分から飲めと言っておいて……ビチビチと顔に精液を塗りたくるなんて…\n…く、くつじょくですわ……！　でも、でも……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「そうやってワガママに、自分勝手に振る舞うあなたを見ていると……ドキド\nキして、身体が熱く……。あぁ、わたくし何かがヘンです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……もしかして、今回フェラチオをしようとして、イラマチオされて……征\n服されてしまったのは、虜になったのはわたくし……ですの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「そ、そんなこと……認めるわけにはいきません。わたくしはいついかなると\nきだって部下にとっての主で……って、全然聞いていませんわね……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「もう……！　もうもうもう……！　わたくし怒っていますのよ、って、し、\n幸せそう？　し、知りません……！　お顔をじっくり見ないでくださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}