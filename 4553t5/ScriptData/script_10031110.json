		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そうですか……襲来者（インベーダー）たちは、競艇場でスケバンサンダー\nに会ったと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010116200001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そうなんです。でも私たちだけじゃ、競艇場には入れませんし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020116200001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「まだ確認できてないのよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116200001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それは仕方ない。おまえたちだけで競艇場に入っちゃいかん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010116200001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ7世" ]},
		{"command":[ "SETTEXT", "「それに、競艇場に行ってみても、今いるとは限らないのである。あの者は街\nのあちこちに出没しているのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010116200001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そうなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116200002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「スーパーで半額弁当を取り合ってケンカしてたり、横断歩道でおばあちゃん\nを助けて車を破壊してたり……フフフフ……変な人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010116200001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「何をやってるんでしょうね、一体……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020116200002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「とにかく、街中あちこちに現れるってことね！　じゃ、街中あちこちを探し\nましょ！　映画館とか、ケーキ食べ放題のお店とか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020116200001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「だから、遊びに行くわけじゃないっての！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116200003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．サイレーン" ]},
		{"command":[ "SETTEXT", "「っていうか、それだけうろつかれると逆に探しづらいねえ……面倒だなあ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010116200001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そうですね……どこに行ったのか、手掛かりだけでもわかれば……たとえば\n、毎日必ず行くような場所――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010116200002" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「――あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010116200003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「なにか思いついたの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116200004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「あそこに行って……あの人に聞けばもしかして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010116200004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「っていうわけで、スケバンサンダーさんはきっとここに飲みに来てるだろう\nし、ほむらさんに聞けばなにかわかるかも、って話になって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020116200003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「そこでこちらにお邪魔してみたわけなのですが……ほむらはまだ来ていない\nんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010116200005" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "正義のマスター" ]},
		{"command":[ "SETTEXT", "「悪いねえ……ほむらちゃん、いつもは連絡なしで遅刻なんかしないんだけど\nねえ。なにかあったのかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020116200001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「わかりました……ちょっとこちらで探してみます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010116200006" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「探す相手が増えた……フフフフ……不運ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010116200002" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「――って、いうわけなんです。おかげで、ほむらさんも探さなきゃならなく\nなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020116200004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうかそうか……困ったもんだねえ……スケバンサンダーどころか、ほむら\nたんも行方不明……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116200001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ん？　いや、ちょっと待ってくれ！？　あの二人がそろって行方不明って…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116200002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．サイレーン" ]},
		{"command":[ "SETTEXT", "「ん？　どうかしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010116200002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ティンときた！　もしかして、あいつら――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116200003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
