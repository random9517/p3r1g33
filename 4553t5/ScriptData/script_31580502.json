{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ぐっ……まさか、こんな初歩的なミスをしちゃうだなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「み、見ればわかるでしょ……暴れすぎて、必要な妖力が……エネルギーが足\nりなくて、深刻なエラーが止まらないのっ……んくぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「もう、いい……アンタでいいから、手、貸して……何をすればいいって……\nチッ……オリジナルと同じよ、分かるでしょ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「エネルギー補給には、男性の精液が一番手っ取り早いの……この発情のステ\nータスを消すには、だから……わ、分かりなさいよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「そのにやにやした顔、うざい、キモイ……ぶっ潰したい……けど……は、早\nくチンポ入れなさいっていってるのよっ……あぁんんっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「こ、こんな、アンタのキモイチンポを入れられただけでっ、あっ、んくぅぅ\nんっ～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504106" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――し、仕方がないでしょ……！　ほんとに、まずいレベルの発情のエラー\nが出てるの、あっ、んふぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「内部構造の一番奥までチンポが届くの、刺激が強すぎてっ……あっ、んくぅ\nぅん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ば、馬鹿にしないで、この程度で壊れる脆弱な作りはしてない……！　いい\nから、アンタはとっとと腰を動かして、精液出して……んくぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「エネルギーさえ補充できれば、エラーも解消できるはずだから――はぁ！？\n　お、おねだり……？　こ、コイツ調子に乗って……チッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「こんな間抜けに、戦闘能力ミジンコのゴミなんかに、頭を下げる、なんて…\n…んくうぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――お、オネガイ、シマス……腰を振って、精液出して、ください……潰す\n……絶対後でぶっ潰す……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！　あっ、んふぅんっ……！　チンポ、内部で暴れてっ、あっ、\nんむふぅんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと、別に私の弱いところを探す必要はないの……！　アンタは\n普通に腰振って精液を出してくれればそれで、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「そ、それじゃあ楽しくない？　折角のチャンスだから私を可愛がってやる？\n　う、うざいうざいうざい！　ほんっとキモイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んふぅんっ！　だ、だめ、その浅いところから奥まで順番にこすり上げてい\nく動きっ、あっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、んひゃぁんっ……！　こんな情けない声、まるでオリジナルみ\nたいで……！　あっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あ、アンタ、分かってその動きしてるでしょ……！　私の身体がオリジナル\nと同じだから、弱いところも分かってっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「い、いいわ、そっちがその気なら……！　んんっ、んふぅんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「不本意だけど、私にだって男に奉仕する機能はついてるの……キモいけど、\nチンポを絞り上げて、とっとと精液吐き出させてあげる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「マンコの奥を絞って、子宮口のパーツで亀頭に吸いついて……あっ、あぁん\nっ……！　おまけに全体を振動もさせてあげるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んふぅんっ……！　さ、先走りがちょっと出てきた……これもエネルギーに\nなる、から……少しでもエラーを処理して、んひゃぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504122" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ま、待って、エラー処理中なのに、それ以上の速さで快感のエラーを増やさ\nれると、あひっ、あっ、んひゃぁんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「チンポのふくらみで、内部機構をがりがり削られてっ、あっ、あひぃんっ！\n　ねっとり抜くなっ、ガンガン突くなっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「だめ、分泌液の調整システムもエラーで誤作動して、あぁあんっ！　マンコ\nぐちゃぐちゃになって、チンポどんどん早くなる、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ど、どうして、私がこんな声を出さなきゃいけないの……っ！　キモイ、う\nざい、ムカつくっ！　あっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あっ、んひゃぁんっ！　また奥っ、ボディの芯に響くぐらい、ズドンってチ\nンポ突き上げられて！　んあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ま、まずっ……ダメなノイズまで走り始めてっ、あひっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「チンポ、き、気持ちいいっ――ち、違う、今のは言語システムのエラーで、\nんひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あ、アンタ、ここぞとばかりにニヤニヤするな……！　も、もういいから、\n早く、出して……あっ、んふぅんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふあぁんんっ！　チンポが膨らんできた……！　やっと終わ\nる、精液をマンコにぶちまけてもらえるっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「心底ムカつくけど、出すのは膣内でいいわ！　一番奥に出されるのが、エネ\nルギー効率がいいから、子宮パーツにぶちまけて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――私も一緒にイけ？　それならすぐにでも射精してやる？　～～～～っ！\n　わかった、わよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「一緒にイクから、エラーとノイズに流されてあげるから、いいから一番奥に\n出して――んひゃあんっ！？　あっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「来たっ、チンポドクドク脈打って、あひゃぁんっ！　馬鹿みたいなエラーの\n数で、あひっ、イクっ、イクッ、あっ、あひゃぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んああぁぁんん～～～～っ！？　出てる、内部機構にキモイ精液がドクドク\n注ぎ込まれてる！　んふぅんんっ～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、んひゃぁぁんんっ！　こ、壊れる、快感のノイズで壊れる前に\n、エネルギーを吸収して……んくぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「だ、ダメ、エラー処理に集中したいのに、絶頂システムも、誤作動起こして\nてっ、あひっ、んひゃぁんんっ！　イクの、止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ひとまず、発情のステータスだけどうにか……んんっ……チッ……ノイズが\n邪魔で、処理順がぐちゃぐちゃになちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――は？　ちょっと、どうして出してマンコの中でまたちんぽを大きくして\nるの？　アンタ、まさか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んくぅうんっ！　――に、二回戦って、確かにまだエネルギーが万全とは言\nえないけど、最低限のエラー処理が終わるまで待ちなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「だからそれじゃあ面白くない？　脆弱なつくりじゃないなら耐えられるはず\n？　こ、コイツ……！　んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――ふっ、ふふふっ……いいわ、こうなったら、こっちだって、アンタが枯\nれ果てるまでエネルギーを搾り取ってあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「アンタが私の弱いところを知ってるように、こっちだってオリジナルの知識\nを総動員すればっ……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「内部機構全体をうごめかせて、根元からちんぽを絞り上げる……あっ、んあ\nぁんっ！　馬鹿な人間の男を感じさせるんて、余裕なのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ほら、小刻みに収縮を繰り返して、ぎゅっぎゅってチンポ潰すのがいいんで\nしょ！　んくっ、あっ、んあぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「出された精液をかき混ぜて、射精後の敏感チンポに塗り込んで、あっ、ふあ\nぁんんっ！　ぐりぐり、腰を回してっ、んくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ、んふぅんっ！　あ、あれ、これもしかして、私の方も変に\n感じてエラーが出ちゃうんじゃ……あひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504208" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――し、仕方ないでしょ！　思考回路にもノイズが走って思考の計算能力が\n落ちてるんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「それに、さっきイった時のエラー処理も間に合ってなくてっ、んふぅうんっ\n！　こ、こんなはずじゃないのにっ、んあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ま、待って、今そんなに激しく動かれたらっ、あひゃぁんんっ！　あっ、あ\nっ、んっひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「チンポでがりがりって、内部機構を引きずり出されちゃうっ！　んふぅんっ\n！　ぐちゅぐちゅ音鳴らして、マンコかき回してっ、あひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「も、もういい、何も処理したくない……い、いいからアンタの精液を頂戴、\nオネガイだから……エネルギー補給させてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、あひゃぁんんっ！　うざい、きもい、気持ちいいっ！　あひ\nっ、好きっ……違うっ、うざい、潰すっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504214" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「き、来た、チンポがまた膨らみ始めたっ！　んふぅんっ！　出して、いいか\nらアンタの精液出してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――分かってる、私も一緒にイクから、キモいけど、アンタに合わせてあげ\nるから、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んくっ、んんんっ～！　また内部を締め付けて、括れの部分に絡みつかせて\nっ、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「このノイズの波、さっきと一緒……！　ああぁんっ！　あひっ、あんひゃぁ\nんんっ！　イクっ、もうイクのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「子宮でちんぽに吸い付くから出して！　精液出して！　私の中をエネルギー\nで満たして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「イクっ、イクイクっ、イクッ、あっ、あひっ、大きなノイズ来て、エラーが\n、ががが！　あひぃいんんっ、あっ、ああぁぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んあぁぁぁんんっ～～っ！！　あっ、ああぁ……！　エネルギーが……精液\nが私の中を満たして……んふぅうぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ふふふふっ……『ご主人』、気持ちいいよ、私とっても幸せ……！\n　あっ、んあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ああ、『ご主人』好き……このノイズとエラー、心地よくて……っ！　ち、\n違う、これはオリジナルの……ぐっ、流されちゃダメ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んふぅぅんっ！　気持ちよくなってないで、今度こそエラー\nを解消しないとっ、んくぅんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「さ、流石にこの精液の量ならエネルギーは十分賄える……んんっ……こ、こ\nれでどうにか……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……お、治まった？　全身簡易スキャン……深刻なエラー無し…\n…興奮のバッドステータスの消去を確認……大丈夫そう、かな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――何？　その残念そうな視線は？　もっと私のことを可愛がりたかった？\n　チッ……アンタ、本当にうざい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「でも……一応、礼は言っといてあげる。アンタのおかげでどうにかなったの\nは事実だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「～～～～っ！　ああもう！　その微笑ましそうな視線やめて！　いつまでチ\nンポ入れてるの！　早く抜いて離れて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「いいわ、やっぱりアンタは私の敵……オリジナルより先にぶっ潰してあげる\nから、覚悟しておきなさい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁぁぁんんっ！　チンポが抜けてっ、精液がボディに掛かって、あっ\n、んひゃぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015805_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、んひゃぁんんっ！　キモいはず、なのにぃ、キモイ精液がボ\nディに付着すると、そこが熱くなって、イクっ、あっ、んふぅんんつ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「あ、アンタ、馬鹿でしょ！　中で出さないとエネルギーを吸収できない、の\nにっ、んくぅぅぅんっ！　どうして外に出すのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……精液のにおい……これ好き、もっと嗅いでいたくて、あっ、\nんくぅうんっ！　ち、違う、嗅覚センサーまで誤作動とか、ぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「し、仕方ない、効率は悪いけど、どうにかボディで受けた精液からエネルギ\nーを吸収して……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「ダメなノイズだけ消去……最低限のエラーだけ処理して……はぁ、くっ……\nこれで、なんとかっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「――え？　おねだりするなら、もう一回チンポを入れて精液を注ぎ込んでや\nるって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「アンタ……それが目的で外に出したわね……うざい……うざいうざい！　ほ\nんっとキモイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「～～～～っ！　ああもう！　分かったわよ！　いいから早くチンポを入れて\n！　オネガイシマス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａクララ" ]},
		{"command":[ "SETTEXT", "「……覚えておきなさい、アンタは私の敵。これから先、一生付きまとって、\nぶっ潰し続けてあげるんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0504410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}