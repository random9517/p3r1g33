{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "034_0204101" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「へへ……待ってたぜ。ガチで、マジに待って、待って……もう我慢出来なく\nなっちまった」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204102" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長が俺をほったらかしてんのが悪いんだからな。俺の気持ちに気づいてる\nクセに……焦らして焦らして、このザマだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204103" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……隊長。見りゃわかんだろ？　俺……すっげえ発情しちまって\nる。これからすること、期待して……濡れてる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204104" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「大洪水なんだよ。だから……意地悪しないで、入れてくれ。バッキバキに硬\nくなったチンポ、隊長のチンポで俺をオンナにしてくれ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204105" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……そのつもりで来たんだよな？　つか、何もしてねえうちから我慢汁ダラ\nダラで、チンポぱんぱんに膨らんでやがるし……そういう意味だよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204106" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「入れる場所わかるか？　あ、避妊とかいいからよ。生で一晩中ぶつかり合お\nうぜ……俺に覆いかぶさって……はははっ、そうそう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204107" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「チンポ……。ンッ……チンポ、ずぶーって……入れろ、入れろよぉ……ああ\nあっ……！　あ、あ、入れっ……入れ、て……ああっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204108" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ゛っ！？　ふぅっ……！？　す、すっげぇ……これが隊長のチンポ……？\n　口でした時よりずっとデカく感じる……ヤベエよ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204109" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「こんなのでガシガシ突かれたら、俺のマンコが隊長のチンポの形になっちま\nう……ユルユルでガバガバのダメマンコになっちまうよぉ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204110" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ……あ……あ、腹ン中でビクビクしてるチンポ……隊長の……ずっと欲し\nかったチンポ……やっべぇ、最高……最強ぉお……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204111" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「内側から、ヒダヒダが割り開かれて……限界ってカンジだよ。これ以上はも\nうなんにも入らねえっていうギリギリ感……スリルだよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204112" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……なあ。動いてくれよ。俺も、出来る限りケツ回すから……はぁ、はぁ、\n隊長のチンポで、俺を……蹂躙っつうの、レイプ、つぅの？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204113" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お、犯し、てくれ……。もうそのことで頭いっぱいになっちまって……この\nままじゃ戦闘に支障が出る。だから……スッキリさせてくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204114" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長専用のオマンコホールだぜ。使って……くれよ、あっ、そう、そうだ、\n腰、揺らして……股間打ち付けて……激しく、はげし、く……ぅう♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204115" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あっひっ、あふっ！？　すっげ……！　すっげ、すっげ、すっげっ！　夢み\nてぇ♪　チンポ、チンポ、隊長のチンポ、ズコズコしてるっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204116" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺のマンコズボズボ往復してっ……あ゛ーっ……♪　ピストンっ♪　ピスト\nンキメてやがる、使ってやがる……ぅうう♪　い゛ぃいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204117" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ああっ！　やべえ、やべえよ……隊長、隊長、隊長……ぉおっ♪　気持ちい\nい、まっじっ、頭ヘンになるっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204118" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長はぁあ……どうだぁ？　俺のマンコ、イイか……？　鍛えてっから、他\nの軟弱なにゅるにゅるマンコとは別格だろぉお……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204119" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長のチンポ良くするためだけのマンコだからよぉ、キュッ♪　キュッ♪　\nって締まったり緩んだり、キツくなったりフワフワにしたり……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204120" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺の腹筋で操り、ながら……ああああっ♪　あっおっおっおっ♪　使いやす\nいように調節……あうっ♪　調節してやるしぃい……っ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204121" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「手を使わなくてもくぱくぱ開閉させられンだぜ……？　あっ♪　ぜってー具\n合いいはず、だ、か、ら……楽しめよなぁあ……あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204122" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あーっ……！　アガる……っ、ハイになるぜぇえ……っ、あの隊長が……俺\nの隊長が、俺のマンコで腰振って……はははっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204123" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「発情期の犬みてーにガンッガン亀頭ぶちこんできやがるっ……あぁ゛っ！　\nマッジ男らしくて……あっ♪　ほ、惚れ直すだろがぁあっ……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204124" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「硬くて……太くて、ぁっ、くっさいくっさい精液をドッバドバ垂れ流す最強\nのチンポを、こうして入れてもらうの、楽しみでさぁ……あっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204125" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「想像だけで軽くイッてたんだからなっ……ヤられるの、想像……してっ♪　\nマンズリ一晩に何回も……こいてっ、ま、待ってた、待ってたんだよっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204126" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おぉっ♪　お゛っおっ！？　こうやって……お゛ぁっおお゛っ♪　ガチ交尾\n、す、すんのっ……想像してダラダラ濡らしてたっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204127" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ナマでハメようとか、直で種付け希望しようとか……あっ！　あっ！　考え\nてたらしんじられねーくらい、あっ！　興奮、しちまって……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204128" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「これが隊長の生チンだったらって思いながら……ぁあっ♪　指でオナッてた\n……早く欲しいって……思い、なが、ら……おぁああ゛っ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204129" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「でも、でも、妄想よりずっと……いい、ずっと太い、それに……俺の手なん\nかよりずっと硬く、て……マンコの中ゴリゴリしてるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204130" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「削岩機みてぇにゴリッゴリズリッズリって……マン肉にぶっといのが突き刺\nさって……動いて、うご、うごいて、そのたび……意識トぶっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204131" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ずっぽっ♪　ずっぽっ♪　ずっぽっ♪　ずっぽっ♪　おおぉお゛っ♪　おぉ\n゛……おおおんっ♪　おぉ゛っおぉおお゛……ぉ゛っ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204132" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あぁ゛……良かったっ、俺、隊長に出会えてマジでよかっ……たぁ♪　今ま\nで俺を倒せた男なんて誰もいなかった、のに……よぉっ、あっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204133" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「チンポ一本で俺のこと虜にするような男に……あっ！　ガチマンしてもらえ\nるなんて……お゛っ♪　し、信じらんねえよ、今もっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204134" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っあ゛ーっ！　あーっ！　ヘコヘコ腰振って、あっ、チンポ喜ばせたくて、\nケツの穴に力込めて……っ、マンコ締めて……絞って……ッ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204135" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「屈辱的なはずなのによぉ……恥ずかしいことしてるって思えば思うほど……\nギューーーーッて締まんだよっ、か、感じちまう……あ゛ーーーっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204136" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「チンポ……チンポ、チンポ、チンポぉ……♪　隊長のチンポっ！　永遠に入\nれてくれ、一時間や二時間じゃ足りねぇ……あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204137" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「毎日っ！　毎晩！　毎朝、いや、もう抜きたくねぇ……！　だって気持ちい\nいっ、気持ちいい、気持ちよすぎて……おかしくなるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204138" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ゛ーっ！　ガンイキきめさせてもらうぜっ……ああっ！　ああ、ああ、奥\nっ……一番奥を突け……ぇえっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204139" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そこが一番感じンだ……っ！　お゛ぉっ！？　おぉっ！？　おひっ……ああ\nああああイグイグイグイグぅうううっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204140" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あーっ！　イっく……ッ！！　イグッ……あぁっ！　キマっちまうぅっ……\n！　あーっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204201" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ッ……はぁーっ……！　はぁー……はぁー……っ、はー……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204202" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「す、すまねぇ。俺だけ勝手に先にイッちまって……。あんまり気持ちいいも\nんだからよ……。次は隊長の番だよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204203" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺のことは気にせず、好きなようにハメていいぜ……あっ♪　俺は、イッた\nばっかで敏感だけど……わかる通りまだ濡れてっし……んんっ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204204" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「絶頂キメて新しく愛液も湧いてきてっから……潤滑油にはもってこいだろ…\n…っ！　気合い入れてケツ揺らすぜ……んんっ！　んんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204205" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あは……隊長の、太すぎてマジ動きずれぇ……あはははっ……あっ♪　なん\nっ、だよコレぇ……出し入れしてっだけで痺れるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204206" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おっ♪　あっ……♪　あっ♪　あっ、あぁっあぁ……！　あっ！　あっ♪　\nあっぁっあっ……♪　俺達……相性ピッタリ、だよなっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204207" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長のチンポ、俺のに入れるためにあるみてぇに形とかエグくて……あっ！\n　フツーに二人で動いてっだけで……ビリビリしてよぉ……あっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204208" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺のマンコも嬉しい嬉しいって、チンポに吸い付いて離れねえよ……。ッ…\n…！　離れたくねぇって、しがみついて……あおおお゛♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204209" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ヤればヤるほど……ぉおっ♪　馴染んで、ぁっ！　一回一回の痺れが強く…\n…なりやがるぅ♪　あ゛っ、またイキ、そ……あああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204210" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長……ぉ、隊長、俺っ……俺、ダメかも……っ、やっぱイグっ、かもっ…\n…ああああっ……またっ、またイカされて……あーっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204211" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「やっばッ……あっ！？　あっぁっあっ……！　隊長イかせるつもりで、何発\nも絶頂しちま……う、あーっ！　あーっぁーっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204212" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「こんなんじゃ……、こんなんっ、じゃ……全然隊長を良くできねぇよぉ……\nっ、え……？　隊長も……イキそうなのか！？　そうかっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204213" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だったらラッキーっつか……う、うれしい……ぜ。これで気兼ねなくイける\nっ♪　俺、俺イキまくるから……だからさぁ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204214" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長も、隊長も一緒に……ぃっ！　あーっ！　イクッ♪　イクッ、んぁっあ\nあっ……イクぅっ……イクぅううっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204215" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「す、きだぜ……好きだぜ、隊長のセックス……ぅっ！　俺以上に俺のこと、\nイ、イカせるのがうますぎる……ああっ、尊敬するぜ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0204216" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ほらまたッ……！　ん゛ぉおおっ！？　おぉ゛っ、おぉ゛っ……！　ヤバイ\n、ヤバイヤバイヤバイっ……なんか出る、なんか出るぅ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_02_06" ]},
		{"command":[ "WAITINPUT" ]},
