		{"command":[ "PLAYVOICE", "034_0204407" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「い、いや……言おうとしたことは本音だけどさ……。こうして抱いてもらっ\nて、……犯してもらっただけで満足すべきだよな」", "NORMAL" ]},
