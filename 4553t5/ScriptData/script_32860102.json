{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あっは……♪　あたしのご主人様ってば、ホンットーに最高だぜぇ……♪　\nはぁ、はぁ、こんなプレイ……マジで体験させてくれるとか……♪」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「興奮が……、あっ♪　あぁ、止まんねぇよ……♪　なあ、こっからあたしに\n何をさせるつもりだ？　ご主人様は何をしてほしいっ……？　あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……誰もいない夜の公園で……。犬っコロみたいに全裸にされて、首輪まで\nご丁寧に着用させられて……。野外露出だなんて恥ずかしすぎる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104103" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「でも……、はぁっ♪　なんでだ？　それがすごく気持ち良くて……！　あた\nしはずっと、こうされたかったんだって心と身体が訴えてきやがるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「なあ……！　ここを誰かが通りかかったら、ど、どうなっちまうんだ……？\n　人気が少ない時間帯つったって、さ、散歩しにくるヤツもいるだろぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……それとも、み、見せつけるつもりか？　あたしがこんな風に……ご主人\n様に屈服して、いやらしい格好をさせられてるところを……。はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「何？　あたしは本物のドマゾだって？　う、うるせえっ……。マゾ犬にはし\nつけをしないといけない？　ハハッ、い、言ってくれるじゃねえか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……ここで足をあげて、放尿しろ？　っま……マジかよ……？　マジでそれ\n、命令ってことか……？　ご主人様からの……逆らえない命令……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「わ……わかったよ。ここでするから……。見ててほしい。……じゃなかった\n！　喜んで放尿させていただきます！　どうか、どうかっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「しっかりとご覧くださいませ……！　っぅ……♪　あ、ぁ、あ……♪　ああ\nあああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んぁあああっ……！　ああああああっ！　ヤベぇっ、あっ……♪　あっ、ガ\nチで！　ガチであたしっ……！　犬のおしっこしてるっ……ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ご主人様っ、ご主人様ぁ……♪　放尿上手にできてますかぁっ……？　ああ\nああっ、恥ずかしいところを見られると……感じるぅううっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ヤバイぃいいっ……！　おしっこ見られてるだけで……イクッ、イッちまう\n……！　あっ！　あっ、ぁっ……！　ご主人様ぁああああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んひぃいいっ！　股の緩い犬で申し訳ありませんんっ！　潮っ……潮まで噴\nいちゃいましたぁあっ！　あっ！　あっ、イキました、放尿して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ご主人様に見ていてもらえるって思ったら、それだけで……！　勝手に一人\nでアクメしました、許可もなくイッてごめんなさいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あぁっ、あっあっ、あっ、あぁ……！　す、すごい……地面がビショビショ\nだぁ……♪　ねえご主人様……！　言われた通りに放尿しました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ちょっと余計なものも出ちまったけど……っ。命令、ちゃんと実行できたよ\nな！？　だから……、だからご褒美ください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ご主人様のチンポ、欲しいです……っ。もうさっきから、興奮しすぎで股が\nヌルヌルで……！　い、今イッたばっかだから絶対具合いいと思います！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「お願いします……っ。はぁ、はぁ……♪　尻を振って、腰をくねらせておね\nだりしますから……！　ご主人様の硬いチンポ入れてぇ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ッあ……！？　あっ♪　んっふっ……んぁあああああ……っ♪　キたっ……\n！　ブッといの入ってきたぁああっ、あ、ありがとうございますううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あっ♪　すっげっ……すっげぇっ♪　ご主人様のチンポ……デカすぎるっ、\nあっ♪　それに熱くて、ふ、太さが尋常じゃねえっ……♪　うぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はいぃいっ♪　そうです、あたしはご主人様の犬ですっ、従順なイヌぅうう\nっ♪　わんっ、わぉんっ♪　チンポ入れてもらえて嬉しいわんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ……♪　このままぁっ、激しく突いてくださぁいい……！　あた\nしのこと、めちゃくちゃにして！　ぐちょぐちょになるまで犯してぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……ンンッ！？　あぁああっ、すっげぇっ♪　すげえよっ♪　ごしゅ、じん\nひゃまぁっ♪　チンポ動いてるっ……あっあっ、その腰使いヤバすぎぃいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んぉっ♪　おぉっほっ♪　おっ♪　おぉっ♪　んっ、んっほっ……♪　あ～\n～～っ♪　あーーーっ♪　もっともっとっ！　もっと突いてくださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしも全力で腰っ、振ります！　チンポをマンコで締めつけて、シゴいて\n……ご奉仕しますっ！　あっ！　あっ、だから犯して、犯してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……んふぅうっ♪　い、今のイイッ♪　奥っ……一番奥にチンポねじこまれ\nてっ！　ズッポズッポ突かれるの最高に気持ちいぃいいっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「っんぉおおっ♪　おぉおっ♪　おっ、あっ、あっ、あぁあああ……っ！　っ\nぅ……っ♪　声、我慢しねぇと……！　誰か、来たらマズいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「そう本気で思ってんのにっ……！　思えば思うほど、……っああああっ♪　\nお、抑えられねぇ……！　つうかっ、ますます感度上がっちまうぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　ドマゾでごめんなさいっ、公共の場所で犬になってっ、お\nしっこ漏らして潮ふいて……！　チンポっ、チンポ欲しがって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「交尾っ♪　動物になりきって、ガッチガチのチンポとマンコで交尾してごめ\nんなさいっ！　あっ♪　あっ、謝罪すると更にクるぅ……！　あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はひぃいっ♪　ひぃっ、あひっ……！　き、もちイイ……！　気持ちいいっ\n！　ダメだ、ゾクゾクするぅ……！　チンポ、チンポ硬すぎるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あうっ！　ううっ……！　すっげぇ中が広がるぅ……！　あっ！　……ご、\nご主人様？　なんか腰の動き、どんどん早くなって……うあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「えっ！？　も、もしかしてご主人様もイキそうになってんのか！？　あ、あ\nああっ……！　嬉しいよ、ああっ、出してくれ、中に出してくれぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしはご主人様のイヌだからっ……！　生で中出しされるなんてただのご\n褒美だからっ……♪　欲しいっ、精液出してくれっ、あああああッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「んおっほぉおおおおおっ♪　おおおおおおおッ♪　出たっ……あたしのマン\nコの中にっ……！　あああっ、ご主人様のあっつい汁出てるぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「わぉんっ！　わおんっ、おおおおおんっ……♪　ドピュドピュ中に飛び散っ\nて……ああああっ♪　ダ、ダメだ……あたしも、あたしもイクぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「おふぅううっ♪　潮っ……また潮が溢れ出して……！　あおぉおおんっ♪　\nイク時潮噴くクセ、ついちまった……！　あっあっ止まんねぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「おぉおおおっ♪　おおッ、んぉおおおおん……！　イクッ、イクイクイクぅ\nううう……！　……ぁ……♪　目の前がチカチカして……あふぅうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あ、あああああ……！　じょろじょろって……！　おしっこまで出しちまっ\nて……！　ああ、でも、でも見てください、ご主人様……あたしがっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「お漏らししながらイクとこ見てくださいぃいいっ……！　あ～っ！　イクイ\nクイクっ♪　ご主人様の精液中に出されながらイ、クぅうううううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……はー……っ、はぁああっ……。はーっ……♪　す、すみません……。ご\n主人様がイッてる時に、それ以上に派手にイキ散らしちまって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はい……。せめて最後に、チンポをマンコで絞り上げさせていただきますぅ\n……。……ンッ……。ど、どうですか？　全部出せましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……はぁっ？　あっ！？　あたしのザコぶりと……エロいお漏らしを見て、\nチンポがデカくなってしまった？　あ、は、はい、確かに……太いです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「むしろさっきより、チンポがゴリゴリしてるっていうか……。は、はい。信\nじらんないくらい硬くて……熱いです。こ、これって……あうぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あっ♪　このままっ、このまま続けて犯してもらえるんですかっ……！？　\nあ、ありがとうございます、ありがとうございますご主人様ぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はいっ！　あたしも精一杯いやらしく……尻を揺らして、あっ♪　ちゃんと\nチンポを気持ち良くしますっ……！　あッ……♪　んぉっ、おおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「二回戦目なんておっぱじめたらっ……おぅっ♪　絶対に見つかる、人に見つ\nかるっ……！　あたりそこらじゅう濡らしてビチャビチャだし、あうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「変質者だと思われるっ……♪　でも、そう思えば思うほど……燃えてきちま\nうぅうっ♪　ご主人様っ、あたし、ヘンタイになっちまいましたぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ドMでイジメられたがりで……あっ♪　野外で裸晒してっ、ひ、人に見られ\nたいってホントは思ってるド変態ですっ！　あっあっ、マンコもぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「よだれだらっだらに垂らして交尾を悦んで、ますっ……！　あひいっ、ひぃ\nいいっ♪　もうなんもっ、何にもわかんねえっ！　気持ちイイことしかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「チンポっ……！　ご主人様のチンポのこと以外どうでもいいっ……！　あぁ\nっ！？　はぁっ、そんなにズンズン突き上げられたらぁっ、あっはっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしっ、発情期のメス犬みたいにキャンキャン鳴いてイキ散らしちまうよ\nぉおお……！　はひぃっ、はおおっ！　ズブズブぐちゅぐちゅっ、おっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「おっおぉおっ！？　あへぇえっ♪　ご主人様っ、またイキそうです！　あっ\n！　あっ、少しズポズポしてもらっただけでっ、あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「すぐに何度でもイッちまうザコよわマンコですみませんっ！　あっ！　イク\nッ……イクっ！　んぉぁああああああっ、あ～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はいっ！　マンコ締めますっ、あっあっ！　ご主人様のチンポにご奉仕ひま\nひゅっ……！　あぁああっ！　あぁっ、あぁっ、イクの止まんねぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「イキすぎて、身体熱いぃっ……！　ご主人様ぁっ、あたしのマンコバカにな\nっちまいました、……あっ♪　交尾が好きすぎて……無限にイケますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あはっ♪　あはぁっ♪　ご主人様……！　ご主人様も一緒にイッてくだひゃ\nいぃいい……っ♪　さっきのドクドクって精液、もう一度感じたいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしにっ……！　あたしのマンコに精子でマーキングお願いしますっ……\n！　これから一生、ご主人様の精子しか受け入れない身体にしてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしがご主人様だけのイヌだって！　身体に刻みつけて、教えこんでくだ\nさいっ……！　射精と一緒にもっかい全力でイキますからっ、ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104220" ]},
		{"command":[ "WAITINPUT" ]},
				
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はひぃいいいっ♪　中出しキたぁああっ♪　精液マーキングっ、あたしのマ\nンコん中に……！　腹がたっぷたぷになるくらい出てるぅうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「うっ♪　はうぅっ……！　わかるっ……！　ご主人様の精液、あたしの奥に\n炸裂してるっ……！　チンポがびっくんびっくん脈打って……んぐっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ドロッドロの粘り気の強い精液っ……！　次々に撃ちこんできて……！　ん\nぁあっ！　イクイクイクっ♪　ご主人様で満たされるとか快感すぎるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あ……♪　あ、あ、あ……っ♪　マンコにぎっちりチンポで栓されて……！\n　逃げられない状態でしっかり中出しされんの……感じるぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あたしはご主人様の精子をありったけ、喜んで受け止めるマゾ犬だからっ…\n…。あふっ♪　イキすぎて足がガクガクになっても……！　あうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「マンコ締めつけて、チンポが最後まで気持ち良く射精できるように……お尽\nくしするだけだ……っ♪　あぁ、ああ、まだ出てる、すげぇ量……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ん、は……っ♪　これ絶対受精してる、あたしのマンコん中、ご主人様の精\n子がめちゃくちゃ自由に泳ぎ回ってるっ……♪　はぁあああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ドMのエロ犬にとって、これ以上のご褒美なんかねえよ……♪　あたし、一\n晩で放尿、潮噴き、野外で交尾、生中出しって網羅しちまった……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_20" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ここまで過激なことばっか経験しちまったら……。他の男でなんか絶対満足\nできなくなってる……♪　ご主人様じゃなきゃイケなくなっちまった♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「なあ？　これからも……あたし、なんでも命令を聞くからさ。だから犬とし\nて、マゾ奴隷として……これからもずーっと可愛がってくれよなぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「イクっ、イきゅぅううっ♪　って、んぁえっ……！？　ご主人様っ、チンポ\n……！　いっちばん大事なとこでチンポ抜かないでくださいよっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_24" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あふぁっ……！　やっ、な、なんだこれぇっ……！　あっ！　あたしの尻に\n、ご主人様のあっついのが……！　真っ白な精液がかかってやがるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「あっ……！　尻に……っ、あたしの尻に精子放出したかったんですか……！\n？　あっ♪　ネットリしたのが、たくさんブッかかって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ひぃっ♪　あひっ……♪　これはこれでマンコがおあずけくらってキュンキ\nュン疼いて気持ちいいですが……中出しもしてほしかったです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_23" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「……あっ！　す、すみませんっ、ドマゾのメス犬のくせにご主人様に意見す\nるなんて！　浴びますっ、黙って尻に精液いただきますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_22" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ああっ、ふぁあああっ……♪　絶対的なご主人様に従い、尽くす……♪　こ\nれがあたしにとって最高の喜び、最高の幸せぇ……あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「っん……ぁ♪　すっげえいっぱい出してくれたんですね……。嬉しいです…\n…♪　よくよく考えたら、一回目に中に出してもらって……」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00028601_02_23" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「二回目に尻の上にかけてもらったら、あたしの下半身ほとんど全部、ご主人\n様の精液まみれになったってことですもんね。そっちの方が、なんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「ご主人様の色に染めてもらったって感じがして……。はい。満足です……。\nさっきはとっさのことだったから、びっくりしちまってすみません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_286_0104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ティシポネー" ]},
		{"command":[ "SETTEXT", "「はぁ……♪　まだまだあたしは、ご主人様の考える領域には達してないです\nね……。これからも、ビシビシ厳しい躾をお願いします。ご主人様……♪」", "NORMAL" ]},
