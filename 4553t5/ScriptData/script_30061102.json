		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んふふふーんっ、やっと来たわね。待ってたわぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104101" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
