		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「もう……分かってるでしょ？　ダイヤナちゃんのこと、散々その気にさせて\nくれたんだからぁ……今日は誘っちゃったってワケ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「だからぁ……んっ、楽しいコトしちゃいましょ？　オチンチンもすっかりそ\nの気になってるみたいだしぃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「えっ……楽しいことがあるのぉ？　おしおきルームの設定を使って……？　\nどういうコトぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あっ……これ……なに……宇宙人……？　なぁによ、ただの背景？　３Ｄ…\n…ふーん、よく出来てるじゃないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000611_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「それで、こんなの出しといて、どうするつもり……えっ、脱ぐの？　この状\n態でするってコト？　へぇ……そーいうシュミなんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ふふん、いいわよ。してあげちゃおうじゃない……上に跨っちゃえばいいん\nでしょ？　んっ……しょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んっ……ふぅん……こんな感じなんだ……反応ないのは分かってるケド……\n結構、視線……気になるかも、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「それで……？　腕を頭の上に持ち上げて……腋も……おっぱいも見せびらか\nす……ふん、いいわよ……やったげようじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「それで、んっ……ちょっと入れる準備……しちゃうのね？　はぁっ、んっ…\n…ふっ、あっ、あんっ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「もう、オチンチン……完全にそのつもりになってるじゃない。ね、入れてい\nいでしょ？　ダイヤナちゃんも準備、出来てるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んっ、どこって……ほらぁ、ここ……オ、オマンコぉ……オマンコ入れて欲\nしくなってるのぉ……オチンチン欲しいのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「その、ギチギチに硬くなって、ビンビンに反り返ってるオチンチンっ……！\n　ずぶって……奥の奥まで突っ込んでっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「欲しくて欲しくて、ヨダレをいっぱい垂らしちゃってるっ……恥ずかしいダ\nイヤナちゃんのオマンコに食べさせてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んぁっ、はっ、あぁぁぁぁぁぁぁぁんっ！　オチンチンっ……あふぁっ、ず\nぶってしたぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んふぁっ、やぁんっ、いきなり……潮吹きなんて……あっ、やだ……ダイヤ\nナちゃん……いつもより感じやすくなっちゃってるかも……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「二人っきりで……してる筈なのに……すごく……近くで、見られてるみたい\nな……思ったより、ドキドキする感じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……う、動くのぉ？　んっ、あっ、あぁっ……ぐいってっ、あ\nぉっ……つ、突き上げられるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁんっ、あぁっ、あっ、おぉっ……ごりゅごりゅっ……来てるっ！　オチ\nンチンっ……オマンコの中で暴れてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あっ、あぁっ……こ、これぇ……本当に、見えてないのよね\nぇ？　すごく……あぁっ、近くに存在感があって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ！　やぁっ……あぁっ、ちょっ……そのペースで……下からさ\nれるとぉっ、はんっ、あっ、あぁっ……おっぱいっ、揺れちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「もっと……揺らすのっ？　んんっ、はぁっ、んっ、んふっ、はっ、んくっ…\n…こ、こうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「やぁんっ、ダイヤナちゃんのおっぱいっ……あぁっ、ぷるぷるしてるっ……\n！　み、みんな見てるのにぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ね、ねぇっ、手……下ろしちゃダメ？　こんな……見せびらかすみたいな…\n…ことぉっ、はっ、あぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「わ、分かってるぅっ……！　これはっ……本物じゃないってことぉっ、けど\nっ、あぁっ、やっぱり視線感じるっ……見られてる感じするぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「その方が感じるんだろうって……ちがっ……ダイヤナちゃんっ、そんな……\n変態チックなことぉっ、あっ、あひぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「うそっ……あぁっ、ホントに凄いっ……あぁんっ、グリグリっ……いっぱい\nっ、かき回されてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「宇宙人のっ……顔……合わせてたらっ……オマンコっ、ジンジンしてくるの\nっ……止まらないのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、ひっ、あぁっ、もっと胸を張ってっ……おっぱいアピールす\nるのっ？　あぁっ、こっ、こんなっ、感じっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あぁっ、揺れちゃうっ……ダイヤナちゃんのいやらしいおっぱいっ！　乳首\nっ……ピンって立ってるの分かっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「見せるほうが……コーフンするなんてっ……あぁっ、見てっ……！　ダイヤ\nナちゃんのっ、ビンビンの乳首っ……もっと見てぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁんっ、オマンコもぉっ！　太いオチンチンをズッポリ食べてっ、いっぱ\nいお漏らししてるオマンコもぉっ……全部見せちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あぁっ、はんっ、あぁっ、あぁぁんっ！　オチンチン激しいっ！　ずっとヒ\nダヒダっ、ズリズリこすれてぇっ！　オマンコいいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、こんなにっ、あっ、されたらっ……もうすぐイッちゃうっ\n！　イッちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　オチンチンっ、まだ激しくっ！　イクまでっ、一気にしちゃう\nのねぇっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あぁっ、来てっ、思いっきりしてっ！　中に出してっ……はっ、あぁぁぁぁ\nぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あぁぁぁぁっ……！　出たっ……んぁうっ……オマンコっ……びゅくって奥\nにっ……出されてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁぁっ、あぁぁ……またお汁吹いてるっ……オマンコイッてるのっ……気\n持ちいいぃぃんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふぁっ……はぁっ、はぁぁっ……これぇ……射精……すごいぃ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「終わり……射精……終わった……？　はぁ……はぁ、んっ、あぁ……すご…\n…かったぁ……あふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ホント……不思議な感じぃ。これ、ホントに見られてるワケじゃないのよね\nぇ？　反応だって別にないしぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「それなのに……すっごく見られてる感じがドキドキして……まだ疼いちゃっ\nてるかもぉ……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、はっ、んっ……やだ……もう勝手に腰が……動いちゃう……\nんっ、さっきの気持ちいいの……もっと欲しいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ねっ、あんっ、いいでしょ？　あっ、はぁんっ、このまま……オマンコ……\n２回目ぇっ……あっ、んふんっ……あっ、ふぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ダメって言ってもっ……もう、ダイヤナちゃんから動いちゃうんだからぁっ\n、あっ、おっ、あぉっ……おぉっ、ほぉんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あぁっ、すごいっ……イッたばっかりのオマンコっ……続けてするのっ、ジ\nンジン来るぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「ウソぉ……ナニこれ……あんっ、はぁんっ、カラダっ……勝手に動いちゃう\nっ……こんな恥ずかしい動きしてるのにぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁっ……んっ、ふひぃ……見られてるぅ……すぐ目の前にいるのにっ、へ\nこへこっ、恥ずかしくっ、腰振っちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あっ、んぁっ、はぁんっ、自慢のおっぱいっ、プルプル揺らしてぇっ、腋も\nっ思いっきり見せびらかしてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「オチンチンっ、かき回されながらっ……オマンコキュウってさせるのっ、い\nいのぉっ、腰が……止まらないのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁんっ……見てっ、ダイヤナちゃんのことっ、もっと見てぇっ！　みんな\nの見てる前でするセックスっ……ハ、ハマりそうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000611_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あっ、はぁんっ、ダメ……そんなのっ、これはっ……本物じゃないんだから\nぁっ……クセになったら、終わっちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「あぁんっ、でもっ……燃えちゃうっ！　あぁっ、オチンチンいいっ、オチン\nチン気持ちいいっ！　ズボズボされるのたまんないわぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ・ダーク" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふぁっ……あぁっ、ち、乳首……立ってるなんてっ……そんなの\nっ、あっ、言われなくても分かってるしぃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1104214" ]},
