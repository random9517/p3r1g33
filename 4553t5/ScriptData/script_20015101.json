{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……。今日も今日とて、代わり映えのしない任務かぁ……」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺はぼやきながら、同じ任務を命じられたカグヤとまりあを横目で見た。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "……最近、大きな危機もないのかＥＤＯの空気は緩みきっていて……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "昨日も今日も、そして明日も明後日も、くだらなくて小さい雑用ばかりを押し\nつけられているところなのだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふあぁ……。今日も適当に終わらせて早く戻ろうぜ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「私もそう思っていたけれど……。待って、敵の気配がする！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023360001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん！　斜め前前方から敵の攻撃……来ます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023360001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「来ますって？」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ごめんなさい、敵の姿がよく見えないんです！　でも武器は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023360002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「さっき少しだけ見えた。たぶんロングライフル。狙撃兵に狙われているみた\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023360002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「狙撃？　俺にはまったく何も見えないが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人！　我らは本当に攻撃を受けていますぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ジュンジローがとっさに俺にぶつかって、敵の狙撃の軌道からそらそうとして\nくれた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "が、運悪く……俺が吹っ飛んだのもまた、別の敵の攻撃の軌道線上だったらし\nい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふぐぁあッ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「うあああああああ！　ご主人！　ご主人～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺とジュンジローは、衝撃波のようなもので、信じられないくらいの距離を吹\nき飛ばされた。", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0194" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぐぉおっ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "何かにぶつかり、見事に気を失った俺の目の前が、だんだん暗くなっていく…\n…。", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人！　ご主人！　起きてほしいですぞ！　早く目を覚ますのです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ん？　あれ……。別に死んではいないみたいだな……？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「当たったのは銃弾の方じゃなくて、ショボい魔法みたいなもんだったのか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いやいや、あの衝撃波もなかなかのエネルギーでしたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「そうですね。あなたたちは相当な攻撃を受けて、ここまで吹き飛んできたと\n考えるのが妥当だと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360001" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ガサッ、と茂みから誰かが現れたせいで、俺とジュンジローはビクリとしてし\nまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あんた誰だ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「あっ。失礼しました。自己紹介が遅れてしまいましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360002" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「私はメガネエルフのアイナリンド。聖エルフ騎士団に所属している軍楽隊の\n一員です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360003" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐんがくたい……ってなんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「楽器を演奏する人達のことなのでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そうです！　よく知っていらっしゃいますね。なんて賢いワンちゃんなんで\nしょう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360004" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そ、そんなに褒められると照れますぞ。デレデレデレ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「瞳に知性を宿した素晴らしいワンちゃんですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360005" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうか？　俺には間抜け面に見えるが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「今、私たちは騎士団の任務で遠征中でして。この森で、カフェを経営してい\nるんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360006" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「よろしかったら、ぜひお飲み物でもいかがでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360007" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんで騎士団がカフェなんか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ふふふっ。遠征の資金を得るために、資金源としてカフェを経営しているん\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360008" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「遠征場所ごとにどこどこ支部といった形で運営して、資金が溜まれば移動と\nいう方法で今までやってきたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360009" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「騎士団伝統の、路銀の稼ぎ方ってヤツか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "と、そこまで口にして俺は急にピンと来た。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（……もしかしてこれって、異世界転移ってやつか？）", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「どうなさいました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360010" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（『くだらない任務に疲れ果てていた俺は、異世界転移して』……）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（『デカパイ聖エルフ騎士団とまったりカフェを経営することになった件』\nってやつか？）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ダメですな。完全に目が遠くを見ております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「打ちどころが悪かったんでしょうか。あの……だ、大丈夫ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360011" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「その、メガネって……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああ、これはですね。私たちメガネエルフの種族は生まれつき視力が弱いの\nで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360012" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「いついかなる時もメガネを外さないようにしているんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360013" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（なるほど、この世界はそういう感じのエルフがいる『設定』なのか！）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺が納得したその時だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「あああああああ～っ！　す、すみませぇええええん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023360001" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ディーネ先輩がオムレツを作ろうとしたらぁっ、かまどが火を噴いて爆発し\nちゃいましたーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023360002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「……おかしいわね。レシピ通りに作ったはずなのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023360001" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "黒い煙を吐くかまどを背景に、新しいエルフが２人すたすたと歩いてくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「……あら？　この人は誰？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023360002" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「今さっき、そこに倒れていらっしゃった旅のお方です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360014" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「せっかくですので、このままカフェにご案内しようかと思っていまして……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360015" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「つまりお客様ということね？　わかりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023360003" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「私はディーネリンド。アイナリンドと同じく、軍楽隊に所属しているメガネ\nエルフです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023360004" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「私はラヴリエータですっ！　この騎士団では一番遅れて入ってきた新人です\nねぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023360003" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どんどんデカパイエルフが出てくる！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "1", "char_00017201_01", "6", "CENTER", "100" ]},
		{"command":[ "SETCHARA", "2", "char_00017301_01", "6", "CENTER", "-500" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "6", "CENTER", "500" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（やっぱりここは……異世界だ。俺にだけ都合のいい最高の異世界なんだ！）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひゅぅ～う！　やったぜ！　こうなりゃもらったも同然だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「もらっ……？　な、なんですと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺の時代が来たってことだよ！　俺にだけ都合のいい世界！　俺だけを愛す\nるヒロインっ！　俺無双！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よーし決めた、俺は決めたぞジュンジロー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「な、何をですかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここで暮らすんだよ！　んでもって、チート能力でやりたい放題だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「生活スペースは、少し離れた場所ですので……カフェでは暮らさないでいた\nだけると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360016" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それもそうか！　あ～、まず何から始めるかな～。定番のジャガイモ育成か\nらやってみるか～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ジャガイモは近くの農家から、譲っていただいたばかりで余っている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023360005" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃ、井戸でも掘るとするぜ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「近くに綺麗な川がありますし、魔法でお水は浄化しておりますから安全です\nよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360017" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へー！　今時は、そういう手間すら省いて美味しいシーンだけ経験させてく\nれる時代なのかもなー」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さ、さっきからご主人は一体何を口走っておるのやら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺のテンションの高さについていけていないらしい一同。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺はエルフたちの人数を数えて、少しハーレムには足りないな……と思って聞\nいてみた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「この少数メンバーでカフェをやってるってことか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「ああ、いえ。本当はもっとたくさん人数がいるんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360018" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうかそうか！　やっぱりそうか！　ま、１０人くらいいてくれないとな！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今いるエルフが、おっとり系、しっかり系、後輩元気キャラだから……あと\nは闇を感じるゴスロリ系と」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「和風メガネエルフのロリババア枠と、うーん。一人貧乳がいてもいいな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あとは、昔実は出会っていた幼馴染キャラと、未来から来た俺の娘」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ここにはそれほど多様なエルフはおりませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023360006" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え～。じゃ追加キャラってことなんだろうなあ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「追加キャラ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360011" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「今まで、エアルミンさんとアーリッドさんという方が店長のような存在でし\nて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360019" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「カフェはこの２人を主軸に回っていたんです。ですが、エルフの国からの緊\n急要請で２人は出張に出かけてしまって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360020" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「それからもう、毎日どっか壊れるわ、お客さんは来ないわで、ぶっちゃけ赤\n字も大赤字なんですよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023360004" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「理由がわからないわ……。私が、世界一の食事を提供しているというのに…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023360007" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「不思議ですよねぇ。心をこめてお給仕させていただいていますのにぃ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360021" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふーん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（つまり、そのトラブルをうまいこと解決すればエッチなシーンが始まるって\nことか）", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺は異世界転移に詳しいんだ、間違いない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "……ということで、最近コミカライズされていた異世界転移モノの知識をフル\nに披露してみることにした。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（任務の合間に、暇潰しに読んでおいて助かったな）", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え～っと、一番最近読んだやつだとどう解決してたっけな……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、そうだそうだ。……お前らが儲からない理由がわかったぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「えっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360022" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「各メンバーの特徴をまったく活かしきれていないんだ。人には……エルフに\nも、適材適所ってのがあってだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「つまり？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023360008" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「料理する時に物をぶっ壊すお前には料理係は向いていない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「が、見るからに頭が切れそうだし、他に得意なことがありそうだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……言われてみれば、そうかもしれないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023360009" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな感じで、もっといいやり方ってのがあるかもしれないってことだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「そんなこと……思いつきもしませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360023" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ね～！　すっごいねぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023360005" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おっ！？　これが正解だったか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「当てずっぽうに思いついたことを言ってみただけではありませんか～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023360012" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいんだよっ。転移者ってのはそれくらい強引で！　なんたって主人公だぞ\n、主人公！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「てんいしゃ……？　しゅじんこう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360024" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし。こうなりゃこれも縁ってやつだ。俺がこのカフェを立て直してやるよ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アイナリンド" ]},
		{"command":[ "SETTEXT", "「それは嬉しいです！　で、ですが……どうして見ず知らずの私たちにここま\nでしてくださるんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_172_010023360025" ]},
		{"command":[ "SETCHARA", "0", "char_00017201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そりゃあ、俺もお前達のご主人様……もとい、協力者としてここで生活して\nいくからだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "それが異世界転移した時のルールってやつだし、いかにもスローライフのはじ\nまりって感じがする。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラヴリエータ" ]},
		{"command":[ "SETTEXT", "「ええっ！？　私達を助けてくれる協力者さんだったんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_271_010023360006" ]},
		{"command":[ "SETCHARA", "0", "char_00027101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「自分には何も利益がないでしょうに……もしかして、とてつもない善人なの\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_010023360010" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それじゃ、さっそく最高の店を目指すために……俺にお前達の能力ってやつ\nを見せてくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺の一声に、エルフたちはさっそくテキパキと働きはじめた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}