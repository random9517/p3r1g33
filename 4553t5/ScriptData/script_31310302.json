		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁあああああああ～～～っ！　あああっ！　あっ！　あっ！　出てます…\n…！　あなたの精子が、私の中に……んあああああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ！　あ、あ、ああ……っ！　子宮が！　……また子宮がぁっ！　あなたの\n精子で喜んじゃってますぅ……っ！　んんんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304302" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、まだ出てる。おちんちんがピクピク動いて、精液がぴゅっぴゅ\nって……！　んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304303" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁああ……だんだん、精液の勢いが弱まってきましたね……もう、出し切\nったんですね……ふぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304304" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「でも、二回も出されて……二回もいっぱい出されてぇ……私のおまんこ、あ\nふれちゃってますぅ……白いのがダラダラって……んぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ……私の子宮が、あなたの精子をどんどん吸い込んでます……なんか\n、そんな気がします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304306" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁあ……初めてのセックスで、こんなにたくさん中出しされちゃうなんて\n。なんだか、信じられないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304307" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「このままだと私、きっと妊娠しちゃいますね。ふふふっ、でも、あなたもそ\nのつもり……種付けするつもりだったんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304308" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ねえ、ホントに赤ちゃんが生まれてきたら、私とあなた、どっちに似てると\n思います？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304309" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「どっちでもいいですね！　だって私、あなたとの子供を、これから大勢作る\nんですし、どっちに似てても、絶対かわいいですもん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あぁあああん！　やめて！　抜かないで……あぁあああん！　精液が！　精\n液が飛んでくるぅ！　ふぁあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、ああああ……っ！　熱い精液が、おまんこに、おなかに…\n…胸にも……っ！　はぁああぁ……んんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304402" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふぁあああ……まだ出てるぅ……！　あなたのおちんちんが、ぶるん、ぶる\nんって震えながら、精液を飛ばしてきてます。んぁああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304403" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁああ……どろどろの、熱い精液……カラダじゅうにかかって……ベタベ\nタして……んぁあああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304404" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁああ……息を吸い込むと、胸いっぱいにあなたの匂いが……こほっ！　\nこほっ、こほっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304405" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫です。あなたの匂いが強すぎて、むせちゃっただけです。嫌いな\n臭いじゃないです。はぁあああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「こうして、あなたのべとべとの精液を浴びて、匂いを吸い込んでると、また\n頭がぼーっとしてきちゃって……はぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304407" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やだ……またぼーっとしすぎて、エッチなことしか考えられなくなってきち\nゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304408" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ね、ねえ？　あなたのおちんちん、まだ硬いですよね？　もう一回、入れて\nもらっていいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304409" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もっともっと、あなたの精液浴びたいです。カラダじゅう、ドロドロのベト\nベトになっちゃうぐらい……うふふふふふっ……」", "NORMAL" ]},
