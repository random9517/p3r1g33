		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんぅ！？　おちんちん、私のおまんこに当たってる……！　あ、熱くて硬\nくて……はあぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304102" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そんなに大きいの、本当に入るかな……？　えっ、入らなくても入れちゃう\nからって……そんなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304103" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はっ……はっ、今あなた……おちんちん入れたくて堪らないって顔してます\nよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304104" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「えっ……私も入れられたくて堪らないって顔してる……？　初めてなのに…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304105" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ん、う……ん。はい。あなたにヴァージン奪われたくて堪らない……です。\nだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304106" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたのおっきなおちんちん入れて下さい……これでいいです……かっ！？\n　ひゃっ！？　ああぁぁぁ～～～！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304107" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はひっ！　ひぃぃ！？　入って……くるぅぅ！！　おっきいので入り口が拡\nげられてっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ぐりぐりって狭いおまんこのナカぁ拡張しながら入って……くぅぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304109" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んああぁぁん！！　そんっ、なぁ……奥に到達、しちゃってます……んんぅ\n！　根元まで入って……くぅぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304110" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「い、痛くないかって……はっ、はい、痛くない……です。それどころか……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304111" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「子宮がきゅん、きゅんってあなたのおちんちん感じて……あぁ、胸がときめ\nいちゃって……あうぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304112" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「いきなり動いちゃダメっ……ダメぇぇ！！　頭の奥にっ……芯にビリビリく\nるぅぅ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304113" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「体験っ、したことないっ……あ、味わったことのない、意味が分からない快\n感が……んああぁぁ！！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304114" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ビリビリって駆け巡って、私ぃ……い、息も忘れちゃうぐらいに感じちゃう\nんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304115" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やあぁ！　初めてなのに感じてるの……私だって、おかしいって思ってるん\nですからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304116" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「へ、変態だなんて言わないで……ひぅぅ！？　子宮口ぉキスしながらドＭだ\nなんて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あなたが激しく責めるから……ああぁぁ～～！？　乳首とか、ダメっ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304118" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やああぁん！！　先っぽクリクリってイジメられたら、私っ……んんぅ！？\n　んああぁぁ～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304119" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「子宮がなびいちゃいます……っ！　こんなっ！　こんなぁ！　がつ、がつん\nって突かれたらぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304120" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ナカぁ、容赦なく突かれ続けられたらぁ……子宮ぅ下りてきて、おちんちん\n咥えこんじゃいます……くぅぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304121" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はひっ、ひっ……本は読んでた、からぁ、エッチな知識だけはあって……あ\nうぅぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「でも、初セックスでアクメきめちゃうなんてエッチな本だけのことだって思\nってたのにっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304123" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「私っ、んああぁぁん！！　私がこうなっちゃうだなんて……ひっ、ひぃぃぃ\n！！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304124" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「おもっ、わなかった……くぅぅ！？　やあぁ！？　乳首っ吸わないで……！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304125" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やぁぁ！　もぅダメ、もぅっ！　もう変なのきちゃう……きちゃいます……\nんひぃぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「このままイッたら、んぁぁぁ！？　初めてぇ……なのにぃ、子宮ぅなびいち\nゃって……あああ！！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304127" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ぜ、絶対に妊娠、しちゃいますっ……！　んああぁ！？　孕ませるって……\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あうぅぅ！！　来るっ！　来るぅぅ！！　妊娠絶頂きちゃいます、くるっ…\n…やあああぁぁ～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304129" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、あああぁ～～！！　イクッ、イクイクッ……んああぁ！！　\nあぁぁ～～～！！！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304130" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひゃふぅぅ！！？　あふああぁぁぁ～～！！　はひっ…………！！　ひぃぃ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304131" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ドクッ、ドクッて熱いのが注がれて……んあぁぁ！！　子宮ぅ、喜んじゃっ\nてますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304132" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んあぁ、まだ射精続いてるぅ……ふあぁ～！　はあぁ！　はっ！　ひぃぃ…\n…いぃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304133" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふあぁ……あっ？　ちゅる、ちゅっ、ちゅるる……んふぅ、ちゅぱ、ちゅっ\n……んっ、んっ、好き…………！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「好きです、もっと抱きしめて……ちゅっ、ちゅるる、ちゅぱ、んあぁ……大\n好き、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304135" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あっ、あれ？　きゃっ……！！　おまんこのナカで、またおちんちん大きく\nなってきちゃいましたよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304136" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふぇ……！？　か、可愛いカオ見てたら勃起しちゃったなんて、真顔でそん\nな……恥ずかし、でも……嬉しい……です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304137" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もっとするんですか？　ああぁ……種付けする？　絶対に妊娠しちゃうまで\nする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304138" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんぅ、分かりました……来て下さい、私のカラダ、あなたに屈服させられ\nたいんです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたのものにして下さい……あっ、あああ、あぁぁ～～！！　またイクぅ\nぅ～～～！！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304140" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんっ！　おちんちんいいっ！　あなたのおちんちん、とっても\n気持ちいいですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あああ、どうしよう、私、ホントはダメな子なのかも！　エッチなことしか\n考えられない、ヘンタイさんなのかもっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304202" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「だって、だって、もう私、あなたのおちんちんで、頭もおまんこもいっぱい\nで……はぁあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304203" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「だめ、だめぇ！　そんなにズンズンぐりぐりされたら、ホントになにも考え\nられなくなっちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304204" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ダメぇ、私、もうダメぇ！？　はぁああん！　ああんっ！　あっ、あっ！　\nあああああ……ああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304205" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ああああ……やっぱりダメです、私、ダメになっちゃってます。今日、初め\nてエッチしたばっかりなのに……はぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え？　ダメじゃないんですか？　私の中が……とってもいい？　気持ちいい\n？　ぁあああん！　そういうことじゃないですぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304207" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「大丈夫？　エッチなことしか考えられなくなっても大丈夫？　ほ、ほんと…\n…ですか？　んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304208" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたも、もうエッチなことしか考えられない？　だ、だってそれはいつも\nのことじゃ……ひぃっ！？　いきなり奥まで突かないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304209" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい！　ごめんなさいぃっ！　もう、よけいなこと言いません\n！　だから、そんなに奥をぐりぐり突かないで……ふぁあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「……え？　あなたがエッチなことしか考えられなくなっちゃうのは、私がか\nわいいから……？　そんな……ふぁあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304211" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あんっ！　そんなこと言われると、私、幸せで……頭がふぁあっ、\nてしてきちゃって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304212" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふぁああん！　そんなに激しくされると、ますます頭がふぁあ～ってしてき\nちゃいますぅ！　あん！　あああっ！　ああああ～ん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304213" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「もう、他のことはどうでもいいです！　何も考えないで、　あなたとこうし\nていたいっ！　んっ！　ん！　ああああ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あああんっ！　あん、あん、はぁああああ……あああん！　そうです！　そ\nうしてほしいんです！　もっと、もっと動いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304215" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁああん！　あんっ！　あ、あ、また……変なのきちゃった！　私、また\nイッちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304216" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、おちんちんが！　あなたのおちんちんが、ぴくぴくしてきましたっ\n！　あなたも、イキそうなんですね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304217" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はいっ！　イキたいですっ！　あなたと一緒に、イキたいんですっ！　だか\nら……あ、あ、ああああああん！　はぁあああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304218" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「イッちゃうっ！　私、ホントにイッちゃうっ！　おちんちん気持ちよすぎて\n……あああああああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0304219" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「イッて！　あなたもイッてください！　私の中に、オチンポミルクもう一回\n……はぁあああん！　あ、あ、あああああああああああっ！」", "NORMAL" ]},
