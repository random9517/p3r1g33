		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あなた、なかなかやるじゃありませんか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113660002" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「え？　え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113660002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「今後ともその調子で、私の後をついていらっしゃい。ともに真の闘球道を極\nめる者として」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113660003" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「は……はい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113660003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや、闘球道ってなんだよ。違うだろ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、ギクシャクしていたみたいだけど、仲良くなれたみたいだな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルルーナも友人が増えたってことで、いいことかもしれないな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「さあ、夜日楽さん！　今度は『帝球』の異名を持つ魔道・テニス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113660004" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ひえぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113660004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「お姉様と呼んでもよくってよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113660005" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「わ、私にはお姉ちゃんがいるので！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020113660005" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、ちょっとやそっとじゃ変わらないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いい関係になったかと思ったが、相変わらず夜日楽はルルーナの無茶ぶりに振\nり回されていた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「夜日楽殿も苦労が絶えませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113660001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まったくだな。まあ、無茶ぶりの相手が分散してくれれば、俺の苦労も……\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「下僕？　いま、私の悪口を言ってたんじゃありません？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113660006" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおぉっ！？　ルルーナ、いつからそこに！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「質問に答えなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070113660007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そんなことありませんって！　では！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「こら、待ちなさーい！」", "NORMAL" ]},
