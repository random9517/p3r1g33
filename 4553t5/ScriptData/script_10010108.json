{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0101" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_005" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETNAME", "将軍風の男" ]},
		{"command":[ "SETTEXT", "「本当にそういう敵が攻めてきたのか？　信じられん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "スーツ姿の男" ]},
		{"command":[ "SETTEXT", "「信じるも信じないも君の勝手だが、映像記録がこの通り残っている。事実と　\nして認めるしかないだろう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "白衣姿の男" ]},
		{"command":[ "SETTEXT", "「だが、今時映像などいくらでも加工できるぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "サングラスの男" ]},
		{"command":[ "SETTEXT", "「だからさっきも説明したじゃないか！　この映像に、改ざんの痕跡などない　\nんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "妖艶なドレスの女" ]},
		{"command":[ "SETTEXT", "「ったく。だらしないねぇ、大の男が右往左往しちゃってさぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "グレート・ルナリアムの定例会議とか戦闘後の反省会なんかもそうだが、会議　\nってのはどうしてこう、眠気を催すんだろうか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "それ以前に俺たちは、なぜこんなところにいるんだ。なんか国際機関の本部ら　\nしいところにある、やけにでっかい会議室に。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "会議室というか巨大なホールを埋め尽くしているのは、正義の組織と悪の組織　\nのお偉いさんばかり。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そんな偉そうな連中が、あーでもないこーでもないと激論を繰り広げる中に呼　\nび出されても、正直俺はすることがない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ねぇねぇ、お姉ちゃん……私達ちょっと場違いなんじゃないかなぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101080001" ]},
        {"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "つきみは落ち着かない様子で、あっちをきょろきょろ、こっちをきょろきょろ　\nと見回しては、大きな椅子の中で体をもそもそ動かしている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「静かにしなさい、つきみ。きょろきょろしていると余計に目立つわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101080001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「場違いといえば我々も相当浮いていませんかな？　ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ジュンジローのヤツも退屈したのか、俺に話しかけてくる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こんな格好のままこんな場所にいるんじゃぁ、目立ってしょうがないだろ。　\nだいたい、俺たちは――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そこ！　静かにしろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、す、すみません……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ルナテミスに一喝され、いつもの習慣で思わず小さくなってしまう。が、当の　\nルナテミスや他の幹部たちも……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「しかし、あれからあんな展開になるとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「いまだに信じられないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "いまでも、自分たちの置かれた状況が飲みこめていないらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そりゃそうだよなあ。あんなことがあったら――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "sbg_0017" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "全員" ]},
		{"command":[ "SETTEXT", "「なっ、なんか凄いの来たぁーーーーっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "000_010101070005" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0017" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "黒いルナテミス" ]},
		{"command":[ "SETTEXT", "「ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101080001" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "黒いルナテミスは、空間をぶち割って現れた鋼鉄の顔を見て、不敵な笑みを浮　\nかべる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そして剣をかざし、標的を指示するかのように上空の艦隊を指し示す。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "黒いルナテミス" ]},
		{"command":[ "SETTEXT", "「放て！　竜の咆哮（ドラゴンズロア）！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_090101080002" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0018" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ！？　なんだなんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ロボットの声で、地面が震えて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101080002" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そして、その声がさらに高まったかと思うと、巨大なロボットの顔から――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "まばゆい閃光が放たれた！", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0019" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「な、なんだ！？　なんだ！？　なんだぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101080001" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0020" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁ～ん！　いったい、何が起こってるのぉ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101080001" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "あたりは強い光、そして連続する爆発音に満たされ、俺たちには状況がまるで　\nつかめない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そして、ようやく光と音が止んだときには――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「こ、これは！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101080002" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0021" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「空から――船が消えている！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101080001" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "上空を覆いつくしていた侵略者の大艦隊は、あの一発で八割……いや、九割が　\nた姿を消していた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そして、生き残った船は現れたときと同じように空間をぶち割り、こつぜんと　\n姿を消したのだった……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0101" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あんなん反則だよなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いまだに信じられないよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だよなあ。巨大ロボットが、宇宙戦艦の群れを消しちまったとか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "俺も、他の連中の言葉にうなずくしかない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ロボットもそうなんだけど、姫様のそっくりさんって何者なのかしらぁ～？　\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そういえばそうだ。ルナテミスにそっくりだが、ルナテミスをはるかにしのぐ　\n強力な技を持った女――黒いルナテミス。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "あいつはいったい……？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ひょっとして、姫様も同じような事が出来る可能性があるのではないですか　\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「え！？　ほんと！？　ルナテミス、あんなことできるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わからん……まったく、なにがなんだかわからん……あ、頭が混乱して来た　\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「姫様…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010101080001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そんな具合に、俺たちが頭を抱えていると――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「あ！？　てめぇ、俺をコケにするつもりか……なあ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080001" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "PLAYBGM", "BGM_014" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "会議室の一角で、大声を上げたやつがいる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「これは失敬、気分を害したのであればお詫びをさせていただくよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "079_010101080001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "なんだ？　あいつら。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「何がワビだコラっ！　もういっぺんさっきのセリフを言ってみろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080002" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「いやぁ、参ったなぁ……さっきのは純粋な好奇心というか、探究心から出た　\n質問で他意はないんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "079_010101080002" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「てめぇ、いいかげんにしやがれ！　俺のことを『裏切り者』だと言いやがっ　\nたろうが！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「いやいやいや、決してそんな言い方じゃなかったと思うけどね、僕が言った　\nのは『正義の味方を辞めるのってどんな気分なのかな』だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "079_010101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「正義の味方……？　じゃ、あいつらも、お前らと同じ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "俺がまりあのほうを向くと、彼女はうなずく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だと思います。この会議には現場で戦う正義の味方や悪の幹部も、大勢招か　\nれていますから。だから、あの人たちもたぶん――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101080002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "俺たちが話していると、ケンカの当事者がまた大声を上げた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「てめぇ……もう二度と口を開くんじゃねぇ、消し飛ばすぞカス野郎……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080004" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「それは勘弁して欲しいなぁ……君の能力と僕の能力じゃぁ相性が悪い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "079_010101080004" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「鳳雛てめぇ、もうしゃべんなぁああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080005" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「やれやれ……まいったなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "079_010101080005" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ナメてんのか、この！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080006" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "カッカしている女の周りで、空気が揺らぎ始める。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "カッカしすぎて陽炎が立つほど、あいつの怒りのボルテージが上がったってこ　\nとか？　それとも、あいつの能力――", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「その探偵の言葉は間違っていません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010101080001" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そう思ったところで、今度はやけにクールな女が現れた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "クールなのは態度だけじゃない。まるで、そいつ自身が冷気をまとっているよ　\nうに、あたりの空気が一瞬にしてキン！　と張りつめる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「仮面戦隊マスカレード、マスク・ザ・ブルー。只今、現着しました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010101080002" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「…………っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080007" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「申し訳ありません。任務を完遂するのに時間がかかり、遅刻してしまいまし　\nた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "俺たちが見守る中で、マスク・ザ・ブルーと名乗った女は会議室の中央にある　\n演壇へと上がる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そして、体の周囲に陽炎をまとった女を指さすと、言い放った。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「しかし、ここは地球の平和を守る礎、正義の味方の総本山・ＥＤＯの神聖　\nな大会議室です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010101080004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「その正義の象徴とも言える場所に、なにゆえ正義を裏切った人間が存在して　\nいるのですか？　赤塚ほむら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010101080005" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「てめぇ……氷華……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080008" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん、いーでぃーおーって何？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101080004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私達の所属するステラルクスも参加している地球防衛機構、ＥＡＲＴＨ・Ｄ　\nＥＦＥＮＳ・ＯＲＧＡＮＩＺＡＴＩＯＮの略称よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「へぇ～、そんな組織に加入してたんだ～、知らなかった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101080005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「知ってましたか？　ご主人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101080002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「知るわきゃねえだろ。しがない下級幹部の俺が、そんな情報もらえるもんか　\nよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "そんな俺たちの会話をよそに、会議室の真ん中でマスク・ザ・ブルーはさらに　\n言う。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「さぁ、この場所にふさわしくない者は直ちに去りなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010101080006" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "だが、この言葉はほむらだけではなく、その周囲にいた悪の組織の連中も刺激　\nした。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "海産物の怪人" ]},
		{"command":[ "SETTEXT", "「つまりそれはナニか？　貴様ら正義の味方だけで、何もかも決めたいってこ　\nとか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "サイボーグ風の怪人" ]},
		{"command":[ "SETTEXT", "「あの女、何様のつもりだ？　俺たちをここまで呼び出しておいて……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "演壇の周囲に、不穏なざわめきが広がる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……俺だってこんなところに来たくねぇのに……来たくねぇのによぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080009" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "だがやはり、ひときわ怒りをつのらせているのはほむら本人だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「地球の一大事だからって頭下げられて、ガマンして来てやったのによぉ！！　\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080010" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "いったん収まりかけた陽炎が、彼女の周囲に立ち上り始める。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「自分が絶対に正しいっていう、その思い込みはどうにかなんねぇのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080011" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ほむらの額に目に見えて太い青筋が立ち、これだけ離れていても、彼女を中心　\nに気温が上がり始めたのがわかる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なに？　なんなの？　この暑さ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101080006" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「てめぇの、その能面ヅラ……今日こそ黒焦げにしてやるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "034_020101080012" ]},
		{"command":[ "SETCHARA", "0", "char_00003401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　あの子の足元の床、溶け始めてるじゃないの～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "006_010101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……炎を操る能力者か」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "003_010101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「やってみるといい、あなたには無理だと分からせてあげます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "050_010101080007" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "一方、マスク・ザ・ブルーの周囲では急激に気温が下がり始めたようだ。演壇　\nのマイクもテーブルも、真っ白な霜に覆われていく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "サイボーグ風の怪人" ]},
		{"command":[ "SETTEXT", "「上等じゃねえか……いっちょ、助太刀と行くか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "昆虫型の女怪人" ]},
		{"command":[ "SETTEXT", "「もともとあいつは気に入らなかったのさ。ちょうどいい機会だ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "悪の組織側の出席者が、険悪な表情で立ち上がり始める。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "忍者風の女" ]},
		{"command":[ "SETTEXT", "「やらせはせん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "全身タイツの男" ]},
		{"command":[ "SETTEXT", "「あーもう！　こんなとこで暴れちゃよくないよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "それにつられて、正義の味方側もじりじりと演壇に迫る。一触即発の空気だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「へぇ～、あいつら強そうだな！　よぉ～し、私達も混ぜてもらおう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "004_010101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「バカ狼はこれだから……。自ら揉め事に加わるなんてめんどくさいことした　\nくないです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "005_010101080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ヤバげな空気にウチの幹部たちも浮足立ち、十五夜姉妹も慌てだす。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ど、どうしようお姉ちゃん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "012_010101080007" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ムーンナイトさん！　早く彼女達を止めてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101080004" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "な！？　いきなり俺に振ってきた！？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんで俺なんだよ！？　見ず知らずの相手だぞ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だってこの会議自体、貴方の能力がきっかけで起こった現象を解決するため　\nに開催されているのですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101080005" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなの！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうなんですっ！　だから、言ってみればあなたがこの会議の総責任者みた　\nいなものなんですよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010101080006" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、ちょっとそれは言い過ぎじゃねえのか？　言いたいことはわからなく　\nもねえけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふぅむ……、彼女の言う事にも一理ありますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101080003" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「てめえ。さっそく俺を売る気満々か」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さぁ、いつもの様に私は安全圏から応援しておりますので、さっさと片付け　\nちゃってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010101080004" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「駄犬、お前、ロクな死に方しねぇぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "ああ、もう！　しょうがねえ！　行くか！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}