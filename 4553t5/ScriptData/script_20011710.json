{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_002" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと待ってくれ！　どうして俺が砂の中に埋められないといけな\nいんだよ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そうですぞ。ご主人ならまだしも、何故わたくしまで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540031" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「これはコンテストを台無しにしたお仕置きよ。しばらくその姿のまま、反省\nしてなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021540008" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そういえば、敵の本拠地というのは何処にあるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ここからそう遠くないところにあるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「ただ、えらく敵が強くてな……さっきの襲ってきたヤツらより、パワーがあ\nると思うぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「これはあくまでも推測だが、敵の基地に襲来者（インベーダー）を強化する\nなにかがあるのかも知れん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021540006" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「それを壊すことができたら、襲来者（インベーダー）退治も楽になるってこ\nと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021540011" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「その可能性は高いだろうね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021540007" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「わかりました。正義の名にかけて、私たちも協力するですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540059" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「そうですね。ここまでご一緒した仲ですし、出来る限りの協力はさせてもら\nいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540041" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「面倒だけど、ボクもやるよ～。みんなで襲来者（インベーダー）を倒して、\nまた海で遊びたいし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540053" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それじゃ、出発しましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021540009" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「オッケー！　でもその前に、出発前の掛け声やってもいいかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021540008" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、別に構わないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021540008" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そんじゃ、いっちょやるか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021540008" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「みんな！　円陣を組んで、手を出して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021540012" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「それじゃあ行くよ～！　せーーーの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021540008" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「イェ～～～イ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021540010" ]},
