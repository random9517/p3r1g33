{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0176" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「止めると言っても……どうするの？　運転席には入れないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうだった！　おい！　誰か！　いい手はないか！　なんとかして、列\n車を止める方法は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「アナザー！　なにか考えろ！　いい手はないのか！　考えてくれ～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114420002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……考えてみたら、運転席に入る必要はないな。そもそも、入ったところで\n誰も列車の運転などできない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114420002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あ。そっか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それに運転席に入らなくても、破壊することならできる！　皆の力を合わせ\nればな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114420003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「壊してどうすんだい！　それで止まるのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「止まらないが、運転席がなくなれば、そこから宇宙レールを攻撃し、破壊で\nきる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114420004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「また破壊なのぉ！？　それに、そんなことしたら脱線しちゃうでしょ～！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114420001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「脱線させるんだ！　そのほうがましだ！　敵艦隊の総攻撃を受けたら、絶対\nに助からない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114420005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「無茶だけど……やる価値はありそう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114420002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうと決まれば、全員集まれ！　必殺技をぶちこんで、まずは運転席を――\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114420003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「いたぞ！　地球人ども！　おとなしく宇宙の塵になれぇええっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010114420001" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「って！　こんなときに襲来者（インベーダー）かい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114420002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やあああ～ん！　いなくなったと思ったのに、どっから乗り込んできたのよ\nぉ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114420002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}