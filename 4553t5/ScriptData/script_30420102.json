		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「隊長くん、気持ちいいこと、たーくさん教えてくれたから……それよりもっ\nと凄いって……うん……ドキドキするー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……どうすればいいのー？　……私は、ベッドに寝転がってるだけでいい？\n　隊長くんがやってくれる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104103" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「私のオマンコに……隊長くんのおちんちん……入れちゃう？　でも、隊長く\nんのおちんちん、大きいのに……入るかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104104" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……うーん……でも……何だか、聞いただけで……オマンコ、凄くうずうず\nして……んっ……熱くなってきてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104105" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……してほしい……かも……オマンコに……おちんちん、いっぱい……いっ\nぱいほしいー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「うん……いいよ、きて……隊長くん。……何だか、今なら簡単に入っちゃい\nそうな気がするー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104107" ]},
	{"command":[ "SETCHARA", "0", "char_00004201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……くふぁぁっ……んんんんっ！　すごーい……ほ、本当に……おちんちん\n、入っちゃった……全部、中……はふぅっ……」", "NORMAL" ]},
