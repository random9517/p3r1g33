		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「私のオマンコ、狭いのに……おちんちんでいっぱい広げられて……はふっ、\n奥までいっぱい……はぁ、はぁ……んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「大丈夫……息……少し苦しいけどー……でも、それより……気持ちいい……\nはぁ、くふぁあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「オマンコの中、隊長くんのおちんちんの形になってる……ぴったりすいつい\nて……はふっ、離れない……んぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「このままじっとしてる……？　動く？　……うん……動いてほしい……何だ\nか、オマンコ、疼いて我慢できないから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「おちんちんの出っ張ってるところで、いっぱいゴリゴリこすって……かき混\nぜて……お願い……あふっ、はぁ、んんぅっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「そこ……いいっ、はぁ、ひふぁあ……あんぅっ、出っ張ってるところ、オマ\nンコの壁に引っかかって……んぅっ、こすれてるー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「中、捲れちゃうみたいで……でも……気持ちいいっ、これ……気持ちいいよ\n……隊長くん……ふぁふっ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「お腹の中まで熱くなって……んっ、もっと深いところ……奥まで突いてほし\nいって思っちゃうー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「腰、勝手に動いて……隊長くんのほうに……んぅっ、あぁ、凄いよ……先っ\nぽ、さっきより深くまで届いてるー……あんぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……行き止まり……ここ……子宮？　うん……子宮、おちんちん\nでグイグイされるの……感じる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「一番大事なところで、隊長くんのおちんちん感じるの……嬉しい……凄く、\n嬉しくて、気持ちいいー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「もっと、そこ……突いて。子宮、中までおちんちん入っちゃうくらい、じゅ\nぼ、じゅぼって……突いて……はふっ、はんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「あはっ、んんっ、いい、それ……好き……はふっ、あぁっ！　んっ、突かれ\nると……声……出ちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「いつもと違う、何だか恥ずかしい声……いっぱい、出て……ふぁああっ、は\nぁ、はんっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「びっくり……私が、こんな声……出せるなんて……知らなかったから。んふ\nっ、くふぁあっ、はぁ、ひぅうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「隊長くんのおちんちん、やっぱり凄い……凄くて……気持ちよくて……好き\n……くふぁっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「うん、もっともっと……動いて、早く……ズボズボ動いていいから……もっ\nと……はふっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「おちんちん、どんどん硬くなって……んぅっ、くうううっ、オマンコの中、\nさっきより窮屈に……はひっ、はぁ、ひうううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「でも……ヌルヌル……してるから……動きやすい？　……おちんちんの汁…\n…それとも……私のオマンコの、お汁……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「いっぱい、出てきて……グチュグチュ、音もしてる……エッチで、恥ずかし\nい音……ドキドキする音……ふぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「聞いてると……オマンコが、もっと熱くなる……んぅっ、おちんちんに甘え\nるみたいに、ぎゅーって締まっちゃう……はふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「不思議……もう……隊長くんのおちんちんのことしか、考えられない……頭\nの中もオマンコもぉ、隊長くんのおちんちんにメロメロぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「うんっ、はぁ、きて……このままいっぱい……きてほしい……精液、精液…\n…ほしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「熱くてドロドロぉ……粘っこい精液……オマンコの奥に……子宮にビューっ\nてしてもらえたら、きっと凄く気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「それ……わかるから……んぅっ、あぁ……おちんちん、今、ビクッて跳ねた\n……ふぁあっ、んぅっ、出る……精液……はひぃ……あぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「うん、きて……出して、精液……熱い精液……おちんちんの汁っ、子宮いっ\nぱいに……きて……ふぁあああっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「くぅっ、はふぅっ、ふぁああっ、あぁ……出てるっ、いっぱい、精液、出て\nる……ひぅっ、くうううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「あぁ、熱い……熱いのぉ、子宮……いっぱいで……んんぅっ、身体、ふわぁ\nって浮いちゃう……イク……くううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「頭……真っ白ぉ……はぁ、はひぃっ、これ……初めての……感じ……こんな\n凄いの、初めて……ふぁあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「子宮に精液、ビチャビチャかかってる……それ……気持ちよくて……んぅっ\n、浮いちゃう……もう……ふぁっ、あふぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「オマンコ、蕩けて……戻らなくなっちゃいそう……はふぅ……んぅ、凄く…\n…幸せ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「熱い精液……染み込む感じ……好き……もっと、もっと……いっぱい感じた\nくなる……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「隊長くんのおちんちんも……まだまだ精液出したいって、オマンコの中でビ\nクビクしてるー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「いいよー……しよ？　隊長くんがスッキリするまで、いっぱい、いっぱい精\n液出してほしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「んっ……もっと気持ちよくなれるように……どうすればいいかなー……教え\nてくれたら、私も頑張るー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「……オマンコ、締める？　ぎゅって……んっ……力、入れて……はふっ、ん\nぅ……こう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「あまり締めすぎても、動きづらい……？　じゃあ、これくらい……んくっ、\nはぁ、ちょうどいい……？　んぅっ、あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「凄いよ……さっきより、おちんちんの出っ張りが壁に深く食い込んで……ん\nくっ、あぁ、中、引っ張り出されそうな感じぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「ゴリゴリ……削られるみたいで……振動、子宮に響くの……気持ちいいっ、\n凄く……ふぁっ、あふうううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「うん……これ、好き……ギュッて締めたオマンコ、いっぱいかき混ぜられる\nの……気持ちいい……あふぁっ、あんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「隊長くん、本当に気持ちいいこと、たくさん知ってる……凄い……はふっ、\nはぁ、んんぅっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「もっと、もっと私のオマンコで気持ちよくなって……私に、気持ちいいこと\n教えて……はふぁっ、くぅっ、んんぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「あぁっ、いいっ、それも……腰、引いて……勢いつけて、奥……子宮、ズン\nッて突かれるの……あんぅっ、あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「中に入ってる精液、ゴボッてあふれてくるぅ……熱い感じ……何だか、いい\nっ、凄くっ、いい……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「あふっ、あぁっ、もう……突かれるたびに、身体、ふわぁって浮くみたいで\n……んぅっ、イク……イッてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00004201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「私、おちんちんでイキッぱなしにされてる……ふぁぁっ、あぁっ、いいっ、\nはひっ、はんんぅっ、くううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「隊長くんも……もっと、イッて……精液、ビューッてたくさん出して、気持\nちよく……なってぇ、はひっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラン" ]},
		{"command":[ "SETTEXT", "「あぁっ、一緒……一緒に凄く気持ちよくなりたい……んんぅっ、、もっとも\nっと気持ちいいところまで、一緒にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_042_0104216" ]},
		{"command":[ "WAITINPUT" ]},
