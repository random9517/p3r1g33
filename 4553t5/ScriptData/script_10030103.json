{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "ルナテミスに殴られて目を覚ましたついでに、説明しておこう。俺がなぜ、こ\nんなところに収容されているのか。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "時間城での戦いから帰って、数日経ったある日……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマが狙われている！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「どうしてカツマさんなんかを！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、なんかってなんだよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「あ！　ごめんね！？　なんか、あまりにも意外だったんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114650002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「どういうこと！？　いったい誰がカツマの貞操を！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんな！　カツマさんがあまりにも総受け感を漂わせてＭ丸出しだからって\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「意外なところに、意外な需要ってあるもんだねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前らもなに言ってんの！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「皆さん落ち着いてください。そういうことではないんです。問題は、カツマ\n隊長が刻の女王の息子ではないかと疑われていることです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0168" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうではない。私がお前の母なのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむ、そういえば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そんなこともあったねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「あったっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あったわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「時間帝国の支配者である刻の女王は、いわば多元宇宙の超ＶＩＰですからね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114650002" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「その息子を確保し、交渉なりなんなりのカードにしようと考える勢力も多い\nはずです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114650003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「つ、つまり、カツマさんが捕らわれのヒロインに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114650002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ヒロインはともかく、奪い合いの火種になる可能性が大きい、とは言えます\n。可能なら、どこか安全なところに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114650004" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0174" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「そういうことなら、我々が引き受けましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「誰だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114650002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「レディ・ホープ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114650005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誰だ、こいつは……って、あれ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114650002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おいおいおい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114650002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ダ、ダイヤナそっくり…！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114650003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ふぇえええっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114650002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "たしかにこいつ、ダイヤナというか……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつかのサメ騒動のときに出会った、過去のダイヤナ！　園子にそっくりじゃ\nないか！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あなた……もしかして園子……ちゃん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114650003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あ、本人が聞いちゃった。だいぶ動揺してるみたいだし、無理もないな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「園子……？　違いますね。わたしはレディ・ホープ。次元管理統制局局長で\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114650002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「ですよね～……やっぱり、そちらのお仕事で来られたわけですよね～……で\nは、私はこれで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114650006" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ちょっと！？　どこへ行くんだ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114650002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミス・パープル" ]},
		{"command":[ "SETTEXT", "「いや……大人の事情と申しますか……組織間のしがらみと申しますか……お\n察しください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_072_010114650007" ]},
		{"command":[ "SETCHARA", "0", "char_00007201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「いや、そこは察するけどさぁ！？　なにもこのタイミングで解説役が……あ\n、ホントに帰っちまいやがんの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010114650003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「多元宇宙の安定を維持するため、不安要素となるカツマさんの身柄をお預\nかりします。カツマさん、ご同行を」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114650003" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、ご同行と言われても……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうよ！　カツマさんにあんなことやそんなことをしようなんて、許せない\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114650003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマのお尻は、渡さない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114650003" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そう言ってくれるのは助かるけど、まだなんか誤解があるんじゃないのか！\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「とにかく、カツマは私の――じゃなくて！　我らの下僕だ！　勝手な真似は\n許さんぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114650001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマの身柄はこちらで守る！　お引き取り願おうか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114650003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "レディ・ホープ" ]},
		{"command":[ "SETTEXT", "「……そうですか。そうおっしゃるのなら、仕方ありませんね。こちらも実力\nを行使します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_090114650004" ]},
		{"command":[ "SETCHARA", "0", "char_00000609_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}