{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さん、少しいいですか？　パトロールも終わりましたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00021002_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「その……この前私の器であるマミの知識で、地球の男性へのご奉仕を覚えま\nしたので、隊長さんにぜひと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「よろしいのですか？　では、早速フィールドを張って認識阻害を……ふふふ\n、これで誰も私たちに気づきません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それでは失礼して服を……ふふ、相変わらずたくましい身体ですね。ん……\n見てるだけで私の身体も興奮してきました。ほら、胸が……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00021002_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「じゃあ、行きますよ……んんっ、ふふっ、隊長さんの下半身がずっぽり埋ま\nってしまいましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203105" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「パイズリ、というのでしょう？　男の人を私の胸で挟んで奉仕する……サイ\nズは違いますけどこうすれば……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「どうですか、隊長さん。私の胸、気持ちいいですか？　え？　気持ちいいけ\nど呼び方が違う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「……おっぱいマンコ。そんないやらしい呼び方……んんっ、想像しただけで\n母乳が……興奮すると出てくる体質なんです。ふあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「そ、それじゃあ、私のおっぱいマンコで、隊長さんのおちんぽにご奉仕しま\nすね……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、こうして両手で寄せて上げて……そうしておっぱいマンコの谷間でし\nごいたら……ふっ、うっ、どうですか、隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、あっ、んっ、この母乳も塗り込んで……ほら、おっぱいミルクマン\nコですよ……ぬるぬるって、ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、谷間の中で、隊長さんのおちんぽが硬くなってるのが分かり\nます……ふふっ、私のおっぱいをつんつんって突いてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、おっぱいマンコの中で脚動かしちゃだめですよ……んっ、こ\nら、いたずらっ子なんですから……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、んっ、ほら、こうしておっぱいマンコの圧を強くして……んっ\n、どうですか？　んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、隊長さんの身体が、私の谷間でみちみちになってます……ふ\nあっ、あっ、逞しい身体がぴっとりと……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、隊長さん、おっぱいミルク塗りつけたらだめ……あんっ、あ\nっ、そんな、飲んでる……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああっ、おっぱいミルク飲んだら隊長さんのおちんぽがさらに……ふああっ\n、硬くなってる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おっぱいマンコの中で、おちんぽがごりごりってえぐって、ふあっ、あああ\nあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、凄い、聞こえますか、にちゅにちゅって、おっぱいマンコのな\nかで隊長をしごいてる音が……いやらしい音が……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、あっ、またおっぱいミルクがいっぱい出てきた……ふうっ、あっ、\n隊長さん、そんなにおっぱいマンコにミルク入れちゃ駄目……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああっ、凄い、ぬるぬるで、熱くて……隊長さんは気持ちいいですか？　私\nのおっぱいマンコ、気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「きゃっ、やっ、あんっ、返事の代わりにおちんぽでおっぱいマンコ突かない\nで！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、分かりました、隊長さんの返事は分かりましたからっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、上下だけじゃなく、おっぱいマンコを手で動かせば、左右か\nらもしごけるんですよ、ふうっ、ううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んやっ、あっ、今は私がご奉仕してるんですから、動いちゃ駄目ですよ……\nあんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、凄い、音が……んっ、にちゅにちゅって音からぐぽぐぽって…\n…ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、んっ、これ、セックス、セックスしてる、おっぱいマンコで、隊長\nさんとセックスしてる！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「こうして、おっぱいマンコをぎゅって絞ったら、ふううっ、隊長さんのおち\nんぽも、びくびくって……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、隊長さんの腰、震えてきた……おちんぽも熱くなって……ふ\nふっ、イくんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「いいですよ、私のおっぱいマンコの中に、おっぱいミルクに、隊長さんのお\nちんぽミルク、いっぱい出して、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私のミルクと隊長さんのミルク、おっぱいマンコの中で混ぜ混ぜしてっ、び\nゅって出して！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、あああっ、イく、イく、私も隊長さんのおちんぽミルクでイくっ、\nあんっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「来た、隊長さんのおちんぽミルク、来たあっ！！　ふあっ、ああああっ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、凄い……見えなくても粘っこいって分かります……隊長さんのおち\nんぽミルク、特濃なの分かります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「熱くて……私のおっぱいマンコ、やけどしちゃいそう……んっ、残ったのも\nぴゅっぴゅって出して……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふううっ、私のパイズリご奉仕、気に入ってくださったみたいで嬉しい……\nんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんぽミルク、ごちそうさまでした……ふううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おっぱいマンコの中、どろどろになって……ふふ、これが本物のオマンコな\nら、妊娠していたかもですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私は……隊長さんとの子供なら、いつだってほしいですけど。ふふ、おっぱ\nいマンコだと今日はおあずけですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「でも、気持ちよかった……ふふ、隊長さんとおっぱいセックスできて、幸せ\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふ……あ……おちんぽがまた大きくなって……んっ、もう一回、したいんで\nすね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、いいですよ。隊長さんのおちんぽで、私のおっぱいマンコ、一杯かき\n混ぜてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おっぱいミルクと精液で濡れてるおっぱいマンコの中、ぐちゅぐちゅって、\n隊長さんの身体で……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それじゃあもう一度、おっぱいマンコでずりずりしますね……んっ、あっ、\n隊長さんのおちんぽを、ずり……ずり……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、またおっぱいミルク出てきました……んっ、もうおっぱいマンコも隊\n長さんの身体もぬるぬるですね……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、手についたおっぱいミルク飲んで……おいしいですか？　ふふ\nっ、子供みたい……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おちんぽは子供どころか大人ですけれど……やっ、あんっ、腰を動かさなく\nても分かってます、やあっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、そこで腰を動かされると、心臓をおちんぽで突かれてるみた\nい……あうっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんの、隊長さんのピストンが私の鼓動と一緒になって……はあっ、あ\nあっ、なに、なにこれえっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おっぱいマンコセックス、んんっ、気持ちいいっ、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あううっ、おっぱいミルク止まらない！！　隊長さんのピストンで止まらな\nい！！　ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さん、んんっ、あっ、ふっ、あああっ！！　隊長さんの身体、おっぱい\nマンコで締めつけてるのに、それ以上に動かれて……あううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、こうしてぎゅって絞って、ずりずりして……ふうっ、うっ、\n隊長さんの下半身が全部おちんぽになったみたい……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅっていやらしい音……それに匂いも……おっぱいミルクの甘い\n匂いとおちんぽミルクの雄の匂い……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「こんな風に使われたら、もう今度から自分のおっぱいが隊長さんのためのお\nっぱいマンコにしか思えなくなっちゃう……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、またおちんぽが硬く熱く……腰もびくびくって動いてきまし\nた。隊長さん、イくんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「いいですよ、いっぱい出して……私のおっぱいマンコ、隊長さんのおちんぽ\nミルクでいっぱいにしてください……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、ふふっ、おっぱいミルクとおちんぽミルク、まぜまぜしたら子供が\nできるかも……ふああっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、嘘、冗談、冗談ですから、そんな本気で腰振らないで！！　あんっ、\nああっ、ああっ、おっぱい、おっぱい変になっちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、ああああっ、おっぱいで、おっぱいマンコにピスンとされて、イっ\nくうううううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んあっ、あああっ、来た、隊長さんのおちんぽミルク、また来たあああああ\nあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、あふっ、あっ、二回目なのにまだ特濃……熱い……とくとくって鼓\n動に合わせてミルク出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、ああ、本当におっぱいマンコが妊娠しちゃいそう……おっぱい\nで子供産めちゃいそう……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ……凄い、おっぱいマンコの中、私と隊長さんのミルクでべと\nべとに……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、素敵でしたよおっぱいマンコセックス……隊長さんと、だからですけ\nれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ん、隊長さんの身体、おっぱいマンコの中で糸を引いてますね……ふふ、気\n持ちよかったですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私もよかったです。隊長さんのたくましい身体をおっぱいマンコで味わえた\nのですから……パイズリご奉仕、できてよかった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「また……ご奉仕したくなったら相手してもらえますか？　誠心誠意隊長さん\nを気持ちよくさせるように頑張りますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「っ！！　ふふ、返事より先に隊長さんのおちんぽが答えちゃってますね……\nあんっ、おっぱい突いちゃ駄目ですってば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それじゃあ、また今度……隊長さんから誘っていただいてもいいんですよ？\n　私なら、いつでもお応えいたしますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、やだっ、隊長さん、なんでおっぱいマンコから抜け出して……\nあっ、ああっ、あんっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「乳首、乳首駄目っ、乳首にしがみついておちんぽミルク出すの駄目っ、ああ\nあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「やあっ、ああっ、おっぱいミルクとおちんぽミルクが出てくる場所がぶつか\nって、ミルク同士もぶつかって……ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「熱っ、熱い、んっ、おちんぽミルクで乳首やけどしちゃううううううう！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあ、ああっ、おっぱいマンコのセックスだけじゃなくて、乳首セックスで\nおちんぽミルク出すなんて……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00021002_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「凄い……隊長さんのおちんぽからどくどく出てるの、直接伝わってくる……\nんっ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私のおっぱいミルクとおちんぽミルクがブレンドされてる……んっ、いやら\nしい匂い……ふああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、最後の一滴まで乳首にかけて……ふうっ、うっ……んっ、隊長さん\nのおちんぽミルク、乳首で全部ごちそうさまです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ずっとこの乳首にぶっかけてみたかった、ですって？　もう、言ってくれれ\nばいつでもオッケーでしたのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、これからはどんな場所でも、好きにかけてください。隊長さんだけの\n特権ですよ。だからまた、おっぱいマンコでセックスしましょうね、あなた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}