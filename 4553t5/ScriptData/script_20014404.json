{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「全員ニンジャになる……のはどうだろうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022970001" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「に、にんじゃ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022970001" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「演歌歌手も人気は高いが、ニンジャはそれより更に凄い。まず最強だし、海\n外からも根強い人気がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022970002" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あー、外国人ほど喜ぶっていうのはあるよな。スシ！　フジヤマ！　ゲイシ\nャ！　ニンジャ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022970001" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「テンプラ！　ハラキリ！　ニンジャニンジャ！　って、とにかく忍者は人気\nが高い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022970002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「それに、露出度も……あげようと思えばあげられる。と思う。私はそれを目\n指したことはないけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022970003" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ボウチュウジュツだとか、適度にやらしー要素もあるし。……忍者。ウケる\nんじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022970003" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「……そうだな。異界の者であるワタクシたちが着ても許されるというのであ\nれば、試してみてもいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022970002" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおお。意外に賛成意見多数か」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カグヤ・ダークの案にまとまりかけていたところで、急にルナテミス・ダーク\nがぴしゃりと言い放つ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「……ですが、却下です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970001" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「な、なぜ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022970004" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「忍者は地味です。色が地味。そして可憐さも、高貴さもありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970002" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ガ、ガーン……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022970005" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……まあ、闇で活動するニンジャが派手派手だったら困るだろうが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ニンジャ風ってことでド派手な衣装にすればいいだろう？　赤とか黄とか青\nとか緑とか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022970004" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「エレガントではございませんので却下ですっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970003" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ニンジャは……エレガントではない……？　今まで気づいていなかった……\nショックだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022970006" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「広く庶民から愛されるとなれば、貴族でしょうね。豪華なドレスで社交界は\nいかが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970004" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ？　ドレス？　それってキワドいスリットが入ってるとかそういうヤツ\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022970005" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「まさか！　全身カチカチに着込むに決まっているではありませんか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970005" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「長い手袋をはめ、大きな帽子で顔を隠し……。キツいコルセットをはめ、ス\nカートは長く」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「……ああ、そうですわね。仮面舞踏会のように仮面をつけるのもエレガント\nでしょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「……それは……いやだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022970007" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「んッ！？　な、なぜですの！　上品で一流で素晴らしいではありませんの！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970008" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「なんかヘンタイみたいだから……イヤだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022970008" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「ガーーーーンッ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970009" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お堅い、露出もないドレスなんて……それこそ貴族にしかウケないだろ。真\n面目に考えろよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022970006" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「わ、私は真面目に考えておりますけれど！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970010" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「うむ。ワタクシも、ドレスは嫌いではない……が、お堅すぎるという点には\n同意する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022970003" ]},
		{"command":[ "SETCHARA", "0", "char_00019401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「カツマ。色々な世界、様々な国の女を見てきた貴方にならあるのではないか\n？　起死回生の妙案が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022970004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あるかなあ、そんなもん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クロートー" ]},
		{"command":[ "SETTEXT", "「どこか一つの層だけではなく、広く万民に好まれる姿。できれば敷居は高く\nない方がいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_194_030022970005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａニャンコ先生" ]},
		{"command":[ "SETTEXT", "「親しみやすくて、でもパッと目を惹く目立つ服」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_030022970007" ]},
		{"command":[ "SETCHARA", "0", "char_00010003_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「それでいて、麗しく可憐でなければなりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_270022970011" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ムリナンダイで……スマヌ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_150022970009" ]},
		{"command":[ "SETCHARA", "0", "char_00000210_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待て。今何かひらめきそうだ……。そうだ、これなら！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ピーンと来た俺は、４人に自分の見た夢のことを話してみることにした。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}