{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0089" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "カツマ達が模擬戦のため、辺鄙な場所に建てられた廃業予定のホテルに着いて\n数時間後――", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……戦闘音は聞こえなくなったね。どうやら模擬戦が終わったようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100001" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「流れ弾が来なくて良かったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100001" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "何かあった時のために留守を言い渡された居残り組。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だがその中で、鳳雛とゲンナイだけはこっそりとカツマ達の後を追っていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「さて、そろそろ行こうか。分かっていると思うが、僕達は見つかる訳にはい\nかない。細心の注意を払って行動するんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100002" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まぁゲンナイくんは忍術と発明品が、僕はガスになれるから、簡単に見つか\nらないと思うけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そうだね。けど本当に尾行続けるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100002" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ゲンナイくん、今更後悔したって遅いよ。僕達はもう現場にいるんだから。\nそれに君も乗り気だったじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100004" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「それは鳳雛さんが、事件の香りがするって言うから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100003" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そう、僕の勘が告げているんだ。これから事件が起こる……とね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100005" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「まぁあの人達がいれば、確実に何かしら起こるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100004" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あれ？　まだ模擬戦終わってなかったのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100005" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふむ……しかし、その割には音が続かないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100006" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「とりあえず近づいてみよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100007" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「あ、あそこにカツマさん達がいますね。あれ？　誰か倒れているみたいです\nけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100006" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「黒い方のルナテミスだね。一体どうしたんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100008" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0089" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_012" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「これだけきれいな顔をしていると、嘘みたいに思えるだろうが……死んでい\nるんだ、これは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010106040003" ]},
	{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0089" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "鳳雛＆ゲンナイ" ]},
		{"command":[ "SETTEXT", "「えっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100009" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "-300" ]},
	{"command":[ "SETCHARA", "1", "char_00009801_01", "3", "CENTER", "300" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "不意に聞こえてきた言葉に、二人は唖然として顔を見合わせた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「今の……聞き間違いですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100008" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕も自分の耳を疑ったが……どうやら聞き間違いではないようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「鳳雛さん、行きましょう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100009" ]},
	{"command":[ "SETCHARA", "1", "char_00009801_01", "7", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「いや、今行ってはダメだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100011" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "7", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「な、何でですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100010" ]},
	{"command":[ "SETCHARA", "1", "char_00009801_01", "3", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「さっき言っただろう。僕達は見つかる訳にはいかない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「それに……今はその方が好都合だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100013" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "0", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「好都合？　どういう意味ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_021" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ゲンナイくん、君はあの黒いルナテミスが、あんな簡単に死ぬと思うかい？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100014" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「いえ、思いません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100012" ]},
	{"command":[ "SETCHARA", "1", "char_00009801_01", "0", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうだろう。さっきの爆発が何かしら関係しているだろうが、死ぬにしても\n呆気なさすぎる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「本来であれば、もっと抵抗して……それこそホテルが壊れていてもおかしく\nない。それなのに、そういった形跡もない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「つまり抵抗がなかった訳だが――その理由は、不意をつかれたか、もしくは\n抵抗する必要がなかったという事だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100017" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "8", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「……ハッ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100013" ]},
	{"command":[ "SETCHARA", "1", "char_00009801_01", "3", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふふっ、気付いたかい？　そう、抵抗する必要がなかったという事は……顔\n見知りの犯行の可能性があるという事だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「じゃあ……犯人はあの中に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100014" ]},
	{"command":[ "SETCHARA", "1", "char_00009801_01", "0", "CENTER", "300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうなるね。そして僕の勘では……おそらく犯人はルナテミスだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100019" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "-300" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
	{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0124" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "PLAYBGM", "BGM_023" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「犯人……死んでますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100015" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「なんという事だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100020" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "自分の推理が外れた事に、鳳雛は愕然として軽くよろけてしまう。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だがぶつぶつと何か呟いたかと思えば、ゲンナイを見る。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYBGM", "BGM_021" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「わかったよ。今回の殺人が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100021" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そうなんですか？　じゃあ誰が犯人なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100018" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まだ推理の途中でまとまっていないから、本当は言いたくないんだが……仕\n方ない、特別に言おう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100022" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まず……黒いルナテミスを殺したのは、やはりルナテミス……けどそのルナ\nテミスさんを殺したのは、別の犯人だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「つまり今回の事件は、連続殺人ではなく連鎖殺人です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100024" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「れ、連鎖殺人……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100019" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうさ。黒いルナテミスが死んだのを見た事がキッカケで、抑えていた殺意\nが膨れ上がってしまい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100025" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「我慢できずに、殺してしまったのさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100026" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「えー嘘でしょ？　そんな事ってあるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100020" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あるさ。彼女達も人だからね。感情に流れてしまう事は……というか、その\n方が多いからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100027" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「じゃあ犯人は一体……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100021" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「むっ……見たまえ。エファナティカが一人で動くみたいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100028" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「これは怪しいね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100022" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「よし、エファナティカを第一容疑者としよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100029" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0124" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_023" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「第一容疑者……死にましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021100023" ]},
	{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「なんという事だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021100030" ]},
	{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "二度も怪しいと思った人物が死んだ事で、鳳雛は思わず膝をついてしまった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
