{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「任務が終わったら、すぐ呼び出しだなんて……報告書なら、あとで提出をす\nる予定だけど、いったいどうしたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「何か用があるなら、早くしてちょうだい。私はさっさと、シャワーを浴びた\nくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「え？　最後の任務として、君との特別トレーニングが残ってる？　そんなの\n聞いてない……って、きゃああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「急に服を脱がして、何をする気……ひゃふっ！？　んっ、あっ！　な、なに\nっ？　熱いのが、オマンコにあたって……んくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026801_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「いったい何を擦りつけて……っ、これ、オチンポじゃない！　ど、どうい\nうこと！？　ちゃんと説明して！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「これはオマンコを鍛えるトレーニング？　隊長と一緒じゃないと、できない\nって……そんなトレーニング、聞いたことないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ふっ、んぐぅ！　あっ、ちょ……そんなに、擦りつけないでっ……オチンポ\nがオマンコに、当たって……あふっ、ひゃ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「デコボコしたところが、く、クリトリスをズリズリしてくる……こんなの、\nトレーニングじゃないわ……あっ、あっ！　んはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「えっ……このトレーニングは、オマンコにオチンポを挿れてからが、本番っ\nて……そ、それはトレーニングじゃなくて、セックスじゃないの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「セックスもトレーニングも、そんなに差はないだなんて……そんなワケ、な\nいっ……あっ！　やっ、あぁ！　擦れる感じが、強くなってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「激しくスリスリされたら、オマンコ感じちゃうっ……気持ちよくなって、エ\nッチな汁が出てきちゃうからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「やっ、あっ！？　オチンポの先端が、割れ目のところに当たってる……それ\n、入っちゃう……セックスになっちゃうからぁ！　あっ、あっ、あぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁっ！？　オチンポがオマンコに、入ってきてるぅ！　ヘソの下あ\nたりまで、カタいのが届いてきて……ひぐっ、あっ！　んぐふぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あっあっ、ひゃ、んはぁっ！？　お、奥をトントンしないで！　そんなこと\nされたら、オマンコ感じて……ひふぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「うぐっ、あっ、あっ！　ひゃ、ひぎぃっ！　オマンコが勝手に締まるぅ！　\n全身が気持ちよくなって、身体がビクビクってするわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「こんなの、本当にただのセックスじゃ……はひぃっ！？　あっ、あっ！　や\nめっ、んんっ！　子宮口をグリグリしちゃダメぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁぁっ！　感じすぎて、汗がたくさん浮かんでくるっ……任務終わ\nりで、ものすごく汗臭いのに……もっと、におってきちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「って、ちょ、ちょっと！？　なんでそんなに鼻息を荒くしているの！？　ま\n、まさか……私の汗のにおいを嗅いでたりしないわよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「スーツの中が蒸れてて、すごくいいにおいがするって……そんなはずないで\nしょう！　絶対臭いからっ！　お願いだから、もう嗅いだりしないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あっ、んひっ！？　ぐっ、んぐぅぅっ！？　オ、オチンポが、さらに大きく\nなってる！？　なんで、急に……はひぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「汗のにおいを嗅いでいたら、もっと興奮してきたって……なんで汗のにおい\nで大きくなるの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「こんな香りで興奮するなんて、変態もいいところだわ！　あっ、あっ！　ん\nふっ、あぁぁっ！　もっと激しく、ズンズンってされてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「くうぅ……こんな変態に犯されて、私も気持ちよくなってるっ……オマンコ\n、感じちゃうっ……あっ、やっ！　ひゃ、あひぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「だ、ダメっ！　オマンコの浅いところをスリスリしないでっ！　奥もいいけ\nど、そこも感じるからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あひゃあぁぁんっ！？　あっ、んっ、あっ！　そんな小刻みに、何度も擦ら\nれたら……また、汗がいっぱい出て……はぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「気持ちよくて、身体の火照りが治まらないわ！　背筋がゾクゾクする！　汗\nでスーツの中が、蒸れて仕方ないのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ひゃぐっ、ふっ！　あっ、ひぐっ、んっくぅ！　また、奥にオチンポがきて\nぇっ！？　はぁ、ああっ！　汗もエッチな汁も、止まらないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ふっ、んんっ！　ぐぐっ、んはぁっ！　自分でも分かるくらい、いやらしい\nにおいがしてるっ……こんなの嗅いでたら、頭がおかしくなる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「お願い……せめて、もう少しゆっくり動いて……んひぃっ！？　み、耳元で\n汗のにおいを嗅がないでぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「隊長の鼻息が当たって、ヘンな気持ちがもっと強くなってくるっ……はぁ、\nああぁっ！　オマンコの奥が、ズキズキしてくるわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、んくぅぅっ！　な、なにこれ……ヘソの下のところから、熱\nいのがこみ上げてきて……んひゅっ、あっくぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「オマンコだけじゃなくて、全身もガクガクって震えてきて……こんなの、知\nらないっ……ひゃ、あひっ！　あっあっ！　んっ、はぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃんっ！？　オチンポの動きが、急に速くなってるぅ！？　オマン\nコの入口から奥まで、一気にズリズリされてるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　そんなに激しくされたら、ヘンなのが溢れちゃう！　オマン\nコから、気持ちいいの出てきちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「おっ、おっ！　んぎひぃっ！　くるっ！　くるぅ！　気持ちいいの、すぐそ\nこまで来て……あっ、あっ！　あっはぁぁぁぁんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あぁぁぁーーーっ！？　気持ちいいの、オマンコから出てるぅ！　それに、\n熱くてドロドロした液体も、オマンコに出て……はひぃぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「なにっ！？　いったい、何が出ているの！？　もしかして、私のオマンコに\n、射精しているとでもいうの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「おっ、おほっ！　んひょおぉっ！？　熱いの止まらないわっ！　びゅーびゅ\nー勢いよく、奥に注がれて……うぐぐっ、おごっ、んっひょぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ほひっ、ふひぃっ！　オマンコ気持ちいいっ！　隊長の精子を浴びるの、す\nっごく感じるぅ！　あっ、あっ！　こんなの、またヘンなの出ちゃう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「またくるっ！　気持ちいいの、奥から溢れてきてるっ……はぎひぃっ！　ほ\nっ、おっ！　おっ！　おっほぉぉぉぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……今のはいったい……んっ、なるほど……さっきのが、絶頂\nというものなのね……確か、本でそんな名前を見たことがあるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「別の言い方をすると、イク、だったかしら……今のが、オマンコでイクとい\nう感覚……ええ、はっきりと覚えさせてもらったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「それにしても、これがトレーニングだなんて……ウソついたわね、隊長。こ\nれは誰がどう見ても、セックスだと思うのだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「別に騙してないって……いいわ。そういうことにしておいてあげる……でも\n、私はまだ、このトレーニングに満足していないわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「身体の火照りが全然治まらないの……私が満足するまで、とことん付き合っ\nてもらうから、覚悟しなさい……んっ、はっ、あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んっ、んっ！　ふっ、んんっ！　さっきは、隊長の好きにされたから……今\n度は私から、動かせてもらうわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「こんなふうに、前後に大きく腰を振って……オマンコをぎゅーって締め付け\nながら、ズリズリ擦りまくれば……あぐっ、ふっ！　んぐぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「おっ、おふっ！　くっ、んくぅ～！　奥の気持ちいいところに、カタいのが\n当たってくるっ！　ここを突くの、好きかもっ……あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「浅いところも好きだけど……やっぱり、こっちの方が気持ちいいわ！　んっ\n、ふっ！　はぁ、あっ！　おっ、おっ！　おひぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んんんっ！　さっき出された精液が、身体の奥に染みわたってくるぅ……お\n腹の中に、どんどん溜まってきて……ひゃふっ、はぁ、あひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「これ、いったいどうなって……んふぅっ！　はぁ、はぁ……な、なるほど。\nこれが、子宮に精子を注ぐという感覚なのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あれ……確か本だと、子宮に精子を注ぐと、赤ちゃんが出来るって書いてあ\nったような……ひぎっ！？　あっあっあっ！？　おっ、んおぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ふんぎぃっ！？　ま、またオチンポが大きくなってぇっ！？　それに、どう\nして隊長まで激しく動いて……おごっ、ほっ！　んほっ、ほひぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「わ、私との赤ちゃんを想像したら、興奮して腰が止まらなくなったって……\nんんっ！　また、ヘンなことを言って……あひっ、あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「や、やめっ！　んぅ、ぐぐっ、ほっ、おぉぉっ！？　そんなに奥をズンズン\nされたら、精子が奥の奥まで入ってきちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「隊長との赤ちゃんだなんて……あぁぁぁっ！　想像したら、私も興奮してき\nたぁ！　また、汗がどんどん出てきて……あっ、あっ！　んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ダ、ダメぇ！　私の汗のにおい、嗅がないで！　そんなに鼻息を荒くされた\nら……その吐息で、また感じて……んふぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、おっ、おぉっ！　オマンコをズポズポされながら、においを嗅\nがれると……気持ちいいのが、奥から来てっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「これ、絶頂しちゃうっ！　イクッ！　イッちゃうのぉ！　隊長のオチンポで\n、イカされるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んっ、おふっ、おっほぉぉっ！　イクッ！　イクイクッ！　\nオチンポでイクッ……イッ、あっ……あっはぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		
		{"command":[ "LABEL", "LABEL1" ]},	
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んぎひぃぃぃっ！？　おっ、おっ！　おぉぉ～～～！？　また熱いの、びゅ\nーびゅーオマンコに出されてるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ドロドロの精子が、子宮に流れ込んできて……あぁぁっ！　オマンコをズリ\nズリされるより、感じるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「こんなの、射精でイクッ！　精子注がれながら、イッちゃうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　イッてる最中なのに、イクッ！　オマンコイクぅぅっ！　あ\nっ、おっ！　んおっ、おほぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「ひっ、んくっ！　くっ、あっ……あっ！　あっ！　あっひぃぃぃぃんっ！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「はぁー、はぁぁぁー……すごいわ……こんな感覚、はじめてっ……気持ちよ\nすぎて、腰が勝手に震えちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「お腹の中も、隊長の精子でいっぱいにされて……んっ、あふっ……本当に、\n赤ちゃんが出来ちゃいそうだわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「えっ……これはトレーニングだから、妊娠しないと思う？　ふふっ……そう\nだったわね。これは、特別トレーニングだったわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「確か、オマンコを鍛えるトレーニングだったかしら……なら、赤ちゃんが出\n来ることはなさそうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「それにしても、この特訓はすごく素敵だったわ……またいつか、お願いしよ\nうかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「おっほぉぉっ！？　オチンポがオマンコから抜けてっ……ひっ！？　んぎっ\n！　はひぃぃぃんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「身体に熱いのがかかってるぅ！？　それに、すごいにおいもして……んっ、\nはぁぁっ！　汗よりもキツい香りがするぅ！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「嗅いでたら、頭がおかしくなりそうなのに……な、なんで……ずっと嗅いで\nいたいと、思えて来るっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、んっ！　ふっ、んふぅ！　あっ、あっ！　嗅いでるだけで、気\n持ちよくなって……はひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「あっ、イクッ！　オマンコイクッ！　熱いのかけられながら、においでイッ\nちゃうぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「んっ……はふっ……はぁ、んくぅ……私のスーツのにおいも大概だけど……\n隊長の精子のにおいも、相当なものね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00026801_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「これをずっと嗅いでいたら、本当におかしくなってしまいそうだわ……早く\nシャワーを浴びさせてちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「シャワーを浴びるなら、一緒に浴びたい？　い、いや、さすがにそれは……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「トレーニングの続きもできるからって……な、なるほど。それは悪くない考\nえだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_0104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "昴" ]},
		{"command":[ "SETTEXT", "「それじゃあ、一緒にシャワーを浴びましょうか……そこで、トレーニングの\n続きをしましょう……」", "NORMAL" ]},
