		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「皆さん、賑やかにされて、大変素敵なお祭りでしたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503101" ]},
		{"command":[ "SETCHARA", "0", "char_00003005_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、私もとても楽しい時間を過ごさせて頂きました。皆さんの笑顔を見て\nいるだけで、幸せな気持ちになりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「それで……この後に、まだ続きがあると伺いましたが……一体どのようなこ\nとを……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503103" ]},
		{"command":[ "SETCHARA", "0", "char_00003005_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「えぇと……こちらの方へ？　はい……承知いたしました。ええと……裏手の\n方ですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「この高揚感を……そのまま、男女の営みに繋げていく……それが、祭りのも\nう一つの目的なのですか……なるほど、勉強になります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503105" ]},
		{"command":[ "SETCHARA", "0", "char_00003005_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、ここでしたら……他の方々がいらっしゃることはありません。あぁ…\n…確かに、貴方のオチ〇ポもこんなに勃起されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00003005_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「これをお鎮めするのが私のお役目ということになりますね。分かりました…\n…私のおっぱいで……オチ〇ポをお扱きさせていただきますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……では早速ですが……んっ、間に挟ませて頂きます……あ、ふ\nっ……んくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……熱いです。ビクビクと隆起なさって……あぁ……とても男らしい…\n…雄々しいオチ〇ポですわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んんっ……くふぅ……んっ、まずはしっかりと包み込んで……柔らかく回し\nて参ります……んんっ、あふ……いかが、でしょうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「気持ちいいですか……ふふ、喜んで頂けると、私としてもやりがいがありま\nすわ……んっ、はぁっ、んふっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「まず縦に……柔らかく動かして……皮の部分を丁寧に捲り返して参ります…\n…んっ……はぁっ、んっ、ぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「この付け根の場所……敏感なのですよね……？　はい……この反応で、察す\nることが出来ますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「集中的に扱くことで……お互いの気持ちを高めあっていく……とても素敵で\nす……あっ、く……んぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「続けて……横から……ぎゅっと……おっぱいを押し付けて……オチ〇ポを包\nみ込んで参ります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……あぁ、確かに……私も高揚していたのだと気づきました……は\nぁ……んっ、あっ、んぁっ、あふっ……ぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ぎゅっと押しつぶすようにして……おっぱいを重ねて……動かしていくと…\n…先端が痺れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……この感覚は、もうすぐです……あっ……挟み込んで刺激していくと\n……乳首がんっ、痺れて……あふっ……もうすぐ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……出てしまいます……母乳がっ……あふっ、んっ、あっ、あぁっ……\n！　んっ、はぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503119" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「お恥ずかしいです……ですが、これで……また滑りやすい形で……パイズリ\nご奉仕が出来ますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……母乳をしっかりと乳房全体になじませて……ヌルヌルにぃ…\n…はぁっ、くふぅぅっ……んんっ……あっ、うんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっと身体を大きく使って……これで……いかがでしょうか……？　んっ、\nふっ……あっ……はだけた浴衣が色っぽい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ……ありがとうございます……自分では実感出来ませんが……この浴\n衣は、とても気に入っておりますの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ですから、あまり汚さないように……もう少し広げて……んっ、よく見えま\nすか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……母乳パイズリ……お楽しみ下さい……あっ、んくっ、はぁっ、あぁ\n……んっ、あぁ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「この、逞しいオチ〇ポを……んっ、ふっ……丁寧に擦り上げて……あっ、く\nちゅくちゅ……鳴り始めました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、この音を聞くと……どうしても、穏やかではいられなくなって\nしまいます……身体の芯が熱くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ……もっと押し付けて参りますね……こうして、はっ、んふっ\n、あぁっ、んっ……はっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ……おっぱいがいやらしくひしゃげて……あぁ、オチ〇ポも亀頭があち\nらこちらに動いて……じっと見てしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふっ……んっ、あぁ……鈴口から、先走りが浮いて来ました……ご様子は\nいかがですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「射精も……そろそろですよね……はい、先端が膨らんでいるので分かります\n……あの、お口で失礼致します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁんむ……ちゅぽっ、んくぷっ、ちゅぷっ……オチ〇ポ……咥えひゃへて\nいたらきまひた……ふぁい、このまま……続けて致します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503132" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、んっ、ちゅぷっ……んふっ、あぁ……ほのかな塩味が致します…\n…れる、先走り……どんどん濃くなっております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「れる……んりゅっ、もっと大きな動きで……しっかりオチ〇ポ気持ちよくな\nって頂いて……んじゅぷっ、んはぁぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「らひて……ふぁい……飲ませて下さい……んっ、貴方の濃厚な精液……直接\n……お口に出して下さいませ……んりゅっ、ちゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅっ……！　んぶっ、んっ……んんんんんんっ……！　こくっ、ん\nっ、んっふ……んくっ、んくんっ、んふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぱ……あぁ、どろりとした感触が口の中に残って……ちゅぷ\nっ……とても美味しいですわ……れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「まだ、もう一絞り出そうですわね……んちゅるっ……んちゅぅぅ……吸い出\nしてしまいますから……ちゅぷっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ふはっ……はぁ……んっ、んふ……はい、一旦落ち着かれたみたいですわね\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503139" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「それにしても、お祭りの後にこのような習わしがあるなんて……先人の皆様\nも色々とお考えがあるのですね……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……あ……それでは、後始末をさせていただきますね。オチ〇ポ、引\nき続き失礼致します……んっ、ちゅぽぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ん、りゅっ……くちゅぷっ……ぴちゃ、んちゅ、れろ……ちゅぷるっ……ん\nっちゅぅぅ……れる……んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……まだヌルヌルがこんなに……んっ、えろ……れろ、んちゅぽ……く\nぷ、ちゅぷ……ぴちゃ、んちゅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふ……あぁ、ピクンとしています……出したばかりですから敏感ですよね\n？　優しくなるように気をつけますね……ちゅぱ、んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「この辺り……お好きですか？　ふふ……良かったです……ちゅぱ……中々落\nち着く場所ではありませんが……楽にして頂ければ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503205" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「れろ、あら……んちゅぷ……お掃除のつもりでしたが……また、グッとオチ\n〇ポが反り返って……逞しくなってしまいましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「まだ奥にも残っていらっしゃるようですし……おっぱい……パイズリの方も\n続けさせていただいてもよろしいでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「承知いたしました。それでは……あっ、んふっ……んっ、んんっ……はぁ、\nんっ……は……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「虫の声が聞こえて来ますね……このような場所で……大胆にご奉仕をするこ\nと……どうしても、心が乱れます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ですが、んっ……貴方の気持ちよさそうなお顔を見ていると……私も、もっ\nともっとして差し上げたいと……自然に思うのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どうか、私のおっぱいと……お口で……オチ〇ポ……感じて……また、たっ\nぷりと射精なさって下さい……は、ぁんむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「くぽっ、ちゅぷっ、りゅぷっ、じゅぷっ、んふぅぅ……はぁ……んっ、口か\nら……涎が垂れてしまいまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、それも……おっぱいに絡めて……まとわりつかせて……滑りをよくさ\nせて……んふぁ……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……乳首……痛いほどにしこっております……オチ〇ポと重ねると……\n強く痺れて……あひぁっ……はい、感じております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「こうして……しっかりオチ〇ポを包み込んでいると……心臓の鼓動が高鳴っ\nて……火照りが強くなって……あぁ、気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「今、この瞬間……同じように身体を重ねてる方々もいらっしゃるのですね…\n…あぁ……その中で貴方にご奉仕できるのは嬉しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「おっぱいの中で、強く脈打っている……このオチ〇ポ……あぁ、また……震\nえが強くなって来ましたね……ちゅぷ、ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぷっ……ちゅぷ……また出して下さい……私のおっぱい……隅々まで感じ\nて頂いて……んりゅっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……はい……どのように出して下さっても大丈夫です……お口\nでも……お顔でも……おっぱいでも……お好きな所にっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「りゅぱっ、んんっ……熱くて濃厚な……精液……ザーメンミルクっ……はぁ\nっ、いっぱい出して下さいませぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「口の中に……ふぁいっ……お願いいたひまふっ……どぷって……くらひゃい\n……んじゅるっ、んちゅぅぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ふぶっ……！　んんっ、ふぐっ……んんっ、んっ、こくっ、んっ……んふぅ\nっ、んくっ、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……２回目でも……とっても濃くて……んっ、一度に飲みきれない位で\nす……こくっ、んっ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んはっ……けふっ、失礼しました……喉に残って……ですが、とても美味し\nいですわ……ぴちゃ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……ちゅぱっ……全部出ましたか……？　はい、続けてのお射精\n……本当にお疲れさまでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「お待ち下さいね……改めて、お掃除をさせていただきますので……ぴちゃ、\nれろ……んれる……れろ、ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「また勃起されるかもしれませんか……？　くすっ、その時は改めてお鎮め致\nしますので……どうか、そのまま楽になさって下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅ……ちゅぷぅ……んっ、れろ……はい、おしまいです……\n大丈夫でしたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、本日は賑やかなお祭りの本番と……その後の男女の営みまで経験させ\nて頂いて……とても素晴らしいひとときを過ごせました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ありがとうございます……はい、またご一緒できる機会がございましたら、\nぜひ……お願い致します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「顔に……ふぁいっ……びゅくびゅくっ、出して……くらひゃい……んぱっ、\nあっ、んはぁぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぷっ……んぁっ、はぁぁぁ……熱い精液っ……顔に掛けてっ……頂いてま\nすぅっ……んぁっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003005_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……べっとり……ぬめって……熱くて糸を引いているのが……はぁぁ…\n…いっぱいにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……んっ、えろ……あぁ……お行儀が悪くて申し訳ありません……\nんちゅぷっ、口の周りの精液を味わわせて頂いております……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「れろ……美味しいです……もう少しだけ出そうですか……？　はい、残さず\n出して頂ければ……ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んはっ……終わりましたか。はい、お疲れさまでした……もう一度、お掃除\n致しますね……れろ……んりゅ、ぺろ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、お疲れでしょうから、今度は優しく……ちゅぷ……本当に少しずつで\n……れろ、ぺろ……んっ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱ……これで綺麗になったと思います。んはっ……れろ……少し\nオチ〇ポは硬いままですがご辛抱下さいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「本日は楽しいお祭りに連れて行って下さった上、その後の男女の営みまで経\n験させて頂いて、本当にありがとうございました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、ぜひまたご一緒出来れば、私も嬉しく思います。貴方と、そんなひと\nときが過ごせることを……今から楽しみにしておりますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0503410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
