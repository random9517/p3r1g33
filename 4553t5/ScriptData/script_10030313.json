{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「いらっしゃ～い。あら、大勢で来てくれたのね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070001" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「どもっす～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010115070001" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「と、いうわけで我々は、地球独自の文化『スナック』を体験するため、この\nお店に潜入することになりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010115070001" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら？　もしかして取材かしら？　最近、酒場紹介番組とかよくあるも\nのね～。うちのお店も有名になっちゃうかしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070002" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「いや、その……それはどうかなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040115070001" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「今日は、地球の社会勉強だし～。ウチ、ここの席に座るね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010115070001" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あー！　待って待って～？　そこは常連さんの『いつもの』席なのよ～。み\nなさん、こちらに座ってちょうだいね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070003" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「へえ？　常連さん用の席なんて決まってるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010115070002" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、人によるんだけどね～？　いつも同じ席じゃないと気がすまない\nって人がいるのよね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070004" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「へえ、そんなお客さんもいるんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010115070002" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「まあ、ウチのお店にはいないけどね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070005" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「は！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010115070002" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「そもそも、常連さんもまだいないわ～？　うふふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070006" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「じゃあ、なんで席開けさせたし！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010115070003" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「そういう常連さんが、いずれできるかもしれないでしょ～？　その時のため\nよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070007" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「いや、あのな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040115070002" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「さすが長い歴史を誇る地球の文化遺産、『スナック』です。奥が深い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010115070003" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「深いか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040115070003" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「まあまあ、そんなことはおいといて、皆さん水割りでいいかしら～？　それ\nともおビ～ル～？　ガソリン～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070008" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「いや、ガソリンはないでしょ！　Ｍ.Ａ.Ｍ.Ａじゃないんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040115070004" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あらあら、そうだったわね～。それはそうと、カラオケもあるのよ～？、一\n曲どうかしら～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070009" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「あ！　カラオケは知ってる！　行ったことあるよ！　Ｍ.Ａ.Ｍ.Ａ、曲入\nれるからリモコン貸して～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010115070004" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「リモコン？　ないわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070010" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「カラオケなのに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010115070005" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「カラオケよ？　だから、曲をこの本から選んで、番号をこの紙に書いてね～\n？　そしたら、Ｍ.Ａ.Ｍ.Ａがディスクを入れてあげる～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070011" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「ディスク？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010115070006" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「ネット配信じゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010115070003" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ネットって～？　カラオケと言えば、このでっかいディスクよね～？　未来\nのハイテク映像記録装置よ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070012" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「知らねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010115070004" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「この分だとたぶん、あーしの歌いたい曲とか入ってなさげ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010115070007" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ほらほら、皆さん。そんなに緊張しないで。気楽に飲んで、歌って～？　ス\nナックは、気軽にリラックスして楽しむところなんだから～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070013" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「は、はあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040115070005" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「それじゃ最初は、Ｍ.Ａ.Ｍ.Ａから歌っちゃおうかしら～？　ふふふふふ\nっ、行くわよぉ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070014" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「こうして我々は、深夜までＭ.Ａ.Ｍ.Ａから地球の文化、『スナック』に\nついて講義を受けることになったのでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010115070004" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｃ" ]},
		{"command":[ "SETTEXT", "「って、そのナレーション、まだ早くな～い？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_228_010115070008" ]},
		{"command":[ "SETCHARA", "0", "char_00022801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ｂ" ]},
		{"command":[ "SETTEXT", "「だって、どうせそうなるでしょ？　この分だと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_227_010115070005" ]},
		{"command":[ "SETCHARA", "0", "char_00022701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "人型襲来者Ａ" ]},
		{"command":[ "SETTEXT", "「っていうか……Ｍ.Ａ.Ｍ.Ａも実はスナックのことよくわかってないんじ\nゃねえかなぁ……ロボだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_226_010115070005" ]},
		{"command":[ "SETCHARA", "0", "char_00022601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルミナス" ]},
		{"command":[ "SETTEXT", "「まぁ……とりあえず飲むかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_040115070006" ]},
		{"command":[ "SETCHARA", "0", "char_00015604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ああ理不尽鬼子母神～♪　ああ、それでもかんばろぉ～～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010115070015" ]},
		{"command":[ "SETCHARA", "0", "char_00021202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}