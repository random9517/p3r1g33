{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ったく！　ひでえ目にあったぜ！　どうなってんだよ、最近の駅前通り！　\n客引き同士のケンカに客が巻き込まれるって、どういうことだよ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ、怪我がなくてよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、カグヤと一緒で助かったぜ。ありがとな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「う、ううん、そんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010109030002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カグヤのおかげでどうやら逃げ出せたが、最近あのあたり、ガラが悪くなりす\nぎじゃねえか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「やれやれ。これも、九姉妹（ナインシスターズ）の内紛のせいかねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010109030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「内紛ったって飲み会をどこでやるか、って話だろ！？　ちゃっちゃと決着つ\nけてくれねえと、こっちはいい迷惑だぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そういうわけにもいかないのですよ。大きな悪の組織同士の、面子と意地の\n問題になってしまってますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010109030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「めんどくせぇなぁ……っていうか、九姉妹（ナインシスターズ）がゴタゴタ\nやってちゃ、ＥＤＯの仕事にも差し支えるんじゃないですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……まあ、その可能性は否定できないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109030001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じゃ、どうにかしなきゃマズいんじゃないすか？　長官から、なにかこう、\n仲介とか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「今回のことはあくまでも九姉妹（ナインシスターズ）内部のことだからなぁ\n……ＥＤＯから、無暗に口を出すわけにはいかんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109030002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうなんですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「九姉妹（ナインシスターズ）との協定でな。そういうことになっている。ま\nあ、加入している組織からの仲介要請でもあれば話は別だが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109030003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……そういう仕組みなんですか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そういうことだ。だがな、そんなことより問題なのは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109030004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「問題なのは？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「『正義（まさよし）』だよ！　『正義（まさよし）』の休業問題！　あそこ\nが当分休みとなると、私は毎晩、どこに飲みに行ったらいいんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109030005" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、どこでも好きな店に行ってくださいよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「あそこの煮込みと串焼きがいちばん美味いんだよぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109030006" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そう言われてもねえ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「私ら美味いつまみ食ってよ、美味い酒飲むために働いてるんじゃないの！？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109030007" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「知るか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0140" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETNAME", "テロップ" ]},
		{"command":[ "SETTEXT", "「Ｘ月◎日　Ω組事務所」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_999_980109030001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「頼む、組長さん！　店のことはあたしがなんとかする。してみせる！　だか\nら、どうにか親睦会は正義（まさよし）で……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「そう言われましてもねえ。マスターが退院できないことにはねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109030001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「大丈夫だ！　あたしだって、店でただ酒やつまみを運んでただけじゃねえ！\n　厨房だって手伝ってたんだ！　マスターに負けねえ料理は出せる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109030002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「ほむらは焦っていた。当てにしていた正義（まさよし）のボーナスが出なけ\nれば、来月分のたばこ代、酒代、おやつ代を捻出できないことになる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109030001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「そればかりか、家賃を払えずアパートを追い出されることにもなりかねない\nのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109030002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そりゃ正義（まさよし）はイモかもしれねぇがよ、他の飲み屋の風下に立っ\nたことは、いっぺんもありゃしねえんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「それを疑っているわけじゃあござんせんよ。でもねえ、こちらにはこちらの\n問題がありまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109030003" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……どうしてもか？　どうしてもダメだってのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「申し訳ございません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109030004" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0076" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「くっ……！　そんなにか！　そんなにあの、鳥Ω（オメガ）に儲けさせてえ\nのかよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「……儲けだけが目的じゃあありませんよ。この世界、同業者に舐められちゃ\nおしまいですからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109030005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……他の組織に勝つのが目的ってことか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「その通り。お料理の質、お酒の種類、お客様へのきめ細かいサービス、そし\nて従業員の皆さんへの公正で手厚い待遇……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109030006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「どれをとっても鳥Ω（オメガ）が一番だと、他の組織に見せつけて、圧倒し\nてやらなきゃならないんですよ！　悪の組織としての誇りにかけてね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109030007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0077" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あんたら悪の組織なのか、居酒屋チェーンなのかはっきりしろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「表の事業も、裏の稼業も、どちらも大事ですからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109030008" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0076" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そうかい……そうかいそうかい！　じゃあもういい！　頼まねえよ！　あた\nしはあたしで、勝手にやらせてもらう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0140" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ちょいとお待ち！　どこへ行くつもりだい、ほむらさんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109030009" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「言ったろ！　あたしはあたしで、勝手にやらせてもらう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「今まで世話になったことには礼を言わせてもらうが……あんたとはこれっき\nりだ。悪く思うなよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ａ" ]},
		{"command":[ "SETTEXT", "「てめぇ！　今まで姐さんにあんだけ世話になっときながら！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ｂ" ]},
		{"command":[ "SETTEXT", "「戦隊を追い出されたてめぇを拾ってくれたのは、誰だと思ってやがんでぇ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うるせぇなぁ……チンピラどもが。そこどきな。どうしてもどかねえってん\nなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「当分飯も食えねえようにしてやろうか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109030012" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}