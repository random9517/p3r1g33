{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "001_0603101" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「まったく。こんな部屋に、一国の姫である私を呼びつけるなんて……誰かに \n見られたら、変な誤解をされてしまうじゃない！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "2", "CENTER", "0" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603102" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……え？　どんな誤解って……だから、それは、ほら……つまり、そういう \n…………そ、そんなことは、どうだっていいのよ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603103" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「それより、一体何の用なの？　まぁ、どうせあなたのことだし、またナニか \nイヤらしいことを企んでるんでしょうけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603104" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……はぁ？　アシコキ？　なんだかよくわからないけど、なぜ姫である私が \n、あなたごときにそんなことをしなくてはならないの？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603105" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……地球の女の子たちは、みんなアシコキをシてるの？　むしろ女子校生の \n嗜み？　ふ、ふぅん、そう……べ、べつに興味なんてないわよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603106" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「で、でも、そうね。あなたがど～してもって言うのなら、そのアシコキとや \nらを教わってあげないこともないわ。……それで、どうすればいいのよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000106_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_0603107" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「な、なんなのよコレは！？　これが、足コキ……！？　男の人のチ、チン… \n…アレを、こんな、足でだなんて……ハレンチな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603108" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「しかも、こんな、はしたない格好で……！　くぅぅっ、スカートの中とか、 \n色んなところが見えちゃってるじゃない！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603109" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「本当に、地球の女子校生たちはみんな、こんなことをシてるの……？　パパ \nにお小遣いをもらうために？　くっ、親子でこんな……ふしだらだわ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603110" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ウソでしょ！？　つきみや、まりあさんまで……？　ていうか、なんであな \nたがそんなことを知ってるのよ！　ちょっと、コッチを見なさい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603111" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「くっ……わかったわよ。やればいいんでしょ、やれば！　パーフェクトな私 \nに、二言などないわ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603112" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「コレを足で挟んだまま、上下に動かすのよね……くぅぅっ、足の裏に、変な \n感触が……固くて、ナマあたたかくて……キモチワルイ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603113" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……ちょっと、どこを見てるのよ！　だらしない顔をして、アレをますます \n大っきくさせて……このヘンタイ！　イヤラシイ目でこっちを見ないで！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603114" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私だって、少しは知っているんだから。男の人は、興奮するとココを大きく \nして、キモチよくなると、先っぽから精子を出すのでしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603115" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私のはしたない姿を見て……足でこんなふうにされて悦ぶなんて……男って \nサイテイね……醜くて、臭くて、汚くて……キモチワルイ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603116" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ど、どうしてアレをビクビクさせてるのよ！？　罵られて感じるなんて…… \nあなたって、本当にどうしようもないヘンタイね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603117" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「男としてのプライドはないの？　こんな、年下の女子校生に足でイジメられ \nながら、罵倒されて悦ぶなんて……恥を知りなさい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603118" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「くっ、またココをこんなに固くして……あなたは人としてサイテイのクズだ \nわ！　キモチワルイ……そう、キモイわ！　キモイ、キモイ、キモイっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603119" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ひぃっ！？　また大っきくなってきた……！？　こんなことで興奮するなん \nて、信じられない……理解不能よ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603120" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「こんな……オ、オチンポを、ビクビクと震わせて……はぁ、はぁ……そんな \nに、私の足の裏がキモチイイの……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603121" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「まったく、どうしようもないヘンタイね……！　こうやって、足の裏で挟ま \nれて、棒のところをゴシゴシされるのが好きなんでしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603122" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「この出っ張りのところとか、どうかしら？　段差に指を引っ掛けながら、足 \nの裏をこすり合わせるみたいに、ぐりぐり、ぐりぐり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603123" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ……先っぽから何か、透明なお汁が……これが、カウパー汁……？　ふ \nぅん、気持ちいいと出るの、そう……まったく、汚らしい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603124" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「このイヤらしいお汁と一緒に、先っぽの亀頭？　ここをネチャネチャと擦っ \nてあげるわ……！　ここは特に敏感なんでしょう？　ふんっ、どう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603125" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あぁ、ブサイクな顔をして……足でされるのが、そんなにイイの……？　は \nぁ、はぁ……男って、ホントに醜くて、臭くって、汚くって、キモいわね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603126" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「は、はぁ！？　この私が、こんなヘンタイ行為で、興奮するわけないでしょ \n！　こんな、足でオチンポをシゴいて、興奮するなんて、そんなこと……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603127" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「そ、そういうあなたこそ！　オチンポがまた大っきくなってきたわよ！　先 \nっぽがパンパンにふくらんで、みっともなくピクピク震えてるじゃない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603128" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「もうイってしまいそうなんでしょ？　いいわよ、ほら、さっさとイってしま \nいなさい……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603129" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「一国の姫である私に、オチンポを足で挟んで、ごしごしとシゴかれて、臭く \nて汚い精液を、お漏らししちゃいなさい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603130" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ほら、ほらぁっ、年下の女子校生にオチンポを足コキされて、みっともなく \n射精しなさい！　ほら、イけ、イきなさい、イけ、イけ、イけっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000106_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "001_0603131" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ひゃあああっ！？　な、なにっ！？　きゃっ、オチンポから、白い液体が、 \nびゅくびゅくって……！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000106_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603132" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「やぁっ！？　熱くて、ネバネバした精液が……ひゃあっ！？　先っぽの割れ \n目から、どんどん飛び出して……イヤぁっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603133" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、またっ……！？　ひゃあっ！？　臭いのがいっぱい飛んで、 \n私の身体にぃっ……！　いやっ、ダメぇっ、かけないでぇっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603134" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「イヤぁっ、制服にもかかっちゃってる……白くて、ドロドロしたのが……イ \nヤぁっ……ニオイが染み付いて、取れなくなっちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603135" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「こんな制服で学園に行ったら……はぁぁっ、みんなに、バレちゃう……私が \nハレンチなことをしたって……みんなに知られてしまうわ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603136" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「つきみや、まりあさんにまで……私が、あなたのオチンポを足コキして、精 \n液をピュッピュさせたって、知られちゃう……やぁんっ、またぁっ……！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000106_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603137" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁぁっ、エッチな精液が、いっぱい……私の足がドロドロ \nに汚れて……イヤぁ、制服にも、こんなにたっぷり……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603138" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「……ふんっ、そんな見え透いたご機嫌取りで、この私が喜ぶものですか…… \n私の足コキが上手だったから、こんなにたくさん出たなんて、そんな……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000106_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603139" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「で、でもまぁ、しかたないわね。あなたがどうしてもって言うのなら、また \nシてあげないこともないわ……光栄に思いなさい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0603140" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「私の華麗なテクニックで、またあなたのオチンポをたくさん射精させてあげ \nるわ。……だって、足コキは女子校生の嗜みなんでしょう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}