{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「失礼します、隊長殿。拙者をお呼びとお伺いしましたが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103101" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00013701_01", "0", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んな！？　い、いきなり一物をとりだして舐めろとは、どういうことですか\n隊長殿！？　セクハラで訴えますよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00013701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「え？　……な、なるほど、パワーアップのためですか。そういえば隊長殿に\nは、そんな能力がありましたね。うっかり忘れていました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ですが……拙者、命令されたり何かを強制されるのは、あまり好きではあり\nません。以前いた暗殺集団では、いろんな無茶ぶりをされましたからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103104" ]},
		{"command":[ "SETCHARA", "0", "char_00013701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ですから、そうやって男根をしゃぶれと命令されても、興が乗らないという\nか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「むっ！　ですから何度命令されても、むしろ命令されればされるほど嫌にな\nると申しているのです。そんな、隊長殿の男根を……だ、男根を……ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103106" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「つ、つばなど飲み込んでません！　今言ったように、拙者、命令されるのは\n嫌いなのですから。ましてや、こんなエッチな命令……エッチな、命令……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「男根を、舐めろだなんて。この、たくましく反り返る一物を、しゃぶるなん\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あむぅ……こ、こんら、ふうに。こんな、じゅる、じゅるぅ、ぶちゅ。咥え\nろら、なんれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「えっちな、命令……せっしゃ、むりやり、じゅる、しゃくはち、しゃせられ\nへる……しゃくはちっれゆうのは、フェラの、ころ、れふぅ……じゅるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「もっろ、はげしく舐めろらなんれ、めいれい……じゅるるるるる。じゅぶ、\nん、んぶぅ、じゅるううぅぅ。ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「こんら、えっちなころ、んぶぅぅぅ、めいれいするなんれ、ひどい人れすぅ\n。おくひの、奥まれぇ、あおくしゃい……こんら、めいれい……んちゅうぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「めいれい、嫌なのに……せっしゃ、めーれーされるの、だいきらいでぇ……\nじゅるるる。こんら、嫌がるころしれ、たいちょうどの、喜ぶなんれぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ひどい、人、れすぅ。拙者のこと、エッチのための道具としか、思っれない\nんれしょう？　んぶううぅぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「こんな、鬼畜な、めーれー……じゅるる、んぶ！？　い、一物が、びくびく\nっれ……ましゃか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103115" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んむうう！？　ろんろん、おっきくなっれ、震えて……んん！？　ふご！？\n　んんん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んぶううぅぅううぅぅ……えほっ！　えほえほえほっ！　げほっ！　く、口\nの、中に、えほえほ！　どろどろしたの、が」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103117" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んあぁ……そんらぁ、飲め、らなんれぇ。らから、せっしゃ、めーれーは、\nきらいらと……んぶ、ん、ぐぅぅ……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んく、んくっ……ん、ごきゅん。ぷあっ、はぁ、はぁ……の、飲んで、しま\nいましたぁ。命令されるままに、隊長殿の、精液、飲んでしまった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「身体が、熱い、ですぅ。お腹に、どろどろで熱い感触が、あります。命令さ\nれるままに飲み干した、隊長殿の精液の感触……あぁぁぁ。熱いぃ", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「命令されたり、強制されたりするの、大嫌いなのにぃ……も、もっと、命令\nして欲しい。エッチなこと、もっと、命令、お願いします、隊長殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「は、はい！　もう一度、しゃぶらせていただきます。んむぅ、ん、じゅるる\nるる……あ、ふあぁ……かたいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「一回、出してるのに、れんれん、かたいまま、れふぅ。それに、もう、びく\nびく、しれるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、ありがとう、ごじゃいまふぅ。上手、らから、なんれ。せっしゃは、た\nだ、たいちょーどのに、きもひよくなっれ欲しいらけれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「じゅるるるる、ん、ちゅ。ちゅっ、ちゅっ、ちゅっｔ……んむぅ、ん、じゅ\nるぅ。い、いっしょに、おっぷいも、れふか？　はい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ん、んっ、んんっ、じゅるぅ、ちゅぶぅ。んああ！？　また、いちもちゅ、\nびくっれぇ！？　あ、ひああ！？　またぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「はぶぅんんんんんん！　しゅご、にかいめ、らのに、量、じぇんじぇん多い\nぃ……ぶぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103127" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んん、あぶぅ……ん、ごきゅ、ごきゅ……ん、ごくん。ぷあっ。はぁ、はぁ\n、はぁ……口の、中ぁ……いいえ、身体の奥から、隊長殿の匂い、しますぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「この匂い、しゅきぃ……もっと、欲しいです、隊長殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「だったら、もう一度……それは、命令、ですか？　は、はい！　命令だった\nら、仕方ありませんよね！　本当は、嫌ですけど！　あむぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「じゅる、じゅるじゅうるぅ、じゅる、むぶ、じゅぶ、じゅるうぅぅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ろう、れふか、たいちょー、どの？　あはっ。泣きそうな顔、しれまふよ？\n　さんかいめは、さしゅがに、感じすぎましゅか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「らめれす、めーれー、したのは、たいちょうどの、なんれふから。ゆっくり\nとか、てかげんとか、しましぇんから。じゅるるるるる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あ、ふああ！？　また、おちんちん、びくっれぇ、さんかいめぇ。また、し\nゅぐに、気持ち良くなっちゃうんれふか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「は、はい！　ぶっかけてくらしゃい！　命令、らから、受け止めましゅぅ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んぶ、んぶ、んぶううぅ！　じゅるるるるる！　あはっ！　血管、ぴくぴく\nしてる。それに、先っぽ、ぷくって膨らんで……あ、ふあああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んぶああ！？　んっ！　熱い！　熱いぃぃ！　熱いのが、顔に……胸にぃ！\n　あちこち、汚して、くるぅ……んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んあ、あ、ふあぁぁぁ……しゅ、しゅごい、ですぅ。拙者の、身体、白いの\nで、どろどろにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「命令、されて、無理矢理、汚されてしまいました……強引に、嫌が割る私を\n、どろどろに、真っ白にぃ……ふ、ふふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「え、エッチなこと、だけは、命令されるの、ぞくぞくして、たまらないかも\n、ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「なんですか隊長殿？　なんかものすごく悪い顔してますよ？　え！？　命令\n！？　もう一回しゃぶれ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「た、たしかに、エッチな命令をされるとぞくぞくしてしまうとは言いました\nが、調子に乗りすぎです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んっ……あむっ……こんな風に……しゃぶれらなんてぇ……冗談が……きつ\nぃれふぅ……じゅるるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ふぇ……？　お約束？　なんれしゅか、それえ……それよりも、おちんちん\n舐めないとぉ……ちゅるっ、ちゅっ、じゅるっ、じゅばばっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「じゅるるるるる……れふからぁ……すきれ舐めへるわけひゃ……ないんれふ\nよぉ……命令なのれ、じゅるるる……しかたなく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んんん……生ぐしゃい……さっき、三回も出しれまふからぁ……じゅぽ、じ\nゅぽ、じゅぽっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「じゅぽ、じゅぽ、じゅぽ、ちゅるるるる……んっ……んんん……じゅるるっ\n、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅるるるる……じゅぱ、じゅぱぱ、じゅるるる……ふぇ？　なん\nれふかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ベ、別に、たいちょうどのの、いちもちゅが、しゅきぃってわけじゃ……な\nいんれふよぉ……じゅぽ、じゅぽ、じゅぽ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「めいれい……らからぁ……しかたないんれふ……ちゅっ、じゅっ、じゅぽ、\nじゅぽ、じゅぽ……んんんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「たいちょぉどの……きもちいいんれふね……？　いちもちゅ……だんだんピ\nクピクしれきましら……じゅぷ、じゅぷ、じゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「じゅぷ、じゅぷ……んふふふ……はやく、せーえき、らして……くらしゃい\nね？　ちゅ、ちゅるる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んんんんっ……べちゅに、のみたいわけじゃ……ないれふよ？　じゅるるる\nるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「たいちょうどのの、命令だから、しかたなくきいれまふ……じゅるるるるっ\n……命令も、エッチなこと以外は……嫌いれふけどね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んあ……たいちょぉどの……いちもちゅが、もうぱんぱんにふくれあがっれ\n……くるひそうれふね……ちゅっ、じゅるるる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ふぁい……わかってまふ……", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ん、ん、んんんんっ……じゅるっ、たいちょうどののいちもちゅ、もう、げ\nんかいみたいれしゅね……ちゅるっ……でそうでしゅか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「はい……！がんばりましゅ……めいれいれしゅから、出させて差し上げまし\nゅ……ちゅ、ちゅるっ、じゅる、じゅぽ、じゅぴじゅぽっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「じゅるっ……じゅるじゅるじゅる……ちゅっ、ちゅぱっ……ちゅうぅうう…\n…ぷはぁ……ちゅっ、ぺろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んっ！　でましゅ？　でましゅかあ！？　顔と、お口どちらに出しましゅ…\n…じゅぽ、じゅぽ……ご、ごめいれいをぉ……！　じゅるるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103220" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ん、んんんんん～～～っ！　んっ、んっ、んぐっ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ん……んっ……んんんっ……らいじょうぶれふ……！　ごめいれいどぉり…\n…全部、飲みまふ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んっ……んぐっ……んんっ……ちゅぅっ……じゅるっ……じゅるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「四回目なのに……どうして……こんなに濃いんですか……んんんっ…………\nんっ。じゅううううううっ……んっ、ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁ……はぁああ～……ああ……また飲んでしまいました。\n隊長殿に、命令されるがままに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「そ、そりゃエッチなことを命令されるのだけは、嫌いじゃないっていいまし\nたけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「でも、いきなり四発目まで命令されるなんて、思っても見なかったですよぉ\n……まあ、嫌ではないですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「……って、隊長殿？　なにを一物をヒクヒクさせてるんですか？　まさか…\n…五発目を！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あああああっ！　やっぱりそのまさかですか！？　本気ですか！　どんだけ\n絶倫なんですか！？　化け物ですか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「わかりましたっ！　わかりましたよっ！　まあ……さっきも言った通り嫌い\nじゃないですし！　それじゃあ……行きますよ？　むふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},
		{"command":[ "LABEL", "LABEL2" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ぷはぁっ！　はぁ……あ、ちょ、ちょっと待って……あ！　あ、あああああ\nああ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んあぁあっ！？　よ、避ける間もなくいきなり顔に……ふぁあああ……！　\n精液……かかってきてますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「んあっ！　あああっ！　顔が……精液でどろどろ……胸にも、首にも……は\nぁあああ……あああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ふぁああ……！　真っ白、今まで以上に、精液で真っ白です。拙者、さらに\n汚されてしまいました……ふふ、ふふ、ふふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「あああ、臭い！　隊長殿の匂いがしみついてしまって、拙者、ものすごく臭\nいです……あは、あは、あははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「な、なんですか！？　拙者、別に喜んでなんかいませんよ！　そこまで特殊\nな趣味は持ち合わせてません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00013701_01_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「いえ、本当か？　と真顔で聞かれると否定はしきれませんが、何もそこまで\n真剣に聞かなくても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「っていうか、これは趣味とか性癖っていうよりも、隊長殿のだから嬉しい\nって言う部分も無きにしもあらずで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「って！　なんでもないです！　別に、隊長殿が好きだからなんて言ってませ\nん！　命令！　命令で仕方なくですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オトハ" ]},
		{"command":[ "SETTEXT", "「ええ！　命令は嫌いですけど！　あー！　もうめんどくさい人ですね！　も\nう一回しゃぶってあげるから、黙ってください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_137_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
	{"command":[ "EXIT" ]}
	]
}