{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0059" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……ひどい目に遭ったぜ……」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "シャナを送り届け、俺は受付に戻っていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「カツマさん、お疲れさま。今日はいろいろと大変やったでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510001" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、そうっすね……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ジュンジローさんもお疲れさま」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510002" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いえいえ、わたくしはここで番をしていただけですので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023510001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当、それしかしてないよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ごく普通の犬にしては、過酷な仕事をこなしていると思いますぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023510002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああそうかい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「本当に助かったわ。いろいろとトラブルも解決してもらって。ずっと働いて\n欲しいくらいです～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510003" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「三食昼寝に温泉つき、うちの尻尾ももふもふし放題。どうやろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510004" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くぅ……それは魅力的……っ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、心が揺れ動いてますな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023510003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だってよ、絶対労働環境はこっちの方がいいだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ……ご主人にとってはそうでしょうなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023510004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「今すぐに決めなくてもええよ。ああそうだ、カツマさんのことえすえぬえす\nに載せてええやろか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510005" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「優秀なスタッフがヘルプに入ってくれました～って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510006" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「別にいいですよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、隣に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510007" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "サクヤが隣にやってきて、ぐっと身を寄せる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ほらほら、もっとうちに近づかんと、ふたりが映らんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510008" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……わかってる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "横乳が押しつけられて、そのやわらかさに思わず顔がほころんでしまう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人……顔が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023510005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「し、仕方ないだろ……うへへ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「はい、ちーず♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510009" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちーず」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "こうして、俺とサクヤのツーショットがＳＮＳにアップされることとなった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「よしっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510010" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "サクヤが投稿したところで、宿の戸が開く。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「お客さんみたいやね。ようこそ九十九尾温泉へ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510011" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ここよ、スザクちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510001" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ここが人間界の温泉……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510001" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "入ってきたふたりを見た瞬間、俺の浮かれた気持ちはどこかへ飛んでいってし\nまった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、お前たちは、時間帝国の！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「むっ！　カツマ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510002" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あらら、カツマさん。元気してた～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510002" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「知り合いなん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510012" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「し、知り合いというか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "相手は時間帝国の四神衆。俺とは比べ物にならないほど強いのは間違いない。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "0", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "1", "char_00025901_01", "0", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "それにここは温泉宿。一般人もいる。できるだけ争わないようにことを運びた\nいところだが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「カツマさん、そんなに警戒しないで。私たちの目的は温泉だから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510003" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「私も沙世子につれられてここに来ただけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510003" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、このふたりの言うことを信じますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023510006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それしかないだろう。戦って勝てる相手でもないし」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「敵前逃亡ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023510007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「戦術的撤退と言ってくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ふふっ、話はまとまったかしら？　それで、さっそく露天風呂に案内して欲\nしいんだけど、カツマさん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510004" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺が！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あらあら、ご指名やね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510013" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……じゃあ、ついてきてください」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「よろしくね。うふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510005" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0075" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETTEXT", "沙世子とスザクを露天風呂へと案内した。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "本当に目的は温泉だったのか、俺に攻撃を仕掛けてくるということはなかった\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そこまでは良かったのだが……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な……なんで俺まで温泉に入っているんだ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「だって、この温泉には三助のサービスがあるんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510006" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだが……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "三助を頼まれた俺は、スケベ心のおもむくままに快諾。ダークエルフと褐色サ\nキュバスの身体を洗えるはずだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "しかし、洗われていたのは俺だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「うふふ♪　よく見てね、スザクちゃん。これが、温泉でするボウチュウジュ\nツよ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510007" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「な、なるほど。そのように……うぅ、大胆に身体を……。む、胸で男を洗う\nのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510004" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "沙世子が俺の身体を洗う様子に、スザクは目が釘付けになっている。吐息に興\n奮が混じっているのがはっきりわかった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「どうかしらカツマさん、おっぱい気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510008" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「き、気持ちいい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "恐るべきサキュバスの洗体ジツ。身体の汚れと一緒に理性まで洗い流されてし\nまいそうだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "それに股間も、ズキズキと痛むほどに勃起してしまっている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。さすが沙世子だ……。カツマの股間も、まるでドラゴン\nの角のように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510005" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「そろそろスザクちゃんも参加して。カツマさんの前を洗ってあげたら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510009" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ま、前……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510006" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「前を洗うということはつまり、ち、チンポを洗えということだな！？　私の\nオマンコで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510007" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでそうなる！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「最終的にはそうなるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510010" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「最終的には！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ジリジリと詰め寄るスザク。その様子がおかしいのは明らかで、目はぼんやり\nとした状態だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、こいつ正気じゃない！　沙世子、お前なにかしたんじゃないか！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「なにもしてないわよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510011" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ただ……久しぶりに男の人とお風呂に入っているから、興奮してサキュバス\nパワーがちょっと漏れちゃってるかも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510012" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっぱりお前のせいじゃねーかー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「わ、私のボウチュウジュツで、お前のチンポを洗ってやるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510008" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "スザクがいよいよ俺に跨ろうというとこで、温泉からなにかが飛びだしてきた\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「またサメか！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "いや、違う。ミナカだ。しかしミナカも様子がおかしい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「お客様の身体を洗うのは、わ、私の仕事です～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023510001" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ああ、な、なんだお前……んんっ♪　そ、そんなところ……汚い……あぁん\nっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510009" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「き、汚いから、綺麗にするんです……。んれろ、れろれろぉ……んちゅちゅ\nぅ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023510002" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ああぁ、やめ……っ、身体が火照ってたまらない……。はぁ、はぁ……んぁ\nっ、ああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510010" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ミナカがスザクを押し倒し、股間を舐めまわしている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "……河童というか、垢舐めでは？　いやいや、そんなのんきな考察をしている\n場合じゃない。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「間違いないな。沙世子のせいで温泉にいるやつらが発情してるんじゃないか\n？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あらあら、困っちゃったわね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510013" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「他人事か！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ちょっとカツマさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510014" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "さらに、怒り心頭といった形相のサクヤまでやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「従業員のキツネたちが一斉に発情期にはいってしもたんやけど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510015" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「……って、なにしとんの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510016" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああっと、これは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "沙世子に身体を洗われている俺。スザクとくんずほぐれつ状態のミナカ。こ\nんな状況になった理由を、いったいどこから説明すればいいだろうか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「女将さんすごいわね～。サキュバスの力に影響されて発情していないなんて\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510014" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、なに感心してんだよ！　お前が原因だろうが。なんとかしろって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「性的にスッキリすればみんな元に戻るから大丈夫♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510015" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫じゃねー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……。お客様の前なのに、オチンチンをそないに勃起させて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510017" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うちはそういうお店じゃありませんの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510018" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……その……わかってはいるんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「節操のないオチンチンは、うちのオメコでオシオキしてあげななりませんわ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510019" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「女将ぃっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「なぁんだ、ちゃんと効いてるのね。いいわよ～、みんなで楽しみましょ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510016" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なに煽ってるんだ沙世子！　ま、まってくれ女将！　いまからちゃんと説明\nを……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「言い訳は、オシオキしながらゆ～っくり聞いてあげますからね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510020" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……ああ……あああ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "完全にスイッチの入った女将に、ふたつの意味でこってり搾られた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0075" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "それから……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "沙世子のせいで起きた騒動の責任をとるために、俺たちはしばらく宿でタダ働\nきをさせられていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……なんで俺までこんなことに……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「くっ、私としたことが。淫らな気にのまれてボウチュウジュツどころではな\nくなってしまうなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510011" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……お前はなんでタオル１枚で風呂掃除をしているんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「こ、これも修行だ！　お前に無防備な姿を見せても動揺しないようにするた\nめのな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510012" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そう言いながら、スザクは浴場の床にブラシをかけている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "前かがみになっているせいで、後ろにいる俺からは股間が丸見えの状態だ。つ\nられて俺まで前かがみになる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「と、ところで、沙世子のやつはどうしたんだ？　俺たちが働き始めてから、\n姿が見えないけど」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ああ、沙世子なら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010023510013" ]},
		{"command":[ "SETCHARA", "0", "char_00025702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0075" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "男客１" ]},
		{"command":[ "SETTEXT", "「うおぉぉぉっ！　勃起がとまらん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040023510001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "女客１" ]},
		{"command":[ "SETTEXT", "「あぁあんっ、いっぱい射精してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_050023510001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "男客２" ]},
		{"command":[ "SETTEXT", "「イクぞ！　孕め孕めぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_060023510001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "女客２" ]},
		{"command":[ "SETTEXT", "「孕ませてぇっ、赤ちゃんちょうだぁい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_070023510001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「ああぁん、うらやましいわ。みんなでヤりまくりじゃないの～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510017" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「でも、私は手を出せない……。なぜなら、サクヤちゃんの術で石像に封じ込\nめられちゃったから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510018" ]},
		{"command":[ "SETCHARA", "0", "char_00025902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「サキュバスに気持ちよさそうなセックスを見せつけるだなんて拷問よ～。鬼\nぃ！　悪魔ぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010023510019" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ふふふ。うちにあ～んな恥ずかしいことさせたからには、いちばんきっつい\nお仕置きを受けてもらいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510021" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「それにしても、サキュバスパワーあふれる混浴温泉で孕ませセックスし放題\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510022" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「期間限定とはいえ、うちの宿の新名所になるわぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510023" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「この際、結婚願望のある客をターゲットに、式場を併設してしまおうかしら\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510024" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「こないだ損した分を取り戻しておつりがくるくらい、沙世子さんには働いて\nもらいますからね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510025" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「さてと。この様子、どんどん発信せな……ぽちぽち、ぽちぽち……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510026" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「アカウント凍結！？　そんな殺生なぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023510027" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「このあと、石像から元に戻った沙世子殿によって、女将は仕返しを受けるの\nでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023510008" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「めでたし、めでたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023510009" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}		
	]
}