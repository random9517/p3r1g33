{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「どうしたのご主人、そんな真剣な声色で呼び出したりなんてして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00015803_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……あー、なるほど、私の水着を見てたら我慢ができなくなったと？　ふふ\nっ、いいよ、解消に付き合ってあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「手ですればいいかな？　――え？　わ、脇？　脇でおちんちん挟んでシコシ\nコしてほしい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00015803_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人って、たまに予想もつかないほどの性癖ぶつけてくるよね？　しかも\n満面の笑顔だし……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00015803_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いいよ、了承したのは私だもん。一応そーゆー行為があること自体はデータ\nで知ってるから。……ほら、腕上げるから……ご主人、来て？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303105" ]},
		{"command":[ "SETCHARA", "0", "char_00015803_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんっ……ご主人のおちんちんが、脇から飛び出てる……分かってたことで\nはあるけど、すごい恰好しちゃってるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015803_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「もうちょっと、ぎゅって挟めばいいのかな……んんっ、どう？　こんな感じ\nで大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――よかった。それで、ここからどうすればいいの……？　私が腕を動かし\nたりする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――まずはご主人が自分で腰を動かすんだね、わかったよ。えっと……じゃ\nあ、私の脇、どうぞご自由にお使いください？　……変なの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ……ほ、ほんとにおちんちん動き出した……んんっ……これ\n、なんか妙に恥ずかしいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「この体勢だと、おちんちんが思ったより近くて、あっ、んふっ……すごい、\n皮がずるずりしてる……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おちんちんの凸凹が脇に引っかかって、あっ、んふっ……これ、血管、かな\n……？　すごい浮き上がってるのまで、分かるんだ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、んふっ……ご主人、ちょっと腰の動き早すぎない？　もうこ\nんなに先走りも垂れてきて……ぐちょぐちょって、えっちな音すごい…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――んっ、くすぐったくはないよ。流石に、人間と同じように脇がくすぐっ\nたくなるようには作られてないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも、感触は普通にあるから……あっ、んふっ……ぐちゅぐちゅって、おち\nんちんで脇をかき回されるのは、不思議な感覚かも……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――もう少し強く脇を絞める、だね、わかったよ。……んっ、強すぎず弱す\nぎず、おちんちんの形が少し変わるぐらいの力加減で……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こんな感じ、かな……？　すごい、もうおちんちん先っぽこんなに赤くなっ\nちゃって、ぴくぴくしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「大きく、ゆっくり……にゅるんって抜けていったと思えば、また勢いよく突\nき出されてきて……んふっ……皮が脇に引っかかってるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ、んんっ……た、確かにデータとして知ってはいたけど、本当\nに脇でも気持ちよくなれるんだ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わ、私の脇まんこが最高過ぎるから当然だって……ち、ちょっと、流石にそ\nの言い方は恥ずかしすぎるって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――わ、私も言うの！？　うぅ……分かったよ……ほら、もっとわ、脇まん\nこ締め付けてあげるから、ご主人は早く腰を振ってよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んくっ、あっ、んふぅっ……！　もう、私の言葉だけでこんなにもおちんち\nん大きくして……ご主人ってば、ほんと単純なんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、怒ってはないよ、ちょっと恥ずかしかっただけ。……まぁ、私も、\n興味なかったって言えば嘘になるから……ほら、もっと締め付けるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんっ、あぁっ……また、えっちな音出しながら、おちんちん動き出した…\n…んあぁっ……脇まんこに凸凹が擦れて、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「やっぱり、括れの部分が少しひっかかるよね、んふっ、んっ……でも、これ\nがいいんだ、んっ、んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「また先走りの量が増えてきた……脇まんこのなか、にゅるにゅるに蕩けちゃ\nうね、んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こ、声が出ちゃうのは、その……くすぐったくはないんだけど、ご主人が気\n持ちよくなってくれてると思うと、私もちょっと感じちゃうと言うか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わ、私のことはいいから！　ほら、脇まんこもっとぎゅ～って締めてあげる\n。さきっぽぴくぴくしてるし、もうそろそろ出そうなんでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んふっ、んっ、あぁっ……えっちな匂いも、どんどん強くなってきた……ん\nくぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おちんちんの動き、すごい早い……あっ、んふっ……！　摩擦が強すぎて、\n脇まんこの中もどんどん熱くなってくる……んぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そんなに左右に暴れられると、おっぱいにもおちんちんが食い込んできちゃ\nう……あっ、んくぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いいよ、このまま出して、私の脇まんこで気持ちよくなっちゃってね。ご主\n人のタイミングで、精液びゅーびゅー出していいからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あふっ、んんっ、んあぁっ……！　先っぽがぱくぱくして、脇まんこの中で\n、おちんちんドクドクするの伝わってくる……あっ、んくぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「出して、ご主人私の脇まんこで射精して！　最後までぎゅ～って締め付けて\nあげるから、私にむかって精液ぶっかけて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ……！　おちんちんがびくびく跳ねて、んんっ！　ご主人の精液\n、すごい勢い……！　んくぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「脇まんこだけでこんなに射精するなんて……んんっ……！　ふふっ、ご主人\nの変態さんめ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、水着の名札の部分、精液でどろどろになっちゃた……んんっ……私\nの水着汚すの、気持ちよかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……やっぱり、一回出しただけじゃ、ご主人のおちんちんはまだまだ固\nいままだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――言ったでしょ、私もちょっと興味あるって。インプットしたデータの中\nに、試してみたい知識があってさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だから、今度は私からも……ね？　ご主人も、好きに腰を振ってくれていい\nからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　もう一度、脇まんこで思いっきり締め付けて……んっ、んぁ\n……射精したばかりだけど、おちんちん痛くない？　大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ん、ならこのまま私も腕を動かしていくね。こうして、腕を少し内側に\nまげて、っと……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こうすれば、おちんちんに角度がついて、先っぽの部分がおっぱいに食い込\nむでしょ……？　んくっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ご主人、さっきこの動き気持ちよさそうにしてたもんね……んんっ\n……おっぱいにぐりぐり、水着にこすりつけて……んくぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「このまま腕も前後に小刻みに動かして……んふっ、んっ、んんっ……！ぐち\nゅぐちゅって、脇まんこすごい音しちゃってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら、ご主人ももっと腰動かしてよ。にゅるにゅるっておちんちん抜き差し\nして、私の脇まんこ、もっといっぱい楽しんで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……！　そう、脇まんこに精液を塗り込むみたいに、激しく……あ\nっ、んくぅっ……！　ふふっ、また括れの部分がひっかかってるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんっ……！　腰を突き出されるのに合わせて、締め付けを強くし\nて……んふっ……抜けていくときは腕を動かして使ってすりすり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、脇まんこの中でおちんちんが大暴れしちゃってるね。真っ赤に膨れ\n上がっちゃって……ちょっと可愛いかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んふっ、んっ、んんんっ……！　おちんちんの動き、どんどん早くなってき\nてっ……あっ、んくぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おちんちんドクドクしてるの、また伝わってきた……んぁんっ……凸凹が脇\nまんこにゅるにゅる滑っていくの、気持ちいい……んふぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人がここまで喜んでくれるなら、もっと脇であれこれできるパーツを取\nり寄せてみようかな……ふふっ、なーんてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……またおちんちんの先っぽがぱくぱくし始めた。いいよ、このままも\nう一度私の脇まんこに射精しちゃってよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んふっ、んんんっ……！　もっときつく、痛いぐらいの締め付けでおちんち\nんをぎゅ～～ってして、んふぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「腕を前後に動かして、摩擦ももっとっ、あぁんっ……！　脇まんこ、熱々の\nドロドロに蕩け切らせて、あっ、んくぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「圧迫して、離して、圧迫して、離して……すりすり、ぎゅ～……先っぽもっ\nとおっぱいにも抉りこませて……括れの部分擦りつけていいからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んくっ、んふぅんっ……！　えっちな匂いがすごいことになって、私\nの思考回路にも小さなノイズが走る、かも……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んあぁんっ……！　これ、脇まんこでも気持ちよくなれるパ\nーツを搭載したら、私どうなっちゃうんだろ……あっ、んくぅん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「いいよ、ご主人の好きなタイミングで出して！　私の脇まんこはご主人専用\nだから、精液いっぱいびゅーびゅーって出しちゃっていいからね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んくぅんっ……！　おちんちん、にゅるにゅる滑りまくって、あっ、\n先っぽ膨らんでっ、来る、ご主人の精液が、あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ……！　脇まんこの中で、おちんちんドクドクしてるのが伝わっ\nてくる……！　あっ、んくぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「また水着に精液いっぱい降りかかってきて、あっ、んあぁんっ……！　二回\n目だって言うのにすごい量……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ、んぁぁ……ご主人の精液、水着からしみ込んで……ボディにまで届い\nてる……触れた部分のパーツが熱い……あっ、んあぁんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、脇の間からおちんちん突き出して、びゅーびゅー射精するのはなん\nだか間抜けに見えるけど……必死なご主人は、ちょっと可愛いかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……もうおしまい、かな？　ふふっ、どうだったご主人、私の脇まんこ\n、気持ちよくなってくれた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――私？　……まぁ正直、最初は馬鹿だなぁとは思ったけど……うん、こー\nゆープレイもたまにはありかな？　なーんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、折角の水着なわけだしね。普段しないことを経験しとかなきゃって\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ねぇ、ご主人、これ、おちんちんまだ固いまま、だよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、そうそう、折角の機会だからね。このままもう一度、私の脇まん\nこを楽しんだり、しちゃってみない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……！　ふふっ、それでこそ、私のご主人だね。精液をぜーんぶ絞\nり切るまで、何度だって付き合ってあげる、ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ……！　こ、これ、脇まんこの中に射精するみたいでっ、あっ\n、んふぅうんんっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ドクドクって、脇まんこに精液が注ぎ込まれてくるっ……んぁんっ……！　\n私の脇、本当のオマンコになっちゃってるみたい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わかってるよ、このまま腕の動きは止めずに前後にぐりぐりして……あっ、\nんんんっ！　精液がかき混ざってすごいことになっちゃってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、んふぅんっ……！　どうかな、ご主人、ぐちょぐちょに蕩け切\nった私の脇まんこ、気持ちよくなってくれてる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、まぁ、この射精量見たら、返事なんていらないけどね。んんっ……\nすごい、まだ出てる……んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015803_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「流石にこれで打ち止め、かな……？　んっ……精液と摩擦の熱で、脇まんこ\nの中すごい温度になっちゃってるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほら、こうやってちょっと腕を動かすだけ……んっ……ぐちょぐちょって、\nえっちな音もこんなに鳴っちゃって……ふふっ、ご主人、出し過ぎだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――え？　本当のおまんこのように気持ちよかった？　我慢なんてできる訳\nないだろ？　……清々しいほどの開き直りだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「でも……ふふっ、こうして新しい知識を試せるのは、私も楽しかった、かな\n……？　ちょっと気持ちよくもなっちゃったしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「最初はちょっと驚いたけど……うん、ご主人がよければ、またいつでも私の\n脇まんこ使っていいからね？　なーんて、ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}