{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だ・ん・な様～♪　ね～え、だんな様ったらぁ、起～き～て♪　起きて～♪\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00000602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あら……？　全然起きてこなぁい……。んもぉ、せっかくダイヤナちゃんが\nこーんなにセクシーな格好で起こしにきてあげたのに～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……でもぉ、疲れてるなら無理やり起こすのは可哀想かしら……？　んん、\nどうしたら……って、きゃっ？　布団の一部が盛り上がって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こ、これって……その、アレよね？　勃起……。オチンチンがおっきくなっ\nて……。ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00000602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　やっぱりそうだ、これ、絶対勃起しちゃってる……♪　あ～ん\nどうしよ……。ビクビクしてるし、ちょっと辛そうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「奥さんとしては……うん。そうよね。だんな様の欲望は解消してあげないと\n～……。起こさないように、そーっとそーっと近づいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203106" ]},
		{"command":[ "SETCHARA", "0", "char_00000602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あああ……♪　すっごぉい……♪　パンパンに腫れあがってるぅ……ちょっ\nとエッチなにおい……。それに、太いし長いしもう大変……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000602_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「このままにしておくと、男の人って辛いのよね……？　だったら、あたしに\n出来ることは１つ……。あんまり自信はないけど……えぇい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ぺろっ……んんっ♪　大好きなだんなひゃまのオチンチン……舐めておとな\nしくしてあげなくっちゃ……。んっ、ぴちゃ……ぴちゃ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……意外とこれくらいしても起きないものなのねぇ。だったら、もうちょっ\nと大胆に舐めちゃってもいいかな？　んっ、ぺろ……ぺろ、ぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「くちゅ……ちゅっ、れろ……。ぴちゃっ、ぴちゃ、ちゅぷ……んっ、んっん\nっ……♪　それにしても巨大なオチンチン……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなの、ダイヤナちゃんのちっちゃなお口にはとてもじゃないけど入りき\nらないわ……。ほら、先っちょだけでもこんなに太くて……んっ、くちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「舌先でレロレロするだけで精一杯……。はぁっ♪　た、逞しくてカッコイイ\nけど……♪　好きだけど、……見ているだけでドキドキしちゃうけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「間近で見ると怖いかもぉ。おっきすぎるし、硬すぎるしぃ……。でも、いつ\nもコレがアソコに入っているわけでぇ……。あっ♪　キュンとしちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だんな様ぁ？　ダイヤナちゃんがたくさんご奉仕してあげるからね。リラッ\nクスしてぺろぺろされてね～……。んっ、ちゅぱっ、ちゅぷっ、ぷちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ぺろっ、ぺろ……ちゅぷっ、ぷちゅっ、ちゅっ♪　ちゅっ……はぁあっ……\n♪　ちゅぅっ、ちゅっ、れろっ……れるっ、ぴちゃっ……ぴちゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁん、舐めれば舐めるほどおっきさが増してくぅ……♪　困るわぁ。んっ\n……これは本気を出さないといけないかしら？　それなら……あむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んんん……♪　こうやってオチンチン全部お口の中に咥えひゃうのはど～ぉ\n……？　むぐ……んぐ、くちゅっ、ちゅぷ……ぷちゅっ、くぷぷぷ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ん、ふふふ♪　気持ち良さひょう……♪　んっ、んっ、ん……♪　あぁ……\n♪　なんらかあたしも身体がウズウズしてきちゃったかもぉ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だんな様のオチンチン……寝込みを襲って勝手におしゃぶりしてる悪い若妻\n……♪　んっ♪　んっ、ダイヤナちゃんってば本当にエッチな悪い子ぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「れも、これはだんなひゃまのことを愛しているからなんだから……♪　だか\nら絶対いいことなんだから……♪　ぐちゅ……れろ、れろっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ンン、……ぐっちゅっ♪　ぐちゅっ、ぬちゅ♪　れろぉ……れろっ、ぐちゅ\nぷっ♪　ぬちゅっ、ぬちゅっ、れろれろ……んんんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁ……エッチな先走り汁がお口の中に溢れてくるぅ……♪　もっとしてほ\nしいのね、わかった、ダイヤナちゃん頑張るぅ……ぐっちゅっ、ぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ぬちゅっ！　ぷちゅっ、ぶっちゅっぐちゅっ♪　ぐちゅっ、ぐちゅっ……れ\nろれろれろ……♪　ぢゅるっ……ん～～～♪　ぐちゅっぐっちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「好きよ、だんなひゃま……♪　んっんっ、愛ひてるぅ……♪　ぬちゅっ！　\nぐぷぷっ……！　ぢゅるっ！　んれろっ、れろ……ずっちゅっぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ん！？　今オチンチンがビクビクって痙攣ひて……！　あっ！？　ウ、ウソ\n！？　お、起きてたの！？　だんな様ったらいつから目が覚めて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい！　オチンチンが大きくなっていて辛そうだったから、楽\nにしてあげたくて……あたし！　え？　このまま続けていい？　ホント？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ～ん、やっぱりだんな様大好きぃ♪　あたしのワガママを許してくれて、\n喜んでくれて……！　こうなったら、全力で気持ち良くしてあげるね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あむっ、んむっ！　……ぐちゅっ！　ぐっちゅっじゅぷっ！　ぬぷっ、ぬぷ\nっ、ぷちゅちゅちゅっ……ずっちゅっ！　ぢゅるっ、ぢゅる、ぢゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「くぷっ……くぷぷっ♪　じゅるっ……！　じゅっぽっじゅっぽっじゅっぽっ\nぢゅぽっ♪　はぁっ、はぁ、感じてる？　ダイヤナちゃんのお口で……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンぎゅんぎゅんって昂ってる？　フフフッ、もっと興奮ひて……♪\n　ん～～～♪　ぐちゅっ♪　んれろっ、れろ……れろれろっ、ぢゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ありったけの愛情い～っぱいこめて舐め舐めぐちゅぐちゅするから……気持\nちいいお顔見せて♪　っんむぅうっ♪　ちゅぽっ、ちゅぽ……ちゅぷっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んはぁっ♪　じゅるっ……♪　ぐちゅるっ、ぢゅるっ、ぢゅる……れろれろ\nれろっ♪　ふぁ♪　ひゅごい、暴れん坊ひゃんん♪　んぁんんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「精液ぴゅっぴゅしたくなっれきちゃった？　いいよぉ……。そのためにご奉\n仕ひてるんらもん、景気よくびゅーっびゅーって出ひてぇ♪　でもぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぁっ♪　ベッド……汚しちゃったら大変だからぁ、出す時はぜーんぶダイ\nヤナちゃんのお口に出ひてね……♪　んっ、んっ、どうぞぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぁんんん……っ♪　むぐっ♪　んむぅううんん……ん～～～っ、んぅんん\nん～っ♪　んッ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あは……♪　うれひぃ♪　こんなにたくさん出ひてくれて……♪　んむっ♪\n　　いいよぉ……遠慮しないでいっぱい出ひてねぇ～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だって、今日のダイヤナひゃんはだんな様のお嫁ひゃんなんらもの……♪　\nんちゅっ、吸い上げた方がいい？　いくわね……ちゅぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ちゅぅうう……。んぁっ♪　尿道に残ってた分もぜーんぶ出た……？　んふ\nふふ、良かった～♪　新妻のお口、気持ち良かった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなたが喜んでくれるのなら～、ダイヤナちゃん、いくらだってちゅうちゅ\nうしちゃうんだから♪　ホントよ？　愛する人のためだものぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ん……ふ、フフ……♪　お口の中、すっごくネバネバ……。少し喋るだけで\n、精液の臭いと味が広がって……んっ。上手に話せなくなっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなたのザーメン……ドロドロで、苦くて、栄養たっぷりって感じ。随分溜\nまってたのかしら、勢いも激しかったし……熱くて驚いちゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「これ……今更外に出すなんてありえないよね？　ダイヤナちゃんが飲んじゃ\nってもいい……よね？　うん、大丈夫。だんな様の出したものなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だんな様の一部だもん。誰にも譲りたくない、あたしがちゃんと飲むから見\nててね……♪　ん、く……ごくっ……ごく……。んんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「しゅ、しゅっごく臭ぁい……！　でも、お嫁さんだもん、平気……。んぐ…\n…。ぷはっ♪　……あ～♪　こんなに出したのにまだ勃起してる～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのラブラブフェラが忘れられなくなっちゃったのね～？　し\nょうがないなー♪　そんなにもう一度してほしいならぁ、いいよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「奥さんのあたしが、いっくらでもチュッチュくちゅくちゅレロレロしてあげ\nる……♪　オチンチン、もうちょっと貸しててね？　あ～～～ん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いっただっきまぁ～す……♪　はむ♪　くちゅ……ちゅく、にゅぷ……ぬぷ\nぷぷ♪　ぷ、ちゅ……くちゅ、ちゅっ……ぬちゅっ、ちゅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あは、ザーメンの味が残ってるねぇ？　でもらいじょうぶ……♪　あたしが\n綺麗にするから……んむっ♪　むぅっ♪　くちゅっ、ぷっちゅっくちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「汗や恥垢が溜まりやひゅいカリ首の段差もぉ……♪　さっきぴゅっぴゅして\nがんばってくれた尿道口もぉ……ぜんぶぜんぶダイヤナちゃんのお口の中」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「まるごと……ぢゅるっ♪　咥えてしゃぶって、ピッカピカにひゅるから楽し\nみにひててねぇ～……♪　んっう♪　ぐちゅっ、ぷちゅ♪　じゅるっじゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んむ～っ♪　じゅるっ！　じゅぽっ♪　じゅっぷっ、ぐちゅっじゅるっ♪　\nはむぅ……♪　んちゅぷっ♪　ぷちゅ、ちゅっ、ちゅむっ……ちゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぁ……♪　裏筋もしっかり舐め舐めしておかないとぉ……♪　んれろぉ…\n…んれるっ、ぺちゃ……ぴちゃ、ちゅぱっ、ちゅぱ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んふふ……♪　根元の方……タマタマのところまで汗と精液が垂れちゃって\nたみたいらね♪　ここもお口でお掃除……。くっちゅっ♪　にゅぷぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んふ♪　ふぅう♪　れろっ、れろ……気持ひいい？　んっ……♪　気持ひよ\nさそうな顔ひてるぅ……可愛い♪　もっとあたひに委ねちゃっていいよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そう……♪　夫のオチンチンのお世話はぁ、妻の大事なお仕事らからぁ……\n♪　んくちゅっ♪　れろ……れろれろれろっ、じゅぷっ、くっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「にゅる……♪　にゅるるっ♪　じゅるっ、ぢゅるるっ……♪　あれぇ？　今\nの舐め方良かったぁ？　んんっ……じゅるっじゅるっ、……こう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、い、いいよ♪　あたひの喉の奥まれ……オチンチン突っ込んでいいよ\nぉ……♪　んむっ♪　あぷ……！　奥の奥までずぶっと入れて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「それで、そこに精液流ひこんれね……♪　ん……強く吸い上げるよ♪　ぢゅ\nるっ……！　うん♪　うん、精液出ひて……早くぅ♪　ぢゅるっ、じゅるる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナひゃんの、奥ひゃんのお口にザーメンどぴゅどぴゅしてぇ……♪　\nんんんっ……じゅるじゅるじゅるっ、欲しいの、お願いぃ♪　んじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ん～～～～ッ♪　んふんんんんっ♪　んぅっ、ん～～～っ♪　んんん～～～\nっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ごくっ……ごくっ……！　あんっ♪　飲んでも飲んでも飲みきれないぃ……\n♪　なんで一回目より濃くて多いのぉ？　かっこよすぎだよぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぷっ♪　ダイヤナちゃんをザーメンで溺れさせるつもりねぇ？　その勝負\n、受けてたつわ……って、んぷぷっ！　出てくる、いっぱい出てくるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぁ……ごくっ。ごくっ、ごく……！　んぁあんんんっ♪　男らしすぎるぅ\n♪　ダイヤナちゃん、お口が妊娠しちゃいそうだよぉ……！　んむっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やぁんん……♪　そんなに興奮してくれてたのぉ♪　うれしい……♪　ごち\nそうがいっぱいで幸せぇ……♪　ん、残さず飲むからぁ……んあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ごくっ♪　……ごくっ……ん～～～～♪　胃の中たぽたぽになっちゃうくら\nい出してもらっちゃったぁ……♪　ありがとね、だんな様ぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……はーっ♪　はぁっ、はーっ……♪　喉に絡みつくザーメンの香り……。\nこんなの、クラクラしない女の子なんていないよぉ……すごすぎ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなにエッチでかっこいいだんな様がいるなんてぇ、他の子たちに知られ\nたら大変よ。みんな奪いにきちゃう、そんなのぜーったいイヤ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ね～え、だんな様ぁ？　だんな様はダイヤナちゃんだけのだんな様でいてね\nぇ？　じゃないと泣いちゃう……。どんなやらしい事だってするからぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「このまま……二人でずーっとイチャイチャしてたいな……♪　そうなの。だ\nんな様にマーキングされて、あたし……だんな様だけのモノになったのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっぁっ、きたぁ♪　って、やっ……！　そ、そっちは違うわよっ、あっ…\n…！　そこはお顔、ダイヤナちゃんのお顔にかけないでぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぷっ、ぷぁううっ……！　あうっ、あぷ……！　やっ♪　あっ、ぁっ、も\nのすごいザーメン臭……っ！　あんっ、お口が寂しいの、こっちぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「お口にびゅるびゅるして……って、あたしのフェラがエッチだったから？　\nお顔にかけてもっとやらしくしたかった？　……あっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そ、それなら……うん。かけて？　いっぱい……あんっ、だんな様のネバネ\nバかけてっ！　あぁあんっ、息ができないくらいいっぱいぃ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、に、二回目なのにまったく精力が衰えないなんて……さすが\nはダイヤナちゃんの自慢のだんな様……♪　惚れ直しちゃったぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203405" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、いいのよ……♪　あたしはあなたのお嫁さんなんだから、どれだけ汚\nしちゃってもいいの……ヌルヌルにしちゃっていいんだからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ん、ぁああああ……♪　精子……お口にドクドクしてほしいって思ってたけ\nど……。こうしてあなたの臭いに包まれるのも、アリかもしれないわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「フフフッ、お顔に出してくれた精液の量と色、臭いに粘り気でよーくわかる\nもん。とっても満足してくれたってこと……ダイヤナちゃん嬉しいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「奥さんのラブラブフェラ……どうだった？　寝てる時にされちゃうのも、夢\n見心地で良かった？　だったら……また、襲っちゃおうかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「朝だって、お昼だって夜だって……好きな時にダイヤナちゃんを使ってね？\n　それで～、年をとっても、ずーっとラブラブな夫婦でいられたらいいなぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0203410" ]},
