{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ふぅ～……。今日の練習はこれくらいでいいかしら……。んぅ……最近、集\n中力が落ちてきているわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……これも胸が妙に疼くせい……。んっ、ああ……。こうして、揉んで\nあげて……気を紛らわせないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00017301_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んくぅ……ふぅ……。でも……やっぱり足りないわね……。はぁ……あの野\n蛮な人間ほどの、力じゃないと……って、きゃぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00017301_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あ、あなた！　いつからそこにいたのよ！　こ、これはオナニーなんかじゃ\nないわ！　ただの……お、おっぱいマッサージよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「マッサージならもっと気持ちいいことをしてやるって？　い、いったいなに\nを……んぅっ！　ちょっと、どこを触って……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「そ……ソコは……んっ、あぁんっ！　濡れてるだなんて……そんなことない\n……あんっ、ちょっと、なに、ペニスを押しあてて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あはぁあんっ！　い、いきなり入ってきたっ！　ニンゲンのペニスが……わ\n、私の中にぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「マンコが、すでに濡れまくっていたせいだって……ンッ、そんないやらしい\nことを、言うな……ぁあんっ！　やっ、動かないで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ペニスが……私の中を、出入りしてる……！　んぁっ、くはぁ\nっ！　ごりごりって、擦れて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「身体が勝手に……ンッ、ペニスに反応して……はぁんっ、こんな……ニンゲ\nンのペニスなんかにぃ……んぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「すごい勢いで、ああっ、中を削り取るみたいに、後ろから突かれて……き、\n気持ちよくなんか……ならないわ……んくぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「こんなところで……こんな、ケダモノみたいな体位でセックスなんて……野\n蛮な人間しか、しないことよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んっ、やめなさいっ、ささやかないでっ。アアッ、耳元で、チンポだの、マ\nンコだの……んっ、ああぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「チンポとか……マンコとか……んくぅうっ、意識しちゃう……チンポ突っ込\nまれてるマンコ、意識しちゃうでしょ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「チンポを、もっと感じろですって……？　汁まみれのマンコを突かれて、気\n持ちよくなれですって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「そんなこと……ニンゲンのチン……ペニスなんかで、エルフである私が……\nマンコ……感じまくるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁんっ！　いっ、いきなり奥までっ、奥までチンポッ！　\nチンポ、ずぼってきたぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「そこはっ、マンコの奥は……ああっ、ああぁんっ！　ダメなのっ、チンポが\n届いたらダメなところなのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んひぃいっ！　やっ、やめなさいっ！　チンポ、そこダメぇっ！　んひぃっ\n！　あっ、あひぃいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「マンコをずぼずぼしないでっ、アアッ、愛液出てきちゃう、ニンゲンのチン\nポにマンコ悦んじゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、あなたのせいよ……チンポを突っ込まれるのは、想像だけで我慢し\nていたのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「こんなふうに、チンポつっこまれて、アアッ、思いっきり、マンコ突かれる\nの……んぁっ、ああっ、想像してたの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「くひぃいいいっ！　マンコ、マンコいいぃいいっ！　チンポがいっぱい、奥\nにまで入ってくるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「こんなにっ、こんなに奥まで届くのね……。ああっ、チンポすごいぃ……実\n物チンポ、想像よりずっとすごいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、ああっ、ああぁっ！　いっぱい、出入りしてっ、んっくぅ\nうっ！　チンポ、チンポ……んぉっ、おおぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ぶっといチンポ、ガンガンくるのぉっ！　エルフマンコほじくりまわされて\nっ、んぁあっ、すごく感じちゃうぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、言わないでっ、ムッツリスケベエルフだなんて……！　ち、違うっ\n、私はムッツリじゃないし、スケベでも……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「一日中チンポのこと考えているような、ド淫乱エルフなんかじゃないのぉっ\n！　んひっ、ああっ、あひぃいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「チンポ激しくなった！　腰が思いっきりマンコの奥を突いてくるぅっ！　ア\nアッ、認めさせようとしてるのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「私のこと……おおっ、スケベエルフだって、認めさせようとしてる……！　\nんひぃっ、ああっ、ああぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「認めたくない……スケベエルフなんかじゃない……！　でも……でも……身\n体が……！　チンポで、悦んじゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ニンゲンのチンポから精液搾りだそうと、マン汁たっぷり溢れさせながらう\nねうね動いちゃってるの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「なっ、中出し！　このまま中出しするつもりなの！？　ああっ、そんな、中\n出しまで許しちゃうなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「違うのっ、中出しされるの想像して、ますますマンコを締めてなんか……ん\nぁあっ！　だめっ、子宮口をチンポでぇえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ケダモノ体位でずぼずぼされながらっ、中出しっ！　ニンゲンの野蛮汁どぴ\nゅどぴゅ中出しされちゃうぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　逃げられないっ！　逃げられないぃいいっ！　精液っ、\n精液だされちゃうぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んひぃいいいっ！　ああっ、ああっ！　きたっ！　どぴゅどぴゅきたぁああ\nあぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「中出しっ、ニンゲンの精液がマンコに注がれるっ！　いっぱい入ってきちゃ\nってるのぉおおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「マンコに……精液びゅるびゅる中出しされるのが、こんなに気持ちいいなん\nて……。頭が……真っ白になっちゃったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……、チンポ……まだ、マンコの中で勃起してる……。ねぇ…\n…もっと、シて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「セックスがこんなに気持ちいいことだったなんて……。知っちゃったら、も\nうオナニーには戻れないわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あなたの知っている、野蛮だけど気持ちいいこと、私にもっと教えてちょう\nだい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あんっ！　そんな、ゆっくりした腰の動き……。さ、さっきまでもっと激し\nく動いていたじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「もしかして疲れたの？　一度射精してヘロヘロになったの？　野蛮なわりに\nスタミナがないのね。チンポ以外は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「チンポはこんなにガチガチで、マンコの壁をぞりぞりこすってくるのに……\nんぅ……はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「も、もっと……動きなさいよ……。んくぅ……こんなの……もどかしくて…\n…。んはぁ……あうぅ……んっくぅう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「なんで……んぅ……もしかして、私を焦らしているの……。んぁあっ、ニン\nゲンに……私が、いいように弄ばれてる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「くぅ……スケベエルフだって認めれば、また激しく突いてやるですって……\nンッ、そんな……ああ……でも、チンポ……ピストン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「わ、わかった……認める……認めるわ……。私はスケベエルフ。チンポ大好\nきなムッツリドスケベエルフだって、認めるからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「だからさっきみたいに、私のマンコをそのチンポでズボズボ突きまくって！\n　お願いぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017301_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、んはっ、はぁああぁぁあんっ！　きたっ、きたっ、チンポぉおおっ\n！　んひぃいっ！　また、激しいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「そっ、それいいのっ！　めちゃくちゃにマンコ突かれるっ！　奥にチンポが\n突き刺さるくらい深いのいいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んひぃいっ！　はっ、んはぁっ！　勃起チンポがごりごりって、マンヒダ削\nるのいいっ、マン汁止まらなくなっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「おおっ、おおっ、おしちゅぶしゃりぇりゅぅうっ！　チンポにっ、わらひの\n子宮っ、どちゅどちゅってしゃれてりゅぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ひぃっ、チンポ、チンポがぁあっ！　中で暴れまわって、んひゅっ、ぶっと\nくなってるの感じひゃうぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「らめっ、らめぇえええっ！　頭っ、トんじゃうのぉおっ！　気持ちいいっ、\n気持ちいいぃいいっ！　チンポ、チンポぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
