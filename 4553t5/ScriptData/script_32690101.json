{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「お呼びですか、あなた。なんてね、ふふ。ここに呼ばれた時点で、もうわか\nってますよ。ええ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「私に、あなたの精液をごちそうしてくれるんでしょう？　否定してもダメで\nすよ。あなたの顔と……匂いで分かりますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103102" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「サキュバスは男の匂いでもその人のことが分かるんですよ……ねえ、お話は\nしながらでもできるし、とりあえず、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00026901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「あんっ！！　ふふっ、相変わらずあなたのオチンポ、素敵だわ……見てるだ\nけで精気がもらえちゃいそう……それじゃ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「まずはこうやって、オチンポをウェルカムマッサージね。ほら、このおっぱ\nいでくにくに、くにくに、あなたが好きな動きよ。ふっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ、おっぱいの中でオチンポが硬くなってきてるわ……んっ、ふ\nふっ、熱くて、太くて……素敵……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「私の谷間も熱くなってきてるの、分かります？　あなたのオチンポと私のお\nっぱい、蕩けて混じりあっちゃいそう……あんっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、オチンポ、完全に大きくなりましたね……ふふ、気持ちいい\nって、びくびく跳ねてます。可愛い……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あなたの腰もひくひく震えてますよ……聞かなくても、気持ちよくなってる\nのが分かります。ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「このままでもいいですけど……こういうのはどうです。脇を締めて、さらに\nぎゅうってオチンポを抱きしめて……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んふっ、密着具合が凄いでしょう？　それで、このまま身体ごと動かしたら\n……んっ、ふっ、んんっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ほら、オチンポがぎゅっぎゅっておっぱいで抱きしめられて、さらによくな\nったでしょう？　オチンポがさらに熱くなってますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んっ、うっ、ふっ……先っぽからとろとろお汁が出てきてますね。おっぱい\nの中、汗とお汁でぬるぬるしてきました……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「これをローション代わりにして、もっともっと滑らかに……あんっ、ふっ、\nああっ、あなたのその顔、気持ちよさそうで……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「顔を見てるだけで私もイってしまいそう……んんっ、あっ、ふうっ、んんっ\n、おっぱいの中でオチンポが暴れて……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「まだ、まだダメですよあなた。もっと、もっと気持ちいいの溜めて、それか\nら私のおっぱいに出して……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ほら、我慢してくれたらきゅっきゅって、おっぱいハグがずっと続きますよ\n。出しちゃったら、もう終わっちゃいますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「好きでしょう、この密着パイズリ。こうして、ぎゅうって抱きついて、上下\nに動いて。あなたのオチンポが隠れるぐらい挟んで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んふうっ、気持ちよくてびくびく跳ねるのをおっぱいで抑えつけたら、もっ\nと気持ちよさが溜まるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふふっ、男の人の、あなたのオチンポならなんでも分かりますから。こう\nいう風に、きつく挟むのが大好きなところとか、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「こうして、柔らかくおっぱいでごしごしするのも好きな所とか、ふっ、うう\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「結局、私のおっぱいならなにをされても好きな所とか……ふああっ、図星突\nかれたからって、腰動かすのダメですよ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ほらいい子いい子、いい子だから射精はまだ我慢ですよ。私のパイズリ、も\nっともっと味わいましょうね、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ほら、おっぱいのお肉で先端をぎゅって潰されるの、気持ちいいでしょう？\n　先走りでぬるぬるしたおっぱいサンドで、こうやって、んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「押しつけながらぎゅっぎゅって動かして、ふふ、あなたのオチンポももうベ\nトベトになってきてる……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「え？　もっと速く動かして欲しいって？　しょうがないですねえ、いいです\nよ。じゃあ、リクエスト通りに……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、うっ、んんっ！！　どうです、高速パイズリのお味は。って、\n聞かなくてもその顔とオチンポの反応で分かりますけど。ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ほら、おっぱいの谷間であなたのオチンポが出たり入ったり、先端が出るた\nびに、ひくひくして出したがってるのが見えますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、もうちょっと、もうちょっとだけ頑張ってください。あなた\nの精液、一番いい状態で欲しいんです、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「私のために、もうちょっと頑張って、ほら、頑張れ頑張れオチンポ、おっぱ\nいが応援してますから、ぎゅぎゅって抱きしめながら応援してますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、そんな歯を食いしばって我慢して……ああっ、私のために、\nんんっ、素敵、やっぱり素敵です、あなた……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103131" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「そんな、そんな顔をされたら、もう……もういいですよ、イっていいですよ\n、あなたの気持ちいいの、全部私のおっぱいに出して！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ほら、出してっ、んっ、私のおっぱいマンコの中に、たっぷりと出してくだ\nさいっ！！　んんっ、んっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「ああっ、来た！！　おっぱいの中で、オチンポが膨らんで、ああっ、来たっ\n、ザーメンきたあっ、あんっ、あああっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「熱い、んんっ、おっぱいがやけどしちゃう！！　あなたのザーメンでおっぱ\nいが溶けちゃう、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふううっ、あっ、凄い、凄い精気……んんっ、おっぱいから全身に\n染みこんでくる……あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「濃くて……熱くて……あなたの気持ちよさが全部私の中に伝わってくる……\nんんっ、おっぱいからザーメン味わって……おいし……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あふっ、んっ、んんっ、おっぱいハグで、オチンポから全部絞り出して……\nあんっ、んっ、おっぱいが妊娠しちゃいそう……ふああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んんっ、素敵でした……私のパイズリ、気持ちよかったみたいでなによりで\nす。ふふ、あなたも溜めこんでいたんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ほら、おっぱいの谷間がザーメンでどろどろに……んふっ、凄い量と匂いで\nすね、男らしい射精でしたよ……あなた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふっ、でも、出した後もまだオチンポ硬いままですね……ねえ、できるん\nでしょう、二回目……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「おかわり……おかわりください。わがままなあなたの女に、ザーメンのおか\nわり、くださいな……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふっ、あなたのオチンポもやる気満々ですね……嬉しい。それじゃあ、ん\nっ、んんっ、んふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ほら、汗と先走りとザーメンが混じりあって、私のおっぱいでぬちゅぬちゅ\nって、いやらしい音が谷間から出てますよ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ねばねばの谷間でのパイズリ、さっきとはまた違うでしょう？　このぬるね\nばパイズリで、またいっぱいザーメン出してください……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふ、オチンポもぶるぶる震えて悦んでますよ……あなたも気持ちよさそう\nな顔……うっとりしちゃう、んっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「はあっ、ああっ、あんっ、なんだか、オチンポでザーメン塗りこめられてる\nみたいで……んんっ、また身体が熱く……ふああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あなたのザーメンだから、こんな風になるのかしら……あんっ、あっ、ふう\nっ、うううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「またこうして、きつく締め上げて……んっ、ザーメンローションでぬるって\n滑って、それがまた気持ちいい……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ぬるぬる、にゅるにゅるって、私のご奉仕パイズリ、気持ちいいでしょう？\n　硬いオチンポが暴れ回ってる……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふっ、また先端が膨らんできてますよ……ザーメン、またいっぱい出して\nくれるんですね。嬉しい、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「いっぱいいっぱい出してください。おっぱいでこうやって抱きしめてますか\nら……んっ、オチンポ、抱きしめてますから……ふっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「隙間なくオチンポに抱きついたおっぱいで、ぎゅぎゅってこすって……んん\nっ、はっ、あっ、触られてないのに、私もイっちゃいそう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、ザーメンと汗が混じりあって、こねた匂いが……あふうっ、\nたまらない……あなたの匂いが……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「匂いからも精気がもらえそう……んっ、ふっ、ふうっ、オチンポ、限界が近\nくなってきてますね、んっんっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「いいですよ。またいっぱい出してくれていいですよ。私のおっぱいに、いっ\nぱいかけて、あなたのザーメン、いっぱいかけて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103216" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「もう我慢しなくていいですよ。ほら、あなたの大好きなサキュバスおっぱい\nに、思う存分、気持ちいいのかけてっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「オチンポ、びくびくして跳ねて、出したいって言ってますよ？　ほら、ほら\n、我慢は身体によくないですから、出して、ザーメン出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、うっ、あんっ！！　出す、出すのねっ！！　私のおっぱいに、\nまたいっぱい出すのね！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ああっ、あっ、オチンポが震えてるっ！！　イって、パイズリでザーメン出\nしてっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んんんんんんっ！！　ふあああっ！！　おかわり来たっ！！　ザーメンおか\nわり来たあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103301" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あんっ！！　谷間からこぼれちゃいそう、んんっ、二回目なのに、凄い量…\n…ふうっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、おっぱいに出されて、私もイっちゃった……ふうっ、うっ、一\n回目のと混じって……おっぱいがたぷたぷに浸されてる……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あなたのザーメン、濃すぎて……んんっ、飲んでもないのにザーメン酔いし\nちゃいそう……んっ、ふうっ、それがいいんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「はあっ……ザーメンからの精気もたまらない……んっ、素敵……気持ちいい\nし、おいしいし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あんっ、いきなり残りを出したら、また……んっ、私も軽くイっちゃう……\nふうっ、あっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふっ、おっぱいがザーメンで真っ白になっちゃった……おっぱいマンコ、\nよかったですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「って、聞くまでもないですね。このザーメンの量と、あなたの顔が証明して\nます……私も凄く気持ちよかったですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「サキュバスだからっていうのもあるけど、あなたのことが好きだから……愛\nしているから、こんなにもよかったんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「だからまた……いっぱいいっぱい、おっぱいに出してくださいね、あ・な・\nた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ああっ！？　なんでオチンポを抜いて……あんっ、あっ、ザーメン、ぶっか\nけて来たあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103401" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んんんっ、私の顔に、んっ、びちゃびちゃって、濃いのが……ふああっ、凄\nい、匂い……嗅ぐだけでイっちゃいそう……ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、んふうっ、それに、この熱さ……ザーメンで顔が火照っちゃ\nう、んっ、ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっ、うっ、ふっ、顔射マーキングザーメンから、精気いただきました……\nんううっ、ふうっ、あくうっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んふっ、嬉しそうな顔……そんなに私の顔にぶっかけたかったんですか？　\nこんな風にしなくても、言えばよかったのに、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「こうして、ぶっかけるのがいいだなんて……ふふっ、まあ、それで悦ぶ私も\n私ですけれど……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ザーメン、全部ぶっかけ終わりましたね……思ったのとは少し違いましたけ\nど、ごちそうさまです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んっ……ふふ、顔射された顔を見てまた興奮しただなんて。でも、私もぶっ\nかけられて興奮してますから、同じですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「今度はどうします？　どうやってザーメンをごちそうしてくれますか？　な\nんでもいいですよ。おっぱいでも、口でも、オマンコでも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「私はあなたの女ですからね……あなたの望むまま、気持ちよくしてさしあげ\nます。それが、サキュバスですからね……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
