{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長、こっちです、こっち。今日はベッドの上で……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204101" ]},
		{"command":[ "SETCHARA", "0", "char_00000812_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「え、顔が赤いって？　そりゃそうですよ……女からこういう風に誘うのって\n恥ずかしいんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204102" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000812_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でも、隊長ならって勇気を出したんですから。隊長のためだけですよ、私が\nこういう風になるのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「今日は……私が全部してあげますから、ベッドに横になってください。そう\nです、ふふ、どうですか、この光景は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ん、相変わらず大きい……隊長も期待してくれているんですね。私も一緒で\nす。隊長とのこの時間……ずっと待ってました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、隊長のおちんちんが私のオマンコにぴったりくっついて……熱くて\n硬くて、入りたがってるのが分かります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ、慌てないでください。ゆっくり、二人で愛しあいましょう。時間はい\nっぱいあるんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「こうやって手を繋いで、ぴったりくっついているだけでも、幸せです。隊長\nはどうですか？　あんっ、腰動かしちゃだめ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「え？　早く私の中に入りたい？　んっ、ずるい……そんな言い方されたら、\n私もそう思っちゃうじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふっ、ああっ、入ってきた……あっ、んっ、分かりますか？　私の中が隊長\nのおちんちんをぎゅって抱きしめてるのが。やんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふああああっ、一番奥までっ、んんっ、あふっ、赤ちゃんの入り口、こつこ\nつってノックされて……ああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「やあっ、隊長、一番奥ぐりぐりってしちゃやあっ、んっ、ああっおっきな先\nっぽが、お腹の奥でごりゅごりゅしてる……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、もう、隊長……今日は私がしてあげるって言ったのに。そん\nな悪い隊長にはおしおきです、えいっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んうっ、どうですか、こうしてゆっくり腰を動かすの、好きですよね……こ\nんな風に、んっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、こうして根元まで入れて……ぴったりくっつきながらぐりぐり\nって押しつけるのも好きですよね。んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んふっ、私も、隊長のおちんちんが中をごりごりってこするの、大好きです\nよ。あんっ、あっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「こうしてオマンコでぎゅってしたら、隊長のおちんちんのカリ首とかが分か\nって……そのまま動かしたら、あんっ、あふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長も私の中がよく分かるでしょう？　手のひらにぎゅって力が入ってるの\n分かりますから。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、隊長の顔、気持ちよさそう……私？　ふふっ、この顔を見た\nら分かるでしょう？　隊長のおちんちん、すっごく気持ちいいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「大好きな人と繋がって、気持ちよくないわけないじゃないですか……んんっ\n、あっ、ふうっ、こうして腰を回転させて、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そのまま上下にピストンすれば……んんっ、隊長のおちんちん、私の中でま\nた大きくなってる……あっ、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、好き、好き、隊長も好きだけど、隊長のおちんちんも好きっ\n！！　どっちも大好きっ！！　あんっ、ふあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、あんっ、こうしてピストンしてると、隊長の形が凄い分かって\n……おちんちんで中が蕩かされてるのが分かって……あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んうううっ、隊長の硬い先っぽで奥をこりこりってするの、好き。んっ、あ\nあっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ああっ、あんっ、あくっ、隊長ので中がいっぱいになってる！！　私の中が\n、隊長ので全部埋めつくされてるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「幸せ……隊長と一緒になれて幸せっ！！　ふああっ、あっ、んんっ！！　気\n持ちいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「じゅくじゅくって、私の中がかき混ぜられて、隊長のおちんちんでどろどろ\nにされて、んんっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「カリ首がごりごりって中をこすって、んんっ、もう私の中全部、隊長に好き\nにされて……でも大好きだから、幸せっ！！　ひあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「手とオマンコの中で隊長にしがみついてるの、分かりますよね。私、もう隊\n長と離れたくない、離したくないっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんんんっ！！　急にそんな激しくっ！！　やあっ、ああっ、あっ、隊長も\n、離れたくないって、あんっ、嬉しいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「大丈夫、私は隊長のものだから、おっぱいも、手も、顔も、心も、オマンコ\nも全部隊長のものだから、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「だから今だけは、私としてるときだけは、隊長も私のものになって！！　あ\nんっ、ああっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あうっ、んんっ、あっ、隊長のおちんちん膨らんできて……出すんですね、\n出したいんですね、いいですよ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私の中に、隊長の精液を好きなだけ出してっ！！　いっぱい出してっ！！　\nどろどろのオマンコに精液出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、こうしてきゅって締めつけてますから、隊長の精液、一滴もこ\nぼさないようにしてますから、好きなときに出してっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふああっ、あっ、来たっ！！　隊長の精液、来たあっ！！　んんっ、熱くて\nどろどろの、濃いのが私の中に来たああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっ、気持ちいいっ、隊長からの中出し気持ちいいっ！！　私も、私もイく\n、イっちゃう、イっくううううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んああっ、あっ、凄い、もうオマンコも、身体も、全部溶けて隊長と一緒に\nなってるみたい……ふううっ、ああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「オマンコが隊長の精液、ごくごくって飲みこんで、もっともっとっておねだ\nりしてる……やあっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、おちんちんと精液で、私の中がいっぱいになってる……これ\nが幸せってことですね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、凄い、出したばかりなのに、隊長のおちんちん、まだ硬いま\nま……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ねえ、こんなに硬いならもう一回……いいでしょう？　私も一回愛してもら\nったぐらいじゃ物足りないですから……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ、返事をする前に隊長のおちんちんが応えてくれましたね。じゃあ、こ\nのまま……んっ、あんっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「さっきと同じように締めつけても、隊長の精液でぬるぬるになってて……あ\nんっ、また違う感じが……んっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、じゃあこういう動きはどうです……ほら、ふふっ、私もちゃん\nと勉強してるんですよ。隊長を喜ばせるために……んんっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「中の動きも、こうして変えれば……ひゃんっ！！　あっ、隊長も動き変えた\nら、私、また、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「もう、悪い人なんですから。そんな人には、えいっ！！　あんっ、あっ、こ\nの動きでおしおき、ひああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふあっ、あああっ、んんっ、私が動かなきゃいけないのに、隊長のおちんち\nんで溶かされてる……あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長の、あっ、おちんちんが……私の中で暴れてて……んんっ、オマンコで\n抱きしめてないと抜けちゃう、ああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふううっ、あっ、あっ、気持ちいいっ！！　隊長のおちんちんが奥をごつご\nつって叩いて、頭の中、蕩けちゃう……あううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「待って、待って隊長、そんな動かれたら、連続でごつごつってされたらおか\nしくなっちゃう！！　おちんちんのことしか考えられなくなっちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「おかしくなった私もエッチだって……あんっ、ああっ、あっ、そんなの、そ\nんなこと言われたら……ひああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長、隊長！！　大好き、愛してます！！　だから隊長も私の全部、愛して\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ひあっ、ああああっ、またそんなにいっぱい突かれたら、もう、もう、私、\nだめになっちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長のせいでだめになっちゃう！！　おちんちんの気持ちよさだけ考えちゃ\nう！！　隊長！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっ、あああっ！！　イって、隊長もイって！！　私の中に、オマンコに、\nいっぱい精液出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長も私のオマンコのことだけ考えてっ！！　んんんっ！！　隊長の精液で\n、私の中を満たしてっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「全部全部、私を隊長のものにしてっ！！　好きっ！！　好きいっ！！　隊長\nの全部、好きっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あううっ、くっ、ああっ！！　イくっ！！　隊長のおちんちんで、またイく\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長もイって！！　気持ちいいの、全部出してっ！！　あっ、くっ、イっく\nううううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふああああああああっ！！　出てるっ！！　また出てるっ！！　中に、隊長\nの全部出てるっ……あうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんんっ、二回目なのにまだいっぱい……どくどく脈打ってて、私のオマン\nコが精液で溺れちゃう……ふああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「お腹の奥がたぷたぷで……あんっ、まだ出てる……んっ、オマンコも喜んで\nぎゅっぎゅって搾り取っちゃう……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、隊長が出してくれてるこの時間も好き……ふふっ、愛されたって証拠\nが私の中に残されていってるから……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ、これだけ出されたら、赤ちゃんできちゃうかもしれませんね……隊長\nと私の赤ちゃん、きっと可愛い子になりますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ひゃんっ！？　今の言葉でまた精液が出たって……それって、隊長も私との\n子供がほしいってことですか？　だったら、嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んふっ、もしも子供ができても、私は隊長のこともずっと愛してますからね\n……隊長を思う心は変わりませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「だからまだまだ、いっぱい中に出してくれていいんですよ。私は隊長の気持\nちいいの、全部受け止めますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ……お腹の中、温かい……これが隊長との愛なんですね。男と女の、私\nと隊長の愛の証……嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長、私今幸せです。隊長のおかげで。それで、隊長も幸せだともっと嬉し\nいな……また、いっぱいしましょうね隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっ！？　隊長、なんでおちんちん抜いて……あっ、先っぽが私の方に……\nんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、すごいっ！！　隊長の精液が私の身体にいっぱい……熱くて……匂\nいもすごい……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「中も外も、隊長ので染められて……ああっ、これが隊長のものになるってこ\nとなんですね……ふっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「中に出されるのもいいけど、かけられるのも気持ちいい……熱くて、ぬるぬ\nるで……私が隊長の女だって示されてるみたい……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「できるなら、このまま基地の中を歩きたい気分です……そうしたら、私が隊\n長のものだって皆が理解するでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、今の言葉で興奮して最後の一滴が出た？　ふふ、言葉にしなくても\n、私が隊長のものだって分かってるでしょうに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ、でもこうして隊長の精液でマーキングされるのは素敵ですね……気\n持ちいいし、なんだか誇らしくもあります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ、それに隊長の独占欲のしるしみたいで、それも嬉しい……匂いもいっ\nぱいで、隊長に包まれてるみたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000812_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ……隊長、これからももっともっと私に隊長のしるし、いっぱいつけて\nください。中も外も、隊長の好きなときに、好きなように……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「愛されることの嬉しさも、愛することの嬉しさも、隊長に教えてもらったん\nですから……私はずっと隊長の側にいますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
