{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「こ、こんな、格好で、ですか？　嫌じゃないです、けど……で、でも、私、\n初めてだから、怖くて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「だって、隊長の顔、これじゃあ見えないですよ。それに、何をされるのかも\n、分からないですし……だ、だから、見つめ合ったままの方が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はう！？　お、お尻、撫でられてる……た、隊長、話、聞いてましたか？　\nお願いですから、普通の格好で……ひうう！？　また、お尻ぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ひゃんん！　今度は、太もも……やぁ。太ももは、駄目、なんですぅ。駄目\nって言ってるのに、まだ、優しく、撫でてくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あ、あの、隊長。私の太もも、太くないですか？　筋トレのやり過ぎて、ど\nうやっても、細くならなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「だから、あんまり太もも、触らないでもらえると、嬉し──ひあうぅ！？　\nい、言ってる側から、またぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「やぁ、だめぇ……触っちゃ、駄目ぇ。そんなところ、触っても、全然、楽し\nくなんか、ない、ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「……や、柔らかいって、嘘です。太くてかたくて、女の子らしくない太もも\nだって、ちゃんと自覚、してますもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「……そんな。私らしくて、とても強くて凜とした太ももだなんて。あうぅ…\n…私、ずっと、太くて筋肉質な太もも、コンプレックスでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「嬉しい、です。そこ、褒めてもらえるなんて、嬉しくて、ドキドキしちゃい\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あ、ふああ！？　おちんちんが、あたってる！？　あそこに……あ、あああ\n！？　ゆっくり……んんん！　入って、くるぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んああああ！　あ、あぁ、ああ……うそ、入っちゃっ、た。こんな、簡単に\n、入っちゃったぁ……私、初めて、なのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ん、ん、ん、ん、ん！　しかも、おちんちん、いきなり、動いてぇぇ……動\nいて、る！　前後に、動いて、出たり入ったり、してるぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ひあ、あ、あ、あ、あ！？　い、痛い、です！　こんな、痛さ、だったん、\nですね、これ！　んんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「いや、だめ！　やめちゃやだ！　そのまま、最後までしてくだ、さい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「一生に一度の痛み、隊長に刻まれるの……う、嬉しい、です、からぁ……だ\nから、このまま、して、ください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んんんん！　中で、おちんちんが、膨らんだ！？　ひあ、あ、あ、あ、あ！\n　動きも、速いぃぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ひぐ、あ、あ、あ、あ！　おちんちん、すご……ひああ！　あちこち、中、\n当たって、ますぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「出っぱってる部分が、私の、中を、たくさん、たくさん、こすって、あちこ\nち、当たってぇぇぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「なにこれなにこれなにこれぇ！　こんなの……エッチって、こんな、感じだ\nった、なんてぇぇぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ひううう！？　お、お尻の、穴ぁ……指、当たって、ますぅ……お尻の、穴\nぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「駄目、駄目ぇぇぇ！　そんなところ、触っちゃ駄目ですぅ！　指で、ぐにぐ\nにって、お尻の穴、揉まないでくださいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ひあ、あ、ああ！？　しゅ、しゅごい……それ、しゅごいぃぃ。ぐにぐに、\nされながら、おちんちん、ずんずん、出たり入ったり、しゅごいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「初めての、エッチで、後ろから、おちんちん入れられて、お尻の穴も、いじ\nられるなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ひぃぃぃ！？　指ぃ……指が、どんどん、入って、くる……お尻の穴に、入\nって……うそうそうそうそうそ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ひああああああああ！　あ、ああ、あが、あ……入っちゃったぁ。お尻の穴\nに、指ぃ……入っちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あ、あ、あ！？　両方の穴、しゅごいぃ。隊長のおちんち\nんと、お尻の穴、指でぐにぐにされるの、しゅごいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「も、もっと、してください！　もっと、私のこと、いじめてください！　痛\nくしてもいいですからぁぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ひんん！　お、お尻、叩かれたぁ……ひん！　あん！　ひゃんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あ、あはぁ……叩かれたところ、じんじん、しましゅぅ。じわぁって、痛い\nの、広がってくぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「駄目駄目駄目駄目駄目ぇ！　それ、気持ち良すぎて、なにか、来る！　来て\nます！　お腹の奥に、なにか、凄いの、来てるぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あ、ああ、んあああ！　来る！　来るぅぅぅ！　隊長！　\n私……ひ！？　隊長のおちんちんも、膨らんで！？　あ、ああああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んあああああああああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_10" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ひうう！？　熱いぃぃ！　熱いのが、中にぃ！　お腹の奥に、出てるぅ！　\nもしかして、これ……ひううううう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んあっ！　あ、あぁ、あ……ふあぁぁ……な、なんですか、今の。もしかし\nて、今のが、その……絶頂、ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「それに、熱いのが、私の中に……精液、中に出しちゃったんですね、隊長。\nえへへ、いいんですよ。こうなるの、覚悟はしてましたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ、はぁ……それにしても、つ、疲れ、ました。エッチって、こん\nなにも、疲れるもの、だったんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「でも、その……き、きき、気持ち、良かった、です。絶頂するときは、なん\nだか怖かったですけど、でも、気持ち良かった、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「隊長も、気持ち良くなってくれたんですよね？　だって、私の中、隊長の精\n液で、いっぱいですから。これ、身も心も、暖かいですぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あ、あの、隊長。その……また、してくれますよね？　私、隊長がまたお尻\nを叩いてくれるの、待ってますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あ、あれ……？　あの、隊長……その、お尻……当たってるんですけど……\nこれは、どういう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「それは、確かにまたって……言いましたけど……い、今からなんですか？　\n続きって……そんなにすぐとは思わなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「い、いえ……！　別に……ダメとか……そういう訳では……は、はい。あの\n……宜しく……お願い……します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「何だか、その……改めて挨拶するのは……は、恥ずかしいですね……あぁっ\n、んんんっ、た、隊長っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、またっ……おちんちんっ……な、中に……入っちゃいました\n……ぁっ、うっ、くぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ど、どこにって……そんなの……分かってるじゃないですかっ……んくっ、\n自分で入れておいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「わ、私が言うから興奮する……ま、また変態みたいなことをっ！　じゃない\nと……動かさないって……卑怯ですよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「だからっ……その……お……まん……こ……です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「い、言いました！　おまんこっ……おまんこですってばっ！　ひぁっ！？　\nあっ、あひぁぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「そんなっ、隊長……急にっ、激しくっ……あっ、あぁっ、どうして……こ、\n興奮したからってっ……ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んぁっ、やだっ、こ、擦れるぅっ！　おちんちんっ……中っ、あっ、痺れて\nっ……くっ、んぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「い、痛みはっ……もうっ、そんな……ないですけどっ……けどっ、違うのが\nっ……あっ、またお尻っ、指っ……あ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ダメっ……はぁっ、おかしくなりますっ！　一度にされてっ、頭が……ボー\nッとしてっ、きっ……気持ちいいっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「さっきは……キツかったのに……んんっ、奥に……入って……くぅんっ、お\nっ、おまっ……んこっ、あぁっ、ジンジンしますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「何でっ……痛かった筈のがっ……全然違うっ、あぁっ、じわって……変なの\nっ……私の中でぐるぐるしてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あひんっ！　あっ、今、お尻ぶたれたらっ！　こんなのっ、すごすぎてっ…\n…どうしたらっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「み、身を……任せてっ？　は、ひっ！　もうっ……何でもいいですっ……隊\n長の好きになさってっ……このまま続けてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「私もっ……んくぅっ、はっ、あぁっ、これっ……このままっ飛びますっ……\n絶頂っ……しちゃいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
