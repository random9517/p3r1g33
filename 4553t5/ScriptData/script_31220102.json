		{"command":[ "SETIMAGE", "0", "still_00012201_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、どこでも……お好きなっ……所にぃっ……あっ、んぁぁぁぁ\nっ！」", "NORMAL" ]},
