		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……さっきより……ずっと凄い……これが……せっくすぅ……は…\n…ぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「は……ふっ、もうすぐ……終わりますか……？　はい……んっ、私は……大\n丈夫ですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「全部……出し切って下さい……んぁふっ……あぁ……変に残しても……もう\nして、あげませんから……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んっ、これで最後ですか……？　はい……んふっ……あぁ……全部……受け\n止めちゃいました……は、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「まさか……こんなになるなんて……夢にも思いませんでした……最初で分か\nったつもりになって……でも、更にすごいのが来ちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
