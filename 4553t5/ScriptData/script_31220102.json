		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「も、もう一回……中にっ……は、はいっ、出してっ……またっ、下さいっ…\n…中出しっ、してぇっ！」", "NORMAL" ]},
