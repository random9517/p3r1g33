		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁーーーっ！　あっ……あぁっ、また中にっ……あふっ、出\nてます……熱いの……んっ、いっぱいにぃ……！」", "NORMAL" ]},
