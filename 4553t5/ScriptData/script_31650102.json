		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「センパイ……んんっ、あ、ふっ……まだっスかぁ……？　んっ、はぁ……ん\nっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そりゃあ、オナニー見せるって言いましたけどぉ……んっ、くぅんっ……は\nっ、ふっ、もうオマンコ……ぐじゅぐじゅでぇ……あ、ひっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「乳首もぉ……ビンビンで……はぁんっ、めっちゃ……うずくっスよぉ……あ\nっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「やっぱ、一回イクまで……するんスか？　これ、結構……ハズいんスからね\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ちゃんと……イッたら、ご褒美……ゼッタイっスよ？　センパイチンポ……\n必ずハメてもらいますからぁ……あふぁっ、んぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「くぅぅ……んっ……ヤバぁ……はぁ……クリが硬くなってるぅ……ここぉ、\n転がしてぇ……あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「マン汁……どんどん溢れてくるっスぅ……はぁ、んっ、見て下さい……オマ\nンコ……ぐちょぐちょぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁ……このまましたら……あっ、はんっ、あっ、んんっ……イクッ……ん\nっ、くぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ……はぁ、はぁ……はぁ……軽くですけど……イッちゃいましたぁ……\nね、もうちゃんとイッたから……いいですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「もぉぉ、ここまで来ておとぼけはナシっスよぉ！　オマンコッ……オマンコ\nぉっ、センパイのチンポが欲しいオマンコですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そうです……そのまま、んっ、チンポ当てて……あーしはずっと待ってるん\nですからぁっ、ずぶって一思いにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あっ……んくぅぅぅんっ！　来たっ……チンポッ……あっ、くぅぅぅぅぅぅ\nんっ！　入って……来ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んぁぁ……ハマったぁ……オマンコぉ……チンポがずぶって……埋まっちゃ\nいましたよぉ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んんぅ……もっと奥まで入れて下さい……んっ、あーしのオマンコぉ……み\nっちり来てぇ……あ、ふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はひぃ……んっ、深いとこぉ……届きましたぁ……センパイのチンポ……や\nっぱり太いっス……く……んんぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ……でも、だいじょぶっスよ……これ、ちゃんとヌルって受け止められ\nますから……ズンズン、突いちゃって下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あーしも、んっ、ちゃんと……オマンコ、キュってして……お迎えしますか\nらぁ……はい、あっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、あんっ、あっ、あぁっ、センパイのっ、ぐりゅって来てるっ…\n…本気のチンポッ、動いてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あっ、すごっ！　これっ、すごっ！　やばっ……全然っ、オナニーと……違\nうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、チンポッ……入ってくる度、カラダが……ビクってなって\n……んっ、くぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「出る時っ……ゾクゾクって……はひっ！　あぁぁっ、いっ、いいっスぅっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふっ、んくぅん……センパイどうですか？　あたし……オマンコ、ユルユル\nとかじゃないですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そりゃあ……心配するっスよぉ……自分ばっか気持ちいいのに、センパイが\n全然だったらやじゃないスかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「でも……んっ、ちゃんといい感じならよかったぁ……もっと、腰とか振った\n方がいーのかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あ……いいっスか？　その代わり……おっぱいもっと自分で弄れって……は\n、はぁい……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「わ……これ、ヤバ……あっ、チンポされながら……乳首とか……こねるのっ\n、めっちゃ……いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はんっ、あんっ、さっきのより……ずっと痺れてっ……あひっ！　オマンコ\nもっ、ジンジン……しますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、もっと……ぐりぐりして下さいっ、センパイのぶっといチンポい\nいっ、ヒダヒダ擦れるのっ、感じるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ふぁぁっ、ヤバいっス……こんなのっ、味わっちゃったらぁっ……もうっ、\nあーしっ、チンポの虜になっちゃいますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、そこぉっ、あぉっ、ごりゅってっ……オマンコもっ、こんなに\nなるのっ、初めてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、あぁっ、またっ……イキそっス……！　センパイはっ、セン\nパイはどうですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「出そうっ……！？　ならっ、このまま……オマンコに直接っ……中っ……い\nっぱいにして下さいっ、センパイのせーえきっ、中に欲しいっス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はひぁっ、あーしもっ……イクっス！　んんっ、オマンコいいのっ、あひぃ\nぃぃんっ！　イクぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……あっ、んんんっ……あっつぅいの……あぁぁ……ドクドクって\nぇ……これ、やばぁぁ……んくぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「中に出されるって……こんな感じなんスねぇ……んくぅ……気持ちよすぎぃ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はひ……あぁ……何か、まだアタマん中がふわふわしてぇ……変な感じっス\nぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ……射精……終わりましたか？　はぁ……ふぅ……あーし、何も出来な\nかったスけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「そんなこと……ないっスか。えへへ……何だかんだで、やっぱセンパイはや\nさしーっスね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「でも、よかったっス……ちゃんとセックス出来ました。えへへぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あっ……でも、センパイのチンポ……また、中でおっきくなって来てます…\n…は、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「これ、気のせいじゃないっスよね？　まだまだ、センパイは……あーしのオ\nマンコ……使いたいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はい……！　もち大歓迎っスよ？　もっと、オマンコぐちゅって……チンポ\nでかき混ぜて欲しいっス……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ほらぁ、今ならセンパイのせーえきがたっぷりでぇ……ヌルヌルがいー感じ\nになりそうですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あっ！　んぁぁんっ！　あひっ！　センパイがっ……めっちゃサカッてるっ\n！　チンポっ……激しいの来たぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あぁっ、オマンコッ……ずりゅずりゅってっ……ヒダがっ、めくれてぇっ…\n…あはぁんっ、音っ……エッロ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ヤバぁ……オマンコの中ぁ……チンポでかき混ぜられてるぅ……じゅぷじゅ\nぷっ、凄い音しちゃってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あぁっ、そこっ、チンポそこぉっ！　奥ぅっ、押し付けて……グリグリして\n下さいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はひぃぃっ！　こんなの堪んないっ！　またすぐイクッ……続けてイッちゃ\nいますっ！　んひぃぃぃんっ、オマンコイクぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あ……はぁっ、はぁぁ……んっ、あぁ……またイッちゃった……センパイの\nチンポまだなのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ、だいじょぶ……ですぅ……続けて下さい……アタマ、クラ\nクラしますけどぉ……この感じ好きなやつれふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んっ……ふぅぅぅんっ……あーしもっ、もっとぎゅーって……オマンコしま\nすからぁ……またズボズボして下さいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、あんっ、あんっ、んぁっ、あんっ、あっ、はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「すご……んんっ、センパイのチンポ……ぎゅうって締めようとすると……勝\n手に声が出て……止まらないっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、おっぱいも気持ちよくて……んっ、はい……揉みくちゃに\nして下さい……んぁ……はぁっ、いい……あひぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「んふぁ……もっとギュってしてぇ……カラダ……くっつけると……キモチと\nろけてぇ……すっごい感じるんれすぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「センパイもっ……またっ……出したいっスか？　んっ、チンポッ……ビクビ\nクしてるの、そうなんですよねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0104217" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETIMAGE", "0", "still_00016501_02_07" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「大丈夫れふっ、強くしてもっ……あーしっ、ちゃんとっ……受けますからっ\n、それでっそれでっ……！」", "NORMAL" ]},
