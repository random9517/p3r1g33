		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁむっ、ちゅぱっ、んふっ……なんて言ってる私も……んんっ、結構…… \nおっぱい……張り詰めてる感じ……は……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「パイズリしながら……どんどん気持ちよくなって……んっ、結構……イッち \nゃいそうに……なってるかも……ふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んんっ、ふふ……なんてこと言ったら……またチンポピクピクさせちゃって \n……このスケベ……ん、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303216" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「そーいう、エッチなチンポの持ち主は……もう、一気にイカせてあげないと \nね……りゅぷっ、じゅぱっ、んちゅぷっ、ほらっ、ほらっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「無駄な抵抗はやめて……また……いっぱい出しちゃおっ……んふっ、りゅぷ \nっ、じゅぷっ、んじゅるるっ、ちゅぷっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「また飲んだげてもいいし……顔に掛けちゃっても……いーよ……？　ほれほ \nれ、欲望まみれのチンポはどうしたいのかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んりゅぷっ、じゅぷっ、さあ……身を委ねて……じゅぷっ、ちゅぷっ、また \n……思いっきり……イッちゃえっ……んじゅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303220" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んんんんんんっ……！　ふぶっ……んっ、射精……んんっ、始まったぁ…… \nんんっ、んふぅぅぅっ、こくっ、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んく、こくんっ……どんどん出てるし……んふっ、おっぱい……もっとシコ \nシコして、ドピュドピュ出しちゃおうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷぅぅっ……んふっ、ふご……飲みきれない……んんっ、こくっ \n、んっくっ……んふぅっ、ぷぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んふっ……めちゃくちゃ出したね……まだ、もうちょっと… \n…？　ちゅるっ……いーよ……吸い出しちゃおう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ちゅるるるっ、んちゅうぅぅぅっ……んっ、ドロっと纏わりつく感じ……や \nっぱり濃いよね……んじゅるっ……ちゅぷっ、んはぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はふっ……はい、おしまい。ふふ……チンポ、いっぱい出したね……よしよ \nし、よく頑張りました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「もうちょっとだけ後始末しよっか……ちゅるっ、んちゅっ、んちゅぅぅぅ… \n…んむっ、りゅぷっ……うん……これでよし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はふ……おっぱいのローションは、シャワーで流しちゃうしかないね。 \n垂れた精液は……んっ、ちゅぷっ、今飲んじゃえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、ふふっ、勿体なかったから。後はもう流すしかないけど、ちょっ \nとだけなら……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「気持ちよかった？　んっ、なら良かった。これで今日の分のお礼はＯＫって \nことで。じゃ、戻ろっか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「きゃふっ……！　んぁっ……慌てて腰引いて……なに……そんなに私の顔に \n掛けたかったってこと……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んふっ、んっ……まぁ、いいけど……なら、もう少しパイズリして……んっ \n、ふっ……全部出しちゃいなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あふっ、あぁ……むわっとするぅ……私もちょっとイっちゃったから……何 \nだかすごくエッチな気分……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ほら、もう少し残ってるんでしょ……？　チンポの先から精液出てくるとこ \nろ……ちゃんと見せて、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ぎゅうって寄せてぇ……あっ……ふふっ、出てきた出てきた……びゅるって \n出てくるの面白いじゃん……んちゅっ、ぺろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「えへへ、舐めちゃった。これで、出し切った感じ？　んっ、いっぱい出せて \n頑張ったねー、お疲れさまっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303406" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「最後にちょっとだけお掃除してあげる……ちゅっ、んちゅっ……ちゅぷっ… \n…これは特別なんだからね……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「おっけー、終わり。おっぱいよかった？　えへへ、それはそれは、お粗末様 \nでした。なーんてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「えっ、また……今度もして欲しい……？　うーん、そうだねぇ……どうしよ \nっかなぁー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ま、またショーをしっかり手伝ってくれたら、考えたげてもいいよ。ふふっ \n、そんな感じで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
