		{"command":[ "PLAYVOICE", "v2_219_0303134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「じゅるっ、ちゅぱっ、パイズリもっ、ラストスパートするからっ……チンポ \nっ……もう少しだけ、頑張って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303135" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、んふぅっ……はむぅっ、んぷっ……じゅるるるっ、んじゅぅぅ \nぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　ぷぁっ……んぐっ、元気……いいっ……んぐっ、こくっ… \n…んくんっ……んんっ、こくっ、ごくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ふごい……量……全部……飲めないっ……口……溢れて来る……んりゅぷっ \n、こぼれひゃう……んんっ、こくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ぷはぁっ……一気に飲んじゃった……はぁ、んっ、結構……美味しい……か \nも……んっ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あふ……どうだった？　へへー、結構よかったんじゃないの？　チンポ…… \n喜んでたもんねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「おっとと……おっぱいの中で、まだチンポ……ビクビクって動いてるじゃん \n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「なーに、これ……まだ続きしてほしいってこと？　んー？　どうなのかなー \n？　もっと責めて欲しいって感じなのかなー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はいはい、全くこんな時は、めちゃくちゃ素直なんだから……じゃあ、その \n正直さに免じて……よっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んっ、また……もうちょっとローション足そっか。後は、キミが出した精液 \nも一緒に絡ませて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁ……うわぁ……ぐぽ、だって……この音……いくらなんでも、やらしす \nぎじゃない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「さっきより、チンポも反応してるし……また舐めて欲しいわけ？　しょうが \nないなあ……はむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んくぷっ、ちゅぷぅぅぅっ……んっ、ちょっとローションまで舐めちゃって \nるし……んりゅっ、ねとねとだよ……れる、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んふぁ……でも、精液が混ざった分、もっと濃い味になってきてる……んっ \n、ちゅぷっ、えろ……れろんっ、れりゅ……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あぁんむ、どぉ……？　一回出したから……チンポ……ビクンって敏感にな \nっちゃってるれひょ……ちゅぷっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303209" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「でもぉ、こうひて……んっ、やさーしく、ペロペロしてたらぁ……ちゅぱ、 \nぴちゃっ……すっごく気持ちいーんじゃない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んふふっ、そっかそっか……うんうん、おっぱいもしてあげるからね……む \nにむにっ……柔らかいの、いー感じ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「分かりやすく声出てるし……チンポの先のこの辺とか……うん、やっぱり弱 \nいんだねぇ、へへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303212" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぅぅっ……弱点を集中攻撃するのは基本中の基本だよね…… \nんっ、ほれほれ……もっと喘いでごらん？」", "NORMAL" ]},
