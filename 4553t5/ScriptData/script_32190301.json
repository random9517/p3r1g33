		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「そうだね、キミもすごく頑張ってくれたよね。人手少ないから、助かったよ \n。感謝してる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「えっ、感謝は言葉よりももっと現実的なもので欲しい？　なーに、バイト料 \nならちゃんと出して……えっ、違う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「おっぱいで……パイズリフェラ……あぁ……それで、こんな人気のないとこ \nろに連れてきたってワケか……なるほどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「全く……しょうがないなぁ……でも、今日は本当に頑張ってくれたのは確か \nだし……どうしてもって言うなら……いいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303105" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「分かった、分かったから、そんなに前のめりでうなずかないっ！　じゃあ… \n…もうちょっと奥の方へ行って……見えないとこ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303106" ]},
		{"command":[ "SETCHARA", "0", "char_00021903_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んっ、しょっ……全く……断りきれないって分かってるからなのかな……ち \nゃんとローションまで用意してるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
