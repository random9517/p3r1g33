		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ふー、お疲れ様。なんだかんだでショーは大盛況だったね。んーっ、楽しか \nったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303101" ]},
