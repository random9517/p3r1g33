		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「うん、たっぷり垂らしたから……谷間の中……ぬめぬめだよ。これで、パイ \nズリご奉仕してあげるね……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んっ、しょっ、あはっ……もうビンビンにさせてる……そんなにチンポ…… \n待ちきれなかったんだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「谷間でビクビク震えてるし……あれだけショーで動き回ってたのに、まだま \nだ元気なんだから……よい、しょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、どう、かな……んんっ、にゅるって……チンポ……よく滑 \nるよね……はふっ、んっ、くぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「気持ちいい？　ふふっ、たっぷりローションをまぶしただけのことはあるね \n……おっぱい……ぬるんって滑ると……私もいい感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ん、っしょっ、よい……しょっ、一日……お手伝い、お疲れ様でした……私 \nの……おっぱいで、しっかり癒やされて……ねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ……ふふっ、チンポがおっぱいの中でビクビクしてる……これ \nだけ分かりやすく喜んでくれると嬉しいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「いいよ……もっと、してあげるから……このちょこんと顔を出してる亀さん \nのところ……舐めて欲しいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303115" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「あぁんっ……ぺろっ、れろ、えろ、ちゅぷ……んちゅぷっ、ぴちゃ……れろ \n、れる……れろぉ……れろ、れる……れりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んっ、もうローションいっぱいだから……そんなに唾液足さなくてもって思 \nったけど……ぴちゃ……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「くぽっ、んりゅぷっ……ねろ、れろぉ……えろ、れる……りゅぷぅ……チン \nポ……舐めてると、私の方が……自然に溢れて来ちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、じゅぱっ、はむぅっ……んふぅっ、咥えひゃった……♪　りゅぷ \nっ、きもひよく……していくね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、じゅぱっ、ちゅぶっ、んくぷっ、うんっ、んりゅっ、くぷっ、 \nじゅぷっ……ぴちゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「れろ、んんっ……舐めながら……ぎゅっと……おっぱいも揺り動かしたげる \n……んふっ、くぷっ、はっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んふぅっ……いっぱい汗かいたでしょ……んりゅっ、結構……ニオイ……キ \nツくなってるからね……？　ちゅぷっ、んむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「まぁ……私は……そんなに嫌いじゃないから、いいんだけど……ぴちゃ、ん \nちゅっ、ちゅぅぅぅっ、んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ていうか、まぁ……ぶっちゃけ好きかも……んっ、クセはあるけど……ちゅ \nぷぅぅぅっ、じゅるるっ、んふ、じゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んふっ、チュウって吸う度……チンポ……面白い位ビクビクしちゃってる… \n…んりゅっ、じゅぱっ、ホント正直なんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「いーよ、もっと舐めてあげるから……れろ、んちゅっ……それで、おっぱい \nの方も……うりうりっ……ぐりぐりっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んふっ……どう、柔らかいでしょ？　んっ、サイズはともかく、形のバラン \nスはそれなりに自信あるんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「ほら……乳首だって……んっ、感度もよくて……当たると……いい感じ…… \nでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んふっ、はぁっ、んちゅっ、ちゅぷっ……ビクビクが大きくなってる……い \nつまで我慢できるかなぁ？　ちゅぷっ、んちゅ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ローションがにちゃにちゃいって……やーらしぃ……んくぅ \n……おっぱいも、もっと滑らせちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303130" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、チンポと……ローションがめちゃくちゃ絡んで……動かして \nるだけで……はぁぁ……めちゃくちゃ気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「うんっ、はぁっ、あ……んっ……ヤバいね……おっぱい……止まらない…… \n私もどんどん動かしたくなってきちゃう……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、くぷっ……んっ、あぁ……カウパー……出てる……そろそろ…… \nあっ、んっ、射精したいんでしょ……んじゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_219_0303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00021903_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "タコ乙女" ]},
