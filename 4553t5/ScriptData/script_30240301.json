{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「さすがは私ね！　このレイジョーローズの衣装も、完璧に着こなせてるわ！\n　あなたもそう思うでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00002403_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「……似合いすぎてて、見てるだけでオチンポが大きくなってくる？　な、な\nなな、なに言ってるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00002403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「こんなところで大きくして……！　し、仕方ないから、小さくするのを手伝\nってあげるわ！　感謝しなさい！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00002403_01", "4", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んちゅ……ちゅ、ちゅちゅ……ふふふっ。どう？　乳首舐められながら、手\nでオチンポシコシコされるの、気持ちいいでしょ？」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "PLAYVOICE", "v2_024_0303104" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「衣装も可愛いし、手袋の感触がスベスベしてて気持ちいい……？　そ、そん\nなこと言わなくていいわよ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「まあ、でも……可愛いって言われるのは、素直に嬉しいわ。お礼に、いっぱ\nい乳首舐めてあげる……ちゅぱっ、じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぱっ……ねえ。普段の私とゴレイジョーな私……どっちがあなた\nの好みかしら？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「どっちも可愛いから、選ぶことなんてできないって……な、なに恥ずかしい\nこと言ってるの！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふん……！　どっちか決められない、優柔不断な悪い人は……レイジョーロ\nーズがセイバイしてあげるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「この勃起した悪いオチンポから、汚いザーメンをたくさん吐き出させて……\n素直にさせてあげるんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅりゅ……ちゅ、ちゅぱっ……んっ、あっ、ぐちゅ……オチンポだけじゃ\nなくて、乳首もカタくなってきてるわね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「こんなに大きくなってたら、舐めやすいわ……あっ、もしかして、舐めても\nらいたくて、ワザと大きくしてるのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふふっ……そんなことないって顔しても、乳首は正直なのよ……ちゅぱっ\n、んちゅ……れろれろっ、じゅずっ、ちゅるるっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「舌先でペロペロしてると、オチンポもビクビクって反応して……んっ、ちゅ\nちゅ……我慢汁が溢れてきてるわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「もう……こんなに出されたら、手袋にローションがかかってるみたいで……\nんっ、あふっ……！　し、シミができちゃうじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅぱ、くちゅ……！　どんどんオチンポの滑りがよくなって、エッチなニ\nオイもしてきてるわ……我慢汁の量が多いのかしら……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「手袋の感触があるせいで、普段より興奮してるの……？　な、なによそれ…\n…いつもシてあげてる手コキじゃ、物足りなかったってこと……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「誤魔化したってムダよ！　オチンポの反応からして、いつもの私より、レイ\nジョーローズの私の方がいいって、言ってるようなものじゃない！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「どっちがいいか聞いたのは私だけど、なんだか腹が立ってきたわ……！　腹\nいせにもっと責めてあげる……！　ずちゅ、れろっ……ちゅぱっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んちゅ……ずっ、れりゅ……！　にちゅ、くちゅ……ずっ、ちゅるるっ……\n！　擦れば擦るほど、オチンポから汁が出て来るわね……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「乳首も唾液まみれにされてるのに、悦んでるみたいだし……女の子に責めら\nれるの、そんなに気持ちいい？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふふっ。言葉にならないぐらい、気持ちいいみたいね……！　そんなに悦\nんでも、許してあげないんだから……！　ちゅ、ずちゅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅぱっ、じゅるっ……！　ちゅ、ちゅちゅちゅ……ぷちゅ、ぬり\nゅっ……れろっ、くちゅ……ちゅ、じゅぱっ、ちゅぴっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ……ちゅ、ぱっ……はあ……はあ……！　オチンポのビクビク\nが、強くなってきてるわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「このカリの部分を、指でシコシコされるのがいいんでしょ……！　あなたの\n弱点なんて、オミトーシなんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「裏筋を撫でながら……んっ、ちゅ……！　乳首を舌で突いてあげると……ほ\nら、また我慢汁が吹き出してきたわ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、にちゅ……ぷちゅ、じゅちゅ……！　私の手袋の中……指にまで、\nエッチな汁が届いてるわ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「オチンポも手袋もドロドロの、グチャグチャよ……まったく。この衣装、借\nりものなのに……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んちゅ、じゅるっ……ちゅぱっ、ずちゅ……んふっ。オチンポ、そろそろイ\nキそうね……痙攣したみたいに、ビクビクしてるわ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「我慢汁だけでも酷い状態なのに……このまま出したら、手袋がザーメンまみ\nれになっちゃうわね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「今洗えば、シミもニオイも落ちるだろうけど……ザーメンまで出されたら、\n確実に言い訳できなくなるわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「くっさいザーメンのニオイをさせながら、アクレイジョーを倒すなんてこと\n……この私にさせたいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「その顔は、私の手をザーメンのニオイでいっぱいにしたいって顔ね……あな\nたって、本当に救いようのない変態だわ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、ちゅ……でも、レイジョーローズは正義のヒロインだから……あ\nなたのことを救ってあげるし、性癖に付き合ってあげる……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「こんなことしてくれる私に感謝しながら……イキなさい……！　んっ、んん\nっ……！　ちゅ、くちゅ……ちゅぱっ、ちゅうううぅぅぅ……！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ、にちゅっ……！　あっ、あっ……！　手袋にたくさんザーメン出され\nてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「熱いのがびゅるびゅる出てるの感じるわ……！　もう……どれだけ溜め込ん\nでるのよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「れろっ、にちゅ……くちゅ、ずちゅ……！　手袋がスベスベしてるせいで、\nいつもより滑って……射精中なのに、手が止められないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ザーメン吐き出してるのに、こんなに動かされたら……しんどいわよね……\n！　でも、わかってるけど、止められないの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あなたの気持ちよさそうな顔を見てたら、もっと動かしたくなって……！　\nああっ……！　んちゅ、ずちゅ……ちゅぷっ、ちゅちゅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ……たくさん出したわね……手袋の中にまで、ザーメンが届\nいてるわよ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ザーメンのシミも、ニオイも、いーっぱい手袋に染み込んでるわ……エッチ\nなことしたって、バレちゃうわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「今から洗ってももう遅いし……いっそのこと、もっと楽しんじゃう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「あなたも一回出しただけじゃ、物足りないでしょ？　ザーメンのおかげでヌ\nルヌルが増してるし、次の手コキはもっと気持ちいいと思うわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ。オーケー。じゃあ、もう一回シコシコしてあげる……あなたの性欲\n、このレイジョーローズが鎮めてあげるわ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_09" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅるっ……ちゅぱっ、にちゅる……！　れりゅ、ずちゅ……ちゅ\n、ちゅずちゅ……！　ぺろっ、れろろっ……！　ちゅ、ちゅぱっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_10" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ちゅ、にちゃ……ぷちゅ、ちゅるっ……！　二回目なのに全然カタイし、熱\nいままね……握ってるだけで、火傷しちゃいそうだわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「でも、ザーメンのおかげで滑りもよくなってるし……これなら、さっきより\nも楽に射精させられそうね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ほら……オチンポの根本から先っぽまで、こうやって一気にズリズリしても\n……抵抗がないどころか、簡単にシゴけるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「くちゅるっ……ちゅぱっ、れりゅ……！　んんっ……！　オチンポがまた一\n段と、激しく暴れてる……！　今みたいにシコシコするのがいいの？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_10" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ふふっ……そんなに気持ちいいなら、根本から亀頭のところまで、思いっき\nりシゴいてあげるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「ぺろっ、ぬちゅ……！　ちゅ、じゅるっ……！　んっ、あむっ……ちゅぱっ\n、ちゅちゅ……！　はあぁ……乳首もカタいままね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002403_01_10" ]},
