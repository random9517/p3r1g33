		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「後先考えないヤベぇ妹と、強引にことを進めるヤベぇ姉……。それを素知ら \nぬフリをするあたし……ふふふ、みんなヤベぇでしょ？」", "NORMAL" ]},
