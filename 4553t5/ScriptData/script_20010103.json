		{"command":[ "SETNAME", "女怪人" ]},
		{"command":[ "SETTEXT", "「ぺぺぶ！！？　お、おのれ、どうしてバレた？　お前達に犬を探させて、そ \nの隙に逃げようと思ったのに！」", "NORMAL" ]},
