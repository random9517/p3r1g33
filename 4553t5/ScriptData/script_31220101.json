		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「え……今度はっ、顔に掛けるって……それって、どういう……あっ、ひぁぁ\nぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_12" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んぁぷっ！　ちょっ、まだいいって言ってないですっ、あぷっ、んんっ！　\nも、もうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ……ヌルヌルがこんなに、うぅっ、この感触……正直、そこ\nまでいいものじゃないですからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はぁ……やっと射精……落ち着いて来ました……もう、本当にどれだけ出し\nたら気が済むんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ん、ちゅぷっ……うぅっ、変な味……あっ……い、いや、これは……何とい\nうか、ほんの好奇心で……だ、だから笑わないで下さい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「もう……隊長はフリーダム過ぎます。こんなこと……他のみんなにもしてい\nるんですか……？」", "NORMAL" ]},
