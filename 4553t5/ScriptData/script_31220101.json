{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「……は、話には聞いてましたけど、まさか本当に、こんなこと、するハメに\nなるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ええ、知ってます。隊長は、エッチなことすることで、相手の能力強化する\n能力があるって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103102" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「だからって、まさか、こんな……む、胸で……おちんちんを……う、うぅぅ\n、屈辱、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103103" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「や、柔らかいとか、暖かいとか、そういう感想は結構です！　言わなくてい\nいですってば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「分かってますよ。約束ですから、ちゃんと、最後までします。しますから、\nいちいち恥ずかしくなるようなこと、言わないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃあ……始めますよ。言っておきますけど、こんなことするの初め\nてだから、下手でも、文句言わないでくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「だ、だから！　初めてを捧げてもらえて嬉しいとか、そういうことです！　\nそういうこと、言わなくていいですってば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ああもう。こうなったら、さっさと終わらせた方がいいかも。だから……は\n、始めますよ……ん、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ん、しょっ……胸を、こうして、持ち上げて……んうぅ……ぐいぐいって、\n押しつけてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「こ、こんな感じ、ですか？　もっと、強く、ですか？　えっと……ん、んん\nっ、しょっ。んん、えいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あ……お、おちんちんが、大っきくなってきました。噂には聞いてましたけ\nど、本当に、こんな風に、なるんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「どんどん、膨らんで……ん、んんっ、んっ……おっぱいで、挟み切れないぐ\nらい、サイズアップ、しちゃいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「それに、匂いも、どんどん青臭くなってきて……うぅ。臭いけど、癖になり\nそうな、変な匂い、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「って、私のおっぱい、いつの間にか、透明なので、にちゃにちゃになっちゃ\nってる！？　さきっぽから、透明なの、滲んでます！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「これが、我慢汁……ふあぁぁ……匂い、どんどん濃厚になってきて、なんだ\nか、頭が、痺れちゃって、ますぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「は、はい、ごめんなさい。手、お留守になって、ました。匂いのせいでくら\nくらしちゃって、つい……ちゃんと、おっぱい、動かします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んんんっ、んっ！　おっぱい、ぎゅって、強く圧迫して……ふあぁぁ。ぎん\nぎんになった、おちんちん、かたいぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「こうやって、おっぱい、動かして、こすってあげると、かたくなったおちん\nちんが、ごりごりってなって……すごい、ですぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あ、ああ、ふあぁ。おちんちん、ますます、大っきく！？　これ、どこまで\n膨らんじゃうんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「血管も、ぴくぴくって、浮き上がってて……痛く、ないんですか？　そうな\nんですね……ふ、不思議、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あ……また、透明なのが、あふれてきてる。私のおっぱい、また、青臭くな\nっちゃってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……なんか、これ、どんどん変な気分になってきちゃう。\nなんで……別に、私が気持ちいい訳じゃないのに、どうしてぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「て言うか、どうなったら終わりなんですか、これ？　ずっと、こうしてなき\nゃ駄目なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「しゃ、射精……なるほど。話には、聞いたこと、あります。保健の授業で聞\nいた、あれですね。性的快感が高まると発射される、白濁液、ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「じゃあ、じゃあ、早くその白濁液、出してください。私……なんだか、本当\nに、身体、熱くなって、変な気分、止まらなくなってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「まるで、自分が自分じゃなくなってくみたい、ですぅ。どうしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ひうう！？　今、おちんちんが、びくって……え？　やだ、びくびくびくっ\nて、痙攣してる！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「イク？　射精、するんですか？　しそうになると、こんな風に震えるんです\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「は、はい。このまま……ん！　ん！　ん！　ん！　あ、凄い、おっぱいでこ\nすればこするほど、おちんちん、かたくなって、震えて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「イッて、ください！　はい！　このまま、イッてください！　ん！　ん！　\nんん！　ん～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んああ！？　おちんちんが、びゅくびゅくって……先っぽ、おしっこの穴、\nぱくぱくってぇ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_06" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はううっ！？　ん！　んんんんん！　熱いのが、胸に……ひゃんん！？　顔\nに、まで！？　んんんん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「やだ嘘！？　まだ出てる！？　んんんん！　ど、どれだけ、たくさん──は\nううううう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ん、んん！　んんんん～！　はぁ、はぁ、はぁ……す、すごい。こんな、大\n量に、白いの、たくさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「……言っておきますけど、ホワイトスワンが本当に白くなった、とか馬鹿な\nこと言ったら、このままおちんちん、握りつぶしますからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103135" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「私の握力、５０kgぐらいありますけど、試してみたいなら、どうぞ遠慮な\nく、くだらないギャグを言ってみてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「それにしても、本当に大量に出ましたね。おかげで、胸も顔もべたべたです\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「じょ、上手だったって……こんなの、上手いも下手もありませんよ。胸で挟\nんで、ちょいちょいっと揉んであげただけじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103138" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ま、まあ、気持ち良くなってくれるの、悪い気分ではないですけど。隊長に\n喜んでもらえるのは、その……ちょっとだけ、嬉しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「ちょっとですよ。本当にちょっとだけですからね！　勘違いしないでくださ\nいね！　って、なにを笑ってるんですか～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あの……それで、ちょっと確認させて頂きたいのですが……一向におちんち\nんが離れないのは、どういうおつもりなんでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「これで、収まる訳がないって……そんな開き直って言うようなことですかっ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「……はぁ……分かりましたよ、そんな顔しなくても……続けてすればいいん\nでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「でも、大丈夫なんですか？　その、おちんちん……こんな短い間隔で出せる\nものなのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「全然問題ない……そう、なんですね……分かりました。とにかく……また、\nしていきます……んっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、あっ、く……あ……さっきより、精液のお陰で……ずっと滑\nりやすくなってますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「これなら……前より、もうちょっと上手く出来る気がします……んふっ、う\nんっ……んく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はぁ……あっ、んんっ……んくっ、やだ……変な音がする……くちゅって…\n…も、もう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「えっ？　も、もっと音をさせて欲しいって……うぅっ……本当に隊長は変態\nですね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「いいです……ここまで来たら、何だってしてあげますよ……こうして……大\nきく動かせばいいんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、おちんちん擦れてる……あぁ……いやらしい音……鳴ってる\nぅ……はぁっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「やだ……私まで……変な感じになって来ました……肌がぬるぬるして……こ\nんなのが気持ちいい……なんてぇ……あ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「乳首も……んっ、ち、違います……別にわざと当ててる訳じゃ……んんっ、\nでも……あっ、いっぱい擦れちゃいます……あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はっ、うんっ……気持ち……いいんですか？　んんっ、あっ、はいっ、わ、\n私も……その……んんっ、これが感じるって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「こんな……あぁっ、おっぱいとおちんちんが重なり合って……い、いやらし\nいのに……止まらなくてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、そんな激しく出し入れしてっ、あっ、隊長……私……変です\n……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、やだ……目の前でおちんちんが……また、出そうに……あっ\n、はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「もうすぐ……なんですね？　んっ、はい……頑張りますっ……あっ、そんな\n腰っ……一緒に振ったらっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……あぁっ、おちんちんの口が……ぷくって膨らんで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「出るんですかっ、出ちゃうんですね……？　あぁっ、もう……一思いに……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「んっ、また……おっぱいにっ……はいっ、ど、どうぞっ……ひぁっ、あぁぁ\nぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
