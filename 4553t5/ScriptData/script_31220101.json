		{"command":[ "SETIMAGE", "0", "still_00012201_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「……今更私は特別なんて言われても全然信用なんか出来ませんけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「でも、一応確認なんですけど……私……その、ちゃんと出来ましたか……？\n」", "NORMAL" ]},
