		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「あっ……あぁっ、また……こんなにっ……嘘……さっきより、ずっと多いの\n……あっ……あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103302" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「まだ出てる……んっ、あぁ……私のおっぱい……もう全部精液まみれになっ\nちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「や、やっと……落ち着いて来ましたか……？　んっ、大丈夫みたいですね…\n…はぁ……このまま止まらなかったらどうしようかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「それにしても……んっ、匂いも強くなって……でも……何だか、この匂いも\n慣れて来ちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「そこまでイヤという訳では……これが、隊長の精液……なんですよね……い\n、いえ、まじまじ見るものではないですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「別にいいんですか……興奮するって……はぁぁ……本当にどうして、こんな\n変態な人が隊長なんでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00012201_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「いえ、もう諦めました。別に許せないとか、そういうことではありませんし\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「そう、ですか……とっても良かったと……はぁ……ありがとう、ございます\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴィクトリア" ]},
		{"command":[ "SETTEXT", "「まぁ、その……隊長がどうしてもと仰るなら……また、よろしく……お願い\n、します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_122_0103310" ]},
