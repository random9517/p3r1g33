{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「って、調子よーく敵を全滅させちゃうつもりだったけど……ふっふっふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550001" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「敵の数が多すぎて大ピンチだよー！　えーん、どーしよスイレンちゃぁあん\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550002" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……そんなことだろうと思ってましたぁ。艦長ってほんっとぉおおおに！　\nノリと勢いで物事決めちゃいますからねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550001" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ひええええええん！　艦（ふね）が！　艦（ふね）がぁ～！　外装、すぐに\nも突破されそうですうううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021550001" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "涙目になりながら、上下に揺れるブリッジの中で必死に抗っているスミレ。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんなスミレの隣で、普段は余裕たっぷりな現代っ子……リリアもこめかみか\nら脂汗を垂らしていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「キリがないです……。増援……？　まさか、増殖……？　理解できない……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021550001" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「こちらは補給が出来ませんから、ジリ貧ですよ！　ジワジワジワジワ削られ\nていくだけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021550002" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……戦闘に必要ない部分のエネルギー、全部かき集めて……。あと５分」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021550002" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「いえ、４分程度で、この艦（ふね）……落ちます」　　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021550003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "焦るオペレーター２人の声を聞きながら……セリカは堂々と仁王立ちになり、\nふぁさっ……と髪をたなびかせる。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「こうなったら、奥の手つかっちゃおうじゃないの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550003" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「いや、いやいやいやいやいや～！　それこそ始末書ものじゃなぁい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550002" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「それどころかクビになっちゃいますよっ！　クビ！　クビ、クビ、クビです\nぅうう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021550003" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「艦長！　これ以上、給料減らされたら……リリア、我慢できませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021550004" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あら～そう？　困っちゃったな～☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550004" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ぜ、ぜんぜん困ってないですよねええええええ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021550004" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "鼻息も荒く、テンションの上がったセリカを止める事が出来ず、オロオロしだ\nしたダイアンサス。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しかし、うろたえる一同にも容赦なく……セリカの艦長命令は発令された。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「うん、使います！　奥の手、派手に使っちゃいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550005" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「全エネルギーでねばっても～。あと４分くらいでオチちゃうんでしょ？　だ\nったら、ケチケチするのはなーしっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「メインエンジン、ブルーインパルスの動力をすべて『超フェイザー砲』にま\nわして一網打尽にしちゃいましょっ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あのぉ！　あのぉ、それって、外したら……死にますよね！　私達！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021550005" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「そうなったらそうなった時だよ！　あ、脱出ポッドがあるじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550008" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……ポッドは４つですよ。まさか、シャムさんを見捨てるつもりですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550003" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……あっ！！　……あはっ、あはっ、あはは、そっか。いっこポッド足りな\nいか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550009" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「じゃー……ミスった時は私が死ぬから、撃って☆　超フェイザー砲☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ガ……ガチで言ってますか？　それ……。あまりにも軽すぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021550005" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「そこはねー。艦長の責任っていうかー。責任とっちゃおっかなみたいなー…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550011" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「あのですねぇ……。艦長を見殺しになんて出来るわけないでしょう。常識で\n考えてくださいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550004" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「その案は却下です～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550005" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「えぇ～？　じゃあ、プラズマコアはどうかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550012" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「防御シールドのエネルギーも振り分けてますが、臨界ギリギリ……アウトで\nす！　厳しいです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550006" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ギリギリってことはイケるってことね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550013" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「どんだけポジティブなんですか！　アウト寄りのアウトってことですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021550006" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「アリ寄りのアリ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550014" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ナシ寄りのナシ、ですーっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021550007" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ぎゃあぎゃあとかしましく、モメにモメるブリッジ内。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その騒動を、鎮めたのはか細く……しかし、可憐な声だった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「待って……。いい案が、あるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021550001" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「シャムさん……！　駄目です、治療ポッドの外に出るなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550007" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「この状況……。前に一回……経験したこと、あるから……。エネルギーの集\nめ方、教えてあげる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021550002" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「ですが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550008" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「平気だよ。命の賭け方くらい……海賊はみんな、知ってるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021550003" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「それより、ちゃんと聞いて。間に合わなくなるまえに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021550004" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……わかりました。そうですよね、ダイアンサスが落ちればあなたも死ぬん\nですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550009" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「死力を尽くすのは当然……と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「そーゆーこと。えへへ……海賊はぁ、しぶといんだよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021550005" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「それで、どうすれば……。……ええ。ええ、ああ……なるほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021550011" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スイレンの目がスッと細まり、鋭くいくつもの指示が飛ぶ。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それをスミレとリリア、下士官２人が見事に拾い上げ……、すぐに状況が改善\nした。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「これなら……！　あっ！　い、いけます！　い……一発なら……撃てちゃい\nます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021550006" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「よーーーーっし！　よしっ、よーーーーっし！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550015" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "パンパンと手を叩き、ダイアンサス艦長……セリカ・ミヤシタの号令がまっす\nぐ宇宙に響き渡る！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「超フェイザー砲、発射用意！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021550016" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「はは……ははは、あははは……。こうなったら、やるしかないですよねぇえ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021550007" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「じゅ、重水素タンク弁閉鎖……。エネルギー充填開始！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021550008" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ガクガクと震えるスミレの手を、シャムの手が優しく握った。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "-200" ]},
	{"command":[ "SETCHARA", "1", "char_00013601_01", "6", "CENTER", "200" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「シャ、シャムさん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021550009" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

