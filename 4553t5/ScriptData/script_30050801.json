		{"command":[ "PLAYVOICE", "v2_005_0803304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
