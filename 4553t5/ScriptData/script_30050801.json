{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「来ましたですね……それじゃあ、早速始めるですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803101" ]},
	{"command":[ "SETCHARA", "0", "char_00000508_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ほら……もうすることは分かってるんでしょう。うだうだ言わずに、さっさ\nとおちんちんを出すんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「テンションがおかしい？　サンタの格好なんですから、少し位テンションが\n上がったって、不思議なことじゃないでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……ていうか、こんな恥ずかしいこと、普通のテンションで出来るわけない\nですっ、いくらパワーアップの為でもですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803104" ]},
	{"command":[ "SETCHARA", "0", "char_00000508_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「さあ、いいからおちんちんを……あぁ……んっ、くんくんっ……すぅぅぅ…\n…んんっ、くんっ、んふぅぅぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000508_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「何ですか……この匂いは……ちゃんと丁寧に洗ってるんですか？　こんなオ\nス丸出しの匂い……んふぅ……くんっ、くんくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「臭いですよ……んっ、本当にいやらしいにおいをプンプンさせて……けしか\nらんです。まったくもってけしからんですよ……んすぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「む、夢中になんかなってません！　ただ、あんまり臭いと、つい嗅いでしま\nうというのは……よ、よくあるでしょうっ、そういう奴ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「とにかくっ……ちゃっちゃと精液出すですよっ、んっ……ぴちゃ、れる……\nれろ、れろぉ……れる……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んんぅぅ……うぅ……変な味ぃ……ちゅぷ……んりゅ、においと相まって…\n…ぴちゃ、んちゅ……おかしくなりそうですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷ、ぴちゃ、んちゅぱっ……んふっ……れろ、えろ……れろぉぉ\n……れろ、れろぉん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「どうですか……精液出したくなって来ましたか？　いつ出してもいいですか\nらね……さっさと出すですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「え……この程度だと……全然……？　むぅぅぅ……ウチのご奉仕が気に入ら\nないとでも……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「もっと、時間を掛けて、優しく……丁寧に……ねっとりと……あぁー、いち\nいち注文がうるさいですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「分かりましたよ、もっとゆっくり、ちゃんと舐めればいいですね……ぴちゃ\n、んちゅぷ……れろ、ん……れろ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んぅぅぅ……やっぱり変な味ぃ……んりゅ、こんなのが美味しいなんて言う\n人の気が知れません……そんな人いませんか……んちゅ、ぴちゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「このむわっと広がるにおいとか……んすぅぅぅ……くんっ、くんくん……ん\nふぁ……普通じゃ……ない、ですぅ……ぴちゃ、んちゅ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んんっ、これは……も、もうちょっと……本格的にしないと……だめ、れふ\nね……は……あぁんむ……はむぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「むふぅぅぅ……んぐっ、ふ……んぐっ……んぷっ……あぁ……咥えひゃいま\nした……こんな、れっかい……おひんひん……むぐぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「じゅぽ……んじゅ……くぷ……んじゅぅぅぅ……においが……もっろ広がる\nぅ……んふぅ……臭いのに……じゅぱ……んじゅるるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んじゅるっ、ちゅぷっ、んじゅっ、ちゅぷぅ……れろ……んれろ\n、れろぉ……舌が……勝手に動きまふぅ……れる……んれるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「お、美味ひくなんか、ないれふっ……こんな、おしっこが一緒に出るような\n所……美味しい訳ないれひょっ、じゅぽっ、じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「その割には夢中って……ウチが、いつ夢中になりまひたかっ……これはっ、\n激しくした方が……あなたも気持ちいいだろうから……じゅぽ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そういう、ウチの気遣いであって……りゅぷっ、おちんちん……美味しくて\n……ペロペロしてる訳じゃ……ない、れふっ、ちゅぱ、ぺろっ、れろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「分かりましたか……？　何をニヤニヤしてるれふかっ、ウチは分かりました\nかって聞いてるんでふよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……んっ、分かれば、いいんれふ……ちゅぽっ、じゅぱっ、んち\nゅぷっ、りゅぷ……んちゅぅぅ……じゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁんむ……ちゅぷっ、絶対美味しくないです……クセが強くて、しょっぱ\nくて……生臭いだけで……ん、すぅぅぅ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「だから、こんなおちんちん……んちゅぷっ、ウチが何とかしてあげないと…\n…いけないです……ちゅぱっ、くぽっ、りゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅ……むぐっ、太い……んりゅぷ……はぷぅ……んむ、もう少し小\nさくならないですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「出たら……しぼむ……そんなことは分かってるですっ、もうっ、とにかくさ\nっさと出すですよっ、ちゅぷっ、じゅぷっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んぁ……我慢汁……カウパー……出て来ました……んちゅぷっ、くぽっ、偉\nそうに言ってた割に……すぐ、でしたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「さあ……きもひ……よくなったんれひょう？　いっぱい……おちんぽ汁……\n出しちゃいなさいっ……じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「不本意れふけど……全部飲んであげまふからっ、じゅぽっ、夢中らんてっ…\n…なってまへんからっ、じゅぽっ、んじゅるっ、んちゅぅぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「さあ……らひなさいっ……早くぅっ、おちんぽ汁っ……んっ、早くぅぅぅっ\n……んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んぶっ！　ふぐっ……んんんーっ、れたっ……んんっ、どろどろのっ、むぐ\nっ……んぐぅぅ……ふごい……味ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んぅぅ……苦い……んむぅ……臭いし……ちゅぷぅ……こんなので強くなる\nなんてぇ……絶対ウソぉ……んちゅぷ……ぴちゃ……んぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ぷぁ……はぁ……はぁ……落ち着きましたね……？　ぺろ……全く、中々遠\n慮なく出してくれたものです、ちゅぱっ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「あぁ……まだ舌に残ってる……臭いのも、まとわりついて……しつこいです\n……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んちゅ……んはぁ……これで、いいですか？　ちゅぷ……こんなことをする\nのも、サンタの季節だけですからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「満更でもないって……そ、そんなんじゃありません！　全く……いくら言っ\nても分からない人ですね、もう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「それで……何だか、まだ物足りないーみたいな顔をしてるのは、何なんです\nかね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「はぁ、分かってます。一発じゃ終わらないって……そういう節操なしのタイ\nプなのは折り込み済みです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……一応、味にも慣れて来ましたし……仕方ないから続けてあげるです。何\nですか、その顔は……ウチの好意を無下にするつもりですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そうです、あなたは大人しく身を任せていればいいんです。もう、やり方も\nマスターしました。残りも、ウチが全部出させてやるですから……ちゅぱ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んりゅ、れろ……えろ……んれろぉ……あぁ……さっきの精液が\nべとって残ってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「まずは、これをちゃんと綺麗にしてからですね……ちゅぷ、んちゅ……ちゅ\nる……れろ……んちゅぅ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ん……これでいいです。いいですか、おちんちんも、常に清潔にする意識が\nないとですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「では改めて……じゅぽっ、くぷっ、んふっ、じゅるっ、くぽっ、りゅぷっ、\nんぶっ、んふぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000508_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「何ですか？　んふ……ちゅぷっ……ウチだって、ちょっとコツを覚えれば、\nこれ位……出来ますよ……ちゅぽっ、んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ん……そうじゃない？　積極的……？　な、なーにがですか。別に……ちょ\nっと位、やる気を出してもいいじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「こんな臭いのがクセになったりなんて……ウチに限って……あるワケないで\nす……くぽっ、ちゅぷ……んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ましてや、美味しいなんて思うワケ……んりゅぷぅ……れろ……んりゅぅ…\n…れる……れろれろれろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「そうれふ……クリスマスなんですから……少し浮かれた気分になっても、い\nいじゃないれふか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んちゅぅぅぅ……ふぉら、おちんちん……先っぽの所……ちゅうって吸われ\nると……いいれひょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んちゅっ……ちゅぷっ、じゅるるうぅ……あぁ……ペロペロして……ほら、\n舌が……うねうねしてるの……分かりまふか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「おちんちんの先……敏感になってるとこぉ……れろ……んれろぉ……れろぉ\n、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「んふふぅ……いい顔になって来たじゃないれふか……ダメれふよ……バレバ\nレなんですから……じゅぱっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0803217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ここから、弱い所の集中攻撃れふっ……じゅぷっ、んちゅぅぅぅっ、じゅる\nっ、ちゅぷっ、んふふっ、ビクビクさせてぇっ……」", "NORMAL" ]},
