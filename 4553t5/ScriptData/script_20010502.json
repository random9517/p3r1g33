{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0125" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「フッフフフ……おまえ、かなりヤるアルな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021050001" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ハハッ、お前こそな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "セレインと、謎の中華娘との腕前はおそらく互角……絶妙に拮抗している。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「これは、戦神蚩尤の本気、出さないといけないみたいあるネ……？　行くヨ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021050002" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「フン、わたしの編み出した超必殺技を食らってもまだ、そんなことが言える\nか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021050002" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、なんだこりゃ。収集がつかないぞ……」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「カツマ！　ぼさっとしてないで、少しは援護してくれたっていいだろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021050003" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうは言うけど……争いの内容がくだらなすぎてだな……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「オマエ、カツマて言うのカ。ふむふむ。カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021050003" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「オマエにこの美少女蚩尤の助太刀する権利与える！　このアホ、二人でとっ\nちめるアルヨ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021050004" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どっちの味方するとかじゃないんだって……！　やめろって二人とも！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "間に割って入ろうとすると、その瞬間、二人は俺を押しのけ戦闘を再開する。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「フン！　欲しいものは力づくで奪いとル！　それが戦場の掟！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021050005" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「完全同意だ！　お前とは、別の出会い方をしたかったよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021050004" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああああ、脳筋しかいないのかこの中華街にはぁああ！！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺の悲鳴を合図に、二人が同時に地面を蹴って飛ぼうとした。その時だ。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「……あ。肉まんあったヨ！　オバサン。これくださいナ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021050001" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021050005" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ああっ！　何ちゃっかり買っちゃってるアル！　それは私タチが狙ってた肉\nまんヨ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021050006" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「ハァ？　アンタタチ、道端でピーギャー喧嘩してたダケ。肉まん残ってたか\nら金華が買っタ。それの何が悪イ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021050002" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あーのーなー！　見てたらわかるだろっ！？　今ここで、肉まんを懸けた熱\nい闘いが繰り広げられてんの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021050006" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「ほんとヨ！　この食欲バカの言うとおりネ！　そいつは筋が通らないっても\nんヨ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021050007" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「でも、もう金華が買ったアルから、これは金華のモノ。話は終わりヨ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021050003" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「……おっと！　逃がさないヨ！　この街では力こそが正義。肉まんを手にす\nるのは力あるものがふさわしいネ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021050008" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「それが欲しいなら、わたし達を倒していくんだな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021050007" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ら、むちゃくちゃ言うなあ……ほぼ言いがかりじゃないか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「ほォーう？　金華に力で挑むと言ったカ？　……ワタシ、受けて立つゾ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021050004" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、お前もこいつらの理論に乗るのかよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "金華" ]},
		{"command":[ "SETTEXT", "「お相手するヨ、二人とも！　どっからだってかかってくるアル！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_142_010021050005" ]},
	{"command":[ "SETCHARA", "0", "char_00014201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「望むところだぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021050008" ]},
	{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「いくアルッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010021050009" ]},
	{"command":[ "SETCHARA", "0", "char_00003801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}