{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あの……隊長氏？　今日はパワーアップのために、ここに呼ばれたはずでご\nざるですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「うう……こんなことをするために、拙者を……ひうぅ、酷いですっ、そうい\nうの駄目なことだと派遣組合の研修で受けましたでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「うう～～……隊長氏ぃ……最初から、まともな人じゃないって思ってました\nけど……ここまでヤバめな人とは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「……いえ、やるでござるよ。だって、今はくのいちとして雇われているでご\nざるですから……これも仕事のうちって割り切るでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「け、けど、その……あうぅ、足でしなきゃならないだなんて……初めてなの\nで、上手くできるかどうか不安でござるよ……ニンともカンとも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「じゃ、は、始めますね……よいしょっと……うあぁ……なんでござるかぁ、\nこれぇ……手で触るより、不気味でござるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「拙者そもそも、手で触った経験もほとんどござらんでござるですから……あ\nうぅ、硬いぃ……カチカチしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「え？　あ、し、失礼したでござる……痛かった、ですか？　すみません……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「えええっ！？　痛いのが気持ちいい……うう、隊長氏、変態なのでござるの\nですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……それで？　これはいつまで続けなきゃならないでござるで\nすか？　え？　イクまで……？　まあ、そうですよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「よいしょ、こらしょっと……ふぅ、ふぅ……つま先で扱くのって、大変でご\nざるですね……ん、ふうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……え？　おっぱいと股間がエッチ……？　やぁん、見ないで下\nさいでござるぅ……はぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「え？　おっぱいを、寄せろ……？　ええっと、これでいいでござるですか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……そ、そうですか、そんなにエッチな光景ですか……嬉しい\nでござるです……はぁ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「それより、早くイッていただけないでござるですか？　見られるのが、だん\nだん恥ずかしくなってきたでござるので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「……ふえ？　拙者、強いのに……どうしてそんなに弱気なのか……でござる\nか？　いや、拙者、別に強くはないでござるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「多少剣技が優れてはいますが、それを戦いに使いたいかどうかはまた別の話\nですから……って今、こんな話している場合ではないでござる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……それより、いかがでござるか？　拙者の足さばき……最初よ\nりも、硬く大きくなっているようでござるが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……ほらぁ……こんなにゴリゴリとして……ああ、血管がクッキ\nリ浮かび上がってる……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ええ？　も、もっと激しくするでござるですか？　わっ、わかりました……\nよいしょっと──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ん、んん……はぁ、ふぅ……こ、これで、いかがでござるか？　こうしてグ\nイグイと踏みつけながら扱いているでござるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「え？　普通に痛い……？　それは失礼いたしたでござる……ええっと、じゃ\nあ、どうすればいいでござるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203122" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「えええ～～……痛いのがいいから続けるでござるか？　それ、さっきも言っ\nてたでござる……拙者には、理解できない性的嗜好でござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「え？　なっ、ち、違いますでござるっ……拙者は、Ｍじゃござらんですよぉ\n……ええ、違います……絶対に違います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「わたし……Ｍじゃない……Ｍじゃないと思います……うう、どうだろう？　\nＭなのかなぁ……う～～ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「っと、そんなことよりっ……はぁ、ふぅ……いかが、ですか？　拙者、上手\nにおちんちんを責められていますでござるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「そう、ですか……あはぁ、よかったですぅ……はぁ、はぁ……ん、ふぅ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あぁぁん……足の裏が、変な感じぃ……はぁ、ふぅ……グニグニして……な\nんだか……はぁ……はぁ……んん、あはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ふえぇ？　こ、興奮……？　どうでしょう……わたし、じゃなくて……拙者\n、興奮しているのかも、しれません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「だ、だって……おちんちんが、こんなになってるんですよ？　ああ、すごぉ\nい……硬くて、大きくて、たくましい……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ふえぇ……？　気持ちよく、なって来たんでござるか……？　わかりました\n……激しくやってみるでござる……はぁ、ふぅ……よいしょっとっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……はぁ、いかがで、ござるか？　両足のつま先と、足の裏\nをこすり合わせて……はぁ、ふぅ……こね回して……ぐぅ、んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203132" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁぁん、すごぉい……はぁ、はぁ……おちんちん、ビクンビクンしてる…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……もうイキそう、ですか？　わっ、わかり、ました……はぁ\n、はぁ……どうぞ、出して、下さい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203134" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁぁん……すごぉい……せ、精液が、根本から上がってくる……\nん、んんぁ、はぁ……はぁぁぁぁあん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ひうぅ！？　すごぉい……こ、こんなに溢れてる……あっ、ああっ、はぁ…\n…あうぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あっ、熱い、でござる……んん、はぁ……はぁぁあん……精液のシャワーが\n……降り注いでくる……ん、くぅ、あはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203137" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ん、んぁぁ……はぁ……はぁ……クンクン……あうぅ……この匂い……んん\n、気持ち悪い……なのに、もっと嗅ぎたくなっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……はふぅ……息が苦しい……はぁ……はぁ……あふぅ……匂いで、鼻\nが詰まっちゃったみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「あはぁ……射精、止まったみたい、ですね……よ、よかったぁ……じゃあ、\nこれでお仕舞いですね…………では、しからば御免──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ええ？　ま、まだ満足していない……？　うう、わ、わかったでござる……\nこのまま続けさせていただくでござるです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「んん……はぁ、ふぅ……んんぁぁ、精液の匂いが、すごい……はぁ、はぁ…\n…ああう、息が苦しいでござる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……はぁ、はぁ……え？　呼吸を安定させて、身体能力向上を図っ\nている……？　ああ、パワーアップの話でござるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「まさかホンキで、拙者をパワーアップさせようと目論んでいたのでござるか\n……？　はぁ……変な人ですね、隊長氏は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……それにしても、ん、ふぅ……つま先がヌルヌルしているで\nござる……ああん、精液がすごぉい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「んん、はぁ……まだ、先っちょから、溢れ出してくるでござる……あぁん、\nすごぉい……いっぱい出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……はあぁん、つま先が……指の股まで、ヌルヌルしている\nでござるよ……にんにん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……この感触、ちょっと気持ちいい、かも……はぁ……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「おちんちんも、拙者の足もドロドロになってる……ああん、いやらしい……\n見ているだけで、ゾクゾクしちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……は、はい……拙者、今興奮しているでござる……今、乳首\nがビンビンになってますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……え？　股間が濡れている……？　どうしてそんなこと、わ\nかるんでござるですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「そ、そうですか……股間に染みが…………あうぅ、恥ずかしい……見ないで\n下さいでござるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ、あふぅ……こうして、足をごしごし動かしていると、ん、ふう……だ\nんだんお腹の奥がジンジンしてきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00015002_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ああん、足を動かすたびに……ん、んん……お腹の奥がジン\nジンしてきちゃうでござる……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「ううぅ、やだなぁ……わたし、エッチな子になっちゃった……うううぅ、お\n母さんに叱られちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
