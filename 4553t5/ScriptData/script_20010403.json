{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETTEXT", "狼のようなシルエットをした敵はめちゃくちゃ手強かった。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「カツマ！　ちゃんと母上様をお守りしっ……きゃあああああ！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「くっ……あっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「な、なんですかコレは！？　新手の海坊主かなんかです……キャーーー！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「このっ、私たちを一体誰だと……ひゃあああああ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "同じように、他の幹部たちも一瞬のうちにひっくり返って無様な姿を晒してい\nる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ビーチで何とか立っている仲間は女王以外、俺とアナザーしか残っていなかっ\nた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「一体全体……なんだってんだ……！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「やれやれ、嘆かわしいのう。わしの動きを見きったのはたった一人だけじゃ\n、幹部の質もここまで落ちるとは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_010021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00001001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「なっ、何者！？　私達を誰かと知っての狼藉なの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "幹部たちの前には狼の毛皮のかぶりものをした老婆……と思われる人物が立っ\nていた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "物腰は柔らかそうだが、幹部全員をあっという間に手玉にとったこの人物、油\n断はならない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして幹部たちの中のセレインだけ、その人物を見た途端、ひときわ目を丸く\nしていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ばっ…………！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ば……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ば、ば……ばっちゃん……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "セレインが心底驚いたような声を出した。俺たちには何が何やら分からない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「ほっほっほ。久しぶりじゃのうセレーナ。いや、ここではセレインだったか\nのう」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_010_010021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00001001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ばっちゃんと呼ばれた人物は、セレインを見て朗らかに笑う。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ばっちゃんだと……？　ということはこいつはセレインとこの婆さんってい\nうのかよ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「その者の名はヘカテリーナ。正確にはセレインの祖母ではなく先祖というこ\nとになる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030009" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「なんせ余がまだ女王になる前の時代の、Ｇ・ルナリアムの幹部じゃからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030010" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「えっ！？　そんなに前の幹部ですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ヘカテリーナといえば月狼族の伝説的族長の名前。彼女が上げた功績によっ\nて、月狼族はその地位を確固たるものにしたと聞きます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「もう、全身砂だらけだわ……。私も陛下と親しい仲とは聞いていましたが、\n実際にお会いしたのは初めてですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ご隠居されたと聞いていましたが、まさか地球に降りてきていらっしゃった\nとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021030006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「私もこんなところにばっちゃんがいたなんて知らなかったぞ。で、なんでこ\nんなところにいるんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021030006" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「決まっておろう。お主らの性根を鍛えなおしてもらうためじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030011" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「鍛え直すって…………まっ、まさか私たちはばっちゃんの特訓を受けるのか\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "急にセレインががくがくと震えだした。普段のセレインは女王に怒られてもこ\nこまで怯えることはない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「おやおや、どうかしたかのうセレイン？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_010_010021030003" ]},
		{"command":[ "SETCHARA", "0", "char_00001001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いやだ！　いやだあああ！！　もう帰りたい！　私は月に帰るぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「落ち着くです、セレイン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、あのセレインがこんなに怯えるとは。一体どういうことだ……？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ふ、ふん。いくら伝説的族長とは言え、今は２１世紀の世の中よ？　昔の常\n識が通じると思ったら大間違いだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふふ、言われてるのう、おばばよ。お主のようなばばあでは力不足だそう\nだぞばばあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030012" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほほほ、わしより年上の陛下にばばあ呼ばわりされるのは心外ですのうこの\nクソばばあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_010021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00001001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふっふっふ。誰がクソばばあじゃ？　クソ度ではお主の方が上であろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030013" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほっほっほ。おやおや、歳のせいか耳も頭も耄碌してるようですのう。クソ\nが溜まっているようですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_010021030005" ]},
		{"command":[ "SETCHARA", "0", "char_00001001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "二人は火花を散らしながら、おもむろに両手を上に上げた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふっふっふ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030014" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヘカテリーナ" ]},
		{"command":[ "SETTEXT", "「ほっほっほ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_010_010021030006" ]},
		{"command":[ "SETCHARA", "0", "char_00001001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして両手をガシィッ！！　と組み合って、力比べを始めた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うわあっ！　ばっちゃんと女王様が組み合ったら、ここら辺が一面焼け野原\nにいい！！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021030009" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "２人のオーラが激しくぶつかり合い、竜巻も発生し砂を巻きあげていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぶわっ、ぺっぺっ！　なんでいきなり喧嘩始めてんだよ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「お二人は昔、切磋琢磨していた仲と聞いていたけど……まさか今も続いてい\nるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんてはた迷惑なばばあどもだ！　とにかくやめさせろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「だっ、誰があの２人を止められるというの！？　きゃああああっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021030006" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "竜巻に巻き上げられそうになるご一行。もちろん誰もこの二人を止められる者\nなどおらず、収まるのを待つしかないと思ったが、しかし。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ！　周りに被害が出る前に我々で止めよう！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい、マジかよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}