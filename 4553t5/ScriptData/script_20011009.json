{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0025" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「うっりゃぁぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121350001" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「へっ、流石にアタシの分身だな。中々やるじゃねぇか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121350002" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿は、私が守る……！　例え自分が相手だったとしても、負けはせぬっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350002" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「上等だ、アタシもいい男を指くわえて譲るつもりはさらさらねーからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121350003" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……マジで、カツマを取り合ってるなこいつら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「さながら騎士達が争奪するお姫様ポジションですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_0121350001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「のんきなこと言ってる場合じゃねぇ！　さっきから安全な場所が全くねぇん\nだぞ、こっちは！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「くっそー、すぐに終わると思ったのに、全然じゃんかー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121350001" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「そんな簡単にやらせるかってのー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121350001" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「アルター！　もっとしっかりして！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121350002" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ははっ、わりぃな。こいつと遊ぶのが思ったより楽しくてよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121350004" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「これは……遊びではないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350003" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「へっ、そう言うなって。アタシについてこれるってのを褒めてやってんだか\nらよ、せりゃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121350005" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「うくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「……確かに埒があきませんね。何か突破口を…………はっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350001" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「何だっ、どうしたんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「いけません……これは……次元の裂け目が……発生している……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350002" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「じげんの……何だって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「同じ次元に、イグニスとイグニス・アルターが同時に存在して戦っている為\nに、次元の因果律が乱れています！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350003" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「このままですとっ……次元の裂け目が広がって……この世界が崩壊してしま\nいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「崩壊っ！？　お、おいっ、カツマ何とかしろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何とかって言われてもだな！　俺にどうしろってんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「何か、世界をなんたらーって力持ってるんだろ！　それで何とかしろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから、何とかって言われても！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「世界を……そ、そうです……イグニスっ、カツマ様のお力を借りて、新しい\n次元の扉を開いて下さい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350005" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿のっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350005" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「おっけー、援護するよっ！　せっりゃーーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121350002" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「あっ……てめっ、何邪魔してっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121350006" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「悪いけど、こっちもお仕事だからねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121350003" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「させるかーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121350003" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おぉっとお！　こっちを無視してもらっちゃ困るぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「イグニスの邪魔はさせませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350006" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「くっ……しまった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121350004" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350006" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イグニスっ……何をどうすれば……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「失礼致しますっ……んっ……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んんっ！？　むっ……んぐっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んふっ、りゅぷ……んっ、ちゅぷ……んんっ、んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「キスって……結局することは同じかよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「全く予期しない所でモテ期とは……あやかりたいものですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_0121350002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んむ……んっ、ぷぁっ……！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「主殿のお力、お借り致します。開けっ……アルター・トール！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350009" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「……う、おっ！　な、何だこりゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121350007" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ヤバっ……これっ、くっ……ひ、引っ張られるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121350005" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「お前達を本来、いるべき場所に戻すっ！　アルター世界に還れっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350010" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「く、くっそー！　あたしは諦めないぞーっ！　また戻ってくるかんなー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121350006" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス・アルター" ]},
		{"command":[ "SETTEXT", "「ちっ……最後まで邪魔してくれたな。いいさ、障害は大きい方が燃えるから\nな、アタシの主をまた取りに戻るぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_168_0121350008" ]},
		{"command":[ "SETCHARA", "0", "char_00016801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「おっぼえてろーーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_0121350007" ]},
		{"command":[ "SETCHARA", "0", "char_00016602_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ど、どうなったんだ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「イグニスが強制的に開いた別次元に、二人を送り返しました。ひとまず、次\n元干渉による崩壊の危機は回避出来たかと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350007" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「でも、結構強引に扉をこじ開けちゃったから、まだ不安定だねぇ。また隙間\nから戻ってくる可能性は結構あるかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121350004" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「そうですね……本来ならば、しっかりとアルマを捕らえておきたかったので\nすが、とてもその余裕はありませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350008" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……済まない。私の力が至らないばかりに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350011" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「そんなことないって！　一つ危機を食い止められただけでも万々歳だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121350005" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「いずれにしても、このことを本部に報告しなければなりませんね。私達も、\n一旦元の世界に戻ります。それで、イグニスは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350009" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私は、主殿と契約を結んだ身だ。まだ、アルマの脅威が去っていない以上は\n、主殿をお守りする義務がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350012" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「分かりました。では、そのことも含めて報告しておきます。暫くは定期的な\nパトロールが必要になりそうですし、連絡も取りやすくなるでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350010" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラ" ]},
		{"command":[ "SETTEXT", "「そだね、また時々顔出しすると思うから、その時はよろしく～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_170_0121350006" ]},
		{"command":[ "SETCHARA", "0", "char_00017001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おう、お前さん達も中々強かったぜ。今度は、もうちょいゆっくりしていけ\nよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシオラ" ]},
		{"command":[ "SETTEXT", "「はい、またお会いできるのを楽しみにしています。それでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_169_0121350011" ]},
		{"command":[ "SETCHARA", "0", "char_00016901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いっちまったなー。何だか随分騒がしい一日だったぜ。さて、戻るとするか\n……えーと、で、どうやって戻るんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は？　来た道を戻りゃそれでいいだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「えーと、いや、どっちだったかなーって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0221350011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おいおい……ああ、ジュンジローお前なら分かるだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いや……私はお二人の後をついてきただけですので、道はどうにも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_0121350003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこは鼻を効かせるとかなんかあるだろ！？　そ、そうだ、イグニス。お前\nなら……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「は、はい、主殿。途中色々ありましたので、頑張ってしらみつぶしに戻りま\nしょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0121350013" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
