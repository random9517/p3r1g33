		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「フン……あたしとしたいのよね？　こんなムードもへったくれもない場所で\n……いかにもあんたらしいわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00025301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ふふん、ま、エリザもそろそろ魔族の嗜みとして？　オトコを分からせてあ\nげるのも悪くないと思ってたのよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00025301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「いいわ、ま、あんたが最初の相手ってのは、ちょっと物足りない気もするけ\nど。贅沢を言っても仕方ないもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ほら、したいんでしょ？　なら、あんたの粗末なオチンチンでも見せたらど\nう？　どうせ、大したことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「えっ……！？　あっ、えっ……えっと……それ……あ、あの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025301_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「わ、分かってるわよ、オ、オチンチンが……その勃起したから……こうなっ\nてるんでしょ？　知ってるわよっ、それくらいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「で、でも……こんな大きさだったかなって……その、こんなの……は、入る\nの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「なっ……誰が怖いなんて言ったのよっ！　この程度のモノで、何を調子に乗\nってんの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「こんなの、ぜんっぜんっ、どーってことないんだからっ。さっさとやってみ\nなさいよ、エリザとしたくてたまらないんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「そうよ……この程度のオチンチン……あたしのオマンコで……柔らかく包み\n込んであげるんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ほら、どうしたの？　レディをいつまで待たせるつもり？　それともあんた\nの方が怖気づいたんじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「うぎぃぃぃぃぃぃぃぃっ！？　あぐっ、あぉっ……いっ……ふぐぅぅぅぅぅ\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「いっ、きなりっ……あぐっ……お、おくっ……までぇっ……ひっ、ぁっ……\nあぁぁぁぁぁっ！　おちんちっ……ぐぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んはぁぁっ、はぁっ、あっ、はふっ、あぐっ……ナニ……これっ……思って\nたのと……違うっ……お、おっき……すぎるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ウソ……お腹……ぼこってっ……ふ、膨らんでぇっ……こんなっ、ひ、広げ\nられるのっ、ふひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「いぎっ……ふぁぁ……ダメぇっ……オ、オマンコ裂けちゃう……広がりすぎ\nて……うくぅっ……どうにか、なっ……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「な……何でもないわっ！　ふぁっ……んくっ、ふ、ふぅぅん……まぁまぁ、\nね……あんたにしては……それなりって感じ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「つ、強がりじゃないわよ！　ちょっとびっくりしただけでっ、大げさにする\nなって……言ってるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「も、もちろんよ。動かなきゃ、セ、セックスにならないでしょ？　それとも\n、エリザの中がよすぎて、腰が抜けちゃったのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んぐぅぅぅぅっ！？　あぉっ、おっ……おぉっ、ほぉっ、おっ、オチンチン\nっ……またっ、はげっ、しいのっ、ふぎぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「あぐぐぐぐっ！　あっ、ぐぅぅっ……！　らめっ、はひっ、ひ、おぉっ、強\nいっ！　オチンチンっ……強すぎぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、奥っ……届いてるっ！　はひっ、メリメリってっ……くひ\nっ、あぐぁっ、だっ、だめぇぇぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「痛っ……むっ……りっ……それ以上はっ……あっ……くぅぅっ、んっ、あっ\n……ふっ、入らない……からぁっ……あっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「いぐっ、痛くっ……あっ……れっ……なっ、いっ……？　あっ……えっ……\nなんっ……でっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「熱い……けっ、どっ……んひっ、あっ……んっ、うんっ、あっ、ずりずりっ\n……滑って……痛く……なくなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ふぁっ、オチンチンのっ……感触もっ、あっ、分かるぅっ……んぁっ、オマ\nンコっ……ヌルヌルになってるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あっ……ふっ……初めて……なのにっ、もうっ、あっ、こんな\nっ……気持ち……い、いいかもぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「あぁっ……こんな、オトコに……いいように、されて、るのにっ……はっ、\nひっ、あぁっ、中……熱くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「エリザの……オマンコっ……くぅぅんっ！　あっ、感じてるっ……！　あひ\nっ、ずりゅずりゅ……なかぁっ、擦れてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「キツキツのが……よく締まるってっ……し、知らないわよっ！　はっ、うん\nっ、か、勝手にっ……体が反応してっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んんっ、オチンチンにっ……あっ、勝手に吸い付いちゃうんだからぁっ、あ\nっ、あひっ、あひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……ぐりぐり……されてるっ……！　待ってっ、あっ、そこっ\n……されるとっ、腰に力が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んくひぃぃぃっ！　ちがっ……して欲しいって意味じゃないからぁっ、はん\nっ、あぁっ、オチンチンっ、あっ、またぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「嬉しそうになんてっ……あひっ、あぁっ、そんなんじゃっ、あひっ、で、で\nもっ、あぁっ、気持ちっ……いいのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はひっ、あんたもっ……？　も、もうっ、出そうってっ……ちょっ、こ、こ\nのまま……中にっ！？　でもっ、それはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、いきなり……中に出すなんてっ……そんなことっ、あっ、あ\nぁっ、オチンチンっ……震えてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃぃぃっ！　あっ、あちゅいのっ……あっ……出てっ……るっ、出\nてるのっ、中っ、オマンコにっ……出てるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「そんっ……あっ、中出しされてっ……はひっ、オマンコッ……くっ、んぁぁ\nぁっ、イ、イッてっ……は、ひぃぃぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、あぁ……あふっ、中……出されちゃった……精液……\nオマンコの中……いっぱいになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んくぅぅ……はぁ、はぁ……でも、あんたにしては……ま、まぁまぁだった\nわ。中々……悪く、なかったわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んっ！？　あっ、えっ、あのっ、ちょっ……あっ、ひっ……まっ、あのっ…\n…なっ、なんでまた動き始めてるのっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「だってっ、もう、イ、イッたしっ……！　あんたもっ……出したばっかりじ\nゃないっ……なのにっ、あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「これからが本番……そんなことっ、聞いてないしっ……ふひぁんっ！　なっ\n、何……これっ、あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「何よ……めちゃくちゃ荒っぽく動いてたクセに……今更、優しく動いたって\n……そんなの……んくっ、あっ……はっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「やだ……んっ、さっきより……ゆっくりなのにっ、あふっ……なんだか……\nんっ、あっ、オマンコ……あっ、じわじわ……来てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んっ……な、何してるの……？　オ、オマンコの……ヒダ……引っ掻いてっ\n……？　開発……してるっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ナニ……そんなっ、んくっ、調子に……乗ってっ……！　あっ、おっ、あぉ\nっ、しょっ、しょこっ……あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はっ、ふひっ……やら……こ、声……出ちゃっ……そこはっ、うんっ……！\n　こ、腰が……勝手に跳ねて……はっ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「ふぁっ、あぁんっ、い、いいっ！　それっ、いいのっ、あっ、ナニこれっ、\nオチンチンっ、すごいっ、オマンコにキスっ、してくるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ……ダメっ、は、反則よっ、反則ぅっ！　こんなっ、まだ経験\n少ないオマンコにっ、そんなワザっ、使うなんてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、硬いところっ……おひっ、グリグリって！　あひんっ！　あぉっ\n、ダメになるっ、エリザのオマンコっ、らめになるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んんっ……あぁ……な、なに、どさくさにまぎれて……おっ\nぱいつまんでるのっ、んちゅぷっ、キスまで……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「全部……メロメロにさせるなんてっ、だからっ、ずるいっ！　魔族なのにっ\n、あんたなんかにっ、全部っ、支配されちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「はひっ、あっ、あたしもっ、締め付けてるっ？　んんっ、わ、分かんないの\nっ、でもっ、こ、こうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　あっ、あぁっ、オチンチンも……いいんだ……んっ、うん\nっ、ビクビクっ、震えてるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00025301_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
		{"command":[ "SETTEXT", "「んふぅっ……あぁっ、ずぶって来る時に締め付けるとっ……オマンコが気持\nちいいっ！　オチンチンもっ……そうなのねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_253_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エリザデス" ]},
