{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "034_0203101" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おいおい。俺をこんなとこまで呼び出して……まさかメシでも食おうってん\nじゃねえだろうなぁ……？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203102" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ？　いい匂いがするぅ……？　さっきまで店でメシ食ってたんだよ。開店\n前の仕込みっつうか……はー……俺も忙しいっつのに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203103" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「で？　なんだ？　くだらねえ用事で呼んだならぶっ飛ばすぞ。でも……なん\nだ。大事な相談とかなら、ま……聞いてやらないこともねえ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203104" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「結構店じゃ女どもから相談されて……って……。フェラぁ？　待てよ、なん\nでズボン下ろしてんだ。本気かよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203105" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……あぁ？　こうすることでパワーアップするぅ？　ねえだろ。アホか。…\n…つまり、こうか。てめえは今発情してて、何故か俺にそれを慰めて欲しい」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203106" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……かぁー……いつもいつも、なんだかんだで損な役回りだなぁ俺は。おい\n。てめぇ嘘はつくな。ガチでヤベぇ時は……その」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203107" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「しゃぶる……くらいはしてやるよ。よっくわかんねーけど、男って一度そう\nなるとどうしようもねえんだろ？　んで俺が選ばれたんなら……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203108" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「他のヤツに迷惑かける前にちょちょっとなんとかしてやんのが筋か……。オ\nイ。絶対うまくねえけど、……してやるから。出せ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203109" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「チンポだよチンポ！　……ったく、そのブラブラしてるモンをスッキリさせ\nたら戻っていいよな？　こっちこい。全裸でいいから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203110" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……うぉ……思ったよりデケぇな、コレ……。口に入るか？　試してみなき\nゃなんとも言えねえし……やるぞ。オラ……ぷっちゅっ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203111" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん……？　特に味とかしねえのな……。で、どこを重点的にやってほしい？\n　先端か？　竿んとこか？　それとも裏筋……キンタマか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203112" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はぁー？　全部ぅー？　んじゃ、開店までに急がなきゃだろ……。ヤるぜ？\n　ぐちゅ……くぷぷぷ……！　れろっ……れろっれろっれろっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203113" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ちゅぷ……ちゅぷぷぷ……くちゅっ、ちゅぷぷぷぷ……んぅっ……くっせ…\n…！　ちゃんとフロ入ってんのかよ……！　はぁ？　汗で蒸れた？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203114" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「人にチンポ舐めさせんなら事前に洗っとけ……今回は、もうしょうがねえが\n……。んむ……、味はそんなにしねえが激クサだぞ、マジに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203115" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「しょーがねーヤツ……。こういうどうしようもねえヤツ見かけっと放ってお\nけねえんだよな、俺はよぉ……。腰上げろ。舐めにくい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203116" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んむ……っ、ぢゅるっ、ぢゅるるるっ……ぢゅるっ！　んはぁっ……！　ぢ\nゅるっ……ぢゅるっぢゅるっ……んんんっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203117" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そう、そのままチンポ上げとけ……っぢゅるっ！　じゅるっ、じゅるるっ…\n…ぴちゅっ、ちゅっぷっ、ちゅぷっ、ちゅっぷっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203118" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んッ……？　なんか、どんどんデカくなってきやがる……おい。顎疲れっか\nらそれ以上大きくすんな。今ので十分やりづれぇんだから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203119" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん、れろっ……れろっ……ほら、な？　俺の舌や口のデカさとチンポのデカ\nさが合ってねぇだろ。これ以上は顎外れるっつうの……んっ、んむっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203120" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「脳みその栄養が全部チンポにいったみてぇなデカさだな……。それに……ん\nぶっ、なんかヌルヌルしたのが出てきたしよぉ……散々だぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203121" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……何？　黙ってやれ？　誰に命令してんだコラ。……でも、集中しねーと\n開店に間に合わねぇか。……しゃあねーな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203122" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ブーストかけていくぞ！　はむっ！　もごっ……もごっ、もぐ……ん、ん、\nん……んーっ……んっ、んむぅ……ぐちゅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203123" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ぐぽっ！　ぐぽっ！　ぐぽっ！　ぐぽっ！　れろれろれろ……ぐちゅぽっ！\n　ぢゅぽっ！　ぢゅぽっ、ぢゅぽっ、ぢゅぽぽっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203124" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん、ぁ……もっと舌を絡みつかせろ？　こうか……？　んれろっ……れろぉ\n……ぢゅるっ！　ぢゅるるるっ！　じゅぷっ！　れろ……れろ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203125" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っ…ぢゅぷっ！　ぢゅぷっ！　れろれろれろっ……れるぅ……！　れるん、\nれるん、れるん……じゅぷっ……ん゛っ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203126" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おえっ！　太さまで増してきやがる……バケモンかよ……！　め、めんどく\nせーから早くイッちまえ……！　ぐちゅっ！　んぅ、ぐぷっ、かっはっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203127" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ぐっぷっぐっぷっぐっぷっぐっぷっ……！　はぁ……っ、なんて顔、してん\nだ……蕩けきった気持ちよさそーな顔しやがって……ぐちゅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203128" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺みたいな男女にしゃぶられて嬉しいか？　よっくわかんねーやつ……でも\n、ま、悪い気はしねーけど……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203129" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「急所晒してねぶられて喜ぶとか……男って意味わかんねーぜ……。はぷっ！\n　ぐぷっ、ぐちゅぷっ！　ぐちゅっ！　ぐっちゅっ、ぐちゅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203130" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んーっ、んっんっ……んんっ、んーっ、んん……！　ぐちゅっ！　ぐちゅっ\n！　ぐちゅっ！　ぐちゅっ！　……あぁ、そうか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203131" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「こっちも舐めてるうちにやり方がわかってきたぜ。唾を多めに……口ん中で\nチンポを絞り上げるように……ん、ぶ……ぢゅーっ！　ぢゅるるるっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203132" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「かなり強めにすすられたり圧迫されんのがいいんだな？　あったけー口ん中\nでヌルヌル、ヌルヌルすんのは手じゃできねぇわけだし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203133" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん……。くちゅ、ちゅく、ぷちゅ……。口の中で唾を溜めて、かき混ぜて…\n…それからチンポをむしゃぶりつくす……ぐちゅっ、ぐちゅぐちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203134" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あは……なんかこれ、チンポから隊長を操ってるみたいでおもしれー……ほ\nら、ほらほら、俺の口に酔いな……ぢゅるっ、ぢゅるるるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203135" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ぐぽっ！　ぐぽっ！　ぐぽっ！　ぐぽっ！　れろれろれろ……ぐちゅぽっ！\n　ぢゅぽっ！　ぢゅぽっ、ぢゅぽっ、ぢゅぽぽっ……！」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203136" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん、ぶっ、んぶぅっ！　ぐちゅっ！　ぐちゅっ……ぐちゅぷっ！　はぁ、は\nぁ……ぐちゅっ、ぐちゅっぐちゅっ……ん、はぁ？　なんだぁ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203137" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「『もう出そう』……？　ああ、出せ出せ。そのためにやってんだ。ラストス\nパート行くぞ。ぐぷっ！　ぐっちゅっぐちゅっぐっちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203138" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん゛……！？　んぅ゛うううっ！？　んんん゛っ……んーっ！　げほっ！　\nごほっ、ごほっ、ごほっ、おええええ……っ！　げほっ！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203139" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ごぉらッ！　予告もなしに出してんじゃねえよ！　思いっきり鼻に入っただ\nろが！　それに、まともに口に流し込みやがって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203140" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んん゛っ……マジかよぉ……こんなに出るし苦いならやんなきゃ良かったぜ\n……。おえっ……、半端ない量出しやがって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203201" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っててめえなぁ……。俺に罵られてまた勃起してんじゃねーよ……猿か……\n。もう俺は仕事をこなした。帰らせてもらうぜ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203202" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……あん？　今度は俺のことも気持ち良くするぅ？　……どうやってだよ。\nフェラで俺が良くなるわけねーだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203203" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「でも……そんなに言うなら……あと一回な。マジで時間ヤバいんだっつうの\n。……かーっ！　まーだ精液が喉にひっかかってるぜ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203204" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「今度は外に出せよな。んじゃ、……やるか。チュッ……ちゅっ、ちゅっ、チ\nュッ、ちゅっ……あー、尿道に精液残ってんじゃねえかぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203205" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うぇっ、苦……んむ……にげぇ……。うぷ……ぢゅる……ぢゅるるる……。\nくぷ……ちゅぅううっ……ぢゅううう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203206" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んっ、ぷっ、ぐっぷっ！　ぐぽっ、ぐぽっ、ぐぽっぐぽっ……んむ……なん\nだよ、さっきと同じじゃねーか、ってぇ……！　んんんっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203207" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「て、てめぇ！　俺の頭を撫でるんじゃねえ！　はぁ！？　上手に出来てるか\nらぁ？　おまっ、俺をナメてんのか……ってんんんーっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203208" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「や、やめ、やめりょっ……！　しゃぶってる時に顔サワサワされっと……ん\nむぅううっ！？　なんか、なんか……ヤベエ、き、気持ち……いい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203209" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っクソっ……！　一体何なんだよ……邪魔すんなぁ……！　んっ……んむっ\n……！　ぢゅっぷっ、ぢゅっぷっ！　ぬちゅっ、ぬっちゅっぬちゅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203210" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、はぁあ……っ！　ぢゅぷっ……んんっ……んむっ……んむぅ\nっ、はぶっ……！　んぶっ、ンッ、んんん゛……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203211" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「目が蕩けてる……？　馬鹿言ってんじゃねぇ……あぁ……れろっ、れろ……\nれろ、れろ……最強の俺が、少し甘やかされたくらいで……れろっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203212" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「態度改めておとなしいオンナに変わるわけ、ねぇだろ……はぁ、はぁっ……\nぐぷっ……ぐぷぷっ……ぐっちゅっぐちゅっ……あっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203213" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あっ♪　や、やめ……んんん……ちくしょぉ……。なんでこんな、落ち着く\nんだよ……。チンポ咥えさせられてンだぞ……はぁ、はぁあっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203214" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「髪なんか撫でなくていいからガンガン腰揺らせよっ……んぐっ！　一人で動\nくのには限度があっから……ん゛ッ！？　そう、そうだ……んう！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203215" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ……ぢゅるるるっ！　ぐぽっ！　ぐっぽっ！　ぐっぽっ、ぐっぽっ\n……あはぁああ……。んぁ……ぢゅっぷっ！　ぢゅっぷっじゅっぷっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203216" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お、俺ばっかエロ顔見られてんのムカつくから……てめぇもイキ顔晒せ……\n！　ははっ、そうだ……これはバトルだぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203217" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺とお前の戦いだ……おら、俺は負けねえ……てめぇをイカせてやる。ちゅ\nるっ……ぢゅるるっ！　じゅるっ、ぢゅるるるるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203218" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「イけっ！　イけっ……！　デカいだけのエロチンポ痙攣させながら精液出し\nまくれっ……！　んっちゅっ、ぢゅるるるっ！　ぐぷっ！　ぐっぷっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203219" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「くぷぷぷ……ぢゅるるるっ！　あは……チンポ震えてんぞ？　イクか？　あ\nぁ？　イクのかよ？　いいぜ……見ててやるからイキなっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203220" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「精液出せっ、出せ……！　出せっ！　ぢゅるっ！　ぢゅるるるるっ！！　ぐ\nっちゅっぐっちゅっぐちゅっぐっちゅっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "PLAYVOICE", "034_0203301" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん゛んんんーっ！　て、てめぇっ、んんーっ！　ん゛ぅうううーっ！　うう\nーーーーっ！？」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203302" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あんだけ口に出すなって言って……ん゛むぅ゛っ！？　おっぶっ！？　んぶ\nっ……んんんんっ……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203303" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……ぶはぁっ！　ハァ、ハァ、ハァ、……ど、どうすんらよ……この精子ぃ\n……。二度目のくせにたんまりこってり出しまくりやがってぇ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203304" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おえっ……の、飲めぇ……？　んぶ……わ、わかっらよ……。っごきゅ……\nごくんっ！　ごきゅ……ぷっはぁあああ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203305" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ごく……ごく……ごく……。う゛ーーーーっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203306" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うぷっ……！　んだこれぇ……ねばっこくて、喉がイガイガしやがる……。\nんん゛っ、全部飲んだのに……まだ口に残ってる感じするぜ……ん゛っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203307" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「この臭い、口ゆすいでも取れる気しねぇよ……あーあ……。なんかよ、出さ\nれた汁がぷちゅぷちゅしててよ、当分ゼリー飲料飲みたくねえな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203308" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「こんなもんアソコん中流し込まれたら、妊娠確実だぜ。それを思えば、口で\n良かった……のか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203309" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "と、とにかく頼まれたことは完遂しただろ！　これでパワーアップしてんだよ\nな！？　げふっ……ひでー目に合わされたぜ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203310" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「今日のことは誰にも言うんじゃねーぞ。言ったら殺すからな！　……あー、\n顎がいってぇ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]}, 
		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "PLAYVOICE", "034_0203401" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お、……あはははっ！　いいぞ、ちゃーんと外に出せたじゃないかよ！　ひ\nゃー……すっげー勢い。これが男の射精ってやつか」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_10" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203402" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ホースでまき散らしてるみてーにビュルッビュル出んのなぁ。感心したぜ、\nさすがはやり手の隊長……って……褒めてるとこなんだけどよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203403" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「で、出すぎじゃ……ねえのか……。あっ！？　おいっ、かけるな、かけるな\nっ！　き、きったねぇ！　それ子種だろうがっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203404" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「この俺に精液ぶっかけてどうするっ……ああああっ！　これから居酒屋行く\nっつってんだろぉおおお……！　バカなのか！？　うあああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203405" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ふ、風呂に入る時間はねぇし……万が一にも客にバレたらどうしてくれんだ\nよっ！　衛生的にも大問題だしよぉ……んっ！　んっ、んんうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203406" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うっわぁあ……さっきは苦いだけだったけどよぉ……。外に出したら出した\nでくっせーし、ベタベタするしとれねーし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203407" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「でも、……元気ねーよりはいいか……。口に出さねえって約束は果たしたし\nな。しっかし、隊長も大変だねぇ。こんなもん体内に溜め込んで」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203408" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「毎日……ってわけにはいかねえが、暇な時なら面倒見てやってもいいぜ。っ\nて……チンポビクビクさせて返事すんな！　口で言えよっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203409" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……それに、さ。必要とされんのは……嫌いじゃねえ。どうしても世話焼い\nちまう性分なんだ。こればっかりは変えられねえ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003402_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "034_0203410" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「と、とにかくてめぇは勃起しやすい危険人物なんだからな。俺以外の仲間に\n迷惑かけんじゃねーぞ！　ってこった！　わかったな！？」", "NORMAL" ]},
