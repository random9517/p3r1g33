{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SPOTCHARA", "0", "1" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおおっ！　こいつはすげえっ！」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "自分は感受性は低いほうだと思っていたが、さすがに感激して声を上げてしま\nった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "Ｇ・ルナリアムご一行の目の前に広がるのは広大な砂浜、そしてエメラルドブ\nルーの海。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ＴＶでよく見える光景ではあるが、実際に自分の目で見るとこうも違うものな\nのか。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あまりはしゃぎなさるな。お里が知れるというものですぞ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そういうお前も既に海で……何してんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「もちろん、犬かきです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「やっほーっ！！　うっみだっーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「きゃ～～んっ！！　これよこれ！　これこそディアナちゃん向きのロケーシ\nョンよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「は、ただの広い水たまりになにを浮かれて……ってセレイン引っ張るなです\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「熱い…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「確かに素敵な海ね。旅行費のことも、大使館の金庫のことも思わず忘れちゃ\nうくらいには、ね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「な、なにをはしゃいでいるのかしら？　このような場所、美しき我が故郷に\n比べると……きゃあ！　すごい、すごい波だわ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「うーーーみーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "女幹部たちもステラルクスの二人も、海を目の前にして分かり易いほど浮かれ\nている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな中、物憂げな表情で海を見つめるアナザーの姿がみえた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうしたんだ、せっかくこんなリゾート地までやってきたのに辛気臭い顔し\nて」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、すまないカツマ。そんなつもりはなかったんだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「まだ侵略者の脅威を退けられたわけではないのに、私のような者がこうやっ\nて楽しんでいて良いのだろうか……と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "責任感の強いアナザーのことだ、過去を忘れてお気楽に楽しむというのは難し\nそうだな……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「けどよ、たまには羽伸ばしてリラックスしたほうがまた頑張れるってもんじ\nゃねぇのか？　ずっと気を張り詰め続けても良くないぜ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そういうものだろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうそう、せっかく海に来たんだし可愛い水着姿が台無しだぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「か、可愛いだなんて…………そんな、からかうのはよしてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こっちの世界に来てからも復讐や任務に明け暮れていたアナザーが普通の女の\n子らしい表情を見せるのは珍しい、と思った矢先――。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜＆まりあ" ]},
		{"command":[ "SETTEXT", "「じぃー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "7", "LEFT", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00001402_01", "7", "RIGHT", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんだよ二人そろって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「私ももっと露出の多い水着にすれば良かったかも…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021030003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさんは可愛い系よりセクシー系の衣装がお好きなんですね…………、\n私、覚えました…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021030002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよ露出が目的みたいにいいやがって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜＆まりあ" ]},
		{"command":[ "SETTEXT", "「つーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "1", "LEFT", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00001402_01", "1", "RIGHT", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "…………この二人は仲がいいのか悪いのかわかんねぇなぁ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「けーびいんさん、ひどぉい！　お姉ちゃん水着選ぶのに半日くらい掛けたん\nだよ！　良く似合ってるって褒めてあげてよぉ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「つきみ！　余計な事言わなくていいの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな隊員たちの様子を眺めつつ、女王だけは不敵な笑みを浮かべていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふん、今のうちに浮かれておくがいいわ。すぐに『もう帰りたい』と泣き叫\nぶことになるのじゃからな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「陛下、その格好で言われても迫力無いっスよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「う、うるさい！　余はいつもどおりで良いといったのに、エファがこれを着\nないと連れてかないと言うから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "子供っぽいワンピースを着ている女王はどこからどう見てもお子様スタイルで\n、まるで威厳がない。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「当然です。裸で往来を歩きまわられてはどんな悪い虫が寄ってくるか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余がそんな輩にどうにかされるとでも思うとるのか？　むしろ返り討ちにし\nてくれるわ、性的な意味でグフフ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「それがいけないと言っているのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "エファが開かれてはいけない目を見開いて女王を睨みつける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「じょ、冗談じゃよ。なにもそんな目で睨まんでも……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "普段あれだけの威厳のある人には見えないほど、この海では小さく見える。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しかしなんだってこんなところに連れて来たんですか？　他の隊員たちに黙\nって合宿っていうから山にでも篭るかと思ったんですがね」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "他の新規隊員達は置いておいて、Ｇ・ルナリアム幹部連中とステラルクスの二\n人を呼び出して何をするつもりなんだか。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「最近、新しいキャラに押され気味だったからの、番組的にもテコ入れが必要\nとおもってな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんですかテコ入れって…………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「ふふふ……ここにはとある人物が居るのじゃ。お主たちを絶望へと誘う地獄\nの使者がな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030006" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「じ、地獄の使者……？　陛下が言うと冗談に聞こえませんよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「余が冗談を言うと思うか？　ふっふっふっふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「さあ～って、釣りするぞ、釣り～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「早速泳がなくっちゃ～♪　待っててね私だけのプライベートビーチー\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな女王の思惑に全く気付かず、いそいそと遊びの準備を始める女幹部たち\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「おやおや……何の苦労もせず遊べると思っているのかのう……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_007_040021030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、その時、突然背後から黒いシルエットが飛び出してきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "3", "char_00001001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なっ……お、狼……か！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "速すぎてよく見えなかったが、まるで狼のようなシルエットをしているそれは\n、瞬時にセレインたちに襲いかかった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}