{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んーーっ、食った食った♪　これは間違いなくリピート確定だし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021650001" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あぁ、たまにはこういうのも悪くねぇな。いやぁ、色々と語り合えて良かっ\nたぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021650001" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「皆様、ご来店ありがとうございました。またのお越しをお待ちしております\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021650001" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「ご苦労さまどす。再訪は前向きに考えさせていただきましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021650001" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「そうだね、何だったら常連になることを検討してもいいかも知れないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021650001" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ありがとうございます。是非ともよろしくお願いいたします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021650002" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……結局、何時間いたんだよ……やっと帰れる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あ……そう言えば主殿、こちらをほむら殿から預かっておりますのでお渡し\nしておきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021650003" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん……ほむらから？　何だ……何かあいつらについてのアドバイスか何かか\n……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっと……本日の飲食代……下記の通りに領収しましたので、よろしくお願\nい致します……後ほど、給与分から引き落とし致します……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って、ちょっと待て、おい！　何でこれが俺の払いになってるんだっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「何故と言われましても……飲み食いしたら金銭を払うのは、この世界の決ま\nりではありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021650004" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いや、それはそうだが……いやいや、そういうことじゃなくて！　普通\nはほむらがおごる流れだろっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ほむら殿は、男気を見せてくれる奴がいて助かると仰っておりました。主殿\nの度量……私も尊敬致します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021650005" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、尊敬って……いや、おかしいだろっ、絶対俺が持つ流れじゃない！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「なーにを、ゴチャゴチャ言ってるの？　ほら、いこ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021650002" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「行こって……どこへ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そんなの、２軒目に決まってるし♪　他にもいいトコ知ってるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021650003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ねーよ！　今、何時だと思ってるんだ！　大体、金も何にもねーのに、何で\n２軒目なんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「えぇーっ、やだやだ、まだ帰りたくないー！　我はもっと楽しいことしたい\nー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021650004" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "奈羅苦" ]},
		{"command":[ "SETTEXT", "「あぁー、またファンタズマが駄々っ子モードになったかぁ。こいつは、どう\nにもならねぇなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_199_010021650002" ]},
		{"command":[ "SETCHARA", "0", "char_00019901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんな簡単に匙を投げるなっ！　そこは仲間なんだから、しっかり面倒みて\nやってくれよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルスラ" ]},
		{"command":[ "SETTEXT", "「中々難しいことを言うね……この子を宥めるのが大変なのは君も見ただろう\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_010021650002" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ラストノート" ]},
		{"command":[ "SETTEXT", "「世の中には儘ならないことはいくらでもあるもの……時には受け入れるべき\nことはありますでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_198_010021650002" ]},
		{"command":[ "SETCHARA", "0", "char_00019801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「せめて、それを俺に押し付けないでくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「あの……あまり騒ぐと、ご近所の迷惑になりますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021650001" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ……お、おい、氷華っ……オーヴァーハングの相手はマスカレードの担当\nだろう？　こいつら何とかしてくれよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「何とか、というのは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021650002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、だから本来相手をするべきなのはお前らじゃないかって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「勤務時間内でしたらそうなりますが……今の私はオフですので」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021650003" ]},
		{"command":[ "SETCHARA", "0", "char_00005002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺だって同じようなものだろ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "氷華" ]},
		{"command":[ "SETTEXT", "「そうですか。まあ、それは別の所に申請して頂ければ。それでは、私もお先\nに失礼致します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021650004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ま、待ってくれっ……せめて、自由の身に」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「さー、行こ行こ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_010021650005" ]},
		{"command":[ "SETCHARA", "0", "char_00019701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ノォォォォォォォーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}