		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ひゃぁっ、ちょ、ちょっとご主人様！？　アームに身体が、あんっ、固定さ\nれて、動けないんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「えぇっ、お仕置き！？　私、なにかお仕置きされるようなことしちゃったか\nしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504102" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「母乳オイルで、ご主人様のことをヌルヌルにしただろうって？　あ、あれは\nメイドのマッサージとして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504103" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ひゃんっ、お尻を叩かないで。……問答無用でお仕置きされちゃうのね。あ\nあん、ごめんなさいご主人様～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504104" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「で、でも、お仕置きってどんなことをされちゃうの？　動けない私に……っ\nて、なにあのタンクは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504105" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ご主人様……ひゃんっ、タンクの中の、なに……た、垂れてきて……あっ、\n熱いわっ、これ……くんくん、甘い匂い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504106" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「もしかして、溶かしたチョコレート！？　あんっ、ご主人様、そんな……あ\nあ、おっぱいに、熱いのかかって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504107" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あんっ、チョコレートで、おっぱいが……ンッ、ジンジンしちゃうの、き、\n気持ちよくなっちゃうなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504108" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、ああ……っ、乳首っ、乳首にも……ンッ、ひゃぁっ、熱い刺激が、勃\n起乳首に、あっ、あふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「熱くてっ、ンッ、でも、気持ちいいっ。やぁん、こんな感覚はじめて、思考\n回路が、変な処理しちゃってるみたいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504110" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、ご主人様……ぁあんっ！　お、お尻っ、お尻にもチョコレ\nートが垂らされちゃってるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「お尻も熱いの、あっ、あぁんっ！　ビクビクって、勝手に動いちゃう……ひ\nゃぁんっ、いっぱい垂らされて、んっ、んはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「反射的に、機体がぁっ！　んっ、ああっ、動いちゃうっ、熱いチョコレート\nをかけられてるのに、感じちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504113" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「そんなに暴れるとへんなところにかかっちゃうって、言われても……んっ、\nああっ、だって、だって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ひゃぁあんっ！　ちょ、チョコレートが、私のセックスユニットまで、垂れ\nてきて……んひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504115" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「せ、センサーが密集してるところに、熱いチョコレートなんて想定外のもの\nが触れたら……あぁっ、だめだめ、エラー、エラーはいちゃって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁ～～～～んっ！！　んひぃっ、い、イクッ、イッちゃう\nのぉ～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「セックスユニット、チョコまみれにされて絶頂しちゃうなんて恥ずかしいわ\n……んぁっ、ご、ご主人様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504118" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ま、まだお仕置きは終わってないって……ひゃぁあっ、ご、ご主人様のがは\nいってきたのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504119" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ひゃはっ、熱いっ、熱いのぉっ！　ご主人様の、熱いっ、チョコレートに負\nけないくらい、熱いぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「セックスユニット、もうヌルヌルになってるから。このまま……ご主人様の\nで、お仕置きしてくださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504121" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ああぁっ、あっ、ああっ、いきなり激しく……あはぁんっ！　ずぷずぷって\n、んはぁっ、突いて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504122" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ひゃぁんっ、チョコレートといっしょに、中をいっぱいかき混ぜられて……\nんぁっ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「どんどん、潤滑油が……オイルがあふれちゃう……っ！　ああっ、ご主人様\nぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「んひゃぁっ、チョコレート追加されるっ！　ご主人様に、お仕置きされてる\nところに……あっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504125" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「乳首っ、お尻っ、あはぁっ、熱いっ、熱いのぉっ！　んぁあっ、こんなの、\n集中できないっ、ご主人様を気持ちよくするのに、集中できないぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504126" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁあんっ！　でも、ご主人様も、気持ちいいんですか……んぁっ、中で、\nすごく暴れてる……んっ、ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504127" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「セックスユニットを、たくましいものがいっぱい、ごりごりってえぐって…\n…んひぃっ、気持ちいいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504128" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ああんっ、ごめんなさい、お仕置きなのに、すごく感じてしまってます。ご\n主人様が気持ちよくなってくれるから、つい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504129" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ご奉仕メイドカーなので、んぁっ、ご主人様が悦んでくれると、こっちまで\n嬉しくなっちゃうのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ひゃぁあっ、ああっ、セックスユニット、ぎゅうっとしまっちゃいますっ。\nご主人様ぁっ、いっぱい、感じてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504131" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「いっぱい、いっぱい、気持ちよくなって……あはぁんっ、射精が近づいてる\nの感じる……ご主人様ぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「はいっ、欲しいですっ。お仕置き精液で、メイドカーの中をいっぱいにしち\nゃってくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504133" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「しっかりうけとめますからっ、あっ、ああ……いっぱい、いっぱいください\n……精液……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、激しくなってるっ！　ご主人様が、パンパンって腰、んはあ\nっ、激しく打ちつけて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504135" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「い、イク、私も……私も、イッちゃう、あっ、ああ……イク、イク……ッ！\n　あっ、あはぁあああぁぁぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504136" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_09" ]},
