		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「熱くて、勢いもすごいの、ああ、気持ちよくって回路がおかしくなっちゃい\nそうっ！　ああぁああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504139" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「だ……だしちゃってる……母乳オイル噴きながら……ご主人様にぃ……イか\nされちゃったの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504140" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「んふぅ……ま、まさか……まだ、お仕置きですか……ひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「母乳オイルまみれのおっぱいに、また、チョコレート……んっ、ああっ、お\n尻にも、チョコレート……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504202" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「んひぃっ、絶頂を迎えたあとの、熱の刺激……んひゃあっ、ああっ、また変\nな反応……気持ちいいって、処理しちゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、ご主人様のを、セックスユニットも嬉しそうにしめつけち\nゃってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、すごいの、まだまだご主人様の硬くて……んぁっ、ご主人様、腰……\n動かしちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504205" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、またパンパンって、腰をいっぱい、あっ、あっ、打ち付け\nて……んはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504206" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「チョコレートをお尻に塗りながら、んぁっ、ヌルヌルのチョコ……あはぁ、\nお尻撫でられて、んはっ、反応、しちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「アツアツのチョコレート、気持ちいいの……ああっ、またおっぱい、乳首に\n……んぁっ、かけられたら感じて……母乳オイルぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「気持ちよくなって、母乳オイルあふれさせちゃう……あっ、あはぁっ、ご主\n人様ぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「気持ちいいですっ、お仕置きなのに気持ちいい……っ！　んぁっ、ああっ、\nこんなのおかしいのにぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504210" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「正常な反応じゃない……でも、ご主人様が興奮しているならいいのぉっ！　\nあっ、あはぁっ、もっともっと、してぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504211" ]},
		{"command":[ "SETIMAGE", "0", "still_00011105_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「ご主人様のことも、いっぱい気持ちよくしますから……んぁあっ、たっぷり\nオイルのセックスユニットで、締めて、しごくのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_0504212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、ご主人様、あはぁんっ！　チョコまみれのおしりをぎゅって\nしながら、んぁっ、腰を……いっぱい振って……っ！」", "NORMAL" ]},
