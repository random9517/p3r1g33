		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ｏ.Ｅ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、ああっ、精液いっぱい、びゅくびゅくびゅくびゅく入ってくるっ\n、中出しっ、中出しぃっ！！」", "NORMAL" ]},
