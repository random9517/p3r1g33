		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「後は、じっくりしっぽり……そう言いたいところだけど、生憎と私はせっか\nちでね。さっさと下を脱いじまいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403102" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら、手間をかけさせるんじゃないよ！　もうパンツなんて邪魔なだけなん\nだからね。そしたら、そこに横になりな。いいから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403103" ]},
		{"command":[ "SETCHARA", "0", "char_00002504_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……よーし、それでいい……くくっ、なかなかいい格好になったじゃな\nいか。無防備過ぎるポーズ……実にいい眺めだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403104" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「恥ずかしいかい？　なぁに、見てるのは私だけさ。今更、みっともないポー\nズなんて気にしたって始まらないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403105" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……今日は、このチンポを徹底的に可愛がってやろうと思ってね……私\nがご奉仕するなんて、なかなかないんだ。楽しみだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どれ……あぁ、ちゃんとギチギチに勃起しちまったねぇ。屈辱的な格好でも\n、ゾクゾク興奮しちまうって訳かい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……じゃあ、早速扱いてやろうね……どれ、こうして……ふふっ、ゆっ\nくりと皮を動かしてと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403108" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おやおや、まだチンポが大きくなっていくよ。くくっ、本当に快感には正直\nで結構なことだ。ほれ、これ位の強さがいいんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「もう、くちゅくちゅ音をさせてまぁ。私の手コキで興奮してるんだねぇ……\nくくっ、金玉がギュッと縮こまってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ……ガラにもなく緊張してるのかい？　それとも、これは期待している\nってことかねぇ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうして、こんなポーズをさせているのか……エロいことに察しのいいお前\nならもう分かってるんじゃないのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふぅっ……！　ふふっ、お尻がビクビクっと震えたね。ちょっと息を吹きか\nけただけでこの有様だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403113" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうだい、ここを舐めて欲しいんじゃないのかい？　もし、そうなら、私の\n目の前で尻穴をヒクつかせてご覧」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「……んふふっ、こいつはいい。しっかりヒクヒクさせて……よぉし、それな\nらご褒美だよ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「れろ……ちゅぷ、んちゅっ、れろ……えろ……こら、暴れるんじゃないよ。\nせっかくのアニリングスだってのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くくっ、冷静でいられるわけないって？　そこはそれ、上手く身体の力を抜\nいて舌を受け入れるんだよ……える、りゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうだい？　アナル舐めなんて、なかなか経験出来ることじゃないだろう？\n　それも、私直々の極上ご奉仕だ……れる、んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おーおー、肛門をヒクヒクさせてまぁ、ふふ……私の舌がそんなに感じるか\nい？　いいとも、もう少し奥を舐めてあげようね……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「えろ……れろぉ……れるぅ……んりゅっ……汚いって？　ははっ、随分と清\n楚なことを言うじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「れろ、りゅぱ……この程度の清濁を気にしてたらね、れる……ブラックメル\nヘンの首領なんてとてもじゃないけど務まらないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前は、細かいことを気にせず、このケツ穴の感触と……こっち……この、\nビクビク震えた正直なチンポ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403122" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そう、そのことだけ考えてればいいのさ。そら、舐めながら扱いてやるよ…\n…ふふ……情けない格好でせいぜいいい声を出すんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「れろ、ちゅぱっ、んちゅっ……ちゅぅぅぅっ……ふふっ、尻をじたばたさせ\nて……勝手に身体がビクつくのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403124" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こうしてチンポをシコシコする度に、いい呻きが漏れてくるよ。どれ……こ\nの無防備なキンタマも……むぐっ、ちゅぽっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふ、唇で吸われると、身体に力が入らないんだろう？　男の弱いところ位\n知ってるさ……そして悦ぶところもね……ちゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んんっ、れろ……んりゅっ、れろ……じゅぱっ、ちゅぷっ……んふっ、舌先\nを尖らせて……ケツ穴を出し入れすると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ちょっとカマを掘られた気分が味わえるだろう？　お前が望むなら、もっと\n太いのでしてやってもいいけどね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「遠慮する？　そうかい……でも、舌の方は止めないからね。れろ、んりゅっ\n、んむぅぅぅっ、れるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「すごいね、手の中のチンポがまるで暴れ馬みたいに跳ね回ってるよ。手コキ\nが嬉しくて仕方ないんだねぇ、この変態は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「少し先走りも出てきたね……すぐに漏らしちまうんじゃないよ？　ここから\nのもうひと踏ん張りで、最高の射精が出来るんだからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「れろ、んりゅっ……アナルで性感を高めて……ちゅぷっ、金玉を揉みたくっ\nて精子を集めて……後はチンポを扱くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403132" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ずりゅずりゅっ、激しく音をさせてっ……バキバキに浮き上がった血管がい\nい感じだよ……まだだよ、亀頭を抑えてるからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403133" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「後もう少しっ……いよいよって時に手を離してやるからねっ……派手な噴水\nを見せておくれよ。はっ、んんっ、はぁっ、んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403134" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「よしっ……いいよっ、大股開きのみっともないポーズで、思いっきりぶち撒\nけちまいなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403135" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ははっ！　飛んだ飛んだっ！　ふふっ、手にもべっとりザーメンが絡んで来\nてるよっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403136" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら……最高の解放感だろう？　あぁ、だらしない顔をしてチンポを震わせ\nて……今はそれどころじゃないって感じだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いいよ、お前みたいな生意気な男が、そうやって腰砕けで射精してるところ\nを見るのが私の何よりの楽しみだからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んーっ、このドロリとした喉越し……やっぱり新鮮なザーメンじ\nゃないとねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403139" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふぅ……やっと噴水も収まったね。どうだい、アナル性感での射精……病み\nつきになりそうだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403140" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さぁて……一息ついたと言いたいところだろうが、私としてはここからが本\n番って感じだねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「チンポの方も、ちっとも硬さが変わらないみたいだし……これは、もっとし\nて欲しいってことなんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403202" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くくっ、だんまりだけど、チンポは正直にピクピクしてると……どれ、また\n気付け代わりにこうして……れろ、んれる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふぉら、すっかりアナル舐めで悦ぶ身体になっただろう？　れろ……ちゅぷ\nっ、またチンポもシコシコしてやろうねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「お前が出した精液のお陰で、手もヌルヌルだ……この調子ならこうして……\nふふっ、いい感じに滑るねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうだい、このぐちょぐちょって音……お前の恥ずかしいチンポが鳴らして\nる、いやらしい音だよ……んっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いっぱい出したから少しはしおれるかと思ったけど、全くそんな気配はなし\nと……まだまだ金玉の奥に残ってるってことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「となれば、もっと派手な噴水を見せてもらうために……しっかりと次の準備\nをしないとね……れる、んりゅぷっ、んむぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら……手の中のチンポがのたうち回ってるよ……まだまだアナル舐めには\n慣れないかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403209" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「こんなの慣れる筈がない……？　くくっ、なるほど……いつまでも新鮮な気\n持ちでアナル責めを楽しめるって訳だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「またタマも一緒に握り込んで……こうしてぎゅうっとすると……そうそう、\nその情けない声……楽しいねぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「りゅぱっ、んちゅっ、ちゅぅぅぅっ……んむっ、ほら……こうだよっ、もっ\nとチンポして欲しいんだろう？　おねだりしてみな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403212" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「クィン・テイル様の手で、恥ずかしい勃起チンポをシコシコして下さいだ。\nじゅるっ、んちゅぷぅぅっ……ふぉら、言いな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふぅっ……ふふっ、やっぱり欲望には勝てないねぇ……その情けない声に\n免じて、特別サービスだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほぉら、ぐちゅぐちゅってね……どうやら先っぽからまた新しい汁が滲んで\nきたよ……もっとチンポを気持ちよくして欲しいって催促だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403215" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いいとも……こうだろう？　ふふっ、気持ちいいんだろう、出したい出した\nいってチンポが震えまくってるよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「れろ……後もう少しだ……身体を楽にして私の舌を受け入れな……そうした\nら、奥に届くからねぇ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403217" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、んちゅぷっ、んりゅぅぅぅっ……れる……さあ、そろそろチンポ\nの震えも限界だろう……いいよ、また派手に出していいからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ギリギリまで我慢してみな……もっとも、今度は加減しないからね……ドピ\nュッと出すまで扱き続けるよ……んっ、ちゅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403219" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふぉらっ、もう遠慮はいらないよ……お前の欲望っ……思いっきりぶち撒け\nちまいなっ、んりゅっ、んちゅぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403220" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふうぅぅぅっ……！　あぷっ、んんっ……出たねっ……んっ、ふふっ、手\nにまた熱いのがどんどん掛かってくよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403301" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「いいねぇ、さっきと変わらない勢いの噴水だ。情けないイキ顔をよーく見せ\nておくれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふふっ、射精中はケツ穴もギュッと窄まるんだねぇ……どうしても自然に力\nが入っちまうんだろう？　可愛いもんだ……ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「そして、こうしてキスしてやると、またチンポが震えてザーメンが飛ぶと…\n…まるで永久機関だね……くくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「とは言え、流石に２発目だし、そろそろ出す量も限界ってとこか……ほぅれ\n、最後にもう一発出しちまいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403305" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「くくっ、出た出た……ちょろっとだけど、根こそぎ搾り出された感じ……楽\nしめただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どれ……チンポもかなりくたびれたみたいだねぇ。最後くらいはちょっと優\nしくよしよししてやろうかね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403307" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「おっと、これくらいの優しさでも、今は相当に敏感になってるんだね。大丈\n夫さ……もうギュッと強くしたりはしないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「うん？　それはそれで物足りないって？　ハハッ、全く気持ちいいことには\n正直な奴だね。心配しなくてもせっかくの聖夜だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「少し休んだら、またカラカラになるまで搾り尽くしてあげるからね……楽し\nみにしておくんだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んんんっ！　はぷっ……出てきたねっ……今度は顔に掛けたいのかい？　い\nいよ、ほら……浴びせてみせな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403401" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「んふっ、さっきと同じ位の勢いだ……頬にへばりつく、このぬめり……ふふ\n、プリプリで活きがいいねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……ちゅぷっ……んっく、この喉越し……生ならではを味わえるのは\n贅沢なもんだ……ちゅぱ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ほら、まだもう少し出せるんだろう？　ケツ穴をつついてやれば……ほら、\n溢れてきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403404" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「とは言え、もう量も落ち着いて来たね。最後の最後にもう一搾りってところ\nか……んーっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ふぅ……カラカラになったかい？　ちょっと刺激が強すぎたかも知れないね\n。まだ、尻の筋肉がプルプル震えてるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「大丈夫さ、最後は優しく撫でてあげるからねぇ……ふふ、頑張ったチンポを\nねぎらってやらないとね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……うん、後はチンポについたザーメンを舐めて……綺麗にしてあ\nげようね……りゅぱ、じゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403408" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「あぁ、いっぱい残ってる……ちゅぱっ……ここにも、んりゅっ、こっちにも\n……ちゅぱっ、んちゅぷっ……ふふ……これでいいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「どうだい、楽しめたかい？　まだまだ聖夜はこれからだ。少し休んだら、ま\nたじっくりと楽しもうねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_0403410" ]},
		{"command":[ "SETIMAGE", "0", "still_00002504_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
