{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「アタシにメンテナンスを頼みたいって聞いたけど……なに、アンタどっか身\n体悪いの？　大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「って、なんでおちんちんそんなに勃起させてるのよ。……あ、メンテナンス\nってそーゆーこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふっ、何よその変な頼み方、バッカじゃないの♪　アタシにしてもらいた\nいなら、素直にそう言いなさいっての」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00021301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……分かった、口でしてほしいのね。いいわ、私の口で、アンタのおちんち\nん、気持ちよくしたげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「実はアタシも前からちょっと興味あったのよね。データでしか知らないフェ\nラチオ……おちんちんってどんな味がするんだろうってさ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「おぉ……改めて目の前に突き出されると、人間のおちんちんって中々にグロ\nテスクよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00021301_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「っていうか、思ってたより大きいわね。ぺろぺろキャンディみたいに咥えれ\nばいいと思ってたけど、これ全部口に咥えきれるかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「とりあえず先端を舐めればいいのよね……ペロっ、ちゅ……んっ、データで\nは知ってたけど、やっぱりキャンディの様に甘くはないのね……れるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ちゅ、れるっ……なるほど、これが人間の男の味……んれるっ……しょっぱ\nくて、苦くて……んちゅ……まぁ、美味しくはないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「でも……ふふっ、アンタの味だって思うと、いつまでも舐めていたいかも…\n…ちゅ、れるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「なるほど、これがフェラチオ……ぺろっ……バカみたいな行為のはずなのに\n、人間が夢中になるのも分かるかも♪　ちゅ、んれるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふっ、そんな焦れた声出さなくても、分かってるってば。アタシの口内の\n感触、しっかり楽しみなさい♪　……あーむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んくっ、ちゅ、んれるっ……やっぱり、根元まで咥えるのは難しいわね……\nんれるっ、ちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「とりあえず、先っぽの膨らんだ部分……んれるぅ……亀頭って言うのよね、\nここだけいーっぱい苛めてあげる♪　んちゅ、んれるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「確か、参考データではこうやって舌先を尖らして……じゅぶ、じゅれるっ…\n…おしっこの穴をほじほじするのが気持ちいいのよね……じゅれるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んっ……おちんちんの反応が鈍い……じゃあこっち、括れの部分を舌から押\nし上げるようにして……じゅれるぅ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「なるほど、この動きね♪　腰をビクンってさせちゃって、分かりやすいんだ\nから、んれるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「じゅぶ、じゅれる、んれるぅ……♪　……ん？　ぷはぁ……本当にフェラを\nするのは初めてかだって？　初めての割にうますぎる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふっ、アタシのスペック舐めてんじゃないわよ♪　アンタのおちんちんを\n手玉に取るなんて、らくしょーなんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「今度はさっきよりも深く……あーむ♪　じゅぶ、じゅぶる、じゅるるう♪　\n頭ごと動かして、唇でおちんちんを扱いてあげる♪　んじゅるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「じゅぶ、じゅるる、じゅぶるぅぅ……♪　口の中で、おちんちんがビクビク\n跳ね回ってるのが分かるわ……んれるぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「血管もドクドクいって……れる、ちゅれるぅ……！　おちんちんの膨張率も\nまたあがったかしら……んじゅぶ、じゅれるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「えっちなお汁もまた溢れてきたわね……んれるぅ！　カウパー腺液……ガマ\nン汁……先走り……呼び名も色々あるものなのね、じゅれるぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「じゅぶ、じゅぶる、じゅっるるぅぅ……！　んはぁ、んんっ、んじゅぶぶる\nぅう！　じゅば、じゅぶじゅぶぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「最初は変な味だと思ったけど……んじゅるっ……飲めば飲むほど、思考回路\nに熱が蓄積して……んんっ……いくらでも飲めちゃうかも♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「私の口が気持ちよすぎるって？　……ふふっ、あったりまえじゃない♪　私\nのボディは最新型、えっちな機能だって全身に完備してるのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「こうして……んじゅるぅ、じゅるぅぅ♪　いつでもアンタの事を満足してあ\nげられるようにね♪　れる、れるれろぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「口内の柔らかさや、温度管理に至るまで……んれるぅ……アタシの全てでア\nンタの事、気持ちよくしてあげるんだから……じゅれる、じゅるぅぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「舐めるだけじゃなくて、喉を鳴らして、おちんちんに吸い付いて……じゅる\nるぅぅ……！　舌も回して、亀頭を振り回す……じゅぶ、じゅぶぶぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふっ、バカみたいな下品な音がアタシの口から響いてる……♪　分かって\nるわよ、アンタ、そろそろイっちゃいたいのよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「おちんちんビクビクさせて、アタシの口の中で射精しちゃいたいんだ♪　じ\nゅぶる、ぢゅっ、じゅるっるぅ！　じゅば、んれるぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「いいわよ、このまま口の中に出しちゃって……！　んじゅるぅ、アタシに精\n液の味を教えて！　じゅぶるぅ、じゅるるうぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅ！　んんっ、じゅれるぅぅぅう……！　じゅぶ、じゅぶぶぅぅ…\n…！　んくっ、んくっ……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「こ、これが精液の味……苦くて、濃くて……喉の引っかかる……んくっ……\nガマン汁とはまた違う……んく、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「なるほど……喉に引っかかって意外と飲み込みづらいのね。あー、あれかな\n？　ヨーグルトみたいな駄菓子？　と同じのど越しかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「確かタンパク質が含まれてるって話よね。……緊急用のエネルギー補給にな\nったりはするのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……で、どうよ、アタシの初めてのフェラチオは？　気持ちよかったかしら\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あっ……ふふっ、なーに、突然頭を撫でたりして♪　……まっ、このアタシ\nが本気出してフェラチオしてあげたんだもの、気持ちよくて当然よね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……それにしても、やっぱり一回出したぐらいじゃ、おちんちん小さくなっ\nたりはしないのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「まったく、しょーがないわねぇ♪　……いいわよ、アンタが満足するまで、\n何度だって付き合ってあげちゃうんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あーむっ、じゅる、んれるぅぅ……♪　アンタの好きそうな動きは、さっき\nので分析が終わったからね♪　んれるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「こうして舌の腹をべったりとくっつけて……じゅれるぅ、じゅる、れるれる\nれろぉ……！　皮と亀頭の隙間をほじくるようにっ……んじゅれるぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふっ、何よ、その女の子みたいなかわいい声は。腰も引けちゃって……ま\nっ、逃がしはしないんだけどね、んれるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「じゅぶっ、じゅれる、じゅるるぅぅっ……！　ぐぶっ、じゅぶ、じゅぶじゅ\nぶるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「こうやって吸い付けば、先っぽからさっきの精液がまだ溢れてくるのね♪　\nんじゅる、んくっ……この味、ちょっと癖になっちゃうかも……じゅれるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ぷはぁ……ねぇ、このままもっと気持ちよくしてあげるからさ、アンタも、\nさっきみたいにアタシの頭、撫でてくれないかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あぅん……んんっ……不思議よね……アンタの手、別に優しくもないし、ど\nっちかと言えば乱暴な感じもするのにさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「こうやって頭を……んんっ……うさみみパーツを撫でられると、それだけで\n凄く幸せな気分になっちゃうのよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「あーん……んれるっ、じゅ、じゅれるぅ……！　今度はアンタがイクまで、\n舐めるのを止めてあげないんだから♪　じゅ、じゅれるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「じゅぶじゅぶ、じゅぶるぅぅ！　んふっ、んれるっ……！　おちんちん大き\nすぎて、全部咥えることはできないから、根元の方は……こうよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふっ、余ってる皮で根元の部分シコシコされるの、気持ちいいんだ？　ん\nれる、ちゅ、れるれるっ、れろぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「じゅぶ、じゅれるぅ……んんっ……！　これ、口の中、アンタからでた色ん\nな液体のにおいで、凄いことになっちゃってる……んれるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んちゅ、じゅる、れるぅ……！　んふっ……おちんちん舐めてるだけなのに\n、快感を司るセンサーも異常な数値が出て……あっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「こ、これがデータにあったエッチなエラーってやつなのね……ちゅ、じゅれ\nるぅ……アタシ、おちんちん舐めてるだけで、イッちゃいそうなんだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「って、なんでアンタが照れてんのよ。……え？　アタシが素直過ぎてドキド\nキした？　……知らなかったの？　アタシ、アンタのことが大好きなのよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「大好きな人のおちんちん舐めて気持ちよくなるなんて、当たり前じゃない♪\n　んれる、れるれるれろぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　口の中でまたおちんちん跳ねさせちゃって♪　ちゅれる、じ\nゅ、じゅるるぅ！　じゅぶ、じゅぶじゅぶ、じゅぶるぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ほら、頭を撫でる手が止まってるわよ……ふふっ、それでいーの♪　ちゅ、\nちゅれる、れるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「我慢なんてするんじゃないわよ♪　アタシのフェラチオで、思う存分精液を\nぶちまけちゃいなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んじゅるるるうっ！　このまま全部出してっ！　れるっ、れるれろぉ！　ア\nンタの欲望を、全部アタシにぶちまけてっ！　んじゅるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んふぅぅうんっ♪　んじゅるる、じゅ、んぐっ、んんんんぅ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「に、二回目なのに、すごい精液の量……！　じゅる、じゅるっるるう……吸\nっても吸っても、溢れてくる……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んくっ、んくぅ……熱いドロドロが、喉の器官を流れていく感覚……あっ、\nああっ、んくぅぅうんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「こ、これ、さっきのエラー……！　全身が熱暴走を起こしてるんじゃないか\nってぐらい熱くなって、視覚センサーもノイズで塗れて……ふあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「アタシもイッてる、アンタの精液飲みながらイッてるわ……♪　んじゅる、\nれるれろ、じゅっるるう……んくっ、んく……んふぅん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ぷはぁ……はぁ、はぁ……んっ……もう出ないわよね？　まったく、出し過\nぎなのよ♪　アタシのお腹の中、アンタの精液でタプタプよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……ふふっ、お礼なんていーのよ。アンタが喜んでくれるなら、アタシだっ\nて嬉しいんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「でも、そうね……お礼だって言うなら、またアタシの頭を撫でさせてあげる\n♪　優しく撫でなさいよ？　ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……で？　どうなのよ、二回出しただけでアンタは満足したわけ？　……ま\nっ、この固いままのおちんちん見れば答えなんてわかり切ってるけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「メンテナンスの続き、しましょうか？　アンタが満足するまで、何度だって\n付き合ってあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ぷはぁっ……！　あっ、んくぅぅぅんんっ～～！！　あ、熱い精液、顔にか\nかってっ、あっ、んあぅぅんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021301_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「これ、顔射って言うのよねっ！　んんんっ！　口の中に出されるのもよかっ\nたけど、これはこれでっ！　あっ、あぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ふふふっ♪　まるでアタシのすべては、アンタのモノだってマーキングされ\nるみたいで……んんっ♪　顔に出されるの、気持ちいい♪　んあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「さっきと同じ……エッチなエラーが思考回路に溢れかえって……んふぅんっ\n♪　そっか、アタシ、アンタの精液を顔に出されてイっちゃってるんだ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「ドロドロの精液が顔を伝ってる……ああ、匂いもすごいわね……すんすん…\n…ふふっ、この匂いもちょっと癖になっちゃうかも……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「んっ……流石にそろそろ出し切ったかしら？　ふふっ、おちんちんぴくぴく\nしちゃって、かわいーんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……って、なーに今更謝ってるのよ♪　大好きなアンタの精液だもん、顔に\n出されるのも嬉しいに決まってるじゃない♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「謝るぐらいならほら、またアタシの頭を撫でなさい。優しく、愛をこめて、\nね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「そうそう、それでいーの♪　アタシはアンタのモノなんだから、雑に扱った\nりしたら、許さないんだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミヤビ" ]},
		{"command":[ "SETTEXT", "「……さぁ、次はどんなメンテナンスをしようかしら？　もちろん、まだまだ\n付き合ってくれるわよね？　ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_213_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}