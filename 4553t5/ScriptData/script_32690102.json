{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ん……起こしちゃいましたか。ふふ、なんでここにって……サキュバスが男\nの寝室に忍び込む理由なんて、一つしかないでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んふ……逞しい身体……昼間見たときも思いましたけど、すごくいい身体を\nしていますよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104102" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「サキュバスにとって、とても魅力的な身体……んっ、もちろん私はあなたの\n全部が魅力的ですけれど、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「毎日毎日、オフィスであなたの顔を見て、声を聞いて……そうしてたら、身\n体が熱くなって我慢ができなくなってきたんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「勘違いしないでくださいね。サキュバスとしてじゃなくて、一人の女として\n……あなたのことが好きなんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「でも、私はこういうやり方しか知らないから……ねえ、私のこの想い、受け\n止めてくださいますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ん……嬉しい。じゃあ、あなたのオチンポを……んっ、入って、きた……あ\nっ、んっ、ずぷずぷって……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、んんっ、なにか、なにかおかしいです……今まで、こんな風に\n感じたことないのに……あなたのオチンポで、腰が蕩けそう……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「動かしてもないのに……満たされて……んんっ、ふっ、あっ、こんな、こん\nなに胸がドキドキしてる……んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「幸せ……オチンポを入れてるだけなのに、幸せ……んっ、あなたの顔も、汗\nも、吐息も、全部愛おしくなっちゃって……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふ、分かってますよ。男の人は動かないと気持ちよくなりませんよね……\n私も今だけで満たされてるけど、もっともっと気持ちよくなりたい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「それじゃ……んっ、あっ、んんっ、ふうっ。あっ、凄い、動いたら、さっき\nよりもお腹がきゅんきゅんしてる……んっ、あっ、あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あなたのオチンポが、私のオマンコをずりゅずりゅするだけで、身体全部が\n溶けてしまいそう……んんっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あふっ、うっ、あんっ、ゆっくり動いてるのにこんなに気持ちいいなら……\nあっ、速くしたら、どんなに……んっ、はっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んんっ、その顔……ふふっ、もっと動いて欲しいって書いてありますよ。そ\nれじゃあ、んっ、あっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、これ、凄いっ！！　あなたのオチンポが奥をとんとんとんっ\nて、叩いてきて、んっ、ごりごりってこすれて……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んっ、うっ、あんっ！！　こんな……こんなに気持ちよくなったの、初めて\nっ！！　あなたのオチンポが入ってくるたび、身体が……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「身体がきゅうううって悦んで、んんっ、分かります？　オマンコ、締めつけ\nてるの、あんっ、あなたのオチンポをぎゅって締めつけてるのっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んううっ、好きだから、あなたのことが好きだからこんな風になってるんで\nすよ。こんなに気持ちいいセックス、初めて……あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んっ、好き、好き、大好きです。こんな風に男の人を、あなたを想ったこと\nなんてなかったから……あんっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ああっ、愛する人とのセックスって、こんなにも違うものなんですね……精\n気を奪うだけのとは全然違う……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「好きな人と繋がったら、身も心も満たされて……ああっ、んっ、これが本当\nのセックスなんですね……ふううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、あくっ、んんんっ。オチンポが奥に届くたび、身体が切なく\nなって……でも幸せになって……ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あなたの想いがオチンポから伝わってくる……ふああっ、あっ、んんっ、あ\nっ、気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「身体だけじゃなくて、心も繋がってる……んんっ、あなたも気持ちよくなっ\nてるのが分かる……ふふ、心じゃなくて顔からも分かるけど……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっ、うっ、急に動かないで、んんっ！！　そんな、からかったお返しだっ\nて……ふうっ、うんっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっ、ダメ、それダメっ、奥をごりごりって押しつぶすの、ダメっ！！　お\n腹の中、オチンポで溶かされちゃう、あっあっあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ダメって言ってるのに、んんっ、いじわる、ふあっ、あああっ、オチンポ、\nオチンポがごりゅごりゅって……ひうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んんっ、軽くイっちゃった、サキュバスなのに、私サキュバスなのにあなた\nに軽くイかされちゃった……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「えっ……愛しあうセックスなんだからどっちが先に、何回でもイっていいっ\nて……んんっ、ああっ、んっ、そうなのね……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「搾精じゃない、なんてことのない、普通のセックス……好きな人とするセッ\nクス……んんっ、あっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んうっ……でも、だからこそあなたにもイってほしい。好きだからこそ、あ\nなたにももっと気持ちよくなって欲しい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「だから私ももっと動くわ……あっ、んっ、ふうっ！！　んっんっんっ！！　\nどう、この腰の動き……オチンポをぎゅって抱きしめて、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「こうしたら、ほら、オマンコの中が舐めるみたいにオチンポをしごくでしょ\n、ふうっ、うううっ、ああっ、気持ちよさそうな顔……ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ああっ、わかるわ、オチンポが膨らんできてるの、私の中に出す準備してる\nの、んんっ、ふうっ、あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「くるっ、くるのね、ラブラブセックスでザーメン出してくれるのねっ！！　\nいいわ、いっぱい出して、オマンコが溺れるぐらい出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、私も、私もまたイくっ、イっく、イくううううっ！！　んん\nんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふあああっ、出てる、ザーメン出てるっ！！　どびゅどびゅ、私の中にラブ\nラブザーメン注がれてるうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふあっ、ああっ、凄い……気持ちよさと幸福感が……ああっ、んっ、好き…\n…好き……幸せ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「満たされてる……あなたの愛で私今、満たされてる……ふうううっ、これが\n、本当のセックス……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んふうっ……ふっ、こんな気持ちいいこと、一回じゃ終われないですよね…\n…？　オチンポもまだ硬いし……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ね……ね、もう一回、もう一回しましょう？　ほら、こうして、ゆっくりと\n腰を動かしたら……ふふっ、あなたも腰が動くじゃないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んっ、さっき出されたザーメンが中でぐちゅぐちゅってかき混ぜられてるの\n、分かるでしょう？　また違った感触で……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「入り口を締めつけながら、こうして動いたら……んっ、ふっ、きつさと絡み\nつきで……んふうっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「亀頭もこうやってちゅっちゅって奥で吸いついて……オチンポ全部、気持ち\nよくしてあげる……んっ、あっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふっ、今なら分かるわ……私がサキュバスとして生まれた意味が……んん\nっ、こうして、愛しい人を……あなたを……あくうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あなたを気持ちよくするために、私はサキュバスとして生まれてあなたに出\n会ったんだわ……んんっ、ふっ、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「だからあなたは私を好きに抱いて！！　気持ちよくなって！！　サキュバス\nの私を抱きつくしてっ！！　ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、そんな、一緒に気持ちよくなりたいって……そうじゃなきゃ意\n味がないって……ああっ、そんな、そんなこと言われたら……あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「もうダメっ、気持ち、抑えられなくなっちゃう……好きっ！！　好き好き好\nきっ！！　大好きっ！！　愛してるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「もう誰にも渡したくなくなっちゃう！！　私の、私だけのあなたにしたくな\nっちゃうっ！！　ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「今だけ、今だけでもいいから、私だけのあなたになって……んっ、ああっ、\nあっ、オチンポから気持ち伝わってくる、嬉しいっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふうううううっ！！　あっ、あっ、あなた……愛してる、愛してますっ、ひ\nうっ、あああっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「オマンコが、オマンコの中が啼いてるっ！！　嬉しいってっ、大好きって、\nきゅうきゅう啼いてるっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっ、オチンポもパンパンになって応えてくれてるっ、ふああっ、あっ、あ\nんっ、いいっ、気持ちいいっ！！　こんなセックス初めてっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んんんっ、今度も、今度も一緒にイきましょう！！　大好きなあなたと、オ\nチンポとオマンコで、一緒に、一緒にイきましょうっ！！　ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、こんなにじゅこじゅこ突かれたら、あっ、溶ける、溶けちゃ\nう、オマンコの奥、オチンポで溶かされちゃううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あっ、イく、イっく、オマンコイっく、んんっ、オチンポも\n、オチンポもイって、私の中にまた出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あなたのザーメンで、私の中いっぱいにして、溺れさせてっ！！　ザーメン\nカクテル飲ませてえっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あうううっ、イっく、イっく、イっくううううううううううううううううう\nうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んんんんっ！！　おかわりザーメン来たあっ！！　中にどぷどぷ来たあっ！\n！　オマンコでごくごく飲んでるっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふうううっ、んっ、あっ、息できない、こんなに注がれたら、オマンコ溺れ\nて息できないっ、ふあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、熱い……んんっ、どろどろザーメン熱くてオマンコの中やけ\nどしちゃう……あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「それにこんな濃い精気……んんっ、頭がくらくらしちゃう……全身でザーメ\nン飲みこんだみたい……ふうっ、あんっ、また追加が、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふっ、全部出してくれてる……嬉しい……んっ、ザーメンからも、あなた\nの気持ちが伝わってくる……あくっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んふっ、ごちそうさま……ラブラブセックスを抜きにしても、凄くよかった\n……あなたに惹かれる人が多いのも、納得です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「もちろん私ももう……あなたからは離れられないわ。こんなに素敵で、優し\nくて、それで……エッチな人とは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「やんっ、怒らないで、サキュバスからしたら最高の褒め言葉じゃない。私の\n気持ちに応えてくれるあなた、とっても素敵……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ね、搾精じゃなくても、これからも一杯抱いて……あなたとセックスしたら\n、心が満たされるもの。いいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あんっ！！　返事代わりにキスだなんて。でも嬉しい……大好き。愛してま\nす、あなた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104310" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、なんでオチンポ抜いて……あくうううっ！！　私の身体に、\nひあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、凄い、ねばねばザーメンシャワーで私の身体がザーメンまみ\nれに……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふあああっ、肌と服に染みこんで、熱さと匂いが……んんっ、身体がザーメ\nンでべとべとになってる、あんっ、ああっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、中じゃない、中じゃないのに……んっ、これはこれで気持ち\nよくて……ああっ、あっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「んうううっ、ぶっかけからあなたの愛を感じる……んっ、はっ、あっ、幸せ\n……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ふふっ、全部かけてくれたんですね……んっ、ふうっ、私があなたの女だっ\nていうしるしですね……愛されてるしるし……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00026901_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「しばらくこのままで過ごそうかしら……んふふっ、冗談ですよ。さすがにこ\nのままじゃ外に出られませんし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「でも、そうですね……またいっぱいこうしてかけてくれなきゃ、もしかした\nらこのまま過ごしちゃうかも……なーんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「中に出されるのもよかったけど、こうしてぶっかけられるのも……あなたに\n包みこまれているみたいで、いいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_269_0104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴梨果" ]},
		{"command":[ "SETTEXT", "「ね、ね、こんどは頭のてっぺんからつま先まで、全部ぶっかけてください。\n私の身体、全部にしるしをつけて……ね、あなた？」", "NORMAL" ]},
