{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0045" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ようこそ、いらっしゃいました。どうぞ、お体を楽にしてこちらへお越し下\nさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00003003_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「それで、何かリクエストがあるようなことを伺いましたから……よろしけれ\nば、仰ってみて下さい。ご期待に添えるといいのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「え……？　私がママになって……母乳をまぶしたパイズリを……して欲しい\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00003003_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ママ……母親ですよね。それで、私が貴方のオチ○ポを……母乳を出してか\nら、おっぱいでお扱きすればいいと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303105" ]},
		{"command":[ "SETCHARA", "0", "char_00003003_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ちょうどご褒美を与えるように、ですか……承知しました。それでは、早速\nですが……オチ○ポをお出し頂けますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あら……もう、こんなにされていたのですね……ふふ、とても逞しいオチ○\nポ……私も、前をはだけさせていただきます……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00003003_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「えぇと、それでは……いつも、みんなの為に頑張ってくれてありがとうござ\nいます。今日は、ママからご褒美がありますからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「では、オチ○ポを挟み込んじゃいましょう……あ……んんっ……んふっ、熱\nを感じます……気持ちよくしてあげますからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「まず……母乳を出さないといけませんね……準備をしますから、ちょっとだ\nけ待って下さい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ……あぁ……軽く摘んで、力を入れながら転がしてあげます……んっ\n、ぁっ……はっ、ふぁっ、んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「こうして、あっ、はっ……刺激を続けてあげると……あっ、あぁっ……もう\nすぐです……あと、もう少し……んっ、ふぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ……出てきました……母乳がびゅくって……あっ、いっぱい溢れ出して\n来て……ますっ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「では、これを……しっかりオチ○ポ全体に塗りつけて行きますね……んふぅ\nっ、この辺から……この辺……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ、もちろん亀頭は、少し重点的にしてあげないと……あっ、ふぁっ……\nんんっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どうですか？　そろそろたっぷり馴染んだでしょうか。それじゃあ、よく頑\n張ったご褒美です。ママがパイズリしてあげますからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、はんっ、ふっ、あふっ……あぁ……ぎゅって押し込むと……オチ○ポ\nの熱をすごく感じます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「このまま、縦に……おっぱいを……えいっ……んっ、はっ、あっ……んんっ\n……ふっ、上下に揺すって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どうですか？　オチ○ポ……気持ちいいですか？　ふふっ、それは良かった\nです。はい……私のおっぱいも、貴方のオチ○ポを挟んで感じていますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっと密着して……それぞれの熱を共有しましょう……んんっ、どうですか\n……おっぱいにすっかり飲み込まれてしまいましたが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、中で……脈打っているのが分かります……あぁ……とっても\n元気なオチ○ポ……んっしょ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ほら……いい子ですね……逞しく成長した所を、ママによく見せて下さい…\n…あぁ……おっぱいも、気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっと母乳まみれがいいのですか？　はい……では、もうちょっと出してみ\nましょう……んっ、あぁ……あふっ、んっ……あぁ、出ます……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、これを全部塗って……ヌルヌルのまま、動かしてあ\nげますからね……んっ、んしょっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「くぅん……んふっ、乳首が……とても感じやすくなっています……キュンと\n硬くなって……オチ○ポに擦れると、すごく気持ちよくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……貴方も乳首の感触……分かりますか？　はい、ぎゅっと……押し潰\nすみたいにくっつけて……そのまま、擦り上げて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……んっ、あぁ……オチ○ポも中で反り返って……ふふ、とっても\n正直みたいですね……可愛らしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……匂いもして来ました……んっ……これは、射精前の……お汁ですね\n……んっ、出したくなって来ましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、出したくなったら、いつでも好きな時に出していいですよ。ママのお\nっぱいに直接出しちゃいましょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、まだ我慢するんですか？　くすっ、男の子の一生懸命な所……とても\n素敵ですよ……でも、無理はしすぎないように……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふんっ……もう、オチ○ポがビクビクしているのは分かりますから……\nおっぱいの中で、今にも爆発してしまいそうになってますもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ、とっても可愛いです。もっと、いっぱい押し付けて……ヌルヌルの母\n乳を絡ませてあげたい……はぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ、あっ、腰が震えてっ……あんっ、いいですよっ……最後は自分でお\nっぱいを……あんっ、犯すようにっ、ずりゅずりゅしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、オチ○ポ……出したがってますっ、はいっ、中にっ……おっぱいに出\nして下さいっ、んっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁんっ……！　あぁっ……元気な子種が……びゅくびゅくって……おっぱ\nいの中に流れ込んで行きます……んっ、はぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……私もまた母乳が……んっ、一緒に漏れてしまってます……んふぅ…\n…精液のヌルヌルと混ざって……とても気持ちいいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ふふ、まだ出てますね……本当に逞しいオチ○ポ……立派になってくれて、\nママはとても鼻が高いですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ……終わりましたか？　それじゃあ、しばらく楽にしていて下さいね。オ\nチ○ポがホッとするまで……おっぱいの中でくつろいでいて下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ふふ……大丈夫です。私のおっぱいも、貴方のオチ○ポを感じたがっている\nので……気にせずに身を委ねて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……温かい……あぁ、この時間……とっても落ち着きますね。同じ喜び\nを共有できた……そのことにとても満足感を覚えるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あら……また、おっぱいの中で……オチ○ポが元気になって来ましたね……\nふふっ、そんなに気まずそうな顔をされなくても、心配はいりませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もちろん、まだまだ続き致しますから。今日は頑張ったご褒美なんですから\nね、うんと欲張って……おっぱいを感じて下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ヌルヌルの精液の中に……またもうちょっと母乳を足してあ\nげましょうか……んっ、あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……乳首も、前よりずっと痺れが強くなって……すぐに出そうです……\nあんっ、出ますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、普段は意識したことがありませんが……やっぱり、母乳が\n出る瞬間は……身体が気持ちよくなるものですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「貴方のオチ○ポがすぐ近くにあるからかも知れませんが……とても淫らな気\n分に包まれて……また、ぎゅっとしたくなってしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ、少し強めに挟み込んで……どうですか？　オチ○ポ……苦しくはあ\nりませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「え……乳首を弄ってみたいですか？　そうですね……それは、もう少し後の\nお楽しみにして下さい。今は、こちらを味わって頂けると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……ふっ、はい……その代わりと言ってはなんですが、しっかりと乳首\nもオチ○ポに押し付けて……よく楽しんで貰います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、んくんっ……あぁ、いかがですか……あふっ、ぬめった感触が……\nはぁっ、とても……気持ちよくて……もっとしたくなっちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あっ、んくっ……くちゅくちゅって……いい音がします……\nこの響きをもっと……聞きたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ、あはぁんっ……感じますっ……私のおっぱいも、一緒に気持\nちよくなって……あぁんっ、イキたくなってますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、息遣いが……一緒に乱れて……んんっ、あぁっ、この分で\nすと……同時にイクことが……出来そうですねっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ、はい……パイズリでも、ちゃんとイクことが出来ますわ……ですか\nらっ、どうかこのまま楽にして、ママのおっぱいを味わって下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ、オチ○ポっ……せり上がって来ていますっ……強く\n擦れてっ、ビクビク震えてっ……あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「お汁が……いっぱい出ていますっ……男の子の匂い、強くなって……オチ○\nポがビクビクしてっ……あっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「出るんですね？　んっ、いいんですよ……貴方の欲望を、全部私にぶち撒け\nて下さいっ……おっぱいでも、お顔でもっ、好きにしていいですからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はいっ、これは……全部ご褒美ですからっ、ママにもちょっとだけお裾分け\nして下さいっ！　ママはオチ○ポから出る精液が好きなんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「だからっ、いっぱいピュッピュって、気持ちよく射精して下さいっ……そう\nですっ、ズリズリっ、おっぱい擦り合わせてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私のおっぱいもっ……またっ、母乳が溢れますっ！　ぎゅうってされるとっ\n……あぁっ、出るっ……おっぱいっ、出ますぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あんっ！　あっ……はぁぁぁんっ、また……おっぱい……中出し始まってま\nすぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私も、ミルク出てますっ、はぁんっ、母乳が溢れてっ……おっぱいっ……\nイッて……ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303302" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふぅぅ……あぁ……蕩けるぅ……オチ○ポとおっぱいが一つになっていく\nような……そんな感覚です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、ふふ、まだ小さく震わせて……一生懸命、残りの分を出そうとしてく\nれているんですね……いい子です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「待ってて下さいね……ちゃんと、搾り出してあげますから……んっ、こうし\nて……あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ……最後の分が出てきました……今日は、沢山頑張りましたね。ふふ\n……とても、素晴らしいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ、おっぱいがお汁でいっぱい……身体にも匂いが染み込んで……んふっ\n……貴方に染められてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「さて……こんな感じで良かったでしょうか。とても満足でしたか？　ふふっ\n、それは何よりでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「それにしても……ママになるという感覚、最初はよく分かりませんでしたが\n、こうしてやってみると、とても素敵な体験でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「私の本能に、そうした甘やかしたいという願望があるのかも知れませんね。\nはい、またいつでも甘やかしてさしあげますわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んぁっ！　ああっ……顔にっ……出てますっ、びゅくって……はぁんっ、\nい、いっぱいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ……ミルク……出ますっ……私も母乳が……びゅるって……出てるぅ\nっ！　あぁっ、おっぱいっ……イキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、もっと浴びせて下さい……んちゅぷっ、れろっ……この粘っ\nこい精液……りゅぷっ、もっとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303403" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ……震えてる……あぁ、こんなに元気に精液を漏らして……本当によく\n頑張ってくれましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あ……んっ、べとべとです……れろ、口の周りにも精液がついて……美味し\nい……ぺろっ、ふふっ、少しお行儀が悪いですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ちゅぱ……ぴちゃ……ミルクの味……私の母乳と混ざって……何とも独特な\n風味ですね……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どうやらオチ○ポも落ち着いて来ましたね。本当にいっぱい出して……お疲\nれさまでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00003003_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「さて……こんな感じで良かったでしょうか。とても満足でしたか？　ふふっ\n、それは何よりでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0303408" ]},
