        {"command":[ "PLAYBGM", "BGM_010" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「よぉおっし！！　これなら……勝てる！　そらそらぁ！！」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "001_010021030052" ]},
        {"command":[ "SETCHARA", "0", "char_00000102_01", "8", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「くっ……！　なかなか重い一撃じゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030032" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「やるな。どこかでフッ切れたようだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030025" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……そうだ！　我、極意を得たり！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030053" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「例えどんな破廉恥な姿だろうと、どこの肉に革が食い込もうと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030054" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「己の美貌に絶対の自信を持ち、恥じることなく君臨すること！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030055" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……！　これが女王としての立ち居振る舞いだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030056" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "鋭さを増したルナテミスの攻撃に、じりじりと後退させられていく二人。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "彼女たちが地に伏せるのに、そう時間はかからなかった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……これで決まりだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030057" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「うっ……！　し、しまった……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030033" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まさか、こんな短時間で……力量を上げてくるなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030026" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ククク……どうだ、二人とも。私は見事に女王として進化しただろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030058" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「改めて礼を言わせてもらうぞ。女王の心得……今までの私に足りなかったも \nの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030059" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それを会得したからには、もはや！　アナザー・ルナテミスなど敵ではない \nわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030060" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……フフフ……ククク……はーっはっはっはっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030061" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「待っていろよ、アナザー・ルナテミス！　誰が本物のルナテミスか思い知ら \nせてくれる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "001_010021030062" ]},
		{"command":[ "SETCHARA", "0", "char_00000102_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETTEXT", "意気揚々と去っていったルナテミスを見送り、二人は顔を見合わせた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ボンデージ姿のまま、あんなに堂々と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030027" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「しかし良かったのか？　あんな適当な嘘をついて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030028" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「まさか、本当にボンデージを着ただけで強くなっちまうなんてね……無茶苦 \n茶だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030034" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「いつ、これは冗談だって言おうか迷っちまったけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030035" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「結果は上々ときたもんだ。なら、ルナテミスの姫さんも後で文句は言ってこ \nないだろうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030036" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「……ボンデージ一枚と少しの度胸で強くなれたら、誰も苦労などしない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030029" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「が……。彼女にはこういう脳筋なやり方が合っていたようだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030030" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「やっぱり、ちょっと……頭の悪い姫さんみたいだね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030037" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ふふ……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030031" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「くくく……。いつ気づくのか楽しみだが、同時におっかなくもあるねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030038" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「アナザー・ルナテミスも別の意味で驚愕すること請け合いだろうしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030032" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「それは間違いない。フフフ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030039" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「それにしても、開き直ってからの姫さんの攻撃ったら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030040" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「あんまりにも鮮やかな攻撃で驚いたよ。これは一本取られちまったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030041" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「まったくだな。しかし、代償に……アイタタ、腰が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030033" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「情けない声あげるんじゃないよ。まったく、ババアだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "033_010021030042" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「き、貴様も変わらぬ年だろう……！　……イタタタ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "049_010021030034" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "生温かい目でボンデージ姿のルナテミスを見送り、疲れた表情を浮かべる \n女傑たち。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "二人の冗談のせいで、ルナテミスがパワーアップしたことだけは間違いなさそ \nうだった……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}