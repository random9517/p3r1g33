		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっ！　ひっ！　はっひぃいっ！　どくんっ、どくんって……中で、脈うっ\nてぇ……ひぃぐっ！　んっ、んひぃいいいっ……！」", "NORMAL" ]},
