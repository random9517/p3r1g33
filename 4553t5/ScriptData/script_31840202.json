		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あぁ、そんな……他所の男を招き入れるなんて、イヤらしい言い方しないで\nください……んっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「確かに誘ったのは、私……ですけどぉ……んあっ……そうしないと……あな\nたが、相手してくれないって言うからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んぅうっ……焦らさないで……お願いですから、ハメて……あなたのチンポ\n、欲しいんです……あっ、ああっ……そ、そこぉ……く、るぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204103" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃっ！　挿入れられただけで……軽く、イッちゃいましたぁ……は\n、はぁあ……おっきぃ……チンポぉ……好きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204104" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はぁあっ……私、人妻なのに……こんなに淫乱になってしまって……ぜ、全\n部ぅ……あなたのせいなんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204105" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あ、あんっ……夫は仕事、で……す……んっ、ああっ……悪いとは、思って\nます……もちろん、思ってますぅ……んっ、はぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「だけど、浮気セックス……気持ちよすぎて、やめられない……あなたとのセ\nックスが最高すぎて……も、もうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「夫とのセックスなんかじゃ、ダメなんです……本当はダメなのに……んっ…\n…夫で満足しないといけないのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ンはぁっ！　な、なかで……また大きくなってるぅ……ンっ……こ、これぇ\n……このチンポが悪いんですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「私、こんなに淫乱じゃなかったのに……このチンポが、私を狂わせてぇ……\nはっ、はあっ……あんっ、んっんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あぁ、ヨダレだなんて……んっ、だって……こんな大きくて、硬いチンポ…\n…ねじ込まれたらぁ……誰だって、濡れちゃいますよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んああっ！　はっひっ、ひぃいっ……若くて、ガチガチに勃起したチンポぉ\n……お、おぉっ……ああっ、ダメ……もう何も考えられない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「このデカチン……！　エロチンポぉ……ねじ込まれたら……はっ、はふぅ、\nんっああっ……す、すごぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あっあんっ……もっと、欲しいっ……あぁあ、ひぃんぃっ……軽く、かき回\nされるのも……気持ちいい、ですけど……ああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ゆっくり、ごりごりって……カリが中で擦れてるぅ……うぅんっ……こんな\n、たくましいチンポ……あなたが初めて、でぇ……はへぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ぐっ、ぐひっ……ひぃうっ！　んっ、ズボズボってきたぁ……オマンコ、お\nおっ……押し広げながら、ぐいぐい……くるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あん、あぁんっ！　こ、腰が、勝手に動いてっ……あぁあっ……！　はっ、\nはひっんっ……！　はぁんっ……！　んっあぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「声、出ちゃうぅ……！　だって、気持ちよすぎるっ……ンンっ、ひぃうっ…\n…！　あはぁっ、あっ、あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「気持ちいい……んっあっ……あなたの、チンポ……やっぱ、すごい……あん\nっ、はあぁあっ……！　あんっ、あっあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「これ、これぇ……このチンポが欲しくて……仕事中も、いつでもどこでも…\n…頭から離れなくてぇ……はっ、ひぃうっ……んふぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「そうですよぉ……チンポのこと、ばかり……考えてしまって……んっ、ああ\nっ……！　だって、だってぇ……んひぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「そうじゃ、ないですっ……チンポなら、なんでもいいわけじゃ、ない……で\nすぅ……あなたのチンポが、いいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あなただけ、誰でもいいわけじゃなくてぇ……このチンポがいい、んですぅ\n……これじゃないと、私っ……わた、しぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あぁ、言わないで……夫のことは、今は言わないでくださいぃ……はぁ、あ\nぁっ……あんっ！　あっ、はっ、ひぃいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「悪いと思ってます……罪悪感でいっぱいです……ウソじゃ、ないですぅ……\nんぅんっ……！　でも……それでも、ダメなんですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はあぁ……このチンポ、欲しくてぇ……オマンコ疼いて、堪らなくてぇ……\nどうしようもないんですっ……んっ、あぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「わ、悪いって、夫には……思ってますから、あっああっ……言わないで、く\nださいぃ……お願いですからぁ……はっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「人妻に手を、出しておいて……ズルいです……そんな、あんっ……言い方す\nるなんてぇ……はぁ、はぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「そうです、浮気オマンコ……若いチンポが欲しくて、濡れて……あっあっ…\n…んっ、あんっ！　もっと、おぉっ……動いて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「中、かき回して……奥、突いてくださいぃ……！　んんぅっ……！　はっ、\nあっ……ああっ！　そう、そうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「いい、気持ちいい……！　デカチンで、オマンコぐちゃぐちゃにされるのい\nいっ……！　感じるっ……んっ、んひぃ！　ひぃいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あっあっ、あぁぁぁんっ！　イ、イク……！　感じすぎてぇ……もうイクぅ\nぅ！　んっ……あんっ、ああんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「な、中出しぃっ！　絶対になかぁ……オマンコに欲しいっ！　中出しザーメ\nンでアクメっ、したいぃ……んっ、んはぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はっあっ……あなたも、イキそうなら、出してっ……！　しゃせぇ……いっ\nぱい、してっ！　私のオマンコで、アクメっ……してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁんっ！！　イ、イクぅうう……イクイクイクぅっ！　はっ、は\nっあっ……！　あっあぁぁぁぁぁぁぁ～～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んひぃいい～～～っ！　お、おくっ……ザーメンがドクドクって……んっん\nあっ！　子宮まで……届いてぇぇっ！　ひぃいんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はぁ、あはぁっ……んっ、すごいっ……いっぱい、出てるぅ……んうっ……\nああっ……中出しされながらイクぅ……んっ、んんぅ……イッくぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あ、あぁ……熱い……すっごく熱いザーメンが、どんどん流れ込んでくる…\n…私を孕ませようと、してぇ……はっ、あんっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あぁ、でも足りない……こんなに出されたのに……アソコが疼いて……もっ\nと欲しい、んです……ねえ、いいですよね？　もっと……もっとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はい、私が動きますから……射精しても、硬いままのチンポ……オマンコで\n、気持ちよくしますからぁ……はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「はあっ、あぁんっ！　はっ、あぁっ……すごいっ……イッたばかりだから、\n感じすぎちゃうぅ……あぁっ、あはぁっ！　あっあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっ、んあっ……ぐちょ、ぐちょ……イヤらしい音が響いて、ますぅ……ん\nっ、やぁ……恥ずかしい、いいっ……くひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「い、今さら、とか……言わないで、ください……ああぁんっ……！　若い、\nデカチン……い、いいっ……やっぱり、すごいぃぃ……ひぃあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あっ、あはっ……腰、止まらない……チンポ気持ちよすぎて、勝手に腰が…\n…あぁ……動いちゃうぅ……んっ、はっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あ、あなたは……どう、ですか……？　ちゃんと、感じてくれてますか？　\nんっ、あっ……は、はひっ……浮気妻マンコの、具合……ですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あぁ、嬉しい……！　そうですよね……感じてくれてるから、チンポも……\nこんなにガチガチになって……ひっ、ひあっ！　あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「もっと、ですね？　わかりましたぁ……オマンコ、締めて……ぐいぐいって\n……んっんっ……こんな感じで……は、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「んっあぁっ……あなたのチンポが大きい、からぁ……オマンコが広がってる\nんです……あなたのせいです……んうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「夫とセックス……？　そんなことしたら、絶対にバレちゃいます……浮気マ\nンコだって……気づかれちゃいますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「もう、私のオマンコはあなたのものなんですからぁ……ああっ、くっ……ひ\nぃっ、ひぃあっ……あんっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「だから、あなたも……動いてっ……んっ、んんっ！　おっ、おほおっ……そ\n、そぉ……奥、ガンガン突いてぇぇ……あっああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00018402_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「あっあっ、あぁあっ！　あっんっ……！　はげしっ……んぅっ！　あんっ、\nあっ……あはぁんっ！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「ま、またイクっ……連続アクメきちゃうっ……！　んっ、んほっ……おおっ\n、おっ……くっ、ほぉっ！　イ、イクッううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「欲し、いいっ……！　若いザーメン、欲しいですぅっ……子宮をザーメンで\n満たして欲しいですぅっ……！　ひっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「お、おおっ……ほっ、おおっ！　イクっ……ガン突き、すごぉいぃぃ……！\n　出して……出してくださいぃ！　んひぃんっ、いいぃぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「どっちでもいいですから……！　中出しでも、ぶっかけでも……んっ、ザー\nメン欲しいっ！　あっああっ！　だから……お願い、ですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
		{"command":[ "SETTEXT", "「も、もぉ、我慢……できないっ！　アクメ、我慢できないから……一緒にイ\nッて、ください！　んっんんっ……んっおっ、おおっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュリ" ]},
