		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「これがカツマさんのオチンチン……！　予想していたよりも、かなり大きい\nです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「えっ……急に押し倒してきてどうしたのかって……これは、その……！　い\nつもカツマさんにはお世話になってますので、そのお礼と言いますか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203102" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「人間の男性はこういったことをされるのが好きと、データバンクにありまし\nたので……あの、イヤ……でしたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203103" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「イヤじゃないなら嬉しいです……！　オチンチンを咥えるのは初めてですが\n、やり方はしっかりインストールしてきましたのでご安心くださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203104" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「カツマさんはリラックスして、私に身をゆだねてくれれば大丈夫ですので…\n…では、始めますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅぷっ……！　ちゅ、ちゅぷっ……ぐちゅ、じゅるっ……！　ぴ\nちゃ、れろっ……ずぞっ、じゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203106" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ちゅ、じゅぱっ……！　ちゅぽんっ……！　はぁ、んっ……オチンチンとい\nうのは大きいだけでなく、熱くて硬いモノなんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「それに……んっ、ぢゅぷっ……！　舐めりぇば舐めりゅほどピクピク動ひて\n……可愛い感じがひまふっ……れちゅ、じゅ、じゅぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あむっ……ずっ、じゅぞぞっ……れりゅ、ちゅぴっ、ちゅちゅ……！　あの\n……私のフェラ……どうれふか……？　気持ちいいれふか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んふっ……気持ちよくなってくれてりゅなら、嬉しいれふ……もっひょ奥ま\nれ咥え込んで、いっぱい舐めていきまふね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「じゅぞっ……ずずっ、ぴちゃ、ぷちゅるっ……！　れりゅ、ずぷっ……ぐち\nゅ、じゅぱっ、ちゅぴっ、んじゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ちゅ、じゅる、んちゅ……！　オチンチンの先端かりゃ、ネバネバしたお汁\nが溢れてきまひたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「確かこりぇ……オチンチンが気持ちよくなりゅと、溢れてくるエッチなお汁\nでひたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「私のお口で悦んでもらえてるなんて光栄れふっ……！　もっと感じて、気持\nひよくなってくらはい……ちゅぱっ、じゅるっ……んっ、ちゅぱ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203114" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、じゅぞっ……！　ぷちゅ、ぴちゃ、ぢゅるるっ……！　ちゅぽっ、\nじゅぽっ……！　にちゃ、ぐちゅ、ちゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んぅ、んぶっ……！　あっ、あのっ……どこか舐めひぇ欲ひいとこりょとか\n、ありまふか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「これはその……日頃のお礼ですひ、カツマひゃんのご要望にはお応えひたい\nと思いまひて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んちゅ……ちゅ、じゅるっ……！　えっと……オチンチンの先端や、カリ首\nのとこりょを重点的に舐めて欲しいんれふか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「わかりまひた……では、まずはこにょ段になってりゅとこりょから、ペロペ\nロひゃへてもらいふ……んっ、ぢゅぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、ずぷっ……ぴちゃ、れろっ、れろぉ……！　んっ、ちゅちゅ……ぐ\nぷっ、ちゅぴっ、ぢゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ちゅ、ぢゅるるっ……！　んっ、んんっ……！　皮にょ隙間にも、舌を入れ\nて欲しいんれふか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「大丈夫れふよ……カツマひゃんのオチンチンにょこと、もっと知りたいのれ\n……ひて欲しいことがあっひゃら、もっと言ってくらはい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「れりゅ……ずっ、くぷっ……！　れりゅ、ずりゅりゅ……！　んっ……皮の\n隙間に舌を入れりゅのは、少し難しいれふね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あまり強く舌を入れりゅと、オチンチンを傷つけちゃいそうれ……ぐちゅ、\nぐぽっ……！　にちゅ、ぐちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んっ、はあぁ……んちゅ、ちゅるっ……！　んっ、んぶっ……！　裏側のス\nジを舐めりゅと、オチンチンが強く反応ひてきまふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こにょあたりが、特に感じるとこりょなんれふね……では、このまま皮の隙\n間とスジを舐めにゃがら、オチンチンの先端に舌を這わせていきまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「れろぉ……！　ずっ、ぢゅるっ……ぴちゃ、くちゅ、ぷちゅるっ……！　ぐ\nぷっ、じゅぽっ、ぢゅぴっ……！　んぶっ、じゅぱっ、んじゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んぐっ、ちゅるっ……！　オチンチンの先端は、特に敏感なんれふね……痛\nくなりゃないように、気を付けて舐めてきまふね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ぐっ、ちゅぞっ……！　ずずっ、じゅるっ……！　んっ、ちゅ……ぴちゃ、\nじゅぱっ、ずずっ……！　ぴちゃ、ちゅぽぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「精子が出りゅ穴のとこりょ……ここを舌でホジホジすりゅと、激しくオチン\nチンが反応ひてまふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「舌先でレロレロって舐めりゅと……オチンチンがお口の中れ暴れてっ……！\n　んんっ、ちゅぱっ、れりゅ、ちゅぢゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んっ、んんんっ……！　舐めまわさりぇすぎると、イキそうになるんれふか\n……？　いいれふよ……いつでも好きなときに出ひてくらはい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「カツマさんにょ精子……全部お口で受け止めまふのれ……！　遠慮せずに、\nいっぱい出してっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「にちゅ、じゅ、じゅぞぞっ！　れろっ、ぷちゅ、ぴちゃ！　ぐぽっ、じゅぽ\nっ、れりゅっ！　んちゅ、ちゅ、ずぷっ、ぐじゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「オチンチンが大きく動いてりゅ……！　だ、出してっ……！　カツマさんの\nザーメン、私のお口にびゅーびゅーしてくらはいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んぐうぅぅぅ……！　これが男の人の精液っ……！　ドロドロひてて、とっ\nても熱いれふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「お口の中で粘液が糸を引いて……！　んっ、ちゅぱっ……こんなに出された\nりゃ、溢れひゃいまふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あぶっ、じゅぞっ……！　ザーメンを飲んれ欲ひいんれふかっ……！？　は\n、はいっ……わかりまひたっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ずずっ……！　ぐちゅ、んっ、ごくんっ……！　じゅぞっ、ちゅるっ……！\n　んぐっ、んぐっ……こくっ、ごっくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、ぢゅ、ずりゅるっ……！　んっ……ドロっとひた感触と、カツマ\nさんにょ遺伝子情報を感じまふっ……！　んっ、ちゅ、じゅるうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んちゅ……はぁ、んっ……はあぁ……！　精液って初めて飲みまひたが……\n正直、凄く飲みづらいれふね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203201" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「味も解析ひましたけど……苦みを感じるといいまふか……あまり好まれない\n味らと思いまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅるっ……！　さて……お礼はこれで終わりなんれふが……いかが\nでひたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「えっ……まだ出し足りないかりゃ、もっとフェラひて欲しい……？　そ、そ\nりぇは別に構いませんが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「カツマさんからのご要望ですし、精一杯お応えひゃせていたらきまふ……で\n、では……改めて、失礼ひまふっ……んっ、ちゅぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ぐぷっ、じゅぽっ……！　じゅるっ、ちゅ、れろっ、ぴちゃ……！　んちゅ\n、ちゅぱぱっ、ぐぶっ、じゅずるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　吸えば吸うほりょ……オチンチンの中かりゃ、精液が溢れ出\nてきまふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「そりぇにザーメンがオチンチンにまとわりついて……んっ、ちゅるっ、ずず\nっ……！　さっきより舐めにくいれふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「れも、カツマさんのご要望れふのれ……頑張りまふね……！　ぐぷっ、じゅ\nずっ……！　んぶっ、ちゅ、ぐちゅ、ちゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「えっと……またカリの裏側や、スジのとこりょ……それに皮の隙間とかを舐\nめりぇばいいんれふよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ずずっ、ちゅ……ぷちゅ、ぴちゃっ……！　ぐぽっ、じゅぽっ……！　んじ\nゅ、れるっ、んじゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、じゅずずっ……！　皮の隙間に、ひゃっき出ひた精液が入り込ん\nでまふ……こりぇも舐めとっておきまふね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「れろっ、ずぐっ……じゅぱっ、ぴちゅるっ……！　んっ、ぐぽっ、じゅぷる\nっ……！　んっ、ぐっ、ぢゅぱぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ……はあぁ……今度は裏スジに舌を伸ばして、ペロペロして……\nれりゅ、ぴちゃ……！　ぺろっ、れろぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あんっ……！　またオチンチンが暴れてまふっ……！　早く精子を出ひたく\nて、たまりゃないって言ってるみたいれふ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「大丈夫れふ……さっき見たいに、ちゃんとザーメンびゅるびゅるさせてあげ\nまふから……んぐっ、じゅぱっ、ちゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ぐぽっ、れろっ……！　ちゅ、ぢゅぢゅっ……！　ちゅく、じゅぞぞっ……\n！　先端の方もペロペロひないと……んっ、ちゅぱぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ぺろっ、ぴちゅ、ぴちゃっ……！　ちゅぱっ、ちゅぽっ……！　ぐちゅ、ず\nちゅ！　ぢゅ、ずぱっ、ぴちゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んっ、んむっ……！　オチンチンのビクビクが強くなってまふっ……！　ま\nた、イキそうなんれふね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「はっ、はひっ……！　またさっき見たいに、出ひてくらはいっ……！　カツ\nマさんの出したいところに、ザーメン出してくらはいっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んぶううぅ……！？　ま、まひゃお口の中にいっぱい精液出されてまふっ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「２回目なのに、凄い量れふっ……！　データでは、男の人は２回目の射精は\nあまり出ないって記載があっひゃのにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅくっ……！　このままらと、また溢れちゃいまふっ……！　全部\n飲まないと……んっ、じゅぞっ、じゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んぐっ、んぐっ……！　あふっ、じゅるるっ……！　ごくっ、ごっくんっ…\n…！　んっ、あぶっ……ぢゅ、ちゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こくっ、こくっ……ごくんっ……！　最後の一滴まれ、全部飲みまふのれ…\n…遠慮せずに、出しきってくらはいね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅるるっ……んぐっ……！　はあぁ……たくさん、精液出されちゃ\nいまひた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ふふっ……私の身体の中にカツマさんのザーメンが入ってると思うと……何\nだか、不思議な気分れふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「私は機械なので精子を口に含んでも問題ないのですが……なんというか、幸\nせな気持ちが溢れてきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「こうした感情が湧いてくるのも、お相手がカツマさんだからでしょうか……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あの……もしお望みでしたら、もう一度フェラチオしますけど……どうしま\nすか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「えっ、あっ……！？　オチンチンがお口から抜けて……きゃあああぁぁぁっ\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024702_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「あぶっ、んんっ！？　か、顔にザーメンがかかってますっ！　ど、どうして\nこんなことするんですかぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「私のボディが精子で汚れてるところが見たいだなんて……！　そ、そんな変\n態みたいなことっ……あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「カツマさんの精液が染み込んできますっ……！　それに臭いも濃くて……あ\nあっ！　このままだと、ボディに精液の香りが移っちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「それに眼鏡にもこんなにかけられてっ……！　精液で前が見えなくなっちゃ\nいますぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ……！　やっと射精が落ち着いたみたいですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「もう……！　顔にかけるなんて聞いてませんっ……！　それにかけるならか\nけるって、先に言ってくださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「べ、別にイヤなわけじゃありません……！　ただ、私にも心の準備と言いま\nすか……そういうのが必要なので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ふふっ……わかってもらえたなら、嬉しいです。次からはちゃんと気を付け\nてくださいね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ツバサ" ]},
		{"command":[ "SETTEXT", "「ちゃんと守っていただけるなら……その……またこうしたご奉仕をさせてい\nただきますので……よ、よろしくお願いしますね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_247_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}