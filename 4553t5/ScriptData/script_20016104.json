		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「わたしの不意をついたことは、褒めてあげるけど……甘いわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「何っ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024030001" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「さすがに油断はしてないってか！　でも、これならどうだい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024030002" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「うふふふっ。力任せに強引に……っていうのも、嫌いじゃないけどスマート\nではないわねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「うぐっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024030003" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まずい、フィルが吹き飛ばされた！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「あらあらあら……。威勢が良いのは最初だけ？　ダイヤナちゃんの勝ちみた\nいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「それじゃ、トドメを刺しちゃうけどぉ……。悪く思わないでね？　宇宙海賊\nさん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「っくぅ……！　アタシの命運もここまで、か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024030004" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「よぉし、ＯＫですわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030001" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「お。そんじゃあ、やっちゃいますか～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024030001" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「そらよっ！　オバサン、さっさとこっち向きな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024030001" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「お、おおおおおおばさんんん！！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「いっくよ～！　反撃のお時間でーす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024030002" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「受け止められるもんなら受け止めてみな！　それっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024030002" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「きゃんっ！　いきなり何よぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024030006" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "強襲されたダイヤナ・ダークは２人のメス〇キに押し切られ、大きく後ろに飛\nび退った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「いや～ん！？　中々強いわぁ、この子たち！　困っちゃうぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024030007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……スーヤチカが他の２人を待たせてたのは、このチャンスを狙うためだっ\nたのか」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「ええ。そうですわ。おにーさんならわかってくださると思っておりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030002" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「わたくしは、彼女が現れた瞬間から……隙をうかがって、次元統制局に状況\n報告と増援の要請を行っていました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030003" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……でもその間に、リサちゃんとグラちゃんを一暴れさせていればよかった\nのに、と思われましたでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030004" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあな。その方が、ダイヤナ・ダークの意識をそらせたんじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「それが……。２人に本気を出させると、事後説明が不可能なくらい暴れて全\nてを破壊してしまいますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030005" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「先に、宇宙船の保険会社に連絡をしていたんです。敵が現れた時にはまだ、\n船は綺麗で無事でした、と」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030006" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……それを先に言っとかなきゃいけないほど、めっちゃくちゃになる予定だ\nったんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「実際そうなっていますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030007" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………確かに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "リサシュルカとグラーシャが出撃した途端、宇宙船はボロボロといっていいく\nらいに荒れて壊れて、大変なありさまだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ダイヤナ・ダークが手を下すまでもないってレベルで破壊されてるな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「うちはいつもこうなんです。ですので、囮として……捕まえておいたフィル\nさんに戦って時間稼ぎをしていただきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030008" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「アタシはまあ、暴れるったって船を壊すほどじゃないからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024030005" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「へぇ～。用意周到ですごいな、スーヤチカは」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「宇宙海賊には珍しい、頭脳派だよ。普通海賊ってのは、頭に血がのぼると戦\n闘狂になっちまうもんだからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010024030006" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「……怒ってはいましたし、かーっと血ものぼっていましたよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030009" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「だ・か・ら念入りに。敵を追いつめていたぶることにしたのです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030010" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ゾゾゾゾゾ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「さて。これでわたくしたちの大勝利……と宣言してしまいたいところですが\n。もう一悶着ありそうですわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030011" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「……ん～！　力では、あたいとグラちゃんの方が上のはずなのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024030003" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「なんっか、あと一歩のところでうまくいかない。コンビネーションがうまく\nいかないんだよお……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024030003" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「リサちゃん！　もうちょっとこっちに合わせて動けないのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024030004" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　いっしょーけんめーやってるし！　グラちゃんこそもっと機敏に\n動いてくれないと困るしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024030004" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「あらぁ？　バラバラの攻撃なんて、取るに足らないわよん？　今度はこっち\nから攻めちゃおうかしら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024030008" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「ほぉーらっ！　これが欲しかったんでしょぉっ！　強烈な一撃で、その生意\n気なお口をふさいであげちゃうわぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110024030009" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「うぐっ！　敵がわたしたちの攻撃に慣れてきてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024030005" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「っていうかこっちに攻撃が当たりはじめてるって！　ヤバイよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_010024030005" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グラーシャ" ]},
		{"command":[ "SETTEXT", "「スーちゃんスーちゃん！　どうしたらいい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_209_010024030006" ]},
		{"command":[ "SETCHARA", "0", "char_00020901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「やれやれ。わたくしの指揮が必要なようですわね。大丈夫、大丈夫ですわよ\n。２人にはわたくしがついております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030012" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーヤチカ" ]},
		{"command":[ "SETTEXT", "「それでは宇宙海賊団……滅棲俄鬼に喧嘩を売った事を後悔させてあげましょ\nうか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_207_010024030013" ]},
		{"command":[ "SETCHARA", "0", "char_00020701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}

	]
}