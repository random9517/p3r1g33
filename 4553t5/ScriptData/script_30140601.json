		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「やっと二人きりになれました……教室……鍵閉めちゃいますから……ふふっ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603101" ]},
		{"command":[ "SETCHARA", "0", "char_00001406_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、もう人は来ないと思いますけど……念の為です。だって……これから\n……見られたら困ること……しちゃいますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「少しだけ向こうを向いていてくれませんか？　すぐに……準備してしまいま\nすから……ん…………と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、いいですよ……どうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603104" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふ……脱いじゃいました……まだ明るいのに……こんな、教室で……おっ\nぱい……全部出しちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「えと……もちろん恥ずかしいです……でも、少しでも……私でその気になっ\nてくれるなら……う、嬉しいですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あっ……ドキドキしてる……本当ですか？　あぁっ、オチンチン……もうこ\nんなに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、はい……分かっています……その、気持ちよくなって欲しいので……\nお口でさせてくれますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ありがとうございます……では、失礼します……んっ、ちゅっ……んちゅっ\n、ちゅぷっ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603109" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あぁ……もっと大きくなって来てる……んちゅっ、ちゅぷっ、はぁっ、オチ\nンチン……こんなに……んぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「どうですか……？　その、ちゃんと出来てるか……心配なんですけど……ぴ\nちゃ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちゃんと……気持ちいい、ですか……？　は、はい……では、もっと頑張っ\nてみます……ちゅぷ、んっ、れろ……えろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふぁ……少ししょっぱい感じがするんですね……オチンチン……んちゅ、\nぴちゃ……んりゅ……れろ、あ……ピクってしてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603113" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ……可愛いです。いえ、もちろん大きくて、逞しいんですけど……で\nも、すごく親しみが湧くというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だから、もっともっと気持ちよくなって欲しいって……ちゅぷっ、そう思い\nます……れろ、えろ、んりゅ……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふ……大分、ヌルヌルになってきました……ちゅぱ、ぴちゃ……そろそろ\n、舐めてるだけだと……物足りないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「くすっ、やせ我慢しなくていいんですよ。これでも私……このオチンチンの\nことはよく分かってるつもりですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603117" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それに、私がしてあげたいんです……もっともっと、このオチンチン感じて\n欲しいので……咥えちゃいますね……はむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あむぅっ、ぷちゅっ……りゅぷっ、りゅぽっ、んふぅぅぅっ、むぐっ……ん\nぁぁ……頬張っひゃいまひたぁ……くぽっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603119" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっふ、じゅぽっ、ちゅぷっ、んじゅるっ、こうひて……口の中に入れると\n……大きさがよく分かりまふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、むぐっ、じゅぽっ、んっ、ふっ……どうれふか……？　れろ……お好\nきな所があれば……言って下さいね……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んりゅっ、あっ……今の所ですね……？　はい……んふっ、皮の剥けてると\nころ……れろれろしまひゅね……んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603122" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「えろ……んれろ……じゅぽっ、んふぅっ……目が……ずっとおっぱいを追い\nかけてますね……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「視線ですか？　もちろん分かりますよ……そんなチラチラっとじゃなくて…\n…じぃっと見てもいいんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ……確かに、ちょっと恥ずかしいですけど……でも、私の裸を見て……\n興奮して下さることが……嬉しいですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「他の人のを見ている位なら……私のこと……見て欲しいです……はぁ……ん\nむっ、ちゅぷっ、んふぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603126" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「りゅぽっ、んふっ……オチンチン……もっと、ひまひゅね……んじゅぷっ、\nちゅぽっ、りゅぱっ、じゅぷっ、んふっ、んちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷっ、ビクビク跳ねて……んっふ……すごく元気……ちゅぱ\n……んちゅぷ、ぴちゃ……んりゅっ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あふ……唾が溢れて来ちゃいますね……んりゅっ……オチンチン…\n…美味しいから……れろ……自然に出ちゃうみたいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「じゅるっ、んちゅぅぅぅっ……んふっ、じゅぽっ……はぁ、んっ、ふふ……\n気持ちいいですか……？　はい、もっとしますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「この……裏の所とか……すごく震えてます……ほら、れろ……舌が当たると\n……反応がすごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……ダメです……腰を引いても逃げられませんよ？　ぴちゃっ……\nちゃんとオチンチン……身を任せて下さい……りゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んじゅるるぅっ……こうして、先端……吸い上げて……出てるカウパー……\n舐め取って……んふっ、ビクビクが大きくなってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いいんですよ……出したくなったなら、いつでも……口の中に出して下さい\n……りゅぷっ、じゅぱっ、ちゅぱぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい……飲みたいです……貴方の精液……全部……ゴックンしたいんです…\n…ですから……りゅぷっ、我慢しないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、りゅぷっ……んちゅうぅぅっ……来てくださいっ……出してっ、\n精液っ……いっぱいっ……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んんんっ……出てますっ……んぐっ、こくっ、んんっ……濃いのっ\n、あぁん……んむっ、くぷんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……いっぱい……ドロってぇ……んくっ、んっ、んくんっ……はふぁ\nっ、んぱぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、ちゃんと全部飲みました……だって、貴方の貴重な精液なんです……\n一滴だって無駄には出来ませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……しっかり身体の中に取り込んで……んふ……今……とっても満\nたされた気分です……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……んふっ、とっても美味しかったです……あなたの精液……でも、ま\nだオチンチン……硬くて立派なままですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……もう少し飲ませてもらってもいいですか？　はい、もちろん…\n…また気持ちよくなってもらえるようにご奉仕します……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい……ありがとうございます。それでは……ちゅっ、んちゅっ、ちゅぷう\n……んちゅぅぅぅっ……んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603203" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「まだ精液がいっぱい残ってましたから……まずは、それを綺麗にするところ\nからですね……ちゅぷ、ぴちゃ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んちゅぷぅぅ……あぁ……粘ってる……このネトネトを全部舐めて……ちゅ\nぷっ、ぴちゃ、んちゅっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「改めて……オチンチン……舐めちゃいますね……れろ、えろ、れろぉ……ふ\nふっ、敏感になってますよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ピクピク震えて……とっても可愛い……ちゅぷっ、んちゅっ、れろ……もっ\nともっと、感じて下さい……はむぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっふっ、唇で……挟み込んで……もごもごさせて……ちゅぱっ……太い柱\nを……濡らして……扱いて……じゅぽっ、くぽっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「おっきぃの……むぐっ、口に入り切らない位れふ……じゅぽっ、ちゅぷっ、\nんふぅっ、じゅるるるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「舌の動き……気持ちいいれふか……？　はい、まだまだ……もっとしちゃい\nまふね……くぽっ、んりゅぷっ、ちゅぷぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「尿道口の所……ん、舌で……くすぐって……りゅぽっ、んふっ、ちょんって\n……つついてあげて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぱっ、こうしてると……私も興奮して……はぷっ、んんっ、\n乳首……しこって来ちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ、でも、今はおいたは駄目ですよ……？　ちゃんとご奉仕出来なくな\nっちゃいますから、まだ見てるだけです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「れろ、んりゅっ……その代わり、好きな所……いっぱいしますから……じゅ\nるっ、んぐっ、裏筋とか……カリ首もぉ……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、んちゅぱっ、逞しいオチンチン……はぁんむっ……あぁ、美味しい\nれふっ、んちゅぅっ……いっぱいしちゃいまふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……あ……また、ビクって……そろそろ、次……出ちゃいそうで\nすね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい、じゃあもっと激しくして……じゅぽっ、むぐっ……んふぅっ、りゅぷ\nっ、また気持ちよく……射精して下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んふっ、りゅぷっ、お口にこのままれもっ……んくぷっ、顔に出\nして頂いても……らいじょうぶれふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603218" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あなたの……欲望のままにっ、濃いの……いっぱいらひて下さいっ……んっ\n、じゅぱっ、オチンチンミルクぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、じゅぱ、んふぅっ、じゅるっ、んじゅぅぅぅぅぅぅぅぅーーーー\nーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……！　むぐっ……んぐっ、こくっ、んぶっ、んくっ、んっ、んふ\nぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふぁ……ふごい量……んっ、全部……飲みきれない位……りゅぱっ、じゅ\nぷっ、んっ、んくんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はふぁっ、んっ、はぁ、はぁ……すごい量……一気に頂いちゃいました……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はい……新鮮で濃い精液……はふ……こんなに飲めて……大満足です……れ\nろ……ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あ……ちゃんとお掃除もしますから、任せて下さいね。れろ……ぴちゃ……\nんちゅっ……オチンチン……お疲れ様でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「多分、今は相当敏感になってますから、すごく優しくしてあげないと……ち\nゅっ、ぴちゃ……んっ、はい、これで綺麗になりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603306" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「くすっ……どういたしまして。私のご奉仕で満足してくれたなら、私にとっ\nても嬉しいことですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それに、今日は……このオチンチン……私が独り占め出来るんです。もっと\nもっとお世話をしてあげたい位……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ……まだ、今はお疲れですし、ちょっと休憩はした方がいいですよね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、その後はまた……素敵な時間を過ごしたいです……あなたと一緒に…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「きゃうっ！　んぁっ……顔にっ……あっ、はぁぁんっ、はいっ……いっぱい\n掛けて下さい……熱いの……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んぁふっ……濃いねばねば……顔面シャワーされて……あなたのにおいで染\nまってしまいます……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅ……んっ、味も濃いまま……２回目なのに、こんなに出せ\nるなんて……本当に逞しいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あ……これで全部ですか……？　はい、いっぱい出して頂い\nて……本当にお疲れさまでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もう少し楽になさってて下さい。今から、オチンチン……綺麗にしてしまい\nますから……ぴちゃ、んちゅぷ、れろ……えろ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603405" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「続けて出したからお疲れですよね……？　はい、少しゆっくりなさって下さ\nい。ぴちゃ……んっ、これで大丈夫です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001406_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いえ、お礼を言われるようなことは何も。私がご奉仕したかったんです。も\nし、満足して頂けたなら、本当に何よりです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あ……でも、その……ちょっとだけ我が儘を言っても……いいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「えっと……もうちょっと休憩したら……その後はまた……色々してみたいと\n言いますか……その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0603409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「この後も……あなたと……気持ちいい時間……一緒に過ごしてみたいです…\n…ふふっ……」", "NORMAL" ]},
