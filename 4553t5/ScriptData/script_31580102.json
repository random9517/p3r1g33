{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んんっ……人をこんな状態で拘束したまま放置するとか……\nあの鬼畜ご主人め……あっ、んふぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「前の戦闘でミスしてお仕置って……んんっ……絶対建前だよね……はぁ、は\nぁ……私にえっちなことしたいだけでしょ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だめ、身体の疼きが止まらない……あっ、んふぅんっ……触ってもないのに\n、こんな気持ちいいの……知らないっ……んぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「さ、さっきのメンテナンスが原因、だよね……その手のパラメーターを無理\n矢理弄られたとしか思えない……あっ、んふぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「も、もう我慢なんて、無理……あ、あそこ、思いっきり触りたい……ぐちゅ\nぐちゅって指入れて、掻きまわしたい、のに……んあぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お願い、ご主人……許して……あっ、んんんっ……この拘束といて、気持ち\nよく、させてよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あ……ご、ご主人、帰ってきたの？　お、お願い、もうどこにもいかないで\n……このまま放置されるの、もうやだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「珍しく弱気だなって……ご、ご主人のせいでしょ……んんっ……私の感度、\nかなり弄ったよね、これ……あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――解放されたかったら、えっちな言葉でおねだりしろって？　……くっ、\nここぞとばかりに調子に乗って……あっ、んあぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わ、分かった、する、おねだり、するから……これ以上は、ほんとに我慢で\nきないの……私の事、気持ちよくしてっ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人のたくましいおちんちんを入れて……ほ、放置プレイでトロトロ\nになった私のお、おまんこにっ、ご主人のおちんちん入れて下さい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふあぁぁぁんんっ！　き、きたぁ、ご主人のあつあつおちんちん、ズドンっ\nて、きたぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あぉっ、ふあぁぁんっ、あひぃぃんっ！　こ、こんなの知らない、知識の中\nにないっ！　こんな簡単にイク、なんてっ、あっ、ふあぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、ふあぁぁんっ！　あっあっ、んあぁあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あっ、んんっ……も、もうイったのかって……んんっ……誰\nのせいでこんな敏感な状態になってると、思ってるの……んあぁん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「気持ちいいの大きすぎて、変なエラーが出ちゃってる……あっ、んんっ……\nでもこれ……嫌いじゃない、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……今更心配するなら、最初から変なことしなきゃいい\nのに……大丈夫、私の身体はそんなに脆く作られてないよ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ほ、ほら、遠慮なんてしなくていいから……ご主人……もっと来て？　私に\n気持ちいいを、もっといっぱい教えてほしいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ふあぁん……！　さ、さっきよりも、優しいね……亀頭が中を\n擦るように、ゆっくり動いて……あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それ、奥を小刻みにぐりぐりって押し込むの、好きっ……んふぅんっ……お\n腹の下あたりが、ジーンってきて……あっ、ふあぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「今の私には人間との間に子供を作れる機能なんてついていないのに、これが\n子宮が疼くってことなのかなっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そ、それに……あっ、んひゃぁんっ……！　こ、この格好だと、おちんちん\n、深い所まで簡単に届いてっ、んあぁぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「動きもどんどん早くなってきた、あっ、ふあぁんっ！　ごりごりっておまん\nこ削られるのっ、気持ち、いいっ、んあぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「腰を打ちつける度にぱんぱんって音が鳴るのも、いやらしくてっ、あぁんっ\n……！　恥ずかしいのに、全身のパーツが熱くなって、ふあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おまんこからえっちなお汁もいっぱい出てきたとか、わざわざ言わないでっ\n、あっ、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「た、確かに遠慮しないでいいとは言ったけど、恥ずかしいのとはまた別なの\n！　変なエラーが増えて、んんっ！　えっちな声が、抑えられないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んひゃぁんんっ！？　な、なに、今のっ、んんっ！　あと、\nご主人、どうしてお尻叩くのっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「は、恥ずかしい事をした方が私が気持ちよさそうって……ち、違う、そんな\nこと、ないっ、あっ、ふあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だ、だからやめてっ、おしりぺんぺんしないでっ、んんっ……！　それやだ\nっ、んひゃ、ふあぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいの、変になるのっ！　あっ、ふあぁんんっ！　お尻叩かれながら\nおまんこ滅茶苦茶に突かれるのっ、よすぎて、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お、おまんこ、掻き回されてる、おちんちんでわざとじゅぼじゅぼ音たてて\nおまんこっ、あっ、んひゃぁんっ！　ふあぁ、あぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいけど、いいっ！　恥ずかしいのが、気持ちいいっ！　だ、だめ、\nもう我慢、できなくてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人のおちんちんも、おまんこの中でぴくぴくって跳ねたっ！　あっ、ん\nひゃぁんっ！　熱く大きくなって、ふあぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だ、出して！　このまま私の一番奥に、ご主人の精液ちょうだい！　私の中\nを、ご主人で満たしてほしいのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁぁんっ！　あ、頭の中、電撃が走ったみたいにノイズ、だらけでっ\n、あっ、あひっ、ふあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「またエラー来た、気持ちいいエラー来たっ！　出して、一番深い所におちん\nちん突っ込んで、一緒にイカセてほしいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふああぁぁんんっ～～～っ！！　出てるぅ、熱い精液、あひっ！　おまんこ\nの奥ドクドクってっ、あっ、んひぃぃんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わたひもイクの、止まらないっ！　おまんこドロドロに汚されてっ、あひっ\n、あっ、んあぁぁんんっ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――はぁ、はぁ……すご、かったぁ……気持ち良過ぎて、私が私じゃないみ\nたいで……まだ変なノイズ、止まってないや……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「こんなに大きな快感、初めて……自分の身体のはずなのに、こんなに気持ち\nよくなることができるなんて、知らなかった……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あ、あんなにいっぱい出したのに、ご主人、まだ物足りないんだ……おちん\nちん、固いままだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それに私も、まだまだ全然満足できなくて……おまんこ、もっといっぱい、\n苛めてほしい、かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そのニヤニヤ顔むかつくなぁ……というか、そもそもご主人が私の身体に細\n工したのが悪いんでしょ！　だ、だから、その……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「せ、責任とって、もっと気持ちよくして！　恥ずかしくてもいいから、私の\n事、無茶苦茶にしてよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んあぁんんっ！　そ、そう、その調子、あっ、ふあぁんんっ！　おまんこの\n中、ゴリゴリ来てっ、乱暴におちんちん突き込んでっ！　あぁあんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「さっき出した精液が混ざり合う音、すごい下品で、えっちで、あぁんんっ！\n　じゅぼじゅぼすごい、腰パンパンされるの、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「で、でも、今度は私もやられっぱなしじゃない、からっ、あぁんっ！　拘束\nのせいで身体を動かすことはできないけど、こうやって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「お、おまんこの中、うねうね動かされるの、気持ちいいでしょ？　私だって\n、一応その手の機能は積んでるんだっ、んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おまんこ全体をぎゅってして……あっ、んあぁんっ……おちんちん、根元か\nら全部しぼりとってあげるっ、んくぅんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んふっ、あっ、んあぁん……！　さきっぽの膨らんだところ、亀頭も、ぐり\nぐりってきつく締め付けて、あっ、んふぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「これ、人間の身体じゃ、できない動きでしょ……あっ、あぁんっ……機械の\n私だから出来るご奉仕、いっぱい味わってくれていいからね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひゃぁんっ！？　またおちんちんっ、あっ、ふあぁんんっ！　ズドンって\n奥まで響く、んあぁんんっ！　ノイズが走ってっ、すごいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それに、お尻叩くの、またぁ！　あひっ、あっ、んひぃいんんっ！　叩かれ\nれるたび、エラー出るのが、よくてっ、あひぃいんっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わ、私も負けないからっ、んんっ！　おまんこの壁、ぐねぐね動かして、あ\nっ、ふあぁんっ！　おちんちん、いっぱい振り回してあげる、ああぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そ、その角度っ、あっ、ふあぁぁぁんっ！　亀頭がおまんこグリッて抉って\n、んん！　お腹ボコってなるぐらい突き込まれるの、いいっ！　ふあぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「またくる、大きい波がくるのっ！　あひっ、あぁんんっ！　い、いいよね！\n　我慢なんて、しなくていいよねっ！　イッていいよね、んひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、んあぁんっ！　おちんちん、大きくなったっ、ふあぁん！　ビクビ\nク暴れて、ご主人もイキそうなんだよね！　射精しちゃいそうなんだよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「わ、私の身体はご主人のモノ、だからっ、んあぁんんっ！　好きな所に、思\nう存分射精して！　私の身体で気持ちよくなって！　ふあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んひぃぃんっ！？　あひっ、んはぁんんっ！　ノイズの嵐が、エラーが止ま\nらないっ！　でもこれ、幸せ、なのっ、んあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人、きてぇっ！　あひっ、ふあぁんんっ！　イクの、一緒にイクから、\nおちんちん、びゅーびゅー射精してっ！　一緒にっ、ご主人と一緒に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふあぁあぁぁんんっ～～っ！！　あひっ、あっあっ、んひぃいんんっ！　射\n精すごいっ、精液すごいっ、あふぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「おまんこの奥にたっぷり出されてっ、んふぅぅんっ！　一回目より量も多く\nて、ドロドロの精液が、おまんこ満たしてっ、あっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んあぁんっ！　私もイクの、とまらないっ、ふあぁんっ！　\nノイズだらけで、視界も何か変、だけどっ、それが気持ちよくてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ふあぁんんっ！　知らない、こんにゃの、しらないよぉ！　初\nめての経験、知識、うれしい、あっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんっ、んあぁんっ……はぁ、はぁ……ほ、ほんとにいっぱい、出したね…\n…んんっ……凄すぎて、熱暴走、起こしそう……んんんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んっ……これで全部、かな？　ふぅ……私もやっと少し落ち着いた、かも…\n…おまんこの奥、ご主人の精液がたぷたぷに溜まってるのが分かるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「まったく……お仕置を口実にメンテナンスで好き勝手して、人の事ここまで\n滅茶苦茶に犯すって……ご主人って、やっぱりアレ、だよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ふふっ、何今更慌ててるの？　別に謝らなくていいって。……そりゃ恥\nずかしくもあったけど……嫌では、なかったからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「だけど……これだけいっぱい出してもらえるなら、本格的に人間の子供を妊\n娠できるパーツの実装、考えてみよっかな……なんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、冗談だと思う？　私の身体はご主人のモノ。ご主人が望むなら、ど\nんな私にだってなってあげる。……そのこと、忘れないでね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふあぁあぁぁんんっ～～っ！！　おちんちん、おまんこから抜けてっ……ん\nんっ！　精液、ボディに降りかかってくるっ、あぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「あっ、んあぁんっ……！　おまんこの中をべったり汚されるのも気持ちよか\nった、けど、んんっ！　身体に熱いのかかるのも、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あぁんんっ！　これ、イクの止まらないっ、あひっ、ぬるぬ\nるの精液、もっと、もっとほしいっ、あっ、んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「全身をご主人にマーキングされちゃうっ……ご主人のモノだって証をいっぱ\nい刻み込まれてっ、あひっ、あっ、んふぅんんん～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……ご主人、ほんとどれだけ出したの……？　私の身体\n、全身精液塗れで、凄い事になっちゃってるよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「――ふふっ、別に怒ってないよ。そりゃ、お尻叩かれたり、えっちな音いっ\nぱい聞かされたりで、少し恥ずかしくはあったけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「放置プレイとか、恥ずかしい気持ちよさとか、新しい快感を学べたのは……\nうん、新鮮で、ちょっと楽しかった、かも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「って、なに、ご主人、そのしょうがないなぁって目は……え？　自分はお仕\n置したのであって、喜ばせようと思った訳じゃないって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ふふっ、残念でした。知ってるでしょ、私は未知の事を『学習』することが\n大好きなの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいのは、やっぱり少し慣れないかもだけど……ご主人が望むなら、\nまたいつでも、新しい快感、私の身体に教えてくれていいんだからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}