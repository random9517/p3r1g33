{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あ、そうなんだ。なるほどなるほど？　わかったよ。報告ご苦労さん。持ち\n場に戻ってね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114540001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "時間帝国兵たち" ]},
		{"command":[ "SETTEXT", "「はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_924_010114540001" ]},
		{"command":[ "SETCHARA", "0", "char_00092401_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00092501_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「女王様、どうやらカツマくんとルナちゃんたち、いろんなルートでこの城に\n近づいているみたいです。もしかしたら、もう入ってきてるかも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114540002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114540001" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いや～。カツマくんもルナちゃんもＥＤＯも、みんながんばってるよね～。\nどうする？　いっそ全員ここに呼んじゃおっか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114540003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「呼んでどうする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「えー？　だって、楽しそうじゃん？　みんなでわいわいガヤガヤ、ドタバタ\nドンパチってさ！　女王陛下の目の前で！　あははははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114540004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「要するに、行って排除してくればよいのだろう？　ここに入り込まれる前に\n。回りくどい言い方をしおって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あれれ～？　ボク別に、そんなこと言ってないけどなー？　でもまあ、行く\nって言うなら止めないよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114540005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「うるさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114540002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おい、そこのウサギ。お前も来い。元はと言えば、おまえが連中を始末しそ\nこなったせいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114540002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ま、いいでしょう。あなたたちだけでは、あいつらを倒せるとは思えません\nし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114540001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はいは～い。いってらっしゃ～い。あ、そうだ、女王様、カツマくんはここ\nに呼ぶんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114540006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「うむ。そのようにせよ。ふふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114540002" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}