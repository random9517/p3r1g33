{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それじゃ、まずはこの方……栄えある人気投票第１位！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022850001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 	
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "じゃじゃじゃん、と自分の口で効果音を発したジェスタに、俺はひとまずスト\nップをかけた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「投票？　投票ってなんなんだ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あ、それは後で説明するから。今はスルーして欲しいかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022850002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうか。それなら聞かなかったことにでもするか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふふふ、話が早くて助かるよ。で、こちらがその第１位」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022850003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……ようやく私の出番が来たようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850001" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スッ、と音もなく俺の前に出現したのは……どうやら、ダークエルフのようだ\nった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「自己紹介をさせてもらおう。お前も知っての通り、私こそは刻の女王に呼び\n出された異界の四神衆が１人……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ！？　なんだその設定！　初耳だぞ、今初めて聞いた！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あれれ？　そーだっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022850004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ら、刻の女王の関係者だったのか！？　ここに呼ばれた時から変だとは\n思っていたが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そーなんだよね。前回は、ダークエルフ三姉妹だったでしょ。だから今回は\n～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022850005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「女王が召喚した異界の４人組って設定みたい。ボクにはよくわかんないけど\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022850006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「設定とか言わないでほしいですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022850001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「で、さっき言ってた人気投票の話なんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022850007" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「どうせ召喚するなら強そうな人を呼びたいよね～ってコトになってさ。女王\nが投票を開催したんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022850008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「どこの世界からどんな人を呼ぶかって。で、決まったのがこの４人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022850009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「え？　え？　え！？　私たちは、そんな雰囲気で呼ばれたのですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022850001" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「あらあらあら～。びっくりしちゃった。でも、望まれて呼ばれたんだったら\n嬉しいかも～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010022850001" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我は貴様らとは違って多忙の身ゆえ、突然呼ばれてだいぶ困惑しているが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_010022850001" ]},
		{"command":[ "SETCHARA", "0", "char_00025801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……そろそろ自己紹介に戻ってもいいだろうか。つまりだ、これまでの話を\nまとめると」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850003" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「その投票によって呼ばれた、刻の女王の異界からの刺客。四神衆で最も支持\nを集めた覇者」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「第１位がこの私。スザクということになるだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え～っと……見た目はダークエルフだよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ああ、そうだな。職業はダークエルフ・シノビマスターだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ダークエルフ・シノビマスターですとぉおお！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022850002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「シノビ……ってことは忍者か！　ダークエルフ・シノビマスター……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「シノビを目にするのは初めてか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850007" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや。そんなことはない。幼馴染にも１人いるくらい、慣れ親しんだ属性…\n…だが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「だが？　なんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ダークエルフ・シノビマスターってのは初めてかもしれん。帝国のやつらは\nなんでその二つの属性を組み合わせたんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あはは、属性の大渋滞がおこっちゃってるよね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010022850010" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……なにがおかしい。私はどこにでもいる、ダークエルフのシノビだ。あや\nしいものではない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850009" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、あやしすぎるだろ。というか、よくこんなドンピシャな人材が存在し\nたな。普通いないぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだ？　ダークエルフのニンジャって」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はっきりきっぱりざっくり言い過ぎですぞ、ご主人～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010022850003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ダークエルフの里に生まれ、秘術によりその身に『アラガミ・エンペラース\nザク』を宿した私は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850010" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「幼い頃からニンジャに憧れ独学でニンジュツを学び、恐るべき炎の力をニン\nジュツに乗せ敵を撃つ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……と、ここまで聞いてもまだわからないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ。まったく理解できん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「でも～実際いるんだから仕方ないわよね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010022850002" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850013" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アンドレッテ" ]},
		{"command":[ "SETTEXT", "「私の世界ではお目にかかったことはございませんけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_260_010022850002" ]},
		{"command":[ "SETCHARA", "0", "char_00026001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「……………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850014" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「我の世界でも見た事はないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_010022850002" ]},
		{"command":[ "SETCHARA", "0", "char_00025801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「うううううるさいうるさい！　いるといったらいるのだ！　ここに！」　　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850015" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあそうか。いくつも世界があれば、どっかにいるのかもな。ダークエルフ\n・シノビマスター」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「もうそれ以上言ってくれるなッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「でも～、彼女ってば可愛らしいところもあるのよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010022850003" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「さ、沙世子！　余計な話はするな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850017" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「スザクちゃんってば、ニンジャとしての技はすべて独学で身につけたらしい\nんだけど～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010022850004" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「『ボウチュウジュツ』だけは相手がいなかったせいで、知識ばっかり溜め込\nんじゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010022850005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「いつかそれを披露する相手が現れるのか、と悶々とする日々を送りながら１\n人でいつもプレイに励んでるんですって～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010022850006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおおお～……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「お前、お前、お前、お前ぇ！　お前が経験豊富な人妻だと言うから信用して\n話したのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850018" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「なぜ、こんな出会って間もない男に私の秘密を……！　ゆ、許すまじ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850019" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「え～。だって、カツマちゃん？　この目で見たら結構良さそうな人だったか\nら～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010022850007" ]},
		{"command":[ "SETCHARA", "0", "char_00025901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "沙世子" ]},
		{"command":[ "SETTEXT", "「スザクちゃんのボウチュウジュツのお相手にどーかなって思って♪　おせっ\nかいだった？　ごめんなさい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_259_010022850008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「ああああああああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850020" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「……と、少々淫乱の素質はあるが。スザクの炎の扱いはこの４人の中でも随\n一だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_010022850003" ]},
		{"command":[ "SETCHARA", "0", "char_00025801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヴァラファール" ]},
		{"command":[ "SETTEXT", "「ゆえにこやつが素晴らしい武人であることは間違いない。第１位なのも納得\nの結果だろうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_258_010022850004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「あ、ありがとう、ヴァラファール！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850021" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「淫乱なのは認めていく方向なのか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スザク" ]},
		{"command":[ "SETTEXT", "「そこにはあえて触れなかったというのに……！　わ、忘れろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_257_010022850022" ]},
		{"command":[ "SETCHARA", "0", "char_00025701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
