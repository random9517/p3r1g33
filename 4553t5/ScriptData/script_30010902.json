		{"command":[ "PLAYVOICE", "001_0904215" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、オチンポがびくびくしてるぅっ、んひぃっ！　パンパンにふ \nくれあがって、あはぁああんっ、また精液でちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904216" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「出してぇっ！　あひぃんっ、ビンビンのオチンポのさきっぽから、あっあっ \nあっ、特濃ザーメンミルクを、びゅーびゅーだしてぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904217" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私のキツキツオマンコで気持ちよくなってぇっ！　あっあっあひっ、精液ど \nぷどぷ、いっぱい出してほしいのぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904218" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたの濃くて臭いザーメンを、おっおっおぉんっ！　私にめぐんでくださ \nぃっ！　オチンポミルクの味を覚え込ませてぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904219" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃいいんっ！　あっあっあっ！　私もクるっ！　イっちゃうっ！　あな \nたのオチンポでイっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904220" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポミルクだしてぇっ！　あなたのオチンポで、私のぜんぶをあなたの \nものにしてぇっ！　んあぁぁっ！　イくイくっ、イっくううううっ！！！」", "NORMAL" ]},
