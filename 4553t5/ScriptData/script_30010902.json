		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904102" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「はうぅぅ……あなたには散々、私のはしたない姿を見られてしまっているの \nにな……今さらとりつくろっても仕方がないだろうに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904103" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「い、いや、大丈夫だ……準備はすでにできている……私のアソコはもうすっ \nかり濡れてしまっているからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904104" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたに声をかけられた時から……オマンコにオチンポを挿れて欲しくて… \n…もうすっかりとろけてしまっているのだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904105" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「だからどうか……挿れて欲しい……私のオマンコにオチンポを挿れて、気持 \nちよくなって……中にたっぷりと射精をしてほしい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904106" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコの奥まであなたの精液でマーキングして……身も心も、あなたのも \nのにしてくれ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904107" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁあああっ……！　あっ、あぁっ、入ってくるぅっ……固くて、大きくて \n……んぅぅっ、熱々のオチンポぉ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904108" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひぁんっ、あぁんっ、あぁあんっ！　亀頭が太すぎるぅっ！　プリプリの雁 \n首がオマンコをかきわけてぇっ！　ブリュブリュって入ってくるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904109" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぉっ、あぁぁっ、んあぁぁぉっ……ビンビンの勃起オチンポが、どんどん \n中に入ってくるぅ……んあひっ、んひぃっ……すごいぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904110" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポの形がはっきりわかるぅっ、あぁんっ、カチカチで、すごく凸凹し \nていて……んふぅぅんっ、すごい男らしいぃっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904111" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっあっあっ、オマンコのお肉をずりずり擦りながら入ってくる \nぅ、あひぅううっ、私のオマンコ、あなたのオチンポ専用に改造されてるぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904112" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁんっあぁぁんっ、もっと来てぇ、んふぅぅっ、一番奥までオチンポ挿れ \nてぇ、ひぃんっ、私のオマンコ、ぜんぶあなたのものにしてぇ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904113" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あふうっ！？　あっあっあっ、オチンポ、奥に当たってる……ガチガチの亀 \n頭が赤ちゃんのお部屋をトントンってノックしてる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904114" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあぁぁ～～～っ！？　押し込んじゃダメぇっ！？　オチンポ止まってぇっ \n！　そこで行き止まりだからぁ、んあぉうっ！　もう入らないからぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904115" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あなたのオチンポ、おっきすぎるぅ……んふぅぅっ、どうだ \nろうか……オチンポはちゃんと根本まで入ったのか……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_02_04" ]},		
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904116" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコの中はあなたのオチンポでいっぱいだぞ……奥もずっとぐりぐり擦 \nれていて……んあぁぁっ、身体のあちこちが敏感になっている……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904117" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあぁっあっあっ……まるで私の身体全部が、んふぅぅっ、オマンコになっ \nてしまったみたいだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904118" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「それに、あぁっ、この態勢だと、顔が近いな……少し、恥ずかしい……んふ \nぅっ、肌を重ねるというのはとても破廉恥で……素敵なことなのだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904119" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたはどうだ……？　私のオマンコはちゃんと気持ちいいか……？　キツ \nすぎたり、ユルくはないだろうか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904120" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……そうか、よかった……実はこの日に備えて、オマンコを鍛えておいたの \nだ。女性用雑誌で見た、膣圧トレーニングというやつだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904121" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたに気持ちよくなって欲しかったからな……私のオマンコで好きなだけ \nオチンポをシゴいて、気持ちよくなってくれ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904122" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあっ、あっ、あっ……オチンポが抜けていくぅ……あんっ、あぁぁんっ、 \nエラがごりごり、オマンコを擦ってるぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_02_05" ]},	
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904123" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、ダメ、オチンポ抜けちゃう……んふぅぅぅっ！　また入 \nってきたぁ、オチンポぬりゅりゅって、オマンコのお肉をかき分けてるぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904124" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁああんっ、あっあっあっ……あひんっ！　奥にコツンて、オチンポ当た \nってる……んあぁぁっ……あっ、あっ、また抜けていっちゃう……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904125" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポがオマンコに、出たり入ったり、あぁんっ、あんっあんっ、ずぽず \nぽ気持ちいいよぉ、あぁああんっ、オチンポすごいぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904126" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁああっ、あっあっあっ、バキバキの勃起オチンポぉ、あぁああんっ！　 \n凸凹がいっぱいで、たくさん擦れるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904127" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコからじゅぷじゅぷっ、イヤらしい音が鳴っちゃってるぅ！　んぁあ \nあっ！　ダメぇっ！　お願いだ、聞かないでくれぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904128" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、カリすごいぃっ！　オマンコの中ほじほじしてるぅっ！　ひ \nぁあああんっ！　あちこちに引っかかって、Ｈな声でちゃうぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904129" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁ～～～んっ！　奥もすごいよぉっ、子宮口とオチンポがちゅっちゅし \nてっ、やぁああんっ！　腰をぐりぐりっ、押し付けちゃだめぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904130" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「やぁああんっ！　イヤらしい動きしないでぇっ、あぅううんっ、脚ががくが \nく震えて、あひぃいいんっ、力が入らなくなるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904131" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポでオマンコぐちゅぐちゅされると、あぁああんっ、私の身体じゃな \nいみたいっ、あなたのための、ただのオマンコになっちゃうぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904132" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私も頑張ってオマンコを締めるから、あぁああんっ、あなたのオチンポの形 \nを、私に刻んでぇっ、あぁんっ、オマンコずりずり、気持ちよくなってぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904133" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ……！？　あっあっあっ、オチンポびくびくしてる……？　亀頭が風船 \nみたいにふくれて、あぁあんっ、びんびんに反り返ってる……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904134" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「もうイキそうなのか……？　あぁんっ、あんっあんっ、オマンコにいっぱい \n射精するんだな、あはぁああんっ、いいぞ、出してくれっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904135" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁああんっ！　オマンコの中がパンパンになるくらいっ、あっあっあっ！ \n　ザーメンを注ぎ込んでっ！　私の中をあなたでいっぱいにしてぇっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904136" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあぁぁ～～～～っ！！？　あちゅいぃぃっ！　赤ちゃんのお部屋に熱々の \nオチンポミルクがびゅうびゅう当たってるぅ～～～っ！！」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_02_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904137" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「どろどろのザーメン気持ちいいっ！　あぁああっ、あっあっ、私もクるっ！ \n　イッちゃうっ！　あっあっあっ、イくっ、イくっ、イくうううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904138" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁ～～～～……っ！　あぁっ、あっあっあっ、オチンポが震えて、んあ \nぁっ、オマンコの一番深いところに、精液がびゅうっ、びゅうって……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904139" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……オマンコの奥に、あなたのどろどろザーメンがべっとりと貼りつい \nて……んふぅぅっ、いっぱいマーキングされてるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904140" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「熱々の精液でオマンコを満たされて……あぁ、あったかい……お腹の奥から \nぽかぽかと……あなたの体温が身体に染み込んでくるようだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904201" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ……あぁ、すごい……オチンポがまだカチカチに固いまま……さすが \nはあなたのオチンポだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904202" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……できれば、その……もう一回、してもらえないだろうか……？　オマン \nコが戻らなくなるくらいに、あなたの形を覚え込まされたいのだ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904203" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「私のオマンコを使って、オチンポをたっぷりとシゴいて……タマタマが空っ \nぽになるまで、精液を私に出してくれないか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904204" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「もちろん、私もできることをしよう。そのためにせっかくオマンコを鍛えた \nのだ。こうして締め付ければ……んんっ、どうだ……気持ちよくはないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904205" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「雁首は……こうか……？　んっ、んんっ……ここを締め付けると……んっ、 \nどうだ……？　亀頭のところだけ締まっただろう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904206" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「竿の部分だってこうして、ぎゅっぎゅっと、んふぅぅっ……根本のところも \n、んん～～っ……あっ、オチンポがびくびくしてる……気持ちいいのだな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904207" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ならば、これはどうだ……締め付けたまま腰を回すと、んあぁっ、あぁっ、 \nあっ、オチンポがぐりぐりっ、んふぅぅっ、擦れるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904208" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたのために、んふぅぅっ、んあぁっ、エッチな本やビデオでたくさん勉 \n強したのだ……んあぁっ、どうだ、気持ちいいか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904209" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁっ、あぁぁんっ、んあぁっ、鍛えたオマンコでオチンポをいっぱいに \nぎにぎしてやるからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904210" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコの味見をして、んふぅっ、オチンポ気持ちよくなってくれ、あぁぁ \nっ、私のオマンコの味を覚えて、あふぅぅっ、いっぱいハマってくれ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904211" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃいいんっ！？　ま、待てっ、締め付けているときに、そんなに動かれ \nたら……んほぉおおおっ！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904212" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひぃっ、んひぃいいっ！　オチンポたくさん擦れてるぅっ！　あひぃっ、ひ \nぃいんっ、カチカチのカリ首がオマンコのお肉をブリュブリュしてるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904213" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃいっ！　お、怒っているのかっ！？　んひぃっ、許してくれぇ、あひ \nっあひぃいっ！　ナマイキなマネしてごめんなさいっ、ゆるしてぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904214" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっあひっあひっ、らめぇっ！　オチンポしゅごすぎるぅっ！　でこぼこ \nいっぱいのオチンポすごいぃっ！　いっぱいこすれちゃうぅっ！」", "NORMAL" ]},
