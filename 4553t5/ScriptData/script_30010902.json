		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコのおくっ、赤ちゃんのお部屋にも、びゅーびゅーって、あふぅうう \nんっ、精液入ってきちゃってるぅっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904303" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んあっ、あっあっあっ、子宮がおぼれちゃうっ、ザーメンあちゅいっ、オチ \nンポ汁きもちいいっ、あっあっあっ、またイくっ、イくっ……！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904304" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁぁっ、あぁっ……オチンポがびくびくすると、んあっあっあっ、びゅる \n、びゅるって、精液出てるぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904305" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコでしぼってあげる……んっ、ふぅっ、ふぅっ、根っこのところから \n、ぎゅっぎゅって、んふぅぅっ、オチンポしぼるぅっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904306" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「きゃぁんっ！　あっあっあっ、また出てるっ、ドプドプって、いっぱい…… \nもっと出してぇ……全部オマンコで、絞ってあげるからぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904307" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ～～っ……オマンコの中がザーメンでたぷたぷだ……んうぅっ、精 \n子がオマンコの中を泳いで……ふふっ、このままだと受精してしまうな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904308" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ、でも……あなたの赤ちゃんなら欲しいな……私とあなたと、一緒に二 \n人の赤ちゃんを育てられたら……それは、どんなに……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000109_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904309" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぐすっ……す、すまない、涙が勝手に……おかしいな、悲しいどころか、今 \nはこんなにも温かい気持ちなのに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "001_0904310" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「……私はもう……ひとりじゃないんだな……あなたのお陰だ、ありがとう… \n………母上様、皆……私は今、幸せです……」", "NORMAL" ]},
