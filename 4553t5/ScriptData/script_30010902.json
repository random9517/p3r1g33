		{"command":[ "PLAYVOICE", "001_0904410" ]},
		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「もっと……身体の隅々まで、あなたのザーメンをかけてほしい……肌が見え \nなくなるくらいまで、あなたの精液を……一生、とれなくなるくらいに……」", "NORMAL" ]},
