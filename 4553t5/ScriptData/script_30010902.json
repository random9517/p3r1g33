		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁあああああ～～～っ！！　あっ、あっ、あっ！　あちゅいぃっ！　ザー \nメンあちゅいっ！　中にいっぱい出てるっ！　しゅごいぃっ！」", "NORMAL" ]},
