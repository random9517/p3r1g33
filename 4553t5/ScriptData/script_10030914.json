		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「遅いのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザー・ハルカプトラの攻撃がハルカプトラに命中した。しかし、そこには\n涼しい顔のハルカプトラが立っている。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「どうやら身体の硬さは我の方が上のようであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「くっ。だが、そなたの愚鈍な動きでは、我をとらえるのは不可能である……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115940002" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ハルカプトラはアナザー相手に互角の戦いを繰り広げていた！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ウヒヒヒヒヒヒ……！　不運になっちゃえ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「じゃあお返しに、君のことを不幸にしてあげる……。フフフフ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「す、すごく激しい銃撃戦です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「わたしたちが入り込む隙間はないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒヒ……ヒヒヒ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115940002" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「フフ……フフ……フ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115940002" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ええっ、倒れちゃいましたよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115940002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ちょっと興奮しすぎて……ひぃ……ひぃ……体力が……限界……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115940003" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「私も……ちょっと休むね……。敵の目の前で体力尽きちゃうなんて……不幸\nだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115940003" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「……相手の目の前で無防備な姿をさらすことになるなんて……なんて不運…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115940004" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "グリムロックは……って、ふたりそろってぜぇぜぇ言ってるじゃねーか！　ど\nうなってんだよ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして、サイレーンは……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「よしっ、いけいけ、ハルカプトラー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「負けるなハルカ！　もっとよく相手をみるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえらは観戦してるだけかよ！　戦えよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115940002" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「うん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010115940002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いやいや、なんで不満そうな顔してるんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そんな戦いがしばらく続くと思っていたが、サイレーンたちが出勤してきたと\nいうことは、ほかの教師たちもやってくるということだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「夜叉！　大丈夫か！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「おねえちゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115940003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「時間帝国の連中がきてるって聞いたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……って、あれ？　いつもの連中じゃないね。新顔かい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょうどいいところに援軍だ！　こいつらは、サイレーン、ハルカプトラ、\nグリムロックのアナザーなんだ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なんだって！？　言われてみれば、確かに似ているような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010115940002" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「まずいのである。さすがにこの人数を消耗した我らではさばききれないので\nある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115940003" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「仕方ない。撤退するよ、グリムロック！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115940003" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒ……ヒヒ……じゃあ、またね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115940005" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「次は負けないのである！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115940004" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "アナザー・ハルカプトラが仲間ふたりを小脇に抱え飛びたつ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ふふん！　次もまた吹っ飛ばしてやるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115940002" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「ツインソードの力を手に入れたわたしには、不可能なんてないんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115940003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ふむふむ……不可能はない、であるか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010115940002" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ならば勉強も思いのまま、というわけだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010115940003" ]},
		{"command":[ "SETCHARA", "0", "char_00001601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「当たり前よ！　なんでも任せなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115940004" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「それじゃあ、引き続きルナテミスたちの勉強……見てあげてね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010115940004" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115940005" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0162" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETTEXT", "そして、桃花はまたルルーナたちに勉強を教えることとなってしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「はぁ……。それで補習の続きなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「ああもう、なんでこんなややこしい文章を読まないといけませんの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いいから読みなさい！　音読して、覚えなさい！　ああもうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "桃花は金棒を振りまわしながらルルーナに勉強を教えている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「なんだか鬼みたいだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「本当ですね。というか、なんで変身してないのに私の金棒を振りまわせてい\nるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、わからん！　わからーん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「暴れるなー！　わかるまで教える！　頭に叩き込んでやるー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115940006" ]},
		{"command":[ "SETCHARA", "0", "char_00002804_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}