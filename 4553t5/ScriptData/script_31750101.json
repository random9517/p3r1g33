{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほうらっ……大人しくしてなさいっ。ヘタに暴れると、ケガするわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムの尻尾……鉄くらいならちょん切っちゃうのよ？　アンタの大切なチン\nポ……血だらけになっても知らないから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、そうそう、素直にしてれば痛くはしないわ。もちろん、チンポは\n大きくさせときなさいよ？　ヤムがしてあげるんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それにしても……ふーん、なかなか変な形ねぇ。いつもは小さくなってて、\nここって時におっきくなるってワケ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うりうり……んふふっ……ナニよ、生意気に反応しちゃってんの？　へぇ…\n…ヤムにされると思って、プルプルさせてんのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いいわ、アンタの望みを叶えてあげる……でも、当然タダって訳にはいかな\nいわよね？　ほら……アンタのご奉仕を見せなさいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ここからだと、よーく見えるでしょ？　ヤムの……ぱっくり割れ目……オマ\nンコ……特別に舐めさせてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「チンポを気持ちよくして欲しかったら、当然先にヤムを感じさせなさい。ほ\nら……さっさとするのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ……！　んふっ……そうね、舌……ちゃんとペロペロするの……スジの\nところ、しっかり……押し付けなさいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁんっ……んっ、くぅ……んっ……なかなか……悪くないわね……んっ、\nヤムのオマンコ……一応、いー感じになってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「それじゃ、ヤムの方も……ちょっとごほうびあげないとね……はむっ、ちゅ\nぷっ……んちゅっ、れろっ、ぴちゃ……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふっ……めちゃくちゃ分かりやすいわね。ビクビクさせちゃって……ちゅ\nぱっ……チンポが喜んでるってことよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、もっとして欲しい？　んふふ……なら、もっとしっかり舐めなさい。\nヤムのオマンコ……ちゃんとよくするのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんっ……あふっ、そう……ネトネトする感じがいいじゃない……これって\n、ヤムの方も同じようにしてあげればいいのよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「れろ……んんっ、えろっ、れろっ、れろれろぉぉぉっ……ちゅぱっ、ヤムの\n汁で……チンポ……ぐずぐずにしてあえる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、んっ、ちゅぱっ、かぷっ……んふっ！　ビックリした？　ヤムの\n牙……ちょっと当たったでしょ……めちゃくちゃビクビクしてるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ、心配しないでも噛みちぎったりしないわよ。アンタが、ちゃんとオ\nマンコをよくしてる間はね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あっ、んん……はぁっ、んく……そうそう……あふぁ……こーいうの、シッ\nクスナインって言うんでしょ……？　ヤムは物知りなのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「両方が……一緒に、いー感じになったら……その方が絶対いいじゃない……\nしっかり、ご奉仕しなさいよね……ちゅぱ……んちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「れろ……んれろぉっ……それにしても……ヘンな味よね……チンポ……ちゅ\nぱっ、ぴちゃ……ここだけにおいもおかしいし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅ……人間のオスなんて、不味いモノだと思ってたけど……\nここだけは、そうでもない感じなのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、なーに、食べられると思った？　アンタを食べたって、何の足し\nにもなりゃしないわよ。イルルも面倒くさいことになるしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103122" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ま、その、ちょっとビクってしてるトコは面白かったけど。ちゅぽっ、もっ\nと……味わってみるわね……はむっ、くぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ、むぐっ、んっ、じゅぷっ……りゅぷっ、じゅぷんっ……ふぉら……\n深く……咥えたげるわ……じゅぽっ、ちゅぷぅぅぅ……んじゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぅんっ……くぽっ、ぐぷっ……じゅぱっ……そう言えば……こっちってど\nうなってるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ！　また……チンポ跳ねたじゃない。ちょっと尻尾でつついたダケなの\nに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふふーん、それだけキンタマってのは敏感なんだ……へぇぇー、なるほどね\nぇ……んふふぅー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「別にぃ、ちょーっと面白いって思っただけだし。つんっ……つんっ、あはは\nっ、マジで跳ねてるのウケるー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「でもぉ……痛い訳じゃないでしょ？　ヤムはちゃーんと加減してあげてるも\nんね。ちゅぷっ、チンポもしっかりビクビクしてるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、何か……汁が出てきた……ちゅぷっ、くぽっ……ん……これっ\nて、アレ？　せいえきってヤツ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふーん、その前に出るヤツ……じゃあ、もう少しで出るんだ……チンポが待\nちきれなくなってるってことよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゃあ……じゅぷぅっ、マジのヤツ……してあげる……んじゅぷっ、ちゅぽ\nっ、りゅぽっ、くぷっ、んじゅぷっ、じゅるるぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ……分かったわ……これ、キンタマと一緒にしてあげると……りゅ\nぷっ、いいんれひょ……じゅぽっ、くちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふぉら……このビクビク……ごまかへないわよっ……じゅるっ、さっさと…\n…らひなさいっ、じゅぷっ、ちゅぷっ、んちゅうぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んんんっ！　むぐっ……んふっ……出て来た……んくっ、こくっ……んふん\nっ……ちゅぷぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「やっぱり変な味ぃ……じゅぷっ、んちゅぅぅぅ……まぁ……でも、ちゅぷっ\n……そう悪くもない……ものかもね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「こく……んくっ、んっ……ふふ……飲んじゃった。で、どうだったの？　ヤ\nムのペロペロ……良かったの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ、まー、こんだけ出しといて、悪いなんてことないわよねー。これ\nで、アンタはヤムの下僕確定ってことね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「何でって？　何でもいーのよ、ヤムがそう決めたんだから、そーいうもんな\nの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤムがこんなにしてあげるなんてないんだから。感謝しなさいよね、くふふ\nっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「で……いっぱい出したけど……まだチンポは欲しがってるみたいじゃない…\n…んふふぅぅー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さあて……どうして欲しい？　もっと続けて欲しいなら、ヤムにちゃーんと\nおねだり出来るでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「もうアンタはヤムの下僕なんだから、それ位出来る筈よね？　ていうか、す\nるのよ。ほら、しなさい……お、ね、だ、り！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふっ！　そーなのねぇ、そんなにチンポ……舐めて欲しいんだー。マジ\n変態じゃん、ちょーサゲ、ドン引きしちゃうー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どこで覚えてきた言葉……？　どーだっていーでしょ。とにかく、ヤムに続\nきして欲しいのね？　全く……仕方ない下僕なんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「いーわよ……ちゅぱっ、んちゅぷぅ……また、いい感じにしてあげる……だ\nから、アンタもちゃんとヤムを感じさせなさい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふっ……！　あっ、んっ……そうそう……オマンコ、ねろって……舐めて\nいくのよ……んりゅぷっ、ちゅぱ……んちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっふぅ……汁の味……残ってる……せーえきの味ね……ちゅぱっ、んちゅ\nぅぅぅ……じゅぷっ、りゅぷっ、んちゅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さっきは……この辺をくすぐったげると、よかったでしょ……んれろっ、れ\nろれろっ……あはっ、マジでまたビクビクしてるし、おもしろーい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あんっ！　んっ……アンタも生意気に……舌……やってくれるじゃない……\nんっ、いーわよ、ヤムも負けてないんだからね……ちゅぽっ、ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「くぱっ、んりゅぷ……んふっ……かぷっ……んふふっ、少し牙が当たるくら\nいでも……いーんでしょ？　じゅぽっ、ちゅぱぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「こっちも……ちょっと本気でしてあげるわ……じゅぽっ、ちゅぷぅぅっ、く\nぷっ、んりゅぷっ……チンポの皮のとこ……めくってぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「えりゅっ、れりゅっ……んっ、つんつんしてぇっ……ちゅぷっ、また……ん\nっ、汁出てきたぁ……んちゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちゅるっ……濃くなって来てるぅ……んふぅ……ここでやめたら、どうなる\nかなぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あはっ、何もしてないのにピクピクさせてるっ。そんなにお預けされるのが\nヤなの？　ほーんと、しょーがない下僕ねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んちゅぷぅぅ……んりゅっ、心配しなくても……ちゃんと、イカへてやるわ\nよ……じゅぱっ、んくぱっ、じゅぷっ、んじゅぅっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほぉら……また、キンタマもさすってぇ……れろっ、スジのとこぉ、れろれ\nろしてぇ……ちゅぱっ、んちゅっ、さきっぽ……咥えてぇ……はむぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はぁ……んむっ、あふっ……チンポ跳ねてるぅ……んちゅぷっ……もう、待\nてないんでひょ……？　バレてるのよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヘンに強がったりしないで……ちゅぱっ……さっさと出しちゃいなさいっ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゅぱっ……んちゅぷっ、ほら……どうしたいか言ってみなさいよ。アンタ\nのチンポはっ……ろうひてっ……ほしいのっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……いーわよ……飲んだげるわ……ふぉらっ……さっさとっ、じ\nゅぷんっ……らひなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふぅぅぅっ……！　んっ、んくっ、こくっ……んくんっ……んむふぅ……\nいっぱひ……れてる……んっく、こくん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「じゅぷっ……さっきより味がちゃんと分かる感じ……こくっ、んくっ、こく\nんっ……んふっ……ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「はふぁ……んっ、思ったよりも悪くなかったわ。アンタのチンポにも一応、\nそれなりの使い道はあるってことかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ま……中途半端に残してても、仕方ないでしょ？　ちゃんと奥にある分……\n出しちゃいなさい……くぽっ、んちゅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んふふふっ……んくっ、れて来た……ちゅぷぅぅ……チンポの扱いも、慣れ\nたもんね……くぽっ、ちゅぱっ……んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「れろ……出し切ったみたいね……あーあ、すっかりふにゃふにゃになっちゃ\nって。だらしないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「さてと……ま、しょーじき全然期待してなかったケド、思ったよりは楽しめ\nたかもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「で、どーなの？　またして欲しい？　ヤムにチンポ弄り回されて、せーえき\nいっぱい出してみたい？　どーなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そう……んふふっ、まーね、そこまで言うんだったら、考えたげなくもない\nわ。せいぜい楽しみにしてなさいよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ……顔に掛けたいの？　ナマイキにマーキングのつもり？　……ま\n、いーわよ……好きにしたら？　……りゅぷっ、んじゅぷぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぁっ！　んふっ……ちょっと……！　顔はいーけど、ヤムの髪を汚さない\nでくれる？　あぁー、もう……ベタつくじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017501_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「全く……狙い方がヘタクソなのよ……んちゅぷっ……クサいの出しといて、\nこれなんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「まあ、いーわ。どーせ、まだ残ってるんでしょ、ごまかしても無駄よ、ヤム\nにはちゃーんと分かってるんだから……ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ほら……チンポ震わせて……ちゃんと奥にある分……出しちゃいなさい……\nくぽっ、んちゅぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んぁっ……ほら、れて来た……全く分かりやすいチンポなんだから……ちゅ\nぱ……ぴちゃ……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んっ、ぺろ……もう出そうにないみたいね……ちゅぱっ、もうちょっと味わ\nえるかと思ったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ま、アンタにしては頑張った方なのかも。下僕にいろいろ求めたって仕方な\nいものね。次はもっとたくさん出せるようにしておくのよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「で、どーなの？　よかった？　どうせ、また下僕のくせにヤムにくっさいに\nおいつけたいんでしょ？　このお肌ドロドロにしたいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「きゃははっ、なっさけない顔！　そんな風にお願いされたら、アワレ過ぎて\n引くけど、今後の態度次第では許してやるわよ！　ふふん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
