		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「っ！？　豪語するだけあって、強くなったな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「減らず口もそこまでだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113950001" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "激しいぶつかり合いの末、目の前に、二人がもんどり打って倒れ込んできた！", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いくらエファナティカでも、今の体勢で攻撃を喰らったら――。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、今こそ行動の時ですぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って！？　蹴るなーっ！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "思わず身を乗り出したところに、駄犬の絶妙な後ろ蹴りを喰らい、俺はみっと\nもなく二人の間へよろめき出てしまい……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「邪魔を……するなっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113950002" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ぐっは！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "修羅姫渾身の一撃を喰らって……しま……った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "『乱杰李威仏斗暴屡（らんじぇりい・ふっとぼうる）』……やっぱりただのス\nポーツじゃない、な……がくっ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「ふん！　敵を庇うとは愚かな！　情にほだされたか！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113950003" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「愚かなのは自分だと気づけ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950002" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「何ぃ……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113950004" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「競技中、選手同士の間でならば、たとえ命を落とすような真似であっても受\nけ容れよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950003" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だが！　しかし！　選手以外の者を巻き込んで、かつその命を軽んじるなん\nて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950004" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それでも乱杰李威仏斗暴羅亜（らんじぇりい・ふっとぼうらあ）か！？　誇\nりはないのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113950005" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「カツマ特別講師、無事！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「嗚呼……こんなにボロボロになって」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「尊い犠牲だった……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "死んでねえよ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「カツマの分まであたしたちは戦う……そして、勝つ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950006" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「その勝利を、今は亡きチームメイト・カツマに捧げる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「オオー！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00090301_01", "7", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00090401_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だから死んでねえよっ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「……私は、なんという、取り返しのつかないことをしてしまったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113950006" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あ、お姉ちゃん？　正気になった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113950001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「カツマは私の母になってくれるかもしれなかった存在なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113950007" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あ、まだ駄目かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113950002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「人は、同じ過ちを繰り返すのです。まったく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「同じかあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113950001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんの話だ、なんの。死んでねえよ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「カツマくんは残念だったけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113950001" ]},
		{"command":[ "SETCHARA", "0", "char_00001801_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "残念じゃねえよ！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グリムロック" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）にも涙してもらえて……本望……かも？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_010113950002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "本望じゃねえよ……って。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「はっ！？　襲来者（インベーダー）！　なぜここに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113950008" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「あ、はい？　さっきからもう正体バレバレでしたけど」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950008" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「おや？　塾長の様子が……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……襲来者（インベーダー）！？　どうしてここに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950009" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「……あーっ！？　しまった、洗脳が解ける時間！？　もうロスタイム入って\nる？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "時間制限があったのかよ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……えっ！？　何、あたし、この格好は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950010" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ここはどこよ！？　あたしは何よ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「なんだ？　やっぱあいつらに操られてたのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「洗脳ってことは、そういうことでいいんじゃない～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113950001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そんな不覚を、あたしがとった……？　なんてこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950012" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「つまり、あれか？　彼女がおかしかったのも、私たちが仲違いしたのも、そ\nしてカツマが死んだのも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113950009" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "死んでねえってば。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……そう。全部、こいつらのせいってわけね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950013" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「ひいぃっ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00090401_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「あんなに熱く婚活について語り合った仲じゃないですか、塾長！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「むしろ塾長の熱弁に洗脳されたのは我々……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「ここは穏便に、ノーゲームってことにしませんか、塾長。ね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしを馴れ馴れしく塾長なんて呼ぶな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113950014" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生たち" ]},
		{"command":[ "SETTEXT", "「ひいぃぃぃっ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "3", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00090301_01", "3", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00090401_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あー……これは、襲来者（インベーダー）が全部泥を被って仕舞い、という\n感じになりそうですなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113950002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「……ご主人。いつまで死んだ振りを続けるおつもりですか？　間もなく本物\nの試合開始となりそうですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113950003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "はあ、めんどくせえ……。", "NORMAL" ]},
