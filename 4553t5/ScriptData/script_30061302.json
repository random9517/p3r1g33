		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「このまま、あなたのそばで休ませてもらってもいいかしらぁ？」", "NORMAL" ]},
