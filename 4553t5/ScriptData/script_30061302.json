		{"command":[ "SETTEXT", "「あぁぁんっ！　オチンチンが抜けて……あっ、ひゃあぁっ！？　ふっ、ぐっ \n、んくぅぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304401" ]},
