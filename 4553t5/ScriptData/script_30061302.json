		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「お腹の中、あなたのザーメンでいっぱいなのにぃ！　子宮に入りきらないく \nらいの精子が、奥に出されてるわぁ！」", "NORMAL" ]},
