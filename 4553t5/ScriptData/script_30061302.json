		{"command":[ "SETIMAGE", "0", "still_00000613_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　熱くてドロドロした感触が、拡がっていくのぉ！　こんなの \n、イッてるのに、またイカされちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「赤ちゃん孕みながら、イクぅぅぅっ！　あっ、あっ！　んっ、あぁぁっ！　 \n気持ちいいの、また溢れてきちゃうのほぉ～！」", "NORMAL" ]},
