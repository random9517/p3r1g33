		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなところに呼び出すだなんて、どれだけダイヤナちゃんのことが好きな \nのぉ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304101" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うふふっ♪　ダイヤナちゃんも、同じことを考えていたわぁ～。あなたのこ \nとを見ていたら、すっごくムラムラしちゃってぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304102" ]},
		{"command":[ "SETCHARA", "0", "char_00000613_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁんっ……もう我慢できないわぁ♪　今日はサービスしてあげるから、あ \nなたのオチンチン、オマンコでいっぱい味わわせてちょうだぁい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あはぁんっ♪　いつ見ても、大きくて素敵なオチンチンだわぁ。こんなに反 \nりかえって……まだ挿れてないのに、感じてきちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000613_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ほら見てぇ……ダイヤナちゃんのオマンコ、もうぐちょぐちょなのぉ。あな \nたのことを思うだけで、こんなになっちゃうのぉ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ！　オチンチンの先っぽから、いやらしいお汁が出てきてるっ \n……早くオマンコに挿れたくて、たまらないのねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ふっ、あぁんっ！　待って……あなたは動かなくていいわよぉ～。今日はサ \nービスするって、言ったでしょ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「挿れるのも、動くのも、ぜーんぶダイヤナちゃんがしてあげるわぁ♪　愛す \nるあなたのためだから、全然イヤじゃないわぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、くぅぅっ……オマンコが疼いちゃって、もう我慢できないからぁ…… \nこのまま一気に、奥まで挿れていくわねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あふっ、ぐっ、んくぅ～♪　少しずつ、オチンチンがオマンコに挿ってきて \n……あっ、あっ！　んふっ、あひゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うぐっ！　んっ、うくぅぅぅっ……あっ、あっ！　んふっ、あっ……んくっ \n、あっ、イッ、クッ……ぐっ、んふぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁぁぁっ……挿れただけで、軽くイッちゃったわぁ～。すっごく \n気持ちよくて、脚が震えちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「快感の波が全身を駆け巡ってて、身体が痺れちゃってるのぉ……だからもう \n少しだけ、待ってちょうだぁい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ぐっ……はっ、あはぁっ……すぐに、ご奉仕するからっ……ひゃ、んくっ！ \n　ふっ、はっ……あふぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁ、はぁっ……まずは、ゆっくり動いていくわねぇ～……んっ \n、あっ、あっ……あはぁぁぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ひゃぐっ、んふっ、んくぅ！　見てぇ。あなたのぶっといオチンチンが、ダ \nイヤナちゃんのオマンコに、ずっぽり入ってるわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「小刻みに動いているだけなのに、すっごく感じちゃうぅ♪　おっぱいが揺れ \nるだけでも、最高に気持ちいいのぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オマンコ感じすぎて、子宮口が疼いてきちゃうぅ～。ねぇ……あなたも気持 \nちよくなってくれてるぅ？　ダイヤナちゃんのオマンコ、気持ちいい～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うふふっ♪　気持ちいいって言ってもらえると、すっごく嬉しいわぁ♪　お \n礼に、もう少し早く動いてあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンの根本まで腰を落として、いーっぱいパンパンするからぁ……た \nくさん感じて、今よりもっと気持ちよくなってぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はひっ！　んっ、ひゃふっ！　くっ、あっ、んくぅ～！　あっあっ、んぐっ \n、あぐぅ！　はぁ、あぁっ！　ふひゅっ、んひゃぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　これ、すごいのぉ♪　入口から奥のところまで、硬いのがズ \nリズリって擦れまくってるぅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチンが当たるところ、全部気持ちいいって思えてくるのぉ～ \n♪　あふっ、んんっ！　はぁ、あぁぁっ！　んっ、あはぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなにも身体の相性がいいなんてぇ♪　やっぱりあなたは、ダイヤナちゃ \nんの運命の人だわぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ずっとあなたと一緒に居たい……こうして繋がって居たいって、本能が訴え \nてくるぅ～♪　んぐっ、あっ、くふっ！　はっ、んぎゅ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのこと、愛してるって言ってぇ～。一生、あなたのそばに居 \nたいのぉ。離れたくないのぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あはぁぁぁんっ♪　オチンチンがビクビクって動いて、お返事してくれるぅ \n♪　嬉しいっ！　ずっと一緒に居てくれるのねぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ、くふっ！　はひゅぅ！　幸せすぎて、腰が勝手に動いちゃうぅ～♪　 \n今よりもずっと速く、オチンチンズポズポしちゃうのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ひゃ、んっ！　あっ、あっあっ！　うぐっ、んぎゅぅぅっ！　おっ、おふっ \n！　はぁ、あっ！　んっ、んんっ！　んあっ、あひぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなたへの愛が溢れて、止まらないわぁ♪　ダイヤナちゃんの赤ちゃんのお \n部屋、もうずっと開きっぱなしよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「このままオマンコに精液を出されたら、絶対に孕んじゃうっ♪　あなたとの \n子供、妊娠しちゃうぅ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのことが好きなら、このまま出してぇっ！　いっぱい、子宮 \nにザーメンびゅーびゅーしてぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなたの子種が欲しくて、たまらないのぉ～！　あなたの赤ちゃん妊娠した \nいっ！　孕みたくて、子宮が疼いてるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　出してぇ！　奥のところで、グリグリってするからぁ♪　子 \n宮口にキスしながら、精液どぴゅんしてちょうだぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、あぐっ！　あっあっ！　オチンチンがすっごく震えてるぅ！ \n　くるっ！　精子くるぅ！　いっぱい、種付けしてぇ～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっはぁぁぁぁんっ♪　熱いの、どびゅどぴゅ出てるぅ！　ダイヤナちゃん \nの子宮に、精子注がれちゃってるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなに出されたら、絶対に妊娠しちゃうぅ♪　あっ、あっ！　んぐっ、ん \nふっ！　ひゃ、あぐっ、あっくぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダメぇ！　イッちゃうぅ～！　オマンコに射精されながら、ダイヤナちゃん \nもイッちゃうのぉぉぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　あっ！　イクッ！　イクぅぅぅっ！　子宮の奥から、すご \nいの来てるっ！　あひっ、ひぎっ！　おっ、おぉっ！　んほぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「イグッ！　イグぅぅぅんっ！　種付けされながら、イッちゃうぅぅぅ♪　受 \n精しながら、イッちゃうのほぉぉぉ～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ……はふっ、んくぅ♪　ザーメン注がれながら、イッちゃったわぁ～… \n…好きな人との種付けセックスって、本当に素敵よぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でもぉ……この程度じゃ、ダイヤナちゃんは満足できないわぁ。もっとシた \nいって、思ってるんだけどぉ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うふふっ♪　あなたのオチンチンも、まだガチガチに勃起しているわねぇ♪ \n　まだまだ出し足りないって、言っているみたいだわぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ねぇ……このまま抜かずに、続きをしてもいいかしらぁ？　さっきよりも激 \nしく動いて、オチンチンシコシコしてあげるからぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あはぁん♪　精子が尽きるまで、付き合ってくれるのねぇ。それでこそ、ダ \nイヤナちゃんの運命の人だわぁ……それじゃあ、いくわね……んっ、くぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あひゅ、んぐっ！　ほっ、おぉっ！　あっあっ、ひぐっ、んくぅ♪　ひゃ、 \nあぁぁんっ！　あっ、やっ、はひっ！　ひっ、あっ、あふぅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ザーメンのおかげですっごく滑りがよくなってるぅ～♪　これだけ激しく動 \nいているのに、引っかかったりしないのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、あひっ！　くっ、んくぅ～！　カリのところが、ヒダに絡んでくるぅ \n～♪　ズリズリ擦れるたびに、すごく感じちゃうわぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でも、ただ擦るだけだと、物足りないわよねぇ～。あなたも、もっと強い刺 \n激が欲しいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「心配しないで……痛くなんてしないわぁ。今よりもっとオマンコを締め付け \nて、オチンチンをぎゅーってするだけよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ほらっ、こんなふうに……んっ！　うぐぐっ！　んふっ、んんっ！　はっ、 \nあぐぅ！　はぁ、あぁぁっ……ふっ、んっくぅぅぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あひっ、んひぃ！　オマンコをギュってすると、あなたのオチンチンのカタ \nチが、はっきりわかるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「カリ高の極太オチンチンが、ダイヤナちゃんのオマンコに絡みついてきてぇ \n……あぁぁっ！　これ、擦るともっと感じちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「上下にズリズリすると、オマンコのお肉だけじゃなくて、ヒダヒダも伸びた \nり、縮んだりしてっ……ひゃひっ、あっ、くふっ！　あっあっ！　んぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304214" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「それに……こんなふうに、グリグリって腰を回したりすると、亀頭が子宮口 \nをえぐってくるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「開きまくってる赤ちゃんの部屋の入口に、硬いのがトントンって当たってく \nるぅ～！　こんなの、頭がどうにかなっちゃいそうよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「で、でも、止めたくないのぉ！　もっとあなたを感じたいのぉ！　オチンチ \nン、いっぱいズポズポしたいのぉ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　ひぃ、んぐぅ！　おっ、おぉっ！　ほっ、おほぉぉっ！　す \nごいぃ！　こんなの、またイッちゃうぅ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ぐっ、んふぅ！　あっ、んっ、あっ！　オチンチンがビクビクしてるわぁ♪ \n　あなたも、イキそうなのねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だったら、一緒にイッて……あっ、！　ひっ、あぁっ！　イクッ！　イクッ \n！　運命の人のオチンチンで、イックぅぅぅ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっはぁぁぁぁんっ！　またオマンコに、びゅるびゅる精子注がれてるぅ～ \n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304301" ]},
