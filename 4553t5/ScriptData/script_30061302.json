		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「身体にザーメンがかかってるぅ！　あ、熱すぎて、火傷しちゃいそうよぉ！ \n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「でも、こうして身体に精液をかけられるのも、すっごく感じちゃうぅ！　気 \n持ちよくて、幸せな気持ちが溢れてくるのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁぁっ！　もっとかけてぇ！　ダイヤナちゃんの身体、あなたの子 \n種で真っ白に染め上げてぇ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ、あはぁぁっ……オマンコの膣内も、身体も……全部あなた \nのザーメンで、汚されちゃったわぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んふふっ♪　怒ってなんかないわよぉ？　むしろ、ちゃんとご奉仕できたか \nら、嬉しくてたまらないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304406" ]},
