		{"command":[ "SETIMAGE", "0", "still_00000613_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ……すごいわぁ……ダイヤナちゃんの子宮、ザーメンでタプタプ \nしてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あぁっ……受精してる感じがするぅ……すっごく嬉しいわぁ……あなたの赤 \nちゃん、孕めるだなんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あと数か月もしたら、ダイヤナちゃんのお腹が、大きくなるのねぇ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「うふふっ♪　今思ったんだけどぉ～。大きなお腹って、ものすごく目立つわ \nよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000613_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いっぱい目立てるだけじゃなくてぇ～、愛するあなたとの子供まで居ると思 \nうと……あはぁん♪　そんなの、幸せすぎよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_1304309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「スター・クリスタルの力だけだと、この幸せは絶対に手に入らなかったわぁ \n……やっぱりあなたは、ダイヤナちゃんの運命の人ねっ♪」", "NORMAL" ]},
