		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さま、頼んでいたお仕事はどうですか？　そろそろお昼だから休憩しま\nせんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「それで……今日のランチ、一緒にしませんか？　頑張ってくれる隊長さまに\n、私のおごりでごちそうしますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403102" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「よろこんで？　よかった……じゃあまずは私からいただきますね。よいしょ\n……っと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403103" ]},
		{"command":[ "SETCHARA", "0", "char_00003304_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「え、なにをしてるかって……サキュバスのランチって言ったらこれしかない\nでしょう？　ん、立派なチンポ……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「じゃあ失礼して……んっ、ふっ、ふうっ……こうして胸で挟んで、こねて、\nこねて……んふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ほら、隊長さまのチンポ、硬くなってきましたよ……気持ちいいですか？　\nふふ、顔を見ればわかります。んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403106" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「はあ……私の胸の中で、隊長さまのチンポがカチカチになって……んんっ、\nふっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、チンポが食べられたそうにびくびくと震えていますよ……ふ～～～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403108" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんっ、吐息をかけただけでそんな嬉しそうに……胸の中で跳ね回ってる。\nんんっ、匂いも強くなって……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふうっ、んっ、あっ。もう我慢できない……いただきます……あー……むっ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んふうううっ！！　舐めただけでこの精気……やっぱり隊長さまのチンポは\n素敵ですねえ……んっ、おいし……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403111" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんっ、れるっ、れろっ、んっ。ふふ、こうやって舐めて、胸で揉んで、隊\n長さまはどちらがお好みですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ちゅっ、んっ、むっ、こうしてキスするのもありますよ？　え？　どれも気\n持ちいい？　隊長さまは欲張りですねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403113" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ですが、男というのはそういうものですからね。そして、それに答えるのが\n女の甲斐性というものでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「だから……あむっ、ちゅっ、れるっ……んふっ、こうして、隊長さまが喜ぶ\nフルコースをしてさしあげます。んんっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403115" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっんっんっ、はあっ、この味、匂い、たまらない……隊長さまの味が舌に\n広がって……頭の中がいっぱいになって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「れるっ、れろっ、ちゅっ、んっ……隊長さまの顔も素敵……んっ、んくっ、\nはあっ、おいし……仕事の疲れも消えていくようで……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403117" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅっ、んっ。先走りのお汁も濃厚で……ふふ、隊長さま、実は溜\nまっていたんじゃあないですか？　んっ、んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「え、私と一緒に仕事したらムラムラして当然……？　あはは、嬉しいことを\n言ってくれるじゃあないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「だったら私も張り切って隊長さまのチンポにご奉仕しなきゃ……おいしいラ\nンチもいただきたいことですし、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅっ、あむっ、れるっ、んんっ、ふふ、ご奉仕のフルコースはどう\nですか？　この口で、この胸で、隊長さまのチンポを……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんんっ、身体の中に隊長さまの精気が染みこんできます。こんなのを味わ\nわされたら、サキュバスなら一発で堕ちますね……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403122" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「私？　ふふ、隊長さまにこうして奉仕してる時点でもう堕ちてますよ？　こ\nんな熱心にしているんだから、当然じゃあないですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403123" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっ、この熱さも、形も、味も、匂いも、全部愛おしくなって……んんっ、\nれるっ、舐めるたびに隊長さまが私の中に入ってきて……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403124" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、隊長さまだって、私の奉仕でチンポをびくびくさせてるじゃないです\nか。好きなんでしょう、こういうの、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ちゅっ、れるっ、んんっ、んむっ、んっんっんっ、胸の中で熱くて……火傷\nしそうですね。ふふっ、そんな所も愛おしい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ほら、わかりますか？　私の谷間も熱く蕩けてきてるの……隊長さまのチン\nポに柔らかく絡みついているの……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403127" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「じゃあそろそろ本格的に、んむっ、ちゅっ、れろっ、ふううっ、隊長さまの\n精気、私にくださいな、ふううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ほら、こうして裏すじを舐めて……キスして……胸で揉んで……ふふっ、隊\n長さまの気持ちよさそうな顔、素敵……んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんっ、先走りのお汁だけでこんなに濃厚な……んくっ、はっ、あっ、味も\n、のど越しも……んくっ、んんっ、れるっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403130" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「はああ……最高……やみつきになりそうです、隊長さまランチ。んんっ、ん\nっ、れるっ、ちゅっ、ふううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「でも、そろそろメインディッシュを……精液を……ね？　隊長さま、私にご\nちそうして……んっ、むうっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、先端がぴくぴくして、胸の中でも暴れて……あんっ、ふっ、\n隊長さまもそろそろ限界なんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403133" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「いいですよ。イって。イってくださいな。私に、隊長さまの精液、たっぷり\nとごちそうしてください……んんっ、んむっ、んうっ、れるっ、れろっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふううっ、ちゅっ、んんっ、んんんっ！！　んぐっ、んっ、んぐうっ、ふっ\n、あっ、んんんっ、んくっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ぷはっ、はあっ、隊長さまの精液……おいし。濃厚で、量も多くて……ふふ\n、ごちそうさまです。んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「竿に残ったお汁も、んっ……ちゅうっ、ちゅっ、れるっ、んくっ、はあ、お\nいしい……絡みつく味が、たまらない……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403137" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、隊長さまも蕩けそうな顔をして……女冥利に尽きますねえ。私の口と\n胸、気に入ってくれたようでなによりですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんっ、はっ……出したもの全部、私の中に……んくっ、ふうっ……最高の\nランチタイムですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまのチンポ、お汁と唾液でべとべとですね……そんな姿も素敵……ま\nたぴくぴくと動いてる……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403140" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んふふっ、なにをしてるかですって？　おかわりですよ、おかわり。こんな\nおいしいランチ、一回じゃ終われません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまだって、やる気満々じゃないですか。ほら、ちょっと刺激しただけ\nで……あんっ！！　こんなにまた硬くして……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ちゅうっ、んっ、むっ、れろっ、ふふ、これで元通り……隊長さまのおかわ\nり、いただきますね。あー……むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403203" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、じゅぷ、んくっ、んっ。れるっ、ちゅっ、んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ちゅっちゅっちゅっ、んっ、はあっ……口の中でびくびく暴れて……ふふ、\n胸の谷間も竿で押しのけられて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んむっ、れろっ、ふうっ……私の口と胸で、隊長さまのチンポがすっごく主\n張してます……そんなに暴れなくても、私は分かってますよ。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまのチンポが悦んでいるのが……ふふっ、ちゅっ、れるっ、んっ、ん\nむうっ。ああ、この匂い、さっきより濃厚で……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「チンポの味もドロドロになって、さっきとはまた違う味が……んんっ、女を\n飽きさせない、いいチンポですね、隊長さま」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んぐうっ！！　んっ、口の中でさらに大きく……ふふ、私の言葉でやる気が\n出たって……んっ、嬉しいですねえ、あんっ、むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403209" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「じゅるっ、れるっ、れろっ、ちゅっ、んくっ、ふううっ。飲んでも飲んでも\n先走りが漏れて……んんっ、逞しいチンポ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふうっ、んんっ、ちゅっ、れるっ、れろっ。舌を押し返す弾力も、亀頭の大\nきさも……んんっ、女にとって凶器ですね、隊長さまのチンポは……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んむっ、んっ、そんな凶器から、サキュバスを蕩かす甘くて濃い精液を出す\nんですから……ふふ、私以外の女にこんなのを出しちゃいけませんよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403212" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「なぜって……社長命令です。破ったら、もうランチはごちそうしてあげませ\nんからね……でも守ってくれるなら、こうして、んっ、むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅるっ、れろっ、んんっ！！　奉仕してあげますから。ふふ、言\nうこと、聞いてくれますね、隊長さま？　ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403214" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んふうっ、ふふ、そんなに頷かなくても、分かってますよ。じゃあ、あむっ\n、んっ、じゅぷっ、れるっ、ちゅっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んぐっ、うっ、ふうっ、隊長さま、我慢せずに出していいですよ。さっきと\n同じように、濃くておいしい精液、私にごちそうしてくださいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403216" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんっ、ちゅっ、んむうっ、ふっ、あんっ、ふっ、谷間の竿も、もうぱんぱ\nんではちきれそうじゃないですか。ほら、こうしてこねて、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「きゅっきゅって揉みこんで、出てきた先端を……あむっ、んっ、ちゅっ、ん\nんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふっ、出して、出してください。焦らさずに、私にごちそうしてください\n。隊長さまの素敵な精液、味わわせてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んぶうっ、んっ、むっ、ふうっ、ちゅっ。あっ、熱くなって、亀頭の先端が\nひくひくって、隊長さま、出すんですね、私に、いっぱい出すんですねっ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんんんんんっ！！　んぐうっ、んっ、んくっ、んっ、んふううううっ！！\n　ふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああ……おいし……んっ、二回目なのに、量も匂いもたっぷりで……もちろ\nん味も濃くて……ふううっ、隊長さま……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あんっ！！　また残りがぴゅって、もったいない……隊長さまの精液は一滴\nたりとも無駄にはできませんから……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああ、この味、この感覚……サキュバスの食事、やみつきになりそうです…\n…でも、これも隊長さまのだからですよ。んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403304" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「隊長さまじゃなければ、そもそもこんな奉仕なんてしませんからね……ふふ\n、私はこう見えても一途ですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「この喉を通る味と、身体に広がる感覚……今の私の身体は隊長さまの精液で\nできてるのが分かります……んくっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、これを繰り返したら、私は隊長さまなしじゃいられないかも……それ\nほど素敵な精液でしたよ、隊長さま」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403307" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「あら、隊長さま、そんな顔をして。私のことを欲しいって、眼がそう言って\nますよ。ふふ、私は上司の立場なのに、悪い顔……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「でも、男はそういう気概の方が素敵ですよ。そういう人にこそ、私のような\n女はついていきたいって思うものですからねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「でも今日のところはごちそうさまでした、ですね。でも隊長さま……また、\n一緒にランチをしましょうね？　ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ああっ、チンポを抜いたら……ああっ、んっ、ああああっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんっ、口じゃなくて顔にかけるなんて、もったいない……あんっ、ああっ\n、あっ、でも、これはこれで……ふうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「匂いと、熱さが……ふうううっ、鼻から精液を飲んでるみたいで……んっ、\nああっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「んんっ、胸にも……ふうっ、こんな濃厚でドロドロで……これを私は飲んで\nいたんですね。んんっ、あっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふううっ、満足げな顔をして、こんなふうにマーキングしなくても、隊長さ\nまにしか奉仕しませんよ、私は……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403405" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「もう、喋ってるときに精液をぶっかけないでくださいな……んっ、ふっ、顔\nも胸もドロドロで、肌から精液を飲んでるみたいで……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「飲めなかったのは残念ですけど、これはこれで精気が染みこんで……サキュ\nバスってのは便利ですね、ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、口の中じゃ分からなかったけど、こういう風に精液を出してくれてい\nたんですね……いやらしいチンポだこと、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403408" ]},
		{"command":[ "SETIMAGE", "0", "still_00003304_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「ふふ、隊長さま、これからは隊長さまが好きなときに好きな場所でご奉仕し\nてあげますからね……出すところも、口でも胸でも自由ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "七重" ]},
		{"command":[ "SETTEXT", "「だからまた、お昼になったら一緒にランチしましょうね。約束ですよ、私の\n隊長さま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_0403410" ]},
		{"command":[ "WAITINPUT" ]},
