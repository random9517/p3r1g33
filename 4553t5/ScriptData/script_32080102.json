{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おまえ……。あたいをほったらかして、他の女の尻ばっかり追っかけてんじ\nゃない！　さんざん開発しておいて……無責任だろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「まったく……。お前と出会ってからというもの、あたいはペースを崩されっ\nぱなしだ！　いつでもエロいことばっか言ってくるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「罰としてこれからは２４時間３６５日、このリサシュルカ様の下僕として尽\nくすことだな！　って、わっ、うわっ！　な、何をするううう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00020801_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んぎゃあっ！？　な、な、な、なんだこのポーズはぁ！　こんな屈辱的なポ\nーズをさせられたのは初めてだぞ！　お、お、下ろせぇえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020801_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おしっこをする時のポーズぅ……？　しーしースタイルぅ……？　おまえぇ\n……！　あたいのことをなんだと思ってるんだ、赤ちゃんか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「はーなーせぇ！　うううっ……！　んおっ！　意外とがっちり捕まえてくれ\nてんじゃないか……！　み、身動きがとれな……！　おいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「何度教えてもわっかんないヤツだな！　あたいは宇宙海賊団滅棲俄鬼の特攻\n隊長で！　とんでもなくエラくて強くてかっこよくて……。うっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ユサユサすんなっ！　な、なんか恥ずかしいじゃないか！　な、なあ……。\nこんな、お股全開のポーズのままでいるの、い、いやなんだけども！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「……お、おしおき……？　わからせ？　わからせってなんだ？　あたいは何\nだってわかってるぞ。つまりぜんちぜんのーの……って、うわああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あッ……！？　は、ぅ、うあ……っ！？　うぅっ！？　チンポ……？　なん\nでチンポ入れたぁ……！？　あっ……ズップリ、ズップリ奥まで入ってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あ……あたいのおまんこに、おまえのチンポが……っ。ああああっ、な、な\nんってことをしてくれちゃってんだよぉおっ……こ、これっ……これ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「せっくす、ってやつじゃないか！　お、お仕置きと違う、だろっ……！　あ\nっ♪　チンポをおまんこに入れるのはセックスだぞ……！？　あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「お、お、おまえなんかがあたいとセックス出来ると思ってるのか！　……っ\nぅ！　はぁっ……う、動かすな……あたいの身体、ゆ、揺らす、なぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おいっ……！　チンポ、チンポ入ってくる、から……！　奥にどちゅって突\nき刺さる、から……っ！　あっ、くそっ……くそぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいの身体が軽いからってぇっ……！　す、好き勝手しやがって！　あっ\n！？　あうっ！？　や、め……んぁあっ……！　め、めりこむぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ゆっくり……ゆっくり上下するなぁあ……っ。はうっ、あ、あっ……あっ！\n　中で動いてるのがはっきりわかる……っ、うう、す、すごい……ぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「セ、セックスってこんな感じなのか……。あっ！　は、話には聞いたことあ\nるけど、するのははじめてだからなんか、よくわかんな……い、ううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あっうっ……！　おまえのチンポ……ふ、普通よりデカいんじゃないかぁっ\n？　あたいには太すぎるっていうか、ぁっ、キツいっていうかっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「規格外のサイズが出入りしてる感じで、こ、こ、壊れそうでちょっと怖いぞ\n……？　っぁっ……！　あ、あんま奥まで入れんな……！　っんぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ま、待てっ……！　な、なんで腰のスピード速くしてんだよっ！　ま、待て\nって！　速いっ……動き速いっ、ぐっちょぐっちょ中で動いてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あッ……！？　は、初めてだって言ってるだろぉっ！　優しく……やさしく\nしてくれよぉっ！　あっ！　あぁっ！　そんなに激しくされたら、あたいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おまんこがおかしくなってしまうっ……！　あっ、ぁっあっあっ！　強くし\nないでくれっ、やっ……わ、わけわかんない、なのに……なのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「なんっかちょっと気持ちいい……！　うぁああっ、あたいともあろう者がぁ\nっ！　こんな風にモノみたいに扱われて……！　はぁ、はぁ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「どっちゅどっちゅ犯されて、お、オナホみたいにされて感じるなんてありえ\nな……い、うぁ、うぁ、やめろ……やめろ、なんかムズムズするぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おまんこが、ムズムズして……！　えっ？　こ、この感じって……まずい！\n　ちょ、ちょっと止めてくれ、まずい！　このままだと！　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「うっ、ううぅううううう～！！　だめだっ、み、見るな見るなぁあああ……\n！　止まらない、漏れちゃっ……！　うああああああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おしっこ！　あ、あたいおしっこ漏らしちゃって……！　あっ、うぁっ、あ\nああ……！　し、信じらんない、全然おさまんないっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「じょばじょば出ちゃってる……っ！　た、大量におしっこ……！　おしっこ\nぉ……！　あっあっ……！　恥だ、恥すぎるぅうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「っぅうう……！　なんであたいがこんな目にぃいい……！　へ？　感じ過ぎ\nて嬉ションしたんだろって？　う、嬉しいもんかっ……オトナだぞ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいは立派な大人のオンナなのに、しっこちびって嬉しいとかありえない\nだろっ！　……か、感じては……いたかもしんないけど……でもっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「お、おまえのチンポで嬉ションとか一生の恥だぁっ！　も、もういいだろっ\n、充分あたいに恥かかせたんだからわからせは終わりだっ、チンポ抜けぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「……ん！？　なんで中でチンコが硬くなってんだよっ！？　あ、あたいのし\nっこで興奮したぁ！？　ま、マジものの変態じゃんか！　あっ、やめろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「チンポずこずこ突っ込むなぁっ！　あぅっ、い、今っ、あたいのおまんこバ\nカになってるからっ！　しっこして感度上がってるから……だからぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ずぽずぽされたらっ……うぁあっ！　ヘンに、ヘンになるぅ……！　目の前\nが真っ白になって……あっ！　なんっだこれ、イク……イく……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あっ！？　コレがイクってやつなのか！？　あっ、ヤバいっ……イくっ、イ\nクぅっ……！　やめろっ、イカせるなぁっ……あああイクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んきゃううっ！　あうううっ……！　中でっ……中でなんかが爆発してるっ\n……！　うぁっ！　うぁっ、イッてるのに、イッてる最中にぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「これ……精液か？　あっ！　お、おまえ、あたいのおまんこの中に精液射精\nしてるのかっ……！　うぐ、うう、あちゅいぃ……！　熱いぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「な……中に出していいなんて言ってないぞ、許可してないのに……あふっ！\n　い、いっぱい出てる……ドピュドピュって……！　はう、うううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あ。あのなぁ！　無知なおまえは知らないかもしんないけどっ……！　おま\nんこに精子を出したらに、妊娠しちゃうかもしれないんだからなっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「チンポから出る精子で、あ、赤ちゃん……赤ちゃんできちゃうんだぞ！　だ\nからもう出すなぁ……！　あっ！　出すな、止めろ止めろぉおお……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あひぃいいっ……！　う……う、赤ちゃん……赤ちゃんできちゃったじゃな\nいかぁあ……！　ああ……っ。一番奥でいっぱい出てたぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「は、早く精子……外に出さないと双子になっちゃうだろ！　チンポスッキリ\nしたなら抜いて……って、ふぁっ！　なんでまだガチガチなんだぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「しゃ、しゃせー……しゃせーしたらチンコちっちゃくなるんじゃ……？　う\nっ♪　なんか、ミチミチ中が広がって……はぁ、はぁ、はぁはぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「お、おかしい……！　あたいもおまんこが熱くなってきた……。ほ、本気の\n子作りしたから？　赤ちゃんできたからセックス大好きになっちゃったのか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたい……淫乱特攻隊長になっちゃってことか！？　あッ……♪　ま、まず\nいぃ……！　チンポに自分からおまんこ絡みつかせちゃってるぅう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「精液っ……まだチンポにたっぷりついてるのに、なのに……！　抜いて欲し\nくなくなってる、もっかいシてほしいって思っちゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あ……あっあっ、わ、わけわかんないってぇ！　絶対良くない、なのに……\nなのに、うぁっ！　チンポのこと好きになってきたぁああ……♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「う、ぁ……♪　はぁああ♪　んぁあああ♪　あ、あたいが腰を揺らしてる？\n　誘ってる？　ば、ばっか、そんなわけ……ない、あっ♪　あっぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「チンポなんか欲しく、ないし……！　あうっ！　や、やだ……っ♪　突き上\nげてくんなぁっ！　またデキちゃうだろぉお……っ、はうっ、ううう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んん！　ンンっ！？　ひぁあっ！　なん、だ……これ、一番奥ぅう……！　\n奥をごちゅって突かれると……しびれ、るぅう、感じるぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、チンポ……チンポ太くて気持ち、イイ……気持ちいい……っ\n！　この格好、めちゃくちゃ深いとこまで刺さるぅう、ひゅごい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あひっ、あひ……ひぅうっ♪　あたい……あたいは最強、なのに……チンポ\nなんかに負けっ……ああ、だめ、だめだぁ、ダメっ♪　ふぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「滅棲俄鬼の誇りっ……チンポに奪われる、あたいなんかただのよわよわちび\nっこだってっ♪　チンポに教わってしまうっ……わからされるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「う、ぁあああ……！　あああっ！　勝てるわけないだろぉおっ！　こんな極\n悪チンポぉおおっ！　メスガキわからせ棒じゃないかぁああっ！　はうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「一突きっ♪　ごとにっ♪　良い子になっちゃう、良い子にされちゃううぅっ\n！　あぁっ、ああ、言うこと聞かされる、矯正されてしまうぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「はひっ！　はひぃっ♪　あひぃっ、ひィイイッ……！　チンポ強すぎるぅう\nっ！　あっあっあっ！　だめ、……ちゅきっ♪　これちゅきぃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あっくぅっ！　もっと入れてっ、あたいのこともっとめちゃくちゃに突いて\n、突き上げてぇ……！　はぁっううっ♪　こ、こんなの初めてだぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あーっ♪　あーっ♪　イクのクセになるぅうっ！　うぁっあぁっ♪　おまん\nこ、勝手にチンポを締め付けて……離れたくないって言ってゆぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ぐっちゅんぐっちゅんやらしい音、して……！　ふぁああっ、も、もう、わ\nけわかんない……！　好きにしろぉっ！　あっあっ、限界ぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おまえ、のぉ……！　おまえの言うこと聞くからチンポ、チンポずっと入れ\nててぇ……！　あたい良い子にするからぁ……っ！　あぅあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「はひゅぅうっ！　あ、くぅっ……くぅうううっ！　きゅぅうう……っ♪　せ\nーしっ、もう一回せーし、おまんこの中に直撃してゆぅうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あひっ♪　あひぃっ……！　ドクドクッ……ドクドク入ってきてゆっ……♪\n　ママになりゅっ、強制的にママにされちゃってりゅぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おッ♪　おっ、おぉっ、おぉおっ……♪　ど、どんだけ出す気だぁあ……っ\n♪　溢れるっ……逆流すりゅっ、そんなにいっぱい入らないぃいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「チンポっ、ビクビクして……あたいの奥にせーし、せーし流しこんで……あ\nぅっ、あっあっあっ……！　もういいっ、もういい～～っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「三日分くらいせーし、あたいのおまんこに入ったからぁあ……！　も、もう\nゆるひて……っ。悪い事やめる、から生意気言わないからぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「ん、ぷ……。はぁあああ……♪　息をするだけで、精液のニオイがしそうな\nくらいたくさん……出されたぁ……。んんん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「え……？　気持ち良かったぞ？　気持ち良かったけど……精子の量が多すぎ\nておまんこ破裂するかと思ったんだよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいの身体がちっちゃいんだから、次からは遠慮して出すとか……。それ\nはムリなのか？　そ、それなら練習すれば……いつかは……うん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「い、いつとかはわかんないけど……。ってか、あたい……。よく見るとおし\nっこと精子とで下半身がドロッドロなんだけど……ううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おまえ、けっこー大胆なこと……するよな。あたいがこういうヒドいエッチ\nでしかイケなくなったらどーしてくれるんだよぉお……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「イクッ、イッちゃうよぉ！　……んんんっ！？　あれっ？　チ、チンポがぬ\nるんって抜けて……ふぁああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あっ！？　せーしが、せーしがあたいの身体にかかっちゃってるよ！？　い\n、いいのっ……？　中に出さなくて……？　んきゃっ、あつ、熱いよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「んんんん～っ……！　真っ白なヌルヌルがこんなに……あうぅっ……！　な\n、なんか肩透かしっていうか……おあずけっていうか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「納得いかないぃい～！！　い、今からでもちょっとでも中に……って、おい\nぃ！　いつまでかけてるんだっ！　無限にせーし出るタイプか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「お、おしっこでもうびっちゃびちゃなのに……その上精子までかけられたら\n、あたい、あたい……めちゃくちゃ恥ずかしい姿になっちゃうだろぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あ、ああああ……。結局、出したいだけ出したんだな～……！？　スゴい…\n…肌にべったりへばりついてる……どんな粘り気だよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00020801_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「あたいの身体に刻印みたいにくっついて……、あっ♪　このニオイ、この色\n……ねっとり感、一生忘れられそうにないんだけど……どうしてくれるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「……ごくっ……。こんなのが、さっきあたいのおまんこの中に注がれてた…\n…ってことなんだよな。し、信じられないぜ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「おまえのチンポのこと……正直みくびってた……。これからはもっとソンケ\nー……してもいいのかもしれない。だって実際スゴいわけだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リサシュルカ" ]},
		{"command":[ "SETTEXT", "「強いチンポの持ち主であるおまえも……。うう、こ、これ以上は今は言えな\nい。とにかく！　色々わかったから、お仕置きはこれで終わりだぞ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_208_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
