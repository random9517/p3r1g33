{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0122" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「いらっしゃいませ～♪　って、あらあらあら～？　隊長さんではありません\nか。お仕事の帰りにこちらへ？　まぁ～♪　お疲れ様です～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00018203_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ただいま、ハッピーアワーでお酒が大変お安くなっておりますよ～？　あと\nは、季節のパフェ……と、まずはお席に案内いたしますね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……こちらになります。えっと、メニューです、どうぞ。……ふふふ、そう\nなんですよ、最近アルバイト、始めたばかりで～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「でも、隊長さんが通ってくれるなら、働きにきたかいがあったかも……。…\n…あ♪　そうだ♪　ちょうど今、お客さんも少ないですし……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「じゃじゃ～ん……♪　こうして、テーブルの下にもぐりこんで～。ちょっぴ\nりイタズラしちゃいます♪　あ、そのままメニューを見ててくださ～い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018203_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んふふふ……♪　人妻ウェイトレスちゃんの、秘密のご奉仕……♪　これは\nぁ、隊長さんだけに提供する、わたしの特別裏メニュー……ですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ん～～～♪　隊長さぁん……じゃなかった、今はお客様、ですね。お客様ぁ\n？　どうしてこんなにチンポをカチカチにしてるんですか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしがおっぱいで挟んでいるから？　え～？　それだけですかね～？　興\n奮しちゃってるんですよね♪　このコスチュームに……ふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしも人妻です、わかりますよ。見慣れた妻の、新しい一面。周囲の男達\nの目を釘付けにして働く妻を、急に独り占めしたくなる男のサガ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「なぁんて、隊長さんはわたしの夫ではありませんけど。……んっ♪　恋人、\nではあるかもしれませんから。おっぱいで奉仕するのは当然です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ、あぁあ……♪　いつ見ても、隊長さんのチンポ……すごいですね。硬く\nて、反り返っていて……あんっ、胸の中でこんなに熱く太くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「まわりに人がいたってまったく関係ないみたい。わたし……度胸のある男の\nひとってだ～いすきですよ……♪　はぁ、はぁ、裏筋もピンと張ってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしの夫なんかとはくらべものにならないくらい……優秀で獰猛な、若く\nてつよ～いオスチンポですね……。カリだってこんなに高くって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んん、んぅ……♪　胸からだってわかります。伝わってきてますよ、亀頭の\n柔らかさ……それなのにゴリゴリに硬い、ダイヤモンドみたいな肉竿……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「これくらい立派なオチンポだと、わたしもおっぱいを駆使して気持ち良くさ\nせてあげたくなるんですけど～……って、家庭の愚痴はここまでにします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「今は♪　この浮気チンポに集中しますね～……♪　あんっ。本当にステキな\nチンポ……♪　こんなの見せつけられたら……濡れちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……我慢できません。しっかり堪能させてもらいますね……♪　\nん……っ、ん……！　はぁっ……はぁ、ふぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303117" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ。声を漏らすのなら控え目にお願いします。数は少ないですけど……。ん\nっ♪　他のお客様もいらっしゃいますし……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ここはドリンクバーの近く、ですから……んんっ！　あんまりおっぱいに夢\n中になっていると、バレちゃうかもしれませんよ～……なんて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「っやん！？　ど、どうして今の台詞で硬くしちゃうんですか……。隊長さん\nって、もしかして露出趣味があるんじゃ……？　んっ、ん、ん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁ♪　本当に、どんどんチンポが膨らんでくる……♪　見られそうになる\nスリルに感じちゃうなんて、んもう……ヘンタイさんですねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「で、も……。ンッ♪　それはわたしも、ですね。こそこそ隠れて、おっぱい\nを露出して……夫以外のチンポを挟んで喜んで、感じて……。んぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたし、たち……♪　いやらしすぎて笑っちゃいますね～。……んっ、あっ\n♪　Hカップでも押さえきれないオチンポなんて反則ですよう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だけど、そんなに嬉しがってくれて、……やりがいがあります♪　あっ、ぁ\nっ……そ、そうだ。隊長さん？　メニュー、決まりましたか～？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「早く決めないと、みなさん不思議に思って、このテーブルに関心が集まって\nしまう、かも……♪　ほら～。決めてください～♪　はやくです、はやく～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……パイズリが気持ち良すぎてメニューが頭に入ってこない？　あはっ……\n。ですよね、そういう反応してます。先走りのお汁もいっぱい出てますし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「でも、あきらめるのはだめですよ～♪　いっち、に♪　いっち、に♪　がん\nばれがんばれ～♪　わたしのおっぱいも応援してますよ、がんばれぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……んっ♪　もっとお汁が滲んできました。カワイイ反応すぎて……母性本\n能で胸が、おっぱいが疼いちゃいます……。んっ、はぁ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ、ら？　今日はわたしがサービスするだけのつもりだったのに……。っん\nっ、こっちも気持ち良くなってきましたね。あっ♪　ど、どうしよう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「やんっ、あっ……あぁっ♪　んふぅっ♪　あんっ、んん、んぅう～♪　あっ\n……ごめんねぇ、わたしこそ声……おさえないと、……あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303130" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「静かに～……はぁっ♪　はっ……♪　ぁっ……すごくイイ……あんっ♪　本\n気になっておっぱい揺すっちゃう……んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そろそろ精液、出ちゃいそうですか？　え？　いいですよ、オッケーです。\nじゃなくちゃパイズリなんてしませんって～……♪　んふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「若い男の子の新鮮なザーメンミルク、わたしのたぷたぷおっぱいオマンコに\n注いでもらうためにご奉仕♪　してるんです。だから望むところです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「出してください♪　精液……おチンポミルク♪　びゅくびゅくザーメン♪　\n淫乱ウェイトレスにボーナスお願いします♪　あっぁっあっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あんっ♪　あんっ、あぁあんっ……♪　きゃはぁっ……♪　隊長さぁん……\n、いつもながら射精がすごすぎます～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ……！　わたしの胸の中で、どぷんっ、どくんって爆ぜてます。あんっ\n！　こ、こんなの爆発です……精液の破裂です～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁああっ♪　あぁ……んふっ、ふぅう……♪　精液の勢い……全然止まら\nない……♪　えぇ……？　普通この量は出ませんよぉ、多すぎます……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　夫の……ダンナのものじゃないチンポから、ダンナのものじゃな\nい精子がびゅるびゅる流れこんでくる……あああ、ゾクゾクしちゃいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「とてつもない背徳感……♪　んんっ、でも～、これを知ったらもう、他の男\nのなんて挟めませんよね。それが自分の夫でも……。だって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「一番すごい精液が……♪　一番強いチンポが人妻は好きなんですもの……。\nはぁっ、はぁ、あぁ……むせかえるような若い男のイカくさいニオイ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「思いっきり吸い込んで……すぅうう～……♪　うっとりしちゃいます。はぁ\nああ♪　この精子、絶対強いです！　くさければくさいほど、いいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「みっしり赤ちゃんの種が詰まってそうで……わたしのオンナがうずいちゃい\nます。恍惚としちゃいます。胸の中がたっぷたぷになるほどの量」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「少しおっぱいを動かしただけで糸を引く粘り気……。そしてきわめつけが、\nこの色……ちょっぴり黄色味がかった純白のニュルニュルさん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あのぉ……♪　このまま、チンポを胸の中から抜かずにヌチュヌチュぬりゅ\nぬりゅ～っておっぱいでシゴき続けてもいいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303204" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたし……一度だけじゃ物足りません。あなただって同じ気持ちですよね？\n　おチンポだって、こうやって刺激すれば……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ほら、すぐに復活しました。あ～……♪　なんであなたのチンポって、いつ\nもいつもここまで逞しいんですかぁ♪　この、人妻キラーさん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「世の中の奥様がたが恍惚としちゃう、夢のようなチンポですね。今だけは、\nわたしのもの……♪　絶対に離したり、譲ったりなんかしたくありません♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……ん……♪　やさしく、やさしく……。だんだん激しくおっぱいをこねあ\nわせて……っ♪　っあぁ♪　エッチな音がクチュクチュ鳴ってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303208" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「隊長さんはすぐにおっぱいに興奮しちゃうんですね。え？　わたしもチンポ\nにそうなってる？　……言われてみればそうですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はい♪　興奮してます……。　あっ……♪　わたし、いやらしい人妻だから\n……Hカップのトロトロおっぱい、オマンコにして楽しんでます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「っんんん……！　精液が谷間でぬちょぬちょになって気持ちいい……♪　…\n…んっ！？　あっ、ま、待ってください。人が近くに……。ん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303211" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ああ……♪　だめ、見つかっちゃう……♪　見つかっちゃうのに、おっぱい\nを上下するのがやめられない……あっ♪　あっぁっ……やだぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしっ……ものすごく感じてきました……っ。ふぅっ……んっ、ンンッ、\nんん……っ♪　チンポっ……チンポ大好き、おっきいのが好きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしのおっぱいにうんと甘えてほしい……♪　ん～……♪　よちよちよち\n♪　よちよちよち……♪　んぁんんっ♪　急に動いちゃイヤぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「本当に感じちゃうっ……あっ♪　おっぱいだけでイッちゃう！　ッあぁあん\n……っ♪　激しいピストンっ……ついていくだけで精一杯です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んんんっ……♪　こうやってぇ、二人で力を合わせてパイズリ、するのって\n最高に気持ちいいですね……っ♪　あっ、ぁっ、胸がとろけそう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「チンポも溶けちゃいそう、ですか？　あんっ♪　ン～～～っ♪　ごめんなさ\nい、そろそろ終わりにしないと本当に誰か来ちゃいそうです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303217" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ず～っとしていたい、ですけど♪　射精……お願いできますかぁ？　んんぅ\nっ♪　もちろんわたしも一緒にイキますよ……♪　っふぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「もう一度、おっぱいの中にびゅくびゅく精液出しますかぁ？　あンっ♪　そ\nれとも……もっとハジケちゃいますぅ？　っぁ……♪　教えてください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしのどこに一番出したいですか……？　どこでもいいですよ、この硬い\nチンポからほとばしる、真っ白な精液をかけてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっあっ……いいですよ！　腰を突き上げて……わたしのおっぱい\nを孕ませるつもりで……！　ひゃんんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「おっぱいの中、熱いです……！　あああっ♪　マグマが次々に噴き出して…\n…！　ふぁあっ、止められません、溢れ出してくるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふふふ……♪　受け止めきるのが大変なくらい出してくれるなんて……自信\nついちゃいます。まだまだ、わたしも現役なんだなぁ～って……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁ♪　ビクビク跳ねてるっ……！　そんなに良かったんですか？　あっ♪\n　あっ、この、胸の奥にドクドク流しこまれるの……気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしの胸、一番上手に使ってくれるのは隊長さん……♪　んっ♪　もうだ\nめ、溢れちゃう……抑えきれない♪　はぁああ♪　こんな量はじめてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ～ぁ……♪　わたしのダンナさんが、隊長さんだったら良かったのに～…\n…♪　そうしたら毎日、身体をもてあますこともなくって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「毎日毎日、好きな時にえっちしてご奉仕してあげたいな～♪　え？　人妻だ\nからいいんだ……って？　ふふふ♪　それはそうかもしれないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303307" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「この職場で働いていると、たくさんの男の人達のあつ～い視線を浴びて、い\nつも切なくなっちゃうの。めちゃくちゃにされたくなっちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……そういう事情だから、隊長さんにはぜひとも常連さんになってもらって\n～。いつでも通ってきてほしいな。って一応、おねだりしておくね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「うん♪　そう。まだまだ禁断の特別裏メニューはい～っぱいあるから。ウェ\nイトレスさんのわたしを、つまみ食いにきてね。待ってます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「っあぁ♪　んもぉ……っ♪　隊長さん、激しすぎます……！　あっあっ、お\n顔にびゅるびゅるかけられてしまって……んあああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「だ、め……♪　顔にたっぷりホワイトミルクコーティングだなんて……ああ\nあっ、夫にも、他のお客様にも、店長にも……させたことないのにぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「なんてウソですよ……♪　あなたにだったら、隊長さんにだったらどれだけ\nすごいことをされてもいいっ……ふ～っ♪　んんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっついシロップが顔中に降りかかって……あはぁ♪　だらだら垂れてきて\n……この粘り気、トロトロ感……スペシャルパンケーキになったみたい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303404" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あなたの蜂蜜みたいな濃厚精液……♪　あぁあんっ、何重にも顔をパックさ\nれて……タンパク質を摂取し過ぎちゃう……。ん～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そんなに♪　そんなに気持ち良くなってくれたんですね……！　うれしいっ\n、かけて、もっとかけて……びちゃびちゃにしていいから、もっとぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ん、は……あぁあ……♪　ウェイトレスの衣装、汚さないようにお顔にかけ\nてくれたんですよね～……そういう優しいところ、大好きですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふふふ……♪　お化粧もぜーんぶとれちゃって、洗わなきゃいけないのは同\nじだったりして……。いけない人ですね、人妻のメイクをとるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303408" ]},
		{"command":[ "SETIMAGE", "0", "still_00018203_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……わたしも全然逃げなかった？　それはそうですよ♪　浴びたかったんで\nす、これが……。若い男の、隊長さんの活発な精子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「このためにここでバイトして、ず～っと待っていたんですから……。だーい\n満足です♪　また、絶対にご来店くださいねぇ～♪」", "NORMAL" ]},
