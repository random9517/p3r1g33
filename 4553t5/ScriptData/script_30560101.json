{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "056_0103101" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「失礼します。清水紅羽、参りました。どの様な御用でしょうか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103102" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ん？　隊長のパワーアップをする為のお手伝いを……？　それは光栄です。\n是非にやらせて頂きます！　えっと、何からやれば宜しいですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103103" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はい、服を……え？　ええぇ？　……も、申し訳ありません。えっとあの…\n…そうだ！　聞き取れませんでした。もう一度言ってもらえますか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103104" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はい……はい……う、うぇぇ……。あ、その……やっぱり、上着を脱いで胸\nを、出す……。ううぅ、聞き違えじゃなかったのか……そんな……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103105" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あの、ではですね……下着の着用は？　……認め、ない……。そう、ですか\n……。いやいや、あの……違います、決して嫌とかでは、その……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103106" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「嫌じゃ、ないですよ。だって、命令ですから。命令には、良いとか悪いじゃ\nなくて『了解』です。私はそんなお仕事をしているのですから。でも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103107" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「で、ででででもですね、その……ううぅ……は、恥ずかしいよぉ……。胸、\n出すってことは……隊長に、その……見られちゃうんですよ？　はうぅ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103108" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「え？　見たい、のですか？　隊長。……そ、そうですか。い、いやぁ、それ\nは困りましたね。見たい。そうか……見たい……じゃあ仕方ないのかな？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00005601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103109" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「分かりました！　了解です！　その、命令通りに……上着をその、脱ぎまし\nて、ですね……胸を……お、おっぱいを……出します！　出しますよ！」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103110" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「わっ！　隊長何で脱ぐんですか？　……え？　隊長の、そ……それを私の胸\nで……はぁぁ？　聞いてない！　それは聞いてないですよ！　ええぇぇ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103111" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あぁ、そっか……隊長のパワーアップ、ですもんね。私のおっぱい見ただけ\nでどうにかなる訳ないか。……そっか、何かしなきゃですよね。納得です」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103112" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「じゃあ、やらなきゃ……いけないのか。そうですよね、もう脱いじゃったん\nだし。やります。やりますよぉ……。挟むんですよね？　……そ、それっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103113" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「うわわ、隊長のこれ……あわわ、熱い。熱くて……すっごく硬いです。うわ\nぁ。こんな、こんなに……うぅ、なんか大変だ。分かってます、擦りますぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103114" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「えっと、乳房を……交互に上下に……んぅ……あの、隊長、どうですか？　\n私、ちゃんと出来ていますか？　こういうことには不慣れなもので……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103115" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あ、気持ちいいんですか？　そっか。じゃあ、良かったです。……あ。あれ\n？　なんかお汁が出てきた。汗ですか？　おっぱい暑かったですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103116" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「汗じゃ、ない？　はぁ、ではこれは……？　我慢、汁？　隊長、我慢してら\nっしゃるのですか？　すみません、私の奉仕が拙いからこんなお汁が……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103117" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「え？　違うのですか？　……気持ちいいと、出るお汁？　……そう、なんだ\n。私の胸が、気持ちいいとそういうことならば……ちょっと嬉しいかもです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103118" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「うわ、お汁が垂れて……え？　舐めるんですか？　あ、ああぁ、はい！　分\nかりました。んんっと……舐め、る……。よし、れろぉ、じゅるぅぅううぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103119" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁ、すっごい匂いです。お魚みたいに、生臭い。じゅるるぅぅ……れろぉ\n、じゅるるぅうぅ……はぁん。舌触りも、トロっとして……不思議な、味」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103120" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……隊長のオチンポ……さっきより熱くなってきました。……ふぇ\n？　私、オチンポって……ひぃぃ、恥ずかしいですぅ！　忘れて下さい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103121" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「え？　もっと聞かせてって……今のその……これの名称を、ですか？　隊長\n、意地悪です。……命令って、ううぅ、それじゃ仕方ない。分かりました」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103122" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「れろぉ……ちゅぱぁぁ……じゅるじゅるぅぅ……はぁ、隊長のオチンポから\nいっぱいお汁、出てきます。……じゅるるぅ、うぅ……が、我慢汁がぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103123" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「もぉ、舐めるだけじゃ……はぁ、全然追いつかない。れろれろぉ……はぁ。\n……え？　咥える？　これを？　わ、分かりました。やります……はぁむ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103124" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んじゅるぅぅう……れろれろれおぉぉ、んじゅるぅ……ぷはぁ。い、息が…\n…はぁ、ちょっと苦しいですね。んじゅるぅ……じゅるぅ、ちゅぱぁあぁぁ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103125" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「口の中が、隊長のオチンポの熱で……熱いぃ。ぐぽぉぉ……ぐぽぉぉ……は\nぁ、じゅるるるぅぅう……ちゅぅぅちゅぅぅ……はぁん、れろぉぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103126" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「隊長、教えて下さい……はぁん。私、何も分からないので……じゅるるぅぅ\n……隊長の気持ちいいところ、はぁ……パワーアップの為なんですから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103127" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ちゅぅぅう……ふぇ？　あ、歯は、立てないように……？　す、すみません\n。気をつけます！　あくまで優しく、舌でですね？　じゅるるぅぅ、れろぉ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103128" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「じゅるるぅ……ちゅぱちゅぱぁぁ、はぁ……ここ、ですかぁ？　この、括れ\nた部分、はぁぁ……。れろぉ、ちゅぱぁぁ……じゅるるぅぅうぅ……ちゅぷ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103129" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ここを舌の先で、くすぐるように……れろれろれろぉ、ちゅぱぁぁ……はぁ\n。ぐっぽぐっぽ……じゅるるぅぅ……あはぁ、隊長、気持ちいぃですか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103130" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「……じゅるるぅ、れろれろれろぉ、ちゅぱぁあぁぁ……はぁ、はぁ……ちゅ\nぅぅ、じゅるるぅう……ちゅぅううぅ……じゅるるぅぅう、はぁん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103131" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んううぅ、隊長？　どうしました？　んくぅうぅ……あ、あのぉ……オチン\nポがビクビク震えて……私の舌が、変なところ触りましたか？　れろぉぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103132" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んふぅ？　もっと、奥まで？　……はい、咥えます。んくぅううぅうぅ……\nぐっぽぐっぽぐっぽぉぉお……じゅるるぅぅ……んきゅ？　んぐぅうううぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103133" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「んぼおおぉおぉお！　んぐぅうぅう！　んふぅぅう？　んっ、んぐうぅうぅ\n……ゴクッ！　んくぅううぅ……はぁ、んくぅぅうん、コクン、コクン……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103134" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「ぷはぁ！　はぁ、はぁ……な、何が起こって……？　はぁ……え？　あ、今\nの熱くて苦いのが……せ、精液？　あの、我慢汁じゃなくて……？　精液？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103135" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「今のが……精液……？　の、飲んじゃいましたが……大丈夫なのでしょうか\n？　い、いえいえ！　嫌じゃなくて、その……本当に本当にびっくりして」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00005601_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103136" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「あと、ちょっと……残念だなぁとか……。いえその、ですね……私、精液を\nみたことなかったので……どうせなら、もっとじっくり見たかったというか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103137" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「な、何がおかしいんですか！　だって飲んでしまったものですよ？　折角な\nら、ちゃんと見たかったです。隊長が、気持ち良かった証でもあるし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103138" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「宜しければ今度は、精液をちゃんと見せて下さい。……え？　あ、今度って\n……すみません。もしまた隊長が私に奉仕をお求めになるなら、ですが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103139" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「わ、私は……命令でしたら何でも、します。……ふぇ？　命令じゃなったら\n、ですか？　それはそれは……ううぅ、隊長に求められるのなら、まぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "056_0103140" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「命令じゃ、なくても……うん、またやらせて頂きたい、です。……私、隊長\nのお役に立ちたいんです。……そうですね、ただそれだけなのかもしれない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}