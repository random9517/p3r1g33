		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「んんんんーっ！　くぅぅぅんっ……あぁ……また来たわっ……入ってる……\n熱いの……中に流れ込んで来るぅっ……んぁぁぁ……」", "NORMAL" ]},
