		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「こうしてっ……キュウってされるのいいでしょうっ？　弱いトコ……全部分\nかってるんだから……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あふっ……歯を食い縛っちゃって……そこで踏ん張ろうとする所がまたそそ\nるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「でも、もう出ちゃうでしょう……？　私も……またイクわ……このまま、一\n緒にイキましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104219" ]},
