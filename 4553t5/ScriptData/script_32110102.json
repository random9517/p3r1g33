		{"command":[ "SETIMAGE", "0", "still_00021101_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「おふっ……あぁ……ごくごく飲んでるわ……そのまま出し続けてぇ……んっ\n、ミルクいっぱいにしてぇ……あぁ、直飲みはやっぱり最高ねぇ……」", "NORMAL" ]},
