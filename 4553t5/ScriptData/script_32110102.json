		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ふふっ、また中に出してくれるのね？　嬉しいわ……貴方の精液はいつでも\n大歓迎よっ……来てっ……ドピュッと出してぇっ！」", "NORMAL" ]},
