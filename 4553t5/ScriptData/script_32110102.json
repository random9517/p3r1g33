		{"command":[ "PLAYVOICE", "v2_211_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ふぅ……でも、少し疲れたでしょう？　密度の濃いセックスだったもの……\nでも、慣れればそれも病みつきになると思うわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
