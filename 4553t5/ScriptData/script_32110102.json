{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「さあ……素敵な時間が始まるわね、ふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「この間は精液の採取に協力してくれて本当に感謝しているわ。お陰で、かな\nり実りのある研究が出来たし、より貴方に興味が湧いてきたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「今はちょっと力が抜けてしまってるかも知れないけれど、悪いようにはしな\nいから安心して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ふふっ……まぁ、オチンポは期待しているみたいだし……そんな心配は無用\nかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「それじゃ、時間も勿体ないし……始めちゃいましょうか。このまま繋がっち\nゃうわよ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ふっ、あっ、はぁぁぁぁぁぁぁんっ……ほぉら……あっという間に、根元ま\nで……オチンポ咥えこんじゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「んんーっ、しっかり奥に届いてる……んふっ、カリのところが擦れて、んぁ\nっ、Ｇスポットがすごく刺激されるのぉ……あふっ、あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ふふっ、今日はゴムなんて野暮もなし……直接、魔力を頂くわ……はぁっ、\nんふっ、あんっ、んふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……やっぱり、貴方のオチンポいいわ……まだ出す前からビンビンに\n力を感じるもの……これは特別な才能なのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「と言っても、中々自覚は出来ないわよね。んっ……その辺は、後でじっくり\nと証明してあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「だから、今はまず、オマンコを味わってちょうだい……あふっ、どうかしら\n……？　私のオマンコ……ユルユルではないと思うんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あら、よかった。ちゃんとヒダの一つ一つまで意識を巡らせて……オチンポ\nのお世話をさせて頂くわね……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「はんっ、あふっ、あぁっ……ピストンの具合はこれ位でちょうどいい？　ん\nっ、粘膜を……ゆっくり馴染ませていかないとね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「うんっ、んふんっ……ふっ、んくんっ……サイズで言うなら、そこまで極太\nって訳でもないんだけど……ちょうどいいのよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「貴方……これまでに、何度も他の女性を蕩けさせて来たんでしょう？　自分\nのテクニックにも自信があるんじゃないかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ……でも、貴方のは……テクニックよりも……このオチンポそのものが\n特別だって考えた方がいいかも知れないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「硬さも……形も……特筆することはない筈なのに……んっ、オチンポ全体に\n纏わりつく見えない力が……んっ、女を酔わせるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「はっ、あはんっ、んふっ、あふっ……こうして、自然に腰を振らせたくなる\nような……その才能は……大事にするといいわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あんっ！？　あふっ、突き上げたくなっちゃった……？　もちろん歓迎よ…\n…私のオマンコを容赦なく突き回して……あぉっ、おぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「おぉっ……おんっ、その調子よっ……あぁ……汁が溢れて来るわっ……マン\n汁がどんどん涎を垂らしちゃうのっ……んひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ほら……お返しっ、んっ、くいって腰を回してぇ……リズミカルに……キュ\nンって締め付けてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「いち、にっ、さんっ、しっ……やだ、私ったら……こんなにおっぱいを揺ら\nして……はしたないわねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「でも、そうやってギラギラした視線で見られていると……あぁっ、ゾクゾク\nして……腰が止まらなくなっちゃうの……あんっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁっ、そこっ、今の所よっ……続けてっ、亀頭ゴリゴリくっつけてぇっ…\n…あひっ、あぉっ、おぉっ、そ、それっ、それよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「おぉっ、オチンポ凄いっ！　あぁっ、腰が抜けちゃうっ……うひぃっ、き、\n気持ち良すぎるのぉっ、あっ、おぉぉぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あっ、あひぁっ、ダメっ……い、一回イクわっ！　オマンコ良すぎてっ……\n！　さ、先にイクッ！　オマンコイクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、あふっ……ごめんなさい……ちょっと油断しちゃったわ……\n一緒にイキたかったのに……待ちきれなかったみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「でも、ここからは私も本気で行くわ……んっ、ナマチンポ……直接射精させ\nてあげるからっ……あっ、んぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「うんっ、はっ、んふんっ、いいわっ……オチンポゴリゴリ来るっ、オマンコ\nいっぱい感じるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁっ、いいわぁっ、もっとよっ、ズボズボさせてっ……マン汁まみれのオ\nマンコにスケベな音を鳴らさせてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、すごいっ、激しいっ、ぐちゅって音ぉっ、こ、興奮するわ\nぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ふんっ、んぐぅっ……私も、かき回すのっ……ほらほらっ、どうっ、亀頭が\nヒダと絡んで……いいでしょうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぁんっ、イキそうっ？　いいわっ、そのまま続けてっ！　決まっ\nてるわっ……最初の一発はオマンコ中出しよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「中に全部っ……！　貴方の特製チンポザーメンっ！　中に出してっ、、子宮\nに直接飲ませてェッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃぃぃぃっ！　出てるわっ……あぉっ……届いてるっ……極上のチ\nンポミルク……オマンコの中に染み渡るのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、オチンポ震えながら吐き出してるぅ……んくぅ……身体に生\n命力が注ぎ込まれてるのぉ……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ……はふっ、あぁ……まだ出てる……んっ、このとぷんって来る感じが\nいいの……あはぁ……気持ちいいわぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「はふぅ……んっ、あぁ、収まって来たわね……とりあえずの一発目はそろそ\nろかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ふふっ、呆けた顔をするのはまだ早いわよ。なんて……そういう私も、少し\nふわふわした気分だけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「でも、やっぱり素敵だったわ。貴方の生オチンポ……本当に素晴らしいもの\nよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「さ……少しだけ落ち着いたところで、また続きをしましょうか。んふ……ま\nた、ゆっくり腰を回していくわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁ……それにしても、硬さは全く衰えてないわね。それでこそ、私が見込\nんだオチンポだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「これは決して買い被りではないのよ。そうね……貴方の精液の力……実際に\n見てもらうのが早いかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「んふっ、この溢れた精液を……トロッとお腹に掛けてあげると……ほら……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ふふ……見えるかしら……？　この紋様……貴方の精液のおかげで、くっき\nり浮き上がって光っているの分かるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「私が何者か……？　まぁまぁ、細かいことはいいじゃない。別に、貴方の力\nを吸い取って干からびさせるなんてことはしないから安心して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「でも、貰った力で……こうして……んふっ、オマンコの中をもっと気持ちよ\nくさせてあげることは出来るわ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ふふっ、オチンポの根元をキュッと締めて……次は幹の真ん中の方……それ\nから、亀頭を……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ね……オチンポ全体もそうだけど、こうして……それぞれの場所が独立して\n感じるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「ふふ……貴方の精液のお陰で、こうしてオチンポを気持ちよくさせてあげら\nれるの。この相乗効果……ｗｉｎ－ｗｉｎの関係だと思わない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「だから……んんっ、もっといっぱい出してちょうだい……あんっ、あふっ、\nあぉっ、思いっきりオマンコ突き上げてぇ……はっ、あひっ、はひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁっ……いいわぁっ、オチンポ効くぅっ……Ｇスポットが喜んでるのっ、\n一番いいとこ、擦れてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00021101_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「んっ、うんっ、んふんっ……あぁ……紋様が疼くわ……身体が自然に求めち\nゃうのよ……んくぅっ、あぁ……止まらないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
		{"command":[ "SETTEXT", "「あぁ……何度もオマンコめくれてぇっ……じゅぷじゅぷ、いやらしい音が響\nいてぇっ……気持ちが高ぶってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_211_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒ．マジョウ" ]},
