{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「論理的に考えて……こんな場所で、私がさらなる力を手に入れられるとは思\nわないのですが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103101" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "2", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「隊長さんのことですから、どうせ、また倫理的によろしくないことを考えて\nいるのでしょう。はい、経験的にお見通しです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103102" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ですが……まあ、隊長さんの言葉が真実である可能性もありますし、あえて\n流されてみるのも確率的にそれほど悪くないと判断します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……はっ？　く、口で隊長さんの……ご奉仕？　それは……さすがに私の論\n理的かつ魔術的な思考回路でも導き出せない内容でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103104" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「そ、そのような経験ありませんし、知識もありません！　私が普段、好んで\n読む書籍、そんな倫理的に外れたものはありませんし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103105" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……何事も経験……ですか？　うぅっとても場当たり的な言葉に思えるので\nすが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ま、まあ……いいでしょう。トリプル・クラウンの名を、このティアの名を\n魔術界に広めるため。パワーアップは必須です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103107" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……もちろん、やり方はご教授いただけるのですよね？　そ、それなら少し\nは安心できます……では……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103108" ]},
	{"command":[ "SETCHARA", "0", "char_00004101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……ひゃっ、あっ、い、いきなり見せなくてもいいでしょう！　紳士的では\nありませんよ、隊長さん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103109" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「驚きすぎと言われましても、男の人の……見るのは初めてですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……学術的に興味があれば、観察してもいい……ですか？　ま、まあ、そう\nいうことでしたら、せっかくですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「予想していた以上に、グロテスクな見た目です。邪悪な気配を感じる赤黒い\n色合い……表面のゴツゴツとした形……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「それに……スンスン……臭いも奇妙です。海の匂い……栗の花の匂い……そ\nれを不快にしたような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んっ、魔術薬の調合で酷い臭いには慣れていますけど、それでもこんな臭い\nは初めて……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「これを、く、口で咥えるのですか？　そ、それでパワーアップなんて、やっ\nぱり論理的にありえないです……」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……ま、まあ……これも経験なので……ここまできて、逃げたと言われるの\nもシャクです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んくっ、はぁ、大きい……ちゅっ、んちゅっ、口、思い切り開かないと入ら\nない……ぷはぁっ、はぁはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「れろぉ、ちゅっ、ちゅううっ、はぁはぁ、思った以上に、お、大きいですし\n……熱いです……ちゅううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「人の身体に、こんなに熱い場所があるなんて……隊長さんのここ……ちょっ\nと学術的興味が湧いてきました……れろぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、ここ……ではなく、オチンポ……と呼べ？　そ、その……あえて\nはしたない言い回しをさせる意味が論理的にわかりません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103120" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「感情的な理由と言われましても……んちゅっ、ちゅぱっ、ちゅっ、まあ、い\nいです……オチンポ……れろっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁ、私が、オチンポ……そう呼ぶだけで、口の中でビクッと熱く震えます\n。反応がよすぎ……じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅぱっ、ちゅうっ……このまま、咥えて……舐め続ければいいん\nですか？　れろっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……んむっ、んうっ、もう少し深く……ちゅっ、はぁ、私の口の大きさでは\n、こんなに太いオチンポ、これ以上は無理です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「その要求は現実的ではありませんので、我慢してください、ちゅっ、ちゅぱ\nっ、はぁはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「それなら……この先っぽを、キャンディのように舐めてほしい？　んちゅっ\n、はぁ、それなら……じゅるっ、じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「唾液をまぶすように、舌を絡める……んちゅっ、れろぉ、れろぉお……ちゅ\nっ、ちゅうう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「くはぁっ、はぁ、さ、先っぽから、少ししょっぱいお汁……滲んできて……\nんちゅっ、ちゅううっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁ、んちゅっ、これが……魔術的に、力を高める効果があるのですか？　\nちゅぱちゅぱっ、れろぉ……はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……オチンポ汁……？　んはぁ、は、はい……オチンポ汁……凄い臭い……\n不思議な味……じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁむっ、じゅるっ、はぁ、れろぉっ、先っぽを舐めると、どんどんあふれ\nてきて……じゅるるるっ、ちゅううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「え……で、出る？　もうオチンポ汁出ていますけど……ふぇ……はぅっ、あ\nぁっ、口の中で、先っぽが……ふくらんで……ふぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んぐうううっ、んううっ、んむうううううううっ！　はむっ、いきなり、ド\nクドク……お汁……んくううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「喉の奥に当たる……はひっ、はぁ、ひぃふぁああっ、じゅるっ、れろぉぉっ\n、じゅるうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……べっとりと……の、喉に……口にへばりついて、取れない…\n…とても濃い、オチンポ汁……じゅるっ、ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「こ、これが……精液……？　隊長さん、そ、そんなものを私のお口に出すな\nんて……り、倫理的によろしくありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んちゅっ、はぁ、いえ……その……それほど不快……というわけではなく…\n…じゅるっ、はぁ、不思議な気分です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「この臭いと、独特のしょっぱい味……身体の芯まで染み込んでくるみたいで\n……れろぉっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んっ、いつまでも舐めていたくなるような……はぁ、はぁ……ちゅぱっ、ち\nゅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「これがパワーアップの妙薬……本当にそうなのかもと……本能的に思えてき\nました……れろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「それにしても……んちゅっ、はぁ、お口の中で、まだオチンポは硬いままで\nすね……ちゅぱっ、ちゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「う、噂で聞いた話ですと、一度精液を出せば、鎮まるものだと……ち、違う\nのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103202" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……私が可愛いし、一生懸命しゃぶってくれるのが気持ちいいから……はぅ\nっ、くう……恥ずかしいことを言わないでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「もっと……してほしい？　その……せ、精液、一度飲めばパワーアップに十\n分なのでは？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……飲めば飲むほど効果が高まるかも？　うぅ、摂取量に応じて効果が高ま\nるのは、論理的にも正しい推測です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……それに……オチンポ、こんなに張り詰めているのは苦しそうです。……\nこれが私のせいだというのなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「じゅるるっ、はぁ、た、多少、責任を取らなければいけないという気持ちに\n……んちゅっ、じゅるるるっ、ちゅううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁむっ、ちゅぱっ、強く吸うと精液の残りが出てきて……んぷっ、れろっ\n、ちゅううっ、じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103208" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「舌に精液の味……臭い、染み込んで……れろっ、取れなくなってしまいそう\nです。ちゅぱっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んくうっ、じゅるるっ、ちゅうううっ！　はぁ、思い切り吸うと、そのたび\nにオチンポ全体がビクッと震えますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「とても素直な反応で……んちゅっ、はぁ、何だか、やり甲斐を感じてきます\n、ちゅぱっ、ちゅぱっ……んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はむっ、じゅるるっ、れろぉ、お、美味しそうにしゃぶっている……？　そ\nんなことは……あ、ありえません……じゅるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「こんな……グロテスクなオチンポをしゃぶって、美味しそうに喜ぶなんて…\n…れろっ、論理的にありえないはず……なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「れろぉっ、ちゅぱっ、はむっ、自分でも不思議なくらい……思い切り舌を絡\nめて、しゃぶってしまうの止められません……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103214" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「私、どうして、こんな……じゅるるっんくっ、はぁ、お口いっぱいにオチン\nポほおばってぇ……れろっ、じゅるるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ちゅうううっ、はぁ、先からあふれてくるお汁、また濃くなってきてます。\nビクビクも止まらなく……んくっ、なって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「また、せ、精液が出そうなんですか？　さっきみたいに濃くて……べとべと\nの精液……オチンポ汁っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んちゅっ、れろっ、じゅるるるっ、はぁ、んんぅっ、はぁ、喉が、鳴ってし\nまっています……んくっ、じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103218" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「私、精液……ほしくなって……こんなぁ……論理的にっ、あ、ありえないの\nにっ、れろぉっ、ちゅぱっ、ちゅうううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んくっ、はぁはぁ、オチンポのビクビク、激しく……ふぁああっ、で、出る\nのですね、精液、オチンポ汁、また……はむうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103220" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_07" ]},
		{"command":[ "WAITINPUT" ]},


		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ふむぅっ、んくぅっ、んむううううううっ！！　じゅるるっ、ちゅううっ、\nんちゅううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「ぷはぁっ、はぁ、さ、さっきよりぃ……激しく、せぇ、精液、くりゅ……ん\nぐっ、じゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はひっ、はぁ、はひぃ……あぁ、喉の奥まで、べっとり張り付いて……んっ\n、息をするたびに臭いがこみ上げてきますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁはぁ、もう、身体の奥まで、隊長さんの臭いに、オチンポ汁の臭いに染\nめられて……んくっ、じゅるるるっ、ちゅううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んくっ、んくぅ、はぁ、全部、の、飲めと……んちゅっ、はぁ、はひ……こ\nれもパワーアップのため……ですしっ、んちゅうううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……それだけと思えないくらい、嬉しそうに飲んでる……？　あ、\nありえません、論理的に、そんな……れろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「こんな、濃くて、べとべとのお汁……嬉しそうに飲むなんて……じゅるるっ\n、ちゅっ、んちゅううううっ……はぁはぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「私の小さな口いっぱいに、精液、こんなに出して喜ぶ……り、倫理的によろ\nしくないオチンポの汁、好きになるなんて……れろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103308" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ちゅっ……ありえないですけど……でも……んちゅっ、思っ\nたより、ふ、不快な経験ではありませんでした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……また、気が向いたら……んちゅっ、してあげなくもありません。だから\n……ちゅっ、れろぉ……ちゅぅ……はぁむ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「え……口から抜いて……ふぇ……あぁ、先っぽの穴がふくらんで……ふぁあ\nあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「きゃうっ、くうううううっ！　熱い……んふぅっ、あぁ、精液が、か、顔に\nかかって……ひふぁあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「はぅっ、あぁ、こんな……顔中に、隊長さんの精液がいっぱい……はぁ、は\nひいいいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「か、顔中……べとべとに……んっ、ど、どうしてこんな……ひゃうっ、まだ\n出てますっ、はぅっ、あううううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「んぷっ、はぁはぁ……そして……精液塗れの私を見て、どうしてそんなに嬉\nしそうなんですか……論理的に、理解不能です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「うぅ……んふっ、はぁ、臭いが染みついて、もう取れなくなってしまいそう\nです……はふっ、はぁはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00004101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「おまけに、オチンポ……まだ硬いまま……はぁ、こんな……精液で私を汚せ\nば汚すほど、興奮するなんて……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「隊長さんは、やっぱり倫理的によろしくありません……きょ、教育が必要だ\nと思います……はぁはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……まあ……でも……隊長さんの臭いに包まれる感じは……それほど、不愉\n快ではありませんし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_041_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ティア" ]},
		{"command":[ "SETTEXT", "「……パワーアップになるのなら、ま、また……こういうことにお付き合いし\nてもいいかもと……少しだけ、思います。す、少しだけ！」", "NORMAL" ]},
