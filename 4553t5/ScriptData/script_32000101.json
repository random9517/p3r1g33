{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「フフ……。私と密室で二人きりになるなんて……。危機管理が甘すぎるんじ\nゃない？　隊長様」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あなたも私も、一皮むけば本能に支配された男と女……。あっという間に、\n食べられちゃっても知らないわよ。特に、私を信用するなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103102" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「追い詰められたのはどちらかしら？　ドアは１つ、私の後ろよ。……なんて\n、いつもね♪　こういう風に敵を脅して生きてきたんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「隊長様みたいに、味方なのに、二人になりたがる人って初めて。だから対処\n法がわからないわ。寝首をかかれるとは思わなかったの？　……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「『エッチなことがしたすぎて、それどころじゃなかった』？　……ぷっ……\nあはっ、あはははっ！　やーだっ、下半身は嘘をつけないってこと！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103105" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「面白ーい……フフフフ♪　それで？　エッチなことってなあに？　私の身体\nで……どんな妄想をして、どんな欲を抱いたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「『パイズリ』……？　あら、このオッパイ？　おっぱいが好きなのね？　へ\nえー……そういえば、いつもチラチラ横目で見てたっけ。……オッパイ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103107" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「オッパイで、オチンチンを泣かせてほしいってこと？　んふ……♪　嫌じゃ\nないけど。甘えん坊なんだなって可愛く思っただけ。フフ、オッパイねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103108" ]},
		{"command":[ "SETCHARA", "0", "char_00020001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……はい♪　布地が少ない服だから……ずるんって乳首のところ。下ろすだ\nけで準備オーケーよ。……あーらあら、鼻息荒くしてくれて。嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00020001_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「隊長様のオチンチン……。……男性器って初めて見るけど……そうなの。こ\nういう形なの……。んッ……ちゃんと胸に挟めるかしら？　ええっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あっ……！？　あらっ！？　きゅ、急にグンッと長さが伸びたわ。それに…\n…えぇっ？　角度が変わって。先端が上を向いて逃げて……。待って！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「フフ、逃がさないわよ……♪　どうしていきなり形が変わったのかはわから\nないけど……。確かに、こっちの方が格好いいし男らしくていいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「それに硬くて長い方が……。んぅっ……！　胸で思いっきり挟めるし、掴め\nるから……。そのまま大きくしていて。……そう。……そうよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……すごい。ドクンドクンって、血液が巡っているのを感じる……。それに\nとてもあたたかいのね。興奮するとそうなるの？　不思議な肉の棒……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「これをオッパイで包みこんでいるわけだけど……。こんなのでいいの？　柔\nらかいものでフカフカしているだけじゃ、気持ち良くないわよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……オッパイをオチンチンに絡み付けたり、まとわりつけながら弾ませたり\n、摩擦でもっと熱くしたり……。ふむふむ。やりようはいくらでもある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「わかったわ。とにかく、胸を絡ませながら……男性器を刺激して、煽って、\nムニュムニュぐりゅぐりゅイジメちゃえばいいのね。……まかせて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ん……。ふぅっ……♪　ふぅっ、ふぅ……♪　上下左右に揺らして、バウン\nド……♪　あぁんっ♪　赤黒い色が、私の谷間からはみだしてくる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「緊張した肉棒ってこんな生々しい色なのね……♪　ん……♪　それに、血管\nが浮いて……。女体には無いおぞましさ……あぁ、好き……♪　はぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「相手を傲慢に支配し、屈服させるための力強さを感じちゃう……っ。いいわ\n……いいわ、はぁ、はぁ……。ゾクゾクさせてくれるじゃない……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あっ……♪　ぁっ、ぁっ……♪　ん？　『チンポに寄り添ってぐねぐね形が\n変わっておもしろい』？　そーよ？　オッパイって自由自在なの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「たっぷたっぷ動かして、ちょーっと力をこめるだけで……くひゃくひゃのプ\nーニュプニュ……♪　あは、戦いの時にもプルプルしてるじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「私、サイズだけは特別大きいから……っ、はぁ♪　隊長様のオチンチンがど\nんなに大きくなっても受け入れられる自信、あるんだぁ……♪　っあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ムニュ、ムニュ、ムニュ、むにゅぅうう♪　ふにゅ、ふにゅ、ふにゅ、フニ\nュぅうう……♪　……ね？　多少暴れても、フワッと受け止めて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「オチンチンを入れる穴になったり……んんぅ♪　ずにゅぅうってオチンチン\nの上を滑ったり、圧迫したり……やりたい放題でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「私は女、だから、わからないけど……どうなの？　ぁっ……あっ♪　オッパ\nイでオチンチン挟まれて、シゴかれるのって……気持ちいい？　っぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「『極上で天国』……んまぁ♪　嬉しい感想だわ……。オチンチンの反応を見\nても、嘘はついていないみたいだし……。どんどん楽しくなっちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「んふっ……♪　ママのオッパイおいしいでちゅかぁ～？　はぁっ、ンン……\nんん♪　トロフワぷにゅぷにゅオッパイ、独り占めしていいんでちゅよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ほらほらぁ、母性でいーっぱいに満たしてあげる～……♪　ん～？　ママっ\nて年じゃない？　じゃあ、おねえちゃん？　フフ、まさか妹？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「なん、て♪　そこまで自分を過信してないわ……♪　でも、いいのよ。先生\nだろうが上司だろうが部下だろうが、お好きな嘘を想像していいの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「わた、しのオッパイで……はぁっ、ぁっ、あぁ、オチンチン切なくしてくれ\nなきゃいやだもの♪　んっ……『この感触は嘘じゃない』？　あっは♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「そうね、オチンチンも嘘じゃないし……。んっ♪　演技をする余裕もなく、\nハァハァしちゃってるあなたの劣情もホーンモノ……あっ♪　あっ、ぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……あらやだ、パイズリって真実しかない、のね♪　素敵な前戯♪　『俺に\nとっちゃ本番だ』？　うふふっ、そうね本番……っ、大勝負♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「だったら勝敗をつけないと……。ねぇ？　ねぇ？　こうやっ……てぇ♪　オ\nッパイ前後にズリズリ動かして、移動してどんどんこすりつけるか、ら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「できるだけ我慢してね……？　私にイかされちゃわないように♪　『いつま\nでもてば勝ちなんだ』？　そんなこと、考える余裕与えないわよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あな、たが♪　私のオッパイに負けてぴゅーぴゅー元気に射精する♪　まで\n♪　永遠に私のターン……♪　つまり、絶対あなたは負けちゃうの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「んふっ……ふふふふ♪　くやしーい？　悪の四天王……悪い女のプニュプニ\nュオッパイに♪　ハメられて射精するまで搾り取られるの……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「悔しいよねぇ？　……っんんんっ♪　だらしなくっ、育ちすぎただけの悪オ\nッパイに無理やり、大事なところをこすられて、嬲られて♪　はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「無防備な射精見られちゃうんだよ？　辛いよねぇ、苦しいよね……♪　あん\nっ……あなたの動揺を想像すると……滾っちゃう♪　ねえ、ねえ早く♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「早くピューして？　私を悦ばせてよ……♪　私がピューするの見たいって言\nってるんだから……出しなさい！　出すの、ピューするの……ほらぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「んふ……♪　んふふふふっ……ふふふふふ♪　あなた、意外と押しに弱いの\nぉ？　それとも、催眠にでもかけられたかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「私が命じた通りにピューピュー出てるよ……♪　あっ！　胸からはみだすの\nはダメ！　ベッド汚さないで……全部オッパイのお皿に乗っけなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「そう、そう……っ！　精液の放物線が……あっ♪　びちゃっ、びちゃってオ\nッパイの上にかかるように……っ、調節して射精、射精して！　んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……やだ……♪　射精中のオチンチンって愛らしい……♪　健気にピュッピ\nュすることに集中してて……。もう夢中って感じが幼くて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……子宮にズンッときちゃう……。あら……あらそうなの、こうやって精液\n放出して……オマンコを孕ませるのね。この目で見られて良かったわ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「量だとか……はぁあっ……種汁の熱さだとか……♪　乳袋の上でこってり広\nがってく、クセになる臭い……。そうなの、これを膣内に出すのよね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「理屈じゃなく、女を妊娠させるための体液っていうのがわかるわ……。ドロ\nッとしてて、オッパイにへばりついて離れない……フフフ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「これをアソコになんて流しこまれたら、おしまいよ。おしまいだわ……♪　\n受精するまで、外に出ていく気がしない。これが、これが精液……白濁液」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ええ。一度観察したかったの……。ん……、ふぅうう……♪　オッパイをこ\nね、ると……粘り気が肌にくっついて、糸を引いて……ああ、スゴい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「どうしよ、私、精液とオチンチンが好きになってきちゃったわ。あは……♪\n　素敵……ステキ、ドキドキが止まらない……。ん、はぁっ、はぁっ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「見たい、もっと見たい……♪　オチンチンって嘘がつけなくて、本当に気持\nち良くないと精子が飛び出したりしないのよね？　真実、真実の証！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「オチンチンにたっぷり詰まってる真実の証をもっと浴びせて……♪　ぅ、ぁ\n……♪　ヌルヌルになったオッパイで全体全部刺激してあげ、る♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ヌチャッ、ぬちょっ、ぬちょ、ヌッチョッ……♪　あああああ……、私の胸\nの表面、から内側にまで快感がしみこんで……くる、これ、いいわっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「精液パイズリってなかなかよ……♪　ん～～～……♪　熱が入っちゃ、う…\n…♪　私を本気にさせる、なんて……罪なオチンチン……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あっは……ぁ♪　うん、うん……私もイイ、よ……♪　隊長様の臭いに包ま\nれて……湯気がたちそーなポカポカオチンチンいじくりまわせ、て♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「はぁああ……♪　んぁああ♪　疼いてきちゃ、う……感じちゃう♪　オッパ\nイとオチンチン、ヌチュヌチュ絡んでエッチすぎ……♪　ぁっ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ん……？　ぐぐぅってオッパイ、オチンチンに持ち上げられちゃってる……\n♪　だめ♪　その角度……乳首、がこすれ、るからぁ、だめ、だめ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ん、ぁああ気持ちいい……♪　あぁっ、あッ♪　もういやぁ……♪　感じ、\nるの乳首感じすぎるから……だめぇ♪　あん、あん、あっ、ぁっ、ん～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ふふふっ、存在を主張しすぎよ……♪　私のオッパイに、あなたの臭いがこ\nびりついて……あなた専用のオッパイになっちゃった……あぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「どうか……どうかこのまま、あなたのモノになった証をちょうだい♪　んっ\n……ん、あ♪　あぁ、はぁ……もう一度、もう一度出して……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あはっ……♪　アハッ、あははっ……♪　キタわ……来たぁ……♪　ドック\nドク脈打って……健康な精液、胸に注がれちゃうぅ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「なんて量なの……っ、ついさっき、射精したばかりなのに二発目までこの濃\nさ……。さては、あなた……セックスの天才ね……っ、はぁああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「すごい……。本当に、ビチビチって精子が胸で跳ねる音が聞こえてきそう…\n…。生きてるって感じがするわ……。生命の源だものね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「っんんんん……！　オッパイを持っていられなくなるくらい、重くなっちゃ\nったわ……。とんでもない重みよ……。これが強いオスの生精子」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「私が認めた男の精子……っ……♪　で、でも少し……凄すぎる気がするわ。\n普通の男がここまでの威力を出せるとは到底思えない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「フフ、フフフフ……♪　今までいいことなんてまるでなかった人生だったけ\nど……♪　最後の最後で大当たりを引いちゃったみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あなたに出会えて良かったわ。あなたの精液を見ればわかる……。はぁ、は\nぁ……あなたって世界一すごい男よ。間違いないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あぁ……。豊富なタンパク質……。ただ、ぬぐい落とすだけではもったいな\nい……。しっかりオッパイに染み込ませておかなくちゃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ああ、大丈夫よ……。後始末は私にまかせて……。一滴でも多く、胸に精液\nを塗りこみたいから……。この乳房で、胸肉で綺麗にしてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ん、ん、ん、ん……ふぁああ……♪　この臭い、忘れないわ……。私を魅了\nした男の臭い……♪　私を驚かせるなんて、大した人物よ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ああんっ！？　何！？　何っ……！　オチンチン、オッパイから逃げ出しち\nゃったじゃないっ……！　う、ぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あぁああん！？　あぁっ、ああああんっ……！　せ……精液が、精液が顔に\n……！　んぷ……！　な、生温かいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「『証をまだつけてない場所に』……？　あ、あぁ……そうね、胸にはさっき\n出したから……。次は顔に……！　ッ、め、名案だけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あっ……あうぅっ、この量をダポダポ顔にひっかけるなんて……！　精液の\nシャワーじゃない、少しかけるのとは違うでしょうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「ふぁ……あぁああ……！　べっとり……！　……もぉっ……！　高慢な悪い\n四天王に、プライドの高い女にお仕置きでもしたつもり……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「……そうじゃなくて？　『美人だなって思ったらつい』……！？　美、美人\n……あら……。って、ご、誤魔化されないわよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「予想外の射精……。こういうの、顔射っていうんでしょう？　こんなこと、\n他の男がやったら即座にぶっ殺しちゃうけど……どうしてかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00020001_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「あなただと……。許せちゃうし、す、少しだけ……嬉しいかも。そう……。\n私の胸だけじゃなく、顔もあなたのモノになっちゃったのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「フフッ、うふふふっ……♪　せっかくかけたんだから、よーく見ておいたら\n？　私にここまでのことが出来るのはあなただけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナス" ]},
		{"command":[ "SETTEXT", "「特別な人間が出すものってやっぱり違うわね……♪　さすがの私も驚かされ\nっぱなしよ。ふふふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_200_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}