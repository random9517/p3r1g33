{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_03" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んんっ！　お、おいっ！　隊長……なんだよこれ！　下ろせ……！　下ろせ\nって……っ！　あっぶねぇだろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「い、いきなり呼びつけたかと思えばこんなところに宙ぶらりんにしてくれや\nがってぇ……一体なんなんだよっ！　説明してくれよっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「こ、この格好さぁ……股ぁ開きすぎてんだろっ！　それに……！　あああっ\n！　アタシは身動きできねーとゾワゾワする性格なんだってば！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「……こんなことして何が楽しいんだよっ……。何？　『変身ヒロインが拘束\nされている姿には美学がある』ぅ？　バ、バカ言ってんじゃねー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「さんざんアタシをほっぽらかしといて、誘えば宙吊りとか……！　隊長はバ\nカか！　ばか！　ばか！　大馬鹿～！　って、ひゃっ、あっうわっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104105" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「今度は何っ……うう！？　ギャ、ギャグボール……？　ギャグボールってな\nんだ？　は！？　うるさいから、それを噛んで黙ってろ！？　あのなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ってんむぐっ！？　むぐーっ！　ふぁっ！？　ふがっ！　ふぎゃぐぎ！　ぐ\nむっ……ううー！　ううううー！！　んぐっ、ぐぅっ、んむー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「と、取れぇえ……！　こえっ、これ、なんか口ん中気持ち悪……んーっ！　\nんーっ！　んっんー！！　取りぇ……！　取りぇえ～……！！　んぉあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「お、おひっ！　おひ、ろ、ろこ行くんらよっ！　ア、アタヒにギャグボーリ\nュ……！　噛まへて置き去りにひゅるちゅもりかっ、お、おぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「……んんっ……んぐ……。い、行っひまっら……。な、なんなんらよ……も\nう……。ひぇっかく……しぇっかく、きょ、今日は二人になれふぁのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「エ、エロひことひゅるって言ってたかりゃ……。期待ひて、ひょっとムラム\nラひてたのにふぁあ……。……放置とか……。ん、んぅ……くしょぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ぜ、全然……れんれん動けにゃい、ひ……。なんの材質でできれんら、こり\nぇ……！　力を込めてもビクともひないぃ……。んっぐっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「宙吊りのまんま、おあずけときゃ……。た、耐えらんにゃひらろ……。おい\n……おいぃ……！　……っ……ぅ……。う、ぅ……んん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「……はぁーっ……。はぁーっ、はぁー……。っふぅ、ふぅ、ふぅ……。ご、\n拷問みらいら……。隊長……も、戻ってきれくれよぉ……ちくひょぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「……ふーっ……ふー……ふー……。た、たいひょぉ……隊長、ろこ……？　\nっふぅーっ……フーッ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「変身、解けちゃうっれ……。っ……ぅ……なぁ……。もろってきてくれよぉ\n……。フーッ、フーッ……。……ん！？　ぁ、た、たいひょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「やっともろってきら！　こ、これ、こりぇ、外ひてくれよぉ……！　あぐっ\n……なんか、よられ……。よだれ止まんないひ……んぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「はぁっ、や、やっとまともに喋れる……！　く、苦しかったぁあ～！　よ、\n良かった、ギャグボール外してくれて……って、あっ、ぁっ、やっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ア、アソコに触るなぁ！　い、今ちょっと濡れてて……！　あっ！　胸っ…\n…ち、乳首も！　あッ♪　敏感で……んぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「だ、だってしょうがないだろ！　エロいことするって思って来たんだし！　\nヘンにほっとかれて、なんかあったまっちゃって……。んっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ちゃ、ちゃんとおねだり出来たらセックスのご褒美ぃ……？　お、おねだり\nってなんだよ。アタシ、そういうのよくわかんないんだよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「うん。うん……。隊長が言うことを繰り返せばいいのか？　わ、わかった…\n…。『サバサバ系のフリしてド淫乱肉奴隷ヒロインのブリキ１は……』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「う、うう……。『隊長様の太くて、硬くて、赤黒くて……ギ、ギンギンにそ\nそり勃ったとってもおいしそうなオチンポが欲しくて我慢で、きません』」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「『は、早くクチュクチュいってるメスヒロインおまんこに、立派なオチンポ\nを入れて欲しいです』……う、ううう……とんでもねーこと言わせるなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「で、でも言っただろ！　だ、だから……い、入れてくれよ。本当に、ほ、欲\nしくて……だから……。なあ！　チンポくれよぉ……っ、ぐすっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「っぁっ……！　い、入れてくれんのか！　そ、そこっ！　そこの穴っ……あ\nあっ、も、もう準備出来てるから、ヌルヌルしてるとこ、に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んああああああああっ♪　チンポ♪　チンポぉおおお♪♪　ん、おっ♪　あ\nっ、あぁああ……！　気持ち、いい……気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あっ！　こっちから動きたいのに……、うまく動けない……ぃっ！　なあ、\nなあ……動いてくれよ……。中、かきまわして……あっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あうっ！　そ、そぉ……それぇ……！　突き上げて、……中、ずりゅって♪\n　ずりゅっずりゅって貫いて……ぇ、っ……んぐぅううう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　がっちり奥まで食い込んでくる……♪　隊長ぉ……やっぱ\n隊長のチンポってすげぇ……。目の前、星がチカチカ、するぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁあ……！　おい、し……おいしいよぉ……！　なあっ、これ…\n…なんとか腰だけは動かせそう……あっ♪　んぁっ、あぁ、キた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「チンポ、とマンコぶつかってるっ……んぁああっ、隊長……隊長、隊長……\n！　アタシの腰掴んで、ガンガン突いて、突いて、突いてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「っんんんん！！　ンンンンーッ！　んんんんーっ……！　あっ、んぐぅっ、\nあぐっ♪　んぐぅうっ！　あっ！　あっあっ、動かれるとたまんねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「アタシの中のメスが喜んでる……んぁああっ、このカラダ、葉金のカラダで\nもあるのにぃ……！　自分の快感のことしか考えられ、ねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んぁっ！　出し入れっ、出し入れ好き……！　ヌッポヌッポやらしい音がし\nて……ああっ！　イキそ……すぐイキそぉ……隊長、ごめんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「イ……く！　んぁああああっ！　あーっ！　あっあっあーーーーーー！　ん\nはぁあっ♪　チンポ心地よすぎて……一往復するたびに、イ、イくぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んっ、んんんーっ！　んぁああっ！　んんーっ！　んあぁああっ！　なぁ…\n…なぁっ！　た、隊長も気持ちいいか……？　あっ、あ、ッンンっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「アタシの中でうんと気持ち良くなってくれ……そんで、そんで……！　生で\nそのまんまっ！　精液注いで欲しい……マンコに注入してほしいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あっんんんっ！　んぐっ、んんんっ！　おマンコの奥……きゅうきゅう締ま\nってる……！　あっ、チンポ気持ちくて……鳴いてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ぐっちょぐっちょぐっちょぐっちょって……！　っああああ、アタシ、また\nイキそ……イキそう、隊長も、隊長も一緒に……ぃ、っんぁああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んぅううううう～～～～～♪♪　くふぅううう……うう♪　最高……♪　イ\nッた瞬間、中に出されると……しみるぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「びゅるるるるっ、びゅるるるって出て、る……！　あひっ、ひぁっ、あぁ！\n　ビューッ、ビューッて中に出てる！　こんなの絶対マズいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「正義……と平和を守るための変身ヒロイン、なのに……アタシ♪　変身した\nまま……セックスして、中出しキめられてる……っ、んんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「一番奥……っ、奥にビチャビチャかかって、それが熱くて……むちゃくちゃ\n気持ちいい……っ、あぁ……ダメなのに、ダメだと思うとさぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「マンコ、ぎゅーーって締まっちゃって♪　チンポを喜ばせようとしちゃうん\nだよ！　射精の予感だけで、うねって……掴んで離さないぞって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「そんで、中に出されると……！　気持ち良すぎて失神しそーなくらい良くて\n……！　快感で頭ブッ飛んじゃって……やめらんなくなる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ねー！　隊長、このまま抜かずの二発目しようよぉ♪　アタシなんでもする\nから……！　抜かないで、このままマンコでグチュグチュしてほしい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「……ん？　ぁ、ギャ、ギャグボール……？　マ、マジ？　それっ、つけたら\n息がしにくくて、喘ぐとか無理なんだけど……！　んぐぅううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　んむぅうう！　そ、そりゃなんれもひていいって言ったばっか\nらけどひゃぁ……！　こんなのちゅけてたら、ヘ、ヘンタイＨひゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ヘンタイのＨはヤだぁ……っ！　んっ！？　あぁっ！？　アッ！？　あぁっ\n！？　ガチ！？　ガチれ、これ、口にハメらまま……すんのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んんんーっ！　んんんんー！！　ヤ、だ……ヤ、らぁ……ヤらぁあああ……\n！　んぁああっ！　れも、れもなんか気持ちぃ……何？　なにぃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「息、できらいのにぃ……！　苦ひいのに、マンコ、ズコズコずぽずぽされり\nゅと、あっ！　あっ、なんかヘン、ヘン、気持ちい、気持ちいいよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「酸欠、なりひょうなのにぃ……あぅっ！　オマンコめちゃくちゃ締まってく\nぅ……！　あっ！　あっ！　どうひよ、どうしよ、気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ヘンタイエッチきもひいいぃ……！！　んっんぶっ……んんぅ……んんん…\n…！　ん、ぁ……ああっ……んぶぁ……ああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「隊長にされるがままぁ……！　て、抵抗もれきずに犯され、てぇ……気持ひ\nいいなんれ、アタシ……あたひ……オマンコおかひくなっりゃった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ぐひゅ、ぐひゅってオチンポ出し入れされれるろころ……ぉ！　電流、流さ\nれてるみらいにビリビリひて、ジンジン痺れれぇ……！　んぃいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あひっ……あひ、ひぃいいっ……んぎぃぃいっ！　まら……まらイッひゃう\n……！　イッひゃうぅ……イッひゃ……！　んー！！　んーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あうううっ！？　うぁううううっ！！　あんっ！　あんっ、あんっ！　中れ\n、中れぇ、隊長のがおっきく、なっれ……んあっ！　あああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「だ、出ひゅのかぁ……！　アタシのこと、捕まえて、ギャグボールはめて…\n…んむぅうっ、一方的に犯ひて、だ、出ふのかぁっ……んぐぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「い……いいろっ、いいからぁ！　出ひて……出ひ、て！　同時にイキらいぃ\nい……！　出ひ、てぇええ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んんんんぐぅうううう！　んむぅううう～～～～！　む～～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んぶぅうっ！　中ぁああ……中にまら出てりゅぅううう……熱い、熱いぃ…\n…！　んひぃいいいっ……んいいいいいッ……♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「マンコの奥れっ……！　ビチビチ跳ねてぅ……！　あっ……ううっ、うぅ…\n…！　いっぱいぃ、いっぱひ注がれて……ぇ、んううううーっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あっ、あっは……♪　ひゅご……ひゅご……あっ♪　逆流、すりゅ……んぁ\nあああ……♪　溢れちゃ……あっ、あああああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「こ、こりゃ……あんま見るにゃ……あっ！　今っ……アソコ！　マンコ、イ\nッたばっかで緩んで……精液まみれらから……見るらぁああ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「……ンッ♪　んっ……んんっ……♪　ハハ……。スッキリひた顔してるや…\n…。あたひも？　あっ……そ、それは言うなっれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「うん……。あたひも、腹ん中に全力れ精子注いでもらっらから……満足らよ\n。ただ……このまま宙づりのまんまらと……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「チンポ抜いたら、一気にせーひ……。せ、精液溢れてこぼれりゅだろっれ…\n…。だからひゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「このまま、ちゅ、ちゅながって……。隊長と繋がってたい……。……う、う\nるせぇ、そんな何度も言わねぇよ。ん？　モゴモゴで聞こえない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「う、うるへぇ、うるへぇうるへぇ！　まだこのままッ！　くっついれたいっ\nて言ったんらよ！！　……き、聞こえたか！？　ヘンタイっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「んぶっ……もがっ、もがもがっ！　そ、外……に出すらんれっ……！　ひで\nぇ……っ！　アソコ、待ちわびてらのにぃ～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あぷっ……んぷっ、んんんんーっ……！　精液ぃ……ひゅっごく飛んで……\n！　あっ！　アタシの顔、に身体に……かかってく……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「あっあぁっ……あああ……！　あっらかい……っ。あったかくて……、んん\nんっ……ドロって、肌の上流れおちてく……ぅ……。ふむぐっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ヤッバイくりゃい……ニオイきっつくて……。もがっ。口の中にも、せーし\n……せーえきの……。チンポの汁の味がしほぉ……。けほっ、けほっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「通り雨みらいに、びひゃっ、びひゃってぶっかけられて……。ワケわかんな\nいけろ、あたひ……すっげ、ドキドキひて……。う、うぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00011601_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「な、なぁ……！　この格好のままらと、ずっと汁まみれれ……！　体中に精\n子がこびりふいちまうだろ……。じ、自由にひてくれよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「ふへっ！？　『ザーメンをぶっかけられて身動きできない姿がエロいからし\nばらく見てゆ』ぅ……！？　お、おいっ、おいおいおひ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「それりゃ、たいひょーの気の済むまれ、アタシ……汁だく、汁まみれで放置\nされっぱなしってわけかよぉ……！　それは、んむ、困る、こまりゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「は、はやくはなへええええええ～～～！　てゆうかっ、まず、くひのギャグ\nボールをとれってぇ！　さっきからひゅっごく間抜けな声だろがぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ１" ]},
		{"command":[ "SETTEXT", "「下ろふぇーーー！　ボール、はずふぇ～～～～～！！　フ、フツーのエロ行\n為なら喜んれ手伝うひ参加ひゅるから、アブノーマルはやめれえええ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_116_0104410" ]},
