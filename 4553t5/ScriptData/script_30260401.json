		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「興奮する……パ、パイズリのための衣装……？　そ、そんな……私はそんな\nつもりで着ているわけでは……あぁ、んっ、でも……」", "NORMAL" ]},
