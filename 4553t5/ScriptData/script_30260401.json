		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「若者でも……しない格好……あぁ……男を誘う……ち、違います……そんな\nつもりは……あぁ、でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「わ、分かりましたわ……貴方をそうさせた責任は取らなくてはなりません…\n…私の、オ、オッパイでご奉仕させて頂きます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁっ、もうこんなに大きくさせて……そんなにムラムラさせてしまったの\nですか……？　熱い……それにはち切れそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「確かに……苦しかったでしょう……ん、ふっ……こうして……包み込んであ\nげますね……はぁ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁ……熱くて……ビクビク震えています……はふっ、なんて立派な……あ\nぁ、谷間に収まりきらないくらい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「それでは、んっ、ふっ……動かしますね……んっ、んんっ……あっ、んっ、\nふっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「いかがですか……？　あぁ……オ、オチンポが中で暴れてる……ご、ごめん\nなさい……もう少しだけ落ち着いて……ちゃんと挟めませんから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「よい、しょ……んんっ、あぁ……お肌がピリピリします……んっ、ずっと敏\n感になってて……オチンポと擦れる度に……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「熱いのが伝わって……はぁんっ、あぁ……私も、あっ……ドキドキします…\n…んっ、ふっ……え……先端……亀頭を……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「は、はい……んっ、れろ、ぴちゃ……んっ、れる……ちゅぱっ、こう……れ\nひょうか……？　んっ、ちゅ……んちゅっ……」", "NORMAL" ]},
