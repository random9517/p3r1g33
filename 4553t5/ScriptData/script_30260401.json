		{"command":[ "SETIMAGE", "0", "still_00002604_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁ……この複雑なオチンポの味……れろ、んっ、舌に残るえぐ味が……れ\nろっ、きついのに……れる、んりゅ……れろ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「少しカスがついています……いけませんよ……ちゃんと清潔にしておかない\nと……増して、ご奉仕をお願いしようとしているのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「仕方ない人です……れろ、んりゅ……ちゃんと綺麗にしてあげますから……\nちゅっ、んちゅぷっ、ぴちゃ、んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷっ……あっ、な、何を……んっ、わ、私にも……？　別に\n、そんな必要は……あっ、ち、乳首は……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_026_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「あぁ、駄目です……ニプレスは剥がしてはいけませんよ……ご奉仕、やめて\nしまいますからね？」", "NORMAL" ]},
