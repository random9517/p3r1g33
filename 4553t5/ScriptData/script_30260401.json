		{"command":[ "SETIMAGE", "0", "still_00002604_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "道子" ]},
		{"command":[ "SETTEXT", "「んっ、このままでなら……？　そ、それは……まぁ……あっ、あぁっ、だか\nらって……あっ、そんな摘まむなんて……あ、ひっ！」", "NORMAL" ]},
