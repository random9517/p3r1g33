		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「しかし、当然そんな想像では満足できない……。本物の、あなたのオチンポ\nがほしくてたまらない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904104" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だから……ここに……。あなたが欲しくて、いやらしいよだれにまみれてい\nるオマンコに……オチンポを入れてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　きっ、きた……あっ、ああ……っ！　オチンポ……一気に……\nっ！　奥、までぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。そうだ……イッた……。あなたの、一突きで……私のオ\nマンコは……イッてしまったようだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……。こんなに簡単にイかされてしまうような、メスに開発されてしま\nったようだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「このオマンコはもう、あなたのオチンポでなければ満足することができない\nだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私は、あなた専用のメスにされてしまったようだ……。ンッ、だからこうし\nて……オマンコが、うねって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「中に入っている、あなたのオチンポに……媚びるように、ヒダを吸いつかせ\nてしまう……んふぅ……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　腰……動いて……っ！　あぁっ、あはぁっ、ピストン……い\nいっ、さっそく激しく……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「気持ちいいか？　私の……オマンコ……んっ、くぅうっ！　たっぷりの愛液\nにまみれた……いやらしい、メス穴ぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうだな……。こんなに、オチンポが奥まで届くように、腰を振ってく\nれているということは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたも……私のオマンコで気持ちよくなってくれているということか……\n。んっ、ああ……そう思うと、身体が、ますます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あなたへの……想いが……！　はぁっ、はぁ……っ！　か、身体から\n……溢れてきて……ンッ、おさえられない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ、気持ちいいぃっ！　あなたのオチンポ、あなたの腰遣い……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私の、いやらしい穴を、たくましいオチンポが蹂躙して……！　んっ、ああ\nっ、ゴリゴリ、こすれて……あはぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「その刺激が……強すぎるぅ……！　気持ちよすぎて、ああっ、一突きされる\nたびに、頭が真っ白になりそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、オマンコも悦んでいるぅ……！　奥から、愛液を垂れ流し\nているぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたのオチンポが、私のいやらしい汁でびちょびちょだな……。んっ、あ\nあ……これも、私があなたのモノになっているからだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「全身が……あなたのことを愛してやまない……。ああ、お願いだ……こんな\n私と……ずっと、一緒にいてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私と……添い遂げてくれないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、それは本当か？　一生側に居てやると、確かに……！　私の、聞き間違\nいではないよな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、ありがとう……！　こんなに嬉しいことはない。んっ、私も、あな\nたのことが好きだ……大好きだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、好きだ……好き……ンッ、大好き……ぃ……っ！　んぁっ、あはぁあ\nっ！　だっ、大好きっ、ンッ、好きぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んくっ、嬉しすぎて、ちょっとイッてしまいそうだった……。んぁっ、ああ\nっ、油断したら……すぐにでもイッてしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だが……次にイクなら、あなたと一緒だ……。大好きなあなたと、一緒にイ\nキたいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、イクの……我慢しながら……。んぁあっ、オチンポを、しっか\nり気持ちよくするからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、あなたの腰遣い……がぁ……っ！　激しくなって……お、\nオマンコ……めちゃくちゃにぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁっ、はぁっ、ああっ！　汁だくのオマンコ、いっぱい……ああぁっ！\n突きまくって、ンッ、オマンコ全部、気持ちいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポが当たるところっ、全部、気持ちいい……っ！　ああっ、ああっ、\nよすぎて……我慢しているのに……！」", "NORMAL" ]},
