		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁっ、ああぁぁ～～～～っ！！　でてっ、でてる……っ！　オチンポから\n、精液……んぁっ、熱いのが、いっぱいぃいいぃぃ～～～～っ！！」", "NORMAL" ]},
