		{"command":[ "SETIMAGE", "0", "still_00000129_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「腰を振って、オマンコ締めて……あっ、大好きなあなたにも、気持ちよくイ\nッてもらいたいのに……！」", "NORMAL" ]},
