		{"command":[ "SETIMAGE", "0", "still_00000129_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まだまだぶっといオチンポが、こすれるっ！　ああっ、イッたばかりのオマ\nンコ、ぐちゃぐちゃになるほど……くひぃいいっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、あなたのオチンポで、私ばかり気持ちよくなってしまう……。あなた\nのオチンポに開発しつくされたメス穴だから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「簡単にトロトロになってしまう……いやらしい汁を、絶えず垂れ流してしま\nう……んっ、はぁっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904205" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……ヒダをうねらせて、オチンポをぎゅっと締めつけて……。精\n一杯のオマンコ奉仕で、いっぱい気持ちよくなってくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、ピストン激しい……っ！　んひぃいっ、オマンコかきわけ\nて、オチンポくるっ、んぁっ、きて……るぅ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁっ、はぁっ、そう……そうだ……。このオマンコは、あなたの虜……\nあなた専用の、淫乱完堕ちマンコぉ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2904208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000129_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｃ・Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたに、いっぱい犯してもらうためのメス穴にぃ……。私は……なりたか\nったんだ……！」", "NORMAL" ]},
