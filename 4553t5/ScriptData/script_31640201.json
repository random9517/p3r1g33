		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ほら……見えるでしょ？　イルルのおまんこ……もう、くちゅくちゅーって\n……えっちぃ音、しちゃってるのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あのね、えっとね、ここのとこをね……おとーさんの、べろでね……ぺろぺ\nろーってなめてほしいの、ね、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ほら……もう、おかお……こんな近くでしょ……？　イルルのおまんこ……\nよーく見えるよね？　ね、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「してくれなきゃ……このままだもん……おとーさんのこと、はなさないから\n……いーよね、おとーさん……だめ？　イルル……わがまま？」", "NORMAL" ]},
