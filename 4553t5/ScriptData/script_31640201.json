		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルね、ずーっとおまたのとこ、ムズムズしてて……いっぱいがまんして\nたんだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ね、ね、イルル……知ってるの。こーいう時、おとーさんにしてほしーなー\nって思ってたことあるの……ね、ね、おとーさん、わかる？」", "NORMAL" ]},
