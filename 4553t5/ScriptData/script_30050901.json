{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチを呼び出し……とは、随分偉くなったものですね。多忙なウチに何用で\nすか？　くだらない用件なら帰らせて欲しいのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903101" ]},
	{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……パワーアップのための儀式？　フン。誰を見て物を言っているのです。\nそれはウチではない、弱者にほどこしてやるべき恩情でしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「『ウチに足りないのは、人を信じ、仲間に委ねる心』？　……ククッ、能無\nしが言いそうなことです。ウチは誰も信じません。無論、あなたのことも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903103" ]},
	{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「『それでは二流にしかなれない』？　ぐっ……。い、いいでしょう……。そ\nこまで言うのなら教えてもらいましょうか、パワーアップの方法とやらを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903104" ]},
	{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……ん？　何をモゾモゾしているのですか。って……わっ！　どうしてズボ\nンを脱いで……あっ！　わ、わかりました！　あなたウチを騙して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903105" ]},
	{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「って、ひぃいいいいっ！　……な、なんですっ、このヤる気満々なオス勃起\nはっ！？　……これを舐める、口で愛撫するのがこちらの世界流……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000509_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「そ、そんな、まさかです。陰部、陰部を口で愛でること……？　さすがにウ\nチもそれが嘘だということくらいは……って、ひぃん！　近づけるなです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「やだあ……なんかピトピトしているのです……。それに……んっ、蒸れた臭\nいが……。ぅ……グ、グロい……。あ、の……ウチ、超絶賢いので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「これがパワーアップの儀式だとは思っていないのですが……。もしかして、\n……これをどうにかしてほしくて呼んだ、のですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ウチのことが好きだから、く、口で、慰めてほしくて……こんなにしている\nのであれば……。嫌ですが、嫌ですが……少しくらいなら、いいですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ごくっ……。なんてデカさです……。ウチの腕くらいある……。それに、何\nかブランブランしてる袋が垂れ下がってて……ヘ、ヘン、です……。でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「なぜか目が離せなくて……。はぁ、はぁ……、なんだか、顔が熱く……。こ\nれを……ウチが口で……。っ……く、口……唇とか……。……ちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぁあっ！？　なんかビクビクって上下に揺れてっ……！　へっ！？　舌で\n止めろ！？　どうやってですかっ……えっと、ええと……えい、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「れろ……れろっ、れろっ……んぅっ……。なんかしょっぱい……ッ、それに\n、か、硬くて……舌が弾き返されるです……。なんと珍妙な……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「へ？　前後左右に舐めまくる……この棒みたいな部分を、ぜ、全部？　この\nプニプニした先端も……臭すぎる股間の根元も全部！？　はぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……こ、怖い顔しないでください。します！　するですから……うう……。\nなんでウチがこんなこと……。ぴちゃ……ぴちゃ、ぴちゃ、ぴちゃ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「こんなの……はぁっ、させて何が楽しいんですか……。れろっ……。ぺろっ\n、ぴちゃっ、ぴちゃ、ぴちゃ、くちゅ、ぴちゃっ……ちゅっ、ちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「『チンポ美味しいか』……ですか？　お、美味しいわけないじゃないですか\n……。汗の味です……、『もっと舐めまわせ』？　注文が多い……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「『ソフトクリームを舐め回すみたいに』……はぁ……そういう方向ですか…\n…。舌を……ぇう……大きく伸ばして……んれろぉっ、れろっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「れろぉ……れろぉおお……んむっ、ここ、味が濃い……。ぴちゃっ、れろっ\n、れろっ、れる……っ。んっ、ぁ……唾が垂れて……ぴちゃっ、ぢゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「舌が取れそうなくらいデカいチンポれふ……。こ、これは本来……性行為に\n使うものです、よね……？　絶対無理なんれふけど……れろっ、れろ、れろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んんん……一度に舐めきれないくらいのサイズ、なのれふよ……れろっ、表\nをベロベロした後で裏を……れろっ、れろ、こうして舐めないといけなくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「こんなものを女子のアソコに突き立てるだなんて、殺人行為れふ……。信じ\nられまふぇん……。あなたのが特別大きいらけなのれす？　ぺろ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……ぴちゃっ、ぴちゃっ、ぴちゃ……。あぁ……。ウチの唾でヌル\nヌルになったオチンポ……テラテラ輝いていて卑猥すぎです……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「根元まで舐めろとか……。ご主人ひゃま気取りで羨ましいですね……って、\nんんんっ、やっぱりクサいです……オス臭ハンパないですぅ、うええ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「それにっ、あふっ！？　舌を伸ばして根元を舐めようとひゅると……んぁう\nっ！？　タマがっ！　タマがビチビチ顔に当たるのですけど……ぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ぁ……んぁああっ、も、もぉ……！　邪魔ひないれくらふぁい……！　ぺろ\n……っ、ぺろっ、ぺろ……ぴちゃ……んぁうっ！　し、しつこいれふ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「こうなったら……はむっ！　袋を口でおひゃえて……あむ！　あむ、あむあ\nむ……っ……ベロで舐め舐めして止めるです！　んむちゅっ、ちゅぅ、ちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「もご、もご、もご、もご……！　ぷぁっ……。どうです、これで少しはおと\nなしくなったれひょう……。後は……んっ、先端ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「これは面積が大きいですから……チマチマ舐めていくより、一咥えしてしま\nった方が早そうです。……というわけで、失礼します……くちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ん、んぅ……んぐっ♪　思ったより太いぃ……っ。く、くひ……口の中に入\nりきらな……！　んっ……ま、負けまへんよ……！　っぐっちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ふ、むぅ……んぐ……んぐっ……ぐぷ……っ。ぐちゅっ、ぐちゅ……ぢゅっ\n……ぢゅっ、ぢゅ……んぁっ。れろ……れろっ、れろ、れろ……あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「口の中ひっぱいにオチンポが詰まっれ……息苦ひい……。ん、む……んむぅ\n……むっ、むぅ……くちゅ……ちゅ、ちゅ……くっちゅっ、くちゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あ……の、どうれふか……。ウチの口の中……。んぁ……、あったかくて…\n…濡れてて、気持ひいい……でひゅか？　ん、む……んぅ、んむぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「な、なんれふ……。頭、ナデナデひないでくらはい……。『必死にオチンポ\n咥えてる姿が可愛い』……？　んう！？　か、かわ……カワイイとか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「うるさい、うるさい、うるひゃいれふ……！　んぁ……あなたは黙って、ウ\nチにおひゃぶりされていればいいのれふぅ……んぢゅっ、ぢゅっ、ぢゅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ん、ん、ん……！　ん……？　なんれふか、こりぇ……？　あっ……むっ？\n　口の中でオチンポの先が膨らんで……んっ？　ぁ、く、くるひい……んぐ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「『止めるな』？　『強く吸え』……？　んもぉ、要求が多いれひゅ……わか\nりまひた、強く……ちゅよく……。ぢゅっ！　ぢゅっ、ぢゅるっ……ぢゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ぐっちゅっ、ぐっちゅっ、ぐっちゅっぐちゅっ……ぢゅるぅっ、ぢゅる、ぢ\nゅる、ぢゅる、ぢゅる……んぁああ、顎が痛いぃ……外れうぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「デカいだけでウチを困らすとんでもないチンポれふ……！　え？　『休むな\n』？　『もう少し』……もう少しってなんれふか？　ぢゅっ、ぢゅううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んんんんぅっ！？　んーっ、んんんん……んぐぅ、こほっ！　けほっ、こほ\n……！　んんっ！？　んー……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「な、なんれすか、喉の奥に……ドプドプあっつい汁が……。んっ、んぁあぁ\n……！　絡んで上手くひゃべれない……！　んっ！　んっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んひゃ……。舌もネトネト……ぉ……。い、いきなりこんなもの出さないれ\nくらはい！　頭が爆発したかと思いましたッ……んぐ……に、苦いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「早く口の外に出ひゃないと……！　って、『出すな』……？　な、なんでで\nすか……？　すっごく臭くて苦くてキモいのですが……。えっ『飲め』？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「の……！？　へ！？　これをれふか！？　って、うぁ、口の端から溢れそう\nに……。『その汁は飲むもの』？　ま、まさか……。え？　本気です？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「『それこそがパワーアップの源』……。んぷぁ……バカ言ってんじゃないれ\nふ、パワーアップなんて建前ですよねぇ？　ん、で、でも……このままじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「息がマトモに出来ない……っ。し、仕方ないれふ、死ぬのは避けないとれふ\n……。うううううー……ん、ごく……！　おええええっ、苦いですうぅう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ごくっ……ごく、ごくぅ……んぶっ。えづいてしまうくらいマッズいです…\n…って、あっ！　オチンポでウチの口をふさぐのはやめてくださ……あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぐぅっ！？　んぐっ！　んぐぅううっ！　や、やめ……んむっ！　オチン\nポ突っ込んだまま、腰を振るのはやめれくだひゃ……んっ！　んっ、んむ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ぐっちゅっぐっちゅっグッチュッぐちゅっ！　んぷぅうう……！　んっぐっ\n！　んぐぅう……！　や、やら……唾、ちゅばこぼれちゃ……んうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「な、なんなんれふかぁ！　あなたの言うとおりにひたのに……っ、くっさい\nくっしゃい汁飲んだれふのに……！　まだチンポをなすりつけてきてぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「どんだけウチの口の中が好き、なんれふぅ……！！　ンッ……！　待っれ、\n待っれくだひゃ……あっ！　ウチの口使わないれくだひゃ……んっ、んむ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んぶっ……！　んぅっ！　んぅっ……ぐちゅっ！　ぐっちゅっ、ぢゅぷっ！\n　ぢゅっぷっぢゅぷっ、ぢゅっぷッぢゅぷ……んぁ……んぁ、んーーーーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「わかりまひた！　わかりまひた！　ウチも舐めて吸って、しゃぶりまひゅか\nら……！　そんなに押しつけないれくらひゃい！　……んっ！　んちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「れろっ……れろぉっ、れろ……れろっ、れろ……れろ……！　何れすか？　\n『間抜けな顔してる』……！？　お、大きなお世話れすぅ！　もごっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「アホな顔させてるのはあなたれひょうっ……！　頭に来ました、トドメを刺\nしてやるれひゅ……！　んっ、あむっ……ぴちゃっ、ぴちゃ、れろ、れる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「じゅるっ！　じゅるっ、じゅっぷっじゅっぷっじゅっぷっぐちゅっ！　ぐっ\nちゅっ、ぢゅぷっ！　じゅる……じゅるっ、じゅるっ、じゅるっ、んじゅる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「バカチンポ……っ、アホチンポぉ……！　さっさと苦い汁まき散らすです！\n　それまれは……ウチも協力してやるのです……んちゅ、ちゅ、ちゅ、れろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……ちゅっぱっ、れろんっ……れろんっ、れる……！　ぐっちゅっ\n、ぐちゅっ、ぐっちゅっ……んあああ……ぢゅっぷっぢゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んっ？　出るのれふか？　いい、でひゅよ……いいから出しやがれですぅ…\n…！　ほら、ほら……早く、はやく……ぅっ、ぐちゅっ、ぢゅるるうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ！　ぢゅるっ……ぢゅるっ、ぢゅるるるるる……！　んん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ぷぁっ……んぷ、おぼ、溺れる……ッ。よくもこんな量を、股間に隠し持っ\nていましたね……っ！　さっきの、一度目より量が多いじゃないですかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903302" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「だ、だまされました……！　二回目なら少ししか出ないと思っていた、のに\n……んぐ……！　またこんなに汁が出て……んぐ……口の中で大暴れです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「この汁っ……飲むの苦手なのです……ぅ！　でも、でも飲まないと……。う\n……んぐっ！　ごくっ……ごくっ、ごく……ごっくんっ！　ううう～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「口の中、汁の臭いと味が満ちて……。こ、これ、うがいしても何日もとれな\nさそうです……。そしたら……そしたらウチは、この味とずっと一緒で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……しんどいですけど……。チンポを汚したままにしておくのも、なんだか\n行儀が悪いですし……。そのまま動かないでください。掃除……します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「とにかくジッとしててください！　……ん……ちゅぱ……。ちゅぷ、ぷちゅ\n……。ぺろっ、ぴちゃ、ぴちゃ……ちゅっぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「この、何とも言えないもったり感……。ぬったりしていて、ドロドロで……\n。んーーーー、やっぱり苦くて、ナメクジみたいにプルプルで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「嫌です、苦手です……。なのに……。なぜ、ウチはこんなものを夢中で舐め\nて飲まされているのか……。解せぬです、理解不能です……ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、ぴちゃ、ぴちゃ……。ごくっ。ま、満足しましたですか……？　は\nい。それならいいのです。ホント、顎が外れそうでしたよ……まったく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ま、待つです！　口からオチンポ抜いてどこへ……って、みゃあああ\nあっ！？　あっ！？　あっ！？　どこにかけてるです、どこにぃ！　やぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「か、顔にかけていいだなんて許可してないですけどぉっ……って、あぷっ！\n　あぁ……ッ、ま、待って、待つです、ま、待てと言っているですのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「あ……、あああああ～！　ウチの顔、顔中にくっさい汁が……汁がぁあ……\n！　あ、あなた、チンポにどういう躾してるですかぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「ううう……。こ、こらぁ！　もう出すなです、まだ出すとは何事ですぅっ！\n　……はぁっ……はぁ、はぁ……呼吸をするだけで臭い、くさいぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「……何スッキリした顔でウチを見てやがるです……！　あぅ……このネバネ\nバ、全然取れない……。もしかして、洗っても取れないんじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000509_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「もし、落ちたとしても……感触が消えなさそうで……。『良いコミュニケー\nションの練習が出来ただろう』ですと？　こ、こ、こ、こここのぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「次にこういうコトをする時には、ウ、ウチからめちゃくちゃにしてやるです\nからねっ……ウチが……ウチがひとりぼっちのダメ兎だからといって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「やられっぱなしは性に合わないです……。い、いいですかっ！　次は！　次\nは勝手にあなたが腰を動かすんじゃなくて、ウ、ウチが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「超絶テクニックでヒィヒィ言わせてやるですから、覚悟しておくです！　…\n…はぁああ……。でも、顔に出されて良かったのかもしれないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アナザーオボロ" ]},
		{"command":[ "SETTEXT", "「こんな、濃くてたっぷたぷの汁……口やアソコに発射されていたら、妊娠確\n実でした……。そう思えば、危機を回避できた……のでしょうか……ぐすん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_0903410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}