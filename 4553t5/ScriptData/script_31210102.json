	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ん……。はぁ、はぁ……。た、隊長ちゃん……？　呼んでくれてありがとぉ\n……。それで……今日は、何をするの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あのね、もし何も決まっていないなら……その……。本番エッチがしたいの\n。最近、隊長ちゃんを見ているとどんどん我慢ができなくなっちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「したい、したいってずっと思ってたから……。一人でしながら、こうやって\n呼んでくれるのを待ってたんだぁ。……どう？　だめ？　したいなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「えっ！？　いいのっ！？　やーったぁ、嬉しいっ♪　って……な、なぁに？\n　なあに？　私が上になるの？　それはいいけど……あっ、やぁんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00012101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「なん、で……乳首にローターなんか……♪　隊長ちゃんが直接触ってくれれ\nばいいの、に……って、んんんんっ！？　んんんっ！？　や、やぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ブルブル、乳首ブルブルさせちゃだめぇえ♪　いやっ、いや、やぁあ♪　ん\nんん……むずがゆいよぉ……！　あっ、あっ、き、気持ちいい、けど！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「目の前に隊長ちゃんがいるのにぃ……ローターなんてやぁ……！　ねぇ……\n触ってぇ♪　その手でいじってぇ……あっ♪　あっ、ぁっ、お願いぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「え……？　焦らし放置プレイぃ……？　えぇえっ！？　やだやだぁあ～！　\n私、Ｍじゃないよぉ！　隊長ちゃんを責めるならいいけど自分は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　し、振動強めないでぇ！　わかったわぁ、わかったわっ……放\n置……してもいいけど、限界が来たらちゃんと抱いてよぉ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「っ……はぁ……っ、はぁ、はぁ、はぁあ……♪　んんん……んぅ……！　ふ\nぁっ！？　ぁ……あ、ぁ……んぁあああ……んんん……！　もぉおお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「いじわ、る……いじわるぅ……あぁ……！　目の前に隊長ちゃんの手、やお\nちんぽちゃんがあるのにぃ……あっ、おあずけなんてヒドイぃ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ね～ぇ～……入れてよぉ……んんっ、その方がぁ～……絶対、ぜった～い隊\n長ちゃんだって気持ちいいはずでしょぉ……っ、ほら、わかるぅ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのカラダと、触れ合ってるところ……もうぐしょぐしょなのっ、\n愛液が湧いて、潤んで、滲んできて垂れちゃうの……濡れてるのぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ん～……ま、まだだめなのぉ……？　き、聞こえるでしょぉ……。くちゅっ\n、くちゅって……恥ずかしい音……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ア、アソコがヒクヒクして辛いの……っ。それに、胸も、あっ、休まず刺激\nされたら……あっ、あっ……だめっ……だめ、軽くイッちゃいそ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あんんっ♪　あんっ♪　やだぁ……！　どうせイくならぁ、隊長ちゃんので\nイキたいのにぃ……あっ♪　あっ♪　おっぱいだけでイッちゃうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ん～～～～～ッ……♪♪　っ、はぁっ、はぁ、はぁ……ううう……！　あっ\n、おね、がいぃ……お願い、隊長ちゃぁん……切ないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「おまんこ、スカスカで苦しいのぉ……。奥が……中が疼くのぉ……♪　隊長\nちゃんの太いので塞いで欲しいのぉ……わかるでしょ？　あっ、んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「んっ……おねだりできたら挿入してくれるの？　っ……恥ずかしい……恥ず\nかしいよぉ、でも……でも……！　っぁ……！　あっ……ぁっ……やぁあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「言うっ！　言うからぁっ！　……『私の、いやらしくて我慢のきかないダメ\nおまんこ、濡れっぱなしでおちんぽ欲しがる淫乱おまんこに』ぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「『隊長ちゃん、……あっ♪　ぁっ、た、隊長さま……の逞しいおチンチン、\nに、肉棒……太くてゴツゴツしてる男根を入れてくださ……い』ぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「真剣に締めます、から……必ず気持ち良くしますからぁ……！　お願い、お\n願いお願いぃ！　おちんぽちゃんちょうだいぃ、もうだめぇ……！　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あっ……！　入れてくれるの！？　あ……あっ、あぁあああああッ！？　あ\nはぁあああ♪　おちんぽっ、おちんぽだぁ♪　おちんぽキたぁ、キたぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あっあああああ♪　スゴい♪　スゴい……最高ぉおお……♪　うん、うんっ\n、これが欲しかったの……これを入れてほしかったのぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あぁぁ……隊長ちゃんのおちんぽ強くて本当に好きぃぃ……！　ねぇ♪　ね\nぇぇ♪　私のおまんこの中ぁ……あっつあつでしょぉ、あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「全力で隊長ちゃんの、かっこいいおちんぽ締めつけて……もう離すもんかっ\nてぇ……しがみついてきて、キツキツでしょぉ……！　んっんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「これっ、これ……もう私のなんだからっ♪　あっ……あっ、ねぇ、おっぱい\nも……おっぱいも触って……うんと強くしていいからぁ……あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「焦らされまくってビンビンになった乳首、指でいじりながら……ぁ！　おっ\nぱいグニグニ揉んで、それで……腰も使っておちんぽ動かしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「……あッ♪　あはぁあんんっ♪　そうっ……そうっ！　攻められるところ、\n全部攻めてぇ……私のやらしいとこ、全部独り占めしてぇ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あっひっ、ひぃっ、あっ♪　あっあっあっ♪　スッゴい腰使いぃ……！　あ\nっ！　わたひっ……わたひも負けないんだからっ、あっ、あんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「それそれぇえ……♪　あっ♪　だめ♪　気持ち良すぎて……腰がガクガクぅ\n……っあっ♪　だめぇ♪　いつもなら負けないのにぃ……あぁんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのおちんぽにっ、負けちゃうっ……んんぅっ♪　だぁってスゴす\nぎるのぉ♪　おまんこから脳天まで……串刺しぃ♪　おっきすぎぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あぁんっ♪　あんっ、あぁんんっ♪　しゅご……しゅごいぃい♪　あっ♪　\nわかるの……私のアソコ、ぐちゃぐちゃに蕩けてぇ……！　っあぁあ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのおちんぽちゃんを喜ばせるためだけの、エッチなおまんこにな\nってるっ♪　隊長ちゃんのカタチに、変わって……く♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ッんんんっ……んんー……！　んんんーっ……！　おねだりしてぇ、入れて\nもらって良かったぁ……信じらんないくらい気持ちーよぉ……♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　隊長ちゃぁん、隊長ちゃんも気持ちよくなってねぇ♪　私\nのお腹の……あっ♪　中、で♪　一番奥でおちんぽウニュウニュされてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「二人で良くなろ……ぉ♪　あっ、あぁああ……！　でも！　でも……！　ご\nめんんっ、私の方が先にイっちゃうかも……ジワジワきてるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あがってきてるっ、快感っ♪　気持ちいいのがゾクゾクあがってきてるっ…\n…ごめんねぇ……でっかい花火あがっちゃう！　イッちゃううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あひっ♪　ひぃいいっあひぃいいいっ♪　んぅううう～っ♪　んんぅううう\n～♪　あははぁ♪　めちゃくちゃ締まるって？　そうでしょっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「だって本気イキだもんんっ♪　本気でイクとね♪　自然にぃ……おちんぽを\n気持ち良くなる動きしちゃうんだよぉ、おまんこは……っあっ♪　あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あっ……！？　あれっ！？　あっ……あっあっ！？　ドクドクって……あぁ\nっ！？　あっ！？　熱いのがのぼってくる……あーっ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ご、ごめぇんん♪　私っ、自分が本気イキしてたからぁあ♪♪　隊長ちゃん\nが出すタイミング、気づかなかった……あっ♪　でも一緒で嬉しいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「一緒にイケてうれし……あっ！　やぁんん♪　中出しされたの、嬉しすぎて\nまた……！　あぁっ♪　イッ、ちゃ……あーっ♪　あーっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「私達、相性バツグンもいいところじゃなぁい……？　それともこれっ、放置\nプレイのせい……？　精子が入ったところが熱いぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「んっ♪　奥の奥にまで入れてくれたみたいでぇ……おまんこたっぷたぷだよ\n……♪　でも……まだ足りなぁい……♪　今度は私のばーん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「完全に火がついちゃったぁ♪　もー泣いても許さないんだからぁ……♪　カ\nラッカラになるまで搾り取ってあ・げ・る……ぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「んっあっ♪　あっ、ぁっあっ♪　お尻ふりふり、腰をぐりぐりひねりながら\nぁ……♪　あぁっ♪　派手に上下左右、前後させるといいでしょぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「おまんこの色んなところに当たってぇ、私もいいよ……ぉ♪　あっ♪　ここ\n♪　ここっ、がっ、私が好き……ここ♪　ぐりってされると感じるぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「うふっ、うふふふっ♪　私が感じると……おまんこの動きも激しく、なって\n……♪　トロトロの愛液でおちんぽもよくなるでしょ？　ウィンウィン♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　あぁっ……♪　うれしい……嬉しいっ♪　隊長ちゃぁん…\n…わかるぅ？　中出ししてくれた精液でおまんこヌルヌルだよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「えっ？　それは私が濡れすぎだからだろって……あはっ♪　大正解……でも\nぉ……♪　二人のお汁で♪　ヌルヌル感アップしてるじゃなぁい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「動きやすくて……あっ♪　おまんこのヒダヒダ、おちんぽにニュルニュル絡\nみついてぇ……あっ♪　あっ♪　欲望全開の生エッチ最高だよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「私の中っ、おまんこの中に隊長ちゃんの精液……ぃ♪　おちんぽで塗りたく\nって、塗り広げてぇ……あっ♪　あっ♪　どうしよぉ、大変だよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「私、今日危険日なのにぃ……♪　あっ♪　赤ちゃん出来ちゃうっ♪　避妊無\nしで生おちんぽ入れてもらっちゃって、ドクドク中出しされ、て♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「何度も何度もイッちゃって♪　受精確率爆上がりだよぉ……！　あっ♪　子\n宮口もちゅうちゅう精液吸ってるしぃ……あぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「できちゃう♪　できちゃうけど……ぉ♪　危ないけど、やめられないぃ♪　\n危ないって思えば思うほど……んふっ♪　興奮しちゃう♪　あっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「もう逃がさないぃ……♪　おまんこでぇ、おちんぽがっちりホールドして♪\n　子宮口にぐりぐりくっつけながら高速ピストンしちゃう、ほらほらほらぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「んっ♪　もう一回出しちゃおっか～♪　ふふふ♪　私、も♪　もう一回大き\nな波がきそうで……あぁ♪　お潮噴いちゃいそう、だか、ら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「いっせーので二人でイこぉ♪　んっ、んんんっ……ギリギリまで、ぇ……！\n　粘膜に気持ちいいのを溜めて、溜めて、ため♪　てぇ♪　うん、うん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「カウントダウンしちゃうよぉ……♪　は、ぁ♪　イくよぉ？　イくよぉ♪　\n５……ぉ♪　４、３、２……１ぃい♪　あッ♪　イクイクイクイクっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あんっ♪　あぁ……きたきたぁ♪　どぴゅっ♪　どぴゅってかかってる♪　\n中にかかってるぅ……んっ♪　でも、注ぐのはこーっち♪　んふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「子宮口にぴったりおちんちんの先っちょくっつけてあげたから……あぁんっ\n♪　あとは思う存分出して♪　出して……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「私もずーっとイッてるから♪　イキっぱなしでおまんこ震えてるからぁ♪　\n好きなだけビュービューして……んぁんっ！　中に出てるのわかるよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「二回目なのにぃ……一回目より勢いスゴいんだけどぉ……んぁっ♪　隊長ち\nゃんは女の子にぃ、攻められるとたくさん出ちゃう人ぉ？　あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「それとも私のおまんこが良かったぁ？　んふふふ♪　隊長ちゃんの気持ちよ\nさそうな顔見てるだけで、私も幸せぇ……。あ、まだ抜かないで♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「今♪　今おまんこの奥で……子宮がちゅーっ♪　ちゅーっ♪　って搾りたて\nの精液を飲んでるとこだから……まぁだそのまま♪　んー……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あぁ……んんん……うぅうん……♪　ふふふ……ありがとぉ♪　お腹いっぱ\nいになったぁ……。隊長ちゃんって魔性だねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「魔法のザーメンでぇ、女の子をイチコロにしちゃうわるーいひと……♪　も\nちろん私も……♪　あーん、嫌になっちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんがこんなに気持ちいいなんて知っちゃったら、明日から一人で寝\nていられないよぉ……欲しくて欲しくてたまらなくなっちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「そうなっちゃったら……。夜這いしてぇ、こうやって上に乗って腰振っちゃ\nおうかなぁ♪　その時まで……しっかり溜めておいてね♪　うふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「やぁああん♪　大爆発ぅ……♪　あっあっ♪　滝みたいにドパドパ出てるよ\nぉ……！　んぅ……んぷ……。隊長ちゃんの臭いぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あっ♪　びちゃっ、びちゃってかかってる……私、真っ白に……隊長ちゃん\nの色に染められちゃったぁ……。幸せぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「んんっ……きゃっ♪　んふふふ……♪　二度目の発射なのに元気余りすぎだ\nよぉ……。嬉しいけどぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00012101_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「全身、精子まみれにするとか……♪　隊長ちゃんって結構独占欲強いタイプ\n～？　だったら私と一緒だねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「すぅううう……はぁあああ……♪　むせかえるような臭い、肌にまとわりつ\nくネバネバ……。これってマーキングってやつなんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「私が隊長ちゃんのモノだ～って、跡をつけて宣言してくれてるんだよねぇ♪\n　……いいなあ♪　私もマーキングしたい♪　んん～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「次にする時には、首や肩に噛みついて歯形をつけちゃおっかな？　それかぁ\n～♪　キスマーク♪　ちゅぱちゅぱつけちゃってもいいなぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「んんんんっ……♪　想像するだけでまた濡れてきちゃうぅ……♪　ホントに\n隊長ちゃんって私をその気にするのがじょーずぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「もう絶対、私のモノにしてみせるんだからぁ……♪　ふふ♪　……って、ん\nむっ……♪　精液、ちょっとお口に入ってきちゃった。ちょうどいいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「身体にかかった精子、舐め取っちゃってもいいわよね？　……ちゅ♪　ちゅ\n♪　ちゅぷ……ちゅる……ぢゅ、ぢゅ……♪　ごちそうさまぁ……♪」", "NORMAL" ]},
