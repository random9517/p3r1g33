{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……お兄。あのさぁ……、今から私、ヘンなこと言うかもしんないけど……\n。マジメに聞いてくれる？　あ、あのさ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「前からわりと考えてたことなんだけど。私とエッチとか……する気ある？　\nう、うん。知っての通り、私って孤高のオナニストだしオナ狂いだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「もし……誰かとエッチするんだったらお兄がいいなーって思ってるんだよね\n……。これはホント、もし良かったら……のハナシなんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「私のはじめて……。もらってくれたり、しないかな……？　どんだけ色々考\nえてみても、どーしても相手はお兄がいいなって思ってて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……え！？　い、いいの！？　シてくれるのっ？　私、超オナリまくりのオ\nナ猿だよ！？　性格だって暗いし、セクシーボンバーって感じじゃないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「でも……。し、してくれるなら……う、うん。したい。今すぐしよう！　ま\n、待ってね。ちょっと準備するね。えへへ……こうやって～……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104106" ]},
		{"command":[ "SETCHARA", "0", "char_00028701_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……はいっ♪　こ、こういうポーズだったら……おちんちん、すっごい入れ\nやすいと思うんだけど、どうだろぉ……？　っうう、恥ずかしいけどさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「このチャンス、逃したくないし……。お兄がしてくれるって聞いたら、もう\nなんか……それだけでおまんこの準備整っちゃった。見えるかなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「奥の奥からじゅわ～っておつゆが溢れ出して……。期待で愛液ヌルヌルにな\nってきてる。ホントにいいの？　初めてがお兄なんて嬉しすぎるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……んっ？　腰をヘコヘコさせて気合入りすぎって？　い、言わないで……\n♪　だってさ、言ってみたけど本当に夢が叶うと思ってなかったんだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「嬉しいっ……。嬉しい♪　だから早くおちんちん入れてっ……！　オナ猿で\nエロガキな私の、ぐちょぐちょおまんこにたっぷりしつけしてっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……お兄が勃起してるのはさぁ～……。見てたらわかるんだよね。だって、\nお兄のおちんちん大きすぎるんだもん。すぐにわかるし。……ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「入れて♪　入れてっ♪　そ、そう！　そうっ……♪　ズボン脱いで、下半身\nモロ出しにして……って、わっ！　想像よりも更にデカっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、それを……！　お兄のいきり勃った、逞しいおちんちんを……\nっ。オナニーばっかして感度ばっかりあげてきた私のおまんこに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「っくぅううううっ……！？　んっ、んんんんっ！　あっ♪　やっ、やっばっ\n……♪　おっきすぎてひっかかってりゅっ♪　あっ！　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄ぃっ！　強引にしていいからっ……あっ、ああああっ！　私のキツキツ\nヌルヌル処女おまんこに思いっきりおちんちんぶっ刺して！　っあああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あひぃいいいっ♪　ひぃいいいいいんんっ♪　入ったぁあああ……！　ずぶ\nぅううって入ったぁああああ♪　あっ……？　えっ？　す、す、すごい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「すごいすごいぃいいっ……！　これが本物のおちんちんなんだっ……！？　\nあッ♪　ウソぉっ！　思ってたよりデカすぎてっ……あっああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「はうっ！？　あうううっ！　うん、うんうんっ！　気持ちいいっ！　痛くな\nんかないっ……！　おまんこの中めちゃくちゃ濡れてるから突いて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あっ、んぐぅっ！　んぐぅううっ、んんんっ！　おちんちんすごいぃっ！　\nあっ♪　こ、これっ、これを知ったらもう指でオナるとか無理ぃいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あひぃいいっ♪　やあああ、信じらんないぃいっ♪　おちんちん入れられて\nっ、ちょっとオナホ扱いされただけで……母乳も潮も噴きまくっちゃうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　あああっ♪　そっか……そっかぁああ♪　私、ドＭだったんだぁ\nああ……♪　オナホ扱いされてっ、ずぶっ、ずぶ、ずぶぅってっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「おちんちんでしつけされるとっ！　あっ♪　おっぱいミルクも潮もぴゅっぴ\nゅしちゃう、淫乱マゾ奴隷だったんだぁああっ♪　嬉しいいいぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、お兄！　やめないで！　もっと……もっとして、強くして、\nひどくしてぇっ！　乱暴にしてぇえええっ♪　あっ♪　あっおっおっぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「オナホみたいに扱われて、チンシコに使われるの最高に好きかもぉおおっ！\n　あぁっ！　あっ！　あっ、お腹熱いよぉっ、おまんこ燃えてるぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄のおちんちんっ、すっごい好きぃいいいっ……！　あっ！　形がカッコ\nイイっ♪　私のおまんこをっ、一番気持ち良くできるカタチしてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あ～っ♪　あ～っ♪　オナニーするより百倍すごいよぉおっ♪　あうっ♪　\nんんぅっ♪　こっちもお尻揺らして、腰振るのやめらんなくなるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「これがエッチっ……！　セックス、せっくすなんだぁあああ……っ♪　あう\nうっ、んんぅううっ！　んふうぅっ♪　気持ちいい、気持ちいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「もう絶対！　お兄専用のロリマゾオナホになるぅううっ！　ってかもうなっ\nてるよぉっ！　わか、るっ？　私のおまんこキュンキュンしっぱなしっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄の極太おちんちん、味わいつくそうとしてすっごいうねってる、でしょ\nっ……？　これっ、普通のオナホじゃ味わえない動き、してるでしょっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あっ……あああっ♪　自然におちんちんにご奉仕しちゃうマゾおまんこなの\nっ……！　お兄専用ロリオナホっ！　いっぱい、いっぱい使ってぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「っぅううううっ♪　やばいぃいい……♪　おちんちんでトントンってっ……\n♪　おまんこの一番奥、コンコンってノックされると、震えるぅううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ゾクゾクしてっ、頭おかしくなっちゃいそぉおおっ……！　ああああっ！　\nマゾ心刺激されりゅっ、お兄ぃっ！　お兄ぃ、大好き、らいすきぃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「このまま……当然生で中出ししてくれるんだよねっ？　ってか、そうじゃな\nきゃありえないっ……！　んぁっ、あぁ、ああああっ、あぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「気合入れて締めつけるから……！　出して、ロリマゾオナホに出して！　び\nゅっびゅしてっ……！　欲しいの、感じたい、お兄の精子……！　あぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「は、ぅ、あぅぁああああああぁっ……♪　出たぁあああっ♪　お兄の特濃栄\n養満点精子出たぁああああ……っ♪　ああああっ、奥に出てるぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「びゅるっ、びゅるっ、びゅうっびゅうって……っ♪　えええええええっ♪　\n射精って、こんっなイイんだぁっ♪　満たされる、おまんこの中ぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あうっ♪　あうっ♪　イッちゃうううっ、イッちゃうよっ！　こんなのイカ\nないとか無理すぎるぅうううっ♪　あぁああっ、あぁ、あひっ、ひぃいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「イグイグイグっ……！　全身痙攣しっぱなしぃいいいい……っ♪　あっ……\n！　あっ……！　や、やばい、身体ぶっ壊れちゃったかも……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「イクの全然終わんない……って、あっ……？　お、お兄……？　何してるの\n？　今射精したばっかなのに、ま、またピストンしようとしてない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あっ、ぐっ……！？　えっ？　う、うん、オナホにしてって言ったのは確か\nに私……だけ、どっ？　れ、連続でするの？　えええっ、それはヤバすぎ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「おまんこの痙攣全然止まってないしっ……！　あっ！　イッたばっかで敏感\nすぎるしっ……！　精液でおまんこの中トロットロだしっ……んぁんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「感じまくってて全身どろっどろだけど、そ、それでもいいの……？　あっ、\nこのままエッチし続けたらっ、アヘ顔になっちゃう、イキすぎちゃうよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……それでもいいなら……あっ！　し、してっ♪　うんっ……！　うん、し\nていいよっ……！　だってぇっ、専属オナホになるって誓ったもんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「オナホはぁっ♪　はぁっ、はぁ、はぁ、はぁっ♪　オナホはご主人様の……\n！　お兄の言うことに抵抗したりなんかしないよっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あっ♪　いっぱい使ってもらってっ！　ロリロリおまんこでおっきなおちん\nちんっ、シゴいてもらえるのが何よりの幸せ！　そ、そうだよねっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あっ♪　マゾおまんこでっ、いっぱい絞ります、気持ち良くしますっ……！\n　だからこのカッコイイつよつよおちんちんでズボズボしてっ……ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あぁっ、んぁああああっ♪　このニュルニュル感、しゅっごいぃ\nいいい……！　一回中出ししてからのピストン、ホントクセになるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ♪　あああああっ♪　んぁあああ～っ、あああああっ……♪　\n指だけじゃ届かない、奥の奥までごりっごりの亀頭でえぐられるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んぃいいっ♪　いいいいっ♪　んぁっ……♪　あぁっ、お兄……！　お兄に\nはじめて、あげてよかった……♪　まかせてホントに正解だったよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「すっごく上手いし、おちんちんは逞しいしっ……♪　妄想よりも熱いし、強\nいし、……あっ♪　やっぱり、頭の中で考えてるよりもっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ホンモノをっ、経験することが大事……！　そうだよねっ♪　あぁああっ…\n…♪　良かったぁあ、お兄にしてもらえて、お兄と出会えてぇえっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「しあわ、せっ♪　最高に気持ちいい初体験させてくれてありが、とぉっ……\n！　あああっ！　これからもいつでも使ってねっ、専用オナホっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「いつでもヌルヌルに濡らして待ってる、からぁっ♪　ああああっ……！　う\nん、そうなの……！　大事に大事に抱かれるより……モノとしてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「コキ捨てられるくらいが一番興奮するの！　あっ……あっ！　オナホが天職\nだったなんて……！　あっ♪　これからの人生楽しすぎ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ねえっ、お兄っ……♪　私のおまんこ気持ちいいっ？　どういう動きしたら\n気持ちいいかなっ……？　あっ……！　何でもするよ、どんなプレイでもっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「だからっ……だからオナホとして可愛がってね！　あへっ……♪　んへぇえ\nっ♪　いつでもっ、このおちんちんだったら入れていい、からねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んっあっあっあっあっあっあっ……♪　あは……♪　お兄のピストン、どん\nどん早くなってきてるっ……！　おちんちんも膨らんで……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「射精したい？　いいよ、いいよぉっ♪　オナホに許可なんか必要ないよっ…\n…！　出して、い～っぱい出して、またイかせて、真っ白に染めて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んくぅううっ♪　そう、奥に……照準定めて、思いっきりっ……！　出して\nぇっ、私も一緒にイクっ、イクからぁあああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104220" ]},
		{"command":[ "WAITINPUT" ]},
				
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「はぁううううううっ♪　ひゅごっ……ひゅごいいいいっ♪　二回目なのにぃ\nいっ、一回目よりもいっぱい出てる、あへっ、あへぇええっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄っ……！　お兄の射精の仕方、好きぃっ……！　あぁっ♪　おまんこ締\nめつけてるからねっ、隙間なくいっぱい出してねっ……！　ああああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104302" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「射精っ……、精液流しこんでもらえるこの瞬間っ……！　専属オナホしてて\n良かったぁって一番思うよぉおおおっ……！　ホント気持ちいいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「んふぅううっ♪　ふぅうっ、くぅ～っ♪　ううううっ……♪　まだ出るっ？\n　出るよねっ、ぎゅって絞るねぇっ！　んんっ、どーおぉっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「最後の一滴まで出して……！　っはぁあっ♪　はぁっ、ああ～っ……キたぁ\nあ……♪　お兄のあっついの来たぁ、届いたよぉおお……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「これからもぉっ……、おまんこオナホのご利用お願いいたしまぁす……♪　\nなんちゃって♪　でも、私は本気だからね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「はぁっ……、お兄……♪　一生に一度のはじめてを……私の初体験を、こん\nなに最高な思い出にしてくれて、本当にありがとね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「えへへへ、する前ちょっと怖かったのがさ。お兄とエッチしたら、良すぎて\nオナニーなんか楽しめなくなるんじゃないかってことだったんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「今日の記憶さえあれば、いっくらでも反芻して……繰り返しオナニーできそ\nうかも。……うん、それくらいスゴかったよってこと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「これからは毎回迷っちゃうなぁ。お兄とエッチするか、お兄のエッチ思い出\nして一人でするか。うーん、贅沢な悩みなんだけど。ふふふっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「あっ！？　ああああっ……！　ひぅっ、お、お兄っ……？　おまんこの中じ\nゃなくて……あっ、身体にかけるのっ？　ぶ、ぶっかけぇっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「いいよ、そういうのも興奮しちゃう……！　あっ♪　オナホ相手に遠慮なん\nていらないんだから……したいこと、したいようにして……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「ッんんんんっ……♪　あっついお汁が、精液が身体中に降り注いでくる……\n！　いいのかな、こんな贅沢なこと……♪　あっ、幸せだよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_21" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄のおちんちんと、精液を独り占めできて……夢みたい♪　あっ♪　もっ\nとかけて……！　ドロドロにして、お兄にだったら何されてもいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「っんん、ん、んんっ……♪　私みたいなロリのオナ狂いでこんなにたっぷり\n出しちゃって……、お兄ったらホントーにドスケベだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00028701_02_19" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「でも……悪い気分じゃないよ、……あんっ♪　まだ出てるぅ……♪　すっご\nいやらしいおちんちん……♪　ほらっ、スッキリするまで出してっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「……ふふ……ふふふふ♪　……ん？　何がそんなにおかしいのかって？　違\nうよ。嬉しいの。今まで、ずーっと一人でオナニーしてたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「はじめて誰かを気持ち良くできたんだなって……。今、身体にかかってる精\n液を見てたら実感しちゃったんだ。これ、私で気持ち良くなってくれて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「私でイッてくれたから出たんだ～って……。そう思うと、エッチっていいよ\nね。オナニーにはオナニーの良さがもちろんあるんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_287_0104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガイラ" ]},
		{"command":[ "SETTEXT", "「お兄のために尽くすのも……ドＭ的にはたまらない、新しい快感だなぁって\n……。これから毎日したくなっちゃうかも……♪」", "NORMAL" ]},
