		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「じゅぷっ！　じゅぷっ、じゅっぷっ……ぐちゅっ！　んっ、はぁっ、はぁー\nっはぁっ……♪　ぢゅる……ぢゅる、じゅるるるっ、じゅるっ……」", "NORMAL" ]},
