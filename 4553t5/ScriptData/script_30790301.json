		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「喉奥まで亀頭を咥えて、精液を掻き出してみせようじゃないか♪　なぁに、\nそれでまた射精したくなった時は相談だ……。そぉれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……ぐちゅっ……。んん……！　あは……♪　肉棒にこびりついた分を忘れ\nていたなぁ♪　これじゃ、掃除どころか精液の上塗りだが……ぐちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「なんでも、試してみるのが僕のモットーだ……。んっ……んっ、んっ……♪\n　さっきよりも、深……く……♪　喉奥まで……しゃぶって……んん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「大きく、頭をグラインドひゃへ、る♪　んーーーーー♪　ぐちゅっ♪　また\n咥えてぇ……ぐちゅうううっ♪　引き抜くっ♪　んぅうーぐちゅっ♪」", "NORMAL" ]},
