		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ゴクッ……。んん……。ダメだ。喉の奥に絡んでとれない。……そうだ、責\n任をとって君のモノで僕の口を洗ってもらおうかな♪」", "NORMAL" ]},
