		{"command":[ "SETIMAGE", "0", "still_00007903_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「って、君のせいで監視がすっかりおろそかになってしまったじゃあないかっ\n！　……ズルいぞ……。僕の弱点を突くなんて……ううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「き、君に男根を見せつけられると……明晰な頭脳の調子がすこぶる悪くなる\n。何も考えられなくなって、むしゃぶりついてしまって恥ずかしい」", "NORMAL" ]},
