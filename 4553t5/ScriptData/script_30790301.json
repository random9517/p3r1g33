		{"command":[ "SETIMAGE", "0", "still_00007903_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「くちゅっ……くちゅ、ちゅく……くっちゅっ……。ちゅ、ちゅ、チュ……。\nんー……水着の中で蒸れていたのかな、かなり濃い匂いら……」", "NORMAL" ]},
