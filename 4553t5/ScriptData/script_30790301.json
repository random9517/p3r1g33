		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕かい……フフ、何をしていたと思う？　と、君を焦らして遊んでいる暇は\nないんだ。浜辺の監視を頼まれていてね。適した場所を求めさまよっていた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そして！　たどり着いたのがこの場所……。隊長、慧眼な君には恐れ入るよ\n。ここがベストプレイスだと知って、見張っていたんだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……え？　違う？　ただ休んでいただけ？　……む。おかしいな。ちょっと\nいいかい？　よっと……本当に偶然ここにいるなんておかしいじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0303104" ]},
		{"command":[ "SETCHARA", "0", "char_00007903_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほら。ごらんよ。ここからなら、浜辺の一番人通りの多い場所……犯罪多発\n予定地を一望できるんだ。……ん？　なんだい」", "NORMAL" ]},
