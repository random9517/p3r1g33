		{"command":[ "SETIMAGE", "0", "still_00007903_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ふぅううっ……♪　ま、まったく君は限度というものを学ぶべきだ……。僕\nなんかに貴重な子種を何度も放出して、計画性のかけらもないぞ」", "NORMAL" ]},
