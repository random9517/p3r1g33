		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああああっ……♪　うぷ……♪　達しながら、快楽に堕とされなが\nら顔にたっぷり出されるなんて……これはこれで素敵、だけれど♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「どうにも出し過ぎな気がするんだが……！　あっ！　無理だっ、それ以上か\nけられたら……息ができなくなってしまう。やめたまえぇ……っ」", "NORMAL" ]},
