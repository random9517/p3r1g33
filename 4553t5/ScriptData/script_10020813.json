	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "塾生三号" ]},
		{"command":[ "SETTEXT", "「うわーん！　ママが虐めるーっ！！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090401_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生二号" ]},
		{"command":[ "SETTEXT", "「楽しい……日々でした……さらば純情塾！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "塾生一号" ]},
		{"command":[ "SETTEXT", "「また会おう、『乱杰李威仏斗暴屡（らんじぇりい・ふっとぼうる）』を愛す\nる諸君！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00090201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "若干、あいつらも気の毒に思えてきたな……いやもっと気の毒なのは、巻き込\nまれた俺か……。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あー……まだ、事態がよく飲み込めていないんだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960001" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしのせいで騒ぎが起きたようで……その、すまない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「案ずることはない。あなたもどうやら犠牲者だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113960001" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「それに、コートの外ではすべてノーカウントだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113960002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ふっ……そうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960003" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや意味わからん。あれか、拳ならぬショルダーアーマーをぶつけ合った者同\n士に通じる何かなのか？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「カツマにも、さすがに悪いことをした……ような。そうでもないような」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「彼は自らの命と引き替えに、私たちに大切なものを教えてくれたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113960003" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "生きてるっつーの。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「隊長の犠牲を無駄にせず、これからも共に戦おう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113960004" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……そうね。そういうことにしましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960005" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「ならば良し！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113960001" ]},
		{"command":[ "SETCHARA", "0", "char_00002502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クィン・テイル" ]},
		{"command":[ "SETTEXT", "「さあ、試合終了だよ。さっさと片付けて、業務に戻る！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_025_020113960002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｄｒサイレーン" ]},
		{"command":[ "SETTEXT", "「はあ、めんどー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010113960001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「カツマの遺骸はどうするのであるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010113960001" ]},
		{"command":[ "SETCHARA", "0", "char_00002001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「その内勝手に復活すんだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010113960001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「放置決定ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010113960001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ね～ね～、早くお片付けして帰ろ～う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010113960001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……ま、俺の扱いなんてそんなものだろうな。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いいさ……疲れてもいるし、さっき打たれた箇所も痛くなってきたし……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ではわたくしめも皆様とご一緒に」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113960001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "この、駄犬めっ……あ、なんか……意識が遠くなってきた。マジで……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "お……おーい……いやこれ、マジでやばくなってきたかも。イタタ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0160" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960006" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……お？　あれ？　気がつけばこれは……どういう状況だ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……起きたかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960007" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだ？　エファに……背負われている？　それに……あちこち手当もされて\nいる、な……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まさか……校庭でダウンした俺を、助けてくれた……のか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「まだどこか痛む？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960008" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああいや。……やっぱり、手当てしてくれたのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「さすがに忍びなくてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ふーん……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、いつもの調子であのまま放置されるかと思ったぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それはいくらなんでも、って思ったものですから」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113960001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ん？　お……よく見れば周りに、夜叉や修羅姫がいる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「頭に血が昇っていたようだ……申し訳ない」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113960005" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あたしたちはみんな、血に酔っていたのよ。熱血という名の血にね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「上手いこと言ったつもりか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「らしくなかった、と反省してる。スポ根に嵌まるなんて、あたしとしたこと\nがねって」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……まあ、そんな日もあるだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "珍しく、しおらしく。そんな感じだな、今のエファは。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "姿勢のせいもあるだろうが、まともにこっちを見もせず、謝罪と反省ばかり口\nにして。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それこそ、“らしくない”。まったく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「エファナティカさんって、カツマさんの前だと素直なんですね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113960002" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はあっ！？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おいおい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「なんだ、そうなのか。そうだったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113960006" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ツンデレですなあ、いやはや」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_010113960002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "おい駄犬。何さりげなく『最初からご主人の側に寄り添っておりましたぞ』っ\nて顔で横を歩いていやがる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あんたたち……あんまり勝手なこと言ってると、また『乱杰李威仏斗暴屡（\nらんじぇりい・ふっとぼうる）』に巻き込むよ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960013" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「それはもう、いいです、はい！　お姉ちゃんがまたおかしくなってしまうの\nで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113960003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "修羅姫" ]},
		{"command":[ "SETTEXT", "「一人で良い子ぶらないで。あなたにも感動を与えてあげるわよ？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001604_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_016_010113960007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「感動も婚活ももういいです！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "5", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_017_010113960004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「婚活……っ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "2", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ん？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はあ……元を正せば、婚活……ねえ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "1", "CENTER", "0" ]},
 		{"command":[ "PLAYVOICE", "v2_003_010113960015" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……なんか、よっぽどのことがあったんだろうなあ、今回の発端は。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、元気出せよ。その内良いこともあるだろうさ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「……あーあ。カツマに気遣われるようじゃ、あたしもホントお終いだね！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000311_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_003_010113960016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "STOPBGM" ]},
