		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「もうこんなに熱く硬くなってるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00006701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「隊長……気持ちいい？」", "NORMAL" ]},
