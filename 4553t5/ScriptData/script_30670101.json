	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「あははっ！　お盛んねぇ。いいわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103102" ]},
	{"command":[ "SETCHARA", "0", "char_00006701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「どう？　私は貴方の思うようにパワーアップ、出来ているかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103103" ]},
	{"command":[ "SETCHARA", "0", "char_00006701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「まぁ、実際の所パワーアップなんて私はそれほど重視してないわ。重要なの\nは……隊長、貴方が満足しているかよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103104" ]},
	{"command":[ "SETCHARA", "0", "char_00006701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「皆、こんな下品な貴方に付き合っているのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ふふ……いいわよ、遠慮せずに、感じて……そのためにやっているのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103106" ]},
	{"command":[ "SETCHARA", "0", "char_00006701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「これも訓練だというのなら、私は喜んでやるわ」", "NORMAL" ]},
