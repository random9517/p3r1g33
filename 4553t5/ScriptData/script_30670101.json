		{"command":[ "SETIMAGE", "0", "still_00006701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「擦りあげて……ゆっくり上下に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00006701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んっ……だんだん、限界が近くなってきたようね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00006701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「そろそろ仕上げに入るわ……んちゅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「もうこんなに先端から透明のどろっとした汁が出ているわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ほら……感じてるかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「わかったわ。ほら、もっと感じて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「随分長い間、溜めていたようね。今にもはち切れそうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00006701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「私のこれは……貴方を満足させられているかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00006701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「訓練の為なら……貴方が気持ちよくなるためなら、私の身体、使ってちょう\nだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00006701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「熱いわ……貴方の欲望の熱が、胸を通じてひしひしと伝わってくるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「チンポを抱きしめるように、そっと優しく包み込んで……どう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00006701_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「それほど上手くはないけれど……気持よくなってくれれば嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「そう、これも訓練……強くなるための、ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んぐぅうう……んっんぶぅううっ……の、喉の奥まで……入り込んでくるわ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00006701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「凄い……舌の上で鼓動を刻んで、跳ねているわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「濃いオスの臭い……これを嗅いでいるだけで頭がくらくらしてしまいそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「溢れてきた……全部、舐めとってあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「すごい……どろどろよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00006701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「真っ白なねっとりしたこの精液……貴方の欲望の象徴ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「こんなに出したのに……まだ弾けそうに大きいわ……」", "NORMAL" ]},
