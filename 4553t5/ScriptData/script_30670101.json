		{"command":[ "SETIMAGE", "0", "still_00006701_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「じゅるるるるぅううう……ねばついた汁が、どんどん溢れて……口の中がい\nっぱいになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んぐむぅううう……隊長のチンポが……私の口をもっと犯そうと乱暴に入っ\nてくる……ふぐぅうううっん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_067_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
