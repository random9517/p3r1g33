		{"command":[ "SETIMAGE", "0", "still_00006701_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「ぐっんむぅうう……隊長のオスの香りが……鼻に抜ける……」", "NORMAL" ]},
