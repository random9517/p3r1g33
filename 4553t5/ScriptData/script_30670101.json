		{"command":[ "PLAYVOICE", "v2_067_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00006701_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
