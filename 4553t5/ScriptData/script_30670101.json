		{"command":[ "SETIMAGE", "0", "still_00006701_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「こんなに逞しいなんて……つい見とれてしまうわね」", "NORMAL" ]},
