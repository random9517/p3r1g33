		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アディー隊員" ]},
		{"command":[ "SETTEXT", "「んぐぅっ……ふぅ、んっ……はぁ、はぁ……んむぅううっ！」", "NORMAL" ]},
