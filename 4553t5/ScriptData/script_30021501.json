{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「アイドル修行をすると聞いて、参上した。ニンジャの修行は私の得意とする\nところだが、アイドルの方はまだ勝手は分からぬのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503101" ]},
		{"command":[ "SETCHARA", "0", "char_00000215_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「……厳しい修行？　ふん、それがどうした。私はいつも、日々辛い修行を耐\nえ抜いて今に至る。臆することなど何もない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「拘束をする……？　ふん……いいだろう。ニンジャは、様々な局面での戦い\nを想定する。好きなようにするがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ……なるほどな。四肢をそれぞれ独立した形で縛り上げる……ニンジャ\nなら、こうした時の縄抜けも……違う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000215_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「刺激に耐える訓練……？　フン、それも問題ない。私は痛みに対する訓練を\n何度もこなしている……何も問題は……ワッザ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「快楽の試練っ……！？　ヌゥ……なるほど……アイドルともなれば、痛みと\nは別の訓練を行うというのだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「よかろう……私は逃げも隠れもしないっ、お前の思う通りにするがいい……\nあっ、んぁぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「なっ……何だ……この振動は……んんっ、ブルブルと小刻みに震えが伝わり\n……んむぅっ……ふっ、んくぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「乳首に直接……んんっ！　この振動は何と形容すればいいのだ……んむっ…\n…痛みではない……くすぐったいという程でもない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「だが、常に……何かされているということを意識せざるを得ない……んんっ\n、中々厄介なシロモノだ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「それに……改めて、このポーズ……むぅ……何という、破廉恥さ……！　ん\nっ、くっ……羞恥とも戦わねばならぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんっ！　こ、今度は何だ……？　あ……ふっ、こ、股間の方の機械からも\nっ……振動がっ……んんぅっ、くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「こ、こちらの方は……最初から……強い……あっ、んんっ……割れ目にぴっ\nたり当たって……あっ、ウネウネ……動くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、くぅぅんっ……！　これがっ、オマンコ……ローター責めっ…\n…！　何という卑猥なっ、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「わ、分かっているっ……！　この刺激に耐えることこそがっ……アイドルと\nしての特訓！　この私は……逃げも隠れもせぬっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……だがっ、あっ……おぉっ……あっ、自由が効かぬ中で……んっ\n、この震えは……はっ、んっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ウカツ……！　思った以上に……集中が乱れるっ……身体が、くねって……\n妙な声が……あっ、出て、しまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「何……声はいくら出しても構わない……？　くぅぅ……んっ、だが……耐え\nられないように思われるのも癪だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんっ、私は……乗り越えてみせる……んんっ、乳首も……オマンコもっ…\n…まだまだ、耐える……あひっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、あぁぁっ……し、振動が強くっ……はへっ、あひっ、あっ、あ\nぁっ……さっきのは、まだ遊び……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「くぅっ……これしきのことっ……はぁっ、んっ……乳首が凝った程度……ま\nだ、何でも……ないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、ニンジャとしてだけでなく……アイドルとしても一流を目指す\nのだっ……快感を堪えてみせるっ……あふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あっ……な、何をしている……チ、チンポを見せつけて……んっ、自ら扱く\nなど……どういうつもりだっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……くぅっ……私の表情で興奮しただと……うぬぅ……んっ、顔\nに出ていたのか……不覚っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「しかも……も、もう一つ……その機械を……ま、待て、どうするつもりだ…\n…まさかっ、あっ、あひっ、ひぃぃぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あっ、んぁぁぁぁっ！　くぅぅぅんっ！　しょ、しょこはっ、あぉっ、ひっ\n、んんっ……クリっ、クリトリスぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ど、どういうつもりだっ……はぁぁんっ、この上……更に刺激が重なるなど\nっ、聞いていないっ……ふひっ、はひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁっ……し、振動が響くっ……！　クリトリスはらめっ、よ、弱いっ……\n！　鍛えてないっ……敏感な場所ぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ひぅぅぅんっ！　オッ、オマンコと一緒にっ……ぐりゅぐりゅしてっ、はへ\nぇっ、あひっ、ち、力が抜けるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んぁっ、あぁぁ……マズい……実際マズいっ！　ここまでっ、あっ\n、震えが……一度に来ることは想定していないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んふぅぅっ……刺激っ……強くてっ！　し、汁が垂れてしまうっ……くぅぅ\nんっ……あ、おっ……あひぉっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「耐え忍ぶっ……！　それがニンジャっ……けどっ、こ、これは知らないっ…\n…こんな気持ちいいのはっ、耐え……きれないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「くぅっ、ク、クリトリスがっ……強すぎるぅっ！　あっ、はぁっ、んんっ…\n…！　こ、このままだと……あっ、イ、イッてしまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「くぅんっ……お、お前も……そんなにこれ見よがしにっ……チンポを扱いて\nっ……私と一緒に出すつもりなのかっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あっ、くぅぅっ、だ、ダメだっ……振動が強くてっ……あひっ！　イッ、も\nうっ、あぁっ、イクっ……くぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　あっ、あぁっ……精液もっ……飛んでっ……ふぁぁっ、あぁっ\n、身体っ……べっとり出て……んふぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぷっ……あへぁ……イ、イッてる……ローター振動強くて……あ\nへぁ……耐えられなかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んうぅぅ……あっふ……あぁ……アイドルらしからぬ顔をしている……？　\nうぅ……ウカツ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「まさか、ここまで厳しい特訓だとは思わなかった……あぁ……絶頂を我慢す\nるのは……難しいのだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ……まだ顔が緩んでしまってる……もっと気を引き締め\nねば……んむっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ふっ……んぁっ、あっ、ま、待て……んんっ、あっ、お、終わりではないの\nかっ？　また……振動が強くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503202" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「イ、イッた後の……敏感な状態で耐え忍ぶのが……本当の修行っ……！？　\nそ、それは……あっ、あひっ、あぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はふっ、あぁっ、こ、今度の振動は……さ、さっきより……あっ、強い……\n！　これをっ、凌げというのかっ、あっ、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「うっく……だ、だが……私もニンジャ……！　快感の試練にも耐えて……見\nせるっ！　んふぅっ……ふっ、んくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんむっ……だ、がっ……これはっ、あっ、あんっ、はっ、くぅっ、あっ、\nあぁっ……力が……入らないっ、くっ、ぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「オ、オマンコへの……振動がっ……くふぅぅっ……強くてっ、ビクビクする\nっ……あひっ、んひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ほ、本当に敏感なのにっ……あっ、おぉっ、割れ目っ……あぁっ、こんなに\nっ、またっ、あっ、んぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ……お前もっ……また、そんなに激しく……チンポを扱いて\nっ……くぅっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「そんなに、私の痴態を見たいのか……あぁっ、いやらしい格好をしたアイド\nルでっ、興奮しているんだなっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「だんだん……分かってきた……！　んっ、この視線に耐えて……いやらしい\n気持ちを克服し……快感に負けぬようにするっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「そうと分かれば、もう簡単には……あっ、あひっ！　乳首……あっ、またっ\n……んんっ！　震えっ……続けてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　ク、クリトリスもっ……！　待てっ……ど、同時にするのはっ\n……ひっ！　オ、オマンコまでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「さっきと……違うっ！　全部っ……強くてっ、あぁっ、ぎゅって……押し付\nけられてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はひぃっ！　お汁っ……溢れるっ……！　気持ちいいのっ……また上がって\n来てしまうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅっ……我慢っ……我慢だっ……ニンジャはっ、快楽にもっ……お\nぉっ、あひぉっ、クリッ……いいっ、ふひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「む、無理だっ……我慢無理ぃっ……！　こんなの耐えられるワケがないっ、\nイクっ……また、オマンコッ……イキそうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あぁっ……そんな、見せつけるようにチンポ……扱いてっ！　私に……ぶっ\n掛けるつもりなんだなっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「一緒にっ……あぁっ、そんな風に言われたらっ……もう絶対我慢できないっ\n……！　イクっ……無様な姿を晒しながらイクっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ……もう何でもいいっ、何でもいいから掛けてぇっ！　私にお前\nの精液ぶっ掛けてっ……んひぁぁぁぁっ、イクぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんんんんーっ！　はぁぁっ……また……ぶっ掛けられてるっ……イ、イッ\nてるオマンコに……ドロドロザーメンっ、ぶち撒けられてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……何という恥辱っ……だが、何という快楽っ……こんな体験……味\nわったことがない……気持ちいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ま、まだ振動が……プルプルするぅ……はぁぁ……蕩けそうだ……こんなの\n……んんっ、おかしくなるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁっ、あぁっ……射精……終わった……？　ん……ふっ、全部\n……身体に浴びてしまった……ザーメンの臭いがすごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっく……まだ、ローターが震えている……あっ、あっ……んんっ\n、も、もう止めてくれ……またイキたくなってしまうからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　んふっ……！　あぁっ……イ、イッたぁ……。はぁぁ……目\nの前に火花が散っている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はふ……アイドルというのは、本当に厳しい研鑽を積んでいるのだな……私\nも、もう少し認識を改めねばなるまい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「痛みに対する訓練だけでなく、快楽に対する訓練か……耐えなくてもいい？\n　受け入れられる度量を持つ……そ、そういうものか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「確かに、快感と共にあるという考えには至らなかった……私もまだまだ修行\nが足りぬな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「それはそれとして……そろそろ拘束を解いてくれぬか？　この格好は……い\nい加減、大変なのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁっ！　あぁっ……顔に掛けられてっ……んぁぷっ……！　ザーメ\nンまみれにさせられてるぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んふぁっ……イ、イッてるっ……オマンコイキながらっ……ザーメンシャワ\nー……浴びてるぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……あぁっ、まだ、振動が止まらないっ……こんなのダメだ……\nおかしくなるに決まってる……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁぁ、あふぁ……射精……終わった……？　はぁ……はぁ……んんっ、私\nの方は……まだ、波が……引いてない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000215_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「んんっ……くぅぅ……腰がぷるぷる跳ねて……み、みっともない姿を晒して\nいる……あぁ……あ、あんまり見ないでくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「はぁ、ふぅ……はぁ、はぁ……こんなにも修行が厳しいものだとは思わなか\nった。アイドルを舐めていた訳ではないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「この快楽への試練は、全く想定したものではなかった。まだ、身体全体が快\n感に包まれて、ふわふわしている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「この快感を支配してこそ……アイドルニンジャ……！　そのような境地には\nまだまだ至らなかった……ナムサン……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「うむ……まだまだ鍛えねばならないことは沢山ある……また協力してくれる\nならばありがたいことだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤＤ" ]},
		{"command":[ "SETTEXT", "「それはそれとして……そろそろ拘束を解いてくれぬか？　この格好は……い\nい加減、大変なのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1503410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}

