{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0010" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「――ハッ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "あ……れ？　おい、俺はなんでまた寝てたんだ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "陛下と、姫さんは？　それに、ここは……どこだ？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ようやく起きたの？　まったく、よくそんなに寝られるわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "え？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「人の気も知らないで。心配して損をしたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "エファ……？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「私を放って仲間と飲み歩いて、挙げ句に前後不覚になって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「呂律の回らない口調で『愛してる～』なんて電話してきたから、心配になっ\nて来てみれば」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "愛してない、と思うぞ。それこそ、酔っても口にしないセリフだと思うんだが\nなー。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まさか、独身時代最後の飲み会、なんて言ってたのも、嘘じゃないでしょう\nね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940005" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「独身……？　おいおい、まさか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「姫様や陛下との、その、結婚だなんだとかいう冗談、まだ続いてるのかあ？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「……姫様？　陛下？　誰よそれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940006" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……あれ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まだ寝惚けてるの？　まさか、私という婚約者の顔を忘れたんじゃないでし\nょうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "はあっ！？　婚約者ぁ！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まさかとは思うけど、マリッジブルーで大暴れした、とか言わないでよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940008" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マリッジブルーとか……それ以前の問題なんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「じゃあ、この惨状は何？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940009" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「惨状？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "お……おお！？　なんで部屋の中に虎がいる！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「可愛いわんこだけど、どこで拾ってきたのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940010" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "わんこじゃねえし！！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「あとほら、そこのソファ。可哀想だったからひとまずタオルをベッド代わり\nにしたけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああん？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "うぉい！！　誰の子供だ！！　なんで赤ん坊がここにいる！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「私、あなたの子供を産んだ覚えはまだないんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940012" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺だって身に覚えがねえよ！　……ないよな？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「何、自分の下半身を確認してるのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940013" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ど～ん！！　カツマちゃんいる～？　あ、いた～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだなんだなんだあっ！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ちょっと！　いきなり入って来て、あなた誰？　カツマから離れなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940014" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "まったくだ……お、おう……胸で、おっぱいで……乳圧で窒息する……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「あんたこそ誰～？　ディアナちゃんは～、カツマちゃんのフィアンセで～す\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "はあっ！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「何言ってるの！　フィアンセは私です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940015" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「え～？　だってディアナちゃん、昨日の夜、お仕事先でカツマちゃんから熱\n烈なプロポーズを受けたよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「し……してねえ、と思うんだが。ぷはっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちなみに、お仕事先、とは？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「いやん♪　ストリップ劇場最前列でかぶりつきだったじゃない、カツマちゃ\nんたら☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940004" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ストリップ……ぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ヘビに睨まれたカエルの気分なんだが！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "えーっと、これは、あれか？　俺には記憶が一切ないし、状況も不可思議過ぎ\nるんだが――。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "婚約者（エファ？）がいる身でありながら、風俗（ディアナ？）で羽目を外し\nた系男子（俺？）というシチュ、なのか？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ほらこれ！　指輪も貰ったよ？　おばあちゃんの形見なんだって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940005" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「私だってまだ貰っていないのに……貧乏だからって、婚約指輪さえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940017" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "万年金欠なのはこの状況でも変わらないのか、俺……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「警察です。全員その場から動かないようになのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「今度はなんだ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ウチのパトカーを盗んだ男が、ここにいると聞いて来てやったのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ああ！　表に停まってたの、あれカツマちゃんのだったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940006" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺のじゃねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "たぶん。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「カツマ……あなた、酔って見知らぬ女性に求婚した挙げ句、窃盗まで……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940018" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「私との婚約が、そんなにストレスだったの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "哀しげに言うな！！　この状況そのものがわけわからんストレスだが！！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「窃盗だけでなく、結婚詐欺まで働いているのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940003" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「や～ん、カツマちゃんってば、悪いオ・ト・コ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940007" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「濡れ衣だ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ちょいと待ちな！　そいつがカツマって野郎かい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030021940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今度はお前かー！！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ウチのシマから大金を盗み出すなんて、ずいぶんと大胆な真似をしてくれた\nじゃねえか、ええ？　カツマさんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030021940002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「窃盗２件目ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940004" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「や～ん、カツマちゃんってば、超悪いオ・ト・コ☆」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940008" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「濡れ衣だ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「カツマ……指輪を買えなかったからって、強盗までして資金を用立てようと\nしてくれたなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940020" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "してねえ！　人生を棒に振りすぎだろそれ！！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「……被害者たちの証言と、この部屋の惨状から推理するに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940005" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「大方、その男が酔っ払ってあちこちでしでかしたんでしょう。だからといっ\nて罪は消えないのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まったく身に覚えがないんだが！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「状況証拠がこれだけ揃っているのですから、おとなしく罪を償うべきなので\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「即決裁判で銃殺にしてあげるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「横暴だ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「婚前未亡人は困るわねえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940021" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや縁起でもないからそれも！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まったく、世話の焼ける。それもまた可愛いところなんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940022" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いやなんか……そんな、生暖かい目で見られてもな。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「まず、そうねえ。そこの、自称婚約者のあなた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940023" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「うん？　ディアナちゃんのこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940009" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「指輪を受け取っただけでは、婚約は成立しないのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940024" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ええっ？　そんなのってある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940010" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「私と彼のように、はいこれ。こうして書類に記入捺印したものがないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940025" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "は？　いつの間にそんな物が？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「誓約書、ですか。ふむふむ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940009" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「なんだあ？　『カツマはエファを一生愛することを誓います』？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030021940003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「こんな恥ずかしいセリフに、サインまでご丁寧に添えてるんじゃあ、裏切れ\nねえんじゃねえの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030021940004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それも酔っ払ってサインを書かされたとかじゃないだろうな？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「ほかにも、はい。生命保険に財産分与の覚え書きも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940026" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "用意周到だなおい！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「保険金詐欺の臭いがぷんぷんするのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940010" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「確かに受取人は私だけど。あくまで老後のためよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940027" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「奪った金については、老後じゃなくて今すぐ返して欲しいんだがなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030021940005" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだこの、俺の命で補填しろ的な流れは。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「一応、手続きとしては問題なさそうですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940011" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「いくら婚約者が身元を保証したところで、無罪放免とはいかないのですよ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃんも、難しいことわかんなーい！　今すぐカツマちゃんと結婚\nするの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940011" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「それぞれに勝手なことを言われても、ねえ……仕方ないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940028" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「カツマの婚約者である以上、彼の面倒は私が見る。彼を守るのも、妻に\nなる者の務め」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021940029" ]},
		{"command":[ "SETCHARA", "0", "char_00000305_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「文句のある奴は、かかっておいで！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021940001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やる気満々で変身しやがった！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「おう！　その方が話が早ぇぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_030021940006" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「公務執行妨害ですね、受けて立つのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050021940013" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「ディアナちゃんはディアナちゃんの幸せを今度こそ掴むんだから～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_040021940012" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "またか！？　また俺を巡って争うのか！？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}