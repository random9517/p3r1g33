	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「少しいいか？　隊長……。他の者には聞かれたくない話があってな、わざわ\nざこうして呼び出したわけだが……。うん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00015601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「その……襲来者のリーダーである私を虐待もせず、差別もせず、丁重に扱っ\nてくれたこと……感謝している。何か礼をしたいと思って調査したところ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おまえは……この部屋で、女の胸を揉んだりいじったりするのが好きだと聞\nいた。だから、今日はこの胸を自由にしてもらってかまわない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「まあ、吸ったり舐めたりされたら困るが触るくらいなら……。って、オイ！\n？　おいおいおいっ、な、何をやっている！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015601_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んぁッ……！　な、なにぃっ！？　に、人間の男が喜ぶと聞いたのは、胸を\n触ることで……！　や、やめろおかしなモノを挟むなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103105" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こ、股間だろうっ、そこは！　うっ……な、なんだソレは！　うひぃいいっ\n！　押し付けるな、ねじこむな……アッ、あっあっあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「生温かい……硬い……くさいっ！　何？　チンポ？　男性器……生殖器！？\n　なんだそれは！　聞いたことも見た事もない！　うひいいっ、ひぃい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ピクピク動いている……！　嘘だろうっ……！　お、おまえの、隊長の身体\nから独立した器官なのか？　神経が繋がって……ううっ、あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103108" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「妙な汁が滲み出してきているぞ！　コレは一体……！　き、気持ち悪い……\nなんてグロテスクな……。抜けっ、話が違う……！　んんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こちらの宇宙の人間は、胸にコレを挟むのが好き……？　そう、なのか？　\nそうすると気持ち良くて幸せになる？　うっ……チンポ、チンポをか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「チンポを挟んで、谷間でシゴいてパイズリするのが友好の証で感謝の証明？\n　……さすが異文化、私の想像もつかない行為を要求してくる！　が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「チ、チンポとやらの感触がどうにも好きになれん！　熱いし表面がグニグニ\nしているし……そのくせ中は硬く芯が通っていて……。あと臭い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103112" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「変なニオイがして、こちらを威圧してきて……！　コレをシゴく？　慰める\n？　愛することが礼だとは私には到底思えな……。あああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うごっ、動かすなっ！　チンポ！　チンポ動かすなぁっ！　んッ……はぁっ\n！　はぁっ、あぁっ、嫌だ、やだ、いやだ、あっあっあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「胸の間……チンポでいっぱいにされてっ……！　にゅりゅっ、にゅりゅって\n谷間からチンポの頭が飛び出してくるっ……！　うぁっ、うぁ、うぁあ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おまえっ、おまえはこんなことが好きなのか……あぁあっ！　私から胸を差\nし出したんだから、遠慮なく使う？　それは……それは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あうっ、ぅっ、んんんっ！　それはこういうことじゃなくて……！　ううっ\n、……あっ、どんどん、どんどんチンポが太くデカくなってきた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103117" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「き、気持ちいいのか……こんな野蛮な行為がッ！　チンポ、チンポを胸でシ\nゴいて……あああっ、ぐりぐり、ズリズリ出したり入れたりぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっ、ンンッ……んっ、ん、ん……！　やめさせたい、やめさせたいが……\n私の爪でおまえに触れたら、おまえを傷つけてしまう……だから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「チンポ、チンポを入れられるのを我慢するしかないのか……！？　んうっ…\n…ニオイ、臭いもどんどんキツくなってきた……ううぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「な……何をニヤニヤしているっ！　何？　重くてハリがあっていいオッパイ\n……？　精液がどんどん作り出される？　お、おまえぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「圧迫感がちょうどいい？　乳首……がデカくて勃起して……って、こらぁッ\n！　そんなにまじまじ観察するな！　見るな見るなァッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……あっ！　っうっ、うぅっ！　んううっ、ううっ……！　本当に……これ\nが人間の、よ、喜ぶことなのか……おかしいだろうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「自分の股間を……あうっ！　女の胸にうずめて、……はぁっ！　叩きつける\nように、打ちつけるように……チンポを、チンポを出し入れ、してっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「硬いモノで柔らかな肉を……いたぶって……あああっ！　こすりあげて、…\n…なすりつけて……ンンっ！　チンポ全体で味わって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こ、こんなことが好きだというのならこっちの宇宙の人間はヘンタイだろっ\n……！　っああああっ！　ニュブニュブしている、あっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「チンポっ……！　チンポというのはっ、グ、グロテスクだ……！　エイリア\nンの触手のようで……こ、これが隊長の生殖器……いやだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「なんか、もっと可愛いモノの方が良かった……。あっ！　んふっ……！？　\n揺らすなっ、揺らすな……胸だけじゃなく上半身まで動くっ」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あッ……あっ、あっ、あっ、はぁ、はぁ、はぁ……！　これはどういう儀式\nなんだ……。えっ？　疑似的な性交？　膣の代わりに胸で……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「なんだと！？　わ、わ、私は今、胸で、胸の谷間でセックス！　子作りをさ\nれているのか！？　そんな……！　あっ！　考えたこともなかったっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「人間の男はっ、あっ！　女の胸にもそんな感情を……性欲を向けるのか！？\n　あっ……セックス？　胸でするセックス！？　そんな……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そんな恥ずかしいことを、私は……！　あうっ、あっぁっあっ、か、顔が熱\nい……胸がジンジンする……恥ずかしい、ヘンタイ、ヘンタイぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっ！？　精液出したくなってきた？　せいえき……？　せいえきとはなん\nだ？　い、今っ、チンポの先から出てる透明な汁とは違うのかッ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「もっと臭くて？　……こ、これ以上くさいのかっ、白くてネバネバしたのが\n大量に出る？　この穴から！？　ほ、本気かっ……冗談だろうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ダメだっ！　せいえきとかいうヤツを出すのはだめ、だっ……！　あぁッ！\n　あぁ……はぁっ、はぁっ、はぁ、そんな得体のしれないモノぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私に出したら容赦しないぞ！　……やめろぉ……あっ！　やめっ……やめろ\n！　コラッ！　照準を定めるな……本当に怒るぞ！　ひ、ひり出すなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「離れろぉ……っ、あぁっ！　あっ！　あっ！　おいっ、おいっ……おいぃっ\n！　バカッ！　ばかばかばかっ！　せいえきなんかいらんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うッ、うぁあああああっ！　なんだこれぇええっ！　うぁっ、うぁっ、うあ\nああっ！　信じられないっ！　せいえきっ、せいえきぃ！？　コレが！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「すっごい勢いで胸にかかって……。蒸れた臭いで頭、ヘンになりそうで……\n！　どこにこんな量隠してたんだよ、出し過ぎ、出し過ぎぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うわっ……また飛び出した！　……元気すぎるだろうっ……！　エイリアン\nか何かが飛び出してきたのかと思っただろうっ……バカっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「はぁああっ……。しかし、やっとわかった。これがこっちの宇宙の礼のやり\n方……。隊長を喜ばせる方法ってことなんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こ、こんなことしたことなかったし……知識の中にも入ってなかったからす\nごく驚いたよ。次々驚愕の事実が出てきて……で、でもさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私はもう、こっちの宇宙にきちまった。それで……あんたと、隊長と一緒に\nいることになったんなら、こっちのルールに従わないとな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……私、覚えるからさ。パイズリ？　ってやつ……だから……もう一度やっ\nてみせてほしい。教えてくれ、こっちの宇宙の感謝の方法……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「っんッ……ふぅっ、せ、せいえきは……洗い流さなくていいんだな？　出し\nたやつのヌルヌルで、チンポすべらせて……胸、押し付けて……はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ま、またズリズリして……。……ンンンッ！？　せいえきのドロドロで滑り\nが良くなって……なんだ！？　にゅるんにゅるんって勢いついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……あっ！？　か、感じちまうっ……私の胸、疼いてたまらないっ……！　\nさっき、透明な汁塗りたくられてた時よりずっと……イイ！　いいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あぁっ……！　なん、か……エッロい音してるしさぁ……！　グチュッ、グ\nチュッて……私の胸の中でせいえきかき混ぜられて……！　っふぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「なんていうか、このっ……本能に直接刺激が来るカンジっ……！　全身が敏\n感になって……あっ！　あっ、意識が全部胸にっ、集中してっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「チン、ポ……シゴくの気持ち良くなってきちまった……！　あっ、ぁっ……\nもっと、もっと強くぶち当てろよっ……ねじこめっ、強く、強くっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私も感じたいっ……チンポで胸気持ち良くされたいっ！　……アッ！　そう\nっ、そうだ……もっと胸の肉っ、鷲掴みにして寄せて……！　そうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そのままっ、そのまま腰を打ちつけて……！　あっ！　あっ！　すっげぇエ\nロいよぉ……！　」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「隊長のチンポっ、せいえきでヌラヌラ光って、ヌメっててエロいぃ……！　\nそれもっと、もっと谷間に入れて……摩擦でっ、あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「グチュグチュって……ズプズプって……！　あっ！　痺れるっ……私の胸、\nビリビリして……なんか、なんかクる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ふぁっ！？　アッ！　あっ、ぁっぁっあっ……！！　ヤバイっ……！　これ\n……これ、こんなの知らないっ……パイズリ、パイズリスゴいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んはっ……ああっ、あっ！　おっ……おっ、おぉっ！　んふぅううっ……！\n　こすれるっ……あっ！　あっ、隊長のチンポ暴れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっ！　ぁっ……奥までっ、胸の奥まで突き刺さって……はぁあっ♪　どん\nどん、どんどん熱くなって……！　あっ……あっ、あああああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「それ以上したら……あっ、私の胸、胸が壊れるぅ……！　あっ！　チンポ、\nチンポ強すぎて……！　あっ！　あっあっあっあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ま、また出したくなってきた？　そ、そんなの私が知るかぁっ……勝手に出\nせばいいだろうっ……！　それに……それに、……ぁっ、うっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私、私の方がヤバいんだよっ……ああああっ！　クるっ、なんかクるっ！　\nチンポ気持ち良くて、胸……胸に電流が走って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んぁあああああっ、ああああっ！　んぁあああっ！　うううう～～～～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あふッ……はひぃっ、ひぃいっ……！　今、目の前が真っ白になって……！\n　あっ！　ドクドク、ドクドクせいえきが……ハァ、ハァ、ハァハァ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「脈打ってんのは私の胸か？　隊長のチンポか？　もうわっかんないよ……。\nパイズリって……こんな激しい行為だったのか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「せいえき……胸全体にべったりはりついて……。隊長、なんでせいえきって\nここまで強い臭いがするんだよ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「動物のマーキングと同じ？　あっ……じゃ、じゃあ私……私はおまえの、隊\n長のせいえきに染められて、隊長のモノになったってことなのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103305" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そんな……。そ、そこまでの無礼を許したつもりはなかったけど……。でも\n、そんなスッキリした顔されたら、嬉しくもなってしまう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私の胸でするパイズリ……き、気持ち良かったか？　そうか……。んっ！　\nわ、私は……。あ、ああ、まあ……うん。気持ち良かった。でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こっちの宇宙の人間に関する知識が足りな過ぎた。ギョッとすることばっか\nりだ。だって、見てみろ……このせいえきの量、異常だろうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こんなものがビュービュー飛び出してくるなんて、人間のことが少し恐ろし\nくなったぞ。それともこれは、おまえが飛びぬけてすごいだけか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うううっ……やっぱりクサい……！　私の生涯で嗅いだ全ての悪臭の中でも\n一番クサいっ……！　これに慣れる日なんてくるんだろうか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あぁっイクっ……！　あッ！？　なんだっ！？　顔に熱いものが……！　あ\nっ！　あっぁっあっ、せ……せいえき……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「どうして精液を顔にかけるんだっ……おまえは！　けほっ、んぷっ、口に入\nった……！　こらっ、やめろっ、やめろもういいだろうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ンンンンンッ……！　うううう……。顔中がせいえきで重たい……。だ、出\nすところを間違えたのか？　違う？　顔に出したかった……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「パ、パイズリをして出たせいえきを許可もなく顔に出すやつがあるかっ！　\nこ、このマスクはリーダーの誇りでありとても貴重なものなんだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「それを……それをこんな臭い汁で汚すなんて！　……れ、礼をしたいと言っ\nたのは私だが、あまりに非道すぎる！　……な、なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「最高に気持ちいいパイズリをしてもらったら、顔にかけること……顔射する\nことが人間の最大の賛辞……だと！？　何っ、そ、そうだったのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「賛辞……。賛辞なのか……。そうか……。そうか？　や、やはり異文化は底\n知れない……。だが、今度からは事前にちゃんと申告しろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「がんしゃ？　でせいえきを顔にかけると一言許可を取れ……って、んぶぅう\nうっ。また口にせいえきが流れ込んできた……に、苦い、臭いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「けほっ、こほっ……。信じられない目にあったぞ。つ、次は……礼をする前\nにおまえに相談して決める……。うううっ、私のマスクがぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ん？　もう礼をしないとは言っていない！　もう少し……こちらの宇宙の人\n間のことを、学ぶことにする。おまえも私にきちんと教えろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0103410" ]},
		{"command":[ "SETIMAGE", "0", "still_00015601_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}