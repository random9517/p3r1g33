		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はんっ、最初から血の繋がりがどうこうなんて主張をする気はないよ。イル\nルが嫌がってるかどうか、それが全てさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470017" ]},
