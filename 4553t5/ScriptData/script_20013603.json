		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「世俗ではそれを洗脳と呼ぶこともあると思います。どうやら、口で分かって\nはいただけないご様子……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470020" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

