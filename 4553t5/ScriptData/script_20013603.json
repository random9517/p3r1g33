{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んーっと……んっと、んっと……これは……８？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470001" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「おっ……当たりだよ。ちゃんと分かってるじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470001" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「当たり？　やったー、えへへぇっ、ちゃんとできたっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470002" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「もっと勉強嫌いかと思ってたけど、中々どうして飲み込みもいいし、意欲も\nある。育てたら伸びる子だよ、これは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470002" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっと……ここが……こうなって、あれ？　何か間違ってるのかこれ……？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「それに引き換え、コイツと来たら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470003" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おかしいな……絶対データバグってるだろ。何で、参照値が一致しねぇんだ\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「見てる場所が全然違うっ！　そこじゃないだろっ、こっち！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470004" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あれっ？　あー、いつの間に……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「いつの間にじゃないんだよっ……たく、まさか、こっちの方が何倍も手が掛\nかるなんて思わないだろ、普通……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470005" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ねっ、おかーさんっ、また見て見てー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470003" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「あぁ、待っとくれ。どれどれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470006" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「た、た、大変ですっ、エファナティカ様っ……て、敵襲がっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010022470001" ]},
		{"command":[ "SETCHARA", "0", "char_00000803_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「敵襲？　敵って……一体何が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470007" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ぷぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022470001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ヤ、ヤムっ！？　敵襲て……まさか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「おいっ、お前らヤバいって！　さっさと逃げろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022470002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はっ？　逃げろって、どういう意味……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぉわあぁぁぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふぅ……今のは、ちょっと追いかけるのが大変でした。見失うかと思いまし\nたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470001" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うあぁぁぁ……絶対振り切ったと思ったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022470003" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「中々、切れのある動きでしたが、やはり完全に気配を消すことは出来ないよ\nうですね。まだ修行の余地があると見ました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470002" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、何だこいつ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「下がってな！　この気配……ただ事じゃないよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470008" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「……おや？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470003" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470004" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「イルル……！　あぁっ……やっと見つけたわっ！　私の子……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470004" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ひゃあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470005" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「私がどれだけ心配したことか……！　でも、無事で良かったわ……貴方の身\nに何かあったらと思うと気が気でなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470005" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えと……え、えと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470006" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「さあ、いっしょに帰りましょう。大丈夫よ、もう決して目を離したりはしな\nいわ。私の可愛いイルル」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470006" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「や……やぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470007" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「イルル……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470007" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おかーさんっ……知らない人っ……イルルこわいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470008" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「イルル……私が分からないの？　貴方のお母さんっ……プルリーヤンカシュ\nですよっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470008" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ちがうっ……おかーさんはおかーさんだもっ……イルルのおかーさんじゃな\nいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470009" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「そんな……はっ……まさか、記憶が混乱していて……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470009" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「確かに、次元の歪みがあって……私のことを認識出来ていない可能性は否定\n出来ませんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うぅー、おかーさんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470010" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470009" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「はて……それで、貴方は一体どなたでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470011" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「人に名前を聞く時は名乗ってからってのが、最低限の礼儀ってもんじゃない\nのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470010" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふむ……それは、仰る通りかも知れませんね。私は、プルリーヤンカシュと\n申します。そこにいる、イルルヤンカシュの母でございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470012" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「イルル、あの母っていう人に見覚えはあるのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470011" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……んーんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470011" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「覚えがないってさ。悪いけど、母親はあたし……エファナティカ様で間に合\nってるんでね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470012" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「なるほど、エファナティカ様と仰るのですか。どうぞお見知りおきを……と\n言いたいところですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470013" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「勝手に母を騙るというのは、いささか穏やかではないような気がいたします\nが？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そっくり、そのままお返しするね。こんな怯えてる子に、一体何をするつも\nりだってんだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470013" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「貴方こそ、私の可愛い子に何を吹き込んで誑かそうとしているのでしょうね\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470015" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい……あのプルリーヤンカシュってのは、マジでイルルの母親なのか\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「確かそう……だった筈なんだけど、ヤムが見たのとは何か違うんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022470004" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「違うって……何が」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「何て言ったらいいか、分かんないけど……何か違うんだってっ……別人とま\nでは言わないケド……何か、こう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022470005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……もしかして、それがこの噛み合ってない感じの原因ってことか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470016" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_010022470012" ]},
		{"command":[ "SETCHARA", "0", "char_00016401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「その辺にしておかないかね。見るからにイルルが困ってるのが分からないの\nかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470014" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「確かに怯えているように見えます……が、それは自然な感情の発露でしょう\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470017" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「何だって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010022470015" ]},
		{"command":[ "SETCHARA", "0", "char_00000312_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「イルルが龍族の娘であるということは、貴方も承知しておりますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022470018" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「…………だったら、どうだって言うんだい」", "NORMAL" ]},
