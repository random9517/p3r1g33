		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「貴方が龍族でないことは、誰の目から見ても明らかだと思います。それでも\n、なお母親を騙るおつもりでしょうか？」", "NORMAL" ]},
