{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_01" ]},
		{"command":[ "DISPIMAGE","0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あのー。お、おっぱいを鍛えれば強くなるって本当なんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303101" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「しかも、隊長さんの……その、お、おちんちんを挟んでるし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303102" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「男の人のって、こんなに大きくなるものなんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303103" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「本当に特訓なんですね……？　えっ。それは何ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303104" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「太陽の石に感応する魔石……？　そんなものどこで見つけたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303105" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「いえ、その話は後にしましょうか……とにかく、それを使えば、特別な訓練\nが実施できると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303106" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あぁ、ＶＲトレーニングみたいなものなんですね。分かりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303107" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「それじゃあ……騙された気になって、えいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303108" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「…………ふふん、久しぶりの肉体じゃのぅ。ええ？　ところでおぬし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「パイズリで戦闘力が上がるわけがなかろうが、たわけが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303110" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「この娘は騙せてもわしをたばかることは出来ぬわ……くくくっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303111" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「なに？　わしが誰かじゃと？　そんなことも知らずに魔石を使ったのか、た\nわけめ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303112" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「おおかた娘を騙してパイズリさせようとしたのじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303113" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「よいよい、素直な童は嫌いではない。それで？　ほう……イカせて欲しいと\nな……良いぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303114" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「人間のオスにしては良いモノを持っておるではないか。気に入ったぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303115" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「この娘もなかなかの乳を持っておる……ふふ、ゴシゴシとしごき立てておる\nと、なんとも小気味良いわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303116" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「それにこの乳首……んんっ、素晴らしい感度じゃ、乳首イキできそうなほど\nに……んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303117" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ほぉれ……動きを大きくしていくぞ、少しずつ、少しずつ……おぉ、この感\n覚じゃ、たまらん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303118" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「むにっとした柔肉が硬い肉棒を包みこむ感触……いつやってもパイズリは楽\nしいのぅ……んふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303119" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「お主が何を言いたいのか、わしには分かるぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303120" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「物足りないであろう、単調におっぱいでしごかれるくらいではなぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303121" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ほれ、熟練の技を見せてやろうぞ……どうした？　まだイクには早いぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふふん、乳の谷間で肉棒が苦しそうに喘いでおるわ……ほら、どうした、根\n性を見せい、ほらほら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303123" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「…………なーんて、くっくっく。どうして突然やめたか、じゃと？　簡単に\nイッたらつまらんじゃろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303124" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「久々に肉のカラダを得たんじゃ、もっと楽しませい。おほっ、ほほほほほ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303125" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「切なそうにオチンポをヒクつかせおって……イキたいか……？　ふふん、そ\nうかそうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303126" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「仕方ない、イカせてやろう……ほれ、ほれ！　んふぅ、この娘の乳も良い感\n度……じゃ、ほぉ、おほぉぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303127" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んふふ、オチンポが乳の間で喘いでおるわ……んふふ、ほぉれ……このまま\nでもイッてしまいそうじゃが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303128" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「先っぽもイジメてやろうかの、尿道を……ほれっ！　ほれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303129" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ほほほ！　いま出してしまいそうになっておったろう？　もっとじゃ……も\nっと我慢せい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303130" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「尿道も、裏筋も、カリ首も、ゼンブ責められて一気にぶちまけてしまうのじ\nゃ……さぁ、さぁ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303131" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「おぉん、わしも乳首がこすれておるだけなのに、感じて……くぅぅ！？　お\nっ、来る……来るぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303132" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふああぁっ！！？　おほっ……♪　これはどうして、なかなか……素晴らし\nい量じゃ、カラダ中が精液まみれじゃぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303133" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「まだまだ出そうじゃな……んふっ、ふふふ……どうやら魔石の力はここまで\nらしい。また呼ぶが良いわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303134" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「…………はっ！？　なっ、ななな……今のは一体、何だったんですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303135" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「私のカラダが知らない人に乗っ取られて……えっ、気持ち良かった？　そう\nですか……それなら良かったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303136" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「まだまだ満足できないからして欲しい……！？　じゃ、じゃあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303137" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「私が、いま覚えたパイズリで……あなたを気持ち良くして差し上げます……\nんんぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303138" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はあぁ、私も、興奮しちゃってるから……まだ、物足りないんです……だか\nら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303139" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「今度こそ、一緒にイッちゃいましょうね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「うわ……あなたのオチンポ、とっても大きくて……熱くて。びっくりしちゃ\nいますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303201" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え？　さっきまでさんざんいじりまわしてたじゃないかって？　も、もう！\n　そんなこと言わないでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あれは、あくまでカラダを乗っ取ってた知らない人で……私がこうして、見\nたり触ったりするのとは、ちょっと感覚が違うんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303203" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そ、それじゃあ、やってみますね。私自身のパイズリ……んっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303204" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ど、どうですか？　こんな感じで、おっぱいでオチンポを挟んで、むにむに\nって……むに、むに……っと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303205" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「どうでしょう？　気持ちいいですか？　さっきの人みたいに、うまくできて\nますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303206" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「うまくはないけど、これはこれでいい？　ぎこちなさが、かえってたまらな\nい？　そういうものなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303207" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「よくわかりませんけど、とにかく、がんばります。えい、えい、えいっ……\nむに、むに、むに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303208" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あなたのオチンポの熱さと硬さが、私のおっぱいに伝わっ\nてきて……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303209" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ……乳首がこすれて……んんんんっ……気持ちいい……あああ……あっ、\nあん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303210" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ち、違いますよ！　乳首をいじるのに、夢中になってたりしません！　ちゃ\nんとやります！　大丈夫ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303211" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「わっ！？　急に何をするんですか？　いきなり腰を振ったりして……え？　\n協力してやる？　そ、そうですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303212" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、あああっ……私のおっぱいの間で、あなたのオチンポが上\n下して……はぁああっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303213" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あああ……犯されちゃってる。私のおっぱい、あなたのオチンポに犯されち\nゃってます……っ！　はぁ……はぁ……はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303214" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、ダメ、乳首をいじるの、やめられなくなっちゃいました。もう、指\nが止まらなくて……はぁあん！　ああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303215" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、気持ちいいっ！　乳首も、おっぱいの谷間も気持ちいいっ\n！　あぁああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303216" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ！　あなたのオチンポも、ひくひくしてきましたよ！　これは、たしかさ\nっきも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303217" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「やっぱりですか！　イクんですね！？　わかりました！　私、がんばりま…\n…きゃっ！　そんなに腰を動かさないで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303218" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、ああああ！　そんなにオチンポでおっぱいこすられたら、\n私、私……！　イッてしまいま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303219" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あああっ！　イッちゃうっ！　ホントにイッちゃ……あ、あ！　はぁあ\nあああああああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},
		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、はぁあああああああーっん！　あんっ、あんっ！　おっぱいの間に、あ\nなたのオチンポミルクが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんんんっ……おっぱいが熱いですっ……！　熱いミルクがいっぱいでて…\n…はぁあああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303302" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ああああ……おっぱいだけじゃなくて、顔にも、首にも、肩にも……！　ど\nうしてこんなに飛ぶんですか？　すごすぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303303" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ま、まだ出てる？　こんなに出るなんて、信じられない……どうしてこんな\nにたくさんのミルクが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303304" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あああ……はぁ……私、染まっちゃいました。あなたのミルクで、真っ白に\n染まっちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303305" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「匂いもすっかり、あなたの匂いになっちゃってますよ。えへへ、すごい匂い\nでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「それにほら、ベトベトになっちゃいましたよ。特に胸の谷間が……え？　な\nんですか？　さっきから言いたかったことがある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303307" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「さっきから谷間とか、なかなかの乳とか、おっぱいのサイズを強調してるけ\nど？　私のおっぱいはそこまで大きくない？　ひ、ひどいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303308" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「でも、かわいらしい？　控えめでかわいいおっぱいで、一生懸命にこすって\nくれた気持ちが嬉しい？　そ、そうですか？　えへへへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303309" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「それじゃあ、あなたが出したいときに、またこすってあげますね。あなたが\n、かわいいと言ってくれたおっぱいで。ふふふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「えっ！？　どうしてオチンポを引っ込めて……きゃぁあああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303401" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あああああああーっん！　んんんっ！　オチンポからミルクが……\n！　はぁあああん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ！　かかってる！　かかっちゃってます！　私の体中に、あなた\nのオチンポミルク……！　はぁああ……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303403" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あ、あああああっ……！　まだ飛んでくる……！　胸に、顔に……きゃっ！\n　髪にも！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303404" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ど、どうしてこんなにいっぱい、こんなに遠くまで飛ぶんですか……？　私\n、もう、全身にあなたの熱いのを浴びてしまって……はぁああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303405" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「すごい匂い……！　生臭さと青臭さが入り交じって……でも、なんだか興奮\nします……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303406" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え……？　今の私が、とってもかわいい？　それにエッチ？　そ、そうです\nか？　こんなにベトベトなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あなたのものを、全身で受け止めてくれたことが嬉しい？　そ、そうですか\n。えへへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303408" ]},
		{"command":[ "SETIMAGE", "0", "still_00013103_01_11" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「そんなことで喜んでくれるのなら、私、いつでもどこでもあなたのオチンポ\nミルクを受け止めます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303409" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ですから、いつでも言ってくださいね？　おっぱいでも、どこでも、あなた\nのオチンポ気持ちよくしてあげます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
