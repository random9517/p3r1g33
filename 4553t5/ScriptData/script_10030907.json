{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "状況は最悪だった。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "洗脳されている状態の生徒たちどころか、ルナテミスたちまで俺たちに襲いか\nかってくる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「み、みんな！　正気に戻って……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115870001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「くっ、こいつら……やけに強い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115870001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "生徒たちの相手をする夜叉。一方、バッケンローダーはルナテミスたちの集中\n攻撃を受けていた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだか、恨みつらみをぶつけているかのような攻撃だな。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETTEXT", "「はぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115870001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「やぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_010115870001" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミスの剣とバッケンハンターの銃弾を、バッケンローダーはかわしきれ\nずにくらってしまう。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガン・シスター" ]},
		{"command":[ "SETTEXT", "「えぇえい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_010115870001" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そこにガン・シスターの正拳突きが直撃した。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「バッケンローダー！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「大丈夫ですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115870002" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「こ……こいつらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115870002" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "戦闘力はバカみたいに高いルナテミスたちを相手に、バッケンローダーはボロ\nボロになっている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。どうしてこいつら……わたしばかりねらってくるのよ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115870003" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒ……それはこの子たちが、自分を不運にしている対象を攻撃するよう\n洗脳したからだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115870001" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「なにか恨みを買うようなことをしたんだね。胸に手を当てて考えてみな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115870001" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010115870004" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「バッケンローダー、惑わされないでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115870003" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、気にするな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなことより、よくもルナテミスたちを洗脳してくれたな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミたち、ついに気づいちゃったか。大戸岐学園の生徒たちを洗脳していた\n事実に！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115870002" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「いや……自分たちで言ってましたよね、洗脳って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115870004" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「時間帝国の手先として潜入させ、内側から崩壊させるという計画まで看破す\nるとは……さすがである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115870001" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「ヒヒヒ……計画の途中で発見されちゃったのは……不運」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115870002" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「いや……そこまでは気づいていませんでしたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115870005" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「関係ないね！　だって、キミたちはここで始末されるんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115870003" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そうか、さてはお前たち、Dr.サイレーン、ハルカプトラ、そしてグ\nリムロックのアナザーだな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「Dr.サイレーン？　ああ、そういえば刻の女王様がそんなこと言ってたっ\nけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115870004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「うむ、ハルカプトラというのは、我も聞いたことがある名前である」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115870002" ]},
		{"command":[ "SETCHARA", "0", "char_00002005_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「同じ名前の人物が同じ世界にいるなんて……。ウヒヒ……不運」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115870003" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「キミのいう通り、ボクたちはキミの知り合いのアナザーさ！　３人あわせて\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115870005" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "３人" ]},
		{"command":[ "SETTEXT", "『クロック・トリニティ！』\n『ファラオとしもべたち、である』\n『ブラック不運時計……』", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115870004" ]},
		{"command":[ "SETCHARA", "0", "char_00001803_01", "0", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00002005_01", "0", "CENTER", "600" ]},
		{"command":[ "SETCHARA", "2", "char_00002203_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこは揃えろよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "肝心なところでバラバラなのは、本物もアナザーもかわらないってことか？", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「は！　おまえらの正体なんざ、俺には最初っからお見通しだっつーの！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ほかにもアナザーの人たち、大勢でてますしね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115870006" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}