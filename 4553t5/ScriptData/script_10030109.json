		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「Ａセレーナ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114710003" ]},
		{"command":[ "SETCHARA", "0", "char_00001499_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「くっそー！　出てきやがったな！　シルバスター！　あいつをやっつける\nぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114710003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「待って！　二人で相手してたら、蝶が逃げちゃう！　セレーナ、お願い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114710005" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「よし、こっちは任せろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114710004" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエナファティカ" ]},
		{"command":[ "SETTEXT", "「そうは行くか！　こちらもセレーナを出す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「さあ、来い！　偽者めぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114710004" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「偽者はおまえだろ！　やんのかこらーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114710005" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
