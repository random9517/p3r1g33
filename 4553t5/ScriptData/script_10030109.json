		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ！　クリスタルモンキーレンチアゲハが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「クリスマスモンローコウカアゲハじゃなかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はははは、バカな奴らだ！　あれはクリ……クリ……むう！　言えん！　と\nても恥ずかしくて言えんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あなたたち、わざとやってるでしょ。クリスタルモンツキハカマアゲハよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00001499_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ええい、Ａセレーナよ！　アホに付き合っておる場合ではない！　蝶を追い\nかけるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114710002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「あ。行っちゃった……ってことは、つまり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私たちも、追いかけなければならないわけだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、疲れちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114710002" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そう言うな。私だって……私だってぇーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もう、やだやだやだやだ～！　蝶々なんか追っかけたくない！　めんどくさ\nい疲れたお腹減ったー！　地球に帰りたーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114710002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「ルナテミス様！　こんなところで駄々をこねないでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114710002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「やだったらやだー！　いくら下僕のためだからって、なんで私がここまで苦\n労しなきゃいけないんだー！　もう嫌ぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114710003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「仕方ないなあ……もう。それじゃ、わたしが様子を見てくるから、みんなは\nルナテミスをお願い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114710002" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「お、私も行くぜ。偽者に先を越されるわけにはいかねー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114710001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「悪いねえ。頼んだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114710003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「それじゃ、行ってきま～す！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114710003" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0186" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "と、いうわけで偵察に出かけた二人はしばらくして……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おおっ！　あれじゃないのか？　クリマンジュウフエスギアゲハ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114710002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんな怖い名前じゃないから！　クリスタルモンツキハカマアゲハね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114710002" ]},
		{"command":[ "SETCHARA", "0", "char_00001499_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルバスター" ]},
		{"command":[ "SETTEXT", "「よし！　さっそく捕まえよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_020114710004" ]},
		{"command":[ "SETCHARA", "0", "char_00001302_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おっと、待ってもらおう！」", "NORMAL" ]},
