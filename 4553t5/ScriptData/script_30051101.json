{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あの、それでは……約束通り……始めさせて頂きます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「マスク……ですか？　そんなもの……取るわけないでしょう。大丈夫です、\n口の部分が開閉出来るのですから、ご奉仕に支障はありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「もし、意地でもこれを取ろうとするのなら……今日の話はなかったことにし\nますが……どうしますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ええ、分かってくれたようで何よりです……。もちろん、ウチの我儘を聞い\nてくれた以上は、満足できるご奉仕をしますから……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「えと……では、ご奉仕の前に……ちょっとだけ……すぅぅぅっ、んっ、はぁ\nぁぁっ……んっ、くふぅぅぅぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あ……すみません。その……前々から、に、匂いが気になっていまして……\nあ、いえ、別に……悪い意味ではないのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「こんなことを言うのは、その……おかしいと言うか、恥ずかしいですが……\nこの匂いには何となく覚えがあるのです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「す、すみません……オチンチンの匂いでこんなこと……んふぅ……あ、あの\n……始めますね？　舐めさせて……貰います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷ……ぴちゃ……ちゅぱ……んちゅ、れろ……ぴちゃ……ちゅぷ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷ……味は、別に……普通で、懐かしさを感じることはない\nです……れろ、ぺろ……んっ、れろ、んれる……れる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「って、何を言ってるんでしょう、ウチは……すみません、変なことばかり…\n…ぴちゃ、んちゅ……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「えと……舌の動きは大丈夫でしょうか？　正しく出来ているのかどうか……\n少し心配で……ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「大丈夫ですか……んちゅぷっ、何となく……こうした方がいいのか……みた\nいなことは、少しだけ分かるです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、れろ……例えば、この鈴口の……割れている所……少し強くても…\n…んりゅっ、れるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「こういう風に押し付けるの……痛かったりは、しない……ですよね？　ぴち\nゃ、んりゅっ、れろ……ぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「良かったです……んちゅぷっ、では……もう少し、れる……れりゅぅ……ん\nれるっ、れろ、れろぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「まず、オチンチン全体……十分に……唾液で濡らすようにして……満遍なく\n舐めたら……今度は、深く……咥え、まふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「くぽぉっ、んんむ……こぷっ、りゅぷっ、んじゅぷっ、じゅるっ、はぷっ、\nんむっ、んじゅるるっ、んりゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁ……長い……口の中に余る位……んじゅぷっ、勃起が……立派に反り\n返ってまふ……んちゅぽっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ですが……んりゅぷっ、感覚は……とても繊細のようれふ……んりゅぷっ…\n…舌が当たると……すぐ、跳ねる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ……んふぅ……くすぐったいれふか？　んふっ……済みません、も\nう少し強い方がお好きみたいですね……んじゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっ、くぽっ、んぷっ、あぷっ……んちゅぷっ、不思議です……他に誰にし\nている筈もないのに……何となく、感覚が掴めてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……ウチの舌、ちゃんと感じていますか？　オチンチン……気持ち\nよく出来ていますか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「りゅぱっ……ちゅぷぅ……そうですか、よかった……この調子でいいのなら\n、もっともっと……感じて、もらいまひゅから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、んっ、くぱっ、ちゅぶっ、んちゅぷぅぅ……こうひて……湿り気\nのある音がするの……んふっ、不思議とゾクゾクします……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「もっと、じゅぱっ、鳴らしてやるといいれふね……くぽっ、んふぅっ、じゅ\nぽっ、んちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んっふっ、そ、そんなにジッと見ても、このマスクは取りませんよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ウチの顔のことは気にしないで……とにかく、オチンチンに意識を集中させ\nて下さい……りゅぱっ、くぷっ、んちゅぷぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁぁんむ……じゅぽっ、んちゅぷっ、んはぁ……くん……くんくん……ん\nぁ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103129" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あ……ウ、ウチ……また匂いを嗅いでいましたか？　ぅ……も、もう無意識\nでのことなので、気にしないで下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「でも……確かにそうなのです……その、このオチンチンの匂い……気になっ\nて仕方ありません……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「このムワッと広がる感じを味わいながら……じゅぽっ、んちゅぅぅっ、強く\n……吸い上げてっ……んふっ、じゅぷっ、くぷっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……出そう……れふか？　ちゅぷっ、はいっ……勿論、その為にしてる\nんれふから……じゅぷっ、射精……いつでもろうぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ひゃんと……お口で、受け止めます……んじゅぷっ、じゅるるるっ……飲ま\nせてっ……じゅぷっ、精液っ……らひて下さいっ……んじゅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんんんっ、ふぐっ！　出て……っ、んむっ、こくっ……んっ、んんんんん\nーーっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あぁ……んむっ、こくんっ……すごい、量……出てます……んっく、これ、\n全部……飲みきれるのか……こく、んく……んっく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んはっ、はぁっ、はふっ……はぁ……何とか……飲み、ました……精液、こ\nんなにも……出るんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ぺろ……ちゅぱ……味は、んっ……そう美味でもありませんが……鼻に残る\n、この濃い感じは……嫌いでは、ないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あぁ、やっと止まりました……簡単に飲むと言いましたが\n、結構大変でした……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ですが、しっかりとお役目を果たせたことは、自分でも誇れます。ウチのご\n奉仕で感じてくれて……ありがとう、ございます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あ……あの、どうしましたか。また……ピクってオチンチンが跳ねてますけ\nど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「い、今ので興奮したって……どこにそういう要素が……？　うぅ……困りま\nしたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「……ま、まぁ、貴方がどうしてもというのでしたら、もう少し続けてあげな\nくもありませんが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「分かった、分かりましたから！　そんなに首が千切れそうな程、何回も頷か\nなくても大丈夫ですからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「全く、どうにも貴方にはペースを崩されることが多いです……何か、過去の\n因縁でもあるんでしょうかね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ともあれ、続きをします……んっ、まず……れろ、ちゅぷ……ついている精\n液……舐めてしまいますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ぺろ……んっ、れろ……ちゅぱ……懐かしい味……ちゅぱ、んちゅぅ……ど\nうしてでしょう……ん、ぺろ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「あ……済みません、こちらのことです……綺麗になりましたから、改めて…\n…ご奉仕しますね……はむ、んむ、くぽっ、りゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ、いっぱいに頬張って……くひの中れ……あぁ、大きい……んちゅぱ\n……はぁ……んむ、れる……くぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぅ、くん……くんくんっ……オチンチンの匂い……んふっ、一段と濃く\nなって来てまふぅ……んくぽっ、んふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ダメです……絶対顔は見せませんからね……じゅぷっ、ウチのトップシーク\nレットより……オチンチンに集中して下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ほら……じゅぷっ、んっ、貴方こそ……顔が緩んでますよ……？　鼻の穴が\nぷくって開いて……ビクって腰を震わせて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「りゅぷっ、弱い所……もっと舌で押し込んで欲しいんれふね？　ここれふ…\n…んりゅっ、れろれろっ、オチンチン跳ねまくってまふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「れろぉ、んふふっ……冷静でいられないなんて……中々可愛いオチンチンで\nふね……ちゅぱっ、れろっ、えろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぅっ、じゅぱっ……はぁんっ、においが濃くなって来ました……くんっ\n、くんくんっ……あぁ……オチンチン……ムワッとしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んふぅっ……らめれす……舌が止まらない……んりゅぷっ、じゅ\nぷっ、んふっ、おしゃぶり……おいひいれふ……じゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、また……先走りが滲んで来まひた……りゅぱっ、んちゅぱっ、\nこれ……もうすぐ、出るやつです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ、んちゅるるっ……んふっ、はぁんむ……おいひい……のっ、だひてっ\n……じゅぱっ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「オチンチンから……精液っ……ドロっとして、濃いの……んっ、欲望の分だ\nけっ……いっぱいにっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、んじゅるるるるっ、じゅるるぅっ……んじゅぅぅぅ……んふぅぅ\nぅんんんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「口にっ……ふぁいっ！　いい、れふよっ……らひてっ……んっ、じゅぷっ、\nくらさいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んぐぅぅっ！　んっ、むぐっ、んっ……んくっ……んんんんっ！　また……\nこんらに……前より……お、多い……んふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「こくっ、んっく……んくっ……はぁっ、んはぁっ……驚きました……一度出\nした後なのに、勢いが凄くて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「え……まだ、奥に残ってる……ですか？　は、はい……なら、吸い出してみ\nます……あ、もう一気に出たり……しないですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んちゅぅぅぅ……ちゅぅぅ……んぁぁ……濃い匂い……クラクラひまふ……\nオチンチンと精液の匂い……強すぎぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぅ、あ……じわって出てきた、これが残りですね……？　んっ、ちゅる\n……よかった、これ位なら可愛いものです……ちゅる、ぺろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「出し切ったみたいですね……じゃあ、最後にお掃除……しちゃいますね……\nぴちゃ、れろ、んちゅ……ちゅぱ……ちゅぷ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ぺろ……はい、これで大丈夫だと思います。まだオチンチンは大きいですけ\nど……もう、顔は十分満足という感じですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ぺろ……んっ、くんくん……はぁ……んっ、くん……くんくん……少し、名\n残惜しいですね……あ、いえ、何でもありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「え……また次ですか……？　まぁ、機会があれば……なくは……ない、です\n……ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「なっ……んんっ、顔にっ……それは……ひゃぁっ！　あぷっ、んんっ、はっ\n……あふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000511_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そんな……マスクに……んっ！　掛けるなんてっ……ウチの大事なマスク…\n…んっ、もうっ……何でこんな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「うぅ……まぁ、好きにしていいと言ったのはウチですか……なら、どうにで\nもして下さい……ん、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんっ、濃いです……こんなの、濃厚すぎて……あぁ、マスクに匂\nいが染み込んじゃいます……はぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んんっ……あふっ！　今のが……最後のですか？　まだ飛ばす元気があるな\nんて……本当に呆れる位、元気なオチンチンですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「はぁ……でも、オチンチン終わりましたね。はい……それじゃ、後始末……\nさせてもらいます……ぴちゃ……ちゅぷ……んちゅ……ちゅる……んっ……」", "NORMAL" ]},
