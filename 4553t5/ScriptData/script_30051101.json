		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「んふぁ……はぁ……あぁ、意識ににおいが刷り込まれていく感じです……ん\nれろ、くん……ぺろ……くん、くん……んふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「終わりました……大丈夫ですよね……満足されたみたいで……はい、何より\nです」", "NORMAL" ]},
