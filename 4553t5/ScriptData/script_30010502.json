{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったくもって歯ごたえのない連中だったな！　ふんっ、覚醒した私の力を\n振るうまでもなかったわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504101" ]},
		{"command":[ "SETCHARA", "0", "char_00000105_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。おかげで身体の昂りが収まらないではないか……。貴様\n、当然責任を取ってくれるよな？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000105_01", "2", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「当たり前だろう！　ええい、貴様からこないのならばこっちからいくぞ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000105_01", "4", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふん。こうやって押し倒してしまえば逃げられないだろう。おとなしく私\nに付き合うのだ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ほら、このように貴様に、私の股間を押しつけて……ンッ、わかるだろう？\n　私の身体が、火照っているのが……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んふぅっ、こうして、腰を動かして……ほら、貴様のオチンポも、だ\nんだん硬くなってきたではないか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「熱いオチンポに、ンッ、私の……オマンコを擦りつけて……。どんどん奥か\nら、いやらしい汁が溢れてしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「も、もう挿入してしまおうか。ここまできたら、もう挿入してしまってもい\nいよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……なっ、待てだって！？　貴様、この期に及んで、私に挿入を我慢しろと\n言うのか！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_01" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そんなに挿入したかったらおねだりしろだと……！　くぅ……。だが、貴様\nが聞きたいというのなら……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、私のオマンコに、貴様のオチンポを……って、もっといやらしくだって\n！？　注文が多い奴め！　今回だけだからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ……私の、淫らに濡れた、はしたないオマンコに……き、貴様の、ガチ\nガチになった勃起オチンポを……ハメ、させてくれ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……これでどうだ？　ああ、挿入していいんだな！　じゃあさっそく、貴様\nのオチンポを、挿入、するから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　ああっ、ああぁああぁぁっ！　すごいっ、太いのが入ってきて\nるっ！　オマンコを、かきわけながらぁああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ、どうだ？　覚醒した私のオマンコは、一味違うだろ？　んっ、ああ\nっ、熱くて……貴様のオチンポを、しっかりと締め付けて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、んはぁっ、ああっ、腰を動かして……ンッ、くぅうっ！　オチンポ…\n…オチンポしごくからな……ああっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅうっ、貴様だって、凄く興奮しているじゃないか……んっ、ああっ、\nビンビンのオチンポが、オマンコの奥まで、きてるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「野外だからかもしれない、だって……？　んっ、そ、そう言われてみれば…\n…確かにそうだな……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、こうして、こんなところでエッチしてしまっているところを……誰かに\n見られるかもしれない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「で、でも、止められないんだ……！　貴様と、こうして繋がってしまったか\nら、もう、腰が止められなくて……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポ、いっぱい気持ちよくなるように……んっ、腰を、動かしてしまう\n……ああっ、んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「奥から、愛液がどんどん溢れてきてしまう……ああっ、腰を動かすたびに、\nはしたない音がしてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、私ばかり気持ちよくなっていないだろうか……。んっ、ちゃんと、貴様\nのことも気持ちよく、できているか……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「愛液まみれで、ぐちょぐちょのオマンコで……んっ、オチンポをしっかり、\nしごけているだろうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もっといやらしく腰を動かしてくれだって？　わ、わかった……やってみる\n……気持ちよくなってほしいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、ああっ、あぁっ！　こ、こうでどうだ？　んぁあっ、さっ\nきよりも激しく、腰を弾ませて……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「じゅぼじゅぼって、ああっ、いやらしい音をたてながら、オマンコ締めて、\nオチンポをぎゅっとして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁあっ、ああっ、すごい……！　オチンポがビクンビクンって、中で暴れ\nているの……感じてしまう……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「太いところ、でっぱってるところ、ああっ、オチンポの形、わかっちゃうく\nらいに……んっ、ああっ、感じるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、そうか、このまま続ければいいんだなっ！　ンッ、このまま、腰を\n動かして、オチンポを気持ちよくして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコ締めて、オチンポがいっぱい射精できるように、すればいいんだな\nっ！　そうする！　そうするぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁあっ、だから、イキそうになったらイッていいから。射精していいから\nぁっ！　んっ、ああっ、いっぱい射精してぇっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁんっ！　射精寸前のオチンポがっ、ンッ、びくびくって、オマンコの\n中で暴れてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だしてっ、注いでっ！　私のオマンコがいっぱいになるくらいに、ザーメン\n、たくさん射精してぇえっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁああっ！　ああっ、あはぁあああぁぁぁああぁぁっ！！　くひぃいいい\nぃぃぃっ！　きたきたきたっ、ザーメンぅうううぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポがびっくんびっくん震えながら、アツアツ、ドロドロのザーメンが\n子宮に打ちつけられてるのぉおおおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひっ、ひっ、ひぃいいいぃぃぃっ！　中出しっ、中出し気持ちいいっ！　子\n宮に精液浴びてイクッ、イクッ、イッくぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぁああぁぁぁ～～～っ！！　中出しでイッた！　オチンポにイかされた\nぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「オマンコいっぱいに、精液感じる……。はぁ……はぁ……。だけどまだ……\n身体が、疼いたままだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_10" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お願いだ……もっと、してくれ……。昂った私の身体を……このオチンポで\n鎮めてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くっ。わ、私がこんなにいやらしくなったのは貴様のせいなんだからな！　\nだから貴様には、責任をとってもらうんだ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様が私に、たくさんいやらしいことをして……はしたないことを、いっぱ\nい覚えさせたから……んっ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だからこうして……あんっ、自分から、誘うこともできるようになったんだ\nからな……んふぅ、んっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「腰を動かすたびに、イッて敏感になったオマンコにオチンポがこすれて……\nんふぅ、はぁ、ああ……声が漏れてしまうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅ、どうだ気持ちいいだろう？　ンッ、オチンポがまた、私の中でビク\nビクとふるえている……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いっぱい締め付けるから……んくっ、根元から、先っぽまで……んふぅ、オ\nマンコで、んんぅっ、離さないから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ、覚醒した私の腰遣いは、ンッ、一味違うんだから……んはぁ、はぁ\n、はぁ……ンッ、んくぅうっ、んふぅうう～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「締めてるから、オチンポをすごく感じる……！　オマンコのお肉が密着して\nいるの、わかるだろう？　なぁっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このオチンポが気持ちいいから、はぁ、はぁ、オマンコがきゅうっと締まっ\nてしまうんだ。オチンポに食いついてしまうぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くひぃいいっ！？　なっ、急に動くなっ、いま動かれたら……お、オチンポ\nがもっと奥に、刺さるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んおぉっ、おっ、おおっ！？　そんなに突き上げるようなっ、んはぁっ、私\nまで弾んでっ、ああっ、んはぁああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_10" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「届いてるっ、届いてしまってるぅっ！　おっ、オチンポが奥にっ、一番奥っ\n、しぃいっ、子宮にぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「先っぽが、んぉっ、どちゅどちゅって、んひっ、ひっ、ひぃいいっ！　当た\nってる、んほぉっ、おっ、おおぉおおっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「責任もってイかせてやるだって！？　んぁっ、嬉しいっ、イキたかったんだ\n！　このオチンポにイかされたいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「パンパンになったオチンポで、オマンコをいっぱい、いっぱいにされながら\n！　イキたいっ、イキたいぃいいっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、私も、オチンポがイクようにオマンコ締めるからっ！　いっぱいザ\nーメンできるように、お手伝いするからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「このオマンコで気持ちよくなって、んはぁっ、さっきみたいにドロドロのザ\nーメンミルクをたくさんだしてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、ザーメンが欲しいっ！　きっ、貴様に射精して欲しいぃっ！　貴様\nのがいいっ！　貴様のじゃなきゃ、イヤだぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んひぃっ、私もまた、キてしまうっ！　んぃっ、いっ、イクッ！　イクイク\nッ！　オマンコ……イかされるぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_09" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だしてっ、だしてぇっ！　オチンポミルク、好きなところにっ！　ああっ、\nああっ、オチンポからぁっ！　びゅくびゅくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くはぁあああぁぁぁああぁぁ～～～っ！！　ああっ、きたきたっ！　ザーメ\nン入ってくるっ！　中出しっ、んひぃいいいぃぃぃっ！！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いっぱい出てるぅっ、びゅーびゅーって入ってくるぅっ！　おっ、おおっ、\n子宮にもぉっ、あひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いっぱい出してっ、もっと、出してぇっ！　ああっ、子宮が精液でたぷたぷ\nになるくらい、いっぱいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「びゅるびゅるって射精……んぁっ、ああっ、オチンポが暴れまわりながら、\n何度も精液を放って……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んひぃいっ、ああっ、子宮で精液を浴びるたびに、イッてる、イッてしまっ\nてる……っ！　んひっ、ひぃいいぃっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_13" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、止まらないんだ……オマンコがオチンポをぎゅっぎゅっとして、精液\nをみんな搾り取ろうとしてしまっている……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。それだけ私は……その……貴様との赤ちゃんを、作りた\nがっていたのかもしれないな……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_11" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ！？　お、おい。どうしたんだ、そんなにぐりぐりと、オチンポで子\n宮の入り口……んひぃっ、こね回して……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「せっかく中出しした精液が漏れないように栓をしてやるって？　ば、バカっ\n、そんなことする必要なんかない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様の精液なんだぞ？　この私が……プリンセスドラゴンとなった私が、漏\nらすなんてもったいないこと、するはずないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁああっ、あはぁああぁぁっ！！　オチンポがっ、抜けて……っ！　んっ\n、待てっ、このままじゃ……っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ひゃはぁあああぁぁぁ～～っ！　出てっ、出てしまってる！　精液ぃっ、私\nの身体に、いっぱいかかってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁっ、熱いっ、火照った身体に、熱くてドロドロのオチンポミルクがぁ…\n…んぁっ、ああ……んはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「もっとかけてくれぇ……。んふぅ、ぬるぬるのザーメンシャワー……んはぁ\n、たまらないぃ……んはぁあっ、イクッ、イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……青臭いザーメンの臭いに包まれて……イッた……イッてし\nまったぁ……んふぅ……あはぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_16" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、真っ白になるぅ……。ザーメンで肌も、頭の中も……真っ\n白にいぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「この感覚……好きぃ……。はぁ……はぁ……。ザーメンがべっとり……肌に\n張り付いてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……そんなに意地悪なこと言うな……私が……前よりもずっと\nずっと淫乱になっただなんて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000105_02_14" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だが……否定はできない……。だって、こうしていやらしいことをされて、\n悦んでしまっているから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「だから……貴様はこれからも、淫乱に覚醒したプリンセスドラゴンこと私の\n面倒を、しっかりみるんだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_0504410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
