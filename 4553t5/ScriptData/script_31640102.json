		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅ……っ、　おとーさんのおちんちん抜けてくときっ、おなかの中\nぜんぶ出てくみたいで……んぁっ、きゃふっ」", "NORMAL" ]},
