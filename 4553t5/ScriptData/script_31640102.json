		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あ、びゅーびゅーって出るの、おさまってきた……。おとーさん、きもちよ\nかった……？」", "NORMAL" ]},
