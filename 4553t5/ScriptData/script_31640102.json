		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルもてつだってあげるね？　おとーさんのおちんちん、たくさん白いの\n出してねー？　しこしこー、しこしこー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふふっ、まだこんなに出てる……イルル、まっ白になっちゃうよお、ぜんし\nんべたべたで、おとーさんのにおいでいっぱぁい」", "NORMAL" ]},
