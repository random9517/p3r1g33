{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_03" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、今日もおつかれさまね？だから……はい、イルルときもちいい\nこと、しよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「え？　なにしてるのか、って？　あれ、だって、おとーさんがくれた本に、\n男の人って、すごくつかれるとこうしたくなるって書いてあったよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104102" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルはむすめみたいなものだから、ダメ？ええー、でも、まえにおちんち\nんから白いのびゅーってしたよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104103" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おっぱいもきもちよさそうにちゅーちゅーすってたでしょ？あれはよかった\nの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルがちっちゃいからダメ？　けいさつが来る？　んー、イルル、けいさ\nつってよく分かんないけど、それってドラゴンが相手でも来るの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルル、人間じゃないし……ドラゴンだし、ホントはおとーさんよりずっと\nずっと年上だよ？　だったら……だいじょうぶだよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルのここに、いーっぱいずぼずぼってして、おとーさんのおちんちんか\nら白いのびゅーってしてほしいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「きゃぁん♪　うん、イルルわるい子なのっ、　だからおとーさん、いっぱい\nいっぱい、オシオキしてえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ、んふ……ちゅっ、ちゅぅ……っ、ちゅぷ……っ、ふぁっ、れろ……ち\nゅっ、ちゅぷ……おとーさぁん……このキス好きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ひゃっ！？　お、おとーさん、おちんちん……イルルのおまたにあたってる\nよ……？　すごくかたくてあつい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅっ、あっ、ぁあんっ、おちんちんでイルルのおまたぁっ、こしゅ\nこしゅって、　しょれきもちいひっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「くちゅくちゅってしゅるのっ、　せなかぞくぞくってしゅりゅっ、え？　こ\nこ、おまんこって言うの？　うんっ♪　わかったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルル、おまんこきもちよくなりたいっ、くちゅくちゅおまんこに、おとー\nさんのおちんちんほしいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ひ、ぐっ、んきゅう……っ！？　めりめりって、おとーさんのっ、おちんち\nんっ、おまんこにきたぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぐちゅぐちゅって音しちゃってるぅ……っ！　イルルのおまんこ、おとーさ\nんのおちんちんの形になっちゃうよぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ、おとーさんキスしたいの？　イルルもしたい、キスするぅ、ちゅっ、\nんふっ、ちゅぅっ、れろ……ちゅぷ……ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさん、ぎゅーってしたい……しゅりゅう……、んきゅっ、おっぱいす\nっちゃダメえ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おっぱいすわれながらっ、　おちんちんじゅぽじゅぽされるのっ、きもちい\nいっ、　イルルわるいこだからっ、　もっとオシオキしてえっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おっぱいのさきっぽ、はむはむってかんじゃダメだよお……っ、んひぃっ、\nひっぱるのもダメなのおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んひぅっ、うんっ、見えてりゅ……おとーさんのおちんちん、イルルのおま\nんこに出たり入ったりしてるのっ、見えりゅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ごめんなさい、えっちなイルルのわるいこまんこぉっ、おとーさんにオシオ\nキされてりゅのにっ、　じゅぽじゅぽされてうれひぃのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっきゅ！？　おくっ、にゃにこりぇっ、　おくっ、おちんちんでどちゅど\nちゅされりゅとっ、　目のまえチカチカすりゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んぶっ、おとーさっ、そんなに体のっかられると苦ひ……っ、ちゅっ、じゅ\nる……っ、にちゅ……っ、んぷぁっ、じゅぷ……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んひぃっ、　キスっ、いきできないっ、くらい……んちゅっ、れろっ、おち\nんちんっ、おくぅっ、ダメえっ、　どちゅどちゅやあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルのおまんこっ、おちんちんでおかしくなっちゃってるようっ！じゅぽ\nじゅぽされるとっ、こしびくびくって、ひぅっ、ぁあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぁっ！？　おとーさんっ、しっぽっ、しっぽひっぱっちゃやあっ！しっぽ\nひっぱっておちんちんずぼずぼやらあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふかひっ、おまんこのおくはいっちゃうっ、　イルルのあたまっ、おちんち\nんのことしか考えられなくなっひゃう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ちがうよおっ、イルルはじめてだもんっ、　おとーさんしかおちんちんおま\nんこに入れてないもんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんのおちんちんだからきもちいいのおっ！　大好きなおとーさんじ\nゃなきゃ、こんなにならないもんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぎゅうってしてえっ、　おとーさんのおっきな手でなでなでしてっ、イルル\nひとりにしないでえ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「だっこされながらおちんちんじゅぽじゅぽされるのしゅきぃっ、おっぱいも\nぎゅうってひっぱられるのきもちいいよおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぁあっ！？　あれっ、お、おちんちんっ、もっとおっきくなってっ、んき\nゅっ！？　おまんこっ、ごりごりってっ、ひぁあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「白いのっ、びゅーってするのっ？　イルルのおまんこにいっ、おとーさんの\nたくさん出されちゃうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んひぃっ、　おちんちんっ、おくにぎゅーっておしつけてりゅっ、さきっぽ\nふくらんでっ、びくびくってしてりゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「きゃふっ、くぅんっ、イルルのおまんこっ、おとーさんでいっぱいになって\nりゅっ、　めのまえっ、ちかちかってっ、してっ、ふぁああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ひぅっ、んきゅうぅ――ッ！？　イルルのおくっ、白いのびちびちってあた\nってりゅうっ、　あちゅいのっ、いっぱっ、ふぁああ……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「にゃにこりぇっ、　イルルのおまんこっ、おとーさんのおちんちんぎゅーっ\nてしてはなさにゃいっ、　びゅーびゅーってしぼってりゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ひぁん……っ、　まだ出てりゅっ、　おとーさんのおちんちん、イルルのお\nまんここわいちゃいそうなくらいびゅーって出してるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んくっ、ぶびゅって音たててあふれちゃってるよう……。おとーさん、イル\nルのおまんこ、そんなに入らないよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ひ、んみゅっ、んぅう～っ、おちんちん、ぬけて……くと、ぞりぞりってお\nまんこの中っ、こすってく……のっ、ひぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぅ……っ、ふぅ……っ、ふぁ……。おとーさん、白いのいっぱい出して、\n元気に……なった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ほら……イルルのおまんこから、白いのぼたぼたーってこぼれちゃって、シ\nーツにたまっちゃってる……♪　すっごい出たね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……あれ？　おとーさんのおちんちん、まだおっきいね？もしかして……ま\nだ足りない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルのわるいこおまんこ、まだオシオキ足りないの？そっかあ……じゃあ\n……もういっかい……しちゃう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルル、おとーさんのきもちいいオシオキ好きだから、なんどでもおちんち\nんでおまんこじゅぽじゅぽされてもいいよお……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んぎっ、きたぁっ、　イルルのおまんこおしひろげてっ、おとーさんのおち\nんちんきたあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぁはっ、おちんちんにおされてっ、おまんこからしろいのぶりゅってあふ\nれてきちゃったぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルルね、これ好きかもぉっ、　おとーさんのおっきいので、おまんこめい\nっぱいっ、　じゅぽじゅぽされりゅのしゅきぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさんのおちんちんしゅきぃ、　おまんこきもちよしゅぎてえっ、あた\nまのにゃかばかになっちゃうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んぷっ、ちゅぅ……っ、れろ……っ、ちゅぷ……ふふっ、おとーさぁん、も\nっとぉ……ちゅー好きぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ふぅ……んっ、あたまなでられながらちゅー、きもちいい……、ふ\nふっ、ほっぺにもしてくれるの？　えへへえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「おとーさぁんっ、おっぱいにもちゅーしてぇ、　、ちっちゃいしなんにも出\nないけど、ちゅーちゅー吸われるの好きなのぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふっ、ふふふっ、おとーさんあかちゃんみたい、おっぱい出ないけど、た\nぁくさん吸ってね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっひぃっ！？　おとーしゃっ、おまんこじゅぽじゅぽしながらぁっ、おっ\nぱい吸っちゃらめぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00016401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「きゃぅっ、ふぁあっ、ひぎぃんっ、イルルのおまんこっ、おとーさんのおっ\nきいので広げられてりゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぐちゃぐちゃにされてるのにっ、気持ち良くっておかひくにゃるっ、おとー\nさんっ、おちんちんっ、びくびくってしてるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「やぁらぁっ、おとーさんっ、イルルこわいっ、　んきゅっ、ひぁあっ！こん\nなきもちいいにょにっ、　白いのだされたらぁっ、ふぁあっ！」", "NORMAL" ]},
