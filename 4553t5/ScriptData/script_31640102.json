		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「えへへえ、じゃあやくそくね♪　じゅんびしないと……あれ？　あれれ？イ\nルル、おまたにちから入んないや……？　うまく歩けない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ひゃんっ？　おとーさん、だっこしてつれてってくれるの？ふふふっ、うれ\nしいな……♪　えへへえ、すりすり～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「……あ、おとーさんにも白いのついちゃった！　ふふふ、はやくおふろであ\nらわなきゃね？　イルルがちゃぁんとあらってあげるから」", "NORMAL" ]},
