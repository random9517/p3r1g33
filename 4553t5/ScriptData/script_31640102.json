		{"command":[ "PLAYVOICE", "v2_164_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んふっ、ぁは……あったかぁい……おとーさんのせーえき、あふれてきちゃ\nったあ……」", "NORMAL" ]},
