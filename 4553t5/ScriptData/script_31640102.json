		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「うんっ、うんっ、わかった、おんなじこと言えばいいのねっ？、イルルのし\nょちょーまえちびまんこにっ、せーえきちょうだいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「しきゅうにどぷどぷって出してっ、イルルのわるい子まんこにっ、たねつけ\nオシオキしてくだしゃいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ちっちゃなしきゅうっ、　おとーさんのせーえきでいっぱいにしてっ、ママ\nにしてぇっ、んっひぃ、きたぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104303" ]},
