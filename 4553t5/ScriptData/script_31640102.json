		{"command":[ "SETIMAGE", "0", "still_00016401_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぁは……おなかふくらんじゃってる……おとーさんのせいえきでママにされ\nちゃったぁ……」", "NORMAL" ]},
