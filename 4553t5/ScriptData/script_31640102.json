		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぁ、でも……こんなにべたべただと、かみのけたいへんかも……？おとーさ\nん、あとであらってくれる？　イルルとあらいっこ！」", "NORMAL" ]},
