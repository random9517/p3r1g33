		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「イルル、ばかになっちゃうっ、　んひっ、きゃうんっ、おちんちんでっ、お\nかひくなっひゃ、きゃふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ふぁんっ、ばかでわるいこでもいいのっ？　イルル、おとーさんといっしょ\nでいいのっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「ぁはぁっ、おとーさんっ、おとーさぁんっ、好きぃっ、だぁい好きぃっ、　\nイルルっ、ずっとおとーさんといっしょねっ？」", "NORMAL" ]},
