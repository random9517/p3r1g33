		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅる……じゅるる……ふしぎなあじ……、ええー、飲んじゃダメな\nの？　どうして？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「食べものじゃないから……？　でも……おとーさんの味……なんだかむねが\nどきどきするの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_164_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「あっ、また白いのびゅーってかかってるぅ……、おちんちん、びくびくって\nきもちよさそう……」", "NORMAL" ]},
