		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イルル" ]},
		{"command":[ "SETTEXT", "「すごい……まだあふれてきちゃう……たっくさん出たね、おとーさん、イル\nル疲れちゃった……おとーさぁん、おふろ入れてえ……」", "NORMAL" ]},
