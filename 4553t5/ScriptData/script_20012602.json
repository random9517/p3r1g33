{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……で。ハロウィンについて聞きたいんでしたっけ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「有名な行事じゃないですか。まったく、そんなことも知らないで生きてきた\nんですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "不機嫌そうに吐き捨てるオボロに、ロボっ娘２人がコクコクとうなずく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私達は機械ですから……広く情報を集めることは得意ですが、取捨選択は少\nし苦手で」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022030003" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「どうせなら、呪術や策略に詳しいオボロさんに聞きたくて……。お部屋の位\n置をご主人に聞いたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022030003" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なるほど。そういう事であれば……ウチを頼るのも納得です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030007" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ハロウィンっつったら呪いとか魔女とか化け物とかだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうのに一番詳しいのはオボロだと思ったんだが……そこんとこはどう\nだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そう、ですね。……確かに、ウチはハロウィンに詳しいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030011" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「わっ、やった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022030005" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「国の違いはあれど、儀式としての祭りには共通するところが多いですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030012" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「巫女として、ウチも学ぶところは色々とありました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「『ハロウィン』。それは、基本的には１０月末日……。１０月３１日に行わ\nれる西洋の祭りです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「この国はわりと行事に適当なので、数日前後することはありますが。おおよ\nそ月末にやるお祭りでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「キリスト教の祝日の１つで、……ま、こちらで言うお盆みたいな感じですか\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「カボチャのランタンを作り、トリック・オア・トリートの掛け声でご近所さ\nんからお菓子をもらいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「一番の特徴は……仮装ですかね。ハロウィンの日には、魔女や悪霊などの魔\n物が現世にやってくると伝わっています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それに対抗して、人間もわざと魔女やオバケの格好をして……魔物たちから\n身を守っていたんだとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「仮装……。やっぱり、私達が見た情報は正しかったんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022030005" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そうですね。自分達を魔物の仲間だと思わせて、禍（わざわい）を遠ざける\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030020" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ですが、現代では……。パリピがはしゃぐためという側面も大きいですから\n、気軽にやるのもアリといえばアリです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030021" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「どんな衣装を着るか迷います。……と、すっかり忘れてました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022030006" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「もし仮装をするなら私達にはメンテが必要です。新しいパーツを作ってもら\nわないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022030007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ＥＤＯ本部にパーツ換装に行ってきてもいいですか！？　ご主人様！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022030006" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「パーツの交換でそんなことまで出来るのか……？　今時の技術ってのはすげ\nえなぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふふっ、ちょっぴり時間はかかっちゃいますけど可能ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022030007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ちょうど本部での点検期間に重なってますし、とってもバツグンなタイミン\nグだと思います！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022030008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「イベントには充分間に合う予定だから。許可をもらえるなら、行きたいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022030008" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいんじゃないか。俺もどうなるか、ちょっと興味をそそられる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それなら、善は急げだね。すぐ行ってくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022030009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私も華麗にパーツチェンジしてきます！　楽しみです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022030009" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……どうやら、お二方の知識欲は充分満たせたようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030022" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「であれば……パーツ換装はウチには関係ないんで、もう一度部屋で一眠りで\nも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030023" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しますです、と言いかけたオボロにロッテがむぎゅっとしがみつく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「んぎゅっ！？　んんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030024" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「オボロさん！　１つ提案があるんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022030010" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「な、な、な、なんなんです！　びっくりさせないでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030025" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「本部の皆さんにも、今の話を聞かせてあげてください！　だから一緒に行き\nましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022030011" ]},
		{"command":[ "SETCHARA", "0", "char_00015701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それで、オボロさんの衣装も作ってもらっちゃいましょう！　とびきり最高\nにカワイイものを！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022030012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「な、なんでウチがそんな面倒な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030026" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「姉さんがそう望むなら……。私がオボロさんを運びます。よいしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022030010" ]},
		{"command":[ "SETCHARA", "0", "char_00015801_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「きゃ、きゃああああ！　持ち上げて持って行くつもりですか！？　やめるの\nです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030027" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "所詮他人事だと侮っていたオボロが、２人のメカっ娘にさらわれていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ロボ娘のパーツ換装ってのも、覗くとやっぱりマズいもんなのか……？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うううう～！　呑気な事いってないで、早くウチを助けるのです～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022030028" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「るんるんるん♪　楽しみだね、ハロウィン！　にゃふふふ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022030013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「うん。楽しみだね、姉さん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022030011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そうして、無邪気な２人の少女と……捕らわれのオボロは爆走していったのだ\nった……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}