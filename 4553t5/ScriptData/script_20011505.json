{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「さて、着替えも終わったし、みんなのところに戻って遊ぶとするか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、ご主人。丁度いいところに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520029" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　どうした……って、序に破。それに急じゃないか。こんなとこでなに\nしてんだ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ、カツマさん。こんにちはです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「こんなところで会うなんて奇遇ですねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、俺は商店街の福引で特賞が当たってな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「偶然だね～。実はボクたちも特賞が当たって、ここに遊びに来たんだ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前たちも？　っていうか、特賞ってこんなにぽんぽん当たるもんなのか…\n…？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「日頃の行いがいいからかもしれませんねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「それにしても、お三方だけで旅行とは中々大胆なことをしますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520030" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「本当はお母さんたちも来る予定だったんだけど……仕事でこれなくなっちゃ\nって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「旅行券の期日もあるし、もったいないから私たちだけで来たんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だったら俺たちと合流するか？　色々あって、幹部連中もここに居るからさ\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「それは嬉しいですけど……いいんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいもなにも、俺一人じゃ面倒な事になりそうだからな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「こんないたいけな少女たちを皆様の生贄に差し出すとは……さすがはご主人\n。悪党の鏡ですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520031" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人聞きの悪い言い方をするんじゃねぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「えっ……私たち、どこかに売られたりするですかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「んなことするわけねぇだろ！　いいから、早く来てくれ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あら、カツマ。遅かったわね……って、序たちじゃない。どうしたの、こん\nなところで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前……まさか三人目を選ばなかったのは、この子たちを誘うためだったの\nか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「いえ、カツマさんのことです。誘拐してきたという可能性も、十分考えられ\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「誘拐だって！？　見損なったぞ、カツマ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「私たち、やっぱりどこかに売られるですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんでそういう話になるんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「誘拐じゃなかったら、どうしてこの子たちがここに居るの～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「実はこいつらも商店街の福引で特賞が当たったらしいんだ。つまり、俺と一\n緒ってことだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当なら両親と一緒に来るはずだったらしいんだけど、仕事の都合で来れな\nくなったみたいでさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「そうなんですよー。それでその話をしたら、カツマさんがあたしたちを誘っ\nてくれたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「本当はちょっと寂しかったから、嬉しかったりするんだよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「困っている子を助けるなんて、さすがカツマさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「カツマ……や、優しい……！　かっこいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「今のやり取りのどこがかっこいいのか、全然わからないんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「ところで序様。その手に持っている紙はなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「あっ、カツマさんに誘われたせいで、すっかり忘れてたです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人のせいにするなよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「あたしたち、これに出ようと思ってたんですよねー。ほら、令和に生きる女\n学生っぽさを大胆に醸し出そうと思いまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「えーっと……豪華賞品がもらえる、渚のマーメイドコンテスト……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そのコンテストでボクたちのナイスバディを披露して、優勝しようと思って\nんだ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ナイスバディかどうかはともかく、豪華賞品というのは気になりますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520032" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「せっかくリゾートに来たんだし、こういうイベントに参加するのも悪くない\nわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「基本的に紅組と白組に分かれて、様々な競技で競い合うみたいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「優勝チームの他にも、最優秀賞や審査員特別賞などで賞品が貰えると書いて\nあるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「面白そうじゃない。賞品もいいけど、コンテストで優勝したらナンパとかさ\nれたりして……んふっ♪　楽しみだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「館長をナンパするような男なんて居るのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「なにか言ったかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いえ、なにも言ってません」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「でも豪華賞品か～。もしかして、ご当地グルメがもらえたりしてな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「本当にセレインさんは食い意地が張ってますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ですが、私も優勝賞品とやらには興味があります。一体どんなものが貰える\nんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「兎子、参加するの……？　競技もだけど、水着コンテストとかもあるみたい\nだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「別に水着を見られても構いません。それに競技はチーム戦みたいですし、大\n丈夫でしょう。むしろ輝夜さんは参加しないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「だ、だって……ひ、ひひ……人前で水着を披露するだなんて……！　考えた\nだけで……わ、私……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「競技の内容は会場にて発表なんだね。どんな競技があるんだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「えっ……つきみも参加するの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「だって面白そうじゃない。お姉ちゃんも参加するよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「い、いえ……私は遠慮しておくわ……他のみんなと比べて貧相な身体だし、\n運動もできないから……優勝なんて夢のまた夢だもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「あら、もったいないわね。せっかくだし参加すればいいじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「そうだよ。まりあさんも一緒にマーメイドコンテストに参加しようよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……カツマさんも、みんなが参加してくれた方が……嬉しいよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　ああ、そうだな。俺としては、全員参加して欲しいと思ってるぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（その方が自由な時間が増えるからな）", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー、見たいなー。みんながコンテストに出て、優勝するとこが見たいなー\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そ、そうなの……？　カツマさんが参加して欲しいっていうなら……私、コ\nンテストに出るわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「やる気になってくれたんだね！　えへへ……楽しみだなぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「っ……！　ま、待って……！　まりあが出るなら……私も……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「優勝賞品は勿論だけど、カツマにそこまで期待されたら出ないわけにはいか\nないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふっ……いいだろう。お前のために優勝してやるとしようか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「優勝……ナンパ……うふっ。うふふふふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「カツマちゃんのためじゃないけど～、賞品のために頑張っちゃうわね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「賞品……食べ物……！　ダメだ。想像するだけでヨダレが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「ウチは別にカツマさんのためじゃありません。ただ賞品が欲しいだけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_060021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000506_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「皆様、随分と目の色を変えてらっしゃいますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「カツマさん……私、なんか嫌な予感がしてきたです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「奇遇だな。俺もそう思ってたところだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「動機はなんであれ、皆様のやる気が増したようでなによりですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520033" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、みんな優勝目指して頑張ってくれ。俺はその間、ゆっくりさせて\nもらうから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「なにを言ってるの。あなたは私たちの応援をするのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000107_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだぞカツマ。お前の応援が、私たちの筋肉をより一層輝かせるんだから\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00000111_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「水着コンテストなんだから、筋肉は関係ねぇだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「そんなことはない。水着に映える身体を披露してこそ、真の水着コンテスト\nだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021520010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「確かに身体付きとかを評価するんだろうけど、アナザーが言ってるのは、ボ\nディビルとかそっちの方だと思うんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「か、カツマ……！　お願いだから、私を応援して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000205_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「カツマが側に居てくれないと……私……恥ずかしくて、全部壊しちゃいそう\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_050021520008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私からもお願いします……！　近くで見ててください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_020021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00001402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「せっかくの機会なんだし、カツマさんにはちゃんと応援してもらわないと！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_030021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00001203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、別に近くに居なくても応援はできるし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファ" ]},
		{"command":[ "SETTEXT", "「うだうだ言ってないで、いいから私たちを応援してなさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_060021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00000306_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「そうよ～。もしディアナちゃんが優勝できたら、賞品を分けてあげるから～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00000605_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えっ！？　本当に！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディアナ" ]},
		{"command":[ "SETTEXT", "「勿論。ただし、ディアナちゃん的に分けてあげられそうなモノだけよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_050021520006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「私も食べ物以外だったら、分けてやるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00000404_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人。これはもう諦めるしかありませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520034" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「そうだよカツマさん。それにせっかくの機会ですし、是非あたしたちの水着\n姿を堪能して下さいねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー、もう！　わかったよ！　応援すりゃいいんだろ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーン" ]},
		{"command":[ "SETTEXT", "「どうやら、話はまとまったみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_040021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00000811_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……それじゃあ、みんなでコンテストに……しゅっぱ～つ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「わたくしはどうすればいいのですかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520035" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前は水着コンテストに参加できるワケねぇんだから、俺と一緒に応援だ！\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0081" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ったく……結局こういうことになるんだよな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「オーケー！　えっと、隊長さんの連絡先は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　この声は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこに居るのはホクサイたちじゃねぇか。どうしたんだ、こんなところで」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ワァッツ！？　どうして隊長さんがここに居るの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、実はかくかくしかじかでな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺はこのリゾートに来た経緯を簡単に説明しつつ、ホクサイたちの話を聞いた\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "どうやらホクサイたちは襲来者（インベーダー）の本拠地を見つけたものの\n敵が強くてどうしようもなくなり、俺たちの助けを求めるところだったらしい。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そういうワケで、俺たちはここに居るってワケだ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さんの事情はわかったけど、僕たちも困ってて……できれば、協力して\nもらえないかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「協力って言われてもなぁ。幹部連中は豪華賞品がもらえる『渚のマーメイド\nコンテスト』ってのに出ることになってるし……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「そこをなんとか……！　僕と隊長さんの仲でしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520004" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、別に俺たちそんな親密な仲じゃないだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「えぇ～！？　一緒にあんなことや、こんなことまでした仲なのに！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「誤解を招くような言い方をするな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「ホクサイ、そう無理を言うもんじゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「それにニンジャには休息も必要だ。せっかくのリゾートなんだから、少しみ\nんなと遊んだらどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「で、でも……！　この非常事態で遊ぶだなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520006" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「わ～い！　じゃあ、みんなで遊ぼ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「先生がそう言うんじゃ、付き合うしかねぇな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00009702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「そうだね。先生からの指示だし、従うしかないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010021520001" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「だから、今はそんなことしてる場合じゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520007" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「遊びと任務の両立ができてこそ、一流のニンジャだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520003" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「それに私も、そのコンテストの豪華賞品とやらに興味があるのでな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「せ、先生まで！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520008" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「よし、お前たち！　ニンジャになるための修行だ！　ともにマーメイドコン\nテストやらに出場し、優勝するぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010021520005" ]},
		{"command":[ "SETCHARA", "0", "char_00010002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "３人" ]},
		{"command":[ "SETTEXT", "「イェーーーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010021520002" ]},
		{"command":[ "SETCHARA", "0", "char_00009802_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00009702_01", "8", "CENTER", "400" ]},
		{"command":[ "SETCHARA", "2", "char_00009902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　みんなぁ～～～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520009" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あー、その。なんだ……あんたも大変だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「この悲壮感……まるでご主人を見ているようですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520036" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうことを言うな。悲しくなるだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「ねえ、隊長さん。コンテストが終われば、襲来者（インベーダー）の基地の\n制圧、手伝ってくれる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520010" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「協力するかどうかは俺が決めるワケじゃないが、幹部どもが手伝う可能性は\nあるかもな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「……なら、僕もコンテストに出るよ！　さっさと優勝して、ミッションを終\nわらせなきゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520011" ]},
		{"command":[ "SETCHARA", "0", "char_00009602_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうかい。なら、俺はお前たちの分も客席で応援するとするか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「うん、ありがとう！　それじゃあ、僕も行くね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010021520012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ルルーナ殿たちの応援はあんなに渋っていたのに、随分と素直ですな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520037" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「別に……ただ応援する相手が少し増えただけのことだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「左様でございますか。では、わたくしたちも会場へ参りましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021520038" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}