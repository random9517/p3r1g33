		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここは……どこだ？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どこかはわかりませんが、どうやら地球ではないようで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010114350001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だから、そんなこたぁわかってるんだっつーの。どうせ、どっかの惑星だか\n小惑星だか、そんなとこだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だけど、ずいぶん寂しいところ……なんだか、廃墟みたいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114350001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「だな。なんだか、ボロボロになった田舎の駅みたいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114350001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ボロボロにもほどがある、って感じだけどね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114350001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「でも、列車まで止まってるわ。どうやらここは、本当に駅だったみたい。\n翔生子さんは、ここがどこだかわかるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010114350001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「わかる……ような気がします。ここはきっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114350001" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "と、翔生子が話し始めたとき！", "NORMAL" ]},
