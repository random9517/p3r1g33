		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "と、いうわけで、学園の守りをブラックメルヘンやＥＤＯに任せて、ワームホ\nールに飛び込んだ俺たちだったが……。", "NORMAL" ]},
