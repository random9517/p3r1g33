{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あ……来てくれたんですね。わざわざ呼び出して申し訳ありません。でも、\nどうしても伝えたいことがあって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「私は今まで自分が生きる意味が分かりませんでした。他人にいいように使わ\nれ、刀を振るい……妹が、うららがいることだけが生きがいでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「けれど、貴方はそんな私に生きがいを与えてくれた……貴方が私に光を与え\nてくれた……貴方のためなら、私はなんだってできます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「私は女としての感性に乏しいですが……それでも分かります。こんな関係に\nなった貴方が私の運命の人だと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ですから……ね。分かるでしょう？　今日、この場所で、私を貴方の女にし\nてください……きゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00027501_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「いきなりこんな格好で……んっ、でも、凄い……貴方の力強さが分かって…\n…ふふっ、戦闘では私の方が強いのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「こうしていると貴方の逞しさがよく分かりますね……腕と、身体と……そし\nておちんちんと……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、そんなおちんちんをこすりつけたら……ふうっ、んっ、それだけで\n気持ちよくなってしまいます……あんっ、あっ、硬い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あんっ、ふうっ……それ、嫌いじゃないですけど、そろそろ\n、私の中に……貴方のおちんちんを……お願い、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「お願いします……私の初めて、もらってください……んんっ、あっ、はっ…\n…あ、先端が触れて……硬くて……ふうっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ああっ、入って、来た、あっ……んんんっ、これが、おちんちんの感触……\nはあっ、ああっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「戦いで、攻撃を受けるのとは全然違う……愛おしい人が入ってくる感覚……\nんんっ、あっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あうっ、奥まで入って……ふううっ、私と貴方の腰がぴったりくっついて…\n…んんっ、繋がってる……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、私の中がいっぱいになってます……ふふ、私の初めて、貴方に捧げ\nられました。これが幸せということですね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んうっ、動いていいですよ……少し痛いですけど、それよりも気持ちよさの\n方が……貴方と一緒になれた幸せの方が上ですから、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふっ、あっ、うっ、凄い、この体勢、一番奥まで、ごつごつっておちんちん\nが……ふああっ、あっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「頭の中までおちんちんで突かれてるみたいでっ、ふあっ、ああっ、んっ！！\n　私、おちんちんで串刺しにされてっ、んっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、ああっ、あくうっ！！　気持ちいいっ！！　初めてなのにお\nちんちん気持ちいいっ！！　んうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、私の中でおちんちんがごりごりって動いて、かき回して、ふう\nうっ、うっ、中から動かれるの、こんなに気持ちいいなんて……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んっ、ダメ、これダメ、気持ちよすぎて、くせになっちゃいそう……ふうっ\n、ああっ、あんっ、貴方のおちんちんの虜になっちゃう……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あっ、貴方も気持ちよさそう……ふふっ、嬉しい、今、私たちは一緒ですね\n……身体も心も……んっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんんっ、その、奥を押しつぶすようにこりこりするの、好き……んんっ、\n貴方のおちんちんを一杯感じられて……幸せな気持ちに……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んうっ、こうして、お腹に力をいれたら……んふうっ、ふっ、貴方のおちん\nちんに私の中が絡みついているの、分かります……？　きゃんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、そんな急に激しく、ふっ、あっ！！　あっあっあっ、そんな\n、そんなにいっぱい突かれたら、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「溶けちゃう、私の中、溶けちゃいます！！　貴方のおちんちんでかき回され\nて、溶けちゃうんんんんっ！！　ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「凄いっ、んっ、これが男の人の逞しさ、あっ、んっ、おちんちん……ふああ\nっ、あっ、あんっ、あっあっあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んふうっ、ふっ、私の中、直接ぐちゅぐちゅってかき回されてるのが分かる\n……貴方のおちんちんで私の中、溶かされてる……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふああああっ、その奥をごつごつってするの、気持ちいいのを、身体が覚え\nちゃう！！　貴方のおちんちんの気持ちよさ、覚えちゃうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「もう、もう離れられないっ！！　貴方から、貴方のおちんちんから離れられ\nないっ！！　私、ずっと一生離れられないいいいっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ、だから、もう貴方のお嫁さんになるっ、ふううっ、身も心も\n、貴方に嫁ぎますううううっ、あっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ね、ね。一生貴方と添い遂げますから……んっ、こうして、いっぱいいっぱ\nい愛して、あんっ、私も貴方を一生愛するから、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「毎日毎日、こうしておちんちんにご奉仕しますから……んっ、全身で気持ち\nよくしますから……んっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「妻としてしっかり務めますから、ね、夫婦の誓い、誓いの中出しを……中出\nしをしてください、貴方の妻だってしるしを、私の中に……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「お願いします……私に中出し、貴方が気持ちよくなった証をどぴゅどぴゅ出\nして……私の中で満たして……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、おちんちん膨らんできたっ！！　いいですよ、出して、いっ\nぱい出して、お願いっ、ひあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},	
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「来たっ、来たあっ！！　あっつあつの精液、私の中に来たあああああっ！！\n　んんっ、びゅるびゅるって、当たってる、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},	
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふああっ、凄い……こんな、中出しがこんなに気持ちいいなんて……愛され\nてるって実感できるなんて……あっ、ああっ、私も、イくっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんんっ、ふあああああああっ！！　あっ、あくうっ、あっ、出されながら\n、出しちゃってる……んんっ、潮が……んんうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ひあっ、あっ、んううううっ、はっ、あくうっ、出された分だけ、出てる…\n…ふうっ、んっ、ふああっ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふふ……お互いにびしょびしょになってしまいましたね……でも、むしろそ\nれが嬉しいかも……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「まだ、硬いですね……もう一回、しますか？　私は大丈夫ですよ。夫の求め\nに応えるのも妻の務めですもの……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、やっぱり、貴方もその気じゃないですか、んんっ、ふっ、まだ硬く\nて……あんっ、あっ、さっき出されたのが漏れちゃう、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んううっ、んっ、えっ……また出してあげるって……ふふっ、じゃあ、溢れ\nるぐらいに注いでください……終わった後もずっと残ってるぐらい。あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104203" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、ふうっ、あんっ、出された後に突かれると、また違う感触が……ん\nっ、くうっ、ふあああっ、あっ、ぐちょぐちょに混ぜられてる……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「これ、この感じも好き……んうっ、貴方からされるなら、どっちも好き……\nふうっ、うっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んふうっ、そうやって勢いよく突かれたら、頭の中までかき混ぜられている\nような……んんっ、思考まで蕩けてしまいそう……んっ、あっ、あくうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「私も、貴方を気持ちよくしたいから、こうして、んっ、力を入れたら……あ\nんっ、ふっ、ちょっとおちんちんが中で跳ねましたね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふふ、いいんですよ。貴方は何も考えず、私の身体で気持ちよくなってくだ\nさい。私は……あなたのおちんちんにご奉仕しますから。あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、ほら、中もこうやって……お腹の中で、あなたのおちんちん\nをちゅっちゅってしたら、あんっ、やっぱり暴れたっ、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んうううっ、少し分かってきましたよ、こうして、きゅって力を入れたら、\nんっ、貴方の形がよく分かって、んっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あっ、あんっ、これ、私も気持ちよくなって……んんっ、お互いがお互いを\n愛してる感じで……ふうっ、うっ、これ、好き……あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、あっあっあっ、貴方も、興奮してるのが分かる……ふふっ、\n私の中にいるから、そういうのも伝わってきますね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、貴方に突かれるたびに、なんだか、身体の奥から、好きって気持ち\nが……んっ、あんっ、私がこんなことを思うなんて、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んううううっ、あっ、ふうっ、俺も好きだなんて、今言われたら……そんな\nこと言われたら……んんっ、身体が熱くなって……あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あううっ、んっ、ふううっ！！　なんだか、私の中でおちんちんも溶けてる\nような、溶けて、貴方と繋がってるような、それぐらい……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「それぐらい気持ちよくて、こんな体勢なのに腰が動いて……んっ、んんっ、\nあっ、ああっ、また、またイきそう、んっ、はあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「貴方も、貴方もイってください、私の中に、貴方の妻であるというしるしを\n一杯注いで、満たして……んんっ、はあっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「出して、出してっ！！　私も一緒にイきますから、出して、いっぱい出して\nっ！！　貴方の精液、私の中にいっぱい出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、ああっ、あっ、イく、イっく、貴方のおちんちんで、またイくうっ\n！！　ふあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「中でおちんちんびくびくしてる、貴方と一緒に、イっくううううううううう\nうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104220" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ああああっ！！　精液来たあっ！！　また私の中に、いっぱい来たあっ！！\n　ふあああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「熱い……んんっ、一番奥にびゅっびゅって嬉しそうに注いでるのが分かる…\n…んんっ、あっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「こんなに熱いのを出されたら、子宮がやけどしちゃう……んっ、ああっ、ん\nんっ、でも、ごくごく飲みこんでる……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んふうっ、私の中に精液がべっとり張りついてる……んんっ、ふっ、こんな\nの出されたら、絶対孕んじゃう……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あふうっ、んっ、力を入れたら、最後の一滴まで中に……んっ、こぼれない\nようにしないと……貴方からもらったものだから……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ふふっ、お腹の中がたぷたぷしてる……まだ妊娠してないのに、もうお腹の\n中に子供がいるみたいですね……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「子供……ふふ、貴方との子供なら何人でも欲しいですけれど、できれば一人\nはうららのように可愛らしい女の子がいいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「男の子ならきっと貴方そっくりの素敵な子になるでしょうし、どちらでも楽\nしみですけど……双子とかなら、賑やかな家庭になりそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「私は妻として貴方に恥じぬように立派な振る舞いをして見せますから……ず\nっとずっと幸せな家庭を築きましょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104309" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「愛してます。私がうらら以外で心の底からそう思えた人が貴方です……いつ\nまでも、いつまでも愛しています、貴方」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あんっ、おちんちん、抜けて……ふあああっ、私の身体に精液が、んっ、あ\nああっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、凄い、身体に精液が塗りこめられていくみたい。まるでマー\nキング……んっ、ふうっ、はああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「んんっ、こんなにぶちまけられて……中とは違う熱さと匂いで……ふうっ、\n全身が精液で包まれたみたい……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104403" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「身体中にべっとりとはりついて……んっ、これが貴方からの愛情だと思えば\n、このぬるつきすら愛おしく思えてしまいます……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「最後の一滴まで、私の身体にふりかけましたね。ふふふっ、嬉しい。私で気\n持ちよくなってくれたから、これだけ出たんですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「こうして身体にかけられるのも、貴方の独占欲を受けているみたいで嫌いで\nはないですけれど……でもやっぱり中に出して欲しかったですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「だって、中に出してもらったら、貴方との子供ができるじゃないですか……\nふふふっ、妻として子を孕むのは当然の務めですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「貴方と、うららと、私と、私たちの子で、温かな家庭を築きましょう。私は\n、貴方とならそれができるって理解しましたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00027501_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「ですから、ねえ？　次は中にたっぷりと出してくださいね。次とは言わず、\n今からでもいいですけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マスク・ザ・ブラック" ]},
		{"command":[ "SETTEXT", "「子供ができたら、どんな風に出してもらっても構いませんから。だって、私\nは貴方の妻なんですから。どんなことにもお応えしますよ。ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_275_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
