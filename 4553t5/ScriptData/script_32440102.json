{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「隊長さん？　こんな夜更けに、私を呼び出して……一体どんなお話をするお\nつもりなのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00024401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「……なんて。ええ、承知しておりますよ。貴方の望み、貴方のおっしゃりた\nいこと……。そしてそれは、おそらく私の希望と同じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00024401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「私を……抱きたいのですよね？　うふふっ……、そう身構えないでください\nませ。今、言ったではありませんか。私の気持ちも同じだと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00024401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「本日はもう、テリオンは寝床についてしまいました。そしてこの、防音完備\nの素敵なお部屋……。私達を邪魔する物など何もありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00024401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「私を抱きたい貴方と、貴方に抱かれたい私……。これ以上は野暮でしょう。\nさあ、しっとりと……大人の時間を共に過ごそうではありませんか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「んっ……ふふふっ♪　そうでしたか……貴方はこうして、ケダモノのように\n後ろからするのがお好きだったんですね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024401_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「いえ？　多少は驚きましたが……嫌悪感なんてありません。むしろ、初めて\nの冒険に……私の胸は高鳴っています。想定外って刺激的でしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「遠慮なんてしなくて結構です。さあ……めくるめく快感を、快楽を私に与え\nてください……。んっ……早く触ってほしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「ええっ……。胸でも、お尻でも……どこでも触っていいんです。貴方はどこ\nから攻めてくるのでしょうね……。あっ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「まずは胸、ですか……？　うふふっ……♪　私の触れて欲しい場所を、熟知\nなさっているんですね……あっ、そうです、そこ……乳房と……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「胸の先端……あっ♪　あっ、乳首……乳首をこねまわしながら、乳房を揉ん\nでください……。あんっ……貴方の指がめり込んで……あっ、いい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「胸を、胸を触りながら……。もう一方の手で、お尻を撫で回して……掴んで\n、いじって……あぁあ、とてもお上手です……何か所でも責めてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「……んっ……ふぅっ……♪　ふぅっ……ふぅうっ……あぁ、あぁあ……っ。\nわかりますか……？　胸とお尻をもてあそばれていると……。っぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「少しずつ、花弁が……アソコの入り口が、濡れてほぐれて……開いていくの\nが……。あっ、んっ、んっ、ん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「アソコにも、オマンコにも指を入れてください……。……っああああ……！\n　それで、それで、中をゆっくりかきまわして……！　っふぅう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「クチュクチュとかきまぜ、ながら……探ってください……！　っあんっ、そ\nこです……！　そこと、もう少し奥……！　っあぁあ、そこ……そこっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「そこが私のＧスポット……！　オチンポを挿入したあかつきには、どうかそ\nこをグリグリとえぐってください……。覚えましたか……？　はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「それから……。い、行き止まりまで指をすすめて……。んっ、もっとです、\nもう少し奥へ……。……あ！　そ、そこです、そこが子宮口ですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「そ、こ……そこにオチンポを突き刺すように、腰を叩きつけていただけると\n……大変助かりますのでっ……こ、ここ、ここも記憶をお願いします！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あ……！　あっ、あっ、あっ……！　Ｇスポット……ぉっ、子宮口っ……子\n宮の位置……！　把握できましたら、すぐ……オチンポをどうぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「今、私のオマンコは熱々のトロトロに仕上がっております……！　あのっ…\n…もう、もう指だけでは物足りなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「く……ください……。早く、ください。私のこの穴に……肉棒を期待してヒ\nクつくオマンコの奥の奥にまで、その逞しいモノを……！　ああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「入っ……♪　入りました……ぁあぁ……♪　あっ♪　あっ♪　私の肉ヒダを\nかきわけて、逞しいっ……力強いオチンポが奥の奥にまで……ぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あッ……ふっ……ふぅうっ♪　ふ～～～～っ……！　うふふふっ♪　すごい\n……！　私のオマンコもマグマのように火照っておりますが……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「貴方のオチンポも、とんでもなく熱くて硬くて……！　ずっぷり差し込まれ\nていますっ……隙間なく……！　あっ！　あっあっなんて嬉しい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あっ……んっ……！　あのっ……あのっ、私……動いてもよろしいでしょう\nか……？　もう我慢できませ、ん……オチンポ、オチンポを感じたい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「はっ、ぁっ♪　あぁっ……あぁっ！　腰……動かします……！　あんっ！　\nあんっ……あんっ、あんっ……！　腰……腰止まりません……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「貴方も……！　私を突いてください！　……あぁああ、そうっ……そうです\nっ！　太いところでＧスポットをこすって……あッ♪　あっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「子宮口を、ひしゃげるくらい……突いてっ♪　突いて、突いて……貫いてぇ\nえ……♪　ッはぁああああ……！　すごいですっ……こんなの、すごいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「っあぁあああああ……！　オマンコ、オチンポに……オチンポ様に絡みつい\nています、ご奉仕しております……！　いやらしい音をたてながらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あっ、あぁあ……しあわせぇ……！　もっとです、もっと……もっとくださ\nい！　激しく水音を奏でて……あっ！　あっ、何もわからなくなるくらい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「突いて……突いて、突いてください……！　んんんん～～～～っ……！　こ\nすれるっ……そのたびに、快感がバチバチ弾けて……あぁああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「たまりません……！　私……私、何も考えられない……！　あっ……あぁっ\n、ヌルヌルしてます、アソコが……オマンコが……ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「貴方と……貴方と１つになって、１つの……同じ快楽を共有して……！　あ\nっ、どんどん……どんどん快感が大きく膨らんでいく……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あっ……あぁ、あっ……あぁ……あぁんっ、あんっ……あんっ！　もう、ど\nうにでもして下さい……！　従います、私、貴方に従います……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「だからどうか、この忠誠の証をくださ……い！　一番奥っ……子宮口のその\n奥に……貴方の快楽の証を……！　注いで……注いでくださ、ぁい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あはぁっ♪　あはっ……！　す、ごい……！　すごいですっ……！\n　これが射精……膣内への容赦のない種付け……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「男らしい腰使いで私を魅了したあげく、初めての私に……あぁぁんっ……♪\n　孕めと言わんばかりの激しすぎる吐精……想像以上です……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「はぁあっ♪　あっ、あ～～～♪　染みますっ、私の胎内の細胞全てに……貴\n方の白濁液が染みこんでいく……これは究極の快感です……！　あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「私……わたくしぃ、今貴方の所有物になりましたっ……！　精を受け止める\nだけの肉の玩具……！　それが、それがとても良いんです……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「支配、支配されているのが快感で……！　あぁんっ！　このあたたかな雫で\n赤子が出来るかもしれないと予想するだけで……スリルに痺れます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「ええっ、ええ、もっと出してください、ひねりだして……！　私の人生、戦\n士としての誇り、何もかも射精だけで破壊して……！　壊してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あっ……♪　んんぁ……っ、はぁああ……っ♪　後戻りできなくなっていき\nます……！　子宮に、生温かい生命の種が広がって……♪　最高です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あふっ……ふぅううっ……！　動物的なマーキング、あえて避妊をせず肉欲\nのままに放たれる大量の子種をご馳走になる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「私はそういった、破滅的な交わりに興奮を禁じえません……っ。背徳で……\n罪悪感でどこまでもイってしまいます！　ッあっ、イく……イ、く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「んんんん～～～～～！！　ご、めんなさい……っ！　私だけまた達してしま\nって……！　はぁあっ♪　止まらない……っ、まだ、まだイ、く……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あぁああ……♪　結構な、お点前でした……♪　え？　満足したか……です\nか？　とても満足です……。ですが……ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「これだけでおしまいだなんて、それはイジワルというものです……。完全に\n私の身体に火がつきました。どうか、どうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「このまま、オチンポ様を抜かずに二度目の交わりを……お情けをちょうだい\nできませんか……？　したいんです、ずっと疼きが止まらなくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「このままオチンポを失うだなんて耐えられません……。っんっ……♪　私の\n……私の卑しいオマンコに貴方のオチンポをお恵みください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「この穴は、貴方のためだけにある貴方だけの穴です……。遠慮なく使って欲\nしいんです……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あッ♪　あっ、わかって……いただけたんですね！？　あっ！　ありがとう\n、ございま……すぅうっ！　オチンポ、オチンポちょうだいしますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「ふっ、ぁっ……！　あっ……！　あぁああ……っ♪　はいっ……入っていま\nす、オチンポ私の一番奥……狭いところにジャストフィットして……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「子宮っ……膣内射精されたばかりの柔らかくトロトロに蕩けた子宮口をガン\n攻めしてくださってますっ……ありがとうございま、す……あぁああんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「き、もちい……気持ちいい、良すぎて……私……！　私、漏らしそうです…\n…っ！　あんっ！　い、いえ、もう愛液をだだ漏らしにしているのかもっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あぁあ……！　私のお尻を掴んで、揺さぶって……！　貴方の昂りを……直\n接私の粘膜で感じます、深……い、あっ……強い……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「オチンポ様っ……オチンポ様ぁ……！　お慕いしておりますっ……あぁ、好\nきっ……好き、強くて格好いいっ……！　添い遂げたい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「その剛直から……ッ、ぁっ♪　迫力満点の凄まじい射精をお願いしますっ…\n…！　子宮の奥っ……私の赤ちゃんルームに種付けを……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あっあっ産みます！　産みます……赤ちゃん産みますっ、人妻戦士になって\nもいいっ……！　いいっ……いいの、オチンポ好きです……ぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「大好きなオチンポ様から最強の射精……射精っ……♪　あっ……あっ♪　ザ\nーメンっ……ドロドロザーメンの発射願います……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あひっ！？　ひぁあああっ……ひぅううう……！　ザーメン、ザーメン……\n子宮直送で到着しました……！　あっ、届いてる、届いて……るぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんっ！　このまま……何百発でも何千発でもザーメン撃ち込ん\nでくださ……いっ、あっ！　あっ……おっ♪　おぉおおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「おいし……っ、美味しいぃい……！　オマンコで……下のお口でガブ飲みす\nるザーメンは何物にも代えがたい……最高の子種ドリンクですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「おっ……♪　おっ、おほっ……おっ……♪　おぁああ……♪　射精の威力で\n下腹が浮いて……！　あっ……こんなの♪　こんなのぉお……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　さ、最後の一滴まで私がいただきますから……！　オマンコ\nに力を込めて……んんん……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「どう……ですか？　精子の在庫が売り切れるほど……陰嚢が空になるまでザ\nーメン……吐き出せましたか？　あっ……す、すみません……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「ザーメンだなんて……はしたない言葉を……。つい、興奮してしまって……\n失礼でしたか……？　精子……精液ですよね。は、恥ずかしいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「でも……本当に新鮮で、勢いのある素晴らしい精液でしたから……。ん、今\nも……お腹の中で泳いでいるのを感じるくらいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「ああ……熱いザーメンで子宮どころか、腰のあたりまで……お尻まであたた\nかくなりました。あっ！　い、いけない……また、ザーメンと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「精子。精子ですよね。……聞かなかったことにしてください。も、もう……\n！　どうして私は……。ロマンチックではなくてごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「どうぞ、どうぞ射精を……！　……んっ！？　ど、どうしたんですか？　そ\nっちは……そっちはお尻……。あぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「おしりっ……にかけるんですか……？　やっ……それは……それは初体験で\nす……！　あんっ……！　すごい、腰にまで広がって……！　んぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「はあぁ……でてます……オチンポ様から最強の子種汁が……私のおしりに\nドピュドピュ……あんっ……かけられて……また…イっくぅっ…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「んふぅううう……っ！　へ……変な感覚です……！　熱い雫が、お尻全体を\n覆いつくしていって……あっ……♪　純白のヴェールを作っていきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「せ……精液のトロトロとした感触……。足の方までしたたり落ちてきて……\n♪　ぁっ……♪　悪くない感触です……でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00024401_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「これだけの量を膣内に注ぎ込んでもらっていたらと思うと……ほんの少しだ\nけ、悔しい気持ちでもあります……。うぅ、複雑です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「……それにしても……。急にお尻に出すだなんて、もしかして貴方にはそう\nいう趣味もあるのですか？　その……後ろの方にも関心があるだとか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「私の前の方だけではなく、後ろの方にも興味があるだなんて……意外と独占\n欲が強いお方なのかしら？　それなら胸も、口も、顔も……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「うふふふ♪　この調子でしたらいずれ、全ての穴と肌を貴方の色に染められ\nてしまいそうですね……。とても楽しみです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリオン" ]},
		{"command":[ "SETTEXT", "「そんなことを考えていたら……。あっ……♪　また、興奮してきてしまいま\nした……。まったく、罪なお方です……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_244_0104410" ]},
