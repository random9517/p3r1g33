		{"command":[ "PLAYVOICE", "049_0104101" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「……ようやく私を呼んでくれたな。随分と待ったぞ。……長官をここまで待\n機させっぱなしとは……良い度胸だ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104102" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「本日は、私自らが君に、上官への姿勢というものを教えてやる。まずは、ん\n……そうだ、私が君の上に乗り……あっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104103" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「一方的に君をじゅ、蹂躙……する。案ずるな。痛いことはしない……だが、\nうんと気持ちいいことはしてやろう。……っ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104104" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ええと……ペニスはここで、私のヴァギナの穴は……あ、こ、ここだな。よ\nしよし。で、では……いくぞ。愛撫も無しでいきなり挿入だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104105" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「なぜなら私は、前戯などしている余裕もないくらい……君と繋がりたくて…\n…君を独占したくてたまらないのだからな。ん、う……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104106" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あっ……あっあっ、入っていく、入ってくる……あああっ！　すごい……す\nごいすごいっ、これがセックス……！　これが君の……ああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104107" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ど、どうだ……私のは気持ちいいか？　んっ……君のために色々と準備を重\nねてきたのだ……、毎日、指でほぐした、り……あっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104108" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「自分の指を君の指だと想像しながら、毎夜……。だから今、とても嬉しい。\nうれ、し……あっ！　あっ！　あっ、大きい……あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104109" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、ンッ、すごい……太いモノが、君の生殖器、が……ヌルヌルと私の中\nを出たり入ったり……あっ！　セックス、セックスしているぅ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104110" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「目の前がチカチカ、して……あ、ああ、もっと、もっとしたい、もっと……\nもっと、もっと……！　腰を動かせぇ……あふっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104111" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「私、も……私も、んぐっ……体重をかけながら、君を容赦なく絞り抜くこと\nを誓うぅ……あうっ！　あっ！　あっ！　あっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104112" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あぁああ……感じる、感じる、感じるぅうう……っ！　今までで一番、君と\n深くわかりあっている、粘膜と粘膜を繋げ……っ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104113" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「二人でケダモノのように腰を振って……あっ！　同じ快感を共有している、\n同じだけ気持ちよく……なってしまってるぅうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104114" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、はっ、あっ、あっ、あっ！　あっ！　もう腰を止められな、\nい……気持ち良さを逃がしたくない、あっ、止まらないっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104115" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「どうしてくれるんだ、隊長くん……！　私は、君のペニスで淫乱になってし\nまった……あっ！　業務よりも平和よりも……あああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104116" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「一本のペニスを感じたくて、はしたなく腰を振り、尻を揺らす淫売に……ペ\nニスのためなら何でもする売女に変わって、いく……あああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104117" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「何もかも君がわる、い……！　っふぅううっ！　君のペニスが魅力的すぎる\n、から……だから、だからぁ……あああああっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104118" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あんっ、あんっあんっダメぇ……ダメ、だめ、だめぇえ……っ！　素敵、素\n敵……素敵ぃいい♪　ペニス、ペニス、気持ちいいっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104119" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「腕のように太く、あっ！　骨で出来ているかのように硬く……ぅう♪　じゅ\nぽじゅぽと、正確に私の弱点を突き上げて……ぇぇえ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104120" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ、はっ、あっ、あっ、あっ！　女に言うことを聞かせるためだ\nけのペニス、女を堕落させるためだけにある悪魔のようなペニスっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104121" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「でも……好きなのぉ、これ、これ好きなのぉ……！　お酒飲んでる時みたい\nに、嫌なことはぜーんぶ忘れられるの、幸せなのっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104122" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ペニス……ペニス、ペニスで私の粘膜をかき混ぜられてぇぇえ……っ！　脳\nも身体もビリビリ痺れてたまらないのぉおおお……♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104123" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　あっ、突いて、突いて、突いて、突いて……ぇっ！　私も\nスピードを上げる、から、だから、突いて、突きまくってぇっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104124" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「っあーっ！　あっああああっ！　だ、め……ダ、メ、だめぇ、イクぅ……！\n　気持ちいいの、気持ちいいのよぉ……あああっ、イクぅううっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104125" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ん゛ーっ♪　んんぅっ♪　っ……あぁあんっ♪　一回イってもそれだけじゃ\n許してくれないのねっ、いいわ、いいわ……もっとイカせてぇ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104126" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あっ、そうだ……そうだ、そこ、だ……そこをズブズブとこすって……あっ\n！　あああああーっ！　ああっ！　う、上手すぎる……ぅ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104127" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「イクっ！　イクーぅううっ！　イクッ……！　っはぁっ、はぁ、はぁ……！\n　こんなに気持ちがいいことは初めてだ、あっ……ああっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104128" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ストレスが吹き飛んでいく、ああああっ……！　快楽だけで頭がからっぽに\n、なって……気持ちいい、気持ちがいい、気持ちいい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104129" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「もっと！　もっと！　もっとしたいっ、もっとだ……！　あっ！　あっ！　\nあっ！　あっ……もっと……もっとぉおおおっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104130" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「君はセックスの天才だ……、私なんかが君のテクニックとペニス、に抗える\nわけがないぃ……降参だっ、降参だぁっ……あーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104131" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「こいつでイクのはクセになるっ……！　このペニス、悪いペニスめっ……あ\nっ！　あっ、執拗に私を何度もイカせおってぇええっ♪」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104132" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あっ！　悪いのに好きっ、悪いから好き、だ……君のペニスが好きだ、好き\nだ、好きだ……ああああっ！　あっ！　んっ？　んんっ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104133" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「なんだ……？　君もイキそうなのか？　いいぞ……遠慮なく中に、膣内に出\nしたまえ、手加減はいらないっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104134" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「私自身が中に欲しいのだ、出来るだけ奥で射精を……あっ！　そう、そうだ\n、そこが子宮口だっ、そこを狙って……っあああっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104135" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「撃てっ！　撃てっ！　一斉射撃っ……！　来い、来い、来い、来いぃい……\n早く君のを奥にくれぇ……あーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104136" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「あぅんっ！？　来たっ、来た来たっ！　精液来た……ぁあっ♪　あっ……！\n　一番奥でビュクビュクと……あ、あっ、これは威勢がいいっ」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004901_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
