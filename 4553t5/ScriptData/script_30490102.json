		{"command":[ "PLAYVOICE", "049_0104137" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「シャワーのように……大量に膣内に発射されて……ああ……！　余韻だけで\n私もまたイッてしまいそうだ、あ、あ、あ、あ……あぁイクぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104138" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ザーメン撃ち込まれながらイクぅっ！　っあッ♪　あっ♪　あっ♪　あああ\nああああんんんっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "049_0104139" ]},
		{"command":[ "SETNAME", "冴島美鈴" ]},
		{"command":[ "SETTEXT", "「ああああ……君、君は……凄いな。敬愛せざるを得ない。君に対する評価を\n更に上げさせられてしまったよ……」", "NORMAL" ]},
