		{"command":[ "SETCHARA", "0", "char_00009901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「繁華街のスシバー周辺を、マッポーサムライが占拠した。どうやら、お前た\nちがいない隙を狙ったらしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102010002" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「え？　それじゃまさか、この公園を荒らしてたヤツらって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102010006" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "先生" ]},
		{"command":[ "SETTEXT", "「マッポーサムライに雇われたチンピラだろう。お前たちを、ここに引き付け\nるために暴れていたのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "100_010102010003" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「くっそぉ！　よくもだましやがったな！　おい、みんな！　今すぐ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102010007" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「みんな！　いざ、カマクラ！　マッポーサムライの悪事を止めないと！」", "NORMAL" ]},
