		{"command":[ "SETCHARA", "0", "char_00014501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「そんな最低賃金スレスレで、オレたちを止められるわきゃねえだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102010010" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「今すぐその機械を止めろー！　止めないと――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "099_010102010008" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "その時、不思議な事が起こった。いきなり彼らの頭上にまばゆい光が降って\nきたのだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「あ、あれ？　なに？　今の」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "099_010102010009" ]},
		{"command":[ "SETCHARA", "0", "char_00009901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「てめえ！　今なにしやがった！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "097_010102010011" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「し、知らん！　拙者は何もしておらん――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "145_010102010005" ]},
		{"command":[ "SETCHARA", "0", "char_00014501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "うろたえる彼女らをさらに強い光が包み込む。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「また！？　いったい何が――」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "096_010102010011" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "シャラク" ]},
		{"command":[ "SETTEXT", "「わ！　わわわわっ！　なんだ！？」", "NORMAL" ]},
