		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「へん！　ざまあみろっ！　みんなの公園を壊そうとするから、そういう目に\nあうんだよ！」", "NORMAL" ]},
