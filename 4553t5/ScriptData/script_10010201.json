		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マッポーサムライの手下" ]},
		{"command":[ "SETTEXT", "「まもなくでございます！　完了次第、動作テストに移るでソウロウ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「しかと承知！　ふふふふふ、今に見ておれ。この街のスシをすべてオニギリ\nに変え、拙者がスシ産業を独占してくれる！」", "NORMAL" ]},
