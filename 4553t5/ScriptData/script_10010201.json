		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「科学を悪に使うなんて、ぜーったいに許さないぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "098_010102010008" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "マッポーサムライ" ]},
		{"command":[ "SETTEXT", "「おのれおのれウサピョン姉妹！　バイトの皆さんが公園に引き付けてくれた\nのではなかったのか！　時給900円出したのに！」", "NORMAL" ]},
