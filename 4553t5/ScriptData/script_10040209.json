		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「うーん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010116610001" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「むむむむむ……なあ、ハルノブ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010116610001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「なんです。どうかしたですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「お前、戦闘中にさ……必要以上にカツマを避けてねえか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010116610002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「そうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「いや、間違いないって。私もさっきから気になってた。なんでだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「なんで、と言われても……キモいからですかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「――というのは冗談として……ウチは言われて始めて気づきました。完全に\n無意識だったです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116610004" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「無意識ねえ……でも、なにか思い当たる原因とかない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_020116610001" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「さあ……よくわかりません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116610005" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なんでもいいんだよ。例えば『顔が気に入らない！』とか『においがイヤ！\n』とか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010116610002" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「においってなんだよ、においって！　これでもいちおう気をつけては――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「におい……！　そうです、言われてみれば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116610006" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「『言われてみれば』で、そうなるの！？　俺、クサいの！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人……においの専門家たる犬としてはですな。いずれ申し上げねばなら\nぬとは思っておったのですが――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010116610001" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！？　何を言い出す気だ！？　やめろ……やめてくれ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そろそろ……いわゆる加齢臭というヤツがですな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010116610002" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ウソつけえぇえええええ！　さすがにまだそんな年じゃねえぇええええええ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「加齢はともかく、においを無意識に避けていたのはありえますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116610007" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もうやめてえええええっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ですが、変です……意識していない程度だから、そこまでひどい臭いだった\nわけではないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116610008" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「なのにどうして、そんなもので気が散ってしまうんでしょう。ウチは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110116610009" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "SETTEXT", "一方、時間城でも特訓は続いている。", "NORMAL" ]},
