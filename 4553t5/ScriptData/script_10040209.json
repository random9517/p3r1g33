		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ…はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116610001" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おおー！　さすがオボロくん！　特訓をやりきったんだね？　偉い偉い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116610001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「これで……新しい力を……いただける……わけですね？　はぁ……はぁ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116610002" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もちろんだよ！　そうですよね？　女王陛下」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116610002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「うむ。オボロよ。そなたに新たな力を授けるが……その前に聞きたいことが\nある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010116610001" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「なんでしょう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116610003" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「なぜ急にウサギ跳びなど始めたのだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010116610002" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「！！！！！！　ジェスタぁ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116610004" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっといけない！　陛下、時間が押してます！　オボロくんに力を！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116610003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「うむ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010116610003" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ちーかーらー授けよぉおーーーーーー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010116610004" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「うっ！？　うううううううっ！　うわぁあああああああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_090116610005" ]},
		{"command":[ "SETCHARA", "0", "char_00000509_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おおおおおお！　これは……！　すごい、すごいよオボロくん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116610004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「これならＥＤＯのヤツらをヒイヒイ言わせて、カツマくんをさらってこられ\nますよ！　さすがです、女王陛下ー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010116610005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「はははははははは！　はーっはっはっはっはぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010116610005" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", ";;獣人オボロ、" ]},
		{"command":[ "SETTEXT", "「うがー！」な感じでいいんでしょうか？", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000503_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａオボロ" ]},
		{"command":[ "SETTEXT", "「ううううううう！　うがぁあああーーーーーーっ！」", "NORMAL" ]},
