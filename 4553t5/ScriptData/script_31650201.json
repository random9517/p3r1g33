		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んんっ……！　まら……んぐっ、なからひっ……んぐっ、ふぶっ、んんんん\nんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203301" ]},
