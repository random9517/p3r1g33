{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0138" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あっ、センパイ、こっちっス！　こっちこっち」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00016502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「へへー、お休み時間に呼びつけちゃってすみません。でも、あーしもどうし\nても待ちきれなくてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ほら、もうお腹も空いてるじゃないですか？　そしたら、どうしても食べた\nいなぁって思うものがあってぇ……にひひ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「そしたら、ほら……センパイのチンポさんも、めっちゃ期待しちゃってるっ\nていうか？　前がモロ膨らんでるじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00016502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「そんなワケでぇ、お互いウィンウィンの関係になっちゃいましょってことで\nぇ……はい、チンポ……見せちゃってくーださいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「うわぉっ♪　やっぱり、もうバキバキに勃起してるじゃないっスかぁ。もし\nかして、あーしに誘われた時から、もうその気になっちゃいました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「へへー、それはお待たせさせちゃって申し訳なかったっス。んーっ、でも、\nもうちょっとだけ焦らしちゃいますねぇ……くんくんっ、ふぅぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「えへへ……やっぱり、美味しいものは、ちゃんと風味と感触も味わっておか\nないとですからねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「くぅ……ムレムレのキツいにおい……たまんないっすね。鼻が曲がりそうな\n臭さ……でも、これがクセになるんスよねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あぁ……ダメっス……こんなの待てるワケないっス……なんでぇ……もう、\nいただいちゃいまぁーす……あぁんむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、くぷっ、りゅぽっ、んぷっ……んんんんーーっ！　んふぅっ、\nあぁ……この味ぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「センパイ……ちゃんとおしっこした後綺麗にしてまふか？　かーなり、色々\n……残っちゃってる感じっスよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「しょうがないからぁ……あーしが、ちゅぷっ……んりゅっ、綺麗にペロペロ\nしちゃいますねぇ……れろ、えろ……んりゅっ……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んふっ、めっちゃビクビク跳ねてるし。マジ、センパイのチンポ……正直過\nぎて、超カワイイっス……ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ、えろ……れろ、れろぉ……やっぱり、先っぽとか、ビンカンっスよね\nぇ？　んふっ、口の中で……震えてますよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「れろ……んんっ、んちゅぷぅっ……れろ、マジ……センパイのチンポ舐める\nの楽しくて好きっス……キツいにおいもたまんないって言うかぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んりゅぷっ、何かオトナの味って感じがしてぇ……ちゅぷっ、チンポの皮と\nかぁ……触感も面白いしぃ……れる、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁ……ヤバ……んっ、楽しみは後に取っとく方なんスけどぉ……もう、奥\nの方……咥えたくてウズウズしてるっス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、いいっスよねぇ？　あぁんむ……くぽっ、ふぐっ……んふぅぅっ\n、深くずっぽりぃ……んりゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「むふぅぅぅっ……マジおっきい……口の中……いっぱいれふぅ……もごっ、\nおぶっ、んじゅぷっ、くぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ、んりゅっ……んぷぁっ……ヤバ……おいひぃけど……マジ……頬張る\nのがやっとっふ……じゅぷ、んちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んふぁっ……時々……息継ぎしないと……チンポで窒息したらシャレんなん\nないれふからね……じゅぽっ、ちゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「てことで……こっからは、しっかりチンポをフェラして……センパイの中に\nあるせーえき……頂いちゃおうと思いまーふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、りゅぱっ、くぱっ、んちゅっ、りゅぷっ、んじゅぷっ……んふっ\n、りゅぶっ、んぐっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁぷ……んっ、んちゅっ、ちゅぷぅっ……ろうれふか……？　あーしの…\n…じゅぽっ、フェラ……きもひぃぃーふかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「れろ、んちゅぷっ……んふっ、返事より先に……チンポ君の方が、教えてく\nれてまふっ……びくびくって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ぬぽっ、んふぅっ……唇……動かすの……いいれひょっ……？　んぷっ、じ\nゅぷっ、じゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あむ、んちゅ……この……ぷにぷにってした柔らかい感触が……堪らないん\nれふっ、じゅぱっ、ちゅぶっ、んぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ、くぷっ……裏筋ぃ……チロチロ……うぐ……むぐっ……んちゅぱっ…\n…かぽっ……ふぐっ、んちゅぷぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んぷっ、りゅぷっ……んふふぅ……スケベな音ぉ……しひゃって\nまひゅぅ……尿道……れろぉっ、れろぉぉぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んぁっ……ダメっスよ……腰を引いちゃ……じゅぷっ、んちゅぷ……しっか\nり、チンポ……味わわせてくださいっス……んじゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203131" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「じゅるるるっ、んふぅっ、そうれふ……んぁっ、中から……お汁……出てき\nました……んちゅぱっ、ちゅぷぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んふっ……先走りれふよね……？　センパイのチンポ……射精したがってる\nって感じでふね……んりゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ、くぽっ、んぐぅぅぅぅっ……なら……もひろん……このままらひてく\nらさい……センパイの濃厚チンポミルクぅ……じゅぷっ……直接……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「くぽっ、んりゅっ、ふぐぅっ……喉で味わうっス……んりゅぷっ、いつれも\n……いいれふよっ、遠慮しらいでっ……んじゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んんんんんんっ！　むぐぅぅっ……んぁっぷ……んふっ……んぐっ、こくっ\n、んくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ぷぁ……いっぱい濃いミルク……出てるっス……ちゅぷっ……んちゅぅ……\nおいひぃ……チンポミルクぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ、こく……んんっ、この喉越し……こくんっ……たまんないっス\nよぉ……んっ、んくっ、んっ、ぷぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁふっ、はぁ……一気に全部飲んじゃいました……えへへ……マジ、ご馳\n走様っス」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「れろ……ぺろっ、口の周りについちゃってるのも舐めちゃお……えへへ……\nセンパイの精液……美味しすぎっスね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……じゃ、ちゃんとお掃除しないと……と思ったんスけどぉ……に\nひひぃ……センパイのチンポ……全然パワー落ちてないですよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「これはぁ……もっと食べさせてくれるって言うかぁ……おかわりしてもいい\nってことじゃないですかねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「おやぁー？　今……チンポがぴくんって上向いちゃったっスよお？　これは\n、マジでそーいうアレじゃないですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「全く……センパイってば、正直なんスからぁ……ってことでぇ……遠慮なく\n……あぁんむっ、んちゅぷ……ちゅぷぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ぴちゃ、ちゅぱ……んっ、まず……残ってる精液の味ぃ……しっかり楽しま\nせてもらっちゃいますぅ……ちゅぷ……じゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んじゅるるっ……んぁ……ふっ……ちゅぅ……んっ、チンポの味と……精液\nのミックスぅ……ヨダレ……止まんないっスねぇ……これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「マジでお行儀悪く頬張って頂くのが大正義っスね……じゅるっ、んちゅぅっ\n……もごっ、じゅぱっ、ちゅぱぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んふぅ……あーし、今……相当ヤバい顔しへまへんか……？　見られたら人\n生オワタみたいなぁ……んじゅるるっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「れもぉ……やめられるワケ……ないんれふよねぇ……んじゅぷっ、だって…\n…チンポ……美味しすぎまふからぁ……んじゅぷぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んぱっ、ちゅぱっ、りゅぱっ、あーしの……唾と……チンポのお汁と混ざっ\nてぇ……病みつきになっちゃいまひゅうぅ……んじゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んちゅぅぅっ……もち……チンポ……気持ちよくさへるの……大事れふよね\nっ……んじゅっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ちゅぽ……んぐっ、うぐ……んぐぅ……しっかり……シコシコ……お口で…\n…ひごいてぇ……じゅぽ、くぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んりゅぷっ、じゅぱっ……ぷぁっ……んふっ……腰……突き出しても……い\nいれふよぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んぶっ！　ふぁいっ……犯して……くらさい……あーしのっ、口マンコぉ…\n…もっろ……ぐぽっ、んぐぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぷっ、んぐっ……喉に……当たるっ……チンポ……めひゃくひゃっ……激\nしいれふっ、んじゅぷっ、むちゅ……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んはっ、くぱっ、んぷぁっ……りゅぱっ……んむぅっ……また、チンポ……\n味が変わってまひゅっ……２発目……出そうれふかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、センパイのチンポの状態はバレバレれふよ……んふっ、ろうぞっ\n……好きな、ようにひてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「また飲まへてくれまひゅかっ……？　ふぉれともっ……顔っ……掛けてくれ\nまふかっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あーしっ、どっちも嬉しいっふからぁっ……もう、我慢なしで……びゅくび\nゅくっ、くらさいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んじゅぅぅっ……ふぉらっ……ろうぞっ、んっ、んじゅぅぅぅぅぅっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203220" ]},
