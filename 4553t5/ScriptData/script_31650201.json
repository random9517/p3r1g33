		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ふぁっ……こくっ、んぐっ、んくんっ、んちゅぷっ……んぐっ……ふご……\n量……ヤバ……くぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「れも、こんなおいひぃの……んっ、絶対こぼひまへんよぉ……んぐっ、こく\nっ、んくっ、んはぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「はぁ、はふっ……完飲しましたぁ……えへへぇ……マジ、ごちそーさまっス\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「やぁ、めっちゃ美味かったっス。あっと、もちお掃除もちゃんとしますから\n。待ってて下さいね……センパイ……れろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んちゅ……れろ、んちゅ……ふふっ、まだチンポ……ちょっと震\nえてますね。お疲れっした……ぴちゃ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んっ……ちゅうぅぅ……奥に残ってる分とか……吸い出しきっちゃいますか\nらね……ちゅぷぅぅ……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んちゅっ……ふはっ……ふぁいっ、これでバッチリっス！　チンポ、新品同\n様にしときましたんで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「やー、でもマジ、この味にハマっちゃってヤバいっていうかぁ。疲れた時の\n栄養補給に完璧っていうかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「そんなワケで、また出撃してお腹減った時は、いろいろよろしくお願いする\nっス！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203310" ]},
