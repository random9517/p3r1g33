		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ふぁっ……！　あぁっ、んぐっ……はぷっ、んちゅぷ……顔に……はぁぁ…\n…シャワーきまひたぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203401" ]},
