		{"command":[ "SETIMAGE", "0", "still_00016502_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んんっ……はい、掛けて下さい……センパイの顔面シャワー……サイコーっ\nス……んぁ……っぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「あぁ……ぬるぬる、べとべとぉ……ちゅぷ……あふ……んんっ……すごい…\n…せーえき……糸引いてまふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「んぁぷ……ぴちゃ……んっ、濃さも全然変わんないっスね……やっぱセンパ\nイ……絶倫精液マシーンです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ふぁ……終わりましたか？　じゃあ、残りの後始末はお任せ下さいっス。あ\nぁーんむ……ぴちゃ……んちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「れろ……えろ……んふ……頬についてるのを舐めるのも、なかなかオツな感\nじっスね。んーっ、ちゅぷっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「後はぁ……奥に残ってる分を吸い出してぇ……んちゅっ……ちゅぷぅぅぅぅ\nぅぅっ……んちゅぅぅっ、じゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、はい、おっけーっス！　やー、なんだかんだで、しっかり栄養頂\nいちゃいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「てか、やっぱりセンパイのチンポミルク、マジツボなんで。出来るもんなら\n、全部独占したい位っスよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アマ子" ]},
		{"command":[ "SETTEXT", "「ま、流石にそれはヤバいでしょうけど？　でも、また出撃してお腹減ったら\n、ぜひお願いするっス！　えっへへぇー♪」", "NORMAL" ]},
