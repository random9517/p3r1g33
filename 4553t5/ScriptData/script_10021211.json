{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだって？　宇宙船で時間城に突っ込んだぁ！？　じゃ、いまの振動は―\n―」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "急にルナテミスとの通信が繋がったと思ったら、えらく近いところにいたらし\nい。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにぃ？　貴様らも時間城にいるのか！　だったら、なにをボヤボヤしてい\nる！　さっさと皆を連れて私のところに来い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114580001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、そう言われましてもねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "連絡がついて安心する間もなく、いきなりの無理難題かよ！　とはいえ――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、いつまでも孤立してるわけにもいかないし、そっちには行きますけど\n、しばらく時間がかかりますよ？　敵がウジャウジャいるんで！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それはこちらも同じだ！　とにかく、ここまで上がって――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114580002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あれ？　ちょっと姫様？　通信切れましたけど？　もしもーし！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「他の方たちと連絡がついたんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「上の階にいるんだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうらしい。でも通信が切れちまったんで、とにかく合流するしかなさそう\nだな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「って言われても、そう簡単にはいかないよねぇ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っ！？　誰だ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いやぁ～！　やっと会えたね、カツマくん！　ずいぶん苦労しちゃったよ～\n。実はある人に頼まれて、キミを探しててね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114580002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ある人……？　いったいそれは――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふふっ……まあとにかく、迷わず行こう！　行けばわかるさ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114580003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETTEXT", "そう言って、ジェスタと名乗る女は指をパチン、と鳴らす。すると――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「ここは……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ひかえ～い！　ひかえおろ～！　こちらにおわすお方を、どなたと心得る！\n　おそれ多くも――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114580004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「刻の……女王！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだって！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっとっと……せっかくキミらの世界のギャグを仕込んできたのに、渾身の\nボケを潰さないでくれるかな～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114580005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まあいいや。こちらのお方こそ『刻の女王』陛下。多元宇宙を流れる時間す\nべての守護者にして、『時間帝国』の統治者さ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114580006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "刻の女王は俺を見て、ゆったりとした動作で手を振る。すると……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "みんな" ]},
		{"command":[ "SETTEXT", "「ルナテミス！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114580002" ]},
		{"command":[ "SETCHARA", "1", "char_00002801_01", "9", "CENTER", "-700" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "9", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00009701_01", "9", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00009801_01", "9", "CENTER", "650" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "3", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "突然そこにルナテミスそっくりの――しかし、本人でもアナザーでもない女が\n現れた！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「この子はルナテミス・ダーク。ルナちゃんの可能性のひとつ、だよ。ふふふ\nっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114580007" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "3", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「可能性のひとつ……だと？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「……女王陛下？　この男をぶった斬ればよろしくて？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「うむ。試してみよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00020199_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「承知いたしましたわ。３秒ほどお待ちくださいな！　はぁあああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114580003" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うわあああっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ルナテミス・ダークは女王の言葉にうなずくと、勢いよく斬りかかってくる！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「危ないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114580003" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ブレードシラハドリッ！　ハイッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「くっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114580004" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あぶねえ……あぶなかった……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "バッケンローダーやＳＭＮＲ、ニャンコ先生、みんなが助けに入ってくれなか\nったら、マジで殺られてるところだった……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ホクサイ" ]},
		{"command":[ "SETTEXT", "「隊長さんは私たちの仲間だよ！　やらせはしない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_096_010114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00009601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＳＭＮＲ" ]},
		{"command":[ "SETTEXT", "「イエーイ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "8", "CENTER", "-500" ]},
		{"command":[ "SETCHARA", "1", "char_00009801_01", "8", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00009901_01", "8", "CENTER", "500" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "DISPCHARA", "2", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「うむ！　弱き友を守ろうという、その気持ち！　それこそが正義のニンジャ\nパゥアーだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00010001_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "DISPCHARA", "2", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Мサムライ" ]},
		{"command":[ "SETTEXT", "「拙者とハルノブもスケダチいたす！　ハイヤーーーーーッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミスＤ" ]},
		{"command":[ "SETTEXT", "「まったく……！　邪魔くさい連中ですわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_190114580005" ]},
		{"command":[ "SETCHARA", "0", "char_00000119_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0180" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETTEXT", "一方、城内に突入したルナテミスたちは――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ちょっと！　なんなのよ、あなたーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「お主が別次元の余というわけか。それにしては、ちと歯ごたえが足りんかの\nう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「なにが『余』だい！　そのしゃべり方、誰かのマネのつもりか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おい、オボロっ！　なんで私たちを裏切った！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「裏切った……？　あなたたちの仲間になった覚えなどないです。一度も」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「こいつっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「くそっ！　なんなんだ、こいつら！　思った以上に手ごわいぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114580003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「このままでは勝てない……！　私たちにはカツマと……エンブレム・シンテ\nシスの力が必要だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「だったら連れといでよ！　あんたはルナテミス様と一緒に、カツマを探して\nくるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114580002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なんだとぉ！？　なにを言い出すんだエファ！　私もここで戦うぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114580004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「この忙しいのに、わがままを言わないでください！　カグヤもそっちに手を\n貸しな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114580003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「委細承知……！　ルナテミス様、こちらへ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010114580001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私たちには、私たちの任務がある！　行くぞ、ルナテミス！」", "NORMAL" ]},
