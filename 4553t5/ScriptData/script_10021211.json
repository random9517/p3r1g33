		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「『置いていけるか』じゃありません！　そっちはそっちで危険なんですから\n！　ルナテミス様……どうかお気をつけて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010114580004" ]},
