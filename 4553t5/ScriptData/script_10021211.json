		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちょっと待て！　おい！　引っ張るな！　エファたちを……エファたちを置\nいていけるかーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114580005" ]},
