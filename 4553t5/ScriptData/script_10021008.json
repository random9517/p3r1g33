		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫大丈夫！　そう心配すんなって！　さてと、それじゃ寮に帰って――\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

