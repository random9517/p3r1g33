		{"command":[ "SETNAME", "円盤少女Ｂ" ]},
		{"command":[ "SETTEXT", "「あーもうっ！　ふたりともなんで負けちゃうのよ～！　まったく、しょうが\nないんだから！　し～らないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_163_010114260001" ]},
