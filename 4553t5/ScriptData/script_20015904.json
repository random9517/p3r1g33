		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「むぅ、これがヴァルキリーたちの力……思った以上にやるみたいだねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023830001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「さあ、戦える人たちも少なくなってきた筈です。そろそろ降伏したらどうで\nすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830001" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「大人しくしていれば、命は助けてやる。後は元の世界への戻し方を教えても\nらおうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023830001" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「ふん、何を勝ったつもりになっている。私たちが一瞬でも膝をついたことが\nあったか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023830001" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「戦力としては、こちらが優位だと思いますが……フレイア様の強化魔法が厄\n介ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023830001" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「ふふ、ごめんなさいね。邪魔をするつもりはないのだけど、どうしてもね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023830001" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「確かに、少し膠着状態になってきたな……あまり長期戦にしたくはないが…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023830001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ならば、余がこの状況を変えてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023830001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ジェスタよ、なかなか手こずっているようではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あ、エファナティカ様……ええっと、これはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023830002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「よい、おおよそのことは分かっておる。我らが客人の敵が邪魔をしているの\nじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「やー、チェンジャーくんの飛ばし方が、甘かったのかなー。かなり近所に飛\nばしちゃったみたいで……てへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023830003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「つまりは、そやつらの動きを封じてしまえばいいのだろう。つまり……こう\nしてやればよい」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "市民Ａ" ]},
		{"command":[ "SETTEXT", "「うぅっ……た、助けて……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あっ……し、市井の民の方を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830002" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ふん、毎度毎度ワンパターンだな。偉そうなことを言う割に、随分とこすっ\nからい真似をするではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023830002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さして民衆に気を使わぬお前たちには効き目が薄いが、そやつらには効果が\nあるようじゃからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830005" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ぬぅ……下僕と違って、強引に蹴り飛ばすのは少し厳しいかも知れんな……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023830003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、俺の時も、もう少し遠慮して下さいよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さて、余は気の長い方ではない。ヴァルキリーと言ったか、直ちに武装解除\nせよ。さもなくば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830006" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "市民Ｂ" ]},
		{"command":[ "SETTEXT", "「ひ、ひぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「ま、待って下さい……！　わ、分かりました……言われた通りにしますから\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830003" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「レイア！　しかし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023830002" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「民の命は決して引き換えにできるものではありません。武器を捨てればいい\nのでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830004" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「１人だけではないな。貴様と……貴様もだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830007" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「……は、はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023830002" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「くっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023830003" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「アリーヤ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830005" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「卑怯な……これでいいんだろうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023830004" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふむ……なかなか素直に言うことを聞くではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830008" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「さあ、武装解除しました！　民を解放して下さい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830006" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「うん……？　なぜ、そなたらの言うことを聞く必要がある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830009" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「そんな……！　約束が違います！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830007" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余は、武装解除しなければどうするとも言っておらぬ。無論、武装解除した\nからと言って、解放する理由も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830010" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00028301_01", "7", "CENTER", "-1500" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "2500", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あの……エファ様……人質は……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023830004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「何……？　むっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830011" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「はーい、怪我はなかったですか？　もう大丈夫ですからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_010023830001" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "8", "CENTER", "-1500" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "0", "FAST" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "市民Ｃ" ]},
		{"command":[ "SETTEXT", "「あ、ありがとうございます……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「なっ……い、いつの間にぃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010023830005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「お前は……その、ス……スク……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023830005" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「スクルド！　貴方もこちらに来ていたんですか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830008" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「そ、そうだ、スクルドだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023830006" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「アリーヤさん……もしかして忘れていましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023830003" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「い、いや、そんなことは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023830007" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どういうことだ……何の気配もなく、余の傍らから人質を取り返しただと…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830012" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フレイア" ]},
		{"command":[ "SETTEXT", "「あの子の気配を消す力は、天界……いえ、あらゆる世界において脅威となる\n力なのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_282_010023830002" ]},
		{"command":[ "SETCHARA", "0", "char_00028201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "フェンリル" ]},
		{"command":[ "SETTEXT", "「え……そんな感じだったか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_284_010023830002" ]},
		{"command":[ "SETCHARA", "0", "char_00028401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ふぇぇぇー、やっと会えましたよ先輩！　変なとこに迷い込んで、右も左も\n分からないし、どうなっちゃうかとー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_010023830002" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「大変だったみたいね、スクルド。でも、ありがとう……危ない所だったけど\n、貴方のお陰で助かったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830009" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「え……えへへぇ、そんな、スクルドは女神として当たり前のことをしただけ\nですよぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_010023830003" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「それでも、危険を承知で飛び込んでくれたのだから……せめてお礼を言わせ\nてちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830010" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「ふぁぁ……憧れの先輩にそこまで言ってもらえるなんて……スクルド幸せで\nすぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_010023830004" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「あぁ……スクルドさん、羨ましいです……私もレイアお姉様に褒めて欲しい\nのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023830004" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あら……そうだったんですか、ヒルダお嬢様。申し訳ありません、私ったら\n全然気が付かなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830011" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「あっ、い、いえいえっ！　そんな、私ったらまるで催促するみたいなおこが\nましいことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023830005" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「いいえ、ヒルダお嬢様も本当によくやってくれていますわ……私、心から感\n謝しています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830012" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「レイアお姉様……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023830006" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「でも、ダメですね……これは、ちゃんと言葉にして伝えなければならないこ\nとです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830013" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「今からでもお礼を言わせて下さい。ヒルダお嬢様、本当にありがとうござい\nます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830014" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒルデガード" ]},
		{"command":[ "SETTEXT", "「うぅっ……レイアお姉様ぁっ！　好きですぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_281_010023830007" ]},
		{"command":[ "SETCHARA", "0", "char_00028101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「きゃっ！　お、お嬢様ったら、もう……甘えん坊さんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830015" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スクルド" ]},
		{"command":[ "SETTEXT", "「あっ、いいなぁっ、スクルドも、スクルドもぉーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_283_010023830005" ]},
		{"command":[ "SETCHARA", "0", "char_00028301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「えぇいっ、いつまでやってるつもりだ！　今はそれどころじゃないだろうが\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023830008" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「あっ……そうでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830016" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「案外、慕われてて羨ましいとかだったりしてな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アリーヤ" ]},
		{"command":[ "SETTEXT", "「なにぃ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_280_010023830009" ]},
		{"command":[ "SETCHARA", "0", "char_00028001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なな、なんでもないです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふん……人質がいないからと安心しきっているようじゃが……そう簡単に行\nくと思うか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023830013" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "レイア" ]},
		{"command":[ "SETTEXT", "「……っ……気配が強く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_279_010023830017" ]},
		{"command":[ "SETCHARA", "0", "char_00027901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「しばらく暴れてなかったからのう……久々にそなたらで楽しませてもらおう\nかのう？」", "NORMAL" ]},
