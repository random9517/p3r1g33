{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "154_0103101" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「え、ええっ……えっ……とぉ、あの。え、エッチなことしてもいいとは言っ\nたんですけど……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103102" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「その、わたし心の準備が……こ、これってぱ、パイズリ……です、よね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103103" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「えっ！？　ふぇ、フェラまでしちゃうんですか？　挟んだオチンチン……ん\nんぅ、しごいて……え、えっと」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103104" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「お口で咥えて、う……うぅっ。分かります、知識はあるんです。興味はあっ\nたから本をいっぱい読んでたし……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103105" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「や、だからどういう本を見たかなんて聞かないで下さいっ……しゃ、写真も\n漫画も、ゲームも……です」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103106" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「で、でも経験ないから、いざオチンチン目の前にすると……あぁ、こんなに\nも、んんぅ……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103107" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「グロテスク？　ち、違います……気持ち悪くなんか、ないです……お、大き\nくて、熱くて……はあぁっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103108" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「わたしに求めてるんだって感じちゃって……あ、あぁっ、わたしばっかり喋\nって、ダメですよね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103109" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「こう？　これでいいですか？　んあぁ、オチンチンが震えてる……感じてく\nれてるんですね、嬉しい……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103110" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「わたしおっぱいだけムダに大きいから……はぁぁ、エッチな目で胸ばっかり\n見られてきて……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103111" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「見られてるって思うと意識しちゃって、ドキドキしてたんです。でも、何の\n役にも立たないと思ってたのに……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103112" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「こ、こうやってオチンポ挟んでしごく時がくるなんて……ふあぁ、わ……分\nかってます。咥えるんです……よね？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103113" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「ちゅる、ちゅっ、ちゅぱ……んふぅ、これが我慢汁の味、なんだ……あうぅ\nん、ふぅぅ、ふぅっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103114" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「あむっ、ちゅむむ！　ちゅぱ、ちゅうぅ！　んふぅぅ！　お口の中でオチン\nポ跳ねて……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103115" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「そ、そんなに気持ちイイんですか？　嬉しい……も、もっと悦んで欲しい、\nです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103116" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「じゅむむ！　じゅぷ、じゅぷぷ、じゅっぷ、じゅぷっ……お口をすぼませて\n、んふうぅっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103117" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「わたし、いまぁ……すごい顔になっちゃってます、よね？　すごくエッチ…\n…！　やあぁ、言わないで」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103118" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「もっと奥まで咥えて欲しい、ですか？　んあぁ……わたし、それなら、あな\nたにイラマチオされたい……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103119" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「頭をがつって掴まれて、喉奥までオチンポ突きこまれたいです……ふぇ！？\n　どうしてオチンポ大きくっ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103120" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「こ、興奮したんですか？　変ですかね、やっぱり……わたし、自分でもマゾ\nだって気付いてるんです」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103121" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「きっと戦ってる時にドＳだから反動なんですよ、さあ、おっぱい一生懸命動\nかしてしごきますから……はあぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103122" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「どうかお口オマンコに、オチンポ突っ込んでガツガツ腰を振り立てて下さい\nっ……ふあぁ、言っちゃった……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103123" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「んみゅううぅっ！！？　んじゅ！　じゅぽ！　じゅぽぉ！　じゅぷぷぷ、ん\nっ、ん～～～！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103124" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「けふぉ！　えほっ！　いいんです、手加減……しないで……この、苦しいの\nがイイんです……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103125" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「あなたに愛されて、ううん、犯されてるって感じるから、んんぅ！？　じゅ\nぷ！　じゅぷぷ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103126" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「じゅっぽ、じゅぷぷ、んっ……んんぅ！　喉オマンコ犯されてるぅ……ぢゅ\nむむ、ぢゅぷぷ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103127" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「じゅぷ、じゅぷっ、んみゅうぅ、んふぅぅ！！　お口の中でオチンポがビク\nビクしてるっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103128" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「じゅむむ、んあぁっ、イクんですか……？　じゅむ！　じゅむみゅぅ！　喉\nオマンコに種付けしちゃう……！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103129" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「んああぁん、来てぇ、来てっ……わたしの喉、あなたのスペルマで孕ませて\n……んっ、んぅぅ～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103130" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「ぢゅぷぷ、ぢゅぷっ、ぢゅむ、んっ、ん～～～っ！！？　ぢゅむみゅ、んふ\nぅぅ、んあああぁぁ！！？」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_06" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103131" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「んぎゅっ、んんぅ……！！　えふぉ！　けふぉっ！　こん、なのぉ……ゼン\nブ飲み込めない、です……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103132" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「ごきゅっ、じゅるる、じゅむぅ、え……？　飲めとは言ってない？　んあぁ\n、でも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103133" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「あうぅ、あなただってわたしにスペルマごっくんされた方が興奮するでしょ\nう……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103134" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「じゅるりゅ、じゅぱぁ、んふぅ……なんて濃いの、これが本物のザーメン…\n…ごきゅ、ごっ……くん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103135" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「ふあぁ、はぁぁ、お口の中も、鼻の奥までスペルマ臭くて、んあぁ……鼻の\n奥まで犯されてしまいました……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103136" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「あっ、え？　あふぁ……！　ま、またオチンポ大きくなってきてますよ……\n？　ど、どうしたいんですか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103137" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「そ、そうなんですね……今度はわたしをベッドに押さえつけてヴァージン奪\nっちゃうと……ごくっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103138" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「き……来て、下さい……ご主人様ぁ。処女のくせに期待でオマンコ濡らして\nるいやらしいメス穴ぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015401_01_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103139" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「あなたの特大オチンポで調教して欲しいんです、んぁっ！？　あああぁ……\n！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "154_0103140" ]},
		{"command":[ "SETNAME", "戦闘員Ｇ" ]},
		{"command":[ "SETTEXT", "「やああぁぁん！！　好きぃ、大好きです……ご主人様ぁ、ああっ、あああぁ\nぁ～～～！！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}