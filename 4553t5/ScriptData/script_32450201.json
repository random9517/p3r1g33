{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0184" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……ん。ここでいい、かな……。確か、いつも……ここを通ってたと思うけ\nど……。うん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00024502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……あ。やっぱり来た。え？　わたしがボーッとしてた？　違うよ、おにい\nちゃんを待ってたの。統制局に呼ばれたって聞いたから。会いたくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203102" ]},
		{"command":[ "SETCHARA", "0", "char_00024502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「少しだけ、お話したいな。いい？　……ん？　もっと人のいない、落ち着け\nるところで話したいの？　……わかった。どこにいけばいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00024502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「エスティマおねえちゃんにも内緒？　えっと、それは……。うん。今日だけ\nならいいよ。それで……こんな暗いところで何をするの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……っあ……。えっちなこと、したいんだ……？　いいけど、わたし、教え\nてもらわないと何もわからないから、今日も教えてくれる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203105" ]},
		{"command":[ "SETCHARA", "0", "char_00024502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「うん。別に嫌じゃない。わたしもね？　二人っきりになりたかったし、……\nえっと。えっちじゃなくても良かったけど、ぴったりくっつきたかったの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だから……ぎゅってしがみついて、抱き着いていいなら……いいよ。わたし\nに何をしてほしい？　無乳パイズリ？　んん、知らない言葉……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203107" ]},
		{"command":[ "SETCHARA", "0", "char_00024502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「へえ。おっぱいで、フニフニ、ムニムニっておちんちんを褒めてあげるんだ\n。いっぱい刺激して、気持ち良くする……わかった。出来る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「こういうの、ご奉仕っていうんでしょ。そういうの、嫌いじゃないし……喜\nんでくれるなら、ちゃんと覚えたい。どうしたら気持ち良くなる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んっ……ぴったり胸をくっつけて……。ンッ……♪　こうやっておちんちん\nにこすりつけるんだ。わた、し、おっぱいちっちゃいから……難しいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203110" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00024502_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はぁっ……♪　ねえ、今日お仕事いそがしかったの？　んっ、なんだか、身\n体……あったかいから。肌がくっついてるとすごく落ち着く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ん、ぁ、あ、ぁ……♪　おっぱい……おちんちんにくっつけて、こすってる\nと……すっごく切ない気持ちになっちゃう……んっ、んっ、うぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「乳首が……ピリピリして、痺れる感じがして……。あっ♪　おっぱい、が熱\nくなってきて……そ、それでお股がぴちゃぴちゃって濡れて、きて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「べつに悪いことなんてしてない、のに……とってもいけない気分……。はぁ\n、はぁ……っ。おにいちゃんは、こういうのが……イイの？　っぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたしの薄い胸……ミニミニおっぱいでプニプニされるのが好きなんだ……\n。んっ……これくらいの強さで、いい……？　もっと押しつける……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁ、はぁ……すごい……♪　どんどんおちんちんが硬くなって\nくる……。あっ♪　どこまで硬くなるのか、知りたい……はぁっ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ふぅうっ……んんっ、ふぅっ、んん……！　わぁ……おっぱい、押し返され\nちゃう……。おっきくなって、太くなって……んんぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「こ、これ以上はおっきくなったらだめだよ……！　わたしのおっぱいからハ\nミ出しちゃう……！　もう充分だよ……！　んっ！？　わっ……あっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ま、まだおっきくなる……。っぅ……。お、おにいちゃん……。おちんちん\n、ゴツゴツしててぱいずり……しにくいよ……。あっ、がんばる、けど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んん……っ！　んぅ……っふぅっ、ふぅうっ……んん……！　おちんちんが\n暴れないように……ぎゅっておさえつけて……ずりずり、むにゅむにゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっ♪　んん、逃げちゃだめ……はぁっ、わたしの胸の中に、いて……！　\nあっ……。ぁっ、んぁっ、あぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「え……？　わたし、ずっとおちんちんのことばっかり見てる？　……だ、だ\nって気になるよ……。この子、動くし、形が変わるし……面白い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぁっ！？　い、今おにいちゃんが動かした！？　おちんちん、ピクピクっ\nてなった……！　じ……自分で動かせるんだ……すごい、すごい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「うん。おちんちんのさきっちょの……穴から出てくる透明なのがカウパーな\nんだよね。これを塗り広げて……。ぅ……？　ふぁ……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにい、ちゃん……！　カウパーって、なにか危険なおくすりとか入ってる\n……？　これでにゅるにゅるすると、おっぱいが、ヘンになるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっ……あっぁっ、んん……！　んんっ……んん……！　あうぅ、カウパー\nでお胸を濡らして、にゅるにゅるするのがやめられないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はぅ……あぁっ、おちんちんの上、滑るの……楽しくて、気持ち良くて、…\n…あっ！　勝手に身体が動いちゃう……あっ♪　あっぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいちゃん……！　わたしがえっちなことしてるところ、見ちゃだめ……\nっ。あっ♪　いやじゃない？　ぱいずりで気持ち良くなってるわたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おにいちゃんのおちんちんで、……んっ、気持ち良くなっちゃってるわたし\n……ゆるしてくれる？　きらいにならないで……はぁっ、はぁ、はぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……かわいい？　あっ……い、いっしょけんめい頑張ってぱいずりしてるわ\nたしのこと……かわいいって言ってくれたの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203130" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「うれしい……！　それならもっと可愛くなりたい……！　はぁっ……あぁっ\n、おにいちゃんにかわいいって思われたい……んんっ……うぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……おちんちん、ビクビクしてきたね……♪　それに……っはぁっ、おにい\nちゃんの腰、浮いてきてる……。いいよ？　おっぱい突いても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたしのおっぱい、使って気持ち良くなっていいよ……♪　っぁっ……！　\nわたしのこと、いっぱいかわいくして、おにいちゃんの好きにして……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ふぁ……んんっ、出そう？　なにが出るの？　……はぁっ、せいえき？　…\n…白いドロドロのやつ？　……ん！？　もう出るの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「きゃっ……あっ、ぁっ、あっ……！　あ、溢れてきた……！　えっ？　こ、\nこれでいいんだよね？　このまま受け止めるの？　うん、うんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「大丈夫、全部かけていいから……あっ♪　そのまま出して……。ンっ、んっ\nんっ……そうか、こんなにいっぱい中に溜まってたんだ……。んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「こ、こんなにあっつくてドロドロのがおちんちんに溜まってたなら……大変\nだったでしょ。もっと早く言ってくれればよかったのに……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だ……だってすごい量だし、ニオイだって何日もずーっと溜めてたみたいに\nくさいし……。もしかして、ずっと一人で我慢してたの……？　あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203138" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「わたしがいるのに、こんなになるまで我慢するなんて……だめだよ。ね？　\n精子溜まってきたらすぐ教えて？　いつだってこうして手伝う、からっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、わたしだったら精子……こうやって胸にかけられても平気だか\nら。辛い思いなんかしないで。相談してほしい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んん～……っ！　びゅるびゅる、ドクドクっていっぱい出たね……。まだ中\nに残ってる？　ぜんぶ出せた？　……それなら良かった……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……精子って、大人の男の人なら誰でもこんなにネバネバしてるの？　おに\nいちゃんが特別えっちなの？見て。真っ白で、濃くて……すごい臭い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「なんで、赤ちゃんを作る大切な精液がこんなにいやらしい色と粘り気なんだ\nろう……。いつもね、かけられたところがずっとペタペタしてるんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっ、でも、もちろんイヤとかじゃなくて……。……あれ？　なんでだろ。\nまた、おちんちんがムクムク～って大きくなってきた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「満足できなかった？　ちがうの？　わたしが精液を観察してるのを見て、ま\nた勃っちゃったの？　……そうなんだ。だったら……もう１回する？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「しても、いい……？　うん。おっぱいでするの、好きかもしれなくて。……\n上手になりたいの。だからたくさん練習させてほしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……いーい？　そしたら……続けるね。んっ……しょ、んんっ……こう、か\nな……？　ヌルヌルの精液があるからちょっとやりやすい、かも……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっ……！　今のこすりかた、気持ちいい？　ピクピクっておちんちんが震\nえてた。こう、だよね……。はぁ、はぁ、今の動き、こう？　うんうん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203208" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おっぱいでおちんちんを包み込むようにしながら……んっ、すりすり、むに\nむにって動かして……。っぅ……♪　押しつけて、プニプニ、して……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「たまーに変化球でちくび、あてたり、転がしたりすると……気持ちいいんだ\nよね。ちゃんと覚えてる……。……っぁっ♪　あっぁっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ、はぁっ、あああ……♪　んッ……♪　おにいちゃんを喜ばせ\nようと思って動く、と……私の方も気持ち良くなってき、て……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「胸……おっぱいがゾクゾクってする、の……っ。んっんん……！　くすぐっ\nたいみたいな、ピリピリするみたい、な……。んぁっ、んふっ、ふぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「へん、だよね……っ。わたしのおっぱい、ちっちゃくてまだ子どものおっぱ\nい、なのに……大人の女の人みたいに感じてて、えっちすぎる、よね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、ごめんなさい……っ。んぁ……ふぅっ♪　おっぱいに、おちん\nちん押しつけて気持ち良くなる悪い子でごめんな、さい……んっんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「っあっ……♪　えへへ……、おにいちゃんも悪い大人だ……♪　んっ、どん\nどんおちんちん硬くなってく……気持ちいいんだ、嬉しい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「もっともっとこすっちゃう……♪　ふ、ぅ……っ、わたしみたいなちっちゃ\nなおっぱいでも、いいの？　おちんちん気持ち良くなっちゃうの？　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あ……♪　透明なお汁が先っちょから溢れてきて……はぁ、はぁ、わたしの\nおっぱいが濡れてきた……。二人でいっしょに気持ち良くなろう……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「は、ぁ♪　はぁっ……んんッ、ぁっ……♪　ふふふ、おちんちん暴れん坊さ\nんだね……♪　ん、ぁ……いいよ、わたしの胸、好きに使っていいから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「だからいーっぱい精液作って、出してね……っ。あっ……♪　ど、どうしよ\nう……。んッ、わ、わたし、おっぱいが気持ち良すぎてイく、かも……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んんぁっ！　おにいちゃんもイッて、ほしい……！　わたしだけイくじゃだ\nめ……！　イって……イくからっ、イこうっ……ん～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ふぁっ……♪　んぁああっ……いいよ、かけて……全部かけて……っ！　ん\nぅううっ……わたしもイク……！　ふぁああっ、もうだ、めぇ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
