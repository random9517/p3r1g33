		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あーっ、あ～っ……♪　ごめんなさいっ、おちんちん、今イッてるのに……\n！　出してるのに、おっぱいくっつけちゃってごめんなさ……ああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　あったかい……気持ちいい……！　もっと、もっとちょうだい\n……っ。わたしの胸、真っ白にして……もっとぉ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「っあぁ……♪　精液、べっとべとだぁ……。わたしのおっぱいに、おにいち\nゃんの臭いが広がってく……。すん、すん……むわって臭ってくる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「なんだかこれ、さっき出してくれたのより……色が濃い気がする……。二回\n目なのにすごいね。わたしの乳首にもかかってる。あ、あああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203305" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ちっちゃいおっぱいでも、二回も射精してもらえるんだ……♪　おちんちん\nさん、ありがとう……わたし、おにいちゃんのこと……だーいすき……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んんっ……。えへへ、トロトロ～って精子……垂れておなかの方にまで流れ\nてきちゃった……。それだけいっぱい出してくれたんだよね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ルナが……。わたしができること、また１個増えたかな？　わたしのぜんぶ\nはエスティマおねえちゃんと、おにいちゃんのためにある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「でも……さすがにおねえちゃんとはこういうことはしない、から……。えっ\nちなわたしは、……おにいちゃんの独り占め、だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「……なぁに？　恥ずかしいの？　わたしだってはずかしいよ。でも、はずか\nしい自分を……おにいちゃんには、見ていてほしいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぁああっ……！　あっ……あ、れ……？　お顔が熱い……んんっ、今口に\n、苦いのがドロって入ってきたぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぁ……んぷ、うぁ……？　あっ、お、おにいひゃん……わたしのお顔にか\nけたの……？　あっ♪　と、飛び出してくる精液、えっちだよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「おちんちんから精子がぴゅっぴゅって出てくるの、よく見える……あっ♪　\nあったかぁい……♪　すっごいにおいするけど……嫌じゃ、ない……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……♪　くちゅ、ちゅぷ……ぷちゅ……。ん……ごくっ……。あぁ…\n…っ。お口の中、ヌルヌルする……精液ってこんな味、なんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「んぷぁ……♪　ふふふ、わたしのお顔にかけたいなんておかしいね……♪　\nん？　こうすると、支配欲が満たされる？　そうなんだ……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00024502_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「どぉ……？　おにいちゃんの精子で、わたしのこと……支配できた？　んっ\n……ネバネバで顔にぴったりくっついてる……すごいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「それに、さっきあんなにドクドク出したのに、こんなにすぐに増えるんだ…\n…。おちんちんって、精液って本当に不思議……いつもおどろく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「あっ……精子がまだ残ってるのかな？　おちんちんの先っちょから垂れてる\n……。んっ、わたしの胸で拭くね……。んっ、こ、こうかな……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……♪　えっと、これで綺麗になった……はず。おっぱいも、お顔も\n……ぜんぶおにいちゃんのにおいになっちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_245_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナ" ]},
		{"command":[ "SETTEXT", "「今夜、エスティマおねえちゃんがいない日でよかった……。だって、ぜった\nい気付かれちゃうもん。今だけは二人っきりで……。ね……？」", "NORMAL" ]},
