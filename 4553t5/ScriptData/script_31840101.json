		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「む、胸で……奉仕をしろと？　あぁ、やはりこうなるんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「いえ、わかりました。こういう日が来ることは、覚悟してましたから……で\nは、失礼します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「サイズ……ですか？　その……ブラのカップはＪカップです……確かに人よ\nり、少し大きい方だとは思います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「えっ……ええ？　服は全部脱がなくていいんですか？　でも、それだと胸で\n、できないと思いますけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「私も人妻ですから……胸で、したことはありますけど……夫は服を着たまま\nしろなんて、言いませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「は、はい……言われた通りにします……うう、チ、チンポ……に、ご奉仕…\n…させていただきます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっ、んふぅ……あぁ、熱い……あなたの、これ……大きくて、熱い……え\n？　あ、はい……チンポ、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103107" ]},
		{"command":[ "SETIMAGE", "0", "still_00018401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「人妻でも恥ずかしいことは、恥ずかしいですよ……当たり前じゃないですか\n、ああっ……グリグリ押しつけてこないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ、あぁ……夫と比べて……？　知りません……ずっと夫のは見てません\n、から……か、過去の男と言われても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ううっ……あまり見たことはありませんけど、たぶん大きいと思いますけど\n……一番？　ええ、そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「どう、と……言われても……んっ、やっぱり若いんだなって……大きくて、\n反り返ってて……それに硬いですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はい、では……このまま……胸、を……動かして、いきますね……はっ、ん\nっ……はぁ、はぁぁっ……はっ、うぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「こんな、感じで……いかがですか？　ええ、まあ……はい……夫とする時は\n、こんな感じでしたけど……ヌルすぎるとは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00018401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「もっと強く、ですか？　こ、こう……？　もっと？　んんっ……はっ、はぁ\nっ……こ、これくらいで……？　んっ、ふうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ……！　はっ、んふぅっ……！　痛く、ないんですか……？　\nこんなに強く、擦って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅっ……胸が、重たくて、揺らし続けるのは……はぁ、はぁ……大\n変ですけど……んんっ……これがいいなら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ふぅうっ……くっ、ふっ……お、夫のことは言わないでください……働いて\nることは知ってますけど、こんなことしてるとは思ってません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「悪いとは、思ってますけど……んっ、あぁ……仕事、ですから……仕方ない\nんです、あっ、んんっ……はぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「本当、です……仕事だから、ですよぉ……興奮してなんか、ないです……夫\n以外の人にこんなこと、して……んふぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「そんな、ノリノリ……だなんて……違います。変なこと言わないで、くださ\nい……あっ、んんっ……恥ずかしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっんっ……ふっ、うぅんっ……あぁ、胸の中で、さっきから……チンポ、\nが……ビクビクいってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00018401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「気持ちいい、ですか？　上手く、できてますか……？　それはよかった、で\nす……んっ、あんっ……あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ンンっ……そうですね……ヌルヌルしてきて、ます……我慢汁、出てきてる\nんですね……はぁ、はっ、はっ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっ、んっあっ……硬くて、ゴツゴツしてて……こんな、の……初めてです\n……今まで、と……全然違います……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あっ、あふっ！　い、今……またビクンって、震えて……あぁ、たくましい\n、チンポ……あっ、あんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00018401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はっ、ふぅっ……そんなに強く擦りつけて、こないでください……んんっ！\n　強く擦れて……熱くて、上手く動かせなくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「くぅ、うくっ、うっんんっ……ますます硬くなってぇ……あふ、あっあん…\n…あぁっ！　で、出る……？　出そう、なんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「わ、かりました……んんっ、もっと……強く挟んで……擦ります、から……\nはっ、んっ……もっと、弾ませて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00018401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁっ……！　Ｊカップの……デカパイ、を……人妻おっぱい、揺ら\nして……ご奉仕、を……あぁ、恥ずかしいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はい、胸で……受け止めますから……許してください……！　そんなはした\nない言葉で、おねだりなんて……あぁあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ、あんっ……！　んんっ、はぁぁぁっ……そんなっ、命令……んっ、ふ\nぅっ……！　だ、出して……くださいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、あっ……んんっ！　ザー、メン……私のおっぱいの中に……出\nしてっ……！　中出ししてください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あっ、んはぁっ、あぁぁっ……！　チンポ、膨らんで、きて……んんっ……\n！　あっ……はぁっ、あふっ！　んんっうぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「は、はうっ……うぅんっ……出し、てっ……出してくださいっ！　んっ、お\nっぱい……に、出してっ！　出してください……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「……んっ！　あっあっ……はぁぁぁっ！　んっふっ、んんんん～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018401_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あぁ、出て、るっ……！　チンポが……ドクドクいって……ひっ、あっ……\nはぁぁっ！　あ、あふぅ……すごい、出て、るっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んはぁ……あっ、あはぁ……たくさん、出てます……こんなにザーメン……\nすごい……はっ、ああ……あつ、いぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……そ、そう……ですか……んっ、興奮して、もらえて……よか\nったです……はぁーっ……はぁあっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「終わり、ました……？　んんっ……それなのに……まだ、大きくなってて、\n若いんですね……驚きました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00018401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「このまま、続けるんですか……？　は、はい……わかりました……んんっ…\n…はっ、あぁっ……あふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「ふぅ、はっ、あはぁ……谷間が、ドロドロしてて……変な、感じです……こ\nれ、気持ちいいんでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「確かに……ぬるぬるして、滑りやすくなってますけど……んふぅっ……はぁ\n、あふっ……はぁっ……ふっ、うぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「連続で……するなんて、したことない……ですよぉ……だって、普通……一\n回、出したら終わるじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「そんな、こと……あぁ、すごい……さっきより、熱くて、硬くなって……あ\nぁああっ……はぁあっ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「私のおっぱい、そんなにいいんですか……はぁ、あぁ……大きいだけで、重\nたくて、肩こりもひどくて……あっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00018401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「こういう、使い方をする……ためじゃない、んです……んっ、あぁっ……も\nったいない、と言われても……困ります……ん、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「オ、オナホ……？　そんな言い方しない、で……くださいぃ……あぁ、ご奉\n仕は、ちゃんとしますから……はっ、あぁあっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あぁ、夫と子供のことは……許して、ください……今は、言\nわないで……ああっ、あっ……はぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「だって、声、出ちゃう……んっ、ふぅ……こんな激しく、擦ってたら……熱\nくなりますよぉ……はぁ、はふっ、はっあぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あぁ、し、してます……胸、ドキドキしてます……正直に言いますから、あ\nぁっ……意地悪しないでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「たくましくって……男らしい、チンポ見せられて……うぅ、んふぅうっ……\nこうやって、胸で奉仕させられて……ダメなのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はあっ……あ、あふっ……身体が火照ってしまいます……それにチンポの熱\nがうつってっ……おっぱいがカヤケドしそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「い、イヤらしい……んぅっ……イヤらしい、匂いもしてます……生ぐさくて\n、鼻の奥までツンってして……蒸せそう、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はぁっ……はっ、はっ……胸で、するのが……こんなに、激\nしい行為なんて……知りません、でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「あふっ！　くっふうっ……！　んんっ！　ま、またですか？　さっき、出し\nたばかりなのにっ……んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「は、はひっ……精いっぱい、ご奉仕しますから……好きなだけ、出してくだ\nさいっ……！　あっ、あぁっ、はっはっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_184_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｊ" ]},
		{"command":[ "SETTEXT", "「んっ、んはぁぁっ……あ、熱いっ……！　んっ、滑って……ひっ、ひあっ…\n…！　あっ、あぁっ……な、中出し？」", "NORMAL" ]},
