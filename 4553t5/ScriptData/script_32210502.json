		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いつか、しんこんでなくなっても……。わたくしが愛する方は、生涯、唯一\n、この星々の中でひとりだけ。旦那さま……お慕いしておりますの♪」", "NORMAL" ]},
