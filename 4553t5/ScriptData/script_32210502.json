{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0080" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ、あの……。旦那さま。今日は、わたくしのワガママをきいてくださって\n……ありがとうございます。イベントがあまりに楽しくて、眠れなくなって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504101" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA","0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「身体の熱を冷ましに浜辺にいきたい……と言ったら、一緒に来てくれました\nよね。やさしくて、すてきな旦那さまがいてわたくしは本当にしあわせです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504102" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えへへ、せっかくですから、波打ち際で少しあそんでいきましょう。わっ、\nすっごく冷たいです！　きゃっ、足が砂に沈んで……うふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504103" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまもいらしてください！　……どうしたのですか？　じっと立ち止ま\nって……。月明かりに照らされたわたくしに、見惚れてしまった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504104" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そ、そんな……もったいないおことばです。で、でも……でもうれしい。旦\n那さま。よかったら……キスをしてください。それで、それで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504105" ]},
		{"command":[ "SETCHARA", "0", "char_00022105_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……んっ♪　ちゅっ……♪　ぁ……。そ、そうですか。旦那さまは、キスの\nあとは……その、わたくしとえっちなことを、したいんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_01" ]},
		{"command":[ "DISPCHARA","0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ……。だれかがきてしまいそうで、はずかしいですけど……いいですよ\n。旦那さまにぎゅっとされるの、だいすきです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それに……♪　わたくしを見て、こうふんしてくれているのがなによりうれ\nしくて……。おちんちん、もう準備ばんたんですね……たくましいです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい。わたくしの素肌は、旦那さまがおおいかぶさって隠してください。他\nの誰にも見られないように……。そ、それで……はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504109" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしも……旦那さまの逞しいおちんちんを、わたくしの身体の中に……\n隠してしまおうと思います。いいですよね、そのおつもりですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　本当におおきくて……かっこよくて、強いおちんちん……。これ\nが、いつもわたくしの中に入っていたなんて、とても信じられません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……わたくしのおまんこが小さすぎるから、いつも大変？　ふふふ、そうだ\nったんですね。キツくて、狭くて……あぁ♪　ち、ちがいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504112" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまのが大きすぎるだけですの……！　ほ、本当ですよ？　いつだって\n、お腹のいちばん奥……おへその裏までしっかり届くくらい長くって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしのお顔やおててなんかより、ずっとずっと……♪　こ、これがずぷ\nぅって入ってくるだけで、わたくしは……いつもびっくりして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「すぐに気持ちよくなってしまって……わけがわからなくなるんです。だから\n、必死にしがみついて、がんばって腰を揺らして……。っあ、あ、の……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504115" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「思い出したら、興奮してきました。旦那さま……どうか、わたくしのおまん\nこに、夏の思い出をください。おちんちん、入れてほしいです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁあっ♪　あぁ……！　あっん……っ！　旦那さま……旦那さまぁ……！\n　おっきいのが中に入ってきました……すごく、中が広がって、ます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504117" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……！　な、なんだかいつもより、とても熱くて硬い……よう\nな？　わたくしの水着に興奮してくれたんですか？　それとも……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んんんっ！　お、お外でしているから……？　あっ……！　か、硬い鉄の棒\nが奥の奥にまで届いているみたい、です……。すごいっ……んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504119" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしの、おなか……串刺しです♪　身体の一番真ん中に、旦那さまがい\nます……♪　ああああっ……ご、ごめんなさい。まだ、入っただけ、なのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だめっ♪　気持ちいいのが止まりません！　イッ……てしまいます♪　んぁ\nあっ♪　ひぅうっ♪　んんんっ♪　あんんんっ……♪　んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504121" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お、ちんちんに……えっちなお汁がまとわりついて……しまいましたね。こ\n、このお汁……あいえき、と言うんでしたっけ……？　っはぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あいえき、が……どんどん分泌されていくのがわかります。それに、お、お\nまんこも……旦那さまのお帰りがうれしくて、は、はしゃいでしまって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「きゅうううっ♪　きゅぅううっ♪　と……おちんちんにしがみついて、甘え\nています……♪　あっ、ぁっ、あまえんぼうでごめんなさいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504124" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「お外で、えっちなことして、お股を濡らしちゃうえっちなおよめさんでごめ\nんなさいぃ……！　……それは旦那さまもおなじ……ですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちん、ビキビキに勃起して……がまんのお汁でニチャニチャになって\nいる……？　っぁ……♪　よ、よかった。それならふたりいっしょ、ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504126" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふたりとも……えっちがしたくて、えっちに興奮して……たくさん濡れてし\nまうなんて、……ふふふっ♪　しんこんさんだから、両想いです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504127" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「しんこんで、愛し合っているふたりだから……。ひとつになるだけで、こん\nなに気持ちがいいんですね。えっちなことばっかり、考えて……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……旦那さま？　わたくしのおまんこは、たしかに誰よりもちっちゃいかも\nしれません。で、も……旦那さまだけはちゃんと受け入れられますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ど、どうぞ、好きなように動いてください。わたくしに気をつかって、じー\nっとしていなくてもだいじょうぶです。んっ、しんぱいむようです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504130" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「何度もすぐにイッてしまうかも、しれません……けど♪　およめさんのおま\nんこは♪　……あっ♪　旦那さま専用のらぶらぶおまんこです、からっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　うごいて……うごいてください、わたくしの中っ、かきまわし\nてください！　つよく……つよくぅっ！　あぁっ！　あっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504132" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っぅうううっ♪　またイキます、が♪　お気になさらず……っ♪　んぁああ\nっ♪　あぁっ♪　またです、またイキます！　あぁっ！？　あっあっあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ふぇ？　わたくしがイクたびに……おちんちんが締めつけられてせいえ\nきがでちゃいそう、ですか？　ふふふっ、いいですよ♪　だしてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504134" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしもっ♪　また……またっ♪　んんんっ！　イキます、から！　いっ\nしょに……いっしょにイッてください、ふぁああっ！　い、イキますぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504135" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁああああああっ♪　あ～～～～～っ♪　あっついのが、旦那さまの赤ち\nゃんの種がドクドクって出てます！　あっ♪　あっ、気持ちいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「子宮にたっぷり種をつけてください……♪　わたくしをにんしん、させてほ\nしいんですのぉおっ♪　あああああああっ♪　もっと！　もっとです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえき出しながら、おちんちんでぐーっと押し込んでくださいぃっ！　旦\n那さまのせいえき、せいえきほしい……！　あふれるくらい！　ん～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……あっ♪　す、砂浜にこぼれてしまって……もったいないです♪　ドロド\nロのせいえき……出しながら、おまんこぐちゅぐちゅしてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504139" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「種付けっ、しながら……あっあっ！　めちゃくちゃに抱いてください！　あ\nっ♪　あっ♪　びゅるびゅるびゅるっ♪　びゅるびゅるいっぱいぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……っは～～～～～っ♪　は～～～っ、はぁああぁ……♪　は～～～～っ♪\n　はしたないことを口走ってしまいました。でも……本心です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま……。いつも、一度だけのしゃせいでは満足せずに、そのままえっ\nちを続けてくれますよね。今夜も、おねだりしていいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504202" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえき、たくさんたくさんほしいです。このまま……つながったまま、カ\nチカチのままのおちんちんで、わたくしをめちゃくちゃにしてください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「この星の方々、全員に見せつけるみたいに……♪　情熱的に、らぶらぶいち\nゃいちゃしながら、赤ちゃん……つくりましょう。おねがいです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504204" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っん……♪　わたくし、も♪　えっちに腰をうごかしますの……！　ふ、ぁ\n♪　あっ、あぁ♪　つたない腰使いかも、しれません……けれどっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504205" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまと、旦那さまのおちんちんへの愛情は誰にも負けませんの……！　\nそれを♪　あっ♪　自分で動いて証明します……！　っぁっあっぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ひぁっ！？　だ、旦那さま、ものすごいやる気ですね……♪　今、中で\nおちんちんがぐぐぐーって反り返って……すごく硬くなりました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504207" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ヌルヌルのせいえきとあいえきまみれになって、あつあつで、トロトロで…\n…♪　んっ、もう、頭がぽーっとしてなにもわからなくなってきました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　ぁっ♪　突いて……突いてください♪　はぁっ♪　あぁっ♪　旦那\nさまっ……は、はげしいです♪　わたくしの幼い身体を……あっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504209" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「貪るように激しく突きあげて……んひぅうっ！？　あっ！？　ま、またせい\nえきがびゅびゅって出ました！　ひぁっ？　も、もう止まらないんですかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ああああっ……♪　三回目……んぁっ！　よ、四回目……！　ドクドク注ぎ\nこまれています！　あっ！？　あっ、ご、五回目……！？　あああぁうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504211" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「すごい、ですのっ！　おちんちん、ずぶって奥に突き刺さるたびにっ♪　ど\nぴゅどぴゅってせいえきが♪　せいえきが流しこまれて……んぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504212" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「すてき、です♪　旦那さまぁ……！　あっぁっ、わたくしの赤ちゃんのお部\n屋が、旦那さまのせいえきでたぷたぷです、真っ白に染まっていきますぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ッんんんんん～っ♪　んんんっ！　ふぁっ♪　ああああっ、も、もう、自分\nで腰を動かせなくなってきました、腰が、痺れて……んぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504214" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい♪　はいっ♪　旦那さまが犯してくださいぃ♪　ずっぷずっぷおちんち\nんでかきまわして……！　動けなくなったわたくしを、はらませてぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504215" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ～～～～っ♪　んぁああ～～～っ♪　お、おっきな声を出したら、いけな\nいのに……！　あっ！　あっ、波の音でも消えないくらいの声、出して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504216" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしっ……わたくし、浜辺で犯されていますの……っ♪　ひぁあっ♪　\nんぁああっ♪　気持ちいい……！　旦那ひゃま、気持ちいいでしゅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「何度でもおまんこにせいえきくださいぃっ♪　っんんんんっ！　つ……次の\nしゃせいで、いちばんたくさん出す……！？　わ、わかりました……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504218" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「いっぱい♪　いっぱい溜めてから出してくださいっ♪　あ、あああ……！　\nわたくしもがんばって、おちんちん締めつけます、あっ、こ、こうですねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こう……！　こうぅうっ♪　強く締めつけて……こだねをおねだりします♪\n　おねがいします、せいしください、赤ちゃんのたね……くださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504220" ]},
