		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「月明かりの下で、愛しあうふたりが何度も快感を共有しあって……。えっち\nって、本当にすばらしいですの。どこまでも深くつながれて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「やきもちをやいてしまうことも多いですけれど、わたくしは……旦那さまに\n出会えて、たっぷり愛してもらえて満たされています……」", "NORMAL" ]},
