		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁあああああぁあ……！　旦那ひゃまぁああっ♪　すきっ……！　すきで\nす、あああっ……！　わ、わたくしもイキますぅうっ……！」", "NORMAL" ]},
