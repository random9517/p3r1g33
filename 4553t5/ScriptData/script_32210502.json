		{"command":[ "SETIMAGE", "0", "still_00022105_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ん～～～～っ♪　んんんん～っ♪　んっ、ううぅっ♪　一滴も、無駄にした\nくありませんの……ぜんぶ、ぜんぶ、中に溜めておきたいのに……ぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504304" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「やぁああっ♪　量が多すぎて溢れちゃ……ふぁああっ♪　熱い……っ♪　ひ\nぅうっ♪　んぅううっ♪　こんなにも力強いしゃせい……！　あうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくし……身も心も♪　旦那さまの色に染まりました……っ♪　そうです\n、ぜんぶ旦那さまだけのものです♪　誓いますっ、ふぁぁああんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504306" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「っん……。あっ、ま、まってください……。まだ、はなれないでいてほしい\nんですの……。このまま、ふたり寄り添って……そうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「すこしの間、星空をながめてから戻りませんか……？　まんまるのおつきさ\nま、きらきらとかがやく星々……。そして、旦那さまのくれた体温」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504308" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふふふっ♪　わたくしのお腹の中に、肌に、身体に……そして心に、旦那さ\nまがぬくもりをくれました。こんなにすてきな夜は他にありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ずうっとずうっと、こうしていたいです。しんこんでなくなっても、わたく\nしのこと……そばにおいて、かわいがってくださいね♪」", "NORMAL" ]},
