		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「きゃ……！　頭にも……お顔にも、い、色んなところにかかってますの……\nっ。あぅっ♪　おぼれてしまいます……真っ白なシャワーで……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504403" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こ……こんなにたくさんの愛が……旦那さまのおちんちんには詰まっていた\nんですね……♪　それを直接浴びられるなんて、果報者です……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぁっ♪　おまんこにはさきほどしっかりいただきましたからっ♪　あとは\n旦那さまのお好きなところに、お好きなだけ……！　んっ♪　んっんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504405" ]},
		{"command":[ "SETIMAGE", "0", "still_00022105_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ドロドロで、ねばねばのせいえき……♪　んぁあっ、何度かけてもらっても\n、毎回胸がどきどきして……苦しいですの……♪　あぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0504406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ふぁ……♪　身体中に、旦那さまの濃いにおいがまとわりついて……。\nぎゅうってだきしめられているみたいです……うふふふっ♪」", "NORMAL" ]},
