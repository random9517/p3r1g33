{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん……なにも言わないで。分かってるわ。その……今日、するんで\nしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ううん、いやじゃないわ。むしろ嬉しいの。でも、でもね、あの、笑わない\nでね……私、初めてだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「皆からママって言われててもそういう経験ないから……その、隊長ちゃん\n、やさしく、してね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ひゃん！？　あ、隊長ちゃんのおちんちん……凄く反り返ってる。私の中に\n入りたいのね……んんっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「見てるだけで身体が熱くなってきたわ……うん、隊長ちゃん、私、大丈夫だ\nから、来て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのおちんちん、中に入れて。精液を出して……二人の子供、作り\nましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふあっ、ああああっ！！　入って、きた！！　これが、隊長ちゃんのおちん\nちん……くうっああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んんっ、大きな亀頭が私の中をかき分けていくのがわかる……んんっ、あっ\n、あうっ、ふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「そう……そこが処女膜よ……私にとって隊長ちゃんが初めての証……隊長ち\nゃん、もらってくれる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふぐっ、あっ、んんっ、来たあっ！！　隊長ちゃんのおちんちん、一番奥ま\nで来たあっ！！　あっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふうっ、んっ、これで、私は隊長ちゃんのものになったのね。ふふ、嬉しい\n……好きよ、隊長ちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ、あんっ、あっ、あうっ！！　どうしたの、隊長ちゃん、急にそ\nんな、ふあっ、ああんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「私の言葉で興奮したって……？　そんな、あんっ、あっ、やっ、だめっ！！\n　そこ、奥トントンってするのだめっ！！　ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ああんっ、だからってこんん、グリグリするのも、ああんっ、あっ、だめっ\n、だめえっ！！　あうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「待って、隊長ちゃん待って！！　隊長ちゃんのおちんちんが気持ちよすぎて\n……んんっ、あっ、私、変になっちゃう、んうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「私の中が隊長ちゃんのおちんちんでいっぱいになって、ごりごりってトント\nンって、ああっ、私の頭の中までかき回されてるみたいに……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長ちゃん、好き、大好き！！　んんっ、これがセックスなのね！\n！　隊長ちゃんとの、セックスなのね！！　ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、ああっ！！　隊長ちゃんは気持ちいい？　私のオマンコ、気\n持ちいい？　んんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あううっ、んっ、こんなになってるのがその証拠？　んんっ、ならよかった\nわ、ふふっ、嬉しい。あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふふ、私の方もちょっと分かってきたかも。お腹にこうして力を入れると…\n…んんっ、隊長ちゃんのおちんちん、私のオマンコでぎゅってできるのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、こうしたら、気持ちいいのね、ふうっ、うっ、んんっ、ふふ\nっ、私も気持ちいいわ。あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、えっ、どうしたの隊長ちゃん、急に腰を動かして……あっ、お\nちんちんが……抜けて……やんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「え、これからが本番って……ふああっ、また入ってきた、んっ、おちんちん\n、硬くて熱い隊長ちゃんのおちんちんがまた入ってきたあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふうっ、うううっ、おちんちんがずりゅずりゅって、私の中をこすりあげて\nるうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、隊長ちゃんのおちんちんが動くたびに、頭の中までかき回さ\nれて……ふああっ、あっ、だめ、だめっ、頭がおちんちんのことだけになっち\nゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふああっ、あっ、ママの中が、隊長ちゃんのおちんちんの形になってる！！\n　あううっ、隊長ちゃんだけの形になってるうううう！！　んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「やあっ、ああっ、奥、ごつごつって叩かれて、ぐりぐりって潰されて、ママ\nのオマンコ、もう、隊長ちゃんにどろどろに蕩かされてるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ひあっ、あっ、だめ、だめだめだめっ！！　こんなの、こんなことされたら\nママじゃなくなっちゃう！！　ただの、女にされちゃううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「やんっ、んっ！！　隊長ちゃんのおちんちんに、私のオマンコが抱きついて\n……あううっ、んっ、お互いにちゅっちゅってキスしてる、ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んひいっ、腰が、私の腰が勝手に動いて、ふああっ、あっ、隊長ちゃんのお\nちんちんに奉仕したがってる……んんっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、隊長ちゃんも気持ちいいのね！！　腰が、がつがつってぶつ\nかってくる、んんっ、おちんちんが私の中で暴れてるっ！！　ふあああっ！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「きゅっきゅって、ちゅっちゅって、オマンコ締めつけるから、んんっ、隊長\nちゃん、おちんちんに奉仕するから、あうっ、はっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あんんっ！！　隊長ちゃんのおちんちん、さらに大きくなって、硬くなって\n、震えてる。出したいの？　ママの中にいっぱい出したいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「いいわ。いっぱい出して。ママの中に、隊長ちゃんの気持ちいいの、全部出\nして！！　全部受け止めるからっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「私の中、隊長ちゃんので全部満たして！！　おちんちんで！！　おちんちん\nから出るもので、私のオマンコ全部いっぱいにして！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あううううううっ！！　きた、きたあっ！！　隊長ちゃんの精液！！　びゅ\nぐびゅぐって、私の中にきたああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！！　精液気持ちいい！！　んんっ、私も、イく、イく、隊長\nちゃんの精液でイっくううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ぐっ、どろっどろで濃いのが出てるのが分かる……んんっ、子宮が\n溺れちゃう……ふうっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ああ……入り口から奥まで、隊長ちゃんの精液が全部満たしてる……ふうう\nっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んん、すごい……これがセックス……中だけじゃなく、心も隊長ちゃんに満\nたしてもらってる……幸せ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あっ……んっ……まだおちんちんががちがちね……もう一回……する？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「え、私のことを気遣ってくれてるの？　大丈夫、伊達にママをやってるわけ\nじゃないわ。隊長ちゃんのしたいこと、全部受け止めてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「それに……私ももう一回気持ちよくなりたいから……ね？　隊長ちゃん、二\n回目、しましょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ん、ふっ、隊長ちゃんのその動き、好き。私も、んんっ、どう？　気持ちい\nい？　ならよかった。ここにこう力を入れれば……んっ、ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっあっ、そんな、角度をつけてこするなんて……カリ首が中を\nこすり上げて、ふああっ、あっ、だめっ、またっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふうう、こすり上げた壁に竿がみっちりひっついて、隊長ちゃんが私と密着\nしてる……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「私も……んんっ、隊長ちゃんのおちんちんに愛されるだけじゃなく、オマン\nコで愛してあげる、こうして、きゅっきゅって……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふうっ、うううっ！！　愛して、愛されて、隊長ちゃんとのセックス、んん\nっ、凄い……好き……やんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ああんっ！！　隊長ちゃんのおちんちんも暴れまわってる！！　私の中、ご\nんごんって叩いてきてる！！　ひあっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「いいのよ、私の、ママの中で一杯暴れていいの。全部、受け止めて抱きしめ\nてあげるから！！　愛しい隊長ちゃんのおちんちんなら、全部受け止めるから\nっ！！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！？　あんっ、ああっ、あっ！！　受け止めるっ、受け止める\nけど、そんな速く動かれたら、あっあっあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ああっ、だめ、だめっ！！　おちんちんでそんなごしごしこすられたらっ！\n！　ごつごつ叩かれたらっ、ふああっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「なっちゃう！！　馬鹿になっちゃう！！　隊長ちゃんのおちんちんで、馬鹿\nになっちゃううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ママなのに、隊長ちゃんのママなのに！！　ただの女になっちゃう！！　隊\n長ちゃんに女にされちゃう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふああっ、あっ、あっ！！　隊長ちゃんのおちんちん、また大きくなってき\nてる。出すのね、またママの中にいっぱい出すのね！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「いいわ、いっぱい出して！！　ママのオマンコを隊長ちゃんで満たして！！\n　ふうっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「隊長ちゃん、好き、好き、愛してるっ！！　隊長ちゃんも……ふああっ、嬉\nしいっ！！　ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104217" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「いっぱい、いっぱいちょうだい！！　隊長ちゃんの愛の証、いっぱいちょう\nだい！！　子供の種、出してっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あうっ、ああっ、あっ、私も、またイく、隊長ちゃんのおちんちんで、また\nイく、イくう、イっく！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふあああああ、隊長ちゃんのおちんちんと精液で、イっくうううううううう\nう！！　あああああああ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んうううううっ！！　きてる、隊長ちゃんの精液、私の中に入ってきてるう\nうううっ！！　ふうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「二回分……二回分の精液で私の中がおぼれちゃう……ふあっ、あああっ、熱\nい……オマンコがやけどしちゃう……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、あっ、出されてるだけで、またイっちゃう……んっ、はっ、\nああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「おちんちんが跳ねてるのが分かる……んんっ、お願い隊長ちゃん、最後の一\n滴まで全部出して……ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「私もオマンコでぎゅってするから……ママの中に、私を本当のママにする精\n液、いっぱいちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あんっ！！　最後にまたいっぱい出てきた……んっ、凄い……お腹がたぷた\nぷしてる……隊長ちゃんのくれたもので、私の中が満たされてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「幸せ……そう、これが幸せなのね。愛する人、隊長ちゃんに抱かれて、私今\n幸せだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「それに、これできっと赤ちゃんができたわ。隊長ちゃんと私の子供、きっと\n可愛くて元気な子供が生まれるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふふ、子育てには慣れてるから大丈夫よ。深海には親とはぐれた子もいっぱ\nいいたから……皆、私の可愛い子」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「でも隊長ちゃんとの子供はやっぱり特別よ。ね、ね、私、男の子と女の子、\n一人ずつほしいわ。だから……これからも、一杯愛してね、隊長ちゃん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「やあんっ！！　なんで、なんでおちんちん抜いちゃうの隊長ちゃん！！　ふ\nあっ、あああっ、だめっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、身体中に精液が……熱い……んんっ、あっ、おちんちんの先\nから精液が出てくるのが……ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ああ、凄い……ゼリーみたいな精液がべっとり貼りついて……垂れ落ちもし\nない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00018701_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「匂いも……凄い……でも、なんでこんなに幸せなの……隊長ちゃんの精液だ\nから……？　好きな人の精液だから……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「んんっ、こんなに出されたら、身体中が隊長ちゃんの匂いになっちゃうわ…\n…そんなことしなくても、この身体はもうとっくに隊長ちゃんのものなのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、最後の一滴までそんなに肌にこすりつけて……ふふ、いいわ\nよ、私の全部、隊長ちゃんの精液で浸して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「髪も、顔も、おっぱいも、お口もお腹も、オマンコも、全部全部、隊長ちゃ\nんの好きにしていいから。隊長ちゃんの精液、かけていいからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「ふふ、隊長ちゃん、嬉しそうな顔。そんなにこの姿気に入った？　じゃあま\nた今度もしてもいいわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「私も……隊長ちゃんにぶっかけられるの、嫌いじゃないから。自分が隊長ち\nゃんのものだって自覚できるもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オクティーヌ" ]},
		{"command":[ "SETTEXT", "「でも……やっぱり子供も欲しいから、ちゃんと中にも出してね、隊長ちゃん\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_187_0104410" ]},
