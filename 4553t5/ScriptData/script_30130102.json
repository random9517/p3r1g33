{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "013_0104101" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「お尻を向ければいいの？　えっと、こんな感じ……？　うぅ、なんだかちょ\nっと恥ずかしいよぉ……あんまり見ないでぇ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104102" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んあぁっ……お尻撫でられると、ぞくぞくしてきちゃう……んふぁ、さわさ\nわ触られるの、すごく気持ちいいよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104103" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あぁんっ、今度はお尻をモミモミ、んふぅっ……男の人の大っきくてゴツゴ\nツした手で揉まれると、んあぁっ、声が出ちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104104" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、お尻を撫でられたり、揉まれたり、んふぅっ、気持ちいい…\n…もっと触って欲しくて、お尻が勝手に浮き上がっちゃう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104105" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んっふふ～♪　わたしのお尻、夢中で触ってるけど、気に入っちゃった？　\nいいよ～、もっといっぱい触っても、うふふっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104106" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……デ、デカくなんてないよぉっ！　ちゃんと鍛えてるから、きゅっと引き\n締まってるし、ツンと上向いてるでしょ、ほらほらっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104107" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んもう、デリカシーがないんだから……女の子に失礼だよ？　そんなだから\n、あなたはあんまりモテないんだと思うなぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104108" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「きゃあんっ！　急にお尻を叩くなんて、ひどいよぉ！　……べつに、そうい\nうのもイヤじゃないから、先に言ってくれれば心の準備が……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104109" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「ひゃあんっ！　あひぃっ！　あぁあんっ！　ひぁああんっ！　そんな、連続\nで……はひぃいいっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104110" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……うぅ、ちがうよぉ……叩かれて感じてるわけじゃなくて……あなたにさ\nれてるからなのにぃ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104111" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……それに、そんなふうにＨな身体にしたのはあなたなんだから……強くな\nるためって言って、わたしにイヤらしいことばっかりして……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104112" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「だから、ちゃんと責任取って……最後までしてよね……もう準備はできてる\nんだよ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104113" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……あ、それともオチンポ挿れるのが怖いのかなぁ？　あなたのオチンポは\nガマンが足りないから、挿れたらすぐ出ちゃったりして……うぷぷっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104114" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んあぁあああっ！？　カチカチのオチンポが一気に奥まで、ひぅうううっ、\nずりゅりゅって入ってきちゃってるぅっ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104115" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あっあっ、奥っ、オチンポの先っぽが、ずんってして、ぐりぐりぃ、あはぁ\nあああんっ、お腹がじんじんしちゃうよぉ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104116" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あぁっ、あっあっ……熱々のオチンポがオマンコのナカ、いっぱいにしてる\nぅ……んふぅぅっ、大っきくて固くて……んあぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104117" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んっ、どうしたの……動かないの……？　それとも……もう入れただけでイ\nっちゃいそう？　んぷぷっ、いいよ、もう出しちゃっても？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104118" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あなたのオチンポがすぐぴゅっぴゅしちゃう弱～いオチンチンでも、わたし\nはキライになったりしないから、だからムリしないでも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104119" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あひぃいっ！　いきなり奥っ、ずんずんってぇっ！　激しいっ！　んあぁっ\n！　オチンポしゅごいよぉっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104120" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「子宮のところどちゅどちゅ小突いて、んあぁっ、パンパンって、お尻にぶつ\nかって、Ｈなセックスの音が鳴っちゃってるぅっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104121" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「腰をがっちりつかまれて、あひぃっ、あんっあんっあんっ！　奥までオチン\nポでずこずこされてっ、オマンコ逃げられないぃっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104122" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「オチンポの衝撃が身体中に伝わってぇっ、あひっあひぃっ！　身体がぜんぶ\n、オマンコになっちゃったみたいだよぉっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104123" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「バキバキの勃起オチンポで、オマンコぐちゃぐちゃにかき回されてっ、あひ\nぃいいんっ！　気持ちよすぎるぅっ！　頭のなか真っ白になっちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104124" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あっあっあっあっ、乱暴なセックスしゅごいっ！　オマンコずんずん、ハマ\nっちゃうぅっ、クセになっちゃうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104125" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「後ろから激しくオマンコぱんぱんされて、あひっ、あっあっあぁんっ！　Ｈ\nな道具みたいに、オチンポしごかれてちゃってるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104126" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んぁあああっ！　もっと激しくしてぇっ！　お尻パンパンしながら、オマン\nコ奥までずこずこ突いてほしいよぉっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104127" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「バキバキに勃起した立派なオチンポでオマンコめちゃくちゃにかき回してぇ\nっ！　あぁあああんっ！　いっぱいほじくってぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104128" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ！？　オチンポおっきくなってきたっ、雁首がバキバキに尖\nって、あひぃいいんっ、パンパンにふくれあがってるっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104129" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「精液出してっ！　太いオチンポの先っぽから、濃くてどろどろしたザーメン\nいっぱい射精してっ、オマンコの奥にどぴゅどぴゅ中出ししてぇっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104130" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んあっあっあっ、わたしもイくっ、イっちゃうっ！　あなたの勃起オチンポ\nにオマンコハメられて、すごいのキちゃうっ！　イっちゃうううううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104131" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んぁあああああっ！　熱いよぉっ！　マグマみたいな精液がオマンコの奥に\nどぷどぷかかってしみちゃうっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104132" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「オチンポの先っぽが子宮口にぴったりくっついて、あぁあああんっ、ザーメ\nンをびゅうびゅう、子宮に注いでるよぉっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104133" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「ネバネバの濃いザーメンが子宮の壁にべっとりとこびりついてぇ、あっあっ\nあっ、孕まされちゃうぅっ、赤ちゃんできちゃうよぉっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104134" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃっ、オチンポしゅごいっ、オマンコじゅぽじゅぽされて、んぁあ\nあっ、簡単にイかされちゃったぁっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104135" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「ふぁああっ、固くておっきなオチンポで乱暴にズコズコされるの気持ちいい\nっ……あぁあんっ、クセになっちゃいそうっ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104136" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「うぅ……まだ身体がブルブルする……脚もガクガクして、全然力が入らない\nよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104137" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あぁ、すごい……オチンポまだバキバキに固いまんまだぁ……アレでまたす\nぐに犯されちゃうんだぁ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104138" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「いいよ、教えて……大人のオトコの人のオチンポを……わたしの身体にいっ\nぱい、覚え込ませてぇ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104139" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「力強くて男らしいオチンポで、力任せにオマンコをずんずん突いて、お尻パ\nンパンされたいよぉ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0104140" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「腰が抜けて立てなくなっちゃうくらい、オチンポでずぽずぽオマンコして欲\nしいよぉ……ね、お願い…………して？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}