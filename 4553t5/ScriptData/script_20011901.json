{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "どこの組織にも所属せず、世の中にとって『悪』と判断したものに対し、自身\nの『正義』を執行するエージェントが居る。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "決して金では動かず、己が持つ倫理観で動き、悪を断罪する。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それが、フランカという女だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ターゲットを補足。正義を執行する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560001" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チンピラＡ" ]},
		{"command":[ "SETTEXT", "「ぐええええぇーーーーー！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「やっぱ姉御はすげーな！　さすが、アタシが惚れたヒーローだ！　こりゃア\nタシも負けてられねーぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560001" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フランカの強さや行動。理念に憧れ、自身も悪を倒すヒーローになった女……\nデビルトンファー。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スラム育ちで口は悪いが、人間離れした能力と武術を持ち、フランカに半ば強\n引に付いていくような形で、今日も悪と戦い続けている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「覚悟しな、悪者どもっ！　せいやーーーーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560002" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チンピラＢ" ]},
		{"command":[ "SETTEXT", "「うごっ……！　あ、兄貴……！　こいつら、つえぇ……！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「姉御！　こっちは片付けたぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560003" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「了解した。残りは私が対処しよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560002" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チンピラＣ" ]},
		{"command":[ "SETTEXT", "「畜生っ！　なんだテメェら！　一体、どこの組織のモンだっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「生憎だが、私はどこの組織にも属してない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560003" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "チンピラＣ" ]},
		{"command":[ "SETTEXT", "「ぐっ、あっ……！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「手下は全員倒した。残るは貴方だけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560004" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
		{"command":[ "SETTEXT", "「ひいいぃ……！？　ま、まま……待ってくれ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
		{"command":[ "SETTEXT", "「お、俺がなにをしたっていうんだ！？　俺はただの、善良な一市民だぞ！？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「嘘をつかなくていい。貴方の悪事は既に調べ尽くしている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560005" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「傷害、暴行、恐喝……他にも、数えきれないほどの余罪がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
		{"command":[ "SETTEXT", "「ば、バカを言うな！　俺がそんなことするワケないだろう！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「シラを切るのは勝手だけどさぁー。こちとら、ちゃーんと証拠を押さえてん\nだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560004" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "デビルトンファーが、証拠として用意した紙きれと写真を悪党に投げ渡す。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それを見た悪者は一気に顔が青ざめ、『ありえない』といった顔をし始めた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「貴方のような悪党は、この世に存在してはいけない。よって、私が正義を執\n行する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560007" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
		{"command":[ "SETTEXT", "「ひいいいぃ！？　わ、悪かった！　もう悪いことはしない！　だから許して\nくれ！　殺さないでくれ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「上っ面の謝罪など、信じるに値しない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560008" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「それに、殺しはしないから安心して欲しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「貴方が自分の罪を償い、心から反省し、その腐った考え方を改めるまで、断\n罪を繰り返すだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フランカが銃を構え、膝を付きながら頭を下げる悪者を撃とうとする。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "引き金に指をかけようとした瞬間……二人の間に、デビルトンファーが割って\n入ってきた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「……なんのつもりだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560011" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「な、なあ。もう十分だろ。こいつも反省してるみたいだし、それぐらいにし\nとかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560005" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「彼は悪だ。断罪を行い、考え方を改めさせる必要がある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560012" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「そりゃあ、アタシもこいつが悪いヤツだってのは理解してるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560006" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「でも、だからって何事もやりすぎるのはよくねぇと思うんだよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「せめて生け捕りにして、ケーサツあたりに突き出すとかさ……そういう手心\nみたいなのがあってもいいと思わねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私はそうは思わない。いいから、そこをどけ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560013" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560009" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「……前から思ってたんだけどよ。姉御のやり方で、どうしても納得できねぇ\nことがあるんだよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560014" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「アタシは、姉御に憧れてヒーローになった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560011" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「自分の理想や信念を持って行動する姉御のことをマジで尊敬してるし、リス\nペクトしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「でも、姉御の断罪は見ててつらいんだよ……いっつも殺してやった方がマシ\nなんじゃないかってぐらい、相手を追い込むだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560013" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「それで改心させてるから、ある意味正しいとは思うけどさ……あんな情けも\n容赦もないやり方だけは、どうもいただけないんだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「アタシたちはヒーローなんだし、あそこまで手酷くやらなくてもいいってい\nうか……少しくらい温情ってモンがあってもいいだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「悪に温情など必要ない。邪魔をしないでもらおうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560015" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "先ほどまで共闘していたフランカとデビルトンファーの間に、冷たい空気が流\nれる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "すると突然、先ほどまで命乞いをしていた悪者が立ち上がった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
		{"command":[ "SETTEXT", "「へっ！　仲間割れとはざまぁねぇな！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "デビルトンファーの首に腕を回して人質に取り、隠し持っていたナイフを頚動\n脈付近に突きつける。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「うぐっ……！　な、なにしやがる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560016" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
		{"command":[ "SETTEXT", "「おい、そこの女！　こいつの命が惜しかったら、武器を捨てろ！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560016" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ、姉御……！　すまねぇ……！　アタシが変なこと言ったせいで……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560017" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「……デビルトンファー。悪とは、こういうモノだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560017" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「自分勝手で、傲慢で、助かるためなら人質を取ることも厭わない。そんなヤ\nツらばっかりだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だから私は、自分の信じた正義を貫く。それを阻む相手は、何人たりとも容\n赦はしない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フランカは武器を捨てるどころか、悪者とデビルトンファーに向けて銃を構え\nる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
		{"command":[ "SETTEXT", "「お、おい！　お前！　なにしてやがる！　こっちには人質が居るんだぞ！？\n」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だからどうした。私にそんな卑怯な手が通用すると思うな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560020" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「えっ！？　ちょ！？　あ、姉御！？　まさか、アタシを見捨てたりしないよ\nな！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021560018" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「別に見捨てたりはしない。少しだけ、痛いのを我慢してくれればいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021560021" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

