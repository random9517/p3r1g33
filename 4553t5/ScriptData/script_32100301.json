{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さん、時間を作ってもらい、ありがとうございます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00021003_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「今日はですね、このテクニックフォームならではのご奉仕を隊長さんにして\nさしあげたいと思いまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、返事を聞くまでもありませんね。隊長さんのおちんぽ、もう硬くなっ\nてきてる……それでは失礼して、服、脱がせますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「相変わらずいい身体ですね……そしてこれが特別なご奉仕です。ふっ……分\n身っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00021003_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「この分身はふたりとも感覚も思考も同調していますので……完璧な協調で隊\n長さんにご奉仕できるんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「論より証拠、それではまず……れるっ、れろっ、れるるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303106" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んむっ、れるっ、どうですか、一糸乱れぬ竿舐めご奉仕は……おちんぽ、ぴ\nくぴくして悦んでいますね。れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「れるっ、ちゅっ、んむっ……こうして左右から、竿を舐めて……キスして…\n…んっ、ちゅっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おちんぽがよだれまみれになってきましたね……んっ、太くて硬い竿と大き\nな亀頭がべとべとになってます……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さん、気持ちよさそうな顔してます。んむっ、れるっ、ちゅっ、ちゅぱ\nっ……んんむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、んっ、ちゅるっ、ふふ、おちんぽの味にガマン汁が混じって\nきましたよ……んくっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「こうして……右は根本から上へ、左は上から根本へ……すれ違いフェラ、ど\nうですか？　れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「それとも、二人で一緒に先端を舌でこうして舐め回すとか……亀頭が舌先で\n暴れまわってますね、れろっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あとはこういう……左右から唇で吸い付くとか……ちゅうっ、ちゅっ、んむ\nっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んふふっ、吸い付くのがお好きなんですね隊長さん。今のが一番気持ちよさ\nそうな顔をしてますよ、ちゅうっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅっ、ちゅっ、んんっ、本当に好きなんですねこれ。そんなに切\nなそうな顔をされたら……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「もっとサービスしてあげたくなっちゃいます。それじゃあ、とっておきの…\n…これで。あー……むっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ちゅうっ、ちゅっ、れるっ、んむっ。どうですか？　先端と玉袋を同時に吸\nわれるのは……むぐっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ちゅばっ、んっ、んもっ、ちゅるっ、ちゅっ、んんむっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303119" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「柔らかい袋と、硬い先端を同時にちゅっちゅっちゅっちゅって吸って、んん\nんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ちゅっ、むっ、れるっ、んんっ、吸いながら舐めるのはどうですか？　んむ\nっ、ちゅう、れろっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「亀頭と玉を口の中でころころと……吸いながら舌で……んっ、むっ、ふうっ\n、れるっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あっ、凄い、隊長さんの顔、とろとろになってる……そんなに気持ちいいん\nですね、これ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「じゃあもっともっとしてあげます。んっ、ちゅるっ、れるっ、ちゅっ、ちゅ\nぱっ、んっ、むっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「じゅる、れるっ、れろっ、ちゅうっ、んむっ、ふっ。竿も、玉も、どんどん\n熱くなって……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「味も凄く……先走りとよだれと、おちんぽの味が混じって……んんっ、じゅ\nる、ちゅっ、んむうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「そのまま、もっと、ですか？　いいですよ。隊長さんが望むなら、いつまで\nもしてあげます。ちゅうっ、れるっ、じゅぽっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「じゅるっ、ちゅうっ、ちゅっ、んむうっ、ふふっ、おちんぽがびくびくって\n震えてきましたよ……隊長さん、そろそろイくんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303128" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「いいですよ。いつでもイっちゃっていいですよ。私のWフェラで、エッチな\nお汁をいっぱいいっぱい出してください。ちゅうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、腰が浮いてきましたよ……んんっ、れるっ、ちゅぱっ、ふっ、\nイくんですねっ、んむっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んぶっ、んっ、じゅううっ、あっ、そんな、暴れたらおちんぽが、あんっ、\nああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、ああっ、おちんぽ汁来たっ！！　隊長さんのエッチなお汁、いっぱ\nい来たっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、粘っこくて、どろってして、匂いも熱さも……ふああっ、顔にいっ\nぱい……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んくっ……味も濃い……喉に絡みついてきます……えっ、気持ちいいからこ\nんなに濃いのが出たって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふっ、嬉しいことを言ってくれますね隊長さん。分身してご奉仕した甲斐\nがありました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんが気持ちよくなってくれたのなら、私はそれが一番ですよ……まあ\n、隊長さんのおちんぽを舐めるのが好きだというのもありますけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、今の言葉でまた興奮してきたんですか？　仕方がない人ですね。私\nは別に構いませんよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303137" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんぽ、ご奉仕してるだけで私も興奮してきますから……ふふ\n、こんなエッチな形と匂いをしているんですもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「味も凄いし、そこにエッチなおちんぽ汁まで混じったら、さらに身体が熱く\nなっちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「実際、さっき飲み込んだ喉が今、ほかほかになってますよ……ほら見てくだ\nさい。あー……ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、おちんぽ、また大きくなって……二回目、したいんですか？　今す\nぐ？　ふふ、いいですよ。それじゃあ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「また、隊長さんの好きなやつ、やりますね……んっ、ちゅっ、れるっ、ちゅ\nっ、んむうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、もうに硬くなってる……本当に気に入ったんですね、これ。\nちゅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「じゃあ、こんな風に吸ったり舐めたり、二人のタイミングを完全に合わせた\nらどうですか？　ちゅっ、れるっ、ちゅうっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、答えなくてもいいですよ。その顔がもう最高だって言ってくれてます\n。それじゃあ本格的に……ちゅうっ、ちゅっ、れるれるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「舐めて、吸って、舐めて、吸って……隊長さんのおちんぽ、私達の口で綺麗\nに磨きますね……んちゅっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ほら、さっきのおちんぽ汁で汚れた隊長のおちんぽ、もうこんなぴかぴかに\n……玉袋も綺麗になりましたよ。れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふううっ、うっ、一回出したのに竿がぎんぎんで、玉もあっつあつでおちん\nぽ汁準備してる……んんっ、ふうっ、れるっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ああんっ、二人で完璧なご奉仕って思っていたのに、フェラしてるだけで身\n体が熱くなってきちゃう……んっ、ちゅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、んっ、隊長さんのおちんぽおいし……竿も、玉も、先端も……ガマ\nン汁も……全部おいし……れるっ、んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あんっ、んっ、血管もばきばきに浮いてて……男の人って感じですね……ふ\nふ、こんなの見せられたら皆隊長さんのこと好きになっちゃいますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「私？　私も当然隊長さんのこと好きですよ。でなきゃ分身してまでご奉仕し\nませんよ……ふふふ、隊長さんも、隊長さんのおちんぽも好きです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ほらほら、ちゅっ、れるっ、れろろっ、んちゅうっ。こんなに完璧な連携で\nおちんぽにご奉仕なんて、好きじゃないとできないでしょう？　ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んふっ、好きって言われて興奮したんですか？　さっきよりも更におちんぽ\nが熱くなってきましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「じゃあ、ラストスパートです。ちゅうっ、ちゅっ、れるっ、んっ、れろっ、\nちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んんっ、んむっ、口の中で先端がふるふる震えてますよ。玉もおちんぽ汁送\nりたそうにぐつぐつに煮えて……んむっ、ちゅっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「いいですよ。隊長さんのイきたいとき、イきたいタイミングでいつでも……\nおちんぽ汁、いっぱい出してください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「あはっ、んっ、凄い膨らんできた。出すんですね、それじゃあ……んむっ、\nんんっ、ちゅううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ほら、出して、いっぱい出して。私のWご奉仕でグツグツに煮えたおちんぽ\n汁、遠慮なく出して！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「イって、隊長さん、思いっきりイって、んんっ、むっ、じゅるっ、ちゅっ、\nれるっ、れろっ、んちゅううううう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んぶうっ、んっ、んむううううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「二回目なのにものすごく濃い……んむっ、それに口の中にいっぱい……んん\nっ、むっ、んぐうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んくっ、ふっ、ううううっ。味も、粘つきも……凄くて……隊長さんのおち\nんぽ汁、喉に絡みついてくる……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「飛び散ったのも、もう一人の私に舐め取ってもらって……んんっ、同時に飲\nみ込むと味も倍に……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んっ、んむっ、んくっ、んっ、んぐっ……ついつい夢中になってしまいまし\nた……おいし……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふう……ごちそうさまでした、隊長さん。ふふ、私は大満足でしたよ。隊長\nさんはどうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「凄く気持ちよかった？　そ、そうですか。もの凄く満ち足りた顔で、私もご\n奉仕できてよかったです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「まあ、二度目なのにこんなに一杯出しましたもんね……ふふ、隊長さんがお\n望みなら、いつでもまたご奉仕しますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「もちろん、そのときも分身して……今日と同じように完璧に隊長さんのおち\nんぽを唇で磨き上げますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「だから……また私のために時間を作ってくださいね、隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「んあっ、はっ、どうしておちんぽ抜いちゃうんですか！？　はっ、あああっ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00021003_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「きゃあっ、あっ！！　隊長さんのおちんぽが私の顔に……はあっ、あっ、あ\nあああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「おちんぽ汁が、私の顔と、眼鏡に……んんっ、隊長さんのエッチなお汁で…\n…塗りたくられる……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふあっ、あっ、二回目なのにいっぱい……眼鏡がネバネバになってる……ん\nんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「二人だから、匂いも倍になって……んっ、ぬるぬるして、どろっとして……\n隊長さんにマーキングされちゃいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「これ、洗っても匂いで皆にばれそうですね……ああ、でもそれもいいかも。\n私が隊長さんのものって公言してるみたいで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「ふふ、それにしても私の誇りである眼鏡にこんなにぶっかけるなんて、悪い\n人ですね隊長さんは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「でも、隊長さんが望むなら、いつでも眼鏡にかけていいんですよ？　特別、\nですからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「そう言ったらまたおちんぽがぴくぴくしてますね。想像しちゃいました？　\n二回も出したのに元気な人ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミラクルマム" ]},
		{"command":[ "SETTEXT", "「だけど、そういうところも含めて好きになったんですけどね。何回も言いま\nすけど、隊長さんだけですからね、こんな事を言うの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_210_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}