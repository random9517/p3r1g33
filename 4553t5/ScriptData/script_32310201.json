{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「う～～～ん♪　久しぶりに外に出たなぁ♪　野外公園かぁ……。ボクには健\n全すぎる気もするけど……い～い天気だ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00023102_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「フフフ、キミも早くこっちにおいでよ。……え？　何の理由でボクに呼び出\nされたのかわからなくて警戒してる？　ふーん、そうだったのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もちろん、理由はあるよ？　仕事の息抜きと、キミとのデートと……。でも\n、そうだね？　一番の理由は……。オシオキ、かな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00023102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「お仕置き。最近キミは、ボクを放置しすぎだからね。優しくわからせてあげ\nようと思ってさ。愛しいキミへのあま～いお仕置き……受けてくれるよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「は～い、オチンチンをぽろーんっとね……♪　んふふふ、驚いてる驚いてる\n。さてここで、キミはボクに何をされてしまうと思う？　想像して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00023102_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……なんて、そんなに難しい問題じゃないよ。見たままさ。さんさんと降り\n注ぐ太陽の光の下、野外でフェラチオ……ふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミに損なんか１つもないだろ？　これはお仕置きであり、ご褒美なんだ。\nキミへのお仕置きで、ボクへのご褒美……。あはは、困った顔をしてる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふふ、その困っている表情は好きだな。もっと見せてもらいたい。だから\n……このまま続けさせてもらおうか。ボクはキミのその顔と反応を見ながら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「チンポを舐めて、しゃぶって、ねぶりつつ……♪　オナニーさせてもらうよ\n。あっ、ボクには触っちゃダメだから。オマンコはおあずけで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203109" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぴちゃぴちゃに濡らしているボクを見ながら、オチンポかた～くしておくん\nだよ……♪　え？　好きなコに意地悪するのって興奮するじゃないか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……それにしても……デカいチンポだね……。何度見てもギョッとするよ。\nこんなのつけてて、よく日常生活が出来るもんだ。驚愕だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203111" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「今日は気温も高いから、オチンポもムレムレで……少しニオイも強いみたい\nだ。それに、イタズラされてるっていうのにもう完全フル勃起でさ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「イジめてイジめてっておねだりされてるみたいだよ。強くてかっこいい、巨\n大なオチンポ……。ごくっ、こんなの、口に入りきるかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「手でなでなでしてあげる……。っわっ、ビクビクッて跳ねた！　わかった、\nわかったって……。指でするのじゃ満足できないってわけね。はいはい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクの可憐な唇と、いやらしい舌でた～っぷりナメナメしてあげるよ……。\n焦らしてばかりいると……フフ♪　怒られてしまいそうだしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「それじゃ、いくよ……。んっ……ぱくっ。んむ……ちゅぷっ、ちゅっ、ちゅ\nぅ……♪　あは♪　妙な味……続けるね。んっ、ちゅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203116" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「っふ♪　ふぅっ、ふぅ……♪　え？　鼻息が当たってくすぐったい？　それ\nくらい我慢しなよ……。すぐに快感でわけわかんなくなると思うし？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「っちゅっぷ……ちゅぱっ、ちゅぱ……ちゅっぷっ……♪　ぴちゃっ、ぴちゃ\n……ちゅぷっ、ぷちゅ、ちゅっぷっ……ふぁああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まだ本気出してないのに、気持ちよさそ～……♪　んん……舌先で先端をチ\nロチロしちゃおっかな……。れろっ……ぴちゃぴちゃぴちゃ、れろれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んッ……んっ、ん……♪　うわっ、暴れないでって……！　うまく照準が定\nまらないじゃないか……。おとなしくしてよ、……んっちゅ……れろ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あ、れぇ？　キミ……。野外でオチンポねぶられてるのに、いつもより興奮\nしてるんじゃないかい？　硬さがハンパないことになってきてるんだけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203121" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「やだやだ、ヘンタイじゃん……♪　でも、ま、それはボクもかな……？　っ\nふ……♪　見て、ボクのここ……オマンコすっごく濡れちゃってる……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「これぇ……キミのが欲しいって意味だよ……？　んふ……♪　聞こえるよね\n、水音……ぴちゃぴちゃ、くちゅくちゅって……指で掻き回して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「気持ち良くなりながら……キミのをおしゃぶりするんだ。このもどかしさが\nクセになる……。っちゅっぱっ、ちゅぱ……♪　ちゅぅ、ちゅぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あ……♪　この硬いトコ、美味しいな……。っくちゅっ、チュッ、ちゅ……\nちゅぅっ♪　ちゅ……ちゅ、ちゅっぷっ、くちゅっ、ちゅっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ねえ、腰突き出して……ボクのお口の中に少しでも多くオチンポ入れてよ…\n…♪　れろ……気持ちいいでしょ？　舌がぬめって……れろ……れるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「カワイイ女の子が、オナニーしながら自分のモノをおしゃぶりしてくれてる\nんだよ？　はぁ、はぁ……外で誰に見つかるかわかんないこのスリル」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「フェラしてるだけで簡単にイキそぉ……♪　あんっ、んん、指が止まんない\nよ……♪　はぁっ……あぁ、あぁっ、あぁ……ちゅ、ちゅ、ちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203128" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「キミも……キミもオチンポからカウパー滲み出してるし、同じ気持ちだよね\n……♪　あははっ、ボクたちはエッチ仲間だ。両方ドスケベ……いいね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もっともーっと仲良くなっちゃおうねぇ……♪　はぁ、はぁあ♪　くちゅ…\n…ちゅぷぷぷ♪　れろっ……れろぉ……くっちゅっ、ちゅるっ、ちゅぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「夢中になって、手も口もがっついちゃう……♪　はむっ♪　キミの反応もス\nッゴくイイし……楽しい♪　面白い、このお仕置き……最高……ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「いっぱいいっぱい舐めてあげるねぇ……♪　んれろっ、れろ……れるれるれ\nるっ、くちゅっ、ぷっちゅっ！　ぐちゅっ、ぐちゅっ……んんんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あぁ～♪　出したくなってきたぁ？　いいよぉ？　さすがに射精まで禁止し\nないよ……。好きな時に出せばいいじゃん。ぴちゃっ、ぴちゃ……れる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「でもさぁ？　つまんない射精はしないでよ？　ボクを驚かせて？　イかせて\nよね？　……ぴちゃっ、ぴちゃ、ぴちゃ……♪　はぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「射精寸前でギンッギンのオチンポしゃぶりながら……ボクもイクっ、イくぅ\n……♪　あ……♪　ふぁあああ♪　ぢゅるっ、ぢゅるるる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぷっ……んんんんぅ、ん～～～～～っ、んっ……んん～～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……うぁ、あっつぅ……♪　す、すごい量を放つじゃないかぁ…\n…！　んぅ……！　あぁ、んぷっ……んふぅううう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと受け止めきれないよ、……んっ！？　待って！　まだ……？\n　まだ出るのかいっ……んはぁああ……！　ぷぁ……うぁああ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んぷぁあ……♪　と、とんでもない巨砲を食らわされてしまったよ……っ。\nうぷ……、やるねぇ……キミ。見直した……。あ、ぅ……ドロドロだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あ……そのまま止まってて。精液の味を確かめたいから、少しこのままで…\n…。ん……、もぐ、もぐ……。んはぁあああ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「なんってしつこい味！　粘り気があって濃い精液だ……♪　これは一級品と\n認めてもいいかもしれないよ……。量も質も申し分ない……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「見てぇ……？　精子、この粘液がボクの口の中に絡みちゅいてる……♪　舌\nを上手く回せないくらいにはりついている……くふふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「お外でお仕置きされているっていうのに、こんなに出して……。キミはダメ\nな大人だね、ダメ人間だ♪　でも……そういうのってボクは好きだよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「もっともっとお仕置きして、甘やかして……ワルくてダメで怠惰なオトコに\nしてやりたくなる……。休ませるもんか、すぐに続けるよ……あむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ん……。ちゅっぷっ、ちゅっ、くっちゅっ……。にゅるぅ……にゅろっ、ぐ\nちゅ……ぐっちゅっ、ちゅぷっ、ぐっちゅっにちゅっ……ん～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふはぁっ、二回目は……ためらいなしの全力バキュームだよ……♪　っぢゅ\nるっ……ぢゅるるるっ、下品な音を立てながらおしゃぶり……ぢゅ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あぁあ♪　精液の味がこびりついてておいひ……♪　んんんっ、ボクのオナ\nニーの方も再開するから……見ててよ♪　ほら……やらしーでしょ♪　んん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「指でオマンコくちゅくちゅしながら……お口でねろねろ……。んれろぉ……\nれろっ、れろっ、ぐっちゅっぐちゅっ！　ぢゅるっぢゅっぢゅっぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぢゅる……♪　クリの包皮を指で剥いてぇ……刺激しながらオチンポねぶり\n倒して……♪　ぐっちゅっ……べろべろぉっ、ねろっ、ねろ……ぢゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「は、ぁッんんんん……！　軽くイッちゃった……♪　ふはぁっ♪　オチンポ\nから湯気が出てる……。キミも欲望を解き放ちなよぉ……！　んれろぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203210" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぢゅっぽっぢゅっぽっじゅっぽっ！　キミのオチンポの粘膜と、ボクのオマ\nンコの粘膜の快感が、リンクして２人で絶頂出来るようにさぁ、っじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「感覚を繋げて……イキまくろうよ♪　ぢゅるるるるっ、ぢゅぅううう……！\n　いくらでも受け止めて上げるから♪　っぐっちゅっ、ずちゅるるるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ、んん……♪　コレ、良すぎ……♪　オチンポしゃぶりながら指でする\nの気持ちいい♪　あっ♪　うぅ♪　れろっ……れろっ、んれろっれろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203213" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふぁああ……またイクぅ……♪　なんだこれ、楽しすぎるぅ……♪　あッ♪\n　あっ、一人でしていても……キミのモノをしゃぶっているから……はぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「すっごく気持ちいい……♪　参ったなぁ、……あっ♪　喘ぐのとしゃぶるの\nとで口が忙しすぎて……足りないくらいだ、くっちゅっ、ちゅぷ、ぷっちゅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はむ……♪　ぐちゅぅううっ♪　ちゅるっ……ちゅぅうう……！　ぬちゅっ\n！　ずっちゅっ、ぢゅるっ……ぢゅっぷっ、ぢゅるるるる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ちゅっぽっちゅっぽっ♪　ぐちゅっ、ちゅぅうう……！　はぁああ♪　美味\nし……い、キミのオチンポのヌルヌル、美味しいよ……♪　ぢゅぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「このまま……いっくらでもすすって、味わって、飲んであげるから……好き\nなように出しなね♪　ボクも勝手にイクっ♪　から……あっあっあ、ぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203218" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「そんなこと宣言してたらまた……！　はぁううう♪　んむッ……♪　チンポ\n……♪　チンポ、チンポ……ぐっちゅっ！　ぐちゅっぐっちゅっ、あぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ねえ♪　出しちゃいなよ、ビュービュー精液♪　今イッたら絶対気持ちいい\nから♪　保証するから、ほらぁ♪　出して、精液出して……ぢゅるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んむぅうううう……ッ♪　んーーーーっ、んぷっ！　んぐぅううっ……♪　\nん～～～～～♪　ドプドプっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「アハッ……やるじゃんっ……！　んぐっ……んぷっ！　んん……っ。んぷぁ\nっ……ヤバい……溺れるっ……んぷぅううっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だからっ、キミの精子は……っ、うぁっ！　ザー汁は濃厚過ぎて飲みにくい\nんだってば……！　っんん……でも、どんどん飲んでいかないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「口から溢れてこぼれてしまう……！　あふっ、し、仕方ない……一気にいく\nぞ……。っごくっ……！　ごくっ、ごく……んん、粘る……。ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んんんむ……っ。ごきゅ……ごきゅっ。んは……♪　飲んでる最中にまた追\n加されて、キリがない……！　ぢゅるっ、ごく……ごくっ、ごく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ぷっはぁああ……！　二度目の射精だっていうのに、この量……この粘り気\n……！　キミはお口でも容赦なく孕ませてくるタイプみたいだねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んん？　いや……褒めているんだよ。責めてなんかない。ただ……スゴいな\nぁって。感心しているんだ。嫌われ者のこのボクのフェラチオで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「遠慮なくこんなにドパドパ精液を発射出来るなんて……。キミの器の大きさ\nは宇宙規模だよ。ボクが認める。証人になる。本当に……スゴい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ふぁあああ……。キミの淫靡な香りに満たされて……口の中だけじゃなく、\n鼻の穴まで精液臭くなってしまった。舌にはまだまだ苦味が残っているし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……もう、ボクのお口はキミ専用のフェラチオ穴にするしかないな……♪　\nいいんだよ、それでボクも興奮するし……。お互い得をするばかりだね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「おっ！？　おぉっ！？　このボクの虚を突こうっていうのかい！？　あっ…\n…！　お口はフェイントで、本命は顔ぉ！？　やるじゃないか……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ、ああああっ……！　降り注ぐザーメンシャワーと、キミのそのイジワ\nルなトリックに魅せられて……ああっ、ボクは、ボクはイッてしまう……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁあああっ♪　ああああ……！　ああ、ああああっ……！　今までで一番\n大きな絶頂、だ……！　うん、うんもっとかけてくれ、もっと！　顔に！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁっ……あぁ……！　目をまともに開けていられない……とてつ\nもない精液の濁流……！　ふぁっ……そんなに良かったのかい、んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ボクのフェラチオ……！　お気に召したようで何よりだっ……はぁ、はぁあ\nっ……ボクもスゴく、スゴく感じさせてもらったよ……。んっあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00023102_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「はぁ～っ♪　はぁああ……っ、はぁああ～……♪　最後にまたイかせてもら\nったけれど……。んっ……キミも大概だよ、こんなに大量に出して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「お仕置きだって言ったのに、ご褒美みたいに楽しんでくれて嬉しい……。ふ\nふふっ、そうだね？　互いに楽しめるのなら、こういうのも悪くはないさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「淫らな道化師の、戯言しか出てこないこの口で……。思う存分イタズラされ\nて、お仕置き射精させられるのはどうだった？　心地よかったかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「……なぁんて、キミ自身に問いかけなくても、こっち……。チンポの方が素\n直に教えてくれているけど♪　そうかそうか、気持ち良かったかぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「だったらこれからも、気まぐれにおしゃぶりしに来てしまおうかな……フフ\nフ。いつ狙われるかわからないんだから、ドキドキしながら待っててよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_0203410" ]},
		{"command":[ "WAITINPUT" ]},
