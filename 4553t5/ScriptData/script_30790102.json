        {"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "079_0104101" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あ、ああ……ついにこの日が来てしまったね……。君といずれはこういう関\n係になるかもしれない、と思ってはいたけれど……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104102" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「き、緊張していないと言ったら嘘になる……。た、探偵はカマはかけても嘘\nはつかないものでね……ここは素直に白旗をあげるよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104103" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……今夜は僕を……君の好きなようにしてくれていい。ごくっ……その……\n信じられないくらい逞しいモノで……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104104" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕を……女にしてくれ。君の女に……。いいか？　僕は本気だ。本当に君の\nことを……。はぁ、はぁ……隊長」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104105" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ここまで来たんだ。ベッドに横になった時点で……覚悟は出来ているよ。そ\nの苦しそうなペニスを、い、いれ、入れて……ほしい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104106" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「でないと、いつも以上にはちきれそうになっているソレが……ふ、不憫じゃ\nあないか。遠慮する仲じゃない……ほら……ここだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104107" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ここにずぶりと刺し穿って……。ぁっ……そう、そう、だ……そこだ、一気\nに処女膜を貫いて……君を僕に刻み込むんだ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104108" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ん゛っ……あ！　あっああーっあぁっ……！　はぁっ……はぁ、はぁ、はぁ\n……入って……いるのか？　何？　まだ半分？　そ、そんな……」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00007901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104109" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「キツくて一度には入らなかった……？　ほ、褒め言葉と受け取っておくよ…\n…って、あっ！？　ミシミシ言っているっ、拡げられて……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104110" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あひぃっ！？　入、った……ああああ、入った、入った……ぁ！　僕の中に\n……あ、男根が……！　君の牡器官がぁ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104111" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あ、う……ううう……い、痛い、痛いけど、いいよ……っ！　う、動いてく\nれ……慣れる、慣れるから……こんな痛み……くうううっ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104112" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「君は自由にピス、トン、を……っ、あーっ！？　ああああーっ！？　なんだ\n！？　なんだ、これっ……これ、あっ、し、知らないっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104113" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕の知識とちが……ああああっ！　こ、こんな強烈な感覚、なのか……！？\n　あっ……これが……これがセックスっ……！？　すごいっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104114" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あんっ……んっ！？　あ……す、すまない……っ、今妙な声を出してしまっ\nて……！　あんっ！？　あんっ、あんっ、あぁんっ！」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00007901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104115" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あっ……あああっ♪　セックスっ……セックスっ、これっ……ああああっ…\n…！　すごい、すご……い、溺れる……ぅ、あーっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104116" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あはっ、あはははっ♪　腹の中で……君が暴れてっ……あーっ……なんっ、\nなんだねっ？　あーっ、これ気持ちいい……っ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104117" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ご、語彙力が奪われ……る、あひっ！　ひっ、ぁっ、あっぁっあっ……！　\nな、なぜ……なぜだ、粘膜同士をズリ合わせているだけでっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104118" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「どういう理論でここまでの……あふっ！　爆発的な快感が生成されているん\nだ……っ？　あぁ、あぁ、頭が……悪くなる、悪くなるっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104119" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「馬鹿になってしまうっ……あぁっ……！　このままでは……あんっ！　あっ\n！　二度と推理なんか出来ない身体にされ……あっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104120" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……それもいいかもしれない……。……じゃないっ！　や、やめたまえ！　\nやめたまえぇ！　僕の頭脳を破壊するようなピストンなぞ！」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00007901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104121" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「っあぁんっ！　あんんっ！　やめっ……や、やめ……、ぁ……！　あぁんっ\n♪　あんっ♪　あんっあぁんっ♪　ふぁああんっ♪」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00007901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104122" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「男根っ、ペニス、気持ちいいっ♪　チンポ……チンポ、デカマラぁあ……っ\n！　だめ、だ……だめだ、壊れる……ぅうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104123" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「単純な前後運動なんかでぇ……あっ♪　僕が破壊されていく……ぅううっ！\n　あっ♪　マラ肉のことしか考えられない痴女になるぅうっ♪」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104124" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あぁんっ、あんっ、ああぁあっ……見るなぁ！　こんな僕を見ないでく、れ\n……ああっ！　あぁっ？　み、見ないで……？　くれ……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104125" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「見ないで……、あっ♪　嘘っ、嘘っ……探偵嘘をついた……ぁあっ♪　見て\nくれ、見てくれぇっ……君のモノが僕のアソコに！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104126" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「僕の女のコに突き刺さってる、中で動いてる……ぅうっ！　ぜんぶ、全部見\nえてる……すごい、すごい、すごい……いぃい……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104127" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「淫靡に口を開けた肉壺、ヌルヌルの愛液に満ちた蜜壺にチンポが出たり入っ\nたりしてるっ……ズコズコって……ずぼずぼって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104128" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ずごずご突かれてる、奥っ……奥こじあけられて……誰にも許したことない\n子宮にま、で……いやらしい肉の棒を受け入れて……るぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104129" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あーっ！　あーっ、あーっ！　永遠にやめたく、ない……！　ずぼずぼ気持\nちいいっ、ずこずこ気持ちいいい……あっあっあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104130" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「頼む……頼むぅ、隊長ぉおお……！　このまま……このままぁっ！　チンポ\nで私を満たしていてくれ……イキそうになってもいいっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104131" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「構わないから……一秒でも長く、僕の膣内にいて……お願いだよ……！　だ\nって気持ちいい、気持ちいいんだ、まんこ気持ちいい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104132" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「離れたくない……恥知らずと罵られてもいいっ、おまんこをチンポで突きま\nわして……あーっ！　そうっ、そうだぁあっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104133" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……あっ♪　出そう？　抜きたい……？　ダメッ、だ……！　抜くなんて許\nさないっ……このまま……このまま……あああっ」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00007901_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104134" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「膣内（なか）に射精（だ）してっ！　射精して、射精、射精ぃい……！　射\n精する時、ドクンってなるの経験したいぃ……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104135" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あっ！　あっ！　あっ！　あっ……来るのか……来るのかっ？　いいぞ、い\nいぞいいぞ……僕も、僕もイッ……ああああああーっ♪」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00007901_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104136" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「イグっ！　イグぅっ、イっグっ……！　避妊無しでおまんこ直で種付けされ\nながら……アヘ顔晒してイッグ……っ！　いぐいぐいぐぅううっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104137" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あーっ！　あーっ、あーっ！　びゅーっ！　びゅーっ！　びゅーっ！　……\n中出し……っ、中出し気持ちいいよぉおお……♪」", "NORMAL" ]},
