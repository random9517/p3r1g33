		{"command":[ "PLAYVOICE", "079_0104138" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「……はぁーっ……はぁーっ……はぁああ……っ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "079_0104139" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「も、もう僕はダメだ……禁忌の快楽を知ってしまった。堕ちるとは……こん\nなに甘美なことだった、のか……♪」", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "still_00007901_02_07" ]},
