{
	"scriptCommands" :  [
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0006" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_003" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「これにてぇ……一見落着ぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_910021010055" ]},
        {"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "8", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "8", "RIGHTEND", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0","1","2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "盗まれたアイテムを取り返し、女怪人も倒した。色々あったが、任務は完了─ \n─と安堵した瞬間、急に腹の虫が騒ぎ出した。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「はぁ……お腹へった…………うぐぅ…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010049" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "1", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「散々走りまわったもんねぇ……はぁ……ねえ、お姉ちゃん……これから、買 \nい物行ったりご飯の支度したりするの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010052" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "6", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "財布を取り出し中身を数える序。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……うーん、ファミレスで豪遊！　と行きたいけど、ちょっと懐が寒すぎる \nかなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010056" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「……ええー？　ハンバーグとグラタンと、チキンバスケットとフルーツタル \nト……食べたかったなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010050" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「古人いわく……所詮この世は金次第……うう、こんちくしょ～～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010053" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "4", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「こんなことなら、本当にお金を奪ってやればよかったねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010051" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "7", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そんなことしたら、流石にお亥さまに叱られるかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010057" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "1", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「で、成績アップの話もなかったことになったりしたら目も当てられないもん\nね……はー、じゃあファミレスは我慢するかぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010054" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「正義の味方は無報酬がセオリーとはいえ……これは少しツラいかも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010058" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "4", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ねえ……こんなこと、ずーっと続けるの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010052" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「んー……災厄が起こったら退治する約束だし、その間、勉強しないで済むの \nは超ラクチンだよね」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010055" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「けどせめて、食費支援くらいあったらいいんだけどなー……うーん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010059" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "懐の寂しさに途方に暮れる三姉妹。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SPOTCHARA", "0","1","2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「……ん？　ねえ、見て。この張り紙」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010060" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "その時、大使館の壁に求人募集の張り紙があることに気づく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0","1","2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「えーと、なになに……悪と戦う特設部隊の隊員を募集しております、経験不 \n問、経験者優遇、報酬については応相談…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010056" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「これ、すごいんじゃない？　いんくれでぃぶる・すくわっど？　ってよくわ \nかんないけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010053" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「んー……ブラック求人の匂いがプンプンするんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010057" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「でも、お亥さまに授かった力と、若苗家の使命でお金儲けなんてしていいの \nかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010061" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "4", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "その瞬間、三人の腹が同時に鳴った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "3", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "3", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "3", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0","1","2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「ははは……お腹で合奏なんて、これ令和に生きる女学生のお話なわけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010058" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "2", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「あーもう……お腹すいたよ～……お姉ちゃん、どーするのぉ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010054" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "4", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「古人曰く、虎穴に入らずんば虎の子を得ず……背に腹は代えられないもんね \n。応募してみるです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_010021010062" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「やったー。これで、ハンバーグとグラタンと、チキンバスケットとフルーツ \nタルトとチョコパフェが食べられる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "103_010021010055" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "6", "RIGHTEND", "0" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「……何気に一品増えてる。急、恐ろしい子…………でも、これでお腹いっぱ \nい食べられそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "102_010021010059" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "これである程度まとまったお金が手に入る。そうすれば好きなものが食べられ \nるはずだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SPOTCHARA", "0","1","2" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "美味しいものをお腹いっぱい食べるシーンを思い浮かべ、自然と笑顔になる。", "NORMAL" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "8", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "8", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "8", "RIGHTEND", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "三人は顔を見合わせて頷いた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "2", "char_00010101_01", "0", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "0", "char_00010201_01", "0", "LEFTEND", "0" ]},
		{"command":[ "SETCHARA", "1", "char_00010301_01", "0", "RIGHTEND", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「せーのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_910021010063" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「思い立ったが吉日ぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "101_910021010064" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "そしてカツマ達の元に向かう三姉妹だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUTCHARA", "0", "NORMAL" ]},
		{"command":[ "FADEOUTCHARA", "1", "NORMAL" ]},
		{"command":[ "FADEOUTCHARA", "2", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}