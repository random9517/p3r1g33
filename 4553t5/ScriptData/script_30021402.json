		{"command":[ "SETTEXT", "「お仕事、お疲れ様。やっと……二人だけの時間……作れたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404101" ]},
		{"command":[ "SETCHARA", "0", "char_00000214_01", "6", "CENTER", "0" ]},
