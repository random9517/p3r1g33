		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん……今日は、もう朝からずっとそのつもりでいて……でも、じっと我慢\nして……結局、お仕事も長引いて……待ってたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ううん、大丈夫……待てば待った分だけ、楽しみも増えるから……でも、そ\nれも、そろそろ……限界に近いかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ……あふっ……待ちきれない……いっぱいして……ああっ、私\nのオマンコ……隅々まで可愛がってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000214_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「足を開いて……うんっ……ふっ……これで、いい……？　あぁ……恥ずかし\nい……こんなに開いて、全部見せちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もう、じゅくって……濡れてるの……分かるでしょ……？　私のオマンコ…\n…ずっと期待してたからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「味見……？　う、うん……いいよ……舐めて、みて……ひぁっ、ひゃっ……\nんっ、くぅぅぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……舌が中に割り込んで来る……オマンコの入り口ぃ…\n…んっ、れろってされてるぅ……あひっ……あっ、くぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「や、やだ……んっ、上手……優しく、なぞられてるの……分かる……あぅっ\n……そこぉ……も、もっとぉ……あ、ふぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「中からお汁が……どんどん溢れ出して来ちゃうっ……くぅぅ……ぜ、全部…\n…啜られちゃってるっ……は、ひっ、あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んくぅっ……あっ、そこっ、ほじられたらぁっ……あひっ、か、感じすぎて\nっ……あぁっ、もっと……出ちゃうっ……あ、溢れちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ひぁぁっ！　じゅるってっ……す、吸われてぇっ……もっ、あっ、それ以上\nはっ、らめっ……あっ、あひぁっ、で、出るぅぅぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁっ……！　イ、イクっ……！　はぁんっ……あっ、お潮……吹\nいちゃってるっ……ん、ふぁぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404113" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000214_02_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ダメ……あっ、見ないで……恥ずかしい……んっ、オ、オマンコ……痙攣し\nたままぁ……あっ、ひぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁ……舌だけでイカされちゃった……んっ、オマンコ……\n待てなかったの……はぁぁ、あふっ……んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ねぇ……もう待ちきれない……準備もちゃんと出来たからぁ……して……今\n度は、オチンチンで……オマンコ……ちゃんとしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「もう一回イッて、トロトロになってるオマンコぉ……ギチギチに勃起してる\nオチンチンでぇ……いっぱい可愛がってぇ……そう、そのまま、そこぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁっ……あっ、んくぅぅぅぅっ……あぁ……入って……あっ、ふぁ\nっ……来たぁ……あ、ひっ……ヌルって……埋まるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅんっ……あぁ、オチンチン凄い……太いのが全部広がってるの…\n…分かるぅ……くぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……あぁ……そ、そんなに顔を覗き込まないで……んっ、絶対いやらしい\n顔……しちゃってるからぁ……は……ひぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「トロけてる……？　んぅ……そんなの、こんなオチンチン入れられたら……\n誰だって、なるから……あっ、んむ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふぅぅ……キスぅ……あふぁ……ひゅごく……気持ちぃぃ……んりゅ、れ\nろ、うん……いっぱいしたい……れる、えろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ……あっ、いいよ……おっぱいも吸ってぇ……私の身体……隅\n々まで貴方のものだからぁ……好きにしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、あぁっ……オチンチン……グリって、来てるっ……んくぅぅっ\n……これぇ……埋まっていくのっ、好きぃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「は、ふっ、んんっ……ゆっくり……あぁっ、そう……オマンコ、押し広げて\nぇ……くぱって……あっ、んぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……ズリズリっ……抜き差しされるのっ、はぁっ、いいっ、オマン\nコっ……あっ、あぁっ、痺れてるのっ……んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んくぅっ……はぁんっ、あぁっ、もっと足を……広げてっ……？　も、もう\n……かなりいっぱいなのにぃ……あっ、んぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ……オマンコ広がってるところ……見せびらかしてるみたいにっ……\nやらっ、こ、これぇ……はしたないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んくぅっ、も、もうっ……さっきから、恥ずかしいことばっかりさせてぇ…\n…悪趣味なんだからぁ……あっ、くぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、でもっ……その方が……興奮するの……あぁっ、全部バレちゃってる\n……オマンコ、じゅくじゅくになるの……知られてるぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くぅんっ、あぁっ、言っておくけどっ、貴方にだけだからっ……こんな、恥\nずかしいところ見せるのっ、他の人には絶対ダメなんだからぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「と、特別なんだから……あぁっ、見てっ……私の恥ずかしい顔っ……いやら\nしいオマンコっ……揺れるおっぱいっ、全部っ、全部見てぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はんっ、あっ、あぁっ……！　オチンチンっ……また速くなってるっ……オ\nマンコ、ズボズボって……激しくされてるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……出るのっ！？　出したいのっ……！？　んっ、出してっ…\n…赤ちゃん欲しいのっ、貴方の赤ちゃんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「このまま……オマンコ出してっ、中出ししてっ、後もう少しっ……オチンチ\nン頑張ってぇっ……はひぁっ、私もっ……イクっ……イクぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ……出てるっ……精液っ……出されてるっ……中にっ……熱い\nのっ……ドピュドピュしてるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000214_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ……んぁぁっ……届いてる……子宮に熱いの……貴方の赤ちゃん\nのもとぉ……流れ込んでくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……身体ぎゅってして……オマンコ、離れちゃわないように……んっ\n、一番深いところで……ぴゅってしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あふっ……あぁ、射精……終わっちゃった……？　んっ、腰……やっと落ち\n着いたから……そうかなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん……気持ちよすぎた……これを味わっちゃったら……もう、戻れないよ\nね……本当によかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ね……まだ、オチンチン抜かないで……？　ゆっくり……キュンってしてあ\nげるから……んんっ、んくぅっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふふっ、ウズウズしちゃう……？　うん、私もそう……まだ、全然終わった\n感じしないから……続き、したいよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、あふぁっ……うん、そのまましちゃお……欲しがりのオマンコ……\nもっといっぱい可愛がって……あっ、あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ、こんなおねだりの仕方……私らしくないかな……？　んっ\n、でも花嫁姿って……いつもより甘えたくなっちゃうの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「か、可愛い……？　うぅっ……こ、言葉にされると……顔から火が出ちゃう\n位恥ずかしいけど……う、嬉しい……かも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んくぅっ、あぁっ……また、オマンコ……ジワってしてる……\nもっと精液欲しいって、勝手に動きたくなっちゃってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うんっ、腰……回すねっ……私の……はしたないオマンコダンスっ……いっ\nぱいオチンチンで楽しんでっ……あっ、んくぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ふぁっ、んぁっ、くぅぅぅんっ……あっ、すごいっ……はひっ、今日のオチ\nンチンっ……特にすごいのっ……んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「好きっ……あぁっ、そこっ、ズボズボされるのいいからぁっ……！　もっと\nっ、んくぅっ、してっ……硬いのっ……めり込ませてぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あぁぁっ……！　簡単に奥まで入ってぇ……先っぽ……子宮に届いて……グ\nリグリされてるっ……もっと激しくしてっ、いいからねっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んくぁぁっ！　あぁっ、気持ちいいっ……オマンコ感じちゃってるっ……！\n　何度もピストンされるのっ……あひっ、よ、良すぎてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くぅぅんっ……！　あぁっ、私も……もっとオチンチン……よくしてあげる\nっ……んっ、いっぱい締め付けてっ……んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んふっ、はっ、んっ……どうっ、かなっ？　ちゃんとっ、オチンチン……い\nい感じ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、弱いところ……いっぱいあるのっ……知ってるからっ、ここっ、とか\nっ……んっ、この辺とかっ、あっ、んふぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、んくぅっ……気持ちいいっ？　よかったっ……いやらしい交\n尾っ……あぁっ、もっとしたいっ、もっとオマンコして欲しいっ！」、", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あぁっ、でもっ……これっ、あぁっ、もうっ……私もっ……またっ\n、あっ、我慢出来なくなってるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「子宮口っ……ずっとグリグリされてぇっ……お汁っ……止まらなくてぇっ、\nあっ、イキそっ、オマンコっ……またイキたいのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ、貴方もっ……あっ、ラストスパートっ？　はっ、うんっ、いいよっ\n……最後までオチンチンしてっ、思いっきりイッてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あひっ、んひぃっ！　私もっ……オマンコもうダメだからぁっ、一緒にイク\nからっ……だからっ、あっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「出してっ……好きなようにセックスしてっ！　オマンコしてっ！　残ってる\n精液っ……ビュクって……全部っ、いっぱい出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁぁぁんっ！　あっ、あぁぁぁっ……また中でっ出てるっ……！　オ\nマンコっ……一番奥にっ……ドプドプっ、されてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000214_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁっ……イッてるっ！　私のオマンコもずっとイッてるっ……！\n　オマンコ……いっぱいにされてっ、あっ、漏れるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ……やぁっ、また潮吹きぃっ……あっ、駄目……精液も漏れ\nちゃってるのっ……ごめんなさいっ……んぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ……ふっ……大丈夫……？　漏れた分……もっと出してくれる……？　ふ\nふっ……ありがと……優しい旦那様で嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なるべく、全部飲めるようにしたいから……深い所で出してね……んんっ、\nあふっ、イッてるオマンコ……締め付けるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あぁっ、ビュクって……した……んんっ、オマンコ……また\n……イッちゃう……はぁぁ、ずっと……イッたままぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んふっ……出した……？　うん、お願いした通り……出してくれた\n……あふ……ありがと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いつもはちょっと頼りない時もあるけど……やっぱり、夜はとっても頼もし\nいね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「くすっ、普段も頼もしい……？　そうね……まあ、昔よりは少しだけ、成長\nしてるのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「だったら、これからもしっかりと私のこと捕まえて……離さないでいてよ？\n　約束、だからね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あっ……出たっ……！　あぁぁぁっ、精液シャワーっ……いっぱいっ、身体\nっ……掛かってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000214_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、私もまたイクっ……はぁんっ、掛けてぇっ……ドレス汚しても\nいいからっ……全身……精液でマーキングしてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あふう……粘っこいの凄い……どんどん溢れてくる……んっ、あぁ……ちゅ\nぷっ、今日のも美味しい……貴方の味がするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、オチンチン……直接お腹に押し付けてぇ……んっ、おっぱいも……精\n液……ぬりぬりして欲しいからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はふ……あぁ……お肌に染み込んでいく……中に出した分と……外の分と…\n…両方とも気持ちいいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……終わりそう……？　最後の分……出しちゃって……んっ、あ\nっ……出た……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はふ……これで、おしまい？　うん、とってもよかった……ふふっ、いっぱ\nい出してくれて……ありがとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000214_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「はぁ……でも、子作りってすごいね……こんなに夢中になったの……初めて\nかも……」」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「こんなの味わったら……もう完全にクセになっちゃうよね……でも、ちゃん\nと旦那様が頑張ってくれそうだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_1404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「うん、これからも、いっぱい私のこと……可愛がってね。ちゃんと約束……\nだからね……」", "NORMAL" ]},
