{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0119" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「宣誓！　我らプリンセスは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_010104050001" ]},
	{"command":[ "SETCHARA", "0", "char_00013001_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「この手にプリンセス・オブ・マルチバースの栄誉をつかむため！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_040104050001" ]},
	{"command":[ "SETCHARA", "0", "char_00013101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「己の技量と、美のすべてをもって戦うことを！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104050001" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "三人" ]},
		{"command":[ "SETTEXT", "「今、ここに誓う！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104050002" ]},
	{"command":[ "SETCHARA", "1", "char_00012801_01", "7", "LEFT", "-200" ]},
	{"command":[ "SETCHARA", "0", "char_00013001_01", "7", "CENTER", "0" ]},
	{"command":[ "SETCHARA", "2", "char_00013101_01", "7", "RIGHT", "200" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]},
	{"command":[ "DISPCHARA", "2", "TRUE" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにが『技量と美のすべてをもって』だ！　マグナシアめ……偉そうに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
	{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「マグナシアだけを見ていても始まらんぞ。他の二人もかなりの強敵だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「シロクマ姫。氷菓の国のプリンセスだ。おてんばで好奇心旺盛。しょっちゅ\nう城を抜け出しては家来たちを困らせている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……とまあ、これだけ聞くとあまり強そうには見えないが、天性の格闘セン\nスと身体能力はプリンセス界随一と言ってもいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なるほど。決して侮れぬ相手、というわけだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「高円寺クリス。通称、紅炎の姫騎士。『太陽の石』とやらの力で変身能力を\n手に入れ、プリンセスとなった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050004" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「戦闘力もさることながら、そのルックスと紳士的な物腰、全身から漂う総受\nけ感で女性ファンの人気を独占している」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「また、彼女は別次元のグレート・ルナリアムの幹部でもある。そういった面\nでも、警戒を要する相手といえる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なるほど。こちらの手の内を読まれる可能性がある、ということか――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050003" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ルナテミスさん！　アナザーさん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_040104050003" ]},
	{"command":[ "SETCHARA", "0", "char_00013101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050004" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「噂をすればなんとやら……か。あなたが高円寺クリスだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050007" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はい！　私のことをご存じなのですか？　とても光栄です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_040104050004" ]},
	{"command":[ "SETCHARA", "0", "char_00013101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「わっ！　わわっ！　この人たち、そっくり！　もしかして、あの有名なふた\nご座のふたごプリンセス！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_010104050003" ]},
	{"command":[ "SETCHARA", "0", "char_00013001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……違うぞぉ？　私たちは双子などではない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050005" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「シロクマ姫さん、この人たちがＷ（ダブル）ルナテミスさんですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_040104050005" ]},
	{"command":[ "SETCHARA", "0", "char_00013101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「またそれか！？　もしかして、他の次元では定着しているのか！？　『Ｗ（\nダブル）ルナテミス』という呼び方が！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050006" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「え？　ど、どうかしましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_040104050006" ]},
	{"command":[ "SETCHARA", "0", "char_00013101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、なんでもない。気にしないでくれ。それより今日はお互い、いい試合\nをしようじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050008" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はい！　私もそれを言いに来たんです。正々堂々、全力を尽くして戦いまし\nょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_040104050007" ]},
	{"command":[ "SETCHARA", "0", "char_00013101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シロクマ姫" ]},
		{"command":[ "SETTEXT", "「プリンセス・オブ・マルチバースの栄誉をつかむため！　だねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_010104050004" ]},
	{"command":[ "SETCHARA", "0", "char_00013001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうだな、そういうことなら、私も異存はない！　お互い、勝利を目指して\n精いっぱいやろうではないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050007" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス＆シロクマ姫" ]},
		{"command":[ "SETTEXT", "「はい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_130_010104050005" ]},
	{"command":[ "SETCHARA", "0", "char_00013001_01", "8", "LEFT", "-100" ]},
	{"command":[ "SETCHARA", "1", "char_00013101_01", "8", "RIGHT", "100" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マグナシア" ]},
		{"command":[ "SETTEXT", "「ふふっ、まあ、せいぜいがんばってや。楽しみやなぁ……誰がウチのところ\nまで、たどりついてくれるか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_128_010104050003" ]},
	{"command":[ "SETCHARA", "0", "char_00012801_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0119" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_022" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「さあ、全次元のプリンセスファンの熱い注目の中、始まりましたプリンセス\nトーナメント！　ただいまメイン会場のスタジアム惑星では――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「大入り満員の観客が見守る中、第一次予選の『障害物競走』が行われており\nます！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050008" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにが障害物競走だ！　わけのわからんロボットが襲ってくる障害物競争が\nあるか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050009" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050009" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「おそらく、すべての障害を打ち倒してゴールせよ、ということなのだろうな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050010" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「おっとぉ！？　今大会の優勝最有力候補、マグナシア・カイザー・ナックル\n姫が早くもぶっちぎりでゴールに入ったぁ！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050010" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「続いて二着は高円寺クリス選手！　シロクマ姫も団子状態から抜け出してゴ\nールに向かっているようです！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「あいつらもか！　うかうかしていては、予選を通過できなくなってしまう！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050011" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「その通りだ！　ルナテミス！　ここはひとまず協力し合おう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050011" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なにぃ！？　どうしてお前などと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050012" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「お前の目的はまず、マグナシアに勝つこと。そして、薄給の皆に賞金を持っ\nて帰ることだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050012" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「それは……そうだが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050013" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ならば、決勝で当たるまでは利害が一致している。それまで、期間限定の共\n闘といこうではないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050013" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「期間限定、か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050014" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「もちろん、決勝でお前と当たれば全力でやらせてもらう。どうだ？　乗るか\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090104050014" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "実況" ]},
		{"command":[ "SETTEXT", "「おっとー！　シロクマ姫がゴールに入る！　さあ、予選通過の残り枠は着々\nと埋まっていくぞー！」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ちっ！　考えている余裕はなさそうだな！　承知した！　ひとまず手を組も\nう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010104050015" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
	{"command":[ "EXIT" ]}
	]
}