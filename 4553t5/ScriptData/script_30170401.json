{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、そ、そんな……。エッチな思い出話をして、あなたを喜ばせてみせろ\n……だなんて。ちょっと横暴だと思います……困ります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403101" ]},
		{"command":[ "SETCHARA", "0", "char_00001704_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「いえ、まったく無いわけではないですけど……。んん……そういうことを話\nしちゃう女の子って、少し口が軽いと思われちゃうかなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「……でも、あなたのことは……はい。信用しています。絶対誰にも言いませ\nんか？　それなら……。あれは、皆が寝静まった真夜中のことでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あのっ……これは、これは一体なんなんですか？　見たことがない機械……\n。な、なんだか、ずっとプルプル震えていて……怖いです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00001704_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「この機械をつけたままフェラチオをして欲しいんですか？　ど……どうした\nら……私に出来るでしょうか。低周波治療器……な、なるほど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「治療器なら……悪い物ではないですよね。わかりました……。でも、怖いこ\nとだけは絶対にやめてくださいね……。あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ……あ……。こ、このぬくもりは……。あぁ……、だ、駄目です……。\nこの臭い……蒸れた空気……。んんん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オチンチン……。オチンチンが顔の前に突き付けられてます……。目を閉じ\nていてもはっきりわかるくらいの存在感……。ちょっと臭くて……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「も、もう準備は万端で私のお口を待っている状態……ということですよね。\nこの状態でフェラチオを……。はぁ、はぁ、い、いつも通り、に……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ！？　あれっ……？　オチンチンが引っ込んじゃいましたね。は、はい\n。低周波をまず体感してからおしゃぶりしてほしい……ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「少しピリピリするだけだから大丈夫……？　本当ですか？　だったら……。\nって、ひぅっ！？　んんんっ、ぁっ、な、なんですか、これっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ブルブル、ブルブルしてますっ……。あっ……？　えっ？　やっ……あっ…\n…なんだか思ったより強い、ような……？　あっあっあっあっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「て、低周波ってこんなにはっきり電波が伝わってくるものなんですか……？\n　あっ……！　か、身体が、コントロール出来なくなっていきます……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ！？　んひぃっ！？　えっ！？　や、やぁ……っ。今、私……私軽く絶\n頂しちゃいました。えぇっ……？　あなたに何もされていないのに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403114" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「や、ややややっぱりこの機械、ちょっと怖いです……！　取ってもいいです\nか？　だ、だめですか……？　あっ！　あっ、で、でも……でも、あのっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んひぃいいっ！　ふぁああっ！？　また、また無理やりイかされて……！　\nこ、こんなビリビリした状況でオチンチンを舐めるなんて不可能です……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「くち、唇、くちびるが震えて、ぁっ、舌を伸ばしても……ピリピリしてて…\n…。くぅうっ、ふぅっ……ふぅうっ、うぅ……照準が定まらないです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あの、一旦電流を止め、止めてもらえたらっ……。ひぅうっ！　無理です…\n…っ、無理です、フェラチオなんて……。んーーーっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ……。お、オチンチンがお口にぴとってくっついちゃいました……。\nほ、本当に、本当にこのままでぺろぺろするんですか？ぁ、あ、あ、痺れる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「全然知らないことさせられちゃってます……。ええと……。いつも通りに…\n…って……。んんん、ピリピリ、ピリピリしている舌で……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「れろっ……ぴちゃっ。んふっ……？　んぁああ……。ま、麻痺……お口が麻\n痺して上手くできません……。れろ……、ちゅ、チュ、ちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、あうっ！　あっ……ぴちゃっ……ぴちゃ、ぴちゃ……。なんとか先端\nだけでも……。くちゅ、チュ、ぺろ、れろっ、ぴちゃっ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はうぅ……れろぉ……。あ……少しだけ慣れてきました……。亀頭もきちん\nとおしゃぶりします……。んれろっ……じゅぷ、ぐちゅっ、じゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んはぁっ、はぁ、はぁ、はぁあ……。な、なんだか変な感じです……。でも\n……この刺激が、あなたにも伝わっているんですよね……？　ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ど……んな感じれふか……？　低周波がオチンチンに伝わるっれ……。んぅ\nっ！？　あ、あれ……急に強くなったり弱くなったり……。んぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403125" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……なんだか感覚が過敏になって、空気に触れているだけで妙な\n気持ちに……。れろっ……これ、少しクセになりそうで……怖いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あふっ……ふぅっ、ふぅう……ふーっ……！　ちゅ、ちゅぎは……。次はオ\nチンチンを全体的に舐めますね……。はい、竿って言うんでしたっけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403127" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あなたのオチンチンの竿を……ぴちゃ……。下から上へ、舐め上げて……ね\nろっ……れろ……れる……くちゅ、ぢゅる……ぢゅるっ、ぺちゃっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、ビ、ビリビリ……！　い……いえ、負けません……。私だっ\nて頑張れます……。ぴちゃ……れろっ、れろれろれろ……じゅぷぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あ、あなたに、ちゃんとご奉仕するために……。んんんっ……電流には負け\nませんん……っ。ぴちゃっ、ぴちゃ、くちゅっ、ちゅ、ちゅぅうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ふぅううっ？　はぁううっ……！　だ、大丈夫れふ……っ。ぐっちゅっグッ\nチュッ……ぬぷっ、ぬぷ、ぴちゃっ、ぴちゃ……ぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「戦いに比べたら、これくらいの刺激……れろっ……ぢゅるっ……。あ……あ\nぁ……気持ちいいですか……？　良かったぁ……ぴちゃっぴちゃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私の限界が来る前に……じゅぷっ、オチンチンを満足させないと……っ。ち\nゅぱっ……ちゅる、くちゅ、くちゅ、くちゅ、くっちゅっ……んあああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ど……うですか……？　イけそうですか……？　でしたら遠慮なく、だ、出\nしちゃってくらひゃい……。んっ、し、舌が回らないです……れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んぷ……じゅるっ、じゅるっ、ぐちゅっ……。んはぁっ……はぁ、くっちゅ\nっ、ぐちゅっ……れるれるれる……ぐっちゅっ、じゅるっ……ください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私のお口に……！　んんんっ……！　んぁううう……！　んふ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あっ、味が……！　精液の味がよくわかりまひぇん……っ。ちゅぱっ、ちゅ\nぷ……。ふぁ……っ。やっぱり口が麻痺しれまふ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「せっかく出してくれたのに……ごめんなひゃい……。その代わりに全部飲み\nまひゅので……。ん……ごきゅっ……ごく……ぷぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「飲みきれないくらい出ひてくれたんれふね……。ごくっ……ごく……。……\nあ……。鼻に香りは少しだけ感じます。濃厚なイカ臭い臭いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「低周波の機械をつけていると、こんな風に精液の味も臭いも、食感も変わる\nんですね……。私は知らないことばかりれふ……。ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403140" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「……まだ、オチンチンには精液がべったりついたままですけど……。全て舐\nめとる前なのに、……あ、あなたのがまた……おっきくなっちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「これ……このままペロペロしていていいってこと……ですよね……？　間違\nっていたらごめんなさい。なんだかとても舐められたそうだったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あ、やっぱりフェラチオ継続でいいんですね……わかりました。それでは…\n…その。い、いただきます……あーん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……くちゅ、ちゅぷ……にゅっぷ……。んんっ！　ビリビリ……っ\n、んぁ……はむっ。くちゅっ、ぐちゅっにゅぷっぷっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「あむ……、んむぅ。くちゅぷっ、れろっ……れろ……はぁあっ、ヌルヌルし\nた透明なお汁が滲み出して、きまひた……んちゅぷっ、ごくっ、ごく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ……？　り、理由はわかりまひぇんが……電流を流したままフェラチオ\nをしゅると、お口の中が気持ち良くなってきまひた……じゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「唾を飲む時も、んっ……オチンチンの太いところが引っ掛かるときも、ゾク\nッて身体の芯が震えて……。あっ？　知らないですこれ、な、何……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んん……、ふーっ……♪　ふぅーっ、ふー……♪　ひゅごい……喉の奥まで\n痺れて、性感帯になっている感じがひまふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んっ、ぢゅるっ、じゅるるるっ……れろっ、じゅぷぷっ、くっちゅっ、じゅ\nるぅうっ……。ぬっちゅっ、ずっちゅっ、はぁっ、はぁあ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403209" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はむ……ぐちゅっ！　じゅるっ……はぁっ、はぁっ、はぁはぁ……！　んぶ\nっ……ぐちゅっ……ぢゅるっ……ぢゅるるる……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「で……電流が流れると、一瞬お口が留守になっちゃって……それがもどかし\nくて、ついがっついてしまいます……。ああっ、逃げないでくらはい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　あぁ……！　だ、め……っ。おしゃぶりしてるとお口が、\nおくひが気持ち良くなっれ……。んふぅうっ、イ、イッちゃいますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「やぁ……！　イ、イッてるのに、ビリビリが……ビリビリがきて……あああ\nあっ……あああああっ……！　らめっ……らめ、らめれふぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私……あなたにも同じくらい……、いえ、もっと気持ち良くなってほひいの\nに……。私ばっかり、感じちゃって……あっ、ぁっあっ、んむっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「オチンチンお口に入れたまま絶頂しちゃいま……すぅっ。んんんんーーーッ\n……！　んむぅううんんーーーーっ！　ひゃっ、ぁっ、あっぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「らめ……。あなたも、あなたも気持ち良くなっれくらはいぃ……っ。ぐちゅ\nっ、ぐちゅ、……じゅぷぷっ、れろっ、れろ……ぴちゃっれろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403216" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「一緒に……んっ、一緒にイキたいです……一人じゃいや……っ。れろっ、れ\nろっ……くっぷっ……くちゅっ、じゅぷっ、ぢゅるっ……じゅっぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んぁ……、どうれふか……？　気持ち良くなれていまひゅか……？　んむ、\n唇で……オチンチンの中に溜まった精液を絞り出ひまふね……？　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……すごい……。どんどんオチンチン、力強くなっれ……。わた\nひの唇を押し戻してきまふ……逞しくて、かっこよくて……あぁ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「く、ください……っ。感じているあなたを見ていると……私まで気持ち良く\nなってきて……っ。ああっ、イキます！　一緒に……一緒にぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「んぷぁっ……むぅうっ……！　んむぅううっ……ふむぅううう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「の……喉にひっかかって……飲み込めまひぇん……。ん～っ……ごくっ……\n。あぁ……これです、今度はしっかり味がわかりまひゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「こんなに濃い味になるまで、たっくさん感じてくれたんですね……ありがと\nうございます……。んっ……ふふ、舌がもつれるくらい粘り気が強くて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「うまく飲みこめまふぇん……。ごきゅ……、んぅ……。ふふふ……♪　喉に\n絡みついて、私と離れたくないって言っているみたいれす……。ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「……えっ……。精液を飲んだ後の私が、とろんとしたエッチな顔をしている\nって……？　は、恥ずかしいです……。見ないでください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403305" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「そんなの、全然意識していませんでした……。ただ、二人で気持ち良くなれ\nて良かったなぁって思っていただけです、ほんとですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はい……。もちろん、苦くてベトベトしていて……精液って上手に飲み干す\nのは難しいです。でも……あなたの一部ですし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403307" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「さっき一度出したばっかりなのに、二回目にもこれだけ頑張って射精してく\nれて……それが嬉しくて……。キュンとしちゃったんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「この人のためにだったら何でもしてあげたいなって……。んっ！？　あ……\n、あの、も、もうこのビリビリ、取ってもらっていいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「二人で絶頂した後にも、ずーっとブルブルしてて……。なんだか落ち着きま\nせん。エッチな気分になっちゃいますので……お、お願いします……はい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「ああああっ……！　ああっ、あぁ……！　いっぱいかけてくださいっ……\nかけて……！　あぁ、ふぁっ、ふぅううっ、うう～～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はいっ……はい、いいですよ……。どこにかけたって……私は全部、あなた\nのものですから……。あっ……あっ、す、すごい勢いです……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403402" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「これ、気持ち良くって飛び出しちゃった精液ですよね……？　嬉しいです…\n…っ、私のお口でこんなに精液作ってくれて、出してくれて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「もっともっと大好きになっちゃいます……。あんっ……。顔に、胸に……\nふふふっ、そこに出すのが好きなんですか……？　可愛いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「私のこと……あなたの精液で塗りつぶしちゃってください……。きゃっ、熱\nくて……。あっ♪　必死にへばりついてくるのが愛おしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……。ど、どうですか……？　満足してもらえましたか……？　\n私ですか？　私は……なんて、聞かなくても本当はわかってますよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001704_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「き……気持ち良かった……です。すっごく……。ふふ、気持ち良くしてもら\nえた上にご褒美にたくさん精液まで出してもらって……幸せ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「でも……このビリビリには、やっぱり慣れそうにありません。い、いえ……\n気持ち良かったですよ？　でも……身体がゾクゾクしっぱなしで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「おかしな趣味に目覚めてしまいそうだったので……。え？目覚めてもいい？\n　い、意地悪です……そんなこと言うの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「わ……わかりました。たまになら……ものすごくたまーになら……また、\nし、してもいいです……。本当にたまにですけど……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_0403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}