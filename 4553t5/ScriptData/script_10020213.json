{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0122" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「もうすぐできるから、待ってて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「うううう、すまないねえ……まさかカードの売り上げを全部没収されて、食\n費にも事欠くハメになるとは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「……今月の食費までカード代に突っ込んでいた、と気づいたときは、驚きの\nあまり機能停止しかけたである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113260001" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「二人ともいい大人なんだから……そういうのやめなさい。学生たちのために\nもならないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260002" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚＆遥架" ]},
		{"command":[ "SETTEXT", "「はい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113260002" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "4", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "1", "char_00002002_01", "4", "CENTER", "200" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「できた。はい、どうぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260003" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「むむむむ……！　これは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113260003" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「おおおお……！　なんておいしそうな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260003" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「遠慮せずに食べて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260004" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚＆遥架" ]},
		{"command":[ "SETTEXT", "「いただきますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113260004" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "1", "char_00002002_01", "8", "CENTER", "200" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ばくばくっ……はぐはぐ……うまい……！　うまいよ……！　田舎の母ちゃ\nんを思い出す……むぐむぐ……手作りの家庭の味っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「むぐむぐ……見るからに貧相で安価な食材を使いつつ……はむはむ……高貴\nな我の食欲をも刺激せずにおかぬとは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113260005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「大げさ……。家庭科実習で残った食材と、学食の売れ残りでさっと作っただ\nけだし、そんな大したものじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260005" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「いや！　うまい！　これはイケるよ！　よかった……！　輝夜に泣きついて\n、本当に正解だった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260006" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「そもそも泣きつかないでほしいけど……困ってるのなら、仕方ない。はい、\nこれもどうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260006" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「こ、これは！　まさかのデザートまで……！　うううう、こんな人間らしい\n食事、何か月ぶりだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260007" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「パンの耳を揚げて、粉砂糖とシナモンを振りかけただけだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260007" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「我はマシンファラオゆえ、スムーズな動作のために適度な脂分を必要とする\nのである。なかなか気が利くであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113260006" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ふふふっ……気に入ってもらえたのなら良かった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260008" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「うむ、ほめてつかわす。我が王宮に料理長として召し抱えてもよい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113260007" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「それは……遠慮しておく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260009" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「いや、しかしリーズナブルな余りもの食材でこの味……！　これは、十分金\nを取れるレベルだよねぇ……はっ！　か、輝夜っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260008" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「な、なに！？　いきなり手を握ったりして……なんなの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260010" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「輝夜！　私と組もう！　学食の隣で裏学食始めよう！　きっと学生たちにバ\nカ売れで研究費ガッポガッポ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260009" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「だ、ダメ……！　手を放して……！　私にはカツマが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260011" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「カツマとかどうでもいい！　二人で儲けよう！　天下取ろう！　ねっ！？　\nねっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260010" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ダメ、やめて！　グイグイ迫らないで！　そんなにされると、私……私ぃい\nいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260012" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「ふ、ふ、ふふふふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260013" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「え？　か、輝夜……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260011" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「フヒィイイイイッ！　殺ス殺ス殺スおろス！　三枚におろシテ色よく焼き上\nげルゥウウウウウウウウッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260014" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「うひゃああああああああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260012" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "輝夜" ]},
		{"command":[ "SETTEXT", "「殺スぅううううううううううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_040113260015" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ご、ごめんなさい、ごめんなさーいっ！　もうしないから許してぇ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020113260013" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「輝夜～、おかわりであ～る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020113260008" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}