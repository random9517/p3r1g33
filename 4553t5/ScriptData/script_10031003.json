{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「きゃあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010115990001" ]},
		{"command":[ "SETCHARA", "0", "char_00006802_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "SETTEXT", "「くっ……！　ダークなダイヤナさん……強い！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010115990001" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「あらあら～お嬢さんたち、あんまり手ごたえないのねぇ？　仕方ないから、\n他の方法で楽しませてもらっちゃおうかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110115990001" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "古館隊員" ]},
		{"command":[ "SETTEXT", "「ほ、他の方法って……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_061_010115990001" ]},
		{"command":[ "SETCHARA", "0", "char_00006102_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「それはもちろん、お持ち帰りしてあんなことやそんなこと……うふふふふふ\nふ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110115990002" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ひいいいいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010115990001" ]},
		{"command":[ "SETCHARA", "0", "char_00019201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "琴吹隊員" ]},
		{"command":[ "SETTEXT", "「バ、バズ太郎きゅん！　助けて～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_064_010115990001" ]},
		{"command":[ "SETCHARA", "0", "char_00006402_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ＢＢ隊とダイアンサスクルーのピンチだ！　しかしそこに……", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「っ！？　時空変動を確認！　所属不明の小型船が、本艦と敵艦に向けてワー\nプアウトしてきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010115990001" ]},
		{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「なんですってぇ～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110115990003" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その直後、ダイアンサスの艦体にまたも振動が走る。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「こ、これはいったい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010115990001" ]},
		{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「何が起きてるのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110115990004" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「所属不明船が、敵艦を攻撃しています！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010115990002" ]},
		{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「なによそれぇ！　ダイヤナちゃんの艦を攻撃してるっていうのぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110115990005" ]},
		{"command":[ "SETCHARA", "0", "char_00000611_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0166" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「わーっはっはっはっは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115990001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「この声は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010115990001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「宇宙の星が輝く影で、オレの笑いがこだまする！　悪の稲妻スケバンサンダ\nー、お呼びとあらば即、参上！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115990002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「助けに来てくれたの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010115990002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「おう、次元管理統制局からの依頼だ。ちょっと待ってな。そこの戦艦、ぶっ\n飛ばしてやんよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115990003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "時間帝国兵" ]},
		{"command":[ "SETTEXT", "「ダ、ダイヤナさま！　お戻りください！　これ以上はシールドがもちません\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010115990001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「ううううううう……！　あー、もう！　なによ、いいところだったのに～！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110115990006" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "SETCHARA", "0", "char_00000611_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナＤ" ]},
		{"command":[ "SETTEXT", "「次こそはあなたたち、全員まとめてトンデモないことしてあげちゃうんだか\nらねぇ～っ！　ブリッジ！　今すぐ転送しちゃって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_110115990007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "清水隊員" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「悪いダイヤナさんが消えた！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_056_010115990002" ]},
		{"command":[ "SETCHARA", "0", "char_00005602_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「敵艦、離れていきます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010115990002" ]},
		{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「どうにかなったみたいですね……スケバンサンダーさん！　ありがとうござ\nいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010115990002" ]},
		{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0167" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「なーに、時給分の仕事をしただけさ。それじゃ、オレは行くぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115990004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「待って！　もうひとつお願いがあります。詳しく説明するので、こちらまで\n来ていただけませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010115990003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「お願い……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115990005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「って、なんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115990006" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「もう来た！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010115990003" ]},
		{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「話が早いですね、助かります。実はお願いというのは、ＢＢ隊を地球まで送\nり届けて欲しいんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010115990004" ]},
		{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「さすがスイレンちゃん！　いいところに気が付いたね！　ダイアンサスはし\nばらく、全速航行できなそうだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010115990003" ]},
		{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「お願いします。彼女たちの持っているデータは、急いでＥＤＯ本部に届けな\nければいけないんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010115990005" ]},
		{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「なんだ、そんなことか。いいぜ、どうせギャラを受け取りに地球に寄るんだ\nし――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115990007" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0166" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「おらおらおら―！　地球まで仏恥義理だぜー！　おまえら、しっかりつかま\nってろ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115990008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーニー隊員" ]},
		{"command":[ "SETTEXT", "「す、スピード違反！　宇宙交通法第２５６条違反です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_068_010115990002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "東風隊員" ]},
		{"command":[ "SETTEXT", "「怖い怖い怖い怖い！　もっとゆっくりお願いしますぅ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_063_010115990001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ははははは！　御意見無用一番星だぜ！　おまえら、急ぎの荷物があるんだ\nろ？　ちんたら飛んでられっかよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115990009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「そ、それはそうですけど……でも、事故なんか起こしたらそれどころじゃな\nいですから～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010115990001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「心配すんなって！　でもよ、そんなに急ぎのデータって、いったいなんなん\nだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_010115990010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「え？　私たちが持っているデータですか？　それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010115990002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「希望……です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_010115990003" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}