		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ようやくふたりっきりになれましたね、ダーリン♪　ふふっ、それじゃあさ\nっそく、はじめちゃいましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504101" ]},
		{"command":[ "SETCHARA", "0", "char_00001405_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「なにをって……もう、女の子にそれ言わせるんですか？　……って、ダーリ\nンってそういうところありますもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「じゃあ、ちゃぁんと教えてあげますよ。えいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほら、こうやって、ダーリンのことを押し倒しちゃって……んっ、オチンチ\nンの上に、跨っちゃいましたよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あんっ、お尻の下にぃ……ダーリンのオチンチンを感じます……。んふぅ…\n…こうしてもぞもぞしているうちに……だんだん膨らんで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふ……♪　ダーリンのオチンチン、硬くなってきましたぁ……♪　それじ\nゃあ、ズボンから取りだして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504106" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私のオマンコで……んっ、直接ぅ……。ああ、硬いオチンチンが、オマンコ\nに、こすれてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……♪　どうですかぁ……。ぷにぷにのオマンコ肉の感触……気\n持ちいいですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オチンチン、こんなに硬くしているんですもの……。んんっ、ダーリンのオ\nチンチン……オマンコの奥までずぶって挿れたぁい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンとエッチするために、こうして呼び出したんですよ……。あんっ、\nはやくシたくて、どんどん濡れちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ヌルヌルのお汁で、ダーリンのオチンチンもべちょべちょになっちゃいます\nね……はぁ、はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンも……このオチンチンを私のオマンコに挿れたくなってきてますよ\nね……？　わかりますよ、オチンチンの反応を見れば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンのオチンチンのこと、一番よく知っているのは私なんですから。ほ\nかの女の子より、ずーっと詳しく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だから……ね？　ダーリンからも、ちゃんと言ってください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「まりあとオマンコしたい。まりあと赤ちゃん作りたいって。ほら、ほら……\nちゃんとダーリンからも、おねだりしてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふっ、もっと大きな声で……。ああ、嬉しい。ダーリンがそんなに、私の\nオマンコを求めてくれるなんて……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「じゃあ、じゃあ、挿れちゃいますっ♪　うふっ、私のオマンコ、ダーリンに\n捧げちゃいます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁああぁぁんっ！　はいったっ、オチンチン……！　ダー\nリンの、すっごくガチガチに硬いオチンチンぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504118" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私のオマンコ……中までたっぷり濡れちゃってる、わかりますよね……？　\nうふふ、いっぱい赤ちゃん作りましょっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あはぁっ。硬いオチンチ……ンッ、私のオマンコでいっぱい\nしごいちゃいますからねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンの上で、あんっ、ウサギさんみたいにぴょんぴょんって、腰を弾ま\nせて、ピストンしちゃいますぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、どうですか？　気持ちいいですよね？　ほかの女の子より\n、ダーリンのこと、気持ちよくできているでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504122" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オマンコの中で、あんっ、オチンチンが膨らんで……。はぁっ、はぁっ、私\nのオマンコ、ダーリンのでいっぱい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ぴょんっ、ぴょんっ！　ぴょんっ、ぴょんっ！　ああっ、どんどんオマンコ\nから、お汁……垂れてきちゃいます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンの、おっきなカリ首にぃ、オマンコの中、ごりごりってひっかかれ\nて……あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私の、エッチなオマンコ汁ぅ……ンッ、かきだされてぇ、ダーリンのオチン\nチンをヌルヌルにぃ、しちゃうぅ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンのオチンチン、ぎゅうって抱きしめて、じゅぷじゅぷしごいちゃう\nオマンコ、気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、どうしたんですか？　もう、射精しそう……？　私のオマン\nコに、中出し、しちゃいそうなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふっ、遠慮しなくていいんですよ。赤ちゃん、つくるんですから。ダーリ\nンにいっぱい射精してもらわないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ほら、こうやって……んっ、オマンコの奥まで、オチンチン咥えちゃいます\nから……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504130" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そのまま、ぐりぐり腰を動かしてぇ……ああっ、ああ……っ！　硬くて熱い\nのが、オマンコ……ゴリゴリしてます……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「子宮も降りてきちゃって……オチンチンの先っぽにちゅーってしちゃってま\nす……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「こんなに、ダーリンのオチンチンに尽くすオマンコは、私だけなんですから\n……はぁ、はぁ……だからぁ、このままぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンの赤ちゃんの素っ、私のオマンコに、たっくさん射精してっ！　子\n宮の中、いっぱいにして欲しいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だしてっ、だしてっ、だしてだしてだしてぇっ！！　我慢も遠慮もいらない\nのっ！　私、ダーリンの精液が欲しいんだからぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504135" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁああぁぁ～～～～っ！！　きたぁっ！　きたっ、きたぁ\nあああぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ドロドロの精液っ、精液いっぱいっ！　ああっ、あああぁぁぁっ！！　子宮\nに注がれるっ、はいってくるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んひっ、イクッ、イクッ！　あちゅあちゅ精液で子宮火傷してイッちゃうぅ\nううぅぅうううぅぅぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あひぃ……しゅごい……。オマンコにたっぷりぃ……ダーリンの精液が、流\nれ込んできてぇ……気持ちいいのぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504139" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「こんなに射精してぇ……。ダーリンも、いっぱい気持ちよくなってくれたん\nですね……。私のオマンコが……一番だったでしょ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「で……でもまだぁ……。これくらいじゃ、終われませんよね……？　んっ、\nたった、一度くらいじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンの赤ちゃんを妊娠するには……もっと、もっといっぱい……中出し\nしてもらわなくっちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、また動きますね……。私が、ダーリンのオチンチンをもっ\nと気持ちよくしてあげますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、んふぅ……♪　まだまだ、中のオチンチン、ガッチガチに硬\nいぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504204" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あんなに射精したのに、硬いままぁ……。はぁ、ふぅ、もっと私と、子作り\nしていたいってことですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私のオマンコが気持ちいいから……んっ、オチンチン勃起したままで……あ\nふぅ、オマンコ……いっぱいにひろげてるんですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あんっ、だめですよ、ダーリン。ちゃんと、私のオマンコに集中してくださ\nい。よそ見はダメです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「誰より一番気持ちいい私のオマンコで、また、いっぱい、いーっぱい射精さ\nせてあげますからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ああっ、あはぁんっ。私もさっき、イッたばっかりだからぁ……ンッ、オマ\nンコ感度……あがっちゃってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンのオチンチン、すっごく感じるぅ……。はぁんっ、オマンコの中が\n、いっぱい……ぎゅうぎゅうって締まっちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オチンチン、抱きしめながらぁ……あはぁ、たくさん、しごいて、気持ちよ\nく……んっ、ああっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「もっともっと、感じてくださいね……。んっ、ダーリンのこと愛してる、私\nのオマンコ……ああ、たくさん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オマンコ全部、あじわってください……っ！　こうしてまた、腰振り、ぐり\nぐりってしますからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オチンチンの先っぽ……んくっ、子宮にぐりぐり押しつけるの……ああっ、\nすごい……気持ちいいぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンのオチンチンに、子宮こじあけられちゃうの……っ！　ああっ、中\nまではいって……オチンチンきてぇ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「このまま、また、私の一番奥ぅ……っ！　子宮に……赤ちゃんしっかり孕め\nるようにぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504216" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「精液っ、精液ぃ……っ！　ああっ、ああぁっ！　絶対孕むからっ、ダーリン\nの赤ちゃん孕むからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「だからっ、またたくさん射精してっ！　いっぱい、いっぱい、私のオマンコ\nに精液出してっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああ……っ！　私ももうイキそう……！　赤ちゃん汁欲しがってる\n発情オマンコ、もう限界ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「いっ、イクッ、私も……私もイクからぁ……っ！　ああっ、ああっ、ダーリ\nンっ、ダーリン……っ！　はぁっ、はぁっ、はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁああぁぁあぁんっ！！　あっ、ああっ、きてるっ、また\nぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「熱いっ、あっちゅいぃいいいぃぃぃっ！　ドロドロの中出し精液がっ、ダー\nリンの赤ちゃんの素がぁああぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「まりあの子宮いっぱいにしてるぅっ！　んっ、んっ、んはぁあああっ！　イ\nクッ、イクッ、イッくぅうううぅぅぅううぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んふぅ……。はぁっ、はぁ……っ。ああ……すっごいぃ……まだ射精続いて\nます……ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「アツアツ……ドロドロの……。ねっとり精液ぃ……。ああ……たっぷり子宮\nに入って……お腹、ずっしり重たくなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふぅ……これで、ダーリンの赤ちゃんを孕むことができたかしら……。は\nぁ……でも……そうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「念には念を入れたほうが、いいわよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ふふ、ダーリン。せっかくだから、このまま学校にお泊りしちゃいましょう\nか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ね？　ダーリンは、まりあに赤ちゃんを孕ませないといけないんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「大丈夫。私はダーリンにとって一番気持ちいいオマンコなんだから。何発だ\nって、射精できちゃうわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んひぃっ！　えっ、な、なんでオチンチンが抜けて……ああっ、んっ、精液\n……出ちゃってる……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああ……っ！　熱いのがっ、い……いっぱいぃ……っ！　おっ、お\nお……身体に、かかっちゃってる……んふぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ああっ、精液浴びてっ、イ……イクッ！　だめぇ、中出しして欲しかったの\nに……ぶっかけでも、イッちゃうぅううぅぅうぅ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ああ……んふぅ……精液ぃ……。たっくさん、かけられちゃった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504404" ]},
		{"command":[ "SETIMAGE", "0", "still_00001405_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ダーリンの精液……もったいないわ……。こんなに、ドロドロ、ぷりっぷり\nのゼリーみたいな精液なのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「オマンコじゃなくて、身体にかけるだなんて……ひどい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「え……？　今のは私が自分からオチンチンを抜いたんだろうって？　そ、そ\nんなことありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「私は、ダーリンの赤ちゃんが欲しいのっ！　だから、子宮いっぱいにするく\nらい、中出しして欲しいって、本心から思っていたのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……こうなったら、もう一回です。もう一回、初めからやり直しましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……はぁ、はぁ。ダーリン、やっとふたりっきりになりましたね。……単刀\n直入に言います。私と赤ちゃん作りましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_0504410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
