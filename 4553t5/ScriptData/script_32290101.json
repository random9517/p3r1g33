{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「さてと、オレのことをこんな部屋に呼び出していったいなんのつもりだ？　\nあぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「まあ、部屋の雰囲気を見りゃあナニをする部屋なのかはなんとなく察しがつ\nくがな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「それで？　……あ、さてはオレの胸に興味があるんだな？　てめーはいつも\nオレのおっぱいを見てるもんな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "2", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「まあまあ、みなまで言うなって。アレだろ？　オレにパイズリして欲しいっ\nてことだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んじゃ、さっさとてめーはチンコ出せって」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00022901_01", "6", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「……んおぉっ！？　で、でけーなおい。あ、いや別に、驚いたりなんかして\nねぇぞ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「このオレがチンコなんかでビビるわけねーだろ！　ほらっ、だまってチンコ\nを差し出しなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んくっ、こ、こうだろ……？　チンコを、こう……胸で、挟んでやって……\nだなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ん……んふぅ……。チンコってこんな生温かい感じで……。それに、こいつ\nの臭いがここまで漂ってくる……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「さて……えっと、そうだな……。ん、なんだよ。挟んだだけで終わりかって\n？　なっ、なに言ってんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「終わりなわけねぇだろ！　えっと……動かせばいいんだろ！？　おっぱいを\n、こうやって……な……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、んふぅ……。んっ、んく……んぅ……んっ、おい、てめー、\nチンコ暴れさせんなって……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「せっかく、こう……んっく、挟んでやってるんだから……んっ、ああもうビ\nクンビクンさせすぎだっての！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「しっかり左右から胸を押さえろって？　んなこと、言われなくても……んっ\n、んふぅ……くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「胸に、んぁっ、熱いチンコが……くぅ……どんだけ硬くしてんだよ……てめ\nーよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「と、とりあえずこれでいいだろ？　動くからな……んっ、んふっ、くぅ……\nんぁっ、ん、んんぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んくっ、ふぅ、ふぅ……んんっ、んんぅ……。おい、あんまりこっち見んな\nよ……んはぁ、はぁ……んぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「チンコがだんだん、大きくなってきて……はぁ、はぁ……胸の間で、ンッ、\nやっぱり、ビクビクしてるじゃねーか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「気持ちいいのか？　そ、そうか。まあそれならいいけどな？　んんっ、だか\nらもっと激しくしろって、注文が多いなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ああ、わかったわかった。んっ、こうやって、こうだろ？　んっ、んんっ、\n動いて……ンッ、チンコ、しごいて……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んはぁっ、んっ、んっ、なんだかだんだん、チンコがヌルヌルしてきたって\nいうか……あんっ、なにか溢れてないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「これが精液……じゃなくて先走り汁？　ああ、そうだよな、オレもそう言お\nうと思ってたところだし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「コイツが出てきたってことは、なんだかんだ、射精も近いってことか……ん\nっ、じゃあ、もっと激しく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んぁっ、あっ、んんっ、んふぅっ！　こうだろ？　んっ、おっぱいをぎゅっ\nとして、動かしてやれば……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「あ、あんまり動くんじゃないぞ？　んっ、ほらほらっ、気持ちよくなっちま\nえって……んっ、んんっ、はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「どんどん先走りが出てくるなっ、んっ、アンッ、臭いが胸に染みついちまい\nそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んくっ、もっと強くか？　んんっ、もっとって言われても……んっ、ええい\n、じっとしてろ！　言う通り、やってやるからよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「こ、こうなんだろ！　んっ、こんなふうに、胸をいやらしく動かしてやれば\n、はぁ、はぁ、あっという間に射精しちまうんだろっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、ほら見ろっ、だんだんチンコが硬く……って、あれからまだ硬\nくなるのかよっ！　んっ、ああっ、くぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「なんだかんだ言って、射精しそうなんだなっ！　いいぞ、このまま射精させ\nてやるから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ほらっ、出しちまえっ、んっ、んっ、オレのパイズリで、んくっ、てめーか\nら精液、たっぷり搾りだしてやる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んんんぅっ！　ああっ、ああっ、んっくぅうううっ！　お、おいいきなり射\n精するやつがあるか！　はぁ、はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103132" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「うへぇ……なんだよこれ、精液ってこんなにねっとりしてんのかよ……んぐ\n、鼻が曲がりそうな臭いだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「胸の中で、んぁっ、まだビクビクしてるじゃねーか……。んっ、ああ、脈打\nって、射精してる……んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ど、どうだった、オレのパイズリは？　効いただろ？　……まあまあだった\n？　てめー、オレのパイズリだぞ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「べ、別に初めてじゃねぇし。ほら、男って感じるポイント？　がひとりひと\nり違うんだろ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だから、一発でポイントを探り当てられなかっただけで、オレが下手くそな\nわけじゃねえからな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「……な、なんだよ。それならもう一回やってみろって？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「上等だ……やってやろうじゃねぇか……。もう一回、てめーのチンコから精\n液絞り出してやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「このまま、胸からチンコを抜かずにもう一回だ！　お、オレの本気をみせて\nやるからな！　覚悟しやがれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ふぅっ、んっ、んくっ、こんなに胸の中がドロドロになるくらい出したのに\n、まだ硬い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だ、だからじっとしてろって！　んぁっ、あんまり動かれると、お、オレが\nうまく、できないだろうが……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んんっ、くっ、このっ、じっとして……んぁっ、精液のせいでぬめって……\nんくっ、もっと胸を押し付けて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「さ、さっきも強くだの激しくだのって言ってたもんな？　こ、こうしてやる\nと気持ちいいんだろっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んぁっ、だからチンコを暴れさせるなって……んっ、ああっ、中でチンコが\nビクビクして……んっくぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「とにかくもう一回、チンコのことをぎゅうっと押さえつけて、めちゃくちゃ\nにしごいてやるんだからなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、はぁっ、はぁっ。ほら、どうだ、こうやって……んっ、さっ\nきみたいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「チンコをおっぱいで、締め付けて……んんっ、てめーの精液のせいで、めち\nゃくちゃヌルヌルしてるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「へへっ、気持ちよさそうな顔になってきたじゃねぇか。もう、まあまあなパ\nイズリだなんて言わせねえからなっ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「オレもだんだんコツが掴めてきたぜ……んっ、こうだろ？　単純に、おっぱ\nいを動かすだけじゃなくて……な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「おっぱいごと、んっ、はぁ、チンコを捏ねるみたいに……んっ、動かしてや\nるとか……んはぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「どうだ？　これ、気持ちいいだろ、んん？　おっと、もうチンコのこと逃が\nさねぇからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「こうやって、しっかり押さえつけてしごいてやる……んっ、んんっ、胸の間\nで、んぁっ、また膨らんできた……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「てめーの腰も、ビクビク震えてきたじゃねーか……ンッ、なんだかんだ言い\nながら、オレのパイズリで感じてるな？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「あー、あー。みなまで言わなくてもいいって。オレのおっぱいが気持ちいい\nんなら、また射精させてやるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ほらほらっ、もっともっと胸をうごかしてっ、ンッ、チンコのこと気持ちよ\nくしてやっからよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「我慢なんかしてないで、さっきみたいにねっとりした精液を出しちまいなっ\nて！　それっ、それそれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、チンコ、でかくなってきてるじゃねーか……んんぅ？　これは\nもう射精しそうって感じだなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、このまま……もっともっと胸を……はぁ、はぁ、ほら、射精し\nちまいなって……んっ、んっ、んん……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「またチンコ膨らんできたっ、はぁ、はぁ、見ててやるからなっ、てめーのチ\nンコが、精液、出すとこ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んんっ、んっくぅうううっ！　んはっ、ああっ、んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「くぅ……っ！　ま、また……オレの胸にたっぷり射精してくれたな……はぁ\n、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「さ、さっきよりも……量が増えてるんじゃないか……？　それだけ、気持ち\nよくなったってことか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んっ、それにしても、まだ胸の中でビクついて……射精……続いてる……チ\nンコってすげぇな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「……いやっ、こうなることくらい知ってたがな！　胸の中が精液でドロッド\nロになることくらい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「そんなことより、どうだったんだよ。オレのパイズリは気持ちよかっただろ\n？　なあ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_07" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ははっ、そうか気持ちよかったか。初々しさがそそると……って、なんだよ\n初々しさって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「泣く子も黙るスケバンサンダーさまが、パイズリ未経験なわけがねーだろう\nがっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃあ誰にやったのかって……？　そ、それは……その……秘密だっ\n！　てか、オンナの過去を詮索するんじゃねえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ふんっ。まあ、これからもてめーになら、胸を貸してやるから。その……気\n軽に声かけろよな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「んぶっ、んっ、あっ、んぁあっ！？　んふっ、くっ、ううぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「ちょ、まっ、なんだこれっ！　んんっ、いきなりすごい勢いで精液がっ、ぷ\nはっ、顔に……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「お、おい、てめーっ！　ぶっかけるなら、ぶっかけるって言えよな！　うぅ\n、顔がドロッドロだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はっ、はぁっ！？　別に、びっくりなんかしてねぇが！？　オレが顔射ごと\nきにビビるわけねぇだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……それにしても、なんだかさっきよりも精液の量がふえてる\nっていうか……こんな濃さだったのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「うぅ……鼻の穴に精液が入ったじゃねぇか……。めちゃくちゃくっせぇ臭い\nが……んぐぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「あぁ？　気持ちよかった？　そ、そりゃよかったな。こっちは大変な目にあ\nってるっていうのに、のんきな奴だ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022901_01_09" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「な、なんだよ……。またパイズリして欲しいのか？　まあ、てめーにならこ\nの胸を貸してやってもいいが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「はぁっ！？　これからどんどんパイズリが上達する様子を観察したいだって\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スケバンサンダー" ]},
		{"command":[ "SETTEXT", "「だ、だから、オレは初めてじゃねぇんだって！　ふんっ！　いい加減にしろ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_229_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}