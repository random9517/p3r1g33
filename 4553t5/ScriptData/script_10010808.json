{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0139" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「――で？　何を大騒ぎしているかと思えば。男子も女子もみ～んな怪我しち\nゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んもう、はいそこに並んで。順番に消毒していくからね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「面目ないのです、先生……世紀の新種発見に、我を失ったのです……イタタ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺たちはそれに巻き込まれただけです――イッテ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうですね、お恥ずかしい。その犬がカツマさんのお友達とは知らず……痛\nっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「お友達を助けようとするカツマちゃん、格好良かったあ……あいた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000204_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はいはい。みんなしてカツマさんカツマちゃんって。相変わらずねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「――っと、これで全員治療はお終い。痒くても引っ掻いちゃ駄目よ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あの～……先生、わたくしは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんは人間相手にしか治療行為は出来ないの。ケダモノは専門外\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「なんの疫病や虫を持っているかも分からない、喋る犬を保健室へ入れてあげ\nているだけでも感謝してね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「とほほ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "保健室、ねえ。ここがねえ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そしてダイヤナも先生役――それも保健の先生ってやつとはな。ま、雰囲気か\nらして適任か？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "通りすがりに馬鹿な戦いを止めてくれた点は、助かったぜ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ふむ。ダイヤナ様はさしずめ、『妖艶な魅力を振りまき学生を虜にしている\n女教師』ポジションですかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108130003" ]}
,		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あるいは『学生たちの恋や性の悩みを解決したり逆に増やしたりする、母性\n溢れる保健の先生』とか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108130004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おまえは何を言っているんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、バブミの癒やし効果を理解出来ねば、この先この世界では生きてい\nけませんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、ここで生きるつもりはあまりないんだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0072" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あらん。カツマちゃんは、こ～んなハーレム状態を放り出して、どこへ行っ\nちゃうつもりなのかな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっ……おい！？　何をいきなり、人を抱き締めて……ふがっ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ああ～ん、そんなところで喋っちゃ駄目ぇ～。先生、胸が弱いの～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "だったら人の頭を胸に抱き寄せる……なっ！　息が苦しい、窒息する！", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「せ、先生！　そんな……昼間から、一体ななな何をしていらっしゃるのです\nか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108130002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「破廉恥ですね……これみよがしに豊満なブツを活用して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108130002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマちゃん、大丈夫？　ねえ、それとも……ひょっとして、喜んでる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108130002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "喜んでねー！！　って、喋る事も出来ねえぞ……ぐ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あの、先生？　カツマちゃんの手や脚が、その、かなり苦しそうに動いてる\nんですけれど。ジタバタって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108130003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「きっと喜んでるのよ～。こーんなおっぱいに挟まれて、嫌がる男子なんてい\nるはずないでしょ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いやまじで無理だから……助けろ誰か。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「は！　今、カツマさんの、心の声が聞こえた気がしましたわ。助けてくれル\nナテミスと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108130003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「はあ？　ウチにはハンドサインで『ＳＯＳ』と繰り返し発信しているように\nしか見えなかったですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108130003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「皆さん好き勝手に解釈されるもんですな～。ご主人も本望でしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108130006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "んなわけ、あるか……あ、本当に意識が遠のいて……いく……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んふふ♪　思った以上に抱き心地が良い子ね～。このまま頂いちゃおうかし\nら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130010" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そんな……カツマちゃんはみんなのものですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010108130004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いや違うから……大体、何を頂くつもりなんだよ……ぐぬぬ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうですわ！　先生、独り占めはよくありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010108130004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「カツマはカツマで貴重なサンプル。独占させる訳にはいかないですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010108130004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0139" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んもう、みんなしてカツマちゃんラブラブな上、ダイヤナちゃんの楽しみを\n奪うつもり～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130011" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「それならそれで～、こっちにも考えがあるんだからあ。――さあ、保健室の\nお友達のみんな～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130012" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＡ" ]},
		{"command":[ "SETTEXT", "「消毒液の匂い大好きっ子、見参！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030108130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000807_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＢ" ]},
		{"command":[ "SETTEXT", "「ベッド借りていいですか常連、ここに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_040108130001" ]},
		{"command":[ "SETCHARA", "1", "char_00000807_01", "6", "CENTER", "-400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピースムーンＣ" ]},
		{"command":[ "SETTEXT", "「ぐるぐる包帯巻き少女とはわたしの事……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_050108130001" ]},
		{"command":[ "SETCHARA", "2", "char_00000807_01", "0", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「さあ、みんなで楽しい保健室ライフを守りましょうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010108130013" ]},
		{"command":[ "SETCHARA", "0", "char_00000604_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、何やらバトルスタートという感じになっておりますが、大丈夫です\nか～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010108130007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺を置いて勝手に話を進めるな……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}