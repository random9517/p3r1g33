{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0145" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………はっ！」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつの間にか、雪原に戻ってる……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファサンタ" ]},
		{"command":[ "SETTEXT", "「いまのが、あなたの原点。あなたの原動力であり……そして、欠点のもとと\nもなっている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_080021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00000308_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「欠点のもと……？　つまり、その欠点をどうにかしないと……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナサンタ" ]},
		{"command":[ "SETTEXT", "「近い将来お葬式……ということね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_120021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00000112_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺はどうすりゃいいんだ！　どうすりゃ、その欠点とやらを克服できるんだ\n！　っていうか、その欠点ってなんなんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「……ようやく、ウチの出番ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00000508_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "兎子サンタが進み出て、他の２人と同じように指をぱちん、と鳴らす。すると\n――", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_016" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「じんぐるべーる、じんぐるべーる！　いぇーい！　メリークリスマース！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「メリークリスマース！　あははははははっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あははははっ！　楽しいわね～！　ステキなオトコとホテルのバーで……と\nかじゃなくって、たまにはこういうクリスマスもいいわよね～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「はははは、なに言ってんだい。あんた毎年、クリスマスはあたしらと一緒じ\nゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00000301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これは……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「現在の、居酒屋・正義（まさよし）の様子です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500002" ]},
	{"command":[ "SETCHARA", "0", "char_00000508_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよ……みんな楽しそうじゃねえか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「うらやましいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「って！　冗談じゃねえ！　こんな中に飛び込んだら、あいつらのストレス解\n消のダシにされるのがオチだぜ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「そうですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだって！　それにあいつらも、俺がいないほうが楽しそうだぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「そうですかねえ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00000201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「カグヤか……そりゃまあ、カグヤは姉弟みたいなもんだから。だけどあいつ\nも、俺を弟扱いして優越感に浸るのが趣味、ってとこあるから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「そうですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500006" ]},
	{"command":[ "SETCHARA", "0", "char_00000508_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだよ！　なにが言いてえんだよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「お！　またなんか出てきた……おおー！　やったー！　ピザだー！　いただ\nきまーっす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010021500002" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ちょっと待つですバカ犬。全部取ってしまう気ですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そうよ。カツマさんの分、ちゃんと残しておかないと。仕事が終わったら、\nすぐに来るって言ってたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わかってるよー！　だけど……カツマ遅いなあ！　まだ仕事やってんのかな\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010021500003" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａ・ルナテミス" ]},
		{"command":[ "SETTEXT", "「きっと書類に手間取っているのだろう。もう少し待とうじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「そだな。んじゃ、わたしは一切れだけもらって、と……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010021500004" ]},
	{"command":[ "SETCHARA", "0", "char_00000401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……？」", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "セレーナが……食欲を抑えた？", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はいは～い、こっちのお皿がカツマちゃん用よ～。そのピザ、乗せてあげて\n～！　あ、ダメよー！　ちゃんとサラミが乗ってるとこ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010021500002" ]},
	{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ダイヤナが手際よくピザを取り分ける。……こういうところ意外とまめなんだ\nな、あいつ。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「でも、カツマさんさすがに遅いよねえ……様子、見に行ってくる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010021500002" ]},
	{"command":[ "SETCHARA", "0", "char_00001201_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「まったく……カツマのやつ、いつまで待たせるのだ！　ほむら！　時間延長\nは大丈夫か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021500001" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「そうか、よかった！　それなら、ケーキは取っておいてくれ。メンバーがそ\nろうまでな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010021500002" ]},
	{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "延長……ケーキ……？　まさかあいつら、俺が行くまで……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「……ね？　皆さん、あなたを待ってるのです。あなたと一緒に、クリスマス\nを祝いたいのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500007" ]},
	{"command":[ "SETCHARA", "0", "char_00000508_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「それを踏まえてですが……答えはわかりましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500008" ]},
	{"command":[ "SETCHARA", "0", "char_00000508_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「答え……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「そうです。あなたの欠点はなにか。わかったですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺の……欠点。欠点か……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "パーティーの様子を見ながら、俺はもう一度よく考える。これまで俺がしてき\nたこと、思ったことをもう一度振り返る。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は、どんなことを考えて行動してきたのか。そして目の前の連中を、どんな\n風に見てきたのか……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「…………そうか、そうだな。わかったよ」", "NORMAL" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もう少し他人を……仲間を信じたほうがいい。頼れるのは自分だけだなんて\n……思わないほうがいい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「ほほう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500010" ]},
	{"command":[ "SETCHARA", "0", "char_00000508_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そのあたりだな、俺に足りてないのは……。それが、俺の欠点なんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子サンタ" ]},
		{"command":[ "SETTEXT", "「よくできました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_080021500011" ]},
	{"command":[ "SETCHARA", "0", "char_00000508_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "兎子サンタはそういって、かすかに笑みを浮かべると指をぱちん、と鳴らし―\n―", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}