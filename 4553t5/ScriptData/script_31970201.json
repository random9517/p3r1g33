{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「むっふっふっふふふふ♪　我を呼んだわね？　この我を～♪　忙しいのに駆\nけつけてあげたんだから、よ～く感謝するよ～に～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「こんっな夜中に我と二人っきりになりたいなんて～♪　これは相当な話があ\nるってことでしょ～♪　ほら♪　ほら、遠慮せずに言ってみなさぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……え。マ、ママになってほしい？　……誰が？　えっ！？　我が、この最\n凶の堕神ファンタズマちゃんがあんたのママになる……ってコト？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203103" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「へ、へ～え……ふーん……。そんなヘンタイちっくなシュミがあったなんて\n……。ま、まあいいけど？　我は心が広いから、ママになってもいいけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203104" ]},
		{"command":[ "SETCHARA", "0", "char_00019702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……って、な～るほど～♪　こーゆーこと……♪　随分エッチな赤ちゃんな\nんじゃな～い？　バッキバキのおちんぽママにシコらせるとか～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019702_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ホンモノのカワイイ赤ちゃんっていうより、赤ちゃんプレイなんですけど？\n　ほらぁ……な～にコレ。ビンッビンのドスケベちんぽが上向いてる～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「腰布でぐるぐるしても収まりきらないくらいデカくて長くて太いおちんぽを\n、よしよしして褒めてもらいたいなんて……ありえなさすぎだから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……で、でも……まあ……。我の中に秘められた圧倒的母性を見抜いたその\n目に免じて、今日は……ママとしてシコシコしてあげなくも……ないし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あんたが勝手に我に癒されて？　おちんぽシゴかれて気持ち良くなったり、\nうっとりしたりするのは自由だし？　好きにすればいいと思う……。うん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そ、そう！　しょうがないバブバブ赤ちゃんを、立派な大人に育て上げるの\nもママの……じゃなかった、堕神様のオシゴトかもしんないから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「と、特別に……やってあげる。……って、嬉しそうにピクピクさせるなぁ！\n　どんっだけ期待してるのこのちんぽ！　ダメちんぽ！　ワルちんぽ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……ん？　意地悪しないで甘く、優しくしてほしい？　ぜ、贅沢ちんぽすぎ\nる……。え、えっと……なでなでしながらママらしく……。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「お、おぉよちよち♪　暴れん坊おちんぽさん♪　ママの言うことを聞いてい\nっぱい気持ち良くなるんでちゅよ♪　フフフ、ぜーんぶ任せなちゃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ここをどうやっていじって欲しいんでちゅかぁ？　先っちょをクニクニして\nほちい？　それとも、棒の部分をいっぱいシゴかれたい～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「タマタマを揉み揉みしてほしい？　それとも～、全部一度に攻められてみた\nい～？　答えなちゃい♪　ママの言うことは絶対でちゅからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……って、言葉責めされてるだけでカウパーがどんどん溢れてきてるぅ～。\nそ、そーなんだ。こういうプレイが好きなんだ……ヘ～ンタイ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「なんか、こういうのも面白くなってきたかも。ざこざこヘンタイ赤ちゃんさ\nん♪　ママの腰布はザラザラしてて気持ちいいでちょう？　……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んっ！？　あんんっ！？　な、なによぉおお……♪　我のおっぱいに吸いつ\nいてくるなんてぇ！　……んぁっ♪　やっ、き、気持ちいいからやめてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ、んん！　こ、こらぁ！　赤ちゃんのくせにいやらしいんでち\nゅからぁ！　ば、バツとしておちんぽシコシコしまちゅからね！　めっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ほ～ら♪　ほ～ら♪　しこ、しこ、しこしこ♪　しこ、しこ、しこしこ♪　\n……んふふふっ、すっご～く感じてまちゅねぇ♪　よわよわでちゅぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203120" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ママにおちんぽめちゃくちゃにシゴかれてぇ、恥ずかしくないんでちゅかぁ\n？　んっ……んん♪　や～だ♪　腰が浮いてきてまちゅよぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「おちんぽが～んばれ♪　が～んばれ♪　まだ射精ちたらダメでちゅからねぇ\n♪　が～んばれ♪　が～んばれ♪　ぴゅっぴゅは我慢♪　いいこいいこ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……ふぁっ♪　も、もぉ……！　自分が気持ちいいからって我の胸、ちゅう\nちゅう吸ったり舐め回すのはやめなちゃいぃい！　……あっ♪　ぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203123" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「も、もう許さないんだからぁ……！　えいっ♪　しこ、しこしこ♪　しこ、\nしこしこ♪　フフフ、赤ちゃんがママに勝てるわけないでちょう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……なぁにぃ？　くやちい～？　ふふふ、ホンットカワイイんだから……♪\n　ほら♪　ほら♪　いっぱいシコってあげまちゅからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203125" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「しーしーは我慢♪　射精はガマン……♪　……んっ♪　もぉ……そんなにお\nっぱい吸いたいわけ？　だったら……好きにすれば♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あんたが我の胸をちゅう、ってするたびに我もおちんぽシコっ♪　ってしち\nゃうから……そしたら……そしたらぁ♪　っあっ♪　んんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「二人とも一緒に気持ちよくなれて最高じゃない……？　っぁ……♪　シコ♪\n　シコ、シコ♪　ふふふ、熱心に乳首吸いすぎぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そーんなに、ママの……ちっちゃいママのロリロリちっぱいがおいしーの…\n…？　ヘーンタイ♪　エッチ赤ちゃん♪　バブバブ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んふふ♪　ちょっと～♪　唾液でおっぱいベトベトになってきてるしぃ、お\nちんぽからもカウパーヌルヌル溢れ出してきてるしぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……ほんっとエッチ……♪　それ、それ♪　エッチな赤ちゃんはママがしつ\nけしなおしてあげまちゅ♪　おちんぽでわからせてあげる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「シコ、シコシコ♪　ふふふ♪　シコ、シコ、シコ♪　ん～……♪　気持ち良\nさそうな顔……♪　なんか、母性本能くすぐられるかもぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ね～え♪　ママに赤ちゃんが射精するところ見せてほちいな～？　ビュルッ\n、ビュルッてかっこよく精子出すところぉ♪　いいでしょお～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203133" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ビンビンのエッチおちんぽから勢い良く、真っ白な精液発射するとこ見たい\nのぉ♪　お願い♪　ママのシコシコでビューして♪　カワイイぼうや♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「上手に白いおしっこできまちゅかぁ？　いきまちゅよ～。５，４，３，２，\n１……はい♪　ぴゅっぴゅの時間でちゅ♪　びゅっびゅっびゅっ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あはぁっ♪　上手ぅう～♪　もっともっと♪　ビュッビュッビュッ♪　びゅ\nるびゅるびゅる♪　いいでちゅね♪　いっぱい出てまちゅよぉ♪」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203136" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「びゅーっ♪　びゅーっ♪　びゅぅ～っ♪　わぁっ、素敵でちゅ～♪　うんう\nんうん♪　ちゃんとママの布の中に射精ちてエライねぇ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ぼうやはてんちゃい赤ちゃんでちゅよ～♪　あっ♪　まだ出るんでちゅか、\n量もたっぷりでスゴいでちゅね～。かっこいいでちゅね～♪　んふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「おちんぽの奥に残ってる分も、ビューしてスッキリしちゃいまちょーか♪　\n絞り出してあげまちゅよ～。……んん♪　こう、やって……ほらぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「最後にびゅーしたぁ♪　んんん～♪　エライエライエライ！　よくできまち\nた～♪　射精がんばったね～。ママもうれちいよぉ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……うわぁあ♪　見て？　赤ちゃんがビューした精子、濃すぎてびっくりし\nちゃったぁ……。出した精子、ベチョベチョに絡みついてきてるしぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んっ♪　出してる間中あっつくて、粘ってて……。ねえ～、さすがにこんな\n精液は赤ちゃんからは出ないってママ、思うんでちゅけど♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「立派なオトナ精子だと思うんでちゅけどぉ～？　んん？　どうなんでちゅか\n？　ま～だファンタズマママにバブバブちたいのかな～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……ちたいよね♪　何も言わなくてもわかるよ、射精ちたのにず～っとおち\nんぽガッチガチのままだし、むしろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「アレだけ大量に出しておいて、ま～た、今この瞬間にもおタマタマで精液ド\nクドク作りはじめてまちゅよねぇ？　ママ信じられまちぇんわぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「そんなに、ママのちっちゃなおっぱい吸いながらおちんぽシゴかれるのが好\nきでちゅか♪　だったらいいでちゅよ、もーっとちてあげまちゅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「しこしこしこ♪　シコシコシコ……って、精子がおちんぽにも、ママの手に\nもまとわりついてヘンなカンジ……。ヌルヌルのベトベトぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203207" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「コレ、一回目と感触違ってドキドキしてくる……。にゅるにゅるで、おかし\nな気分になってきて……。はっ！？　い、いけないいけない……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「我は今、ママなんだから。しっかりしないと……！　い、いきまちゅよ？　\nヌルヌルしこしこ、おちんぽ全体をいじめてあげまちゅよぉ？　そぉれぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「にゅるにゅるにゅる♪　しこしこしこ♪　にゅるにゅるにゅる♪　しこしこ\nしこ♪　あ～っ♪　もうこんなに硬くしてぇ、シコりにくいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「根元から……裏筋♪　裏筋からカリ首、亀頭……んふふふ♪　こうやってぇ\n、我のザラザラな布でシゴかれるの……好き？　気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「え？　布が絡んで気持ちいい？　あ、あぅ……！　そ、そぉ？　おちんぽへ\nの刺激がうまいのは……あ、あんたのだから。わかるのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あんた、気持ちいいところを触るとわかりやすく反応するんだもん……！　\nそれが面白くって覚えちゃった。性感帯……えっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「こことか♪　そことか好きでしょ♪　んふっ♪　精液ローションでニュルニ\nュルさせながらいーっぱい触ってあげる、ほら♪　ほらほら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203214" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ふぁあ……♪　すっごいやらしい臭い～……♪　ど、どんどんシゴくんだか\nら！　……にゅる♪　にゅるにゅる♪　ぐちゅ、ぐちゅぐちゅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ママにいっちばん情けない顔見せなさい～♪　おちんぽシコられて感じてる\n顔～♪　大丈夫、嫌いになんかなんないから♪　ほら、ほら♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んんん♪　気持ち～の？　気持ちいいねぇ♪　またおちんぽ膨らんできてる\nよぉ、限界超えてゴリッゴリに硬くなってるぅ……♪　あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あは♪　またビュルビュル射精したくなってきちゃったんだ～♪　ほんっと\nガマンのできないよわよわザコおちんぽでちゅね♪　でも、それでいいの♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ママがたくさんおちんぽ刺激して、精子がい～っぱい溜まるように頑張った\nんでちゅから♪　溜めたのはぜーんぶ出しちゃっていいんでちゅ♪　ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「出しちゃお♪　ママのシコシコでビューしよ♪　タイミングむずかちい？　\nじゃあ教えてあげる♪　５……４……３……２、１！　今出ちて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んんっ！　んっんっんっ！　いいカンジぃ♪　二度目も上手にビューできて\nまちゅ♪　上手、上手、びゅっびゅっ上手♪　出ちて出ちて～♪　もっと♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ママの腰布が妊娠しちゃうくらい、精液の臭いが洗っても取れなくなっちゃ\nうくらいビューちて♪　びゅーっ♪　びゅるびゅる♪　びゅるるるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「ん～っ♪　精液のくっさい臭いで部屋中がいっぱいに満たされてまちゅ～♪\n　精液を二回もこんなに出しちゃった赤ちゃんは誰かなぁ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203303" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「むふふふっ♪　ママの布の中でおちんぽがビックンビックン痙攣してるぅ…\n…。そんなに興奮ちたんでちゅか？　んぅっ、また出た……♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっ、ぁっ♪　布の中で受け止めきれなくて……赤ちゃん精子、ダラダラこ\nぼれちゃってる……もったいないでちゅね♪　ふふふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「でも大丈夫でちゅよぉ♪　頑張って白いおしっこぴゅっぴゅできた赤ちゃん\nのミルクはぁ、ママが後で全部舐め取って飲んであげまちゅから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……ふぅ～♪　我の赤ちゃんプレイはどうだった～？　立派なママだったで\nちょ♪　こんなこと、他にだ～れもしてくれないんだから！　絶対っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あんたみたいなドヘンタイドスケベおちんぽ赤ちゃんに付き合ってあげられ\nるのは～♪　最高最凶のファンタズマちゃんだけ～♪　わかった～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「だから～♪　またこーゆードエロプレイがしたくなったら、その時は我にし\nっかりおねだりすること～♪　約束ちなちゃいよね～。いいわよねぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「だ～ってあんたは我の赤ちゃんなんだもん♪　ママと赤ちゃんはいつでも一\n緒にいないとダ～メ♪　そーゆーことだからよろしくねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「よちよち、いっぱいビューちまちょうね……って、んふぁ！？　あっ！？　\nあっあっ！？　な、なんで言うこときかずに顔にかけてるのぉ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「あっ！？　あっ！　こ、こらぁ！　あっつい！　熱いからぁ！　精液ビュー\nするのは布だからぁ！　顔じゃないし！　んっ！？　あぷ！　んぷぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「やぁあっ♪　んあぁっ……んぅ～♪　もう、バカバカバカ～！　ダメ赤ちゃ\nんんん～！　ここじゃないのぉ！　布にぴゅーちてよぉおお！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……んっ……♪　デロデロになっちゃったじゃないぃ……。精子って一回髪\nにつくと洗ってもとれないんだからぁ！　んんん、くっさいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203404" ]},
		{"command":[ "SETIMAGE", "0", "still_00019702_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「んひゃっ！？　まだ出てるっ……！　んもぉっ……我の顔じゃそんなにたく\nさん受け止めきれないし！　あっ♪　こぼれるからっ……んああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「……すっごいキツい臭いぃ……♪　さっきあれだけ出したら普通薄い精液に\nなるはずでしょお！　なのに、一度目と同じくらい濃い……さいあくぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　気高く美しい最凶の堕神であるファンタズマちゃんにこんなこと\nを要求して、思う存分射精しまくるなんて……ホントさいて～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「でもぉ……そういう一番アブナいところを、我に見せてきたってことは～。\n我のこと、尊敬して、信頼して、愛しちゃってるってコトだよね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「それなら……許してあげなくもないし。なんなら定期的に？　こういうドス\nケベプレイを手伝ってあげてもいーし……って我優しすぎ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ファンタズマ" ]},
		{"command":[ "SETTEXT", "「どーしよーもない赤ちゃんをかいがいしく育ててあげられるのは、我くらい\nの器の大きさのある堕神じゃないとね～♪　それを肝にめいじるよーに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_197_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}