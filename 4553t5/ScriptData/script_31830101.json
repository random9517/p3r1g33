		{"command":[ "PLAYVOICE", "v2_183_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はあっ……なんなの、この量……さっきも出したのに、見たことない勢い…\n…んんっ、やめ、て……顔に、かけないで……ぶっ、んぶぅっ……！」", "NORMAL" ]},
