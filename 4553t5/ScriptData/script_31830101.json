		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ど、どうして……さっきも出したのに……こんなにたくさん……んんっ……\nはっ、んはぁ……出しすぎ、よっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「どれだけ出せば気が済むの……んっ……はぁ、はぁっ……胸を、ドロドロに\nしてぇ……はぁあっ……あぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_09" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「も、もう好きにして……好きなだけ、出せば……いい、わ……あぁ、熱い…\n…さっきより、匂いもキツくて……ンンっ……」", "NORMAL" ]},
