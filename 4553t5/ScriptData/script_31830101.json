		{"command":[ "PLAYVOICE", "v2_183_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あ、はぁ……クサい……生ぐさい……夫のと、全然違う……なんなの、この\n濃さは……はぁ……あぁ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「粘っこくて……汚くて……こんなもの、人の顔にかけて……いいご身分ね…\n…気分は、どう？　満足……した……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ふぅっ……そうね……これだけ遠慮なく出しておいて、満足してなかったら\n……どうしようかと思ったわ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_11" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「は、はぁ……？　それで、どうして私が……興奮しなきゃいけないの？　勝\n手なこと言わないで……不快なだけに決まってるわ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_12" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……また？　こんなことさせられるの……？　楽しみなわけないでしょ……\nこんな、顔も胸も汚されて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103408" ]},
