		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はあ……男って、相変わらずこういうこと……好きね……こんな感じでいい\nの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「べつにいいわよ……やれって言われたら、断れない立場なことくらいわかっ\nてるわ。好きにすれば？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ……だからＩカップだって言ってるでしょ……ふぅ……デカいデカい言\nわないで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「胸でご奉仕……？　パイズリくらい知ってるわよ。私も人妻なんだから、こ\nれくらい……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、ふぅう……やるなら、さっさと済ませて……ンっ……勝手に気\n持ちよくなって、早く出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「べつに、チンポ見たくらいでわざわざ恥ずかしがらないわよ。ほら、おっぱ\nい使いたいんでしょう？　もったいぶらないで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……夫？　どうかしらね。あなたに教える義務はないと思うけど……はぁ…\n…命令？　趣味が悪いわね、ホント……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_01" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ええ、そうね。新婚のころは、結構頼まれたりしたかしら。最近はあまりし\nてないわ……これでいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「夫と比べてどうか？　もういいでしょ……早く終わらせて。べつに照れてな\nんかないわよ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_02" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……大きいわ。長いし、太い……それに硬さも全然違う。若いから当たり前\nかしら……ねえ、もういいでしょう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んんっ、んふぅっ……こらからも、こういうこと……させられるの？　嫌な\nこと、聞いたわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「なに……？　もっと胸を押しつけろ……？　まったく……注文が多いわね…\n…勝手にしてって言ってるじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「奉仕？　そう言われればそうね……その方が、早く終わるっていうなら……\n仕方ないわね……んっ、ンふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「これくらい、できるわよ……ほら、気持ちいいでしょ？　こうやって……挟\nんで擦ってあげれば、すぐ出ちゃうでしょ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「これじゃダメ……？　もっと強く……胸を揺らせ……はぁ、なんなの、もう\n……パイズリに本物もなにもないでしょう……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「わかったわよ……言われた通りにすれば、いい……でしょう……んっ、んん\nっ……は、はあっ……んふぅ……どう、なの……これでいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、はっ……ふぅ……感じてるか、わからないのかって……言ってくれる\nわね……んんっ……はっ、あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……先っぽ……ええ、濡れてきてる、わ……べつに気分がいい\nものじゃないけど……当たり前でしょう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ……んっ……ヌルヌルして……それにクサいし……はぁ、あっあ\nっ……ちょっと、強くしすぎじゃない……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「普通？　どこが普通なのかわからないけど……んっ……は、早く……終わら\nせて……わかったから、んっ……ふっ、うぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あんっ……こ、声？　べつに……あなたが、強くこするから……反射的に出\nてるだけ、で……意味はないわよ……ンっ、んんっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「胸が火照ってるとか、言われても……知らないわ……擦ってるから、それで\n熱くなってるんじゃないの……ふぅ、んっふぅう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ……はぁあっ……こ、興奮？　私が……？　冗談でしょう……ど\nうして、こんなことされて、興奮しなきゃいけないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「こんな……胸を、道具みたいに使われて……はっ、んっ……悦ぶなんて、お\nかしいじゃない……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「ほ、ほら……こうすれば、感じるんでしょ？　余計なこと……言わなくてい\nいから……はや、く……んっ……あふっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_03" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……いい感じ、なの？　それはよかった、わね……はぁ、あっ、あふ……わ\nかったから、出して……いいから、出して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「べつにおねだり、してるわけじゃない……んんっ……あぁあっ……熱い、し\n……硬いっ……なんなの、そんなに大きくして……ああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_04" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はっ……んあっ……言わないで、って……んんっ……あなた\nこそ、息荒いわよ……人のこと気にしてる場合なの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　も、もうすぐ……？　いいわよ、好きにして……それですっ\nきりするなら……はっ、はっあっ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はっ、はあぁ……あぁんっ……！　んっ、んっ、んんぅぅっ……！　な、何\n回も言わせないで……いいから、出して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、あはっ、あぁっ……！　顔はダメ……！　顔にかけないで……\n！　あっ、あっ……んっんんんんっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……やっ！　んっ……はっ、あっあっ……はぁぁぁぁぁぁぁっ！！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁはぁ……んっ、んんっ……や、んっ……どれだけ……んんっ……\n出して……ああっ、んはぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「なんなの……ま、まだ……出て……ひゃうっ！　胸が……んっ……ドロドロ\nになってる……あぁ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103134" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んはぁ……はっ……はぁ……お、終わった……？　ああ、もうっ……信じら\nれない……こんなに汚して……少しは遠慮したらどうなの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「もういいわ……これで満足した？　なら、私はこれで……早くシャワー浴び\nたいので……え？　まだ足りない……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「今、出したでしょう？　こんなにたくさん……！　はあ？　確かに……大き\nくなったままだけど……ちゃんと奉仕したじゃない？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あぁ、もうっ……！　擦りつけないで……！　んっ、クサいから……近づけ\nないで！　わ、わかったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　若いからって、がっつきすぎじゃないの……他の人にも、こ\nういうこと……させてるのかしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「いいえ、べつに興味ないから……答えなくていいわ。それより……んっ……\n早く終わらせて……今度こそ全部出して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あ、あはぁっ……あ、熱い……全然萎えないし……よくまあ、こんなに勃起\nしてられるわね……しかもまた大きくなってる……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「なにしてるの、早く動いて。求めてなんかないわよ……どうしたら、そうい\nう考えになるの。まったく……で、私にどうしろって言うの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あなたの考えそうなことね……相変わらず趣味が悪い……いいわ、胸で奉仕\nしてあげるから……はっ、んっ、んっ……んふっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「だから、私、人妻なのよ……これくらい、大したことないわ……ほら、気持\nちいいでしょ？　んんっ……出そうなら、出していいわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ……んっ……全然？　わかったわよ、もっと強く……でしょう…\n…んんっ……ふっ、んうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「顔が赤い……？　知らないわよ……興奮なんかするわけないでしょう……こ\nんなことさせられて……はあっ……はっ、んっ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_06" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あぁ、もうっ……ヌルヌルして気持ち悪い……くっ、ふぅ、んっんっ……し\nかもすべって、やりづらい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「……なに？　声？　仕方ないでしょ……こうやって、胸揺らすだけで……結\n構大変なんだから……んっ、ふぅ……息、出る……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はあ？　やめて……どこが色っぽいっていうの……んんっ！　もう、そうい\nう安い言葉で……んっ……悦ぶような小娘じゃないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「あ、ちょ、ちょっと……！　んんっ！　ジッとして……なにを、急に……！\n　あっ、あふっ……んんぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ……はあはあっ……いやっ……乱暴にしないで……胸、が……\n痛い……ンっ、はぁっ……はっ、はっ、くふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「どうして、私が……興奮しないといけないの？　冗談はやめて……あっ、ん\nぅっ……き、気持ち、いい……わけないでしょう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「胸を、擦られるだけで……感じる、なんて……ありえない、わ……んんっ！\n　ひうっ！　はぁ、あぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「や、やめて……！　汚い、それ……擦りつけながら……顔にまで、近づけて\nこないで……あぁ、クサくて頭が変になりそう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「く、ふぅっ……んふぅっ！　はぁ、はっ……あふっ……ほら、こうやって…\n…強く、挟めば……いいんでしょう……ンっ、んあっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_05" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んんっ……ま、またそれ、ヒクヒクしてる……わよ……出そうなの？　出る\nなら、先に言って……はっ、はあっ……あ、ああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103216" ]},
