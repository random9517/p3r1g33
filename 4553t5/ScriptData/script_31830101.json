		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「いやっ、も、もうっ……んんんんっ！　ひっ、うっ……こっちに向けないで\n……んぅうぅぅぅぅぅぅ～～～～っ！！！」", "NORMAL" ]},
