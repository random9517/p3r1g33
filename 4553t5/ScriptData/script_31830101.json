		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「はぁあ、はぁあっ……はーっ……クサい……鼻が、曲がりそうよ……興奮し\nた？　それはよかったわね……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_08" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「は、はぁ……？　私が……どうして私が、興奮しなきゃ……いけないのよ…\n…非常に不快、よ……はぁ……はぁ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018301_01_09" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「勝手に言ってればいいわ……か、顔……？　ジロジロ見ないで……終わった\nんでしょ……それなら、早くどいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　擦りつけないで……さんざん出したんだから……もう\nいいでしょ……これ以上……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
		{"command":[ "SETTEXT", "「こ、これからも……？　どうして……私なんかとしてもつまらないでしょう\n……もっと愛想のよくて、若い子がいるんじゃないの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_183_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "戦闘員Ｉ" ]},
