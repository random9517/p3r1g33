{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「し……失礼します。あの……隊長さん。今、お時間ありますでしょうか……\n？　少し、ご相談したいことがありまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104101" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "2", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あの。最近……気になることがあって、どうにも職務に集中できないんです\n。それで……自分なりに理由を突き止めてみたのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104102" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「私……どうやら、恋を……しているみたいで。いつも、そのことばかり考え\nてしまって。でも、そんなんじゃ、いつか戦いに支障が出てしまいます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104103" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「それで。解決しようと思ったんです。私のこの想い……。た、隊長さんが好\nきだっていう気持ちを……今夜だけ、受け止めてもらえませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「つ、つまり！　抱いてほしい……ということです。皆が隊長さんのことを好\nきなのは知ってます。だけど……今日だけ。私を特別にしてほしくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104105" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「……え？　い、いいですか？　『ちょうど呼び出すところだった』？　……\nあ……う、嬉しいです。嬉しい……。はい。覚悟は出来てます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104106" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あっ……！　……えへへ……実際、ベッドで裸になると……照れちゃいます\nね。何度も妄想したのに……。本番は全然ドキドキが違って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019201_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「はい。は、恥ずかしいので……後ろから。隊長さんのお情けを……お慈悲を\nください。お風呂に入って、そ、その、気分は高めてきましたけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「前戯として胸を揉んでいただけるのでしたら……少しだけ。……あっ……♪\n　あっ、あっ……！　隊長さん、隊長さんの手、好き……好きです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「胸をもてあそんで……あっ♪　敏感になった身体をまさぐって……あん♪　\n少しずつ下、に……。ん……あ、あ、あ……脚を持ち上げられたら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「見え、ちゃいます……。私が濡れてるの……。『可愛い』？　かわっ……！\n　あ、あああ……！　そんなこと言わないでください、もっと湿って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「は、はしたないおツユが溢れちゃいます。……『脚を大きく開いて、おまん\nこを見せつけてほしい』？　……はい……。こ、こう、ですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あっ！　た、隊長さんっ……！　隊長さんのおちんちん！　おちんちん、と\nてつもなく、そ、その、勃起っ……勃起して、大きくなって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「すごい……！　私、今から……今からこんな大きいのとするんですね。っ…\n…見てるだけで心臓がうるさくなります。とても立派な……ごくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「は、はい。太くなった硬いおちんちんで……ひゃんっ！？　わ、私のアソコ\nを何度かなぞって……。そ、それから……あっ！？　あっあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おち……んちんっ！　あああああっ！　おちんちん入っちゃいました！　あ\nっ……！　太いっ……！　えっ、こんなに太いの、に、大きいのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ずぶずぶずぶって入っ……あっ！？　あッ！？　あっ！　隊長さん！　隊長\n、さんのが入ってる！　私のおまんこの中入ってる、あっ、あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「隊長さぁんん……！　はい！　痛くないです、お腹が……お腹が中から押し\n上げられているような……あっ、中、中が無理やり拡げられているような」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「でも……でも全然嫌じゃないです！　あっ……ああああああ♪　私っ……私\n、隊長さんのおちんちん受け入れられたぁあ……入れてもらえたああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「嬉しい、嬉しい、うれし……い♪　はぁっ、はぁ、はぁ、はぁ……！　すご\nい、すごい……！　興奮で、もう何もかもよくわかんないです……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あ、の……！　私！　私、大丈夫みたいなので！　動いてください……あっ\n、こういうおねだりってウザいですか？　大丈夫……ほっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あのっ！　私のことは気にせずに、隊長さんにうんと気持ち良くなってほし\nくて……って、あぁ！？　これすっごいっ、これすごい、しゅご、いい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おちんちんっ！　おちんちん大移動してる、あひっ、ひぃっ、んひっ……♪\n　おまんこの中ぁ……！　前、に♪　後ろに♪　前に♪　うしろ、にぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あふっ♪　あんっ！　あんっあんっあんっ！　処女なのに！　私処女なのに\n！　おまんこズポズポされて悦んでる！　痛くない、気持ち、いい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あーっ！　あっあっあぁっああっ！　隊長、さん！　隊長さん！　好き……\n好き、好きです、好き……ぃ、す、き……ああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104125" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「伝わり……ます、か？　私の初恋っ……初恋で、恋愛で、す、好きだから…\n…！　好きだからおまんこがおちんちん簡単に受け入れて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「恥ずかしいくらい情熱的におしゃぶり……しちゃってます！　聞こえますよ\nね！？　じゅぽっじゅぽっじゅぷっじゅぷっておまんこでねぶってる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ッあああああ……！　ああああ！　これが……これがセックス♪　好きな人\nとするセックスぅう……♪　頭、頭がキラキラ、して……すごいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おまんこグチュグチュされてるだけなのに♪　おちんちんがおまんこいっぱ\nい往復してるだけなのに♪　全身、全身気持ち良くて……すっごいぃい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「っはひっ♪　はひ……♪　あひ、あひ……ひぃいい♪　あっ♪　あっ♪　や\n、だ……！　や、だ……！　愛液っ、愛液どんどん溢れてくるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「隊長さんのおちんちんに恥ずかしいお汁絡みついちゃう、……あっ！　痴女\nみたいに、へ、変態みたいに……初めてなのに感じすぎちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「嫌いにならないでください……！　濡れすぎてるのも、自分の意思とは関係\nなく、おまんこがきゅうきゅう締まっちゃうのも、これ、自動なんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「自動で！　勝手に！　あっ、あっ、気持ちいいとなっちゃって！　おちんち\nんにすがりついて……甘えちゃって……！　は、はずか、しい恥ずかしい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「……はぁっ、はぁああっ、は、ぁ♪　はぁああ……♪　んんん……！　隊長\nさんの匂い、隊長さんの体温、隊長さんの硬い股間……！　うううう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「私、私……イキ、ます……イキます！　んんんんんっ……！　え？　私がイ\nクとおちんちんも気持ちいい？　や、やったぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「だったらどんどんイッちゃいます、イキ続けますぅ……！　んひぃいいいっ\n♪　あふ♪　イく♪　イく♪　またイク……んぃいいいいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『締まりすぎてキツすぎ』？　あは……ごめんなさい、でも制御できないで\nす！　ずっと、ずっとイッちゃって、おまんこ勝手に締まっちゃって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あう♪　あう♪　イクのが止まんないですうう……！　あああああ！　隊長\nさん！　隊長さんも気持ちいいですかっ！？　……はい！　はいぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『もうすぐ精液が出そう』……？　あぁ♪　だったら♪　だったら中に出し\nてください……！　私避妊なんてしてませんから、せっかくですからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「初めての証がおまんこに欲しい、です♪　お願いします……！　隊長さんの\n精液、私のおまんこに、おまんこにくださ……ぁいい、いいいいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あーーーーーーーーーっ♪　ああっ♪　ああっ♪　ああああああーーーーー\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「き、たぁあああ♪　おまんこに、おまんこに精液来た、来た、来たぁ……イ\nクぅうううう♪　あはっ……かはっ、すっごいっ、すっごい量っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おねだりして良かった……ッ。わ、かる……わかりますぅ！　快感で麻痺し\nたイキすぎおまんこでもわかるくらい、ドップドプ注がれてます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「幸せ……しあわ、せ……♪　中出しです……！　ラブラブカップルみたいに\n♪　最後まで抜かないで中出し……ぃ♪　素敵……素敵♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「んっ、全部、全部注いでくださいね……。いくらでも感じていたいんです、\n好きな人の精液……。それでお腹が破裂しちゃってもいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「っあっ！　あっあっあっ……！　はぁああああああ～～～～♪　出しきれま\nしたか……？　『出せたけどまた勃起してきた』？　きゃあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「隊長さんって絶倫さんなんですね！　あっ♪　本当です……！　も、もう中\nでムクムクって……！　えへ、私のおまんこ好きなんでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「『柔らかくてプニュプニュしてて、みっちりでキツキツ』……？　あは……\n♪　しかも、愛液と精液で大洪水……ですもんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「このおまんこは……。えっと。隊長さん専用ですので、隊長さんが好きに使\nっていいんですよ。はい。他の誰にも見せません。触らせません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「隊長さんがしたい時にする場所です。それが……んふふふ♪　私も一番気持\nち良くなれますから……いいんです。っ……おちんちん、かっこいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「一回出したのに、……ううん。一回目よりもゴツゴツしてて……。男らしく\nなったっていうか……その。エッチに、中をニュリニュリしていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「……もう我慢できません！　つ、続けて二回目……していいですか？　あっ\n……！　ぎこちないかもですが、私も腰、使いますから……んあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104212" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「隊長、さんも……！　腰の動き、合わせ、てください……っ！　私と一緒、\nに♪　あっ……！　いっちに、いっちに、で……。ふぁっ、はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あああーっ♪　あぁっ♪　あっあっあっ♪　後ろからっ♪　後ろ、から♪　\n狭くなったおまんこ突かれるのいいですっ、痺れます、あああああーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「奥っ……一番奥、突いてくださぁいぃ……♪　あぁんっ、あんっ、あんっ…\n…あぁんんっ！　すごい♪　すごい、腰っ……グリグリしないでぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「感じすぎちゃいますっ……あああっ！　またイキます、イくの、まったくこ\nらえられないです……あぁ♪　気持ち……いい、気持ちいいですうう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんっ、あんっあんっ！　あぁ……ああ♪　全身を一突きにされ\n、て……♪　おちんちんの力だけで身体中揺らされてぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おっぱいもたぷたぷ、たぷたぷ、たぷたぷっ……！　お尻にどちゅっ♪　ど\nちゅっ、どちゅ……！　めまいがするくらい……いいです、気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「隊長……さん♪　隊長さん……私、私……脚が痺れて……！　今までで一番\nスゴい絶頂きちゃいそうです、だから、だから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「一緒にイッてください♪　達してください……っ！　好きです……好きです\n、愛してますううう……！　ああああ、イクぅううううーーーー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あっ、あああああああーっ♪　嬉しいです、うれしい……うれ、しいぃいい\n……好きですうううう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　何度されても……幸せで、気持ち良くて、あああ……！　\nカーッと体温が上昇していくのがわかります……しあわせぇえ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あっんんんっ♪　んーっんんん……！　あっ♪　あっ……♪　えへ……♪　\nおっぱい、揺れすぎ……ですか？　ふふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「絶頂するたびに……♪　おまんこから胸にズドンッて太い快感がはしっ……\nて♪　女の喜びが全身に広がるんです、それで……でしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「よくわからないですけど……あっ♪　好きな人とするエッチが……。初回か\nらここまで気持ちいいものだとは思っていませんでしたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「嬉しい誤算でした……。あんっ♪　あはは、また今ぴゅって出ましたね。も\nぉ……。隊長さん、どれだけ精力が強いんですか……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「おちんちんは私の手首より太いですし……。腕かと思うくらいに長くて、し\nかも……。エッチもうまくて、精液もどぱどぱ出るんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「性豪……なんでしょうか？　女を酔わせる悪い男のような……♪　あ……で\nも、私一つも後悔していません。おまんこの反応からもわかりますよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「隊長さん……とはじめて、できて……。最高に幸せです。んっ……精液がま\nだアソコに溜まっていますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「そのことで興奮しちゃっているのは誤算でしたけど……。自分の新しい一面\nを知れた気がします。感謝です……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「あっ……！　なんでっ……なんで抜いちゃうんです、か……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　あっ、あっ、ああああっ……！　精液っ……私のおまんこに出\nしてもらうはずだった精液ぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「いやです、どんどん、どんどん外に出ちゃって……あっ！　身体に……かけ\nられるのは気持ちいいです、ですけど……ぉ！　あぁあんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「イ……イッたばかりの肌にかかる精液……。お尻に……太ももに浴びせられ\nた精液……。あぁー……二回目なのにまだこんなに……ぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「これが私のお腹の奥に出ていたら、さぞ満足させてもらえたでしょうに……\n。ん……、悔しい、です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「けど……。うん……。隊長さんが私の身体に出したかったなら、私は……そ\nれで納得し……。……納得できませんー……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「好きな人の精液……。『一回は中に出した』？　そうですけど……。目に見\nえると、どうしても想像しちゃうんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019201_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんの素、こんなにたくさんあったら絶対妊娠しちゃうって。隊長さん\nの臭いと、熱さと、気持ちさが詰まった精液は私にとっては……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「私にとっては宝物みたいなものですから……。……本当に、目を疑うくらい\n濃くて、プリプリで……おいしそうな精液です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「まあ……。隊長さんの香りに包みこまれて……、あっ……♪　恍惚とする瞬\n間も……嫌いじゃないですけど……。あ……♪」", "NORMAL" ]},
