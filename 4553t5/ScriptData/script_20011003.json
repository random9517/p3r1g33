{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ……きりがねぇな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「ホントだよねー、そろそろ遊びもおしまいにして……えいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021290001" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うわっ！　くそっ……何だこりゃ、煙幕かっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290001" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「へへー、隙ありっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021290002" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおわぁぁっ！？　なんだっ、こりゃ……くっ、網が絡まって……動きがっ\n……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アルマ" ]},
		{"command":[ "SETTEXT", "「っていうことでー、お兄さんは貰っていくね♪　ばいばーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_166_010021290003" ]},
		{"command":[ "SETCHARA", "0", "char_00016601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「待てっ、アルマっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290001" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「くっ……取り逃がしたか……すぐに後を追わねば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290002" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おいちょっと待て、お前ケガしてんじゃねーか。手当てするから、こっちに\n来い」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290002" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そんな暇はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290003" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いいから、落ち着け！　頭に血が登った状態で何かしようたって、犬死にす\nるだけだぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「っ……それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290004" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「それに、こっちも聞きたいことが色々ある。なに、時間は取らせねえよ、顔\n貸してくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「……承知しました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290005" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「これで、よしっと。間に合わせだが、何もしないよりはマシだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「かたじけない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290006" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「いいってことよ。ほれ、ペットボトルのお茶で悪いけど飲んでくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そんなお構いは……いや、かたじけない……ありがたく頂戴します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290007" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あんた……イグニスとか言ったっけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はい、イグニス・タルヴォットと申します。どうぞ、お見知りおきを」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290008" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あたしは、赤塚ほむらだ。ほむらでいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「これはご丁寧に……よろしくお願いします、ほむら殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290009" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「で……差し障りのない範囲でいいんだが、事情を聞かせて貰えるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「……そうですね。既にこの地でご迷惑をお掛けした以上、当然説明する責任\nはあるでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290010" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「とは言え、何と説明したものか……その、俄には信じられない話になるかと\n思いますので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290011" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あー、その辺については割と大丈夫だと思うぜ。まぁ、とにかく話してみて\nくれよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はい……それでは、その……まず、私は……この世界の人間ではありません\n。別の世界……異世界から来た者です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290012" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ああ、なるほど……それで？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290011" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あ……ええと、驚かれないのですか？　こんなにも、すんなりと信じてもら\nえるとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290013" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「身も蓋もない言い方をすれば、もう慣れっこでございますからなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021290001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「うわぁぁぁっ！？　い、犬が言葉を！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290014" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そこまで驚かなくてもいいでしょう。少し傷つきますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021290002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あ……す、済まない……いや、だが……しかし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010021290015" ]},
		{"command":[ "SETCHARA", "0", "char_00016701_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まあ、あんまり驚かないって理由が何となく分かったろ。この犬っころのこ\nとは気にしないで続けてくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020021290012" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ほむら殿まで犬っころ呼ばわりはひどいですぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021290003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}
