{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_02" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅるっ、れるっ……どうだ……れちゅるっ、んれっ、れじゅるっ…\n…こんな感じで、いいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ふっふー。そうだろう？　気持ちいいだろう？　さっすが私……んっ、れち\nゅるっ……やっぱりナニをヤらせても、私は天才だな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303102" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「まぁ、お前にはいつも奢ってもらってるからな……んちゅっ、ちゅれっ……\nたまには私がサービスしてやる……れちゅるっ、ありがたく思えよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「それにしても……れるっ、れちゅるっ……意外と、大っきいよな……んれっ\n、れりゅるっ……これを口の中に、咥えるんだろ……？　入るかな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「まったく、弱っちいくせに……んっ、ちゅっ、れりゅりゅっ……こんなとこ\nろばっかり立派で……れるっ、れるれるっ、ナマイキだぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「それに、ココのニオイも……すんっ、すんっ……んっ、ふぅぅぅっ……なん\nていうか、すごく男臭いぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「でも……すんっ、すんっ、んっ、はぁぁぁっ……悪くはない、かも……？　\nオスのニオイって感じがして……んぅっ、くふぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ま、まぁ、キライなニオイじゃないな……すうっ、はぁ……すぅっ、はぁ…\n…んんんっ……！　このニオイを嗅いでいると……んはぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、あふぅっ……気持ちが、落ち着くような……すぅぅっ、はぁぁぁっ…\n…逆に、胸がドキドキして、身体が熱くなるような……ふぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「なんだよ、お預けされた犬みたいな顔して？　んっふっふ～♪　分かってる\nって。もっとちゃんと舐めたりして欲しいんだろ？　しょーがないなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303110" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、れるっ、れちゅるっ……味も、ちょっとショッパイような……れじゅ\nるっ、えれぇっ……でも汗とも違う感じで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「不思議な味だけど……れるれるっ、えれぇっ……あんまり、気にならないな\n……んっ、ちゅれっ……お前のだからかな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あ、ち、違うぞ……！　今のは別に、変な意味じゃないからな……んっ、れ\nちゅるっ……言っておくけど、勘違いはするなよな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「れるっ、れちゅるっ、んじゅるるっ、これは奢りのお礼として、仕方なくや\nってるだけなんだからな……んえれぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「口と舌を使ってするマッサージなんて、れるっ、れりゅりゅっ、れるぅっ、\n本当はイヤなんだからな、んちゅっ、ちゅっ、ちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「コレはただの、スキンシップみたいなもので、んえれぇっ、れじゅるるっ、\nお前だから特別に……でも、仕方なくヤってるんだからな、れじゅるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「くっ……ニヤけた顔で、私を見るな……！　れちゅっ、れりゅりゅっ……そ\nんなやつは、こうしてやる……ぬぐぷっ、じゅぐぷぷぷっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ぬじゅぷっ、じゅぞぞぞっ……んふぅっ、やっぱり、おっきい……ずじゅる\nるっ、じゅぐぷぷっ……口の中に、ぜんぶ入りきらないぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ふぅっ、んふぅぅっ……のどのところまで……れじゅるるっ、じゅぐぷっ、\nじゅぷっ……おまえので、いっぱいになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、くふぅっ……味とニオイが、さっきよりもつよくなって……んじゅぷ\nっ、れじゅるるっ、からだが熱くて、ぬぶぷっ、頭が、ぼうっとする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「じゅぬぶっ、ぢゅぐっ、ぬぶぷっ……口の中で、お前のが……れぶりゅっ、\nぬぶりゅりゅっ……ぴくぴく、ふるえてるぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「じゅぷっ、じゅぬぶっ、ぬじゅぼっ、わたしにされるのが、ぬぶっ、ぬぼっ\n、ぬぼっ、キモチイイのか？　んっふっふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いいぞ……ぢゅずるるっ、ねりゅりゅっ、れるぅっ……ぬぢゅぼっ、ぢゅぼ\nっ、ぢゅぼっ、ぢゅぼっ……もっと、気持ちよくなれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「わたしの舌で、いっぱいペロペロされながら……れじゅるるっ、ねぶりゅっ\n、れぶりゅりゅっ、ぬぐりゅりゅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ぬぢゅぼっ、ぢゅぶっ、ぢゅぐぶっ、ぬぶぷっ、口の中で、カチカチのチン\nポを、たっぷりとシゴかれて……ぢゅぞぞっ、ぢゅぐぶっ、ぬぢゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いっぱい、キモチヨクなれ、ぐぬぶっ、ぬぶぶっ、ぐぢゅぶっ、ぢゅずるっ\n……んふふっ、さっきよりもかたくなって、おっきくなってるぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ぬぶりゅっ、ぢゅぬぼっ、ぬぼっ、ぬぼっ、もう、イきそう……なのか？　\nぬぶりゅりゅりゅっ、ぢゅぐぼっ、ぐぼっ、ぐぼっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いいぞ、好きなときに、イって、れぶりゅりゅっ、れぢゅるっ、チンポ、き\nもちよくなって、イっちゃえ……！　ぬぐぼっ、ぢゅぼっ、ぢゅぼっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「わたしの口のナカで、いっぱいナメられて、シゴかれて、ぬぶりゅりゅっ、\nぐぬぼっ、ぬぼっ、ぬぼっ、チンポ、イけ、イけっ……ぬぢゅるるるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んむぅううう～～っ！？　んぶっ、うぶぷっ、んぷっ、ぅぶぅううっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303130" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ちょ、いきおい、つよすぎるっ……んぶっ、うぶぅぅっ！　ドロドロ、あつ\nいの、のどの奥まで……あぶっ、んぶっ、うぷふぅうう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「こんなに、いっぱい、んふぅっ、ぶぷぅっ、りょう、おおすぎる……くちか\nら、あふれて……ずぢゅぢゅっ、うぐぷっ、いき、できな……うぶぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、くっ……ごきゅっ、ごきゅっ……んふぅぅっ……！　ふぅっ、ふぅぅ\nっ……んくっ、ごきゅっ、ごきゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ぶぷぁっ、くっ、ベタベタして、のどに、ひっかかる……んぐくっ、ごきゅ\nっ……ちょっとずつしか、のみこめな……あぶぷっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ウソ、また、出て……んぶっ、んふぅぅっ！？　もう、はいらな……んぐく\nっ、ごきゅっ、ごきゅっ……ごっきゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んくっ……ぷはぁっ！　はぁっ、はぁっ……くぅぅ、お前ぇ……遠慮なく私\nの口の中に、いっぱい出しやがってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「口の中にまだ、ベタベタしたのが絡みついて、んっくふぅぅっ……すごい、\n匂いだぞ……身体の中までぜんぶ、お前の匂いにされたみたいで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅぅっ……ネバネバして、苦くて、ちょっとしょっぱくて……ん\nんっ、んぐくっ……はぁぁっ……なんか、クセになりそうな味だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「……お前のチンポ、まだ固いままだぞ……？　もしかして、もっとシてほし\nいのか……？　ふ、ふん……まったく、しかたないヤツだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「私はべつに、ヤりたくないけど……んっ、ちゅっ……お前がどうしてもって\n言うから、仕方なくシてやる……ちゅっ、ありがたく思えよな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000403_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
