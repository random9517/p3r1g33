{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "ほむらからもらったレシピをもとに、ついにパンケーキが完成した。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「できた……。『炎のパンケーキ』……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020114030001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「流々那さん、パンケーキを焼くのとても上手でした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020114030001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「これは、私が初めて覚えた料理だから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114030002" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「カツマ、食べてみて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114030003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "流々那に差し出されたパンケーキを早速食べる。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "これは……美味いっ！", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "見た目も味もシンプルだ。だからこそ甘味や酸味といった素材の味が活きてい\nる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「どう、かな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114030004" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、美味いぞ。めちゃくちゃに美味い！　これならいける！　優勝も狙え\nる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「やったね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020114030002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「それじゃあ、これを売りましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020114030002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "流々那" ]},
		{"command":[ "SETTEXT", "「うん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_130114030005" ]},
		{"command":[ "SETCHARA", "0", "char_00000113_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0147" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SETTEXT", "それから、地球防衛科の屋台はカレーからパンケーキに大幅シフト。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "炎のパンケーキはその味もさることながら、見た目的にも女性客の心をつかみ\n、客も増えていく。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「はい、パンケーキですね。カツマ先生！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020114030003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「お持ち帰りですね、すぐに用意します。カツマ先生！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020114030003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう、おうっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は忙しくなった屋台の手伝いをしていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルルーナ" ]},
		{"command":[ "SETTEXT", "「防衛科の屋台はこちらー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_070114030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000106_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「炎のパンケーキ、まだ残ってまーす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010114030001" ]},
		{"command":[ "SETCHARA", "0", "char_00001205_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「美味しい。これ、美味しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040114030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「スイーツ三銃士にも声をかけて、客引きの手伝いをしているのだが、セレイン\nはさっきから食べてばっかりだな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「失礼な。美味しく食べているところがなによりも宣伝になるんだよ？　もぐ\nもぐ。おかわり！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040114030002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "はぁ……。まあ、実際口コミで評判は広がっているからいいけどなぁ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ここですか、地球防衛科の屋台は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114030001" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「イグニスじゃねーか。正義の方はいいのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ほむらに様子を見てこいといわれたので。ということで、パンケーキをくだ\nさい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114030002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "イグニスにもパンケーキを食べてもらう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「いいですねぇ……ふわふわのパンケーキに甘酸っぱいベリーソース」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114030003" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「甘味の王道ともいえる組み合わせ。間違いない味です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114030004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「メニューとして正式採用してほしいくらいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114030005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「褒めすぎじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いやいや、それくらい美味しいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_040114030003" ]},
		{"command":[ "SETCHARA", "0", "char_00000403_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「おかわり！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_010114030006" ]},
		{"command":[ "SETCHARA", "0", "char_00016704_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「もう食べたのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「地球防衛科の屋台、盛り上がってる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020114030001" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「あれから盛り返すとは、驚きであるが……我々には到底及ばないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020114030001" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「うん。前半戦は所詮茶番。コンテストの優勝は後半の審査が大きなウェイト\nを占める……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020114030002" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架" ]},
		{"command":[ "SETTEXT", "「我々には、グレーテルにも見せていない隠し玉があるのである。それを出せ\nば優勝間違いなし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_020114030002" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "グレーテル" ]},
		{"command":[ "SETTEXT", "「まだこっちの手の内は全部見せてないよ。ふふ、優勝はもらっちゃうね……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020114030003" ]},
		{"command":[ "SETCHARA", "0", "char_00001802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "遥架＆グレーテル" ]},
		{"command":[ "SETTEXT", "「ふふふふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_020114030004" ]},
		{"command":[ "SETCHARA", "0", "char_00002002_01", "6", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00001802_01", "6", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "兎子" ]},
		{"command":[ "SETTEXT", "「怪しい人たちですね。そういう人って、たいてい負けますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_050114030001" ]},
		{"command":[ "SETCHARA", "0", "char_00000505_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
