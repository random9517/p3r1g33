		{"command":[ "PLAYVOICE", "v2_065_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「オチンポもイって！　隊長殿もイってぇぇぇっ！　んっひぃあぁぁぁっ！　\nあっ、あふうぅぅぅんん～～～～っ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_065_0204220" ]},
