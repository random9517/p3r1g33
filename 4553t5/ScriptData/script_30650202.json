		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "宵待隊員" ]},
		{"command":[ "SETTEXT", "「はっひぃうううぅぅぅっ！　おっおおっ！　おほぉぉぉっ！　で、出てるっ\n！　な、なかっ……出てるぅぅぅっ！！」", "NORMAL" ]},
