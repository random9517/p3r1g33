		{"command":[ "PLAYVOICE", "v2_131_0503112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひぃうっ！　な、なんですか……いきなり……舐めないで、くださいっ……\nひゃっ……あっ、あうっ……んひぃっ！」", "NORMAL" ]},
