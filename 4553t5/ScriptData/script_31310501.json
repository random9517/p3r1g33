		{"command":[ "SETIMAGE", "0", "still_00013105_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「か、可愛い、声……じゃなくてぇ……大人しくしててくださいって、言った\nのに……くっ、ひっ……ひぃいっ……んっ！」", "NORMAL" ]},
