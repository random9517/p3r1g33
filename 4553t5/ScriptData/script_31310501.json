		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「だって、私のアソコが丸見えで……恥ずかしいですよ……！　恥ずかしいに\n決まってるじゃないですか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんっ……この方が興奮するんですか？　あなたって人は……本当にスケベ\nなんだから……もうッ……」", "NORMAL" ]},
