		{"command":[ "SETTEXT", "「ンっ、んふぅっ！　じゅぷっ……じゅぷじゅぷっ……はあっ、んっ、あはぁ\n……出して……また射精、して……んぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「どっちでも、んぶっ……好きなように……口でも、いいですし……かけても\n……いいですっ……れろ、れるっ、れろぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ……じゅっ、じゅぶっ……ンぶっ、早くぅ……じゅぷっ、じゅぽっ\n……ンぶっ、んれろっ……じゅっ、じゅるるるぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んんぅぅっ！　はっ、んぶっ！　んぐっ……はあぁぁっ……！　んむっ、む\nっ……むぐぅぅぅぅ～～～っ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013105_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁン、んぁっ……んぐっ……くふっ、んううっ……んっ、くっ……ンくっ\n……ごくっごくっ……ザーメン、出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あんっ……んぶっ、んくっ……熱ぃ……すごい、量で……はぁんっ……ごく\nっ……ごくんっ……ん、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んふぅっ……さっきより、おおい……んくっ……ンっ、んっ……喉に、絡み\nつく……んぅうっ……んぐっ……んっ、ふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503304" ]},
		{"command":[ "SETIMAGE", "0", "still_00013105_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁはぁ……に、匂いも、すごい……ザーメンの匂いで……んぷっ……口の\n中から……鼻まで匂いが……いっぱいぃ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んっぷっ……ぢゅっ……ぢゅるっ……ぷはっ……はぁ、はーっ……あ、はぁ\n……ちゃんと、残ってる分も……ちゅうっ、ちゅるるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503306" ]},
		{"command":[ "SETIMAGE", "0", "still_00013105_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ふぅ……全部、飲みました……んー、ちゅっ……！　教えられた通り、おち\nんちんも舐めて綺麗にしましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503307" ]},
		{"command":[ "SETIMAGE", "0", "still_00013105_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はふぅ……それにしても、すごい量でしたね……なんか途中で、余計なこと\nしてましたけど……もうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「……は、はい？　き、気持ちいいとか……まあ……全然、感じてないかと言\nうと……ウソになりますけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「またですか……？　そんなに気に入ったんですか、これ……あなたがそこま\nで言うなら、またしてあげてもいいですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ぷはぁぁぁっ！！　んっ、あっ……抜けちゃった……あっあっ、はぁんっ！\n　ひゃっ、あぁぁぁぁあ～～～っ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00013105_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ひゃぁ！　あぁっ……！　か、顔にかかってぇ……ひゃうっ、んうぅっ……\nちょ、ちょっと……ひぃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ンンっ！　出していいって……言いましたけど……あぁんっ……出しすぎっ\n……ひぃ、あっ……あんっ……んうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あぁあっ……あ、熱いっ……んっ、あっ……！　か、顔……精液でドロドロ\nになってぇ……ンンぅっ、くっ……ひぃいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ンっ、ふぅうっ……さっきも、いっぱい出したのに……まだ出てるっ……は\nぁ、あはぁぁ……あぁ……あぶっ、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503405" ]},
		{"command":[ "SETIMAGE", "0", "still_00013105_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「も、もうっ……溜めすぎ、ですよ……どれだけ出せば、気が済むんですかぁ\n……んっ、ふぅっ……に、匂いもすごい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「あふぅ……んっ、んぷっ……顔が、ザーメンくさくて……匂い、取れなくな\nっちゃいそう……ンふぅ……はあ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503407" ]},
		{"command":[ "SETIMAGE", "0", "still_00013105_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「気持ちよかったのは、わかりましたけど……ふうっ……ちょっと、出しすぎ\nですよ……それに邪魔ばかりして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「私が気持ちよくなって、どうするんですか……ご奉仕してたのに……もうっ\n……勝手なんですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はい？　またですか……？　またこの格好で……そんなに気に入ったなら…\n…仕方ないですね……今度だけですよ……」", "NORMAL" ]},
