		{"command":[ "PLAYVOICE", "v2_131_0503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「まったくぅ……舐めっこ、とかしなくていいんです……こんなこと、で……\nんっ……興奮しないでください……あんっ」", "NORMAL" ]},
