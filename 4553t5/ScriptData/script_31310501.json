		{"command":[ "SETIMAGE", "0", "still_00013105_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はむっ……んっ、ンむ……はぁ、大きい……ちゅぱ……はぁん、んっ……ヒ\nクヒク動いてます……ンンっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503110" ]},
		{"command":[ "SETIMAGE", "0", "still_00013105_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちゅ、ちゅるっ、ちゅっく、ちゅぷ……どうですか？　気持ちいい……です\nか？　れろっ……れろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
