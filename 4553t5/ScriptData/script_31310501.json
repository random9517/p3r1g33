		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「はぁ……じゃあ、ご奉仕を始めますけど……邪魔しないでくださいね？　大\n人しくしててください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503105" ]},
		{"command":[ "SETIMAGE", "0", "still_00013105_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅっ……はぁ、大きい……近くで、見ると余計に……んっ……れろ\nっ、ちゅ、ちゅむ……れろぉっ……」", "NORMAL" ]},
