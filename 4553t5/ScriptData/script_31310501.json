		{"command":[ "SETIMAGE", "0", "still_00013105_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ですから……あなたが、邪魔するからぁ……あっ、あふっ……ンンぅ……わ\nかって、ます……んっ、舐めて、あげますから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
