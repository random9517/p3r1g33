		{"command":[ "SETIMAGE", "0", "still_00013105_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと……息がかかって……んっ！　どこって……アソコですよ…\n…あなたの鼻息が……はっ、ああぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_131_0503107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クリス" ]},
		{"command":[ "SETTEXT", "「気持ちいいとか、言ってないでしょう……くすぐったいというか……あふっ\n……気が、散って……ご奉仕が……」", "NORMAL" ]},
