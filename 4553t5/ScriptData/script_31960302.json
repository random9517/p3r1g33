{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_01" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あれ～？　おにーさん、どこ行って……ってひゃんっ！？　んもぉっ……！ \n　背後から抱きしめて、いきなりベッドに押し倒すとか……ケダモノぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あはぁ……♪　ちょーっとからかいすぎたかなぁ～♪　でもさぁ、いきなり \nオチンポ押しつけてくるなんてぇ～。アーちゃんのこと好きすぎじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……ん？　な、なんで黙ってるの……？　べ、別に怖くないし！　しょせん \nおにーさんじゃん、オチンポ太くておっきくてバキバキで硬くって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「長くて臭くて強そーで……、ビ、ビクビク震えてて……。っくぅっ……、な \n、な～んか今日……いつもよりおっきいよーな……？　ま、待って？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304104" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「もしかして、このままフツーにアーちゃんのオマンコにハメちゃうつもりじ \nゃないよねぇっ！？　む、無理だよぉ……、すっごい凶悪オチンポだし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「クリスマスなんだからぁ、女の子には優しくしないとじゃないっ！？　あっ \n……無理ぃっ、入んないからそんなデッカいのっ！　っああああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいんっ♪　い、入れられちゃったぁあああッ……！　おにーさん \nのデカデカつよオチンポっ！　無理って言ったのに挿入されちゃったぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304107" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぁひぃいいんっ！？　ね、ねぇええっ！　なんかっ！　入れられただけで \n軽くイかされてっ……、あっあっ、母乳まで噴かされたんですけどぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なにコレぇっ、んひぃいっ♪　き、気持ち良すぎぃいいっ……！　邪道オチ \nンポじゃんんっ！？　あっ……こんなの抵抗できる女の子いないしぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「や、やぁあっ……、ら、らめ……！　らめらからぁっ！　だめぇっ！　こん \nなオチンポに本気で動かれたら……突かれたら、おかしくなっちゃうぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「確かにおにーさんのこと、からかいまくったしっ！　イジワルもしたけど… \n…だからって、こんな凶悪ゴリゴリオチンポで反撃するのずるいよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……んっ！？　おっ！？　だ、だから動いちゃだめらって……、んひぃんん \nっ！？　ひゃぁああっ！？　んひぁあっ！？　ピストンだめだめだめぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304112" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぉふぅうっ♪　……ヘ、ヘンな声出ちゃうからぁっ！　可愛くない声ぇえ \n……！　本気イキしちゃうからやめてってぇっ、ばかばかばか～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ひぅうっ♪　お、おにーさんのオチンポ、はぁっ！　アーちゃんがいじって \nぇっ、遊ぶのっ、そういう楽しいオチンポなのっ……なのになのにぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「突然男らしくオマンコ犯すとかぁっ……聞いてないんですけどぉおっ……！ \n　あぁあんんっ♪　も、もぉ～っ、ありえない！　気持ち良すぎるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んもっ……！　もぉおっ！　カリ高でエグエグの極太オチンポぉっ、アーち \nゃんのちっちゃいオマンコぐっちゅぐちゅに突いてくるぅっ、やだぁ～っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あひっ♪　ひぅうっ♪　感じるぅっ♪　んにゃああっ♪　お、おにーさんの \nオチンポ、アーちゃんのすっごい好きなところばっか刺激してくるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304117" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そ、それに……アーちゃんのおまんこの形にぴったりで……んぁああっ♪　 \nちょっと動かされるだけで、摩擦っ……ましゃつヤバイぃいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ、ぅっ♪　うっ、うぅうっ♪　好きになっちゃう！　なんかぁあっ♪　こ \nのままオチンポで突かれまくったらぁっ、身体と心が誤解しひゃうぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んッ、んぅううう～っ♪　おにーさんのこと大好きになってっ♪　おにーさ \nんのオチンポでしかイケない身体にされりゅっ、あーっ♪　あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんのことどーするつもりなのぉおおお～っ♪　はぅうんんっ♪　え \nっち奴隷にする気ぃっ！？　そ、それともお嫁さんにするつもり～っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んっあっあっあっ♪　あ、赤ちゃんできちゃうっ！　こんな本気のオチンポ \nブチ込まれてっ、後ろから好き好き好き～ってオマンコえぐられてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304122" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「このままホカホカのドロドロ精液流しこまれたらっ！　赤ちゃんできちゃう \n、妊娠しちゃうぅっ！　アーちゃんママにされるぅっ、奥さんになるっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「それで毎日毎朝毎晩んんっ♪　このデカつよオチンポでえっちされちゃうぅ \nううっ♪　あ～～～～っ♪　あっぁっ、そんなの、そんにゃのぉお……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「最高にしあわせぇええ～……♪　って、あうっ♪　ち、違うしぃっ！　思っ \nてないしそんなことぉおっ！　お、お嫁さんになんかならないしぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304125" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「って、ぐちゅぅうってめちゃくちゃ強く突き上げてくるぅうっ♪　ひゃんん \nんっ♪　わ、わかったぁっ♪　わかったよぉ、もぉ～っ♪　あんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんがそんなに毎日っ、アーちゃんとオチンポしたいならいいよぉっ \n……♪　あっ♪　オチンポセックスらぶらぶえっちしてあげてもいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だ、だから今みたいにぃっ、このカッコイイオチンポでいっぱい気持ち良く \nしてぇえ……っ♪　んぁああっ、気持ちいいっ、気持ちいいよぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ああああっ♪　な、なんかっ……オチンポ動かされるたびに、身体の奥から \n……幸せって気持ちが溢れてくりゅのっ、しあわせ、しあわせってぇっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「このオチンポに屈服しなさいってオマンコが言ってるぅううっ……♪　あっ \n♪　女の子の本能がっ♪　負けちゃえって言ってくるぅ～っ♪　あううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んっあっ……おにーさぁん……♪　そんなに腰振って、アーちゃんに種付け \nしたいのぉっ？　アーちゃんのこと、好きで好きでたまんないのぉっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304131" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だったらぁ……することわかるよねぇ……っ♪　あんっ♪　そーだよっ、射 \n精……オマンコに射精してっ♪　受け入れ態勢整ってるからあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁっ、ああああっ……んぁあああっ♪　外に出すとかありえない \nからぁっ……♪　今日はクリスマスだしっ、絶対中がいいっ、中だよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんの……中に、あんっ、出して……っ♪　キツキツでせまぁいオマ \nンコの、一番奥にオチンポぐりぐり～って突き刺して、そのままっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「そのままびゅーっ♪　びゅーっ♪　って出してぇっ……！　絶対妊娠するよ \nうにっ、精液いっぱい流しこんで、あっついのちょうだぁいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ッああああああああぁあああっ♪　キたっ♪　キたぁあああっ♪　ほんっと \nーに中出しきたぁああああっ♪　うれしいっ、うれしいぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304136" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんっ、オチンポの中にある精液ぜんぶっ、ぜーんぶアーちゃんにプ \nレゼントしてっ♪　絶対外にこぼしちゃだめぇっ、中に注入してぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304137" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あはっ♪　すごいっ、すっごい勢いで入ってくるっ……！　んぁああっ♪　 \n精液っ、あっついのがお腹の中に溜まってくぅ……♪　あ～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だめぇっ、出すのやめちゃダメだからっ！　搾りとっちゃうよぉ……♪　ん \nっ、んんんん～っ……！　きゃははっ、まだまだ出るよねぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304139" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ほぉら、びゅーっ♪　びゅーっ……♪　……っあああああぁあ……♪　イク \nぅっ、イクッ……！　アーちゃんも中出し精液でイッちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304140" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あーっ♪　あっぁっあ～～～っ……♪　ふぁああ……っ♪　お、おにーさぁ \nん……♪　おにーさんの射精、ホントしゅごいぃ……♪　満足度高いぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ってか、相手がアーちゃんだったからこんなに出しちゃったんだよねぇ♪　 \nあっはっ♪　光栄なんですケド～……♪　んん、お腹が精液で膨らんでる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「えへ……♪　ね～？　どーだったぁ？　アーちゃんとのメリクリえっち♪　 \nきょーれつにオチンポにキちゃったぁ？　……って、……んん？　ん～っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ、あれぇっ……？　な、なんかまた動き出してない！？　あっ！？　え、 \nこんだけびゅぶびゅぶ射精しといて、ま、まだ勃起してるとかアリぃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぁっ！？　う、うそぉ！　……あっ、休憩もしないでもう一回するのぉっ \n……♪　も～っ♪　おにーさんってばアーちゃんラブすぎぃ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「その気持ちはうれしーけどさぁ～、イッたばっかだしちょっとだけ休んで… \n…って！　ああぁあっ！？　ふぁあっ！？　ご、強引に……んぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304206" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ！？　ひぃんっ♪　んひぃっ、はぁあっ♪　あんっ♪　あんっ♪　あぁ \nああっ……！　な、何よぉ～っ、むちゃくちゃピストンして……あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「イッたばっかだしまたすぐイっちゃうから、だ、だめ……っ♪　はぁああっ \n♪　あふっ！？　……あっ……♪　らめ……らめなのにぃ……！　あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「な、なんでぇ～？　一方的にオマンコ犯されるの気持ちイイよぉ……っ！　 \nあっ♪　あ、あたしっ、マゾになっちゃう、ドMにされちゃうよぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304209" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ！？　ああああああぁっ……！　おっきいオチンポにぐちょぐ \nちょオマンコ、わからされるのってスゴすぎぃっ、気持ち良すぎるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304210" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ～っ♪　ああああっ、イクイクイクぅううっ……♪　イクっ……！　あぁ \nっ！　乳首、おっぱいがムズムズするっ、出るぅ、母乳出るぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はひぃいいいっ♪　出ちゃったぁあ♪　おっぱいミルクぴゅっぴゅしちゃっ \nたぁああっ！　母乳出しながらイクのクセになる、やめらんないよぉおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んはぁああっ♪　身体に力、は、入んないよぉお……っ♪　出ちゃう、全部 \n出ちゃうぅ……！　あっ！　あっ、い、今揺さぶらないれぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ミルク、ミルクこぼれちゃうからっ、溢れちゃうぅうっ……！　ん～～～～ \nっ♪　気持ちいいぃっ！　オチンポ好きぃっ、気持ちいいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんのオチンポの言うとおりにしますぅううっ♪　このオチンポっ、 \n入れてくれるなら何でもします、もうワルいこともイタズラもしませんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「良い子になるからぁああっ……♪　あ～～～っ♪　おっぱいミルク止まんな \nいよぉおっ、オマンコもきゅうきゅう締まって、オチンポに媚びてるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「うんっ、うんんっ♪　あたしのっ、アーちゃんのオマンコはおにーさんだけ \nのもの！　おにーさん専用マゾマゾオマンコだよっ……！　だからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「もっと！　もっとちょうだい！　おにーさんの出したての精液でイキたいも \nん！　っあんっ♪　まだ足りないよぉ……もっと欲しいのぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304218" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ふぁあっ……ああっ、ぁっあっ♪　おにーさんっ♪　おにーさんのオチンポ \nどんどん硬くなってくる、太くなってくる……精液出そうなんでしょぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304219" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「一緒にっ……一緒にイッてぇっ……♪　おにーさんっ、アーちゃんのこと甘 \nえさせてよぉっ！　イキたいぃっ♪　おにーさんの精子でイキたいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あはぁあっ♪　ありがとぉっ……♪　おにーさん！　出てる、出てるよぉっ \n……！　ドクドクっ、ドクドクって……んああああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304301" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「やっ……やぁあんっ♪　おしっこも母乳も全部一度にあふれ、ちゃったぁあ \nあ……っ♪　あひっ♪　ひぃっ、うううっ！　イクっ、イッくぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304302" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_21" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「しゅごいぃいっ♪　あたしの中にっ……射精二回分の精液っ、入ってきて… \n…！　かわりにお外にミルクとおしっこがびしゃびしゃ出てってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304303" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ホテルのベッドっ……もうびっちゃびちゃだよぉお……！　アーちゃんとお \nにーさんのえっちなお汁でばっちゃばちゃになって……。んぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ひゅ、ひゅごいぃいっ♪　まだ出てるぅっ！　おにーさんの精子まだっ…… \n！　な、なんで連続でそんなに出せるの、すごすぎるからぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっあっあっ……♪　い、イイよ……！　全部出しちゃっていいよっ！　ア \nーちゃんはおにーさんの精液、ぜんぶぜんぶ受け止めちゃうんだからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_21" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……はーっ……♪　はーっ、はーっ……。な、なんかぁあ……もぉ、しゅご \nすぎてぇ、えっちな夢……見てたみたいな気分になったかもぉお……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304307" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「わからせ、とかって……あたしは絶対大丈夫、負けるわけない～って思って \nても……やっぱ負けちゃうんだね……。悔しいっておもうけど～、でも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304308" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……正直ハマっちゃいそう……。う、うん……。もちろん、相手はおにーさ \nん限定だけど……たまーに、こういう風にガンガン攻められて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304309" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あたしがおにーさんのモノなんだ～って理解させられるのって、イイよね… \n…♪　ふぁああ……、最高のクリスマスだったぁ、ありがとぉ～……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304310" ]},
		{"command":[ "WAITINPUT" ]},
