		{"command":[ "SETIMAGE", "0", "still_00019603_02_22" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「身体っ……に！　精液かけてくるじゃんっ……！　あっ！　あっ、でも、で \nもぉ……！　むせ返るよーないやらしい臭い……！　ダメ、イクっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ひぃいいいいんっ♪　おしっことおっぱいミルクっ、母乳出ちゃったっ…… \n！　あっ！　あっ、止められない！　イクと出ちゃうんだぁあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_25" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ、あうぅうっ！　んぁうううう～っ……！　さっき中にっ……オマンコ \nの一番奥に出してもらったアツアツの精液、それに外出しの精液っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あたしの身体にびゅっびゅっびゅって何度も何度もしつっこく降りかかって \nくるこの精液で……もう、部屋もアーちゃんも汁まみれなんですけどぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304405" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_26" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「大好きな可愛いアーちゃんをっ……あっ♪　自分の色に染めたいんだぁ？　 \nだったらいいよっ……真っ白く染めて！　もっとちょうだい！　もっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ふぁああああ……♪　出すの２回目で、こんな量……。オマンコに放出され \nてたら、お腹ぽっこり膨らんじゃってたかも……♪　はぁ、はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304407" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_23" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんって、えっちはほんっと天才的だよね～……？　オチンポすごい \nし、すぐに精液溜まるしぃ……。あたしも頑張ってるんだけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304408" ]},
		{"command":[ "SETIMAGE", "0", "still_00019603_02_24" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「どーっしても勝てないんだよねぇ……。はぁ、はぁ、まーた今日も泣かされ \nちゃったぁ……。クリスマスにお仕置きされるとかー……ううう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0304409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……あ。もしかして？　おにーさんは、サンタさんとは逆にぃ、ワルい子に \nえっちなプレゼントをくれるヒトなのかも。来年も楽しみにしてるねぇ♪」", "NORMAL" ]},
