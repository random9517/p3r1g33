		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あああああっ♪　イクイクっ、イクぅうっ……！　って、うそぉおおっ！？ \n　お、おにーさんっ、オマンコに出してってちゃんとおねだりしたのにぃ！」", "NORMAL" ]},
