		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「……ご、ご主人さま……今……時間、大丈夫だよな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004101" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「な、何だよ、この格好の時はそういう風に呼べって、お前が言ったんだろ？\n　だから、ご主人さまだ……何もおかしいことはないぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「えと……それで、その……何が言いたいかって言うと、つまり、だからその\n……こ、こういうことっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、はぁっ……んっふ……ご主人さまのせいだぞ……私に色々…\n…仕込むから……はぁっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004104" ]},
		{"command":[ "SETCHARA", "0", "char_00000410_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「夜になって……もう、我慢できなくなって……んっ、だから……その、はぁ\nっ、んっ……何とかして欲しくて……来ちゃったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ほら……も、もうここぉ……オマンコ……ぐしょぐしょになっちゃってる…\n…チンチンが欲しくて、溢れてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ここのとこ……ずっと、私にやらしいことばっかするからぁ……今日はもう\n……こっちから来るしかないって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……あぁ……おねだり……んっ、ちゃんとしたら……入れていい\nのか……？　うん、するっ……メイドらしくっ、するからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あの……ご主人さまぁ……お願いしますぅ……いやらしく発情した……メイ\nドセレインのオマンコに……ご主人さまのチンチンを入れて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004109" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000410_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ずっとチンチンが欲しくて、ムズムズしてたオマンコ……もう、こんなに濡\nれてるんです……ほ、ほらぁ……んっ、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「入り口のところ……ちょっと擦るだけでクチュっていうの……分かるでしょ\n……？　チンチンが欲しいんです……ご主人さまのチンチン早くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぁっ、ありがとうございますっ。自分で入れて、いいんですねっ？　んっ\n、それじゃ……入れちゃいます……はっ、んんぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぁっ……あっ、はぁぁぁっ、入って来たぁぁっ……！　あっ、あぁっ、熱\nくてカタいのっ、ずぶって……来たぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ……そうっ、これぇっ、これが欲しかったんだぁ……じゃないっ\n、欲しかったんですぅっ……あぁっ、チンチンがいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はぁ……んくぅっ……入れただけでぇ……もう、ちょっとイキそうになっち\nゃってます……あ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んくぅ……でも、自分ばっかり感じてないで……ちゃんと、ご主人さまにも\n気持ちよくなってもらわないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「待って……んっ、深く……チンチン……あっ、ハメてくぅ……んっ、はぁぁ\nぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あふぁ……届いてる……んっ、チンチンの先っぽが……オマンコの一番奥…\n…子宮の入り口のトコ……当たってますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ここから、んっ、腰をゆっくり回してぇ……はっ、んっ、あふっ、あぁっ…\n…チンチンとオマンコ……擦れ合わせますぅ……はっ、ふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、あふっ、んふぅっ……あぁ、この深くめり込んでる感じぃ……すごく\n……いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「もっと……激しく動いていい……？　ふふっ、ご主人さまもその気になって\nくれたんですね……それじゃ、もう少し強く……んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はっ、あっ、あぁんっ、はっ、んふっ……あぁ……すごく硬い……ご主人さ\nまのチンチン……んっ、ふぁ……んくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「多分、いつもしてる時よりもっと……興奮してる感じ……んっ、はっ、んふ\nっ……あっ、んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「じっとおっぱい見てるし……そんなに揺れるの見るの、好きなんだ……んっ\n、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「いいよ……ご主人さまなら……見てもいいから……もっと激しくぷるんって\nさせちゃう……はっ、あっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「リズム……よくっ……からだっ、揺らしてっ……はんっ、あんっ、あはんっ\n……チンチンっ、オマンコで扱いていくのっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、はぁんっ、あぁっ、やらしい汁がっ……どんどん……オマンコ\nから溢れてっ、あぁっ……いっぱい滑るのっ、あ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はぁっ、んぁっ、ご主人さまっ……こんな感じで……いいですか。私は……\nんっ、すごく……気持ちいいけどっ……ご主人さまはっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっ、んくっ、オマンコ……ぐりぐりってするの……いいっ？　あぁっ、は\nぁんっ……うんっ、よかった……ちゃんといいんだ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「もっともっと、激しくするからっ、あっ、オマンコッ……もっと感じてっ、\nはっ、んぁっ、あはぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「くぅぅっ……んっ、はぁぁぁっ、オマンコ気持ちいいっ、子宮に……ズンズ\nンっ、先っぽ当たってぇっ……赤ちゃんの部屋っ、感じすぎてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「これっ、あぁっ、もう我慢出来ないっ、はひっ、イ、イッちゃうっ！　オマ\nンコッ、もうイッちゃうからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はっ、あぁんっ！　あぁっ、はいっ、見てっ……私がっ……ご主人さまのチ\nンチンでイクとこぉっ、よくっ見てぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「イクッ、はひぁっ、オマンコ良すぎてイクのっ、んぁぁぁっ、も、もうっ、\nイクぅぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んくぅぅぅぅっ！　あぁっ……はぁぁっ、先にイッちゃいました……あっ、\nあぁっ、ご主人さまもっ……後少しっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はいっ、このまま……出してっ、中に……子宮に下さいっ……熱くて濃いの\nっ……いっぱい中に流し込んでぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ！　あぁっ……来てるっ……ドロっと濃いの……んんっ、オマ\nンコいっぱいにされてるぅぅ……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぁぁ……また、私イクっ……どぷどぷ中出しされてっ……はぁぁっ、続け\nて……オマンコ……イッてるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んくっ……はぁぁぁ……あっ、ふっ……いっぱい出てくれた……あぁ……オ\nマンコ気持ちいい……あふぁ……んっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004139" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ご主人さまぁ……気持ちよくしてくれて……ありがとうございましたぁ……\nんっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっ……でも、まだ中でチンチン……大きいままで……すごく硬い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ご主人さまぁ……このまま……続きしてもいいよな？　じゃなくて……よろ\nしいですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「さっきより、もっともっと……オマンコ……気持ちよくしますからぁ……ほ\nら、こうしてぇ……んっ、んくっ、揺すってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ひゃふっ……！　んっ、ありがとうございますっ……じゃあ……また、腰っ\n……はんっ、いっぱい振りますっ、あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はふっ、さっきの精液で……中……ぐちゃぐちゃになってるっ……んくぅぅ\nっ、あぁっ、前よりもっと気持ちいいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、こことかぁ……あっ、一度擦れて……くふぅっ……すごく……感じや\nすくなってるとこ……あっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あっ……チンチンも、ぐりぐりって……動いて……オマンコ広げられてるっ\n……あ、くぅぅっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「今の……もっとして欲しい……あっ、あぁっ、そうっ、それぇっ、はぁんっ\n、ご主人さまのチンチンっ……すごくいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「何度も、何度も……硬いのがっ……奥をコンコンしてぇっ……腰の力……抜\nけちゃいそうっ……！　んっ、くぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……私も……ちゃんと……ご主人さまのチンチン気持ち\nよくさせてあげないとぉ……んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「もっと……腰を回してっ……おっぱいもっ……ぷるんぷるんってっ……揺ら\nしてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あんっ……おっぱいっ……触りたい？　んっ……もう……今日は特別なんで\nすから……あっ、ふっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぁぁ……先っぽもすごく敏感になってるぅっ……乳首……指でくりくり転\nがされるだけで……からだ全体が……ビクってするぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、はっ、あぁっ……お汁も……止まらない……精液と、私のいやらしい\n汁がぐちゅって混じってぇ……オマンコから垂れて来ちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……んんっ、はいっ、気にしないで……腰……振りますぅっ……\nオマンコの中っ……かき混ぜてもらうようにっ、動きますぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あんっ、はっ、あっ、あぁっ……いいっ……チンチンが、一番気持ちいいと\nこっ……ずっと当たってるぅっ……そうっ、そ、そこぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はぁっ、あひぁっ、ずりゅって沈めて……ずぽって体重がかかるとこぉっ…\n…あぁっ、こんなの……我慢出来なくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、あぁっ……また、イキそっ……！　はぁんっ、オマンコっ…\n…全然我慢できなくなってるっ……あくぅっ、あっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ご主人さまもっ……同じっ？　はんっ、あぁっ、ズボズボっ……腰振りして\nっ……イキそうになってるっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うんっ、出してっ……下さいっ！　私もっ、一緒にイクからっ……ご主人さ\nまもっ……イッてっ……精液っ、出してぇぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んひぃぃぃぃぃっ！　あぁっ……出てるっ、中にっ……またオマンコいっぱ\nいにされてるぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んくぁぁ……お腹……熱い……はぁぁ……気持ちいいの……ずっと続いてぇ\n……からだ……とろけちゃう……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぁ……ドロドロがあふれて来る……全部……入り切らないです……せっか\nくご主人さまが出してくれてるのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……せめて……一生懸命オマンコ閉じて……んんっ……これ以\n上漏らさないようにしないと……んくぁ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あ……射精……終わった……？　うん……ちょっとだけ……収まった感じす\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はふ……ホント凄かったぁ……いつもと違うのが、こんなに新鮮だなんて思\nわなかったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「でも、メイドらしく出来たのかな……そこら辺は、最後までよく分かんない\nままだったけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「まぁ、ご主人さまが良かったんならそれでいいかな。私もすごく気持ちよか\nったし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「最初は動きにくいかと思ったけど、全然そんなことなかったし……バレンタ\nインが終わっても、時々ならこういうのしてもいいかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「という訳でぇ……その時はまた……気持ちよくしてくださいね、ご主人さま\nっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁんっ！　あっ……精液っ……飛んでっ……！　からだっ、ドロ\nドロにされてるぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はふぁぁっ……あぁっ、あったかいの……ぬるって……お腹……おっぱいに\nも……はぁぁ……掛かってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「んっ、ご主人さまのにおいづけぇ……頭……くらくらするぅ……はぁぁ……\nからだ……ビクビクってイッてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はふぅ……んっ……あぁ……オマンコの周りも……熱い……からだ全体……\n精液まみれになっちゃってるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……お、終わった……？　んっ、えっと……お疲れさまでした\n……ご主人さま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000410_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「うん、すごかった……最初から最後までずーっと気持ちいいままだった……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あぁー、ちょっと染みができちゃってる。クリーニングしないと、怒られち\nゃうな、これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「あ……別にご主人さまは悪くないぞ。メイドの格好で興奮したからこうなっ\nたんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_1004408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレイン" ]},
		{"command":[ "SETTEXT", "「バレンタインの特別な格好って……やっぱりいつもと違うね。こういうのな\nら、またしてもいいかも……んふふっ」", "NORMAL" ]},
