{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「正義を執行する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570001" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フランカが悪者とデビルトンファーに銃を向け、手をかけようとした瞬間……", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「見つけたぜ、フランカあああああぁーーーーーっ！！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570001" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "悪者" ]},
		{"command":[ "SETTEXT", "「うげーーーーーーーっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "眼帯を付けた女が現れ、ものすごい勢いで悪者に飛び蹴りをかまし、吹っ飛ば\nしていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "変な声と共に吹っ飛ぶ悪者と、救出されるデビルトンファー。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はああぁ……た、助かったぁ……！　誰か知らねぇけど、ありがとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570001" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「って、ライオットじゃん！？　なんでここにオマエが居るんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570002" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「そんなの決まってんだろ。フランカから、いい返事をもらうためだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570002" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "悪者を吹っ飛ばした女の名はライオット。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "私設組織『Ｆ．Ｉ．Ｒ．Ｅ．Ｓ（ファイアーズ）』を率いており、戦闘のプロ\nフェッショナルだ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「また貴方か……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570002" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「おいおい。そんなつれねぇこと言うなよ。アタシとお前の仲だろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570003" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私と貴方の仲がどういうものか知らないが、デビルトンファーを助けてくれ\nたことは感謝している。ありがとう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570003" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「礼なら、その身体で払ってくれて構わねぇぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570004" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「な、なに言ってんだ、このヤロー！　姉御はアタシのモンだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570003" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はっ！　いつまでも金魚のフンみてぇに引っ付いて、フランカの足引っ張っ\nてる分際で、なーにが姉御はアタシのモンだー、だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570005" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「はーーー！？　アタシが姉御の足を引っ張ったことなんか、これっぽっちも\nねぇし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570004" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ついさっきまでピンチになってたヤツがほざいても、説得力がねぇんだよ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570006" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「なんだとぉ！？　やるかぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570005" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「いいぜ！　かかって来いよっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570007" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「落ち着け、二人とも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570004" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「別に私はデビルトンファーのモノではないし、ライオットに身体でなにかを\n払うことなどしない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「それに、デビルトンファーが私の足を引っ張ったことなど一度もない。だか\nら安心しろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「あ、姉御ぉ……！　マジかっけぇよぉ……！　一生ついてくよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570006" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「へへっ。相変わらず冗談の通じねぇヤツだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570008" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「まあいいや。それで？　この前アタシが言った、プロポーズの返事はどうだ\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「プロポーズ？　なんのことだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570007" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「とぼけんなよ。アタシの組織、Ｆ．Ｉ．Ｒ．Ｅ．Ｓ（ファイアーズ）に入っ\nてもらうって話だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570010" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「ああ、そのことか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570008" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私の実力を買ってくれるのは嬉しいが、貴方の組織には入らないし、興味も\nない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私は私のやりたいようにやる。それだけだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ふん。予想してた通りの返事だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570011" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「やーい、やーい！　フラれてやんのー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570007" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「うっせぇぞ、三下ぁ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570012" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「誰が三下だ！　アタシには、デビルトンファーってヒーローネームがあるん\nだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570008" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「なにがデビルトンファーだ！　ヒーローなら、本名を名乗りやがれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570013" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「だから落ち着けと言っているだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570011" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "顔を見れば、些細なことで喧嘩をするライオットとデビルトンファー。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そしてそれをなだめるフランカ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "これがこの三人のいつもの光景だ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「っていうか、前から気になってたんだけど……どうして姉御は、どこの組織\nにも所属しないんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570009" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「私はただ、世の中にはびこる悪を倒すため、断罪するために、正義を執行し\nている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570012" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「己の信じる正義を貫き通すのに、組織なんてものは必要ないだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「その考えはすげーし、いいと思う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570010" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「けど、アタシも姉御も、どっかの組織に所属した方がより多くの悪を裁ける\nんじゃね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「どんな悪事を働いてるのかーみたいな情報とかも、入りやすくなるだろうし\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「組織に所属しなくても、悪を裁くことは出来る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570014" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「それにどこかに所属すれば、大なり小なりしがらみが出る。そうなると、色\n々と動きにくくなるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「なるほど……そういうことか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570013" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「これはあくまでも私の考えだ。だからこの考えを、デビルトンファーに押し\n付ける気はない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570016" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「貴方がどこかの組織に所属したいというのなら、止めはしない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570017" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「それこそ、ライオットの仲間になったって構わないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570018" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はっ！　なに言ってやがる。こんなヤツ、頼まれたって仲間に入れてやんね\nぇよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570014" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「まあ、フランカのオマケとして入るなら、考えてやらなくもないけどな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570015" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「なんだとぉー！？　っていうか、オマエの組織なんてこっちからお断りだっ\n！　なっ、姉御！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570014" ]},
		{"command":[ "SETCHARA", "0", "char_00020601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「どうして私に同意を求めるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570019" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そもそも、ライオットには断りを入れただろう。なにを言われても、組織に\n入るつもりはない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570020" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「そうかい。なにを言ってもダメってことか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570016" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「そういうことだ。悪いが、他をあたってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570021" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「言葉がダメってんなら……力ずくで仲間になってもらうぜ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570017" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ライオットは言葉と同時に、手にしていた銃を撃ってくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "フランカとデビルトンファーは咄嗟に反応し、なんとか銃撃を避けていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「勝負だ、フランカ！　これでアタシがお前に勝ったら、仲間になってもらう\nぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570018" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「どうしてそういう話になるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570022" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「どうもこうもねぇ！　口で言って通じねぇなら、実力でわからせる！　これ\nが一番手っ取り早いだろ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_010021570019" ]},
		{"command":[ "SETCHARA", "0", "char_00016101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フランカ" ]},
		{"command":[ "SETTEXT", "「悪でない者と戦うのは気が引けるが、己を身を守るためだ。少しだけ痛い思\nいをしてもらおう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_160_010021570024" ]},
		{"command":[ "SETCHARA", "0", "char_00016001_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "デビルトンファー" ]},
		{"command":[ "SETTEXT", "「オーケー！　アタシのトンファー術、あのクソ野郎にたっぷりと味わわせて\nやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_206_010021570016" ]},
