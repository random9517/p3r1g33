{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0043" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふぅっ……♪　籠絡完了しちゃいました。これでお仕事は終わりましたから\n……。ここからは、プライベートゾーンですね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504101" ]},
		{"command":[ "SETCHARA", "0", "char_00018205_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「どうですか？　わたしと延長戦……していきませんか？　こちらはもう、と\nっくにその気で……うさちゃんしっぽをフリフリしちゃいます♪　ふりふり」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504102" ]},
		{"command":[ "SETCHARA", "0", "char_00018205_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……え？　この尻尾の構造はどうなっているのかって？　そういうところが\n気になっちゃうところ、男の人～ってカンジでいいですね。これは～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504103" ]},
		{"command":[ "SETCHARA", "0", "char_00018205_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「じゃぁん♪　お尻の穴に入っているんです。ぐーってお腹に力をこめて、お\n尻に留めているんですけど……って、わっ♪　引っ張って抜くんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504104" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ん、ぁ……♪　やぁだ、恥ずかしい♪　ちゅぽんって抜かれちゃいました～\n♪　あっ♪　あんまり見ないでください、今日は朝から入れてましたから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504105" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「お尻の穴がぽっかり広がっちゃって……。あんっ。ぜ、全然戻らないです。\n……って、めちゃくちゃ見てきますね？　もしかしてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「お尻の穴に興味があるんですか？　わたしのアナルで……エッチしてみたか\nったり？　あんっ。そんなに顔を近づけないでください。い、息が♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504107" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「息がかかって……ムズムズしちゃいますぅ♪　でも、そうですか……わたし\nのお尻がご希望ですか♪　どうしよっかな～？　なぁんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504108" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「いいですよ♪　せっかくのプライベートエッチですから、お仕事ではしない\n特別な♪　過激でアブノーマルなエッチ、しちゃいましょう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504109" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はい♪　それじゃあオチンポを～。わたしのお尻の穴にあてがって……。…\n…んっ♪　そ、そうです、そこです……♪　あっ、入ってくるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁっ♪　あぁあああああぁんんっ……♪　あっついオチンポがっ♪　ずぷ\nぅううっ、ずぽ～ってお尻の奥まで突き刺さってますぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504111" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっ……♪　んふふふっ♪　だ、だいじょうぶです。わたしは平気です……\n、しっぽで拡張してましたから。でも、こんなに太いオチンポ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504112" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「お尻の中に入っていると、圧迫感がすごいですねぇっ……♪　あっ、ぁっ、\nあっ……♪　ほら、呼吸するだけで……異物感がすっごいです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「オチンポの形ぴったりにすぼまったアナル……。はぁ、はぁ、わたしのアナ\nルの具合はどうです？　オマンコ以上に締めつけてくるでしょうっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504114" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「括約筋でぎゅっ♪　ぎゅっぎゅってオチンポをがっちり捕まえちゃってます\nからね～♪　……あ、お気に召しましたか♪　良かったぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「こっちの穴は、普段使わない穴ですから、少しだけ……んんっ、不安だった\nんです。はい、そうですよ？　夫ともしないです。アナルセックスなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504116" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「いやらしい淫乱奥さんだと思われちゃいますから……♪　でも♪　あなたに\nなら……そう思われたいです。エロエロで淫らな人妻だって……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、お尻を揺らしたら、オチンポがめちゃくちゃ反応してます♪　そ\nうですか、好きですか～。お尻。じゃあ、どんどん攻めてください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……んふっ♪　んんんっ♪　はぁっ♪　ンンッ……んんんんっ……！　あっ\n♪　う、動くともっとすごい！　このオチンポすごすぎですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504119" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「わたしのお尻の奥までずぶぅうっ！　ズンッ！　って入ったかと思うと……\n。ふぁあああっ！？　あッぁっあっ♪　引き抜く時にはぬるううって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ヌル～～～っていやらしい動きで出ていって……。はぁううっ♪　ま、また\n強引に入ってくる、ねじこまれるぅううっ。素敵ですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504121" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はいっ♪　もっと、もっとしてくださいぃっ……！　ああぁあああっ♪　ん\nんんぉっ♪　おッ♪　しゅ、しゅごいぃいっ、お尻の穴熱いぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504122" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ずっぼずぼえぐられてっ……！　あ～～～っ♪　お尻の穴、トロトロになっ\nてきちゃいましたっ……！　あっ、このオチンポおっきすぎますっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「こんなので肛門っ……！　攻められたらわたしアヘアヘになっちゃってっ…\n…！　あぅんんっ♪　お尻がオマンコに変わってくぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　わたしのオケツマンコ♪　ケツマンコが、このオチンポが\n最高だって言ってますっ！　あっ♪　拡がるぅっ、拡がっちゃうぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504125" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「お尻の粘膜♪　めくれちゃうっ……！　あっあっ、……んぉおっ！？　い、\n今の突き方すごく気持ちよかった、です……！　んっ♪　おっぉっおっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504126" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ヤ、ヤバイぃいい……！　プライベートアナルセックス、よすぎて腰が抜け\nそうですぅううっ！　ヤバイ、ヤバいぃいっ！　ひぃんんっ♪　んっんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504127" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「腰が自然に浮いてっ……！　あっあっ、勝手にお尻が動いちゃいます！　ア\nナルが開いたり閉じたりぃ……！　あっぁっ自分でも制御できないぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「おぉおおっ♪　ひゅ、ひゅごいぃいっ！　頭の中真っピンクに染まってきま\nした……！　お尻っ、アナル、ずこずこ犯されて感じちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んおぉおっ♪　おおおぉっ♪　おほっ……♪　あぁんんっ、お尻を突き上げ\nられると下品な声が漏れちゃう……ごめんなさいぃっ♪　ほぉっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んんんぉっ！　だ、だめぇ……っ♪　足がガクガク震えて……あっぁっ、し\nっかりお尻を上げていられないですぅっ、あっ♪　あっぁっうぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「オチンポでっ、さ、支えてくださいぃ……！　はぁううっ！？　そこっ、そ\nこ、もっとこすってください！　あっ！　あっ、だめっ、イイっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504132" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「お願いです！　わたしのケツマンコの中に、ドパドパって濃い精子！　真っ\n白な精液を流しこんでください！　お尻の快楽を教えてくださいぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504133" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ケツマンコにたっぷり種付け希望ですぅうっ♪　……おっ♪　おぉおおっ♪\n　イグっ……！？　お尻の穴をほじられてはしたなく絶頂します！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504134" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んひぃいっ！　ひぃいっ！　おっ♪　おおぉおっ♪　んぉおっ、イグッ……\nイグぅうっ！　精子、精子をケツマンコに注入お願いしますううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んっぐぅううううううっ♪　ぐぅううっ♪　んぉおおおおっ……♪　で、出\nてますぅうっ！　わたしのケツマンコにドロドロの精液がぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504136" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あああああっ！　こんなのイクに決まってます、熱いぃいっ……！　粘膜が\n焼けちゃうぅううっ！　あひっ♪　はひぃいっ♪　私の恥ずかしい穴っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「お尻の穴にあなたの大事な精子がびゅっびゅって……！　入ってきて……！\n　んぁああああっ♪　トんじゃうっ、意識が飛ぶほど気持ちいぃいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁっ、あああああっ……！　だめです、まだ抜いちゃだめぇええっ……♪\n　絶対に逃がしません、ぎゅうううってお尻を締めつけてぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ああああんっ♪　精液、あるだけ絞りとらせていただきますね～っ♪　はぁ\nああっ♪　あふぅうっ♪　んひぃっ、ま、まだ出てるぅ……すごい量！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504140" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「っあああああ……♪　オチンポで栓をしていてもらわ、ないと……。お尻の\n中にたっぷたぷに溜まった精液が逆流して溢れ出しそうです……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「もう少しこのままでいてもらえますか？　はぁっ、はぁ……♪　オマンコで\nするセックスももちろん大好きですけど……お尻ってすごいんですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504202" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「本当はこっちの穴はエッチする穴じゃないのに、って考えるだけで……そこ\nで気持ち良くなっている自分に、背徳感を感じて燃えあがって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「オマンコもケツマンコも、どっちでも絶頂しちゃう自分のいやらしさにうっ\nとりしちゃいました……。はぁああ……。なかなか余韻が抜けません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504204" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……んっ？　ど、どうしたんですか？　わたしの兎のしっぽを……あっ！？\n　ま、またもう一度、お尻の穴に戻すんですか！？　……やっ、やぁんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504205" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「た、確かにこれなら精子が漏れることもありませんけど……！　あっ♪　あ\nんまりぐりぐりするのはだめですよ、あっ♪　まだ敏感なので……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504206" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「きょ、今日はこれでプライベートエッチは終わり……ということですか？　\n……って、はっは～ん？　わかりましたよ、あなたのたくらみ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そうですかそうですか♪　お尻でたっぷり射精した後は、オマンコでもズコ\nパコハメて気持ち良くなりたくなっちゃったんですね？　贅沢ですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504208" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……でも、その考え。わたしも賛成です♪　お尻の穴に精子が溜まったこの\n状態で……オマンコにも射精してもらえるなんて最高じゃないですか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「というわけで……ぜひぜひ、オマンコにもオチンポを入れてください♪　あ\nはは、前戯なんていりませんよ。もうさっきからずっと濡れてて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ♪　んぁあああっ！？　す、すっごい急に挿入してくるじゃないですか\nぁああっ♪　ふ、不意打ちで軽くイっちゃいましたよ、もぉおっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504211" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_13" ]},		
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁっ、ああああっ♪　そうですかっ、オマンコは最初からっ……あっ♪　\n全力種付けモードで高速ピストンキメちゃうんですねっ、あっ、いいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　射精したばっかりなのにガチガチの勃起美味しいぃいいっ♪　\nあんっ♪　あんっ、女の喜び丸ごと独り占めですっ、あっあっあんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504213" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「前も後ろもぉおっ♪　太くて逞しいオチンポで突かれて、掻き回されてぇっ\n……！　あぁあんっ、下半身がぜーんぶおかしくなっちゃうっ、あぅんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「こ、これ、すごいですよ！　アナルの精液で……お尻が圧迫されていて♪　\nオマンコはオチンポに圧力かけられてっ……本当に気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504215" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「まるであなたにっ、両方の穴を犯してもらえているみたいでっ……♪　んぁ\nああっ！　こんなの、こんなの初めて……！　人妻なのにぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「夫ともしたことないプレイしちゃってるっ♪　仕事でもなく、ただしたいか\nらっ！　アナルもオマンコも差し出して、自由に使われてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「でもそれがたまらなくイイっ……！　あっ♪　あっ、わかりますかっ？　わ\nたしのオマンコ、さっきからずーっと痙攣してる、うねってるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504218" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あなたのオチンポに媚びて、オチンポ締めつけておねだりしてるっ！　っあ\nああっ！　もっと、もっと精液欲しいです！　中出ししてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「オマンコにも新鮮な精子ください！　なんでもしますっ、なんでもしますか\nら……！　あっ！　あっ、精液出して、出して、注入してぇええっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504220" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はぁああああああぁっ♪　んはぁあああっ♪　あうっ♪　うぅっ♪　んぁあ\nあああっ♪　出てる、出てるっ、前の穴にも！　オマンコにも出てるぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504301" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ……！　射精しながらさらに奥にねじこむの、だ、だめです、感じ過ぎ\nて……！　あぅうっ！　イクッ……！　イクっ、イッくぅううううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁああああっ♪　わかりましたぁっ、わたしの穴はどっちもっ！　ケツマ\nンコもオマンコも、あなたのものです、あなた色に染まりましたっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504303" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ、あぁああっ♪　夫には内緒にしてください、わたしがこんなに乱れなが\nらイッていることっ……！　あっ！　いけないことなのにまたイクッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「イクっ……！　イクぅっ、止められないぃいいっ！　どぴゅっ、どぴゅって\n精液注入されて、オマンコでもイッてますっ！　イクっ、イクぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504305" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ……♪　あなたの精子を、全部わたしのものにしますっ……！　んぅっ\n♪　ほぉらっ……オマンコで絞り上げますよ、あっ……あっ、あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504306" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_15" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「ん、ふ……♪　今夜もつまらないお仕事か～って思ってましたけど……。あ\nなたがターゲットだったおかげで、うんと楽しめちゃいました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あ～あ……。毎日あなたがターゲットだったらいいのに……。でも、そうな\nったら、逆にわたしが籠絡されちゃう日が来るのかも……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「そしたら、クビになっちゃいますよね。もしクビになったら……そうですね\n。あなた専用のエッチな人妻にでもなっちゃいましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504309" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「それはそれで、毎日気持ち良くなれてイイかも……♪　その時は、なにとぞ\nよろしくお願いしますね♪　な～んちゃって。ふふふふっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あっ♪　出た……！　って、きゃぁっ……！？　あっ……！　オマンコじゃ\nなくて身体にかけたかったんですかっ？　エッチですねっ……あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504401" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_19" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　す、すごい勢いでびゅるっ、びゅるるって……っ♪　わたし\nのお尻に、オマンコに、足に……あっ♪　こんなにいいんですかっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あなたの精液でヌルヌルにされて……っ、精液の臭いに包まれて……♪　あ\nぁっ、こんなのっ、刺激的すぎてイッちゃいますぅううっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504403" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「んあっ♪　あぁっ♪　あああぁあっ……♪　さっき出したばっかりなのに、\nもうオチンポにこんなに精子を溜めちゃってたんですねっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「はい♪　好きなだけかけちゃってください……！　わたし、あなたに精液か\nけられるの大好きです♪　……あっ♪　あったかぁい……プルプルぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あはっ……♪　真っ白でいやらしい……♪　どこもかしこも、あなたの精液\nまみれで……。今夜のこと、一生忘れられなくなっちゃいました……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……はぁっ♪　はぁ、はぁ、はぁ……♪　ものすごくたくさん出してくれた\nんですね……♪　なんだか得をした気分です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504407" ]},
		{"command":[ "SETIMAGE", "0", "still_00018205_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「あなたって、本当に絶倫で、オチンポも一流で……。ターゲットがみーんな\nあなたみたいな人だったら、仕事も心から楽しめるのにって思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504408" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「……最後に中に出さずに、外に出して良かったのか、ですか？　ふふっ。そ\nんな日があってもいいですよ。だって、これからもわたしとあなた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ハルミ" ]},
		{"command":[ "SETTEXT", "「どこかで出会う気がするんです。その時に、ぜひともリベンジしちゃってく\nださい♪　楽しみにしてますね。これ、秘密の約束ですよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_182_0504410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
