{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "広大な宇宙の片隅に、浮かぶ一隻の巨大な艦（ふね）。", "NORMAL" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "インペリアル・スペース・フォース（皇国立宇宙軍）に所属する、セリカ・ミ\nヤシタの率いる旗艦ダイアンサスからは……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "今日も今日とて、間の抜けた声が響き渡っていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ええ～っ？　うまくいったと思ったんだけどな～！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520001" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……結果的に、でしょ。１つ間違えば、この艦（ふね）もろとも木っ端微塵\nだったと思うけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021520001" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "大規模な戦闘になればなるほど、強さを発揮する艦長、セリカ・ミヤシタとそ\nの女房役……副艦長のスイレン・アファナシエフ。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「艦長はいつも行き当たりばったりすぎるんですよ！　大事なことは何も説明\nしてくれませんし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520001" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「ま、それで結果オーライなんだから……。天が味方してくれてるってことじ\nゃないのぉ？　知らんけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021520001" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そして２人に従う女下士官……オペレーターのスミレ・サイオンジとリリア・\nユウキ、計４名がこの艦（ふね）の主なクルーである。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「リ、リリアちゃんは適当すぎっ！　ああもう……今まで、なんとかなってき\nたのが不思議です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520002" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「艦長はぽやぽやで、ノリと勢いばっかりですし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「えへへ～♪　それほどでも～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520002" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「まったく褒められてないからねぇ～……？　テヘペロしてる場合じゃないで\nすよ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021520002" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「副艦長……スイレンさんはムチムチで唯我独尊、マイペースすぎて思考が読\nめないですしぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520004" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「あはは♪　ムチムチは関係なくなくない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021520002" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "会話にちょくちょく参加しつつも、手元のモバイルフォンから視線をはずさな\nいリリア。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "やる気の見えない現代っ子に、スミレはわなわな震えるばかりだった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「みんなっ、真面目に働いてくださいよぉ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520005" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「真面目に……かぁ。でもぉ……私達が、外からなんて呼ばれてるか知ってる\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021520003" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「『巨乳艦隊ダイアンサス』……ふふふっ。確かに、全員胸は大きいけれど…\n…。もっと別のところを評価してほしいものね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021520004" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「お、お、おっぱ……おっぱい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520006" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "慌てて自分の胸を隠すスミレに、セリカは能天気な投げキッスを放った。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おっぱいも女の魅力のうちっ♪　悪い評価じゃないならいいじゃない。せっ\nかくだし♪　今日も今日とて！　太陽系の平和を守るためっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520003" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「おっぱいプルンプルンさせながら頑張っちゃいましょー！　いぇーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520004" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "えいやっ！　と拳を突き上げたセリカの胸部は、確かにプルンプルンと揺れま\nくっていた。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「も、もうやだぁ……。私、まだ初恋もしたことないのに！　大事な命をこの\n人達に委ねるなんてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520007" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「そうかな？　リリアはけっこー良い職場に配属されたと思ってるけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021520003" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「それって、勤務中にケータイいじってても怒られないから……じゃないです\nよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520008" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「うっ、バレた？　って、今ドキＳＮＳやってないサイオンジ先輩……。スミ\nレが時代遅れなだけだと思うけど？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021520004" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「オペレーターは忙しいんですっ！　それに！　情報漏洩は厳禁……ですよね\n！　職務中に電子機器を触るのは禁止です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520009" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「んんー……。前時代的ぃ……。ま、そこがスミレのいいとこなんだけどね…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021520005" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "しぶしぶモバイルの電源をオフにしたリリアは……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "後方、艦内で一番高い位置に仁王立ちしながら腕を組み、\nその上に胸を乗せているセリカのつまらなさそうな顔を見上げた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「で、何すればいいですか。……パトロールとか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021520006" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「パトロール……かぁー……。パトロール任務ってちょっと地味。ドッカンバ\nッタンの大抗争が、近くで起きてないかなあ？　バトルがいいのよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520005" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「そうやって、何にでも顔を突っ込むから、お騒がせ超バカ艦隊なんてウワサ\nされるんですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520010" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「だぁってー……ヒマなんだもん！　書類にハンコ押す仕事なんてつまんない\nし！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520006" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「宇宙だって！　なーんにもないのがただ広がってるだけじゃ……すぐに飽き\nちゃう！　そう思わない！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520007" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「艦長の才能は、戦闘に特化してるから～……通常任務はダメダメですもんね\nぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021520005" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「私なりには努力してるんだけどねー。うーん、うーん……ヒマだなぁ\n、どーしよっかなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520008" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「あ、そーだ！　皆でしりとりしよっか。４人もいるから暇つぶしになるかも\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520009" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「私は経路を監視しておかないといけませんので……パスです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520011" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリアも、ＳＮＳチェックで忙しいので……はい。パスで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021520007" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「えええええぇ～！？　じゃあさ、じゃあさ、恋バナは！？　恋バナだったら\nハズレないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520010" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「だって私達！　花も恥じらうお・と・し・ご・ろだもん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520011" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……そういう艦長にはぁ、あるんですか？　恋のお話」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021520006" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「そうですね。艦長がすっごい危険な恋バナしてくれるんだったら、皆で楽し\nく聞きますけどぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021520008" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ええーっ！？　えっえっえぇ！？　私！？　私の恋バナ！？　そ、そうだよ\nね、私から話すのが筋だよねっ……て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520012" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ない……です……。何もないです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520013" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「トホホホ……。もー！　皆のいじわるー！　艦長いじめだぁー！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "えーんえーん、と泣き真似をしているセリカが、全員にスルーされていじいじ\nしていると……。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ピコン、ピコン、とリリアのレーダーに小さな光が点滅しはじめる。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「……ん？　通信が入ってきてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021520009" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「これは……救難信号ですね。待ってください。すぐに位置を解読します」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520012" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「オーケーぇ。うんうん……スミレは真面目でいい子だなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021520010" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「艦長。そんなに遠い場所じゃありません。助けにむかうべき……でしょうか\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021520013" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「スイレンちゃぁん、どーするどーする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021520015" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「何者かの罠……という可能性は大ですが、放っておくわけにはいかないでし\nょうねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021520007" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
