{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ん～っ♪　この商店街……全然期待してなかったケド～♪　クレープすっご\nい美味しい♪　タピオカジュースもイケてるぅ～♪　くぅう～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00019602_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ねっ、ねっ、おにーさぁん？　どう？　嬉しい？　超絶美少女のアーちゃん\nと、場末の商店街でアツアツデートとか……って、んっ！？　どしたの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「急にあたしの後ろに回って……？　へっ！？　いやっ！？　何ッ！？　あっ\n……！？　やぁあっ……ろ、路地裏に連れ込んで……。んあああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00019602_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あッ……！？　あっあっあっ……！　コレっ……！　コレぇっ……！　さっ\nきおにーさんが、こそこそアダルトショップで買ってたアイテムぅ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なにっ……な、なぁによぉ……ッ！　せっかく久しぶりのラブイチャデート\nで盛り上がってた時に……あぅっ！　こんなエロいことはじめる、なんて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ね……ね～え……？　冗談、なんだよね？　でも……あっ！　乳首……イジ\nられちゃってるし、ロ、ローター……挿入されちゃって……。ん、ぁ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ア……アーちゃんのはずかしーとこ、全部丸見えじゃん……。こんなのって\nヒドいよぉ……。今日は１つも悪いコトしてないし、むしろっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「デ、デート……のつもりだったんだけどぉ？　おにーさんがどうしてもって\n言うなら、手つないだり、チューくらいしてあげてもって……。やぁんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あんっ！？　う、ウソぉっ！　なんで容赦なくチンポ……オチンポ、おまん\nこになすりつけてくるの！？　ぎゃあああっ、ヒトデナシ～っ！　やぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204109" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あぅっ！？　あふっ……あああっ……！　だ、めだからぁ……！　こんな、\n人の多い場所でオチンポ出して女の子襲うとか……ヤバいからっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ねっ？　で、デートしようよぉ……甘い、お子ちゃまみたいな可愛いデート\n……。あっ！　こ、こらっ……チンポ、おっきくするなぁヘンタイぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ……ぅ、ううっ……あぅうう……！　あたしのこと……こうやってゴーイ\nンに犯すつもりだったんだぁ……。ロ、ローター使うとか卑怯でしょおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あっ！？　ンっ……んっ、んっ。乳首……乳首弱いのぉ……！　やだぁ……\nあっ♪　あっぁっあっ……しかもローター、ブルブルしてヘンな、カンジっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「硬くなった先っちょ……胸のぽっちをねちっこくイジり回して……。あぁあ\n……っ、強制的に発情させられてるところに、こ、このチンポ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こんなガチガチの極太チンポ押し付けてくるとか極悪人じゃぁんん……！　\nあっ、ふっ、い……いれたいなら勝手に入れればいいの、に……！　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204115" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あてがうだけで……。んぁっ！　おまんこクニクニするだけで、ギリッギリ\nで挿入しないし……っ！　そのくせローターで中っ、膣内イジめるし……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ア……アーちゃんをどうしたいわけぇ……。あっぅっ、くふぅううっ……！\n　つ、つらいんですけどぉ！　生殺しで、寸止めで……あぁあああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……ええええっ……？　入れてほしければおねだりしろ？　うっ……そ、そ\nっか……そーゆーつもりで焦らしてんだ……意地悪意地悪ぅうう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ふ、ふふーん……こ、このまんまの状態だったらおにーさんだって辛いクセ\nに……♪　ほーら、アーちゃんのロリぷにマンコが濡れ濡れだよぉ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「今ずぶーって奥まで入れたら気持ち～のになぁ～？　……っぅ……。だ、ダ\nメだ……膝がガクガクしてき、た……ううう、負け……負けちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「い……入れない？　オチンチン……。この中、に……。アーちゃんのヌル\nヌルおまんこに……入れたければ入れればいーし……。っぅ、ち、違う」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「入れて……入れてよぉ……！　ねぇ、我慢できないぃ……！　そうなの！　\nホントはデートしてる時から期待してて！　濡らしてて、……っぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんのぶっといデカチン挿入して欲しかったの！　奥までえぐってほ\nしいし突き上げてほしいっ、お、お願いします、オチンチン……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんのオチンチン、そのテラテラしてる赤黒いオトナチンポをアーち\nゃんの穴にください！　お願いします！　お願いしますぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ふぁっ……！？　アッ……！？　あっ……！　オチンポっ……オチンポ入っ\nて……♪　んぁああああ、チンポ、チンポおまんこにずっぷって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204125" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「初めて……アーちゃん、オチンポ入れるの初めてなのにオモチャとオチンポ\nっ、いきなり一緒に入ってき、たぁあああ♪　ありえないぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あぅううっ！　気持ちいいっ、気持ちイイよぉ……！　ああああっ！　アー\nちゃん外なのに、路地裏なのに、さっきまで甘々デートしてたのにぃいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「チンポずぶぷって入れられちゃったらすぐわからされちゃうぅ……っ！　あ\nんっ！　あんっ、弱いぃ……！　アーちゃんまんこ弱すぎぃいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ……ぅ、あうううっ……んぅううう～～っ！　ちっちゃい穴の中……アー\nちゃんのミニミニおまんこがオトナちんぽでいっぱいになってる……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「それ、に……うううっ！　ローターのブルブルで常にアソコが刺激されて…\n…も、もぉ混乱しっぱなしだよ……上も下も超気持ちイイよぉお……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……あッ♪　あぅっ♪　んくぅうう……っ！　ふぅううっ……うぅううう…\n…！　息っ、上手くできないくらい奥までチンポ入ってる、しぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あふぁあああっ！　母乳っ、母乳溢れちゃった……！　挿入されただけであ\nたしっ……あたし絶頂しちゃって、母乳……噴いちゃったよぉお……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204132" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あううっ！　止めらんない、し……あっ！　どうしよっ、オマンコの奥ぅ…\n…！　一番ビンカンな子宮の近くでローター震えてて……あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ガンギマっちゃう……っ！　あっ！　子宮、アーちゃんの処女子宮開発され\nてく……！　おにーさんのオモチャとオチンポで……！　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んふぁあああああ♪　ちょっとぉおお♪　母乳がぶしゃぶしゃ噴き出して…\n…あっ、止まんない！　あっ！　ヤバい……ヤバすぎぃいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あうっ……！　あふっ、あっ……あっあっ！　……えっ？　オマンコキツく\n締めすぎ……って知るかぁあっ、そんなの！　アーちゃんやってない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204136" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「勝手に締め付けちゃってるの！　……えっ？　中で……ローターの振動が亀\n頭に当たってきもちいい？　そ、そんなの知らないし……あっ、や、やだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おちんぽ、おちんぽに負けちゃう……負けちゃう、ローターとオチンポのW\n攻撃でイッちゃう……！　っあああああっ……！　ふぁああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「はぁうううう♪　ちょっとぉおっ……！　イッてる時に精子、出さないで…\n…ぇ！　あっ！　処女喪失直後、すぐ中出し……あっ、うううぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204139" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こんなのっ……、お、おかひくなるっ、おかしくなっひゃうッ……♪　あふ\nっ……！？　ううっ、あっつい精子注がれてまたイ、クぅううう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あぁっふっ♪　ふぁあああ……！　ああああっ！　ドクッ、ドクッて……せ\nーし♪　せーし、せーしぃ……あったかい……重たぁいぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「コレ……っ、お尻に注がれるのと全然違ぁう……！　しちゃいけないことっ\nてカンジ……あっ！　背徳感と危機感すっごいよぉ……あぁ、ヤバいぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「っひゅぅうう……！　無限に精液流し込まれて……ローターも、アーちゃん\nのお腹の中も真っ白になって……。はぁうう、気絶しそー……あっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「お……おにーさん……おにーさぁん……！　わかったからぁ、アーちゃんが\n悪かったから、この強すぎるオチンポ一度抜いてぇ……じゃないとぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「トんじゃう……意識トんじゃって、し、失神しちゃうよぉ……。アーちゃん\nが悪いコでした……！　強いオチンポには女の子は絶対叶いませんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「だから……だから許してぇ……♪　って、ふぁううっ！　な、何動いてるの\nぉっ……！　あっ！　待って！　おまんこかき混ぜちゃだめっ、あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「精子これだけ出しといて即復活ぅ！？　その上……はぁんんっ♪　ロリ処女\nおまんこガン突きでえぐってくるとか、あうッ、ど、どうかしてるぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんんっ！　カラダっ……力入んないよ、もう好き勝手動かされ\nて、勝手に揺らされてぇ……！　オ、オナホにされてるみたい……ひぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃん……！　アーちゃん、デート中にお外で犯されて……母乳まで出\nしちゃって、そんで……そんで、ずっとオマンコ使われて……あぁああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204209" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「それで何度も軽くイッてる……！　こんなの、メスガキダークエルフオナホ\nじゃんかぁ……！　イチャイチャしたかったのにぃ、わからされちゃってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あううっ！　ううぅうっ！　イヤなのにおまんこ気持ちくて腰、揺れちゃう\nよぉ……！　あうっ、んんぅっ！　中で……中で精子が泳いでる、うぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「妊娠しちゃうかもしれないのに……それなのに、チンポ抜いてもらえなくて\n……そのままエッチされちゃって……こんな初体験ヤバいのにぃいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「女のコの悦びっ、わからされてる……！　あッ♪　あっあっ、ひゅごい……\nぃっ、しゅごい、オチンポ強い、かっこいい……好き、しゅきぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204213" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんなんでも言うこと聞きますっ、イイ子にしますぅ、だから……だ\nから、このカッコいいオチンポでいっぱい可愛がって……犯してよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あッ♪　あぁ、……あぁううっ♪　あうぅうっ……♪　アーちゃん……っ、\nは、初めてのヒトがおにーさんで良かったかもぉ……だってだってっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こんなっ、こんな気持ち良くて、イキっぱなしにさせられちゃうオチンポっ\nてことは……あぁんんっ、アーちゃんのおまんこと相性バツグンじゃんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「究極のカラダの相性ってこと、だから……あぁっ！　だから……、もう一生\nコレだけでいいっ、あたしっ、このオチンポだけで生きてくぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あーーっ♪　すっごいのっ、しゅっごいぃい……♪　どちゅどちゅ突かれる\nと、ローターねじこまれ、て♪　頭がおかしくなっちゃいそうだよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あ～～～っ♪　ああああ……！　おにーさん、おにーひゃぁんん……！　ア\nーちゃんをおにーさんのモノにして♪　孕ませて……妊娠させて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「せーし……せーしプレゼントしてくだひゃいぃ……♪　おまんこにっ、いっ\nぱい上手に締めるから……ちょうだい♪　絶対妊娠するからぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ふぁっ♪　ああああああッ♪　あ～っ、あぁああ……！　クるっ……精液あ\nがってきた、あぁっ……子宮に、子宮にかかってりゅぅうっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「アーちゃんの、アーちゃんの赤ちゃんを作るお部屋にせーしどっぴゅんどっ\nぴゅんかかってるぅうう……！　あぁっ♪　ハーフエルフ出来ちゃうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「っんぅううう……！　おにーさんの射精……しゅっごい長い……こんなにい\nっぱいぃ……♪　アーちゃんのおまんこが幸せで満たされてくぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あぅっ、あぅうう……！　ローター……ローターで子宮ほぐされてるしっ、\nザーメン掻き回されてるから……受精率高いよ、今っ、絶対受精してるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにー、さん……♪　おにーひゃんん……♪　そんなに精子出したら身体壊\nれちゃう、よぉ♪　どうしてそんなにオチンポ強いのぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「っはぁあああ……♪　あぁあああ……♪　ううぅ、信じらんないくらいイカ\nされて……注がれて……こんなアブナい初体験ありえないよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「でも、でも……まったくイヤじゃなくなってたし……。んっ、さ、最後の一\n滴まで欲しいから……今絞り取るね？　んッ……。ふぁっ♪　出た♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんのイキのいいエッチザーメン……♪　ちゃんとごちそーさましな\nいとだよね……♪　だけど……まだ、ずっと細かくイッてる、からさ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ローター外れてから……改めてお礼言う、ね……♪　ん……んんん……♪　\nもっとロマンチックなロストバージンが良かったけど……うんうん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「こーゆーのも……やっぱキライじゃない……♪　おにーさぁん、アーちゃん\nをヘンタイにしちゃった責任……とってもらっちゃうんだからねぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「んぁっ♪　ねえ来て♪　来てぇ……って、あッ！？　オチンポが抜けて……\nきゃうっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「あうっ！　お腹……おっぱいにかけるのっ……せーし……！　あたしの、ア\nーちゃんのおまんこのために作ったせーし……！　もったいなさすぎっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00019602_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「えっ……？　ぁっ……ここ……ここにかけるのが独占欲の証……なの？　ホ\nントにぃ……！？　二度目も中に出して欲しかったのにぃ……ぶぅ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……って、んんん……！　ローターが、下がってきて……ふぁっ♪　気を抜\nいたら落ちちゃいそう……。んっ、ブルブル。ブルブルって……やぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「も、もぉ！　こっちはオマンコがゾクゾクして大変なのにぃ！　気持ち良さ\nそーに身体中にぶっかけまくってくれちゃってぇ……！　ばかばかぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……出しすぎ、だし……っ♪　くぅううう……！　こんなにいっぱいせーし\n残ってるなら、ちょっとくらい中に入れてくれても良かったじゃんん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「なによぉ……。えっ？　アーちゃんの褐色の肌には精子の白がすごく似合う\n……？　あっ……そ、そういう？　なんだ、そっか。そっか……。でもぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「ピンクのおまんこに注ぐのだって絶対良かったと思うケドぉ……？　はぁっ\n、はぁ……。初体験が路地裏で、中出しからの全身ぶっかけとかさぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「おにーさんってば、アーちゃんで遊びすぎぃ♪　わかるけど♪　こんなダー\nクエルフ美少女がいつもそばにくっついてたらイタズラしたくなるよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_196_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アトロポス" ]},
		{"command":[ "SETTEXT", "「……んふふ♪　今度は、負けないから♪　勝つまでおにーさんから離れない\n～♪　そういうつもりでぇ、覚悟、キメててよね～？　ふふふふっ♪」", "NORMAL" ]},
