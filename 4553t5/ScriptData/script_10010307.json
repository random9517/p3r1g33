        {"command":[ "DISPCHARA", "0", "TRUE" ]},
        {"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まりあ殿のようなお嬢さんはご存じないかと思いますが、ここはいわゆる\n紳士の社交場（しゃこうば）、競艇場ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103070001" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「それは、看板を見ればわかりますが……ここにカツマさんがいるんですか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070002" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「間違いありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103070002" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「今度こそ、本当なんでしょうね？　ジュンジローさんの『間違いない』は、\n昨日からもう７か所目ですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070003" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「大丈夫大丈夫。今度こそ本当に間違いありませんぞ。考えてみたら、今日は\n本場開催日ですからな。ご主人は必ずここに――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103070003" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "WAITMOVE" ]},		
        {"command":[ "DISPIMAGE", "0", "FALSE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETTEXT", "………………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "…………", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETTEXT", "……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0108" ]},
        {"command":[ "DISPIMAGE", "0", "true" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_019" ]},
        {"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これは外れ……。ちっ、こっちもか……？　お、これは……おおおおっ！？\n　これは文字通り、拾いもんじゃね！？」", "NORMAL" ]},
        {"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「いた！　カツマ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070001" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん……何をやってるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070004" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これはですな、捨てられた舟券の中から、当たり券を探しておるのですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103070004" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「外れたから、捨てられてるんじゃないんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070005" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これが意外とそうでもない。当たった舟券をうっかり捨ててしまう慌て者は\n、決して少なくはないのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103070005" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうそう。いざとなったら、これでしばらく食いつなげるんじゃないかと思\nってたんだが、この分なら――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュンジロー！？　なんでてめぇがここに――って、カグヤとまりあまで！\n？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……！　よかった！　やっと見つけた！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070002" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「無事だったんですね……！　本当によかった……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070006" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おい！？　ちょっと待てって！　抱きつくな、こんなとこで！　いった\nん離れろ！　離れろって！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あ、ご、ごめん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070003" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「す、すみません。見つけるまで苦労したもので、つい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070007" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ったく……それで？　そんなに苦労して俺を探して、何の用だ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……カツマを、連れて戻る」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070004" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ＥＤＯ本部に戻りましょう。やっぱり、隊長がいないと部隊は成立しません\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070008" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「やっぱりその話か……悪いけどな、俺はもう、あんなところに戻る気はない\nぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そんな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070005" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おおかた、俺を探しに来たのはお前らだけの独断なんだろ？　他の連中は、\n俺に戻って欲しいなんて思っちゃいねえんだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そ、それは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070009" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「他の人には、聞いてない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070006" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあおそらく、ご主人がいなくなったことは我々以外誰も気にしておらんで\nしょうなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103070006" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ジュンジローさん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070010" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おっと失礼、持ち前の誠実さが、ついこんなところで出てしまいました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103070007" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ほら見ろ！　やっぱりじゃねえか！　誰も俺のことなんか気にしちゃいねえ\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070007" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「とにかく、俺は戻る気はねえぞ。俺はこれから、ここで立派な地見師（じみ\nし）として生きていくんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「じみし……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070008" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「今やってた、当たり券拾いのことですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070011" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「そんなので生活できるの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070009" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう。バカにしたもんでもねえぞ。俺はいままで、休日にこれやって薄給を\n補ってたんだからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そんなことを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070012" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「フルタイムの地見師には、この商売で家族５人を食わせてるベテランもいる\n……って噂もあるぐらいだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「家族……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070010" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ホントですかぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070013" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マジだって！　疑うんならお前らもやってみろよ。けっこういい稼ぎになる\nんだからよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やってみろって……カツマと一緒に？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070011" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おう。二人がかりでやれば、二人分の生活費ぐらいは充分稼げると思うけど\nな」", "NORMAL" ]},
        {"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "sbg_0043" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「生活費……！　カツマと……生活！　つ、つ、つまりそれは、カツマと二人\nで生きていくという……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070012" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ちょっと！？　カグヤ！？　あなた、何を考えて――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070014" ]},
		{"command":[ "WAITINPUT" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "SETIMAGE", "0", "bg_0108" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
        {"command":[ "PLAYBGM", "BGM_008" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「やる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070013" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
        {"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「ええええっ！？　カグヤ、待ちなさいって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070015" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……まりあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070014" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「な、なに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070016" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「ここまで、ありがとう。みんなによろしく。私、カツマと生きていく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070015" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「何言ってるのよぉ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070017" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「よし、それじゃあやり方を教えるからな。あの辺が穴場なんだ、あっちへ行\nこう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「……うん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "002_010103070016" ]},
        {"command":[ "SETCHARA", "0", "char_00000201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カグヤ、落ち着いて！　カツマさんも冷静に――ちょっと待って！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070018" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「行ってしまいましたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103070008" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「はぁ～……しょうがないわね。わたしも、しばらくお付き合いするしかなさ\nそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070019" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "1" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうやらそのようですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "009_010103070009" ]},
        {"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……はあ。面倒なことになっちゃったなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070020" ]},
        {"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "1" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「そういえば、今日もつきみに電話できてないけど……つきみ、大丈夫かしら\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "014_010103070021" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
        {"command":[ "WAITMOVE" ]},		
        {"command":[ "DISPIMAGE", "0", "FALSE" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
