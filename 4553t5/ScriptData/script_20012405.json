{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0022" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「ハルカさーん、サイレーンさーん、大丈夫っすかー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021860001" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「こちらに問題はないのである。サイレーンも怪我はないであるな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021860001" ]},
		{"command":[ "SETCHARA", "0", "char_00002004_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「おかげさまでね。まぁ、一番危なかった彼も、あの子が守ってくれたみたい\nだし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021860001" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「いや、ホント空気読めない上に、思いつきで行動するんで……ウチの神様が\nすみません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021860002" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「あ……え、えと……その、ご、ごめんなさい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021860001" ]},
		{"command":[ "SETCHARA", "0", "char_00008103_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「結果的には丸く収まったので大事ない。以後、気をつけるといい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021860002" ]},
		{"command":[ "SETCHARA", "0", "char_00002004_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「はぅ……ありがと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021860002" ]},
		{"command":[ "SETCHARA", "0", "char_00008103_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「時々君たちの関係が、よく分からなくなるね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021860002" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「とにかく、あんまり世話を焼かせないで下さい。ホント、ハルカさん達にも\nアヌビス様の面倒見て欲しい位っす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021860003" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「いやぁ……いくらボク達でも、さすがにちょっと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021860003" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「謹んで辞退するのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021860003" ]},
		{"command":[ "SETCHARA", "0", "char_00002004_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「うぅ……やっぱり不人気……冥界に戻る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021860003" ]},
		{"command":[ "SETCHARA", "0", "char_00008103_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「あー、もうそんな落ち込まないで下さいよー。あーしは、ちゃんとお供しま\nすから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021860004" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌビス" ]},
		{"command":[ "SETTEXT", "「うぅぅー、アーマーン……好き」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_010021860004" ]},
		{"command":[ "SETCHARA", "0", "char_00008103_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「はいはい、よしよし……って、向こうは向こうで何か話してますね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021860005" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ソウデシタカ……既ニ、王国ハ過去ノモノトナリ、私ガ仕エタ主モ既ニイナ\nイノデスネ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021860001" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「休眠状態の間に色々あったんだろう。だが、これだけ長い時間、休眠してた\nのに、全く問題なく動けたんだ。大した技術だと思うぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ゴ理解頂ケルコト……大変光栄ニ思イマス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021860002" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アーマーン" ]},
		{"command":[ "SETTEXT", "「隊長～、何だかすっかり仲良しさんっすね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_165_010021860006" ]},
		{"command":[ "SETCHARA", "0", "char_00016501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「仲良しって程でもないが……まぁ、色々事情があったのは聞いたぜ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「皆様ニモ、ゴ迷惑ヲオ掛ケシマシタ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021860003" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「今も任務を果たそうとする、その忠義やよし。しかし、今の我はお主の期待\nに応えることは出来ぬのだ。すまぬ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021860004" ]},
		{"command":[ "SETCHARA", "0", "char_00002004_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「恐レ多イオ言葉デス。シカシ、私ハ……コレカラドウスレバ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021860004" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……なぁ、行き場がなくて困ってるのか？　だったら、俺達の所に来るか？\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「……貴方達ノ元ヘ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021860005" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「古代の高等技術がどの程度のものかは分からないが、少なくともウチの組織\nの技術力も相当なモンだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「一概に比べることは出来ねぇが、少なくともお前の整備ぐらいなら何とかな\nるだろう。どうだ、ドクター？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「お任せあれ。ボク達に掛かれば、メンテナンスはバッチリ面倒見ることが出\n来るよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021860004" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まぁ、長官の許可はいるだろうが……あの人は大体ＯＫしてくれるだろ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「ソレハ……大変助カリマス……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021860006" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そのついでにっと言ったら何だけど、出来ればより詳しい内部調査までさせ\nてもらえると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021860005" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「……！　警戒レベル……上昇……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021860007" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、あー、それは、とりあえず待っといてくれ。するにしても、もうちょい\n段階的なステップを踏んでくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ふむ……仕方ないね。なら、ピラミドンに関しては君の預かりって感じにな\nりそうかな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021860006" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……いや、でも俺は特に整備の知識は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「でも、この子はなんとなくその気みたいだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010021860007" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「危険ナ目ニ遭ワセタニモ関ワラズノ深イ度量……貴方コソ、新タナマスター\nトシテ相応シイオ方デス……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021860008" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「い、いやいや、マスターなんてそんな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「コレカラ、私ト共ニ新タナ王国再建ヲ目指シテ行キマショウ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021860009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、壮大過ぎるから！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルカプトラ" ]},
		{"command":[ "SETTEXT", "「むぅ……あっさり主を切り替えられるとそれはそれで複雑であるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_010021860005" ]},
		{"command":[ "SETCHARA", "0", "char_00002004_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピラミドン" ]},
		{"command":[ "SETTEXT", "「マスター、何ナリトゴ命令下サイ。私ハ、マスターノ為ニオ尽クシシマス！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_218_010021860010" ]},
		{"command":[ "SETCHARA", "0", "char_00021802_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}