{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ] },
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "113_0103101" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「確かに、今日は一日中戦闘で、大変ではあったよ。隊長様の我への労いの言\n葉は本当に嬉しい。……だが。だが、だ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011301_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103102" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「風呂くらいは一人で入れる！　子供扱いするではないわ！　だから、出て行\nけ！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011301_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103103" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「んぅ？　……あぁ、確かに埃や泥が入り込んで酷いことにはなっておる。耳\nの、裏？　あぁ、そんなところにまで……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103104" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「い、いやいや！　確かにそこは見過ごしてしまったが……！　それでも、隊\n長様の手を煩わせはせぬよ！　もう、本当に結構じゃから……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103105" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「あ、あいたたたたたた！　動いたから目に泡が……んううぅう……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103106" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「あぁ、隊長様。目を水ですすいでくりゃれ！　んんぅ……すまぬな。もう大\n丈夫じゃ。はぁ、痛かった。まだチクチクする」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103107" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「……あぁ、確かに。そなたがいてくれれば目に泡が入っても安心じゃな。…\n…はぁ、分かった分かった。では、洗ってもらうことにするさ。ふぅむ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103108" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「んん……我の目の届かぬ……特に背中辺りを重点的に洗ってくりゃれ。そし\nて、あまりじろじろ見るでないぞ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103109" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「……何でって……はぁ……隊長様、デリカシーがなさすぎる。そなたは好意\nで洗ってくれているとはいえ……我は、裸を見られておるのじゃぞ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103110" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「恥ずかしくて当然であろうが！　……ん？　普段から裸？　そ、そなた！　\nそのような目で我を見ていたのかえ！　なんたる破廉恥な……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103111" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「んううぅぅ……冗談？　はぁ……ではその様に受け取ってやるかの。全くも\nって笑えぬがな。本当に、人間という奴は、もぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103112" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「それに、見られることは当然……見るのも恥ずかしいというか……隊長様も\n裸であるから……目のやり所に困る」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103113" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「それは、風呂は裸で入るのが当然ではあるが……もぅ！　本当に分からぬの\nか？　呆れるわ！　と、とりあえず下半身位はタオルで隠せ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103114" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「……ん。まぁ、とりあえずはそれでよい。ではもう我も腹を決めた。がっつ\nり洗ってもらおうかの」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103115" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「ふぅぅ……それにしても、そなたの手はくすぐったくて敵わぬ。そぉっと触\nり過ぎじゃ。もそっと強くてもいいぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103116" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「ふぅむ。あー、それくらいなら……ほぉ……。首の後ろを洗ってもらえるの\nは気持ちがよいのぉ……", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103117" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「んぅ？　……何じゃその『お客様痒いところは御座いませんか』というのは\n。いや、痒い所を尋ねるのは分かる。しかしその……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103118" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「我は、『お客様』かえ？　……とっくに仲間になっていたと思っていたのだ\nが……我は思い上がっておったようじゃな……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103119" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「はぁ？　美容院での定番の台詞だとぉ？　そう、なのか……。あぁ、髪を洗\nってもらえる際の？　ほほぉ、そんなことが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103120" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「ほほ。我は、妙な勘違いをしてしまったようじゃな。お恥ずかしい。さっき\nのは聞かなかったことにしてくりゃれ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103121" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「あぁ、そうじゃ。さっきの『仲間』云々の件は、内緒で秘密じゃ。隊長様と\n我、二人きりのな。……いいな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103122" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「ほらほら、手が止まっておるぞ？　こうなったら徹底的に洗ってもらうから\nな。尻尾も一本一本丁寧に泡立てておくれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103123" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「すべすべだと？　当然であろう、石鹸を使っているのだから。……そうでな\nくて我の毛が？　フフッ、褒めておるなら有難くお言葉受け取ろうか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103124" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「まぁそれもこれも、普段から隊長様が撫でてくれているからかもしれんえ？\n　暇になるとお膝に呼んで撫でてくれるじゃろう？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103125" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「……まぁ、最初は鬱陶しかったがのぉ……今は、うん。慣れてしまったよう\nじゃ。でなければ、そなたの膝の上で居眠りなどせぬよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103126" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「ふぁー、それにしても耳の後ろを洗ってもらえるのは気持ちがいいのぉー…\n…。極楽極楽……。夢心地じゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103127" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「んふぅー、そこ！　あー、そこそこそこ！　もっと強くゴシゴシしてくりゃ\nれ。はぅーん、頭がとろとろになるのじゃ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103128" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「か、身体が……ぽっぽぽっぽするぅ。んぅ、これは……湯で身体が温まった\nだけかえ？　それとも、隊長様の指が……きゅぅぅううぅぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103129" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「はぁん、おぉ……尻尾も……うん。あ、洗ってもらおう……か？　ん……ん\nん……ふぅ、ん……！　く、くすぐったいのじゃ！　んふぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103130" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「さ、先っぽは……んぅ、大丈夫じゃが……根元はぁ……んふぅ、んんん……\n！　ひゃあぁぁ、せ、背中がぁ、ゾクゾクするのじゃぁ！　きゅぅぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103131" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「あ、熱いのに……寒気が止まらぬ！　な、何じゃこれは？　隊長様、そなた\n何をしておるか？　我、我……おかしいぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103132" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「う、うるさいって……わ、我だって！　こんなに騒がしくしとぉないわ！　\nだが、声が勝手に……ふわぁぁぁん。くすぐったぁぁぁい！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103133" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「はわっ！　はわわわ……隊長様！　もういい加減に……わ、わざとであろう\nが！　そこを執拗に洗うのはぁぁ！　ふひゃぁあぁぁあぁぁん、くぅぅん」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103134" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「ちょ！　そんな尻尾をいっぺんに……！　だ、駄目ぇ！　だって、九倍！　\n九倍気持ち良くなりゅぅぅうぅぅ！　そんなぁ、無理じゃぁぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103135" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「んきゅぅぅうぅ！　き、気持ちぃいいぃぃ！　尻尾ぉ！　尻尾が九本ともぉ\n、全部！　全部気持ちぃいいぃいぃ！　隊長様ぁああぁぁ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103136" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「はわっ！　はわ！　はわわわっ！　足が、尻尾がぁ……！　ぴ、ピーンって\n！　ピーンってなるぅぅ！　はわわぁああぁぁぁぁー！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103137" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅん、ほぉ……。んんぅぅ……気持ち良すぎて、腰が抜けてしま\nった。はわわ……。隊長様、しっかり抱き留めておくれ？　んぅぅ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103138" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「はぁ、ここまで我を好きにしたのじゃ。泡をすすいだ後、タオルでよく拭く\n役目もそなたに任せるぞ。心してかかれよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103139" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「ほぉ、ドライヤーで乾かしてくれるのか？　あれは一人で扱うのは難儀故に\n敬遠しておった。そなたが扱ってくれるなら安心じゃ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00011301_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "113_0103140" ]},
		{"command":[ "SETNAME", "バラカモン" ]},
		{"command":[ "SETTEXT", "「はー。毛がきっとふっわふわになるぞ。嬉しいのぉ。その時は今日の礼に、\n一番に隊長様にもふらせてやるさ。楽しみに待っておれ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}