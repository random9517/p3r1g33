		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「アンタもだいぶ、ウチの手伝いに慣れてきたな。人手が足らんかったし、ほ\nんま嬉しいわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00017401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あ、あんな……よかったらなんやけど……このままずっと働いてくれてええ\nし、将来的にはウチと一緒にお店をやってくれてもええんやで……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00017401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あ、あははっ！　なんてな！　ウチ、なに言いよるんやろ！　ちょっと冗談\nが過ぎたわ！　忘れてーな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00017401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「えっ、あっ……な、なんや……？　ひょっとして、本気にしてくれたん……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00017401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ウチは……アンタがずっと側に居てくれたら、ほんま嬉しい……だから、そ\nの……ウチを、アンタのモノにしてくれへんか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00017401_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「アンタのオチンチン見るんは初めてやないけど……や、やっぱり、いざとな\nると恥ずかしいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00017401_02_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「それに、なんか前よりも大きい気がするわ……熱さも、硬さも……もしかし\nて、ウチを見てこうなってくれたん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あははっ……ウチのこと好きすぎやろ……でも、めっちゃ嬉しいわ……んっ\n、あっ……ちょ……！　そこ、アカン……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「クリトリス、オチンチンでシコシコせんといて……！　か、感じすぎて……\nふあっ、あっ……あああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あ、アカン……！　めっちゃ気持ちええ……！　一人でするんと、全然ちゃ\nう……！　オマンコの奥、あつなってくるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ウチのおっぱいやオマンコ、アンタに見られとる思うと……変な気持ちなっ\nてくる……！　オマンコ、濡れてまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あっ、んひゃうぅ……！　わ、わかるで……ウチのぐちょぐちょのオマンコ\nに、ガチガチの勃起オチンチン……挿れたいんやね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ウチも……アンタのオチンチン欲しいわ……オマンコぐちゃぐちゃにかき回\nして欲しいって、子宮が訴えてきよる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んくうぅ……！　入口にオチンチンの先っぽが……！　ゆ、ゆっくり……入\nって、来よる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「やっ……っ、くううぅ……！　ええで……そのまま、一気に……！　ウチを\n……女にしてや……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ふあああぁ……！　あっ、ひっ、ああぁ……！　ほ、ホンマに……オチンチ\nンが、オマンコに入っとる……！　奥まで、にゅるにゅるって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ヌルヌルオマンコのお肉……掻き分けながら、子宮の前まで……！　やっ、\nああっ……！　アカン……めっちゃ感じる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んくうううぅ……！　今、奥にコツンって……！　子宮口までオチンチン届\nいたのわかるわ……！　ウチ、完全にアンタのモノになったんやね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「幸せすぎて、おヘソの下あたりがジンジン疼きよる……！　アンタの精子が\n欲しいって、合図なんかな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はぁ、くっ、んんっ……！　オチンチンが膣内でビクンってしよる……！　\nええよ……う、動いて……あああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あっ、うううぅん！　やっ、あっ、んくうぅ……！　そない激しく\n動かんでも……！　あっ、くっ、んんっ……ふくっ、あっ、ああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あああぁ……！　か、傘の部分がオマンコ引っ掻いとる……！　膣内抉られ\nとるみたいやのに、めっちゃ気持ちええ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ひうううぅ……！　お、オチンチン引き抜く時の感触、ウチ好きかも……！\n　オマンコ引っ張られるみたいな感じが……あぐうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「パンパンに膨らんだオチンチンが、オマンコの膣内で暴れとる……！　こん\nなん、オマンコがオチンチンの形覚えてまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「くっ、あっ……あっあっ、ひゃぐうぅ……！？　そ、そない腕引っ張らんと\nいて……！　おっぱいに擦れて……あっ、んっ、あふうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「そない強くせんでも、ウチはどこもいかんよ……！　アンタの側におるから\n……もう少し、落ち着いて……やあぁ、あっ、あああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「オマンコの浅いとこに、オチンチンのでっぱりが当たって……んんっ！　あ\nっ、あきゅうぅ……！　お、押し付けるの反則や……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はぅ、あっ、あはあぁん……！　アンタも気持ちようなっとる……？　ウチ\nのオマンコ、ちゃんとオチンチン気持ちようできとる……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104128" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ほんならよかったわ……！　あっ、くうっ、あんっ、あんんっ……！　身体\nの相性も、バッチリかもしれんね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はぁ、くっ、あっあんっ……！　ふぐっ、んっ、ああぁ……きゅ、急に動き\n強めて……どないしたん……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「オチンチンもビクビク跳ねまわっとる……！　もしかして、イキそうなん…\n…！？　ウチのオマンコに、精子びゅーびゅー出したいん……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「うん……！　ええよ……！　ウチもオマンコの奥から気持ちいいの、迫って\nきよる……！　そろそろ、イキそうや……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ひいっ、あっ、んくっ、やっ、ううぅ……！　オマンコから、ずちゅずちゅ\nってすごい音鳴りよる……！　めっちゃ激しいわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あっ、あぁん、あぅ、ふくうぅ……！　一緒に……あっ、あああぁ……！　\nウチと一緒にイこ……！？　一緒に、気持ちようなろ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んあああぁっ……！　あっ、くっ、ふああぁ……！　イッ、イクッ……！　\nウチ、もう……！　ああぁ、あっ、んはあぁ……ああああぁっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あはぁああああぁんっ！　あっ、熱っ……！？　オマンコの奥に、精子流し\n込まれとる……！　ぐうっ、んんっ、あぐっ、ああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっあっ……！　まだ出よる……！　どぷどぷって音立てながら\n……ドロドロの精子が、子宮に……はああぁん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「アカン……！　めっちゃ幸せな感じがして、気持ちええ……！　こんなん、\nウチまた……イッ、イク……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んんんんっ～～～～～！！　はぁ、はぁはぁ……！　なんや……イッたのに\n、全然昂りが治まらへん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ウチ……もっとシたいみたいや……！　で、でも……アンタが無理いうなら\n諦め……きゃあああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「オチンチンまだギンギンに硬いままや……！　もう一回、付き合ってくれる\nん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「お、おおきに……！　で、でもな……はしたない女と思わんといてや……こ\nないな気持ちになったん、初めてやから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あははっ。オチンチンが気持ちよくなりとうて、膣内でビクビクしよるね…\n…我慢できひんみたいやし、好きに動いてええよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ウチもオマンコがジンジンしてたまらへんから……あっ、ああっ……んっ、\nんふううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あっ、ひああぁ……うくっ、んっ、ああはぁ……！　子宮に精子出されて、\n敏感になっとるせいやろか……さっきより、オマンコ感じるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「オチンチンが出たり入ったりするたびに……膣内でぐちゅぐちゅっていやら\nしい音がして……身体に響いてきよる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「やああぁ……！　オチンチンズポズポされて、ウチのエッチなお汁と精子が\n混ざりあって、ドロドロに泡立ってるオマンコ見んといて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、んひいいぃ……！　エッチな音、さっきから止まらへんからぁ\n……！　オマンコの外も膣内も、全部ぐちゃどろや……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はひいぃ！？　あっ、んああぁ……！　おっ、奥……今、えらい勢いで突か\nれて……あっ、アカン……！　軽くイッてもうたわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はぁ、はああぁ……！　クリトリスも、乳首も……痛いぐらいに大きくなっ\nとる……！　触ってへんのに、かとうなっとるんわかる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ウチの身体、おかしなっとる……！　アンタのオチンチンでずちゅずちゅさ\nれるたびに、全身が悦んどる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あっ、ふああぁ……！　か、完全にエッチな子になってもうた……！　ウチ\nの身体、オチンチンで開発されてもうたわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んくううぅ……！　あ、あんな……ウチがエッチな子になっ\nても、嫌いにならんといてや……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んんっ、ひっ、ひぐっ……あっ、はひっ、ぐううぅ……！　え、エッチな子\nでも、ええのん……？　ウチみたいな子、嫌いやないん……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「エッチな子は好きてアンタ……でも、嬉しいわ……！　ほんまおおきに……\nくっ、うっ、ひんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「くっ、あっ、あっ……！　な、なんや……嬉しいのと気持ちいいのが混ざっ\nて……！　ああぁっ、オマンコ、きゅうぅってなっとる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ふくううぅ……！　お、オチンチンもビクビクして……！？　ま、また、イ\nキそうなんやね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「う、ウチも……また奥から気持ちいいのきてる……！　幸せすぎてイキそう\nや……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ああっ、んはあぁ……！　え、ええよ……！　出して……いっ\nぱい、白いの出して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んひっ、ひっ、ああっ、んひゃああぁ……！？　イッ、イク……！　イクッ\n！　ああぁ、ウチ、もう……！　んっ、ひいいぃ、あはああああぁん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んひゃああああぁ……！？　ま、また熱いの出てる……！　子宮にどぷどぷ\n流し込まれとる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「オマンコが悦んで、痙攣しよる……！　あっ、んあっ、ま、また……！　イ\nッ、イク……！　んぐうううぅ～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　もっと、奥まで白いの出して……！　子宮口にオチンチン\nの先端当てて、グリグリしながら射精してや……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ウチが妊娠するぐらい……！　赤ちゃんの部屋に、アンタの子種……全部出\nして……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ひっ、んふあああぁ……あははっ。お腹ん中、精子でたぷたぷや……オマン\nコに精子のニオイが染み付きそうやわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁはぁ……ふはああぁ……手足に力が入らへん……こら暫く、起き\n上がれそうにないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「回転焼き作るときでも、こんなんならへんのに……もっと精進せなあかんな\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「精進するには、もっとセックスすればええ……？　な、なに言うてんの……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104308" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「でも、確かにそうやな……ウチにはもう、アンタという大切な人がおるけん\n、いっぱい練習できるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「そんでゆくゆくは、子供と一緒に親子水入らずで回転焼き作って……あはは\nっ。そないなったら、ほんま嬉しいなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「あっ、熱っ……！　お、お腹の中やのうて、外に白いのが……！　あっ、ふ\nあっ、んくうううぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「精子、身体にかかってる……！　ああぁ、アカン……！　精子浴びながら、\nイッて……んはああああぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「んっ、ひうぅっ……ま、まだどぴゅどぴゅ白いの出てる……！　すごい量や\nね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「身体中ドロドロや……ニオイも染み付いて……んくうううぅ……！　あ、ア\nカン……このニオイだけで、イッてもうたわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「それにしても、すごいなぁ……二回目やのに、こない出るやなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00017401_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「ウチのためなら、なんぼでも精子出してくれるん……？　も、もう……！　\nそないなこと言うて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「でも、ウチのためいうんは、ほんま嬉しいわ……大事にされとるいうことや\nろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「そない照れんでもええやん……ウチかてアンタのこと大事やし、大切に思う\nとるんよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「これからもずっと、側に居てくれるん……？　めっちゃ嬉しいわ……ほんま\n、おおきに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "天神さき" ]},
		{"command":[ "SETTEXT", "「大好きな回転焼きがあって、アンタがずっと側におる……あははっ。ウチは\n世界一、幸せな少女や……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_174_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
