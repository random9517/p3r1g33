{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……あなたも忙しいでしょうに、こんな森の中まで呼び出してごめんなさい\n。でも、他の人には相談できなくて……。一つ、聞いてもいいかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「この……メイド服って何か、妙な魔法がかかっていたり……しないわよね？\n　最近、この服を着ていると、どうにも気持ちが落ち着かなくって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「具体的に……？　胸が疼くんだ。見せてみろって……？　それならちょうど\nいい。どうせなら昂ったこの身体を、あなたに鎮めてもらうとしようか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00017302_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「そぉれっ……フフフっ。ここなら他のメガネエルフにも見つからない。ここ\nは、森の中でもとびきり奥まった場所。私の秘密の場所だからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_02" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……隊長さん……、じゃなかった。今はご主人様、か……。この\n服のせいでもあるとは思うけれど……胸が疼く理由を今思い出した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「それは、あなたにさんざん開発されてしまったからだ……。身に覚えがある\nだろう？　ほらっ、この胸……たくさんいじり倒してくれたでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204106" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「だから、どちらかが原因なんだと確信して……こうやって森に誘いこんだの\n。そして今、こうして押し倒してみてわかった……。はぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「両方……だ。私はあなたに胸をもてあそばれ、感度を上昇させられたあげく\n……メイドの衣装を身に着けて、そのどちらにも興奮してしまっている」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「それを解消するためには……ああ、そうだ。あなたの……ご主人様の協力が\n必要……。さあ、欲望のままに吸って。力いっぱいっ……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んんっ……！　んっ、んん……ッ。すごい吸いつき……っ、あぁっ、乳房が\n、乳首が、全部あなたの口の中に吸い込まれていく、みたい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「でも……くふぅっ♪　や、やっぱり思った通りだわ……！　あなたに胸を、\n吸われると……はぁ、はぁ、少し疼きが楽になるっ……んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204111" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「かわりに身体全体が火照って……あんっ、いやらしい気持ちになるのが困り\nものだけど……、はぁ、はぁ、いいわ。本当に耐えられなかったのよ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ジンジンジンジン、触れてもいないのに疼き続けて……あっ。あなたがぴち\nゃ、ぴちゃって舐めると……そこだけ楽になるぅ……！　あっあぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んふ……♪　ふぅううっ、赤ちゃんみたいに吸うの……っ。ちゅうちゅうっ\nて！　それ、から……揉みしだいて！　下から持ち上げるみたいにぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204114" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　そうよ、そう、もっと強くっ……いいからっ、めちゃくちゃに\nしていいからっ！　私の胸、いじり尽くしていいからしゃぶってぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……え？　しゃぶりながら、ちゅぱちゅぱ味わいながら、セックスもしたい\nですって？　そ、それは……。今はペニスの相手をしている場合じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204116" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んっ？　許可してくれないなら胸も触らない？　くっ……卑怯よ……。そん\nなことを言われたら、マンコを貸し出すしかなくなるじゃないっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はいはい……わ、わかっているわよ。ペニス、だとかお上品な言葉ではなく\nて……。チンポ、でしょう。チンポ、マンコに入れていいわよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204118" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「っえっ……？　それはメイドの頼み方じゃない……？　立派なメガネエルフ\nメイドならちゃんとおねだりできるはずだ、ですって……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204119" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「く、ぅ……くぅうう……！　わ、わかったわ、言えば良いんでしょ！　……\nご主人様……メガネエルフメイドのディーネリンドのマンコに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「その素晴らしいチンポを奥まで、そ、挿入していただけませんか……？　私\nの胸を吸って、乳首を転がして、乳房を揉みしだいて……はぁ、はぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204121" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「め、めちゃくちゃに……してください、メイドのマンコはご主人様のチンポ\n専用です……。ああっ、早く……早くくださいっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「んふぁあああッ……！？　ああっ、あああああっ、あぁああっ……！　チン\nポっ、チンポを挿入していただいてぇえっ、ありがとうございますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ、あぅうっ、んっ、くぅうっ、んぅうう……っ！　お、大きいぃい……\n！　太いぃいいい……！　それに、乳首っ、乳首舐められてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「こんなの……おかしくなってしまうっ！　あっあッ！？　私の二つの性感帯\n……っ、マンコがチンポに！　胸が口にぃっ、むちゃくちゃにされてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「それがどうしてこんなに気持ちよすぎるんだぁああっ……！　あああっ、い\nや、だ……♪　勝手に胸を、腰を揺らしてしまう……！　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ご主人様の愛撫っ、チンポっ、自分から求めてしまうぅううっ……！　あっ\n、あぁっ、はぁあっ、ご主人様……ご主人様ぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204127" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ご主人様のチンポ、私のマンコいっぱいに入っていますっ……！　はぁあっ\n……♪　もっと、もっと腰を突き上げて、マンコ貫いてくださ、ぁいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ……あぁっ……！　濡れそぼった私のマンコを尽きながら、舌先で乳輪\nを舐め、乳首を吸い……あっあっ、乳房をこねくりまわす……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あぁっ、ご主人様はチンポも愛撫も天才です！　ご主人様と、ご主人様のチ\nンポにお仕えできて幸せ、で、すっ……あああっ、ふ、深いぃいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「一番奥に簡単に届いて……！　あっ！　あっ、子宮口が押し潰されている、\n気持ち良すぎておかしくなるぅうっ……！　あああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「身体の上も、下も気持ち良くなって……私、私は……っ。んぁああっ、やめ\nないで、ください……！　もっと突き上げてっ、止めないでぇ……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ご主人様……！　ご主人様ぁっ、一緒に……一緒にイッてください……っ！\n　メガネエルフメイドのディーネリンドが、全ての精子を受け止めます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ですから……、あぁっ、ああ、噛んで、乳首……！　あぁんんっ！　精液を\n出せぇっ……私のマンコに、その太いチンポから精子、精子ぃい……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204134" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「欲しいっ……。我慢できないっ……！　あっ♪　あっ、絶対服従するから、\nご主人様の言うことを聞くから……お願いしますぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぅぁあああっ！？　あぁッ♪　あっ♪　精子っ、精液きたっ、マンコの中\nをのぼってくるぅっ♪　ああっ、あっぁっあぁあああっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「乳首でもイク、乳房でもイクぅ……っ！　あっ、熱い精液と、ご主人様の熱\nい口内ぃ……！　私、私はトロトロに溶かされて……イクぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あ～っ！　あっぁっああああっ……！　こんなのっ、イカずにこらえられる\nわけがないだろうっ……！？　あっ、き、気持ち良すぎるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あ、私のっ、メイドマンコの具合はいかがですか……っ！　あうぅっ♪　こ\nれだけたくさんの精液を次々に吐き出しているのですからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204139" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「それはそれは極上の締めつけでしょう……っ？　あっ♪　ご主人様のために\n、禁欲をして、全身を敏感にして、胸を疼かせて……待っていました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「一緒に……っ、チンポとマンコでセックスして、同時に絶頂したくてっ……\n！　んぁあああっ、イクのを我慢して……濡らしていたんですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ご主人様も……私のメイド服を見て、このいやらしい衣装に勃起してくれて\nいたんですよねぇっ？　その視線で、私……私、昂って……あぁあんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あぁっ……あぁ……。わ、かりますか……？　私のマンコの中……完全にご\n主人様の精液で満たされています。ですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204203" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、まだ足りません。まだ、ご主人様に私の疼きをなだめていただ\nきたいのです……。いいですね？　……んっ、荒々しいピストンと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「強烈な乳首吸いで、あなたのメガネエルフメイドを満足させてくださいませ\n……！　っはぁあっ♪　はぁっ、あぁ、あぁ……、は、激しいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「さすがです！　ご主人様っ……、んぁあああっ。ご主人様の精液で満たされ\nたマンコを、更に容赦なく掻き回して、突いて、貫いて……あああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「私の胸もっ、尻も全てご主人様の思うがままに揺らされて、犯されて……！\n　んんんぁっ、でもそれがいいんです、それで感じるんですっ……あああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁっ……あああっ、あぁっ、ああああ……！　す、ごい……♪　夢中にな\nって私の胸をしゃぶっている……っ。マンコをえぐってく、るぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「これだ、この快感、がっ、欲しかったのだ……私はぁあっ♪　あああっ、ご\n主人様に奉仕する、絶対服従する喜びを知ってしまった……ッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ、あぁああ……っ、くぅううっ……♪　くふぅううっ♪　ご主人様ぁ…\n…っ♪　私をめいっぱい可愛がって、ほしい……！　っあっ♪　あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ズンズン奥を突かれて……意識が飛んでしまいそうなくらい気持ちいいッ…\n…♪　あっ♪　あっ、メガネがずれるくらい……はげ、しくてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「胸ももみくちゃに揉まれて……んぁああっ！　ぢゅるるるっ、じゅるるるっ\nて乳首……吸われて……。あっひィッ♪　ひぃんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「舌先っ……尖らせて、ドリルみたいにグリグリグリグリ……！　あああっ、\n乳首、乳首が乳房に押し込まれるっ……こんな刺激初めてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ご主人、様ぁ……！　ご主人様ぁっ！　私も、私もご奉仕させていただきま\nすっ！　メガネエルフマンコで再びっ、精液搾り取らせていただきますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204214" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁああっ♪　あっ♪　んぉおっ♪　おぉおっ♪　ずっぽっずっぽってすご\nい音たててっ、私っ……チンポ貪ってる、夢中で味わってるぅうう～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ひィイイっ……♪　太いチンポがマンコを掻きわけて……あああっ♪　出た\nり入ったり、出たり入ったりィ……っ♪　そ、それにっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「胸ぇ……！　こんなに吸われたら跡がついて、しま、うぅううっ♪　でもい\nいっ、吸って！　吸って、掴んでっ、揉んで……吸い上げてぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ああっ、ああああああ……！　ご主人、様ぁあ……！　私、もう一度っ、も\nう一度イキますっ、イ、イカせていただきますっ、よろしいでしょうかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「くぁああっ♪　あぁっ、イクッ……！　ご主人様っ、私の感じるところっ、\nイキそうになるところばかりを突いていただきありがとう、ございますっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「一緒に……一緒にイッてくださいっ！　もちろんマンコに出してくださいま\nすよねっ！？　あっ……あっ、イクっ、イクイクイクぅううう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204220" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ひィイんんんんっ……♪　ドクッ、ドクッとチンポが脈打ちながらっ……私\nのメガネエルフメイドマンコに新しい精液を注いでおりますぅううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あひっ、ひぃっ♪　んんんっ……！　熱いっ……それにすごい量……！　さ\nっき射精したばかりなのに、もうこんなに溜まっている、なんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あなたって本当に……ご主人様の才能がありすぎるわ……！　あっ♪　メイ\nドを従えるにふさわしいチンポよっ、あぁっ、褒めてあげるぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あぁああ……！　んぁああっ、はぁああんっ、あぁんっ♪　まだよ、まだ出\nせるでしょうっ……！　精液枯れるまで、出してっ、出してぇえっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_21" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あふぅううっ♪　やっぱりまだ出せたじゃない……っ♪　ああああっ、子宮\n口にびゅるっ、びゅるって精液が当たる瞬間がたまらないのよ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ご主人様のチンポ、最高にイイわっ……！　こんな量を何度も注いでくれる\nなんて……。絶対に、他のニンゲンには不可能だものっ……あぁあんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「はぁああ……っ♪　ようやく……胸の疼きが、身体の火照りがおさまってき\nた……♪　何度か強く絶頂して、精液を注入されるといいみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「対処法がわかったことは素晴らしいけど……。でも、まだまだこのメイド服\nを脱ぐわけにはいかないし……。ええ、そうよ。まだ稼がないといけないの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「と、いうことは……フフフッ。必然的に、これからもご主人様に疼きを鎮め\nていただかないといけないってことね。よーくわかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「疼きが止められなくなったら、すぐに森の中に呼ぶから。そしたら……今み\nたいに。ご主人様のすごいチンポで解決してね。頼りにしているわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あっ！？　ちょっと、何をしているのよっ……！　チンポが抜けてしまった\nじゃないっ……。えっ？　か、身体にかけたい？　待ってっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204401" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あンッ！？　あっ、いやぁっ……もぉおおっ♪　これじゃあ疼きがおさまる\nところか、もっともっと強くなっちゃう……っ、あっ！　だめっ、だめ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_23" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「ああああ……っ♪　こんなに外に漏らして、仕方のないやつだ……♪　そん\nなにっ、私の胸にかけたかったのか……っ？　あっ、ヌルヌルするぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204403" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_24" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「も、もう外に出してしまったものは仕方ないっ……！　あっ♪　それに私は\nご主人様に絶対服従の、命令をきくメガネエルフメイドだ……っ、んっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「あなたがっ、かけたいところにかけて、一番気持ち良くなれるようにっ……\nするのが役目、だからっ……。気にせずかけろ、もっと、もっとだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「っああああっ……！　熱いいぃい……っ♪　どぴゅどぴゅ降りかかる真っ白\nな精液……♪　さっきはこれが、私のマンコの中に……んぁうううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「……フッ、フフフ……♪　疼きを止めてほしいと頼んだのに、ますます私を\n疼かせるとは……。とんでもない悪いご主人様だな、あなたは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00017302_02_22" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「いつもこれくらいの量の精液が、こんな色と熱さでマンコに出ているのだと\n……身を持って教えてくれたというわけか。たしかに、全てがすさまじい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「夢に見てしまいそうなほど完璧な精液だ……。……んっ？　う、うっとりな\nんてしていない。でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204409" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ディーネリンド" ]},
		{"command":[ "SETTEXT", "「今日は、二回目の精液はマンコに出してもらえなかったから。近いうちに、\nリベンジをしてもらわないとな。今からその時が楽しみだ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_173_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
