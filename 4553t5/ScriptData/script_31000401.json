		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くああああぁ……！？　あっ、あああっ……！　隊長どのっ……！　一緒に\nイッてくれたんだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「しかもこんなに出してっ……！　やっ、あっ……！　嬉しくて、またイッて\nしまうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんんっ……！　い、イッてる最中も、おっぱいをシコシコして欲しいのか\n……！？　ああ、いいぞ……シコシコしてやるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「くふっ、あひっ、ああぁ……！　絞り出すようにすると、さらに精子が谷間\nに出てきて……あっ、熱いぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どの……！　このまま全部出してくれ……！　私のおっぱいを孕ませる\nくらい、大量に……！　あっ、あぁ……！　ふあああああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ……ふふっ。すっかりおっぱいが精液まみれになって\nしまったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403306" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「拭けば精子は取れそうだが……さすがにこのままだと、ニオイでバレてしま\nうな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「仕方ない……今日はもうこのまま、ここでゆっくりするとしようか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403308" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「祭りを最後まで楽しめないのは残念だが……こうして隊長どのと、ひと夏の\n思い出が作れたと思えば悪くないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……愛しているぞ。隊長どの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「きゃああああぁ！？　か、顔にまで精子が飛んできて……！？　あっ、んん\nんっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「さすがに飛ばしすぎだ……！　せめて胸の中に出して……あああっ……！　\nま、まだ顔にかけるのか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなにも精子を浴びせられたら……ま、またイッてしまうっ……！　あっ\n、あっ！　アソコが疼いて……んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ……ダメだっ……！　何回もイクッ……！　み、見ないでくれ、隊長ど\nの……！　私のイキ顔……見ないでくれぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あああああっ……！　くるっ！　くるぅ！　すごく深いのが、アソコから込\nみ上がってきて……イッ、イクうううぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……んふうぅ……！　まったく……顔にかけるなんて聞いてない\nぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これが終わったらみんなのところに戻って、祭りを楽しもうと思っていたの\nに……この姿では、出るに出れないではないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403407" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「でもまあ……隊長どのが満足してくれたのなら、よしとしようか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403408" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んなっ……！？　な、何故またペニスを大きくしているのだ……！？　もう\n十分出しただろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403409" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「どうせ戻れないんだし、もっとエッチしたいだと……！？　わ、わかった…\n…！　付き合ってやるから、とりあえずその手を離せ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}