	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「祭りの最中だというのに、急に境内に誘ってくるからなにかと思えば……ま\nさかエッチしたいなどと言い出すとはな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ほら……早く済ませて戻らないと、みんなにバレてしまうぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ずっとこうして居たいから、バレてもいいだと……？　そ、そういうことを\n言うのは反則だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403103" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが……私も同じ気持ちだ。こうして、隊長どのとずっと触れ合っていたい\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403104" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、んふっ……！　ペニスが胸の中で大きくなって……ふふっ。我慢でき\nないみたいだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403105" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それに手つきもいやらしいぞ……そんなに私のおっぱいが気に入ったのか？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そういえば、初めてエッチしたときから、隊長どのはずっと私のおっぱいに\n夢中だったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403107" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「別にイヤだなんて思ってない。むしろ、こうして私を求めてくれることがな\nによりも嬉しいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、すまない……話に夢中で、すっかり焦らせてしまったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「いっぱいシゴいてやるから……私のおっぱいを好きなだけ堪能してくれ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ……んっ、ああっ……！　シコシコするたびに、ペニスが跳ねてくるぞ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そんなに動かされたら……はぁ、あふっ……！　谷間が熱くなってきてしま\nうではないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「日は落ちているとはいえ、まだまだ暑いのに……んんっ、余計に暑くなって\nきてしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、やっ……！　こ、こら……おっぱいをそんなに弄るなっ……シゴきに\nくいだろうが……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あ、ああ……パイズリの邪魔をしないなら、好きに揉んでくれて構わないぞ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ……！　そ、そうだ……そんな感じで、優しく揉んでくれると\nパイズリもやりやすいし……か、感じるから……ああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ、んふっ……くっ、あああぁ……！　胸を揉まれながらだと、いつもよ\nり気持ちいい……あっ、あっ……！　んふうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ……隊長どのも気持ちいいみたいだな……ペニスがすごくビクビクし\nているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403118" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「エッチなお汁もこんなに溢れて……はあぁ……谷間が汗と我慢汁でベトベト\nだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが、これくらいベトベトしてた方が、滑りもよくなるなるからな……さっ\nきより動きやすくなって……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はぁ、くっ、あああぁ……！　ペニスの段になっているところが、おっぱい\nに擦れるっ……はぁ、あっ、これ……気持ちいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どのも……この亀頭のあたりを擦られるのがいいみたいだな……！　な\nら、ここを重点的に擦ってやろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、んっ……！　あふっ、んっ、あああぁ……！　隊長どのの我慢汁で、\n谷間がいっぱいになって……んぐっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「濃くてエッチなニオイが込み上がってくる……こんなのを間近で嗅がされた\nら、感じてしまうではないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああっ……！　シコシコするたびに、どんどんエッチな蜜が吹き出してくる\nぅ……！　ヌルヌル滑って、おっぱいが刺激されるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ、んふっ……！　だ、ダメだっ……！　今、おっぱいビンカンになって\nいるから……そんなに強く揉まれると……んはあぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっあっ……！　やっ……気持ちいいっ……！　おっぱい弄られ\nると、たまらなくなってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「が、我慢できない……！　隊長どの……もっと激しくシゴかさせてもらうぞ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ぐっ、あふっ……！　ひっ、あっ、んくうぅ……！？　ペニスの熱が……肌\nからどんどん伝わってくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「おっぱいに圧をかけながらシゴくと……ペニスが悦んでいるのが、はっきり\nわかるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「谷間の中でずっとビクビクして、小刻みに震えている……！　そろそろ、イ\nキそうなんだな……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふふっ。もう何回も肌を重ねているんだ……それくらいわかるに決まってい\nるだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ああ、遠慮なんかしなくていい……！　隊長どのの精子、思い切り谷間に出\nしてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「私もあのニオイと感触を味わいたい気分なんだ……！　だから、好きなだけ\n出して……あんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あっ、んっ、あっ……！　く、来るっ……！　隊長どのの精子が、ペニスか\nら出て……あああああぁっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_05" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「す、すごい勢いだ……！　まさかパイズリでこんなに出るとは……あっ、ん\nんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「それにすごく熱くて……！　ニオイもすごく濃い……！　肌に貼り付きそう\nだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こんなのを味わわされたら……私もイッてしまうっ……！　あっ、んっ……\nくううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「隊長どの……！　私も、イッ……イクっ……！　あっあっ……ひっ、あああ\nああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ……ダメだ、見ないでくれ……！　私のイッてる姿、見ないでっ……ん\nはああああぁんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、ひふっ……どうやら、たくさん出たようだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これだけ出せば、性欲も鎮まっただろう……？　早く祭りに戻って、みんな\nと合流を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こ、こらっ……！　終わったのに、どうしておっぱいを揉むんだ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403203" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これくらいで終わりたくない。もっとして欲しいだと……？　まったく……\n相変わらず底なしの性欲だな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「だが……素直に私を求めてくれるのは、すごく嬉しいぞ……特別に、もう１\n回だけしてやるとしよう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んっ、あんっ……！　精子のおかげで、おっぱいの滑りがよくなっているな\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こうして擦るたびに……んふっ……！　ぐちゅぐちゅとエッチな音が響いて\nくるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ん……？　さっきよりも激しくして欲しいだと……？　いいだろう。お望み\n通り、いっぱいシゴいてやろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こうしておっぱいを強く寄せて、上下に擦れば……！　んっ、んんっ……！\n　どうだ、この乳圧は……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403209" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「アソコでシゴかれるみたいに、つよく締まっているだろう……？　ふふっ。\n隊長どののために、練習しておいたんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「こうやって、いつ求められてもいいように……隊長どののことを思いながら\n、いっぱい練習して……あああっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「やっ、あっ……！　隊長どのの手が、さらにおっぱいを押し寄せて……あん\nんんっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403212" ]},
		{"command":[ "SETIMAGE", "0", "still_00010004_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「自分でするのと全然違うっ……！　こんなの、練習でも感じたことないのに\n……あっ、あっ！　やっ、あああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んふううぅ……！？　谷間でペニスが暴れてるっ……！　そんな乱暴にされ\nたら、ペニスがはみ出てしまうぞ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「これくらい激しい方が気持ちいいし、すぐにイケそうなのか……？　そ、そ\nうか……隊長どのが望むなら、このままシコシコしてやろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「んんっ……くっ、あっ、ふっ……あああっ……！　おっぱいがジンジンする\nっ……！　熱くて、火傷してしまいそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「このままだと……隊長どのがイク前に、私が果ててしまう……！　そんなの\nはイヤだ……！　できれば、隊長どのと一緒にイキたいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「えっ、あっ……！？　いっ、一緒にイッてくれるのか……！？　なら、もっ\nと最後まで強くシゴいてやるとしよう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「ふっ、んぐっ……あっ、あっ！　あふっ、んんんっ……！　た、隊長どの…\n…私はもう、限界だ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「約束通り、一緒にイッてくれっ……！　あっ、イッ、イクッ……！　隊長ど\nの……！　だ、出して……！　精子、私に出してっ……！！」", "NORMAL" ]},
