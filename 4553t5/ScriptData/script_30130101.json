{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "013_0103101" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「呼ばれたから来たけど……用事ってなぁに？　あ、もしかしてトレーニング\nのお誘い？　いいよ～！　ビシバシ鍛えてあげるね！」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103102" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……え？　ちがうの？　なーんだぁ。それじゃあ、何の用事なの？　……特\n別なマッサージ？　それを受けると強くなれるってこと？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103103" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「うーん、ホントかなぁ……？　お姉ちゃんから、あなたは変態だから気をつ\nけるようにって、口を酸っぱく言われてるからなぁ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103104" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……ねぇ。実はまた、Ｈなこと考えてるでしょ？　えー、誤魔化したってダ\nメだよ。だって今、すごくＨな顔してるもん」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103105" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……やっぱり、今からお姉ちゃんにお願いして、あなた専用の地獄のスペシ\nャル特訓メニューを用意してもらって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103106" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「な～んてね、ウソウソ！　わたしだって女の子だからＨなことは興味あるし\n、あなたにはもう散々Ｈなことされてきたから、今更かなーって」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103107" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……それに、あなたとならそういうことしてても楽しいから……え？　うう\nん、なんでもないよ！　それで、ナニをするの？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103108" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……えぇ～っ！？　わたしのおっぱいでオチンチンをシゴくって……という\nか、やっぱりＨなこと考えてたんだね……もう……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103109" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「いつもわたしのおっぱいをそういう目で見てたってこと？　それってセクハ\nラって言うんだよ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103110" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「まったくもう、しょうがないなぁ……いいよ、してあげる。わたしもちょっ\nとだけ興味あるし……あなたの頼みだからね」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00001301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103111" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「おっぱいを両側から寄せて……んしょ……こうでいいんだよね？　んっふふ\n～、どう？　こう見えて、けっこうおっぱい大きいでしょ？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_01_01" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103112" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「実はねぇ、お姉ちゃんよりもちょっとだけ大きいんだぁ～！　あ、でも、お\n姉ちゃんには言わないでよ？　気にしているみたいだから……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103113" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「それで、この後はどうするの？　このままおっぱいを持ち上げてればいいの\n？　この間に、今からあなたがオチンチンを入れるんだね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103114" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「ん、ぁ……オチンチン、固くて、熱い……んぁぁ、おっぱいの間にずぷずぷ\n入っていくよぉ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103115" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「おっぱいの中でオチンチンびくんびくんしてる。これが気持ちいいんだ？　\nそっかぁ～、男の人って時々変わってるよねぇ～……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103116" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んっ……おっぱいの間を、オチンチンが出たり入ったり……んふ……むにゅ\nむにゅって、おっぱいに擦れてる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103117" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「オチンチンってこうして間近で見ると、思ったより凸凹してるんだね～。ゴ\nツゴツしてて、男らしくって、ちょっとカッコいいかも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103118" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あ、でも……うふふっ、おっぱいの間に一生懸命、オチンチンを出したり挿\nれたりしてるのは、だいぶカワイイ感じだよねぇ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103119" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「なんだか応援したくなっちゃう。がんばれ～、がんばれ～って。わたしもち\nょっとだけお手伝いしてあげようかな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103120" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「オチンチンが入ったのにあわせて～、おっぱいをむぎゅ、むぎゅって寄せた\nり、ぐにゅぐにゅ～ってこすり合わせたり……どう？　気持ちいい？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103121" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……あ、おっぱいの中がぬるぬるしてきたよ。オチンチンの先っぽから、先\n走りのお汁が出ちゃってるのかな？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103122" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あんっ、オチンチンを出し入れすると、にちゅにちゅって音がなって、んっ\n、ちょっとヤらしい感じだね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103123" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「おっぱいの間にオチンチンがにゅこにゅこ、出たり入ったりするのを見てる\nと、んぁっ、おっぱいがまるでアソコになっちゃったみたい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103124" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んっ、んんっ、んあぁっ……オチンチンにおっぱいを擦られて、んふぅっ、\nわたしもちょっとだけ、気持ちよくなってきちゃった……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103125" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「んぁっ、あっあっ！？　オチンチンがびくびくしてきたよ……先っぽが風船\nみたいにふくれて、んあぁ、パンパンになっちゃってる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103126" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「もしかして、もう精液出ちゃいそうなの？　そっかぁ……オチンチンって、\n案外スグにイっちゃうものなんだね～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103127" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あ、それとも……あなたのオチンチンが、ちょっとガマンが足りない感じな\nのかな？　特訓の時とかも、すぐにヘバっちゃうもんね～」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103128" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あんまり早いと女の子は満足できないって、雑誌にも書いてあったよ？　も\nう少しだけ、イくのガマンしてみよっか？」　", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103129" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「ほらほら、おっぱいでうりうりされても、すぐに出しちゃダメだよ～？　ち\nょっとだけガマンしてみようね～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103130" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「おっぱいでにゅるにゅる擦られても、シコシコされても、ガマンガマンだよ\n～？　ほらほら～、がんばれ～、がんばれ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103131" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「おっぱいでぎゅうぎゅうに挟まれながら、むにゅむにゅむにゅ～ってされて\nも、ガマンガマン～、がんばれがんばれ～」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103132" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「わ、オチンチンがすっごいびくびくしてる……え？　もうガマンできないの\n？　んもう、しょうがないなぁ……じゃあ、いいよ、出して？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_01_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103133" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「おっぱいでオチンチンぬぽぬぽ擦って、Ｈな精液をびゅーびゅー出しちゃえ\n……ほらほら、イって、射精して、えいっ、えいっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103134" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「きゃっ！？　おっぱいの間に、びゅるる～びゅるる～って、たくさん出てき\nた……」", "NORMAL" ]},
        {"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_01_09" ]},
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103135" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「熱くてドロドロの精液が、おっぱいの谷間からあふれてきて……むわって、\nすごくＨな匂いがする……頭がくらくらしてきちゃう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103136" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「オチンチンがびくびくって震える度に、さきっぽから、びゅびゅって精液が\n出てくる……おっぱいでもっと、オチンチンを絞ってあげるね」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103137" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「ぎゅむ、ぎゅむって……わ、またいっぱい出てきたぁ。いいよ、もっと出し\nて。タマタマが空っぽになるくらい、いっぱい出して……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_01_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103138" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「……ふぅ、もう出ないのかな？　……うわぁ、けっこういっぱい出したね～\n！　おっぱいの間がベタベタのドロッドロだよぉ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103139" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「あ、でも、あんまりガマンはできなかったんだよねぇ。もっと頑張らないと\n、Ｈの時に苦労するんじゃないかなぁ……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001301_01_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "013_0103140" ]},
		{"command":[ "SETNAME", "ガンシスター" ]},
		{"command":[ "SETTEXT", "「身体と一緒に、オチンチンももっと鍛えないとダメだよ？　どっちの特訓も\n、いつでもわたしが付き合ってあげるから。遠慮なく言ってよね！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}