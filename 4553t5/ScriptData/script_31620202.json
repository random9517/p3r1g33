		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「とにかく、私の気持ちは伝わったようだな。ここまで続きをしてくれたとい \nうことは、お前も私を憎からず思っているということだろう？」", "NORMAL" ]},
