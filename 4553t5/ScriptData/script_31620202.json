		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁ……チンポを直接押し付けながら出されてる……いいぞ、もっと塗りつ \nけてくれ……私の身体を精液まみれにするといい……」", "NORMAL" ]},
