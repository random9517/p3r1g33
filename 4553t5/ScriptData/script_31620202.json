		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「それがお前の気持ちの証だからな……私はそれに応えるまでだ……んふっ、 \nゾクゾクして……またイクっ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、続けてイカされたぁ……チンポが抜けたのに……オマ \nンコがまだジンジンしている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204406" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁ……収まったのか……こんなに粘っこいのがいっぱい……にちゃっと糸 \nを引いている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204407" ]},
