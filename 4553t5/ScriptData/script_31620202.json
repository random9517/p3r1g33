		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「こんなにっ、オマンコズボズボされてぇっ！　はぁんっ、好きだっ……チン \nポもっ、お前のこともっ、もっともっと好きになってくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204215" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、チンポがビクビクしてきてるっ……はぁんっ、声も上擦っ \nて……んふっ、これはつまり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「また次が近いんだな……？　んふっ、ああ……また一緒がいい……同じタイ \nミングで……お前とイキたいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はんっ、あぁっ、もっと激しくっ！　このままっ、ラストスパートするっ、 \nイクまで……本気セックスするぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ！　そこぉっ、そんなにされたらっ！　あぁっ、もぉっ、私も \nっ、らめらっ、イクっ、イクからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「お前もっ……イッてっ！　２発目精液っ……どこでもいいからっ、いっぱい \n出してっ、あっ、んぁぁぁぁぁぁぁっ！」", "NORMAL" ]},
