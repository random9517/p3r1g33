		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……流れてきてる……とぷとぷ……また、熱いの……いっぱい溢れて \n……来てるっ……あぁっ、すごい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ん……もう２発目だからな……残さず全部出してくれ……私のことを孕ませ \nる位の気持ちだ……今日も、別に安全というわけではないが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あふっ……！　今のを聞いて、また出すということは……私を孕ませる気満 \n々ということだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204304" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふふ……問題ない……あぁ……んっ、全部受け止めてみせるぞ……んぅっ、 \nくぅぅん……はっ……ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁ……終わったのか？　んっ、チンポの感じが少し落ち着いた気がする… \n…は、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「とにかくいっぱい出したな……ちょっと漏れて来てる……もう少し引き締め \nないとダメか？　んんっ……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「まだ、チンポが大きいから……キュッとすると、私もビクっとなってしまっ \nた。本当にすごかったな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「だが、これ以上ないほどにお前の気持ちが伝わって嬉しかったぞ。私の気持 \nちも伝わっていればいいのだが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふふ、照れくさそうな顔をする。そういうところが好きなのだ。どうした、 \n私にも同じように言ってくれてもいいんだぞ？　ほれ、早く」", "NORMAL" ]},
