{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「おお、来たか。待っていた。そこに座るといい……いや、他でもない話があ \nってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「うむ、実は……最近、お前を見ていると……どうも身体が熱くなってくるの \nだ。最初は気のせいかとも思ったが、どうやら間違いなさそうでな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204102" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「それで私なりに原因を調べたが、もしやテレビで見た『恋』というものでは \nないかと……そ、それでだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「もし、それが本当なら……この先というものがあるだろう……それを、お前 \nに教えてほしいのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204104" ]},
		{"command":[ "SETCHARA", "0", "char_00016202_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「うむ、言われたやり方に従おう……その、お前の上に跨がれば……いいんだ \nな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00016202_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んっ……あぁ……大きくなってる……ちょっと擦るだけで……どんどん膨ら \nんで来るぞ……これはどういう……期待しているということか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204106" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「そう言われれば……確かに私のオマンコも……いつの間にか濡れてきている \n……そのまま入れてしまえそうだ……い、入れるぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んっ、くぅっ……あっ、はぁぁぁぁぁぁ……んふっ、ゆっくり……沈めてい \nくぞ。少しずつだ……あっ、く……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「入った……んっ、一番奥まで届いたぁ……オ、オマンコと……チンポ……繋 \nがってるぅ……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁ……改めて、一つになれたんだな……どんな気持ちになるのかと思った \nが……想像していた以上に、嬉しさが……込み上げてくる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204110" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「気持ちいいのは間違いない……だが、それだけでなく、心があったかくなる \nと言うか……幸せな感じでいっぱいになるんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204111" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んっ、待ってくれ。私が上なんだから……私から動かないとな……その、自 \n分から腰を使うのは初めてだから、上手くいかなかったらすまん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「とにかく、お前のチンポを感じさせてやりたい……んっ、ふっ、頑張って動 \nかすからな……はぁっ、んっ、あっ、んふっ、あぅっ……んくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204113" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁっ……ぞりぞり……オマンコが擦れるぅ……うくんっ、チンポが……中 \nでちょっとずつ動いてるのが……分かるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ……こんな感じで……ちゃんと気持ちよくできてるか？　その \n、私は……すごく……気持ちいいが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「そうか……！　この調子でいいんだな。うむ……もっともっとオマンコで擦 \nって愛してやるぞ……はっ、ふっ、んふぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、あぁ……こんな風になるんだな……あっ、んっ……ゆっくり \nでも……ずぶって嵌っていく瞬間が、すごく熱くなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「腰を浮かせて……チンポが抜けていく時のムズムズする感じも……身体、全 \n体に広がって……はぁぁぁっ、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204118" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「お前が好きだという気持ちが……こんな風にさせるんだろうな……んっ、好 \nきだ……好きっ、あっ、んっ、好きぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふふ……どうした、照れているのか？　顔が赤いぞ……？　私は好きだと言 \nったが、お前はどうなんだ？　私のことが嫌いか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「違う？　ならば、直接言葉にしてもらわないとな。ほら、ちゃんと言わない \nと、ここでやめてしまうぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「うん？　今、言ったのか？　随分声が小さいな……聞こえなかったから、も \nう一回言ってみろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「好き……？　ふふっ、好きと言ったな？　今、間違いなくそう言ったな？　 \nそれは奇遇だな……んっ、ふっ、んくんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204123" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「実は私もお前のことが好きなんだ……はぁ……んっ、だから……もっと腰を \n振って、お前を楽しませるからな……んぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204124" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ、あっ、あぁっ……身体が勝手に動く……もっとチンポを感じた \nいと……腰が、速くなっていく……んく、あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ほら……分かるか？　ぬちゃぬちゃ……音をさせて、オマンコがもっと強く \n……チンポを締め付けているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204126" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ……腹に力を入れて、キュウっと吸い付かせると……んふっ、お \n前も声が出てしまうみたいだな……可愛いやつだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ほれ、ほれ……どうした？　こういうのも好きなのか？　私の下で、チンポ \nを好きにされる気分はどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「おっと……ダメだぞ、下から突き上げようとしても……今日は私がしてあげ \nるんだからな……意識はチンポだけに向けていろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「そうだ……何もしなくても、ちゃんと……射精するまで、しっかり導いてや \nるからな……このヌルヌルオマンコでぇ……あっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁっ、動けば動くほど……痺れていく……くぅんっ……身体も火照ってい \nく……んぁっ、熱い……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204131" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、どうだ……？　私の動きで物足りないなんてことはないか？ \n　ちゃんと……チンポ、よくなっているか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204132" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「もうすぐ出そうな位……そうかっ、んっ、なら……このまま……最後まで、 \n一気にするぞっ、はぁっ、うんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んぁっ、あぁっ……私も……気持ちいいっ、このまま……中に \n出してくれたら……そのままイクからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204134" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「来てっ……オマンコの中っ！　いっぱい出してっ、一つになろうっ……んぁ \nっ、もうっ、あとっ、少しぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204135" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふぁぁぁぁっ！　あっ……出たっ……中にっ、ビュクってしてるっ……！　 \nんぅぅぅぅんっ……イクっ、イクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……あぁ……オマンコの中で、チンポが震えてる……すごい……量 \nが溢れて止まらない……はふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁ……隙間から溢れてきてる……いっぱい出したんだな……はぁ……気持 \nちいいぞ……最高だ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204138" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んっ、はふ……すごいな……これが恋の続きなのか……こんなにも気持ちが \nいいものなんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁ……いっぱいイッた……最高だったぞ……ふふ、お前も感じてくれたよ \nうで何よりだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204140" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ところで……まだチンポは全部出しきった訳じゃないよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204201" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「ふふ……そうだ。私も、一回イッただけでは、まだ足りないと思っている。 \nこのまま、もう一回……セックスしたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「今度はお前の方から動いてもいいぞ？　私のオマンコも欲しがってるからな \n……いっぱい可愛がって欲しい……ふぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204203" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ！　くぅんっ、はっ、んんっ、あぁっ……突き上げっ……来て \nるっ、チンポがっ……届くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁっ……さっきよりも、深く食い込んでいる感じがするぅ……ずんってさ \nれる度に……頭が真っ白になって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ、んんっ……それ、いい……あぁっ、さすがだな……私のして \n欲しいところが全部分かっているみたいだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んぁっ……もちろん、私も分かっているぞ……さっきまでの反応で、チンポ \nのどこを締め付けてやればいいか……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204207" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「どうだ？　表情が変わっただろう……ふふっ、可愛い奴め……私のオマンコ \n締めがいいんだろう……もっとしてやるからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204208" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んんっ……んくんっ……お前の突き上げに合わせてっ……お腹 \nにぐっと力を入れて……チンポを絞るっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んぁっ……！　オマンコに響いてくるっ……あぁっ、私も気持ちいいぞっ… \n…お前はどうだっ？　私の気持ち……受け取っているかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204210" ]},
		{"command":[ "SETIMAGE", "0", "still_00016202_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「んくぅっ……そうか……気持ちいいんだな……嬉しいぞっ……はぁんむ…… \nキスしてやりたいくらいだ……ちゅぷっ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204211" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「実際してる……？　ふふっ、少しだけだ……それより腰を動かすのが本番だ \nからな……うんっ、んくっ、はっ、んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204212" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「見ろ……このいやらしい動きぃ……割れ目をくぱって広げながら、腰を回す \nの……ドキドキするっ、お前の鼻息も……荒くなってきている……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_162_0204213" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シルヴァローゼ" ]},
		{"command":[ "SETTEXT", "「あぁっ、どんどんスピードが速くなってるっ……あぁっ、何度も、グリグリ \nっ、突き上げられてぇっ……すごいっ、はひぃっ！」", "NORMAL" ]},
