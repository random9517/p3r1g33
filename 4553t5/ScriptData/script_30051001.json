{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0189" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ウチとしたことが、つい童心に返ってはしゃいでしまいましたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003101" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ですが、まぁ……たまには、こうしてビーチを満喫するのも悪くないもので\nす。さて……とは言え、遊びはここからが本番です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ふふっ、あなただってしっかり期待しているんでしょう？　ごまかしてもム\nダです。もう前が膨らんでるのバレバレですから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003103" ]},
		{"command":[ "SETCHARA", "0", "char_00000510_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「全く仕方ありませんね。ほら、こっちに来て下さい。いいから、ついて来や\nがるです。ふふっ、ほらっそこに座るんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……ほうら、やっぱり。見事にオチンポ……ビンビンじゃないですか。\nこれは一体どういうことでしょうね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000510_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「まぁ、そもそも……？　ビーチに来たときからずっと、ウチのことをチラチ\nラ見ていましたよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ええ、もちろんバレバレです。あんな分かりやすい視線、バレてないと思う\nほうがどうかしています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……そんな訳ですから、さっさと観念してオチンポを突き出しやがれで\nす。そうそう……えいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んふふっ、手で優しくしてもらえると思ったですか？　お生憎様ですね、あ\nなたにはウチの足がお似合いですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「こうして、指先で……ぎゅぅっと握りこんで……くくっ、オチンポがビクビ\nクしてますよ。本当に分かりやすい人です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ほら……ここ……強く押し込まれるのがいいんですよね？　ちょっと痛い位\nが好きなんでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んっ……ふふっ、いいですよ……もっともっとしてあげます。欲望まみれの\nオチンポ……いっぱいシコシコしてやりますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「それにしても、節操なく膨らませて……こんな状態でビーチをうろついてい\nたなんて……とんだ変態さんですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ウチが処理してあげなかったら……それこそ、通報されて連行されたとして\nも仕方なかったんじゃありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「こんないけないオチンポには、しっかりウチの教育が必要ですね……んっ、\nふっ……ほら……もっと腰を突き出すです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……また目がギラギラしてますよ……？　そんなにウチの身体…\n…じぃっと見つめて……視姦したいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んっ……そんないやらしい視線をむき出しにされたら……んんぅっ……ウチ\nも、どうにも堪らなくなってきますよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ……！　あっ……はぁぁ……あぁ……濡れてる……んっ、オマンコが\nもう、ヌルって……してます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ダメですよ……お触りはＮＧです。許してあげるのは見るまでだけですから\nね。それが守れないなら、この足コキもやめちゃいますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうです……大人しく指を咥えて見てるといいです……んっ、はぁ\n……ウチは、ウチで……しちゃい、ますからぁ……は、んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んっ……何ですか？　ウチが発情してたら……どうだって言うんですか……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「こんな、オチンポをビンビンにさせて……ウチに足コキさせながら見せつけ\nておいて……興奮するに決まってますよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あふっ……んっ……いいんですよ……？　ビキニの隙間から見えるオマンコ\n……ちゃんと見ていいですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んんぅっ……ウチも、視線を感じるとぉ……いろいろ……捗ってし\nまいます……あふっ、はぁ……んっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ふっ……はっ、んぁっ……くっ、ふっ……ほら、どうですかっ……？　足の\n指が……スライドしてっ……ぎゅっとオチンポに絡んで来てっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「結構……強めにしてるのにっ……これでも、気持ちよくなっちゃうんですね\n……？　変態っ……変態っ……度し難い変態ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、はんっ……何ですかこのオチンポっ……ウチが罵ったら、それだけで\n、またビクンって跳ねて……膨らみましたよっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「こんな開けたビーチで……ウチにシコシコ足でいじられてっ……気持ちよく\nて仕方ないんですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んふぅっ……そんな欲しがりのオチンポには、もっといいことをしてあげな\nいといけませんね……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ふふっ、両足で挟んでぇ……ぐにぐにして……はぁんっ、ダメです……指も\n自然に動いちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ、こ、ここぉっ……クリっ、クリトリスぅっ……あくぅ……ずっとジ\nンジンしてぇ……は、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「そうですよっ……ウチだって気持ちよくなってますっ……こんな風に……ヌ\nルヌルにしてたらっ、分かるでしょうっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んくぅっ……乳首もピンってなってぇ……はぁぁっ、きゅって潰すのがっ、\nあぁっ、気持ちよくてぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……ウチばっかりじゃないですっ……オチンポも我慢汁が止まら\nなくなってるじゃないですかっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「もう出したくて出したくて仕方ないんでしょうっ？　抵抗なんかしないでっ\n……さっさと、ビュビュって……射精しちゃうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ほらっ、あっ、んぁっ、ほらあぁっ……亀頭をぎゅうってしてあげますっ、\nずりゅずりゅっ、シコシコしてあげますからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「いっぱい出しちゃって下さいっ、はんっ、ほらっ……オチンポッ……ドピュ\nってっ……しちゃうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁぁんっ！　出て来ましたっ……んんっ、あふっ……めちゃくち\nゃっ……いっぱい出てっ、んっ、精液っ……掛かってるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んふぁっ、あっ、んんっ……身体に……あぁ……おっぱいにもドロって……\n精液……ねとねとがへばりついて来ます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁ……んふっ……足コキで射精しちゃうなんて……やっぱり、\n変態でしたね……んふふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「でも……まだまだオチンポは、ギチギチに硬いままですね。この位の射精じ\nゃ、まだ満足には程遠いということですか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ほら、どうなんです？　正直に言ったらどうですか？　そうしたら、続き…\n…してあげないこともないですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んふふ……秒で頷きましたね。そんなにオチンポを苛められたいなんて……\nやっぱり変態さんです……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はい……ぎゅうって……オチンポしてますよ……んくっ、足に……出した精\n液……ドロってついちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……指先にニチャって絡んで……これをオチンポに絡ませたら……また\n、ふふっ……もっとねとねとになりますね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……足が滑りやすくなって……んふぅ……指先が気持ちいい……ウチ\nのオマンコも……また、ムズムズして来ました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「さっきはいいところで……止まっちゃいましたから……ウチもオナニー……\nやり直しますね……んっ、あっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁぁんっ……あぁ……ジンジンしてます……内側から……気持ちい\nいの……広がってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んくっ……あふっ……指が止まらないです……はひぃっ……あっ、\nあぁんっ……はっ、んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んふっ……くぅっ……さっき以上にギラギラした視線を感じます……んくぅ\nっ……ダメですよ……お触りは厳禁なんですからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あなたは、そうやってぇ……ウチの足で……オチンポをビクつかせていれば\n……んっ、いいんですっ……あ、ふっ……んぁっ、クリ……すごいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ、んぁっ……その代わり……ちゃんと、オチンポは弄り倒して\nあげますから……んっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……また、亀頭……汁が浮いて来てるじゃないですか……これは、さっ\nきの精液の分じゃないですよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「本当に節操なく溜めて、すぐお漏らししちゃう……いやらしいオチンポです\nっ……こんなの見せられたら……ウチももうっ、はぁっ、んっ……あっ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「イ、イキそうだから何なんですか？　先にイッたのは、あなたなんですから\n、ウチだってイク権利はある筈ですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、くぅっ……あなただって……また我慢出来なくなってる顔して\nますよっ……んふっ、どうなんです？　また、ドピュって出したいんですよね\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「いいですよっ……ほらっ、顔にぶっ掛けたいんですか？　それとも……この\nビキニ？　オマンコ……おっぱい……どこでもいいんですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「オチンポ……グリグリしてっ、あぁっ……ウチの足の指に……お汁……掛か\nってっ……もうすぐ……ですよねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、くぅんっ……ウチも……もうっ、ちょっとで……イキます\nからっ……だからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁんっ、イッて下さいっ……またぴゅぴゅってっ……精液飛ばしてっ……\n思いっきり、射精っ……しちゃって下さいっ！　んぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あっ……んぁふっ……！　あぁっ、掛かってるっ……身体っ……いっぱいっ\n、精液っ……おっぱいにっ……びゅくって……出てますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ……ウチもっ……イッてっ……お汁……飛んでるっ、びゅくび\nゅくってっ……はぁぁんっ……潮吹きしちゃってますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……遠慮しないで……全部出しちゃうです……ウチのビキニをじっと\nり湿らせる位に……いっぱい染み込ませて下さい……んっ……あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あふっ！　また……飛んできました……ふふっ、本当に欲望まみれのオチン\nポです……はぁん……おっぱいも熱い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んっ……搾り出しましたか……？　それなら、後は……先端についた精液も\n……ちゃんとお腹の辺りに擦り付けて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003305" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はふぁ……ねとねとです……ウチの身体……精液まみれにさせて……満足で\nすか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「くくっ、まぁどれだけ強がっても、これだけ射精した時点で何の説得力もあ\nりませんからね……ウチの足コキにメロメロでしたね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「でも、悪くなかったですよ？　精液……たっぷり出して下さいましたから…\n…ウチのお肌、まだピリピリって気持ちいい痺れが残ってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ぴちゃ……んっ、中身も……とっても濃厚ですね……ちょっと味見しただけ\nで妊娠しそうなエキスが詰まってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……そうですね、そのうちそちらを試してみるのもいいかも知れません\n……ね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ひぁぷっ！　んぁっ……顔にっ……どぷって……精液っ、出て来ましたぁっ\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁっ……ウチもイッてますっ……はぁぁっ、オマンコっ……震えてっ\n……お潮っ……飛ばしちゃってますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁ……もっと掛けて下さい……ウチの顔……ザーメンシャワーでベトベ\nトにして……においも……しっかり染み込ませて下さい……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あっ、また……顔に残ってるのが……んんっ……いいですよ、残さず出して\nしまいましょうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁん……出し切りましたか……？　んふっ、ついてる分……全部……ウチ\nのビキニに染み込ませちゃいましょうね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000510_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ……これでいいです……あふぅ……本当に遠慮なく出しました\nね。どうですか、ビーチでこんなに出した感想は？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「くくっ、まぁ何を取り繕っても言い訳にしかなりませんよね。それだけ、ウ\nチの足コキの虜だったということです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「まぁ、ウチとしても楽しめましたよ。ここまで、ドピュドピュ出すなんて思\nいませんでしたからね……ふふ……ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……ちょっと舐め取るだけでも、この喉に絡みつく感じ……たまらない\nですね……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1003409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Aオボロ" ]},
		{"command":[ "SETTEXT", "「ふふ……今度は直接頂いてしまうのもいいかも知れませんね。その時は……\nまた、よろしくおねがいします♪」", "NORMAL" ]},
