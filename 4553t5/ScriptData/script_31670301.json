		{"command":[ "PLAYVOICE", "v2_167_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「しかも、お尻が……ずっと……い、今も……あっ、感じて……は、はい、後\n始末も致します……ん、れろ、ちゅぱ……ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
