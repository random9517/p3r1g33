		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「しゅるっ、じゅぽっ……んっ、いつれもっ、いいろっ……らひてっ、主殿の\nっ……望む場所にっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「わらひもっ、イクッ！　あっ、んちゅぷっ、オチンポしゃぶりながらっ……\nケツ穴っ、震えてぇっ、イ、イクぅぅぅっ！」", "NORMAL" ]},
