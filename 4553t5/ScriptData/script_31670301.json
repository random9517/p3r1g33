{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、くぅぅぅ……あっ、ふっ……んくっ、あっ、あぁっ、はっ、んぐっ…\n…くぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「くぅぅっ……お、おのれ……主殿を騙る偽物め……このように、あっ、私を\n捕らえて……んんっ、どうする……つもりだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「こんなアナルバイブなどっ、んくぅぅっ……鍛えた、私の身体にはっ……き\n、効かないっ、おっ、おほぉっ、し、振動がぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「な、なんで……さっきより、振動が強くっ……んんっ、あっ、あぉっ、ダメ\nだっ……そんなに震わせるのはっ、あっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303104" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んくぅんっ、ダメだっ、あっ、そんなにお尻っ、強くされたらぁっ\n、あっ、あぁっ、イ、イクぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、あぁ……わ、私としたことが……こんなバイブでイクなんて……あ、\nひっ！　ま、またブルブルしてるっ、あっ、あぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ、んっ、こ、これ以上は……んっ、オ、オチンポをしゃぶってイカせれ\nば……振動を止める……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そ、その言葉に二言はないな……？　あ……あぁ、この勃起しているオチン\nポを舐めればいいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「わ、分かった。では……んっちゅぷ……ぴちゃ……んちゅ、れろ……んっ、\nえろ……れろ……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……濃い味だ……ちゅぷっ、んっ、こんな所まで主殿に似せるなんて…\n…んっ、ちゅぷ……れろ……んりゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「お、美味しいなどと、そ、そんなことはない……んちゅぷっ、ふ、普通だ…\n…これは……い、いつもの味だからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「れろ、んんっ！　あっ、ま、また振動がっ……つ、強くぅっ、待ってくれっ\n、あっ、これでは話が……あっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303112" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、わ、分かった……認める……んっ、本当は美味しいんだ……この\nオチンポの味が……大好物なんだ……ちゅぱ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「れろ、んちゅぷっ、は……あぁんむ、れろ……えろ、あぁ……んちゅぷっ、\nはぁぁ……この味……クセになりそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「なら、もっと深く……わ、分かった。ちゃんと咥えるから……は、あぁんむ\n、くぽっ、りゅぷっ、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、りゅぷっ、れろっ、じゅぽっ、んむっ、くぽっ、あんむ……じゅるっ\n、じゅるっ、んちゅぅぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「な、慣れてなど……んっ、んはぁ……くぽ……ただ、口で扱いているだけだ\nからな……んっ、じゅぽっ、んふっ、りゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁ……それにしても、んっ、くぽっ、雄々しく反り返って……あぁ、なん\nて……太いオチンポなんだ……りゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「こんなの口に収まらない……じゅぱっ、りゅぷっ……んちゅぷっ、あぁんむ\nっ、いっぱいに頬張って……んりゅぷっ、ぎりぎりぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、んふっ、りゅぱっ、ちゅぷ、んちゅぷっ……あぁ、この味ぃ……\nれろ、じゅぱっ、んっ、ふっ……あぷ、んりゅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そんな、顔が蕩けてなんか……らい……んりゅぷっ、これは、強制されて…\n…やむを得ず……じゅぽっ、んちゅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303121" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「だが……んりゅぷっ……オチンポ美味しい……それは、んりゅぷっ、認めざ\nるを得ない……あぁ、じゅぱっ、そうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303122" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「私は、こうして……んりゅぷっ、主殿にいつもオチンポをしゃぶらせてもら\nって……こ、興奮している……じゅぽっ、くぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「貴様のような偽物でも……んっ、身体が疼いてしまって……じゅぽっ、はぁ\nんむ、舌が勝手に動いてひまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「じゅるるっ……んふぅっ、あぁ、ちゅぷっ、先走りが浮いてきた……んちゅ\nるっ、この味まで同じなんて……りゅぷっ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁんむ、舌が止まらない……あぁ、主殿のオチンポ汁ぅ……この塩気が…\n…じゅぷっ、んちゅっ……堪らない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303126" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んじゅぷっ、ちゅぱっ、りゅぱっ、んぱっ……んぁっ、ま、また…\n…お尻の震えが……ん、んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「こ、このまま……しゃぶり続けてイカせるまで……と、止まらないっ？　そ\nんな、あ……んりゅぷっ、や、やるっ、やればいいんらろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んんっ、おぷっ、んんっ……！　あぁっ、んんっ、あっ、あぁっ、\nそうだ……ケツ穴の振動……か、感じてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、んふっ、わ、私は……敏感なケツ穴を、震わせながら……オチン\nポに夢中になっている……いやらしい女剣士だっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「こ、この姿は……主殿が求めるから……んっ、それに従って……あぁ、決し\nて露出狂などではないっ、じゅぱっ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「見られて興奮するなど……んっ、そんな変態では……あぁっ、だが、こんな\nに振動させられたらっ、あっ、んぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「じゅぽっ、オチンポも震えて……はぁんむ、イキそうなんだなっ？　あぁ、\n早く……", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、らひてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんんーーーーっ！　んぶっ、ふぐっ、んんっ、れてるっ……んっ、んふっ\n……んくっ、こくんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「全部……ろめっ……？　んんっ、こくっ、んくんっ、こくっ、じゅぷっ、ん\nちゅぷっ、んっ、んくぅ……んはっ、はぁっ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303136" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ、全部……の、飲んだぁ……ちゅぱ……あぁ、舌に濃いのが残っ\nて……んちゅぷっ、は、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303137" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「舌で……綺麗に……？　わ、分かった……んっ、ちゅぷっ、れろ……えろ、\nぴちゃ……んちゅぷ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「どうだろうか、これでオチンポは綺麗になったぞ……れろ、ぴちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「な……べ、別に、楽しんだわけではない……私は、脅されて仕方なく……だ\nな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「え……？　ひ、引き続き……？　あ……ま、まだオチンポが……こんなに反\nり返って……んっ、ごくっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「も、物欲しそうな顔などしてないっ……だ、だが、まだ命令するのならば、\n私は……さ、逆らえないからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んっ、れろ、ぺろっ……あぁ……ちゅぷっ、まだ、さっきの精液の味が残っ\nているみたいだ……んりゅぷ、れろ、ぺろ……んれる……れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んっ、はぁ……りゅぷっ、んちゅぱっ、あぁんむ……じゅるっ、\nんちゅるっ……多分、まだ奥に残っているんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「それを吸い出さない限り……んっ、私は……解放されないという訳だ……じ\nゅるっ、くぅぅ……んちゅぷっ……じゅるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「分かっている……んちゅぷっ、まだまだ元気なオチンポ……ちゃんとしゃぶ\nる……んっ、りゅぱっ、じゅぽっ、ちゅぷぅっ……んちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……んちゅぷっ、れろ……あぁ、舌が……止まらない…\n…じゅぽっ、オチンポの先から奥まで……全部味わって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00016703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、んんっ、もっとおしゃぶりしたい……んぁ……オチンポ、おいひ\nぃっ……喉の奥まで……咥え込むぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んりゅっ、ぐぽっ、じゅぽっ、んふぅっ、あ……あぁ……らめら……みらい\nでくれ……こんな、オチンポを頬張ってる顔なんてぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「自分でも分かってるぅ……んじゅぷっ、こんないやらしすぎる顔ぉ……あぁ\n……恥ずかしいからぁ……んりゅぷっ、じゅぱっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んんっ！　あぁ……ま、またおひりのバイブぅっ……はぁんっ、ダメだ……\nそっちまで気持ちよくなってひまったらぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「わらひはっ、あっ、どんどんおかしくぅっ……んじゅぷっ、オチンポに逆ら\nえなくなるぅっ……じゅるっ、んじゅぷぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「そうだ……私は……オチンポが大好きなっ……淫乱な、あっ、女剣士っ……\n！　はぁん、あぁっ、もっとしゃぶるぅっ……んじゅぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、んちゅっ……れろぉ、あぁ、口のらかれ……オチンポが、またビ\nクビクひてるっ……んじゅぷっ、じわって汁が滲み出してるっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「んちゅうるうっ、じゅるるっ、んんっ、おいひぃっ……先走りぃ……んちゅ\nぷっ、好きな味ぃ……私は囚われの身なのにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「じゅぱっ、敵にこのような辱めを受けて……あぷっ、か、感じてしまうらん\nてぇ……あひっ、お、お尻っ……またバイブがぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_167_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "イグニス" ]},
		{"command":[ "SETTEXT", "「あぁっ、んじゅぷっ、分かってるっ……イ、イカせるからっ、じゃないと、\nわらひもっ……お尻っ、イクからぁっ！」", "NORMAL" ]},
