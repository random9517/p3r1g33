{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "ハロウィン当日、深夜――。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「一応、警戒はしてきたが……驚くほどあっさりと潜入できたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「誰もいない……警備員すらいないな。やっぱり、エファナティカの読みが当\nたったみたいだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023430001" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「皆、お祭りに浮かれてるみたいですね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023430001" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「やっと来たんですのね……本当に来るのかどうか、疑わしかったのですけれ\nど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023430001" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おお、メガデス！！　うまくやってくれたようだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「潜入工作は完璧でしたわ、ですが懸念点が――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023430002" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「話は後だ、ラケシス！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023430003" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「はいは～い。さあさあ、メガデスさん、お着替えしましょうね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023430002" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「えっ、な、なにを……ひあっ、服を脱がさないでください！！　ちょっとっ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023430003" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「あん、暴れないでください。セレーナ、手伝って～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023430003" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「よしきた！！　おらっ、お前もハロウィンにしてやろうってんだよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023430002" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "貴子" ]},
		{"command":[ "SETTEXT", "「なにをわけのわからないことを……ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_020023430004" ]},
		{"command":[ "SETCHARA", "0", "char_00012502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「う……ううっ、これは……なんですの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023430001" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はっはっは、よく似合ってるじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023430004" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「これでお前も本当の仲間だな！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023430003" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「ふふふ、徹夜でデザインした甲斐がありましたね～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023430004" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「徹夜って……あなた方、連絡がつかないと思ったらこんなものを……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023430002" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なにを言う。これも立派な潜入のための変装じゃろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023430005" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「………………まあいいですわ。先ほども言いかけましたが、システムとセキ\nリュティの把握は終わっております。ただ、１つ注意がありまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023430003" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「エファナティカさんの呪術を行うには建物の中央、つまり司令室で行う必要\nがありますが、そこで隊長……カツマさんが残業で働いているんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023430004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……こんな祭りの日に残業？　しかもこの時間まで？　何かの間違いではな\nいか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023430006" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「いいえ、事実です。わたくしもつい先ほどまで手伝っていましたし。疑うな\nら、隊長の出勤表をごらんくださいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023430005" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "今月のスケジュール。カツマ……出勤→仕事が終わるまで。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「……なんだこの地獄のようなスケジュール表記は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023430007" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ちなみに、ここ数日は日中からずっと仕事をこなしておりますが、まだ終わ\nっておりませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023430006" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ハロウィンの催しなどでＥＤＯの人員が警備にかり出されたり、遊びに行っ\nたりして不足がちなところに普段の業務とイベント業務が重なってこうなった\nのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023430007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いやそれはわかるけど……この出勤表は……いつもこんななのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023430004" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「いえ、いつもはもう少しまともなようですが、切羽詰まるとこういう風にな\nるらしくて……ともかく、そのせいで肝心の場所にカツマさんがいるという状\n況です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023430008" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なあ、残っているのはカツマ１人だけなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023430005" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「え、ええ。確認した限りでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023430009" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ならカツマをぶっとばせば問題ないじゃねえか。ついでにカツマをかっさら\nって女王様に献上しようぜ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023430006" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おお、名案じゃ！！　善は急げ、早速向かうぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023430008" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0117" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "「都会の夜景は誰かの残業でできている……なんてな。はは、終わらねえ……\n終わらねえんだ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "PLAYSE", "SE_M_009" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「カツマ、覚悟っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023430007" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおおおおおおっ、なんだなんだっ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ちっ、避けたか。反応だけはいい……だけど、次は外さねえっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023430008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ラケシス" ]},
		{"command":[ "SETTEXT", "「出口は塞ぎましたよ～。どこにも逃げられません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_195_010023430005" ]},
		{"command":[ "SETCHARA", "0", "char_00019503_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「システムも掌握しておりますので警報も鳴りませんし、助けも呼べませんわ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_010023430010" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「もはやお主は籠の中の鳥……大人しく捕らわれるのじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023430009" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「させるかっ！！　やああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_030023430001" ]},
		{"command":[ "SETCHARA", "0", "char_00015605_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「っ！？　なんだっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080023430009" ]},
		{"command":[ "SETCHARA", "0", "char_00000414_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ヒカリ！！　ってなんだその格好！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「定時帰宅してハロウィン仮装パーティーを満喫していたら、緊急のコールが\nかかって戻ってきたのだ！！　そうしたら見知った顔が潜入してるではないか\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_030023430002" ]},
		{"command":[ "SETCHARA", "0", "char_00015605_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヒカリ" ]},
		{"command":[ "SETTEXT", "「これはただごとではないと駆けつけたってわけだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_030023430003" ]},
		{"command":[ "SETCHARA", "0", "char_00015605_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「祭りの最中でも呼び出しに応えるその精神に涙がで、出ますよ……いや、な\nんにせよ助かった！！　とはいえこの人数じゃ勝ち目はない、逃げるぞ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「逃がすなっ！！　あやつらがいると安心して召喚ができん！！　なんとして\nもこの場で始末するのじゃ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100023430010" ]},
		{"command":[ "SETCHARA", "0", "char_00000317_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}