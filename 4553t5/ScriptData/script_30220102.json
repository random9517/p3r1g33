{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「こんなところに呼び出して、一体どうしたんだい？　まさか、先日の爆発の\n件……まだ根にもってたりする？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「怪我はちゃんと治してあげたし、謝罪もしたじゃないか。そもそも、研究に\n爆発はつきものなんだから、しょうがないだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「……えっ？　詫びとして、ボクの初体験の話をしろ……？　じゃないと、キ\nツいお仕置きをする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00002201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ど、どどどっ……どうしてそういう話になるのさ！？　もしかして、あの爆\n発で頭がおかしくなったのかい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「な、なんだい、その目と怪しい手つきは……！　わかった、わかったから！\n　話をするから、まずは落ち着こうじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「こ、こんなところでするなんて……誰か来たらどう言い訳するつもりだい…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002201_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「べ、別にボクは構わないよ……？　ただ、初めてのセックスがベッドじゃな\nいのは……恥ずかしいというか、なんというか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……！　そんなにオチンポを擦り付けないでくれたまえ……！　\n変な声が出てしまうだろう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「やっ、んんっ……！　あっ、うぐっ、はああぁ……！　いっぱい擦って濡ら\nしておかないと、奥まで入らない……？　そ、そういうモノなんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、あふっ……！　で、でも……本当にこんな大きなモノが、ボクの膣内\nに入るのかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「さっきも言ったが、これが初めてのセックスでね……すごく不安なんだ……\nもうすぐ三十路になるっていうのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「年齢なんて関係ない……？　ボクとセックスがしたいからするし、ちゃんと\n気持ちよくしてくれるのかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そ、そんなこと言われたら、嬉しくてオマンコの奥が疼くじゃないか……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ああっ……んっ、ああぁん……！　オマンコが切なくて、エッチな汁が溢れ\nてくるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ふぐっ、んはあぁ……！　つ、ついに挿れるんだね……！　いいよ、覚悟は\nできてるから……一気に、奥まで挿れて……あっ、はあああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっ……んっ、あふっ……！　本当に、オチンポがボクの膣内に入ってるっ\n……！　熱いの、感じちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はぁ、ふっ、んぐっ……別に痛くはないよ……むしろ、気持ちよくて変にな\nりそうだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「初めてのセックスは痛いって本で読んだことがあるけど……痛くないことも\nあるんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「くっ、ああぁん……！　ただ、ちょっとだけお腹がキツい感じがするから…\n…動くのはもう少し待ってもらえると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ふぇ……？　いっぱい濡れてるから、大丈夫って……ちょ、ちょっと……！\n　まだ心の準備が……あぐっ、んふううぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ！　やっ、あひいぃんっ！　いきなり、激しっ……！　やっ、\nああぁ！　変な声、出ちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「な、なにこれっ……！　オチンポが出入りするたびに、気持ちいいのが全身\nを駆け巡ってくるっ……あっ、あっ！　んっ、うぐぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そこっ……！　その浅いところ、すごくいいっ……！　オチンポでズポズポ\nされると、デコボコしたとこが当たって……はああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ひぐっ、んはっ……あっ、んぐっ、んんぅ……！　こんなの、初めて……あ\nっ、あっ！　あっ、頭……おかしくなりそっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「やっ、ああっ……！　なんで……！　か、身体が勝手に動く……！　ボクの\n頭脳でも……全然、理解できない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んんっ、んはっ……！　んく、んあああぁ……！　だ、ダメっ……もう気持\nちいいことしか、考えられないよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、あんんっ！　あっ、んひいいぃ……！　やっ、やめっ……！　ボクの\n弱点ばっかり、擦らないでっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「Ｇスポットのあたりを突かれると……え、エッチな汁が、止まらなくなるか\nらっ……！　身体に、チカラが入らなくなるからぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ひああああぁんっ！？　だ、だから、なんでそこばっかり責めるのさっ！？\n　チカラ入らなくなるって、言ってるじゃないかぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104129" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ボクの反応が可愛いから、もっとイジメたくなる……？　なっ、なにを言っ\nてるんだい……！　こんな、年増女をからかって……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「がっ、あぎっ……！？　こ、今度は奥まで一気に突かれてっ……！？　そん\nな……なんで、急に……あっ、あううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「えっ……膣内で出す……？　それって、赤ちゃん作るってことだよね……！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「やっ……あっ！　んんっ！　ち、違っ……イヤとか、そういうことじゃなく\nて……！　ボクなんかで、いいの……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ボクがいいって……うっ、嬉しいよっ……！　うん……出してくれ……！　\nボクのオマンコにいっぱい出して……妊娠させてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっあっ！　んっ、ふあああぁ……！　子宮が疼いてるっ……！　早く、出\nしてっ……！　出してぇ……！　あっ、ああっ！　くあああぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104135" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はあああぁ……！　あっ、んはあぁ……！　熱い子種が、いっぱい……出て\nるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「すごく温かい……お腹だけじゃなくて、心も満たされる感じがするよ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「これが、セックスなんだね……！　今までに感じたことがないくらい、幸せ\nな気持ちだよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んはっ、んっ……あっ、あひっ……！　嬉しくて、ボクもイッちゃいそう…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ふぐっ、あぁっ、あああぁん！　イクッ……あっ、イクぅ……！　精液出さ\nれながら、イッ……イクッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ふっ、んんっ……初めてのセックスで、膣内出しまでされるなんて……予想\n外どころの話じゃないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「子宮の中が精液でいっぱいだよ……こんなの、すぐにでも妊娠してしまいそ\nうだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それにしても……いつまでこのオチンポは大きいままなんだい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「もっと出したい……？　そうじゃないと、小さくならない……？　そ、そう\nいうものなのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「正直、ボクももっとして欲しいと思ってたから……うん。いいよ……このま\nま、二回戦といこうか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……！　あっ、あああぁ……！　また最初から、そうやって飛ば\nして……！　本当に、底なしの体力と性欲だね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んんっ……あっ、あひぃん……！　今度は浅いところじゃなくて、奥の方を\n責める気かい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104207" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ひっ、あぐっ……おっ、んふううぅ……！　お、奥も……感じるっ……！　\nオチンポのカタチが、はっきりわかるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ボクのオマンコ……弱点だらけじゃないか……！　なんで、こんな身体にし\nちゃったんだろ……あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ、んぎゅうぅ……！　でも、こうして弱いところがあるから……\nいっぱい気持ちよくしてもらえてるんだよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そう考えると……あっ、んふっ、うぐうっ……！　この身体も、悪くないか\nな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それに、自分でもオチンポのカタチがはっきりわかるぐらいだから……締ま\nりも、いいと思うし……ふっ、んふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ふあっ、んはあぁんっ！　お、オマンコの奥……カタいオチンポで、トント\nンされてるっ……！　ひあっ、くはぁぁぁあぁ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「こんなにキツく締め付けてるのに……どうしてそんなに速く動けるのさ……\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「さっき出した精液と……ボクのオマンコから出てる汁が多いから……？　そ\nんな、こと……あっ、やっ、はひいいぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「精液で滑りがよくなったのはわかるけど……！　ボクのエッチな汁が、多い\nだなんてっ……ひぐっ、んふっ、あああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　そこ、気持ちいいっ！　浅いところもよかったけど、オマン\nコの奥も好きっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「そんなに激しく出されながらグリグリされると、またイッちゃうっ……！　\nあっ、あっ！　ダメ……が、我慢できないよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「うああっ、あっ、んああっ！　オチンポがオマンコの奥で跳ねてるっ！　イ\nキたいって、暴れ回ってるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104219" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「うん……！　一緒に、イッて……！　好きなだけ出して……！　ボクのこと\n、真っ白に染め上げてぇ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「くあああぁんっ！　また膣内に出されてるぅ！　子宮の中、もう精液でいっ\nぱいになってるのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「無理やり子宮の奥まで流しこまれて……！　あっ、あぐっ……！　本当に、\n苦しっ……！　んっ、ふぐうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「んんっ、ふぎゅっ……くあっ、ふあああぁ……！　ダメっ……お腹いっぱい\nで、幸せすぎるっ……！　こんなの、またイッちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「もう何回もイッてるのにっ……！　こんなに気持ちよくされたら、イキすぎ\nてバカになっちゃうじゃないかぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はんっ、ひううぅぅ……！　うぷっ、あっ……あううぅ！　イクッ……膣内\n出しされながら、イクッ……イグうううぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あぁんっ……はぁ……とっても素敵な初体験だったよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「その……できれば、またこうしてセックスしてもらってもいいかな……？　\n気持ちよくて、結構ハマっちゃったんだよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ボクが望むなら、いつでも、好きな時に抱いてくれるのかい……？　そ、そ\nりゃ願ってもないことだけど……いいのかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ぼ、ボクたちは恋人同士だから、遠慮しなくていい……？　ちょ、ちょっと\n待って……！　恋人って……えっ……？　ほ、本当に……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ううん……！　すっごく嬉しい……！　こ、これからも……よろしくお願い\nするよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ひはぁっ！　あうっ、んふうぅ……！　オチンポが抜けて……！　んはっ、\nふぐっ、ひゃうぅぅぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「あ、熱いのが、ボクの身体にかかってるよぉ！　こんなの火傷しちゃうっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ああっ、んんんっ！　でも、この熱いの好きっ！　ドロドロの精液ぶっかけ\nられるの、とっても気持ちいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「ボクのこと、マーキングされてるみたいで……なんだか、愛されてるって感\nじがするっ……！　あっ、はああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「膣内出しされるのと同じくらい幸せだよぉ！　んんっ、あっ、はひぃ！　幸\nせすぎて、イッちゃうっ！　あっ、あっ！　イクッ、イグぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「はぁ、んむっ……ふっ、んんっ……ボクの身体、精液まみれだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「膣内からもいっぱい垂れてきて……はああぁ……エッチなニオイが染み付い\nちゃいそうだよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「それにしても、膣内で出さなくてよかったのかい……？　確実に妊娠させる\nためなら、膣内出しした方がいいと思うけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104408" ]},
		{"command":[ "SETIMAGE", "0", "still_00002201_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「膣内出しする機会なんて、これからたくさんあるって……そ、そんなの、ま\nるで夫婦みたいじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サイレーン" ]},
		{"command":[ "SETTEXT", "「えっ……ボクと、結婚する気なの……？　い、イヤなワケないじゃないか！\n　すっごく嬉しいよ！　ああ、なんだこれ……！　夢みたいだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_0104410" ]},
