		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「来たか……うむ、その……つまりだな、貴様を呼んだのは他でもない……そ\nの、色々とあってだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503101" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「何となく察しはついているんじゃないのか……？　まぁ、そういうことだ…\n…その、分かるだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「わ、分からない？　うぬ……貴様っ、そんなに鈍いことでどうするっ！　だ\nから気配りが足りないというのだっ、そんなことでは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503103" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「な、何……？　直接私の口からだと？　くっ……さては貴様、全て分かって\nいて……い、いいだろうっ、ちゃんと言ってやる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「貴様に開発された……か、身体が疼くんだっ！　だからっ、その……奉仕を\nっ、だなっ……させてやらなくも……いや」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503105" ]},
		{"command":[ "SETCHARA", "0", "char_00000125_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「私が……貴様のオ、オチンポに奉仕をしたいのだっ！　だからっ、私の身体\nを好きにするが……ひゃあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、こらっ！　いきなり押し倒すとはっ……もう少しデリカシーというもの\nを考えろっ、あっ、んぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503107" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000125_01_02" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふ……全く強引なんだからな……こんな時ばかり、手際よく服を脱がせて\nっ……あっ、も、もう挟んでくるのか……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……すごいな……貴様のオチンポも、もうこんなに大きく……はっ、あ\nぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んんっ……あぁっ、遠慮なく……おっぱいが揉まれてるぅ……うっ、んっ…\n…あふっ……あぁっ、やっぱり……上手い……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、そうだ……貴様がしつこく開発するから……多少乱暴にされても……\nか、感じやすくなっているんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「は……んんっ……オチンポが……めり込んでくる……うぅ……目の前で、ひ\nくひくしている……んふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「これは、期待しているんだな？　んっ……私のおっぱいで気持ちよくなりた\nいから……興奮しているんだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「……っ、そうだ……私も同じ状態だ……貴様の……太いオチンポを見て……\nあぁ……このクサいオスのニオイを嗅いで、興奮してるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……ダメだ……我慢できない……んっ、ちゅぱっ、れろ……んふっ……\nんりゅっ……んちゅ……あっ、んむっ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……舐めてしまった……あぁ……私としたことが、我を忘れて…\n…だが……このオチンポの味ぃ……れろ、ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、しょっぱい……不思議だ……絶対に美味いものではないのに……んっ\n、りゅぷっ、舌が……止まらなくなってしまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ、んちゅぱっ……舐めれば舐めるほど……あっ、んふっ、身体の内側が\n熱くなって……はぁんっ……ムラムラする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぽっ、ちゅぱっ、んちゅぷっ……もっと……あぁ……おっぱいを使って\nいいぞ……んっ、いや……使って欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁぁっ！　そうだっ……あぁっ、ぎゅっと押しつぶして……私のおっぱい\nで……オチンポを扱いてくれ……あぅっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……熱いのが……擦れるぅ……んくっ、あっ、うんっ……オチンポと\nおっぱいが……ずりずりしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、これでは、まるで……オナホールにされているみたいだ……\n私のおっぱいが……道具のように……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「でも、んくっ、気持ちいい……はぁっ、んっ、ぎゅって握りしめられるの…\n…くぅっ、ゾクゾクするぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁ……んっ、またオチンポ震えてる……待ってろ……今……ちゅぷっ、気\n持ちよくするからな……れろ、んりゅ、ちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……んちゅぷっ、どうだ……？　んっ、気持ちいいか……？　んふっ、\nあぁ……れろ……舌が敏感なところ……舐めてるらろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んじゅっ、ちゅぷっ、はぁっ、ぴちゃっ……あっ、んんっ……！　はぁんっ\n、そうだ……ち、乳首も……好きにして……いいぞっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅぷっ……！　ぴちゃっ、んりゅっ……くぅんっ……コリコリされてぇ\n……あっ、んんっ、ひ、引っ張られてるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ぼ、勃起……う、くぅっ……そうだ……んっ、貴様のオチンポのように……\n私の乳首も勃起してしまってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「そうやって、指で……あっ、転がされると……くぅんっ！　き、気持ちよく\nなってしまうんだ……はっ、あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んむっ、ちゅぷっ、ぴちゃっ、えろっ……れろぉぉっ、ちゅぱっ、んちゅぱ\nっ……あぁ……んちゅぷっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503130" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふっ、貴様も感じているみたいだな……んれろっ、分かるぞ……んちゅぱ\nっ、その顔……それにオチンポの震え方もな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ……こんなに素直なオチンポを見ていると……もっともっと、してあげ\nたくなってくる……ちゅぷっ、んちゅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ぴちゃっ……んっ、れろ、この筋のところも……んっ、割れてるところも…\n…んふっ、ビクって震えて……バレバレだ……ちゅぷ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、えろ……あぁ……先走りも、かなり滲んで来たな……んちゅ……れろ\n、そろそろ……射精したいんじゃないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ちゅぷっ、分かってると思うが……出す時は……このまま、私の舌に出すん\nだぞ……？　れろ、新鮮なザーメンを味わわせるんだ……いいな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ、その為に……こうして奉仕をしているんだからな……あんむっ、ぴち\nゃ……んちゅぷっ、ほら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、そうだ……ぎゅっとおっぱいを掴んで……はぁっ、もっと激\nしく擦り上げてっ……そのまま……出してくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ、あぷっ！　んっ、ちゅぱっ、出たっ……はぷっ、精液っ……い\nっぱい……出てるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぷぅぅ……はぁ……あぁ、この味だ……んんっ、美味くない\nのにクセになる味ぃ……んちゅっ、ちゅぷぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「ふはっ、はぁっ、はぁっ……あぁ……濃い……こくんっ、んんっ、喉に絡む\n……んんっ、濃厚ザーメンだぁ……はぁ……んふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ、んっ……ちゅぷっ……れろ……んふぅ……んぷ……あ……れ\nろ……終わったか……いや、まだだな……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、れろ、ぺろ……射精は落ち着いたようだが……私の方は……精液を味\nわって、もっと発情してしまったんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「だから……もっと、オチンポ……舐めさせてくれ……ちゅぷっ、んぁ……は\nむ、ぴちゃ、れる……れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……えろ……れる、ぴちゃ……んんっ、ザーメンと……オチンポ\nの味が、混ざって……んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「れろ……んりゅっ、そうだ……あぁ、れろ、クセになる味ぃ……れろ、舌が\n……伸びて、ぴちゃ……んっ、もっと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「えろ……い、いやらしい顔なんて言うな……分かっているっ、自分でも……\nこんな発情顔を晒すなど……恥ずかしいのだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「だが、んっちゅ、れる……お前の……オチンポが目の前にあったら……そう\nなるんだ……もう、勝手に身体が反応するんだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……おっぱい……ギチギチにしこってる……んふっ、また、コリコリ\nってして欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「あぅんっ！　そ、そこだっ……あひっ！　あぁっ、わ、私のおっぱいがっ…\n…ぐにゃぐにゃにされてっ、乳首も一緒に……んあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503209" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁんっ、オチンポも来てるっ！　谷間の中でっ……あっ、グリグリっ……\n動いてっ、くひっ、んっ……んひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「くぅ……んっ、気持ちいいっ！　あんむっ、ちゅぷっ、ヌルヌル滑る……お\nっぱいとオチンポの感触が……たまらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「んふぅっ、構わないぞっ……もっと荒々しくっ、あぁっ、そうだ……乳首も\n引っ張るくらいでいいっ、それぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んんっ、ピリピリ来るっ！　あぁ……ダメだ……ご奉仕にならない\nっ、んっ、全部貴様に支配されて……おっぱいがいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000125_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈルナテミス" ]},
		{"command":[ "SETTEXT", "「私は……ハイパー……ルナテミスっ！　あうっ、フルムーンの……筆頭でっ\n……同時にっ、貴様のオ、オナホールっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_2503214" ]},
		{"command":[ "WAITINPUT" ]},

