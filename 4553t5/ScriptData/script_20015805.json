{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_007" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「全ての交通安全とカツマちゃんのためにっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023790001" ]},
		{"command":[ "SETCHARA", "0", "char_00011105_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「一度火が入ったら周りが見えなくなる癖、直しなさい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023790001" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「Ｍ．Ａ．Ｍ．Ａさんが抑えてくれているうちに……隊長、どこですか隊長！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひいっ！！　もう俺を追いかけてこないでくれえええええっ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「１度は私たちを味方だと認識したのに……相当追いかけられることがトラウ\nマとなっているんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「まあ、あんな止められ方をすれば、致し方ありません……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ともかく、捕まえましょう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790003" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、私ですぞ。辛いときも寂しいときも哀しいときも寒いときも共にい\nたジュンジローでございますぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「何が一緒だ！！　お前俺を見捨てたりするじゃねえか！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ぐうの音も出ませんな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023790003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「反論してください！！　もう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790004" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長、私です！！　ピースムーン・ソレイユです！！　私は先ほど恋の病に\nかかってないって見ましたよね！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790005" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「１度落ち着いてください！！　隊長の追われる原因を解決できますから！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790006" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「それとも、いつもあなたの手伝いをして補佐している私のことも信じられま\nせんか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790007" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、ご主人が足を止めました。ソレイユ殿、ここからですぞ。ゆっくりと\n、確実に警戒心を解いて捕らえるのです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023790004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「野生のご主人をゲットするには、細心の注意が必要です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023790005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ちょっと静かにしててください！！　隊長、大丈夫、大丈夫ですから。私は\n味方です。ただのピースムーンだった頃からずっと、隊長の味方です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790008" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……本当か？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私はいつだって隊長の味方ですよ。隊長がどんな風になったって、ずっと側\nにいます……信じられませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790009" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……分かったよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、頑なだったご主人の心が氷解しましたぞ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023790006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前後で覚えておけよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ともあれ、ニャンコ先生のところへ戻りましょう。あの人が薬を用意してく\nれているはずです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790010" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「分かった。ソレイユ、ありがとな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「い、いえいえ。隊長の補佐役として当然ですから！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790011" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ニャンコ先生殿はあちらにいるようですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023790007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「えっと、これは人間をミュータントにする薬、これは服を溶かす薬、これは\n全身の痛覚をむき出しにする薬」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790001" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "4", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「どこにいったかな……ん、これは男を女にする塗り薬。なあ、これでも解決\nするんじゃ――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790002" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そんなわけないでしょう！！　真面目に探してください！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790012" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「お、おお。すまない。えっと……あ、あったあった、これだ。反転薬！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790003" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それを飲めばこの騒動は収まるのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「少なくとも、追われることはなくなる。反転薬、つまり好意が嫌悪に変わる\nからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790004" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「嫌悪って……嫌われるってことか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「まあ、そうなる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790005" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「極端すぎる……俺の人生に救いはないのかよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「救いはどうかは分からないが、少なくとも時間はないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790006" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あん？　なにを言って――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「見つけた！！　こんな所まで逃げてたか！！　さあカツマ、私と共に並び立\nつぐらいまで特訓で鍛えてやる！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前が立派な男になったら、母上も２人の仲を認めてくれるだろう……！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「悪いがそうはさせない。カツマは私と共に生きるのだ。次元を越えて、時間\nを越えて……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマは渡さない……私だけのカツマにする！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん、子供は３人でいいですか？　もちろん、あなたが望むなら何人\nでもいいですけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023790001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんだかまりあ殿だけ方向性が違いますな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023790008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そんなことを言ってる場合ですか！！　隊長、さすがにこの人数を相手に私\nは持ちこたえられませんよ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790013" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええい……どうしようもないか。くそっ、薬をくれ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はい。水も用意しておいたぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790007" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPIMAGE","1", "TRUE" ]},
		{"command":[ "SETIMAGE", "1", "bg_0000" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……効果、出たのか？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "FADEOUTIMAGE", "1", "VERYFAST" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「……………………私は何を……カツマ、いや、下僕にあんなことを……不愉\n快だ！！　帰る！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023790003" ]},
		{"command":[ "DISPIMAGE","1", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「むう……今のカツマを見ているとなんだか妙な気分だ……私も帰還して休む\nことにしよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「あう……カツマの側にいたいのに、なんだかいてはダメなような……おかし\nい、一時撤退します！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「う……うふふふふふ、私の愛は薬ごときでは……しかし今カツマさんの側に\nいると心にもないことを言ってしまいそうです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023790002" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん、この続きはまたいずれ……ううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023790003" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はは……好かれてるから一転して嫌われるか。まあ、俺らしいな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「嫌われるというよりは、むしろあの方々の愛の深さを見せつけられたような\n。とくにまりあ殿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023790009" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ま……まあ、事件自体は落着したじゃないですか。それに隊長、元から影響\nのなかった私たちはそのままですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790014" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういやそうだな。個人差があるのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ね？　私は隊長の側にいたでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790015" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「はあああああああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023790002" ]},
		{"command":[ "SETCHARA", "0", "char_00011105_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「やあああああああああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023790002" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「あの２人のことを忘れていたな。そろそろ止めなければ被害が大きくなる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790008" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「それならもうカツマちゃんの身体は無事なのね。よかったわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023790003" ]},
		{"command":[ "SETCHARA", "0", "char_00011105_01", "6", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうみたいだな。色々と世話をかけた」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「いいのよ。カツマちゃんを乗せて走れたんだもの。一足早いホワイトデーだ\nわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023790004" ]},
		{"command":[ "SETCHARA", "0", "char_00011105_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういやもうバレンタインデーだったか。恋の病ってなあ……いかにもな病\n気だけど」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「モテとか非モテとか関係なく、普通の生活がしたいよ、俺は……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ＥＤＯに所属している限り、それは不可能なのでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023790010" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ここは色んな勢力の人たちが集まりますからね……毎日どこかしらでトラブ\nルが起こっていますし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790016" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんはそれを仲裁したり解決したりしているものねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023790003" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「言わないでくれ……哀しくなってくる」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「はははははっ！！　禍福は糾える縄の如し、そう悲観するものでもないさ。\n悪いことがあればいいこともある」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790009" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうだな……せっかくここまで出てきたんだ。手始めに皆でドライブにでも\n行かないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790010" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「美女たちとのドライブ。これはいいことじゃないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790011" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「自分で美女っていうなよ……ま、でもそうだな。たまにはいいか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ａ．Ｍ．Ａ" ]},
		{"command":[ "SETTEXT", "「じゃあＭ．Ｏ．Ｅちゃんも含めて皆で私に乗りましょうか。ドライブは道中\nのおしゃべりも魅力でしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_010023790004" ]},
		{"command":[ "SETCHARA", "0", "char_00021203_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ．Ｏ．Ｅ" ]},
		{"command":[ "SETTEXT", "「本音を言えばカツマちゃんを乗せたいけど……ちょっと燃料を消費しすぎた\nし、そうしましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_111_010023790005" ]},
		{"command":[ "SETCHARA", "0", "char_00011105_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ニャンコ先生" ]},
		{"command":[ "SETTEXT", "「そうと決まれば早速行こう。さあ乗った乗った！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_100_010023790012" ]},
		{"command":[ "SETCHARA", "0", "char_00010010_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あの、隊長……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790017" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん？　どうしたソレイユ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「これ……どうぞ。Ｍ．Ｏ．Ｅさん達からももうもらっているかも知れません\nが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790018" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え……これって……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「チョコです。隊長のために、ちゃんと選んできました。恥ずかしいので、メ\nッセージは後で読んでください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790019" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お……おう」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「部下からのチョコレート。これもいいことじゃないですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790020" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……そうだな。ありがとな、ソレイユ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ずっと味方だっていう言葉、本当ですからね。さ、それじゃあ行きましょう\nか。ドライブに！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790021" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETIMAGE", "1", "bg_0194" ] },
		{"command":[ "DISPIMAGE", "1", "true" ] },
		{"command":[ "FADEINIMAGE", "1", "NORMAL" ] },
		{"command":[ "SETTEXT", "私がチョコレートに込めた意味。", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790022" ]},
		{"command":[ "FADEOUTCHARA", "0", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "それを隊長がどう受け取ったのか。", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790023" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "はっきりさせるのは、まだまだ先のようだった。", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790024" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "それでも、少しずつでも進んでいけばいつの日かきっと。", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790025" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "ともあれ、今日の所は――", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790026" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "ハッピーバレンタインです、隊長。", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023790027" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}