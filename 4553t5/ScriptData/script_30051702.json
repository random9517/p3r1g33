		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「全く……こんな時にウチを呼び出すなんて、一体何の用事ですか？　言って\nおきますが、ウチはそれなりに忙し……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704101" ]},
		{"command":[ "SETCHARA", "0", "char_00000517_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ひゃぁぁっ！？　ちょっ、な、なんですっ！？　えっ、えっ、ぬ、脱がして\nっ……あのっ、まっ……きゃぁぁあん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704102" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000517_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「うぅっ……どういうつもりなんですかっ……いきなり問答無用で迫ってきた\nと思ったら、こんな格好させて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「すごくムラムラしたから……直球にも程があります……もう少しオブラート\nに包む気はないんですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「だいたいウチは……するなんて一言も……うぁっ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ど、どうなってるんですか……まだ何もしてないのに……そんなにオチンチ\nン勃起させて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「いくらウチに……そ、そういう機能が備わってるにしても……節操がなさす\nぎませんかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ウチが魅力的で仕方ないから……い、いやいやっ、そんな調子のいいことを\n言っても、それとこれとは……ひぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「やめ……わ、割れ目のところ……擦りつけないで下さい……ああぅっ……ほ\n、本気……なんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ウチだって……その、こ、心の準備といいますか、こういうのは、色々と然\nるべき手順というものを踏まえるべきで……んひっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あっ……あぁぁぁぁぁぁっ……！　奥にっ……あっ、ひぃぃぃっ……は、入\nってぇっ……あぁぁぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「やっ、らっ……お、っきぃっのっ……そんなっ、一気に、お、奥までぇぇ…\n…ふ、ぁぁぁぁぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ちゃんと……濡れてたって……それはっ、元々……そういう風になっている\nからでっ……だからって、こんな不意打ちはっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　あぁっ、ぐりって来るぅっ！　オ、オチンチンっ……こつんっ\nて……うっ、ひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あぁぅ……あ、はぁ……イ、イッたワケじゃ……た、ただ、ちょっ\nと……ビクってしただけで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ひ、ヒクヒクなんてさせてません……違います……ウチの意志じゃなくて、\n自然にボディがそうなっただけで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁんっ！？　はっ、あぁっ、ちょ、ま、まだ話の途中っ……！　あ\nっ、あぁっ、そんなにオチンチン動かしたらっ、あ、ひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぅっ、うぅんっ、くぅんっ……ま、待ってっ……あっ、下さいっ……はん\nっ、あぁっ、ほ、本当に……このまましちゃうんですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「て言うかっ……もう、あっ、普通に……あぅんっ、し、しちゃってますよね\nっ？　オチンチン……こんなに盛ってっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ま、まだしていいとは言ってないのにっ……こんな一方的なのはっ、ど、ど\nうかと……思いますっ……あっ、そこっ、あっ、あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あっ……ち、違いますっ……今のはっ、気持ちいいっていうのじゃなくてっ\n、そのっ……自然にっ、あっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「声が出るのはっ……仕方ないんですっ……はっ、んっ、こんなの……どうし\nたって、出るに……決まってますっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んぁっ、はぁっ、あぅっ……ねちっこい……ですっ……ゆ、ゆっくりなのに\n……んっ、奥の部分にしっかり押し付けて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、弱いところ……はぁっ、うっ……確かに……今してる場所は……んっ\n、他のところより……いい、かも知れないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あぅんっ！　だ、だからって……ねちねち……んんっ、同じとこっ、あっ、\nばかりぃ……しつこくぅ……あっ、はっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704125" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「べ、別に……違うところもして欲しいって意味じゃ……やっ、あっ、なに…\n…おっぱい弄ってますかっ……ひゃんっ、そこっ、うなじ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「やばい、です……これ……あぁっ、た、ただ突かれてるより……あっ、あぁ\nっ、すごい……か、もっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んんっ、喜んでるわけじゃっ……あひっ！　あぁっ、またオチンチンっ、あ\nぁぉっ、ぐちゅぐちゅしてっ、は、ひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、はぁっ、あんっ、あぁんっ……ま、まだ奥に届いてぇっ……んぁっ！\n　そこっ、あっ、腰が……砕けっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「す、すみません……あぁ……か、片足で支えるのは……大変で……せめて、\nもうちょっと普通に……あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ちゃんと支えるって……そういうことじゃ……あんっ、あぁっ、ずりゅずり\nゅっ、らめっ……あんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、そこはっ、ほ、本当に弱いんですっ……気持ちっ、よすぎて\nっ……はっ、ひっ、ウチの弱点っ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、だからっ、そんな……休みなくっ、するのはっ、はひぁんっ！　\n本当にイ、イッちゃいますっ、からぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁっ、あぁっ！　イッて……いいって……本気のオチンチンっ……！\n　またっ、激しくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「イ、イクっ、イッちゃいますっ！　あぁんっ、オ、オマンコっ……ウチのオ\nマンコがっ、イ、イキますからぁっ、あっ、あぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あひぃぃぃぃぃっ！　あぁっ……中っ……あっ、出てっ……そんな、いきな\nり射精っ……あっ、あぁぁぁっ、イクぅぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「な、何も言わないで……いきなり中出しなんて……そんなの……んくっ、イ\n、イクに……決まってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……熱いの……まだ、出てる感じ残ってます……ふぁぁ……んっ、オチ\nンチン……大きい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……射精……止まった……んっ、終わりましたか……？　全部…\n…出したんですね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あふっ……あぁ……お腹の中がドロドロです……んふっ……オチンチン……\nすごかった……です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んっ……満足されましたか……？　もう、何もかも性急なんですから……ウ\nチにも都合というものが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「って……どうして、何事もなかったかのように、また腰を動かし始めてます\nか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「こんなにドロドロになるまで出しておいて……まだ出し足りないと？　うぅ\nっ……どこまで、お猿さんなんですか……理解できません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「……はぁ……でも、どうせ言っても止めるつもりはないんでしょう？　もう\n何でもいいですから、早く終わらせて下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、ふっ……んんっ、今度は、妙にゆっくりですね……んんっ、さっきみ\nたいに激しくしないんですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ち、違いますよっ、そうして欲しいワケじゃなくて……やり方が変わったか\nらどうしたのかと思って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、お許しが出たから……じっくり……本当にあなたという人は……んん\nっ……それなら、それでいいですけど……あっ、んっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「まだ、この格好のままなんですかっ……ちょっと疲れてきましたし……は、\n恥ずかしいんですけど……あっ、ぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「それがいいってっ……よくないですっ！　あぁっ、こ、こんな……繋がって\nるところ……全部見せちゃうようなポーズっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ウチは……犬じゃないんですっ、はんっ、あっ、あぁっ……見せびらかした\nくなんか……ないですからっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「そ、その方が興奮するなんてこと……絶対に、あんっ……あっふ、また、い\nやらしい触り方ぁ……あっ、乳首……そんなにぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「やだ……んっ、いつも以上に……感じやすくなってる、みたいな……んふぅ\nっ……あっ、あぁっ、はうんっ、どうして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あんっ……色っぽいとか……ヘンなこと言わないで下さいっ……射精したく\nなるって……だったら、さっさと出したらどうですかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「おねだり……って……んくっ、どういうやつですか……ウチに……出して下\nさいとか……そんな感じのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「もっと心を込めてって……はひっ！　あっ、んんっ、注文が多いですねっ…\n…そう言われたって、どんな風にすればいいのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んあっ！？　あっ、あひんっ！　またっ、オチンチンが……中でっ、グリグ\nリっ……つ、強くぅっ、はぁぁぁうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あんっ、気持ちを高めてっ……感じるままに……お、おねだりっ？　はぁっ\n、あぁっ、これ……もうっ、ウチの方が……イキそっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んあぁっ、あっ、はぁんっ！　あっ、かき回されるぅっ！　あひっ、そんな\nにされたらっ、あっ、い、今……おねだりっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ、はいっ、イ、イキますっ！　ウチのオマンコっ……！　また気持ち\nよくてイッちゃいますからっ、い、一緒にイッてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「中でもっ、身体でもっ、いいですからっ！　ウチに出してっ！　精液っ……\nいっぱいっ、出して下さいっ、はぁんっ、ウチもイキますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んんんんんーーーーーっ！　あぁっ、また……中に出てますっ……あぁぁぁ\n……続けて中出し……されて、ますぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁぁ……オマンコ……熱いっ……あぁっ、ま、また冷却液が……漏れち\nゃいそうに……あぁ、ドクドクってぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あ、ふっ……溢れてきちゃいます……オマンコ……入り切らないぐらい出す\nなんてぇ……ふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「これで出し終わりましたか……？　最後にもう一回……んんっ！　は、はい\n……出ましたぁ……あふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、あぁ……はい、ウチも一緒にイキました……イカされ\nました……まだ、頭がクラクラしてます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、でも……流石に強引過ぎると言いますか……何もかも急で、ウチとし\nては納得の行かないところが多いです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「こんな、後ろから動物みたいに……いえ、動物だってこんな片足上げた状態\nでしたりしないですっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「でも、いつもした時よりも……気分が高揚したような……もしかしたら、ウ\nチは……強引に……荒っぽくされる方が好きなのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、ち、違います……気のせいですからねっ！　だから、ニヤニヤするな\nですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「とにかく……こんなやり方は、他の子にしたらダメですよ！　ウチには……\nまぁ、その……よ、余裕のある時なら……一応……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁんっ！　あぁっ、オチンチン抜けてっ……はぁっ、精液っ……身体\nにっ、出されてますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んふぁぁ……お尻にっ……んんっ、背中ぁ……お、おっぱいまで……あぁ…\n…ネバネバが纏わりついて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ……んんっ、お肌に染み込みます……イッて敏感になってるところに\n……じんわり浸透しちゃいますぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ま、まだ出てませんか……？　どれだけ絶倫なら気が済むんですか……はぁ\n、んふっ、これで最後の最後……本当ですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はふ……はぁ、はぁ……あぁ……やっと終わり……集中的に何回もイッて…\n…おかしくなるかと思いました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「全く……欲情スイッチが入ってからここまでが早すぎます……！　ほとんど\n思いつきだけで動いて、ウチをいいようにして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ウチにも心の準備というのがあるんですからっ。メカだから好きにしていい\nとか思ったら、大間違いなんですからね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ま、まぁ……多少強引に迫ること自体は……ドキドキするところもあるし…\n…ウチ自身は絶対ダメという程でもないですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、ち、違います……これが好きとか、そんなんじゃないですよっ！　本\n当ですからねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「また次もこんなことになったらっ……う……えと、それは……まぁ、考えな\nくも……ないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1704410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}