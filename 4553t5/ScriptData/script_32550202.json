{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0127" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁあぁっ♪　良かった……！　よく来てくれましたね、私の貴方……♪　\n待ち焦がれてどうにかなってしまいそうでした……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204101" ]},
		{"command":[ "SETCHARA", "0", "char_00025502_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「さきほど、これを飲みました。ボニューデマクール……ふふ、そうです。知\nっての通り、この秘薬を摂取すればすぐに乳房から母乳が分泌される……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「その、副作用でしょうか。身体が熱くて、落ち着かなくて……。一刻も早く\n会いたかったんです。んっ……こっちに来てください。それから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204103" ]},
		{"command":[ "SETCHARA", "0", "char_00025502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「そのいきり勃ったおちんちんを、私の股の間に挟んで……。あっ♪　そう、\nです……♪　このまま後ろから、激しく交わりましょう。いいですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あ……♪　んッ、ふぅっ……。はぁっ、はぁ、はぁ……♪　おかしいですね\n……。以前にした時よりもずっと、おちんちんが逞しく、なっています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00025502_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方はまだ成長期の真っ最中ということでしょうか……♪　んんっ、若くて\nうらやましい限りです……。ふふふ、まだ挿入はまってくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ええ♪　私も……すぐに入れてほしくて、オマンコも脚も、期待の愛液でだ\nだ濡れです。貴方のおちんちんも、破裂寸前に昂っているのもわかります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「です、が♪　最大限まで焦らしてから挿入された方が……っ、んふっ♪　じ\nっくりと粘膜をこすりあわせて、互いに一番敏感になってからの方が♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204108" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「多く母乳が出せるそうなんです……。あっ……♪　まだダメなのか、ですか\n？　うふふ、せっかちさん……まだですよ、まだ……♪　ま、だ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「本当に耐え切れなくなるまで……あっ♪　こう、やって♪　素股で高め合い\nましょうね……。んん……、ふ、ぅ……♪　くぅ……んん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「うふふふ、偉そうなことを言っておきながら、私の方が切なそう、ですか？\n　ええ……そうですよ、もう貴方が来る前から濡れて乱れてしまっています」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「だから……。んぁんんっ♪　すごくおちんちんがニュルニュルしますよね？\n　私の愛液ぃ……たくさんおちんちんにまとわりついて……あっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んふ……♪　入れたいですか？　腰をカクカク揺すぶって、私の割れ目に亀\n頭をなんとかもぐりこませようと必死になっていますね……♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「だ、め、ですけど……♪　もっと強くクチュクチュと花弁を往復していたら\n……間違って入ってしまう可能性も♪　あり、え、ますよね。にゅぷぷぷって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ぐちゅうぅううっ♪　っておちんちん……♪　はぁっ、はぁっ、はぁっ、愛\n液でぬめって勝手に挿入されてしまうかも……！　ッふっ♪　うぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……ここまで煽られて、おとなしくしているつもりですか？　はぁ、はぁ、\n遠回しに誘っているんですよ。許可なしでハメてくださいと……んああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「は、ぁッ♪　あああああっ！？　んああああっ！　うぅうぁああっ♪　あぁ\nっ、ああああっ♪　入れ、ましたね♪　強引に挿入しましたねぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204117" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ああっ♪　ああっ、あっあっあっ！　んふふふっ♪　怒っているんですかっ\n♪　私の腰を掴んで……後ろからズプズプおちんちんを出し入れしてっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「完全に中にっ♪　オマンコに深々と突き刺さっていますよぉおおっ♪　あぁ\nあっ♪　言い訳もっ♪　できないくらいっ……！　あぁぁんっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「そのっ、自己中心的な……乱暴なピストン……っ♪　あぁダメ、ダメです、\nイキます……イッてしまいます、イクぅ……！　イカされますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んふぅううううっ！　おっぱいっ！　おっぱい出ましたぁ♪　そうですか、\n絶頂すると出るんです、ねぇっ♪　ぴゅぴゅっ、ぴゅっぴゅって……ぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んぁふうううっ！？　あらっ！？　これ、全然止まりません……！　あっ！\n　あっあっ！　おちんちんが往復するたび、たらぁ、たらぁって垂れてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204122" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あっあっあっあんっ！　私の感度が上がりすぎているから！？　しっかり粘\n膜の準備をしたことで……！　くぅうっ！　乳首の反応が暴走して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁんんっ！　漏れてる、出てる……！　おっぱいミルク、ぴゅぴゅって出\nてます……！　あっ！　あっ、イクたびに……！　ふぁっあっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「い、やぁあああ♪　びゅぶって♪　精液みたいに乳首から母乳が溢れて……\n飛び散って……！　こんな量、恥ずかしい……あぁっ、卑猥すぎますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んぁっ♪　あぁ、あぁ……ひぁああ……♪　奥の奥までおちんちん挿入され\nて……あっ♪　膝はガクガク、胸からは母乳……♪　こんなことって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁうう♪　想定よりもいやらしい、姿にされてしまいましたね……っ♪　\nでも、でも、これで貴方が喜んでくれるなら……私は、私はぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……んっ？　貴方の世話を焼くふりをして、本当は自分がこうやって乱れて\nみたかったのだろう、と言うのですか……？　あッ、答えられませんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんっ、んんっ！　い、言わないでください……！　あっ♪　え\n？　オマンコの締めつけが強くなった？　そ、それはぁ……！　あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204129" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ち、がうのぉ……っ！　本当に、私は心から……！　貴方っ、を幸せにした\nくて……！　んぁんんっ！　や、やぁあ♪　そこ、そこえぐらないでぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「そ……そうです！　認めます！　あんっ！　あんっ、わ、私は……私は！　\nボニューデマクールを飲んで、こうして誘惑すれば……あっあっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204131" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方が私にむしゃぶりついてきてっ♪　こうやって、後ろから容赦なく犯し\nてくれるって、めちゃくちゃに抱いてくれるってわかっていて誘ったの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「欲しかったのぉっ！　貴方のおちんちんっ、欲しくて欲しくてずぅっとオマ\nンコヒクつかせてたのぉっ！　ちょうだいっ、だからちょうだいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ふッ♪　あっ！？　あぁあああ～っ♪　あぁっ♪　あぁんん♪　あんッ♪　\nあんっ、あぁんんっ！　この体勢……すごく奥まで届いて……気持ちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ゴリゴリ子宮口を突き上げられて……あぁ、脚に力が入らなくなると、更に\n刺さって……あっ！　だめ……だめ、イッてしまうわ、あぁイクっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「貴方も……貴方もイッてぇっ♪　お願いよ、絶頂する時に貴方の精を、その\n熱いほとばしりを感じたいの……！　子宮でちゅうちゅう吸いたいのぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「出して……！　出してぇ♪　真っ昼間の学園長室でっ、密会して、あやしげ\nなお薬を摂取して！　乱れに乱れている私にお仕置きしてぇっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っくふぅううううううう……ッ♪　ああああっ！　ああああっ、出てます…\n…っ！　あっ！　本当に同時、に♪　射精、射精、届いてますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っあぁあああッ♪　絶頂でビクビク痙攣しているオマンコに染み渡るような\n熱い精液……っ♪　は、ぁ、ぁ♪　一瞬失神してしまいそうに、なって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「腰が抜けてしまいそう……っ♪　んぅっ♪　んんんっ♪　んふぅううっ♪　\nいいのっ、中出しされながら母乳垂れ流すの、乳首も気持ちいいのっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あああああっ……！　もうだめぇ♪　んぁ♪　んぁっ、ああ……♪　あぅう\nう……♪　あ、あ、あ、あ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……ん……♪　ふーっ♪　ふーっ♪　は、派手にイキ散らしてしまって……\nああ、だめね。床も私の愛液でびちゃびちゃになってしまったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204202" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「早く、情事の痕跡を消さないと生徒たちにバレて……って、きゃっ！？　う\n、嘘……？　どうして貴方、精子を射出したのに萎えていないの……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「というより……出す前よりずっとスゴくなって……。ひゃん！？　も、もし\nかしてボニューデマクールの副作用で？　ち、違うの？　私の……せい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204204" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……あ♪　いやだわ、そんな風にオマンコをミチミチに満たされたら……私\nの方も我慢がきかなくなってきて……♪　ふぅっ、ふぅうっ♪　ふー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……決めたわ。このまま、続けてしましょう？　もう逃がさない。……ンッ\n♪　思いっきり締めつけて……あぁ♪　私も腰を動かしていくわね……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ふ、ぁ♪　あぁ……ッ♪　あぁんっ、くぅう……ッ♪　や、やっぱりそう、\nよ……っ♪　中で動かしてみるとはっきりわかる、わ……！　っんんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204207" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ますます巨大化してる……！　あッ♪　どういう仕組みなのぉっ！　んんっ\n！　少しお尻を揺するだけで、ずんっ、ずぶっ、ずぼって貫かれて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んんんぃっ♪　こんっなのぉ……！　理性を飛ばさない女が存在するわけな\nい、わ……っ！　あっ♪　私もっ、私も本気になってきてしまいましたっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はぁんんっ♪　あぁんんっ♪　んんっ！　んっ、んっ……♪　ね、ねぇ……\n♪　さっきみたいに、一度目みたいに貴方からもピストンしてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「そうしたらっ、二人の動きで摩擦が強くなって……もっともっと感じられる\nからっ！　……あッ♪　す、すごいわ……電流が駆け巡るみたいぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204211" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんんんっ♪　子宮に……膣内に響くぅうう……！　いいわっ、\nスゴくいい……っ！　中で膣ヒダに精液が塗りこめられて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「強力なマーキングをされている、みたいっ♪　あああっ♪　貴方の精子をオ\nマンコにっ♪　ぬりぬりぬりぬり亀頭で塗られて……！　んッ、んひぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ひぃいいっ♪　どこまでも感じてしまいますっ！　あーっ♪　あーっ♪　こ\nこは学園長室、なのに♪　大きな音をたてたら誰か来てしまうのにっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「やめたくないですっ……！　あっ！　あっ！　あっ！　学園長として恥じる\nべき姿っ♪　おっぱいミルクまみれで精液をオマンコから逆流させてっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204215" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「だらしない表情で快感に酔っている私……っ♪　見られてしまったら軽蔑さ\nれると思うと……あぁあっ、またイッてしまいますっ……！　ん～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あっ、あっ♪　私ばかり良くしてもらって……！　貴方のおちんちんにすっ\nかり溺れてしまっていました♪　ちゃんと……二度目も受け止めますよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ね？　ねぇ？　私の中に……♪　煮えたぎってドロッドロになったアツアツ\nのオマンコにもう一度♪　精液を……子種をいただけませんか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「いただけるのなら……あぁんんっ♪　今日一番、いやらしい動きで絞り取っ\nてみせます……♪　よ～く見ていてください、浅ましくお尻を振る私をぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁっ♪　くださぁい♪　貴方のがいいんですっ……！　私の奥を……っ、\n子宮を貴方の精子で撃ち抜いて！　子宮口を突破させて……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んひぅううううっ♪　ダメッ、だめぇっ♪　強烈すぎる射精ぃ……！　あっ\n！？　あっぁっ、頭が真っ白になって……っ、ああああっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「す、ごいです……ッ、ドプッ！　ドピュッ！　って中に……んんんぁっ♪　\nオマンコどころか子宮に直接入ってきていますっ……！　っあぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「私の身体の中を一直線に駆け上がって、受精させたい、卵子奪いたいって言\nってます……ッ♪　う、ぁああああっ♪　のぼってきます、上がってくるぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「精液がお腹の中にどんどん溜まって……あぁあっ♪　白いプールが出来てる\nっ……♪　臭い子種が、赤ちゃんのお部屋に蓄積されていきます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っん……！　ンンンッ♪　びくんっ、びくんっておちんちんが脈打つたびに\n……あぁっあっあっあっ！　永遠に精子が撃ちだされて……はぁああっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「全身が……この熱い体液に浸されていくみたいで……♪　んんんっ♪　とろ\nけてしまいます……♪　もう何も考えられないぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「あぁ……♪　はぁああ……♪　ふぁあああ……♪　と、年がいもなく本気で\n……イかされて、何度も何度も中出しされて……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204307" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「も、う……当分、まともに歩けそうもありません……。はぁ、はぁ、イキす\nぎて体力を根こそぎ奪われてしまいました……。それなのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「どうして、こんなにも心が満たされて幸福なのでしょうね……♪　うふふふ\n、こうして貴方と過ごすかけがえのない時間……。これは私へのご褒美です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「この時間があるからこそ、普段学園長として、一人前の大人として頑張って\nいける……。ですからまたしましょうね。可能であれば毎日でも……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「中に出してください！　……ん？　あ、貴方？　どうしておちんちんを抜い\nたりするんですか……？　っやっ！？　えっ！？　そ、そんなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んぁんんんっ！　あッ♪　おっぱい……おっぱいに、頭に精液を……？　あ\nっ♪　ゆ、油断していて不意打ちを予測できませんでした……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「んっ！　んんんっ！　あふ……っ♪　ふ、ぅ……んぅううう♪　あぁ……っ\n♪　熱い♪　皮膚にべっとりとはりつくこの純白の体液……あああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「うふふふっ♪　二回目の射精なのにこぉんなにたっぷり出してしまって……\n♪　よほど昂っていたんですか？　好きですね、貴方も……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「ええ。私もものすごく……興奮しましたよ。ほら、よく見れば乳房が母乳で\n濡れそぼっています。甘い香りが部屋中に広がって……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「っん♪　貴方の精子と私の母乳……♪　どちらの量が多いか、濃度が高いか\nももうわからないくらい……びしょ濡れになってしまいましたね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……中に出してもらえなかったことは、残念でしたけど……。さきほど、一\n度目は膣内にしっかり射精してくれていましたからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00025502_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「二回目は貴方の好きなところに出してもらっても、まったくかまいはしない\n……はずだったのですが……。突然の変更はいけません、驚きます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「……え？　している時の私が綺麗だったから、思わず汚してみたくなった…\n…ですか？　あっ……♪　ズルいです、そんな言い方……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルシエル" ]},
		{"command":[ "SETTEXT", "「はい……。これからも、どうぞ自由に、好きなところにかけてくださいね。\nそうしたらそこが、貴方のお気に入りだと……私も知る事が出来ますから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_255_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
