		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「お疲れ様、姉さん。超目立ってた。さすがね～！　よっ、尻女！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540036" ]},
