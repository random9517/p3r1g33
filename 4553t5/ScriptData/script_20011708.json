		{"command":[ "SETNAME", "襲来者" ]},
		{"command":[ "SETTEXT", "「はははははっ！　愚かな原住民どもよ、ひれ伏すがいい！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「大変ですぞ！　会場の外に襲来者（インベーダー）が現れて、暴れておりま\nす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021540029" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なにっ！？　なんでよりにもよって、こんなタイミングで……！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「襲来者（インベーダー）がこんなところに……姉さん、急。あたしたちも加\n勢に行きましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540037" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「そうだね！　行くですよ、二人共！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540054" ]},
		{"command":[ "SETCHARA", "0", "char_00010103_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「カツマさん！　私たちも行くですよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540055" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "破" ]},
		{"command":[ "SETTEXT", "「古人曰く、旅は道連れ世は情け。情けない世の中とおさらばするには、やっ\nぱ道連れが大事ってことです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_102_010021540038" ]},
		{"command":[ "SETCHARA", "0", "char_00010203_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「ボクにかかれば襲来者（インベーダー）なんて、真っ二つのズンバラリンだ\nよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540050" ]},
		{"command":[ "SETCHARA", "0", "char_00010303_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前たち……！　助かるよ！　ありがとな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「礼には及びません。それでは、失礼するです！」", "NORMAL" ]},
