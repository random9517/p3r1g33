		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "急" ]},
		{"command":[ "SETTEXT", "「負けたのは悔しいけど、とっても楽しかったね～。またいつかやりたいなぁ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_103_010021540049" ]},
