		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "序" ]},
		{"command":[ "SETTEXT", "「普通の相撲ならまだしも、さすがに尻相撲はもうこりごりですよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_101_010021540052" ]},
