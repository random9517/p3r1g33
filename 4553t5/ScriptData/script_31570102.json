{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……あ、あの馬鹿ご主人様、人をこんな格好で拘束したま\nま放置するとか、何を考えているんですか……んんっ、んふぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「た、確かに、仕事でミスをしたのは私ですけど……はうぅっ……何がお仕置\nですか……んっ、んぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こーゆーところがどうしようもないんですよ、あの人は……はぁ、はぁ……\nんあぁんっ……だ、だめ……身体が、うずいて……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こ、これ、さっきのメンテナンスで確実に何かされてますね……人間と違っ\nて、勝手に発情するなんてありえないはずなのに……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「だ、だめ……触りたい……おまんこに指をいれて、掻き回したい……んあぁ\n、んんっ……こんなの我慢、できませんよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「気持ちよくなりたい……おまんこぐちょぐちょしたい……はぁ、はぁ　……\nご、ご主人様ぁ……謝りますからぁ、おちんちん、くださいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――んにゃ！？　ご、ご主人様！？　今の聞いてたんですか！？　……な、\nなんですか、そのニヤニヤした顔は！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「仕方がないじゃないですか……ご主人様が悪いんですよ……私の身体、好き\nなように開発して……あっ、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――お、おねだり？　そうすれば、おちんちん入れてくれるんですね……ん\nんっ……わ、分かりました……もう、ほんとに我慢できないんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご、ご主人様、どうか私のおまんこに、そのご立派なおちんちんを挿入して\nください！　私はご主人様だけの玩具です、だからどうか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃあぁぁん……！　あっ、ふあぁっ、入ってきたっ……ご主人様のたく\nましいおちんちんっ……んふぅぅっん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あぉっ、ふあぁぁんっ、んひぃぃんっ！　すごい、これすごいですぅ！　大\nきな亀頭が、ぐりぐりと私の中をけずって……んにゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「こ、これ、ほんとに私、ご主人様専用になっちゃう！　あっ、んひゃうっ！\n　おまんこの形、おちんちんに合わせて変わってっ、んひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「と、止まらないで、そのままおまんこの奥まできて、ください、んふぅぅっ\n！　人間と違って本物の赤ちゃんの部屋はないけど、奥をズンって突いて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、おっ、んひゃぁうっ！　あっ、ふあぁんっ！　きたぁ、奥の奥まで\n、ご主人様を感じます……気持ちいい、気持ちいいですぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……これ、エラーが止まらない、快感が強すぎて……わ、私、す\nごいこと口走った気がしますけど……だめ……何も、考えられない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様ぁ……お仕置でも何でもいいですから、私の事、むちゃくちゃにし\nてください……おまんこ、いっぱい激しくしてぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あぁああんっ、ふあぁ、んんっ……あひんっ！　そ、それ、そうやって乱暴\nにズンズンされるの、すきっ、んひゃぁうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、あっ、んにゃぁんんっ！　あっあっ、ふあぁぁんっ！　あひっ、ん\nひゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「しゅ、しゅごいです、ご主人様、すごいぃ……おっ、んひぃんっ！　快感で\nエラーが止まらなくて、でもそれが良くて……おっ、んおぉぉんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んんんっ……はぁ、はぁ……んっ……ご、ご主人様……？　どうして\n勢いを落とすんです？　何かありましたか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――え？　聴いたこともない激しい喘ぎ声だから流石に心配になった、です\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ……まったく、自分で私の身体に細工をしておきながら、今更何を\n言ってるんですか……でも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「どうしても悪になり切れない、ご主人様のそーゆーところ、私は好きですよ\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――大丈夫です、そんな簡単に壊れるほど、私の身体に安物のパーツは使っ\nてませんから。だから、ご主人様……来て、ください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あぁああんっ！　ふあぁ、んひゃんっ！　おちんちん、すごい勢いで動き出\nしたっ、あっ、んにゃあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「大きくなった亀頭が、おへその裏をごりごりって削って……ふあぁ、んあぁ\nんっ……下腹部がぷっくり膨らんでるのが分かりますっ……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃあぁんっ！？　そ、そこ、浅いトコロの、うえっ、んひぃんっ！　カ\nリが擦れると、すごい、そこすごいです！　あひっ、んひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「そ、そうです、人間で言う所のＧスポット、あぁぁんっ！　こーゆー時にご\n主人様にご満足いただく為、しっかり実装済でっ、あっ、んあぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほら、ご主人様の責めで、専用の玩具がこんなに喘いでますよ……あっ、あ\nひんっ！　ほんとにお上手で、ふあぁっ、とっても気持ちいいです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「聞こえますか、おまんこから聞こえるいやらしい音が！　んひぅ、あぁああ\nんっ！　ご主人様がすごいから、溢れる体液が止まらないんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、んにゃぁあんっ！　ま、また一段と、おちんちんが大きく、固くな\nってっ、あっあっ、んぁああっん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「亀頭も膨らんできましたね♪　知ってますよこの反応、もう我慢できないん\nですよね？　びゅーびゅー射精したいんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――はい、もちろん中で出していいですよ！　あぁんっ、ふあぁんっ！　私\nの内部機構に、ご主人様の所有物であるという証を刻み込んでください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひゃぁぁんっ！　あっあっ、んにゃぁんっ！　あ、頭の中にノイズが走っ\nてっ、これ、私もイキそうなんだ……あひっ、ふあぁんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「出してください！　おまんこの奥、赤ちゃんの部屋はないけど、一番深い所\nにおちんちん突っ込んで、あつい精液をたっぷり注ぎ込んでください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃあぁあぁ～～～っ！！　きた、来ましたぁ！　ドクドクって精液溢れ\nて、あひっ、あっ、ふあぁぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様、私もイッちゃってます！　ご主人様の精液で、私、わたしぃ、あ\nひっ、あっ、んにゃぁんんっ～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……にゃふふ♪　気持ちよかったですね～ご主人様。私の中に、\nご主人様の熱をしっかり感じますよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あぁ……これが、幸せってことなんだ……人間と機械、種族は違っても今思\nってる気持ちはご主人様と一緒なんだって、そう信じられます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……にゃふふ、ご主人様ったら、一度出したぐらいじゃ、まだまだ物足\nりませんか？　おちんちん、まだまだ固いままですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――いいですよ、心ゆくまで、何度でも。ご主人様が満足するまでお付き合\nいしちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んあぁんっ！　にゃふふ、その調子です♪　んんっ……今度は私がご奉仕し\nて差し上げたかったんですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「今どこかの誰かさんが身体を拘束してくれたので、私はこの通り動けません\nからねぇ♪　腰を振るのは引き続きお願いします♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「その代わりではないですけど、こうしておまんこを動かして……にゃふふ、\n良い表情です、ご主人様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「何をしたか、ですか？　さっきも言いましたが、こーゆー時にご主人様に満\n足していただく為、身体に少しだけ色々仕込んでるんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ……こうやって、お腹の中をぎゅってすると……あっ、んあぁんっ…\n…おちんちん、搾り上げるみたいに中が動いて、気持ちいいでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、あっ、んあぁん……まだまだ、こうして……んんっ！　亀頭だけを\nぎゅっとして、離して……いっぱいにぎにぎしてあげますからね……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「人間の女性では味わえない快楽を……あっ、あぁんっ……機械の身体なら\nではの気持ちよさを、た～っぷり堪能してください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁんっ！？　またズドンって、あぁんっ！　おちんちん、一番奥まで\nきましたっ！　あひっ、あっあっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おまんこの奥、ご主人様の精液でぐちょぐちょで、あっ、あぁぁんっ！　お\nちんちん、すごいスピードっ、んあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「わ、私もまけませんよ、んんっ、入り口をぎゅっと絞めてっ、あっ、ふあぁ\nんっ！　おちんちん、根元から搾り取ってあげますっ、ふあぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ふあぁ、あぁぁんっ、んひぃんっ！　それ好きっ、お腹ボコってなるぐらい\nゴリゴリ削るの、好きですっ！　あひぃぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様っ……ご主人様、ご主人様ぁ！　あっあっ、んひぃんっ！　こんな\n、だめっ、またノイズが走って、んにゃぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あひっ、んあぁんっ！　おちんちん、ビクンッて跳ねて、ふあぁん！　イキ\nそうなんですね、射精しちゃいそうなんですねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「出してくださいっ、私の身体はご主人様のモノですっ、んひぃんっ！　好き\nな所に、好きなようにっ、射精してください、ふあぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様の所有物である証をくださいっ！　あっあっ、んんんっ！　私の全\n部を使って気持ちよくしますから、精液の熱で刻み込んでくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁんんっ！？　あひっ、んはぁんんっ！　いいっ、気持ちいいっ！　\nんんっ！　ノイズとエラーが止まらないっ、んっひゃぁうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私もイキますっ、ご主人様といっしょにイクからっ、あひぃぃんっ！　滅茶\n苦茶にして、私が壊れるぐらい激しくしてくださいっ、ふあぁんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んひぃいいんっ！　あっあっ、にゃひぃぃんっ！　ご主人様、きてぇっ！　\nびゅーびゅー射精してっ！　あぁんっ！　イクの、イクイク、イクぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃぁあぁぁんんっ～～っ！！　あひっ、あっ、んひぃいんんっ！　ご主人\n様の熱いのが、出てっ、あふぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すごい勢いですっ、んんんっ！　一回目より量も多くて、私のおまんこの奥\nの奥まで、全部を満たしてきてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃ、あっ、んふぅんっ！　私もイクの、とまらないっ！　あっ、ふあぁ\nんんっ！　エラーだらけで、でもそれが気持ちいいんです！　んにゃぁん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、んあぁんっ……ほんとにすごい射精量ですね……んっ……おちんち\nんがビクついて、まだまだ精液を吐き出してるのが分かります」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――いいですよ、最後の一滴まで出し切っちゃってくださいな。今日の私は\n、ご主人様の為の玩具ですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「え？　さっきみたいに中を動かして搾り取ってほしい、ですか？　……にゃ\nふふ、仕方のないご主人様ですねー♪　んんっ！　あぁんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おまんこの中、ご主人様の精液でぱんぱんですよ。妊娠機能ついていないん\nですけどね、これだけ出されたら妊娠しちゃうかも……なんて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「……いえ、ちょっと本気で考えてみましょうか。実はその手のパーツがあり\nまして、換装するのもありだと思いませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　メンテナンスで先に私の身体を弄ったのはご主人様のほうです\nよ？　何を今更焦ってるんですか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104309" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「どんな私になろうと、私の主はあなただけです。なので……にゃふふ、これ\nからもよろしくお願い致しますね、ご主人様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ふあぁあぁぁんんっ～～っ！！　おちんちんが抜けてっ、んんっ！　すごい\nっ、精液がいっぱいかかって、あっ、んあぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んん、んにゃぁんっ……！　内部機構を汚されるものよかったですけ\nど、ボディをご主人様色に染められるのも、これはこれで……んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あぁんんっ！　精液がべったりつくの、気持ちいいかも……\nご主人様を全身に感じて……んにゃぁんっ……もっとかけてください……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ビクビクしてるおちんちん、かわいい……んんっ……ぬるぬるの精液、最後\nの一滴まで、全部私の身体に……あっ、んふぅんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ♪　ご主人様ってば、ほんとにたっぷり出しましたね？　見て\n下さいよ私の身体、ぐちゃぐちゃのドロドロですよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015701_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「これもお仕置の一環、ですか？　……残念ですがご主人様、私にとってはむ\nしろご褒美なぐらいです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私はご主人様のモノ。こうして所有権をしめすように精液塗れにされるのは\n、大大大、だーい歓迎です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「って、なんですかご主人様、その呆れたような顔は。え？　放置プレイで苛\nめてやるつもりだったのに、喜ばれるとは思わなかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　そーゆー所ですよ、ご主人様♪　まだまだ詰めが甘いって言わ\nれるのは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私でしたらいつでもお相手致します。ですので……また今度、特別なメンテ\nナンス、よろしくお願いしますね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
