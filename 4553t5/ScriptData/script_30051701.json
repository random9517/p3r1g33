{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んっく……うぅっ……一体、どういうつもりですかっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「こ、こんな……確かに、ちょっとしたミスはしましたがっ……いくらお仕置\nきだからといって……こんな拘束は不当ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「は、反省はしていますっ！　ですがっ、ここまで拘束されてっ、あ、足を開\nかされるなんてっ……おかしいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「しかもっ、んんっ……あっ、ふっ……変な場所にっ……ローターなんてっ、\n悪趣味の極みですっ、恥を知るですっ、変態ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「とにかくっ、降ろしやがるですっ……お仕置きはっ、もっと別の形で……な\n、何をニヤニヤしていますかっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703105" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ウチの態度っ……そんなことっ、言われる筋合いはありませんっ！　ウチは\n、この不当な扱いに断固っ、はにゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、ひっ、あぁっ、あひゃぁぁっ！　あっ、や、やらっ、プルプルっ……\nあっ、震えるっ、はひっ、ひぁぁぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「やっ、めっ、あぁっ、し、振動がっ……ひぃっ、あっ、ひんっ、つ、強いっ\n……ま、待ってくりゃひゃいっ……ひぃうんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、はぁっ……んんっ……卑怯ですっ！　いきなりスイッチを入れるなん\nてっ……恥ずかしくないんですかっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「な、何をニヤニヤしてっ……まさか、またスイッチを……ふひぃぃっ、あっ\n、あへぁっ、またっ……はひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「くっ、んぅぅぅんっ……！　ふ、震えるっ！　中っ……らめっ、プルプルさ\nせないれっ、やめっ、やめなひゃいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「こんなっ、あっ、身動きを取れない状態でっ……い、いいようにっ、するな\nんてぇっ、ひゃひっ、あっ、くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「か、身体がっ……熱量上昇っ……！　ダメですっ、このままだとっ……冷却\n液がっ……はぁっ、んっ、出てしまいますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ど、どこからっ……って……それはっ……し、知っているんじゃないですか\nっ？　わざわざっ……言わせるつもりですかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、ひぃんっ！　あっ、またっ、振動っ……強くっ、ふひっ、ひぃっ、あ\nっ、あくぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「くぅっ……！　い、言いますっ、はぁんっ、感情の高ぶりによりっ、全体の\n熱が上がった時にっ……こ、股間から冷却液が放出されますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「お、おしっこみたいなって……それはっ、んぐっ……！　そうっ、かも知れ\nませんけどっ……は、んふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ちょっ……な、何を……オ、オチンチン出してっ……扱き始めているんです\nかっ……ウチの姿でそんなっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んっ、ひぅっ！　こんな吊るし上げた姿を見て……オナニーするなんて、お\nかしいですっ、まともじゃありませんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ひぁぅんっ！　なっ、ちょっ……む、胸の方までっ……振動がっ、ど、どう\nしてっ……は、ひぃぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「またっ、体温上昇しちゃいますっ！　ダメですっ、冷却液っ……漏れちゃい\nますからっ、止めてっ、止めなさいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「この状態はっ、危険なんですよっ！？　それをっ、分かってやがりますかっ\n、さっさと……止めるですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「め、命令してるわけじゃないですっ！　これはっ、忠告でっ……しゃ、謝罪\nっ……誠意を見せろっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「どうしてウチがっ……そんなことをっ……あっ、んひっ！　くっ、ぅぅぅん\nっ！　はっ、あぁっ、また震えっ……強くぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、ひっ、わっ、分かりましたっ！　しますっ、謝罪っ……しますからっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっく……ウチは……任務で、失敗をして……それでお仕置きをさ\nれているのに……反省せずに不満を言ってしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「もう、心を入れ替えて……反省しましたので、どうかローターを止めて下さ\nいっ……ほらっ、言いましたっ、言いましたからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「も、もっと心を込めて……？　うくっ、ちょ、調子に乗ってっ……！　あ、\nうぐっ……す、すみません……あっ、ひっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……今のは、違いますっ……本当に反省してるですっ……つ、\n強くしないでっ、あひっ、ローターっ、らめっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ほ、本当に……反省しています……だから、振動止めて下さい……股間の中\nの……ローターっ、オマンコっ、オマンコの中のですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「オマンコの中のローターがっ、ずっと震えてっ！　はぁんっ、プルプルする\nのがっ……あっ、ダメっ……なんですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「気持ちっ、よさそうって……こ、これはっ……そういうのじゃなくてっ、あ\nっ、んぁんっ、余裕がなくてっ……あぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「なっ、なんでそんなに興奮してるんですかっ……オチンチンっ、ビクビクさ\nせて……んぁぁっ、ローターっ止まらないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ウチの顔がいやらしいのが悪いって……ローターがっ、ウチをおかしくさせ\nるからっ、あっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あぁっ……オチンチンっ……もっと激しくしてるっ……だ、出すんですかっ\n？　ウチの身体にっ……はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁっ！　やっ……あっ、精液っ……掛けられてっ……！　ひぁっ、\nウチもっ、イっ……イクっ！　イキまひゅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁぁぁぁ……イ、イッたの……も、もうらめ……あ……あぁぁぁ…\n…あっ、はぁぁぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「やっ、らっ……あぁぁぁ……出てるっ……み、みないれっ……お、おもらし\n……見ひゃらめぇぇ……は、あぁぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ……止まらない……緊急冷却液……あぁっ、放出……止められ\nない……見ないで下さい……見ないでぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……はぁ……んっ、あぁ……だから……ダメって言っ\nたのに……はぁぁ……あふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「うくぅ……ウチの恥ずかしいところを見て満足ですか……？　完全にウチを\n私利私欲に使って……オチンチンを扱いて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「もう、十分楽しんだでしょう……早く拘束を解いて下さいです……んっ、こ\nの態勢……辛すぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ま……まだ？　お、お仕置きは終わってないって……そ、そんな……もう十\n分した……あっ、あぁぁぁっ、ひっ、あひぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あひっ、そ、そこはっ！　あっ、あぁっ、お尻っ……お尻の中がっ……プル\nプルっ、しまひゅぅっ！　あっ、あぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ダメですっ、そっちはっ……も、もっと弱いのっ、んくぅんっ！　ムズムズ\nするからっ、あぁっ、だ、ダメですぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んっ……ひっ！？　なっ、オ、オマンコもっ、またっ……！？　同時なんて\nっ……ひっ、あぉっ、しょんなっ、しょんなのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はへぁぁぁぁぁっ……あぁぁっ……無理っ、無理れひゅっ！　あぁっ、待っ\nてっ、またっ、謝罪しまひゅっ！　反省してまひゅからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁっ、プルプルらめっ、止まらないのらめっ、おかひくっ、おかひく\nなりまひゅからぁっ……んぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、あぁ……と、止まった……？　んっ、けど……まだ……ム\nズムズして……んぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「敏感になり過ぎて……お尻も……オマンコも……感覚がおかしくなってます\n……ぁ……ふぁ……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「お汁……垂れてる……こ、こんなことされれば……ウチの身体は……そうい\nう風になります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「も、もうしませんか……？　んっ、イ、イッたばかりで敏感なんです……次\nにされたら、ウチは……またおかしくなっちゃいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「えっ……あっ、ち、違いますっ！　今のは、そうして欲しいって意味じゃ…\n…ひぁぁぅっ！　あっ、ま、またぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ！　お、おっぱいまでっ！　ぜ、全部同時になんてっ……ま、ま\nた強くぅっ！　ひっ、いっ、いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あっ、んぁぁぁんっ！　オ、オマンコっ……グリグリっ……ひゃれてっ、ま\nひゅっ、あひゃんっ、はぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「やらっ、あぁっ……！　こんなのでっ、気持ちよくっ……なっひゃうなんて\nっ……んぁぁっ、ま、また出ちゃいますからぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「お、おしっこっ……そうですっ！　冷却液ですっ……！　温度上昇率がっ、\n基準値を越えたらっ……出ちゃうんですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「分かってるのにっ、ま、また……見せつけるようにっ……オチンチン扱いて\nっ……はぁんっ、ウチに……掛けるんですねっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、らめれすっ……も、もう止まらないっ！　気持ちいいのっ、止ま\nらなくてっ、あひっ、ウチもっ、またぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「イッ、イクっ！　イッちゃいますっ！　オマンコっ、かき回されてっ！　ロ\nーターでイキますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ひぁぁぁぁぁぁんっ！　あっ……お尻っ……精液っ……熱いのっ、はぁぁん\nっ、またぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「だめっ……だめですっ、またっ、感度っ……上昇……と、止められませんっ\n……で、出ちゃうっ……出ちゃいますぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はっ……あぁぁぁぁぁ……み、見ないでぇ……漏れてるとこぉ……見たら…\n…らめれす……ん、ぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あぁ……お、お漏らしいやぁ……恥ずかしい……ウチの恥ずかしいところ…\n…もう、見ないでぇ……あぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んっ、あぁ……冷却……終了……ぁぁ……は、ふぁ……うっ、う\nぅぅぅ……終わりました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「うぅ……最悪です……こんなみっともないところを見せるなんて……お仕置\nきにしてもあんまりです……ぐすっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「か、可愛かったとかっ……適当に言っとけば許されるワケじゃないですっ！\n　うぅ……確かに、気持ちは……よかったですけど……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んぁっ……あぁ、まだ振動してるみたいな感じが残ってます……と、止めて\nますよね？　最弱っ？　き、切って下さいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……もし、こんなのが癖になったらどうするんですか…\n…ウチは変態になりたくないです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「その時はまたお仕置き……こ、今度は失敗しませんからっ！　するにしても\n……違う名目でお願いしますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「えっ…か、顔をこっちに……？　それは……んぁぷっ！　はぁっ……精液っ\n、そんな……掛けられてぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000517_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ……濃いの……ダメですっ、はぁんっ……ウチもっ……またイクっ\n……あぁんっ、イキまひゅぅぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あ……あぁぁぁ……ま、たっ……我慢できなっ……あ……で、出ちゃうっ…\n…出ちゃい……ますぅぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「あぁぁぁ……ダメぇ……見ないで……恥ずかしい……ウチのお漏らし……見\nないで下さい……あ……あぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁぅ……あっ……全部出ちゃう……あぁ、奥にある冷却液……出し切っち\nゃいます……あふぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……あぁ……終わりました……うぅぅ……一番見せてはいけない\nところ……一部始終見せてしまいました……うぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「身体中に精液も掛けられて……続けてイカされて……お漏らしまで……んぅ\n……ウチは変えられてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「き、気持ちは……その……よくなかったと言えば……そんなことは、ない…\n…ですけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「け、けどっ、これはダメですっ……！　お仕置きだからって……変な道に目\n覚めるのはマズイですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メカ・オボロ" ]},
		{"command":[ "SETTEXT", "「ま……また次も……？　ダメ、ダメですっ……！　お仕置きでも……恥ずか\nしすぎないのでお願いしますからぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_1703410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}