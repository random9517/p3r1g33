		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あはぁあああぁぁぁああぁぁ～～～～んっ！！」", "NORMAL" ]},
