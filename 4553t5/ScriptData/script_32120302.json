		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さん、大丈夫……？　ごめんなさい、私ったら、隊長さんに迷惑かけち\nゃったわね……」", "NORMAL" ]},
