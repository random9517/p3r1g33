		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「オマンコをオイルまみれ、ヌルヌルドロドロにしながら、んぁっ、オチンチ\nンいっぱい、気持ちよくするのっ」", "NORMAL" ]},
