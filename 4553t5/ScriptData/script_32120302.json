		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんっ、ああっ、隊長さん、もっと、もっとママのオマンコで気持ちよ\nくなって、オチンチン、オチンチン……っ！」", "NORMAL" ]},
