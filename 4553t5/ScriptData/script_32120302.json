		{"command":[ "PLAYVOICE", "v2_212_0304128" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あぁんっ、だからこんなに、腰をふっちゃうのね。人間が、本気で孕みたい\nときの腰遣いでっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんの上で、隊長さんの子種を欲しがるような動き……っ！　ああっ、\n隊長さん……オマンコも、うねっちゃってるわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304130" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「欲しい……欲しいの……！　隊長さんの、精液……ザーメン……子種汁ぅ…\n…っ！」", "NORMAL" ]},
