		{"command":[ "SETIMAGE", "0", "still_00021203_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ。私もまた、オマンコをいっぱい動かして、オチンチンにご\n奉仕するわ、んんっ、んはぁっ、あぁんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
