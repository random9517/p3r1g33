		{"command":[ "PLAYVOICE", "v2_212_0304110" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
