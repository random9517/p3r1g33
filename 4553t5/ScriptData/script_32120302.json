		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「イクッ、イクッ、イッくぅうううぅぅぅ……っ！　ああっ、こんなに気持ち\nいいの……はじめて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……はぁ……っ。ああ……やっと、おさまった……かしら……\n？」", "NORMAL" ]},
