		{"command":[ "SETIMAGE", "0", "still_00021203_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「わ、私……私ぃ……っ！　んはぁっ、ああっ、こんなに、母乳をだして、気\n持ちよくなっちゃうなんて……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さん、ああっ、ママ、本当におかしいわ……こんなの、正常じゃないの\nに……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「で、でも……でも……不思議と、嫌な気分じゃないの……嬉しい……？」", "NORMAL" ]},
