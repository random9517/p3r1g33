		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、隊長さんっ、いいの、いいのよ、射精してっ、またたくさ\nんでちゃいそうなのよねっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304216" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「私もいっぱい腰をつかって、オチンチンをしごいて、イかせてあげる。隊長\nさんに、射精させてあげるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304217" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、腰振っちゃうわっ。隊長さんのための、ママのオマンコで\n抜き抜きしちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「だから、だからぁ……っ！　だして、だして、だしてちょうだぁい！　射精\nしてっ、ザーメンちょうだぁいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304219" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、私ももう……回路が、限界ぃ……っ！　あっ、あっ、あぁ…\n…っ！　あはぁ……っ！　あはぁあああぁぁぁ～～～～っ！！」", "NORMAL" ]},
