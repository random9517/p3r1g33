		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「でも、もしまた暴走しちゃったときは……。隊長さん、また、お世話させて\nね♪」", "NORMAL" ]},
