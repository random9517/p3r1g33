		{"command":[ "SETIMAGE", "0", "still_00021203_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「でも、まだまだ……妊娠するには、足りないんじゃないかしら……？」", "NORMAL" ]},
