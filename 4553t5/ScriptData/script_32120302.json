		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ママの子宮をいっぱいにして、ママのことを孕ませてっ、ああっ、何台でも\n妊娠させてぇ……っ！」", "NORMAL" ]},
