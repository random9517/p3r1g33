		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんに、ママにして欲しいの。隊長さんの精液で、ママになりたいのぉ\nっ！」", "NORMAL" ]},
