		{"command":[ "SETIMAGE", "0", "still_00021203_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「こんなに強烈な快楽信号、はじめて……っ！　ああっ、だめ、回路が耐えら\nれないかもっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304116" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁっ、すっごく気持ちいいのっ。あぁんっ、オチンチン、もっと、\nもっと……んぁあっ、ああぁんっ！」", "NORMAL" ]},
