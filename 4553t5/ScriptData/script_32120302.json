		{"command":[ "PLAYVOICE", "v2_212_0304125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「このまま、隊長さんに中出しして欲しいの。ママのオマンコに、アツアツの\n精液、たっくさんだして欲しいの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、隊長さん……ママ、隊長さんとの間に、もう一人欲しいって…\n…思っちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304127" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
