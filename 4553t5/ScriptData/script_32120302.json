		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「いっ、いくっ、いくっ、いくいくっ、いくっ、いっくぅっ！　おぁっ、あっ\n、ああっ、ああぁぁ～～～～っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「またたくさん、隊長さんの精液、中出しっ、あっ、あっ、濃いの、熱いの、\nどぴゅどぴゅ中出しぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁあっ、あああっ、オマンコが、動くわ……搾るように、吸いだすように\nぃ……っ！　精液、精液ぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304304" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「隊長さんに、中出ししてもらった精液……っ！　ああっ、どんどん、子宮に\n……ママの子宮に、おさめるの……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304305" ]},
		{"command":[ "SETIMAGE", "0", "still_00021203_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。あ……ああ……。な、なにかしら……この感じ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304306" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「もしかして、隊長さんの精液のおかげで、機体の調子がもとにもどったのか\nしら……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304307" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「新機能を発動している状態のままなのに……。なんの違和感もなく、各部が\n動作しているみたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ふふっ、隊長さん、どうもありがとう。隊長さんのオチンチンのお世話をし\nたおかげで、この機能をつかいこなせそうよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304309" ]},
