		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「しごかれて、気持ちいい？　あんっ、私のオマンコ……感じてくれているか\nしらぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、私は気持ちよくって、あんっ、どうにかなっちゃいそうよ……\nあぁんっ、隊長さんの、オチンチン……気持ちいい……っ！」", "NORMAL" ]},
