		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ママに射精してっ。ママのオマンコをイかせてぇ……っ！　ああっ、ああっ\n、イクイク、ママも、ママももう……っ！」", "NORMAL" ]},
