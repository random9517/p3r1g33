		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「ああっ、いっぱい、またたくさんの精液っ、はぁっ、はぁっ、私の……身体\nにぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_212_0304402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「たくさんぶっかけられて……い、イッちゃう……アクメ信号、ああっ、全身\nを駆け巡って……あはぁあああぁぁぁんっ！」", "NORMAL" ]},
