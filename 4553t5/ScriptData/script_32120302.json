		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……っ。すごい……いっぱい射精してくれて、ありがとう……\n隊長さん……」", "NORMAL" ]},
