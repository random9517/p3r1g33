		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ｍ.Ａ.Ｍ.Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、絶頂信号が全身を走るのっ！　ボディが弾けそうっ！　あっ\n、ああっ、イッくぅうううぅぅぅ～～～～っ！」", "NORMAL" ]},
