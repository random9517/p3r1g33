{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さま♪　旦那さま……♪　準備ができました、きてください……♪　え\nへへへへ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「今日は、未来の妻であるわたくしに……特別なお作法を教えてくださるんで\nすよね。これでいいですか？　おまんこさん、ちゃんと見えますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい。ここが……旦那さまのおちんちんさんを入れる穴、だと思います。わ\nたくしも初めてなのでよくわからないのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「だいじょうぶです。わたくしは、旦那さまを信頼しています。ですから……\nとうぜん、えっちなこともぜんぶしてほしいんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104104" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「でも……。あの……。頭の中でかんがえていたより何倍も……おちんちんさ\nんって熱いのですね。すごく長くて……知らないにおいがして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こんなに大きなおちんちんさんが、わたくしの中に全部入ってくれるでしょ\nうか？　えっと……見えますよね。おへそのあたりまできちゃいそうで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「かっこいい……ですね。これが、旦那さまのなんだって思ったら……意識し\nたら、どきどきってしちゃいます。それから少しだけ、わくわくも」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あの……。ふつつかな未来の妻ですが、どうかよろしくお願いいたします。\nえへ……。それでは、……は、はじめてください。入れてください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……ん……んん……！　う……！　わ……わわ、やっぱ、り……ミチミチで\nす……。あっ……い、痛くないですか？　へいきですか……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わ、わた、くし……！　わたくしはへいき……です！　あっ！　大きくて、\nびっくりしましたけど……んぅ！　入ってきてます、でも、でも！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104110" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おまんこさん、初めてで狭いですから……おちんちんさんがはさまれて痛か\nったらって思って……！　え？　あいえきがあるから心地いい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「中があったかくてヌルヌルしてるから痛くない？　そ……それなら良かった\n、です……！　あっ……もっともっと入れていいですよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んぅっ！？　あああああ……！　入りました、入ったです……っ！　ひゅぅ\nっ……ひゅぅ……んああ、い、息がしにくいくらい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おまんこさんの中に、おちんちんさんがぎゅうぎゅうに詰まってます！　わ\nたくしたち……一つになっちゃってます！　ふぁああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こ、これがえっち……。旦那さまとの営みなんですね……！　はぁ、はぁ、\nひゅ、ひゅごい……ひゅごいれす、まだ入れただけなのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「頭の中がぽーってピンク色になって……おちんちんさんと、旦那さまのはだ\nか……体温でもうなにもかんがえられませんの。あぁ、しゅき、しゅきぃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまぁ……だいすきですうぅ、だーいすきぃ……！　わたくし、なにも\nわからない妻、ですが……おしえてください！　なんでもっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「次はどうすればいいですか……っ。どうすれば旦那さまを喜ばせることが…\n…！　んっ？　お尻を揺らして、腰をくねらせる？　は、はいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こうっ……こうっ、です……か♪　あああ♪　んぁああ♪　はぅうう♪　ち\nょっとだけ、ちょっとだけ痛いけど……いたいより幸せ、で♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んう♪　んう♪　んぅう～～♪　動くの、きもちいいですね……！　あっ、\nぁっ……あう♪　ぎこちなくてごめんなさい……♪　はぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……♪　だ、旦那さまも動いてくれるのですか？　大歓迎です……！　\nわたくしも、もーっともっと愛情をこめて揺れてみます……！　ああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっんっ！　あっ、んん！　おまんこさんが広がって……！　はぁうう♪　\n閉じて、またひろがって……んぁうううう♪　ふぅううんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おちんちんさんが出入りするたびに、閉じたり開いたり閉じたり開いたりし\nて、ますぅう……！　こんなのしゅごい、ひゅごすぎますぅうう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おまんこさん、おちんちんさんがめちゃくちゃにかきまわしてます……！　\nああ……！　えっちです、えっちすぎます……！　あんっ、あん、あん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「これがえっち……！　あっ、だ、だんだん……動きが合ってきて……。おち\nんちんさんがずっぷり深くもぐりこんできて……！　っひぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ！　一番奥をぐりぐり押し上げてきます！　なにこれっ……なにこれ、\nしらないです！　知らないのがきてる、気持ちいい、きもちいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ……！　あっ、ぁっ、あっ、う、うそみたいです！　わたくしのちっち\nゃな穴のいちばんおく、奥でおちんちんさんがご挨拶にきてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ちゅっ、ちゅっ、ちゅって……んううう！　おまんこさんとチュウしてます\n……！　ちゅっちゅってキスしてます……！　あ、あ、ちゅうしてる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ど、どうしましょう……！　おまんこさん、おちんちんさんのことが……っ\n、あぁ♪　す、好きみたい……大好きっ、みたいですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「もっともっとくっつきたいって……！　えっちなチュウしたいっておねだり\nしてる……！　んぁっ……無理なのに、こんな太いの無理なのにぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「からだがぜんぜん言うことを聞きません……！　あぁ……！　もっとくっつ\nきたいって、えっちなチューしたいって言ってます……。だ、だめぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁっ！　あっ、ぁっ、あっあぁ……！　腰が浮いちゃいます……！　あぁ\nっ、すみません、締めすぎていますよね……！　んんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そ、それが良い……んですか？　わたくしのミニミニおまんこさんで、ぎゅ\nーって絞められるのが好きなんですか？　し、知りませんでした」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104133" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それなら……ん～～～っ！　締めます、……あっ！　こうですね？　こうっ\n……！　ふぁああ♪　ええ、絞めるのは簡単、なのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「なにやらわたくしの方が♪　これっ……あんっ♪　気持ちいい、のです……\n！　えっ？　えっ、わぁ……あれっ？　あれ、あれ……何っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……旦那さま、今なんておっしゃったのですか？　せいえき？　おちんちん\nさんの先っちょからネットリしたお汁が出ると言ったのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「は、はい……いいですよ。それはいいですけど、どこに……？　ま、まさか\nこのままわたくしのここにお出しになるのですか……。ふぁああ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「そ……それが営みの作法……。わ、わかりました。それではどうぞ……この\n穴に、わたくしの穴にお汁を出してください……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと怖いですけど……旦那さまを信じます！　あっ……！　おち\nんちんさん……ここです、ここに出すそうですよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「少し狭いところ、ですが♪　あっ♪　愛情で受け止めますから……どうぞ♪\n　どうぞ……あっ、あぁ♪　せいえきっていうのを出して、出して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁあああぁああん♪　んぁあああん♪　くぅううううん……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっ？　えっ、えっ……せいえきって……！　せいえきってこんなにどぷど\nぷ出続けるんですか……っ？　やぁ、止まりません、止まらないぃっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わ、たくしの身体の中に溜まっていきますぅ……！　んふぁああ♪　あぁあ\nふ♪　あうっ、あぅっ、うう……！　こんなに、こんなにぃ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あぁあああああ♪　……っんんん……っ……！　ご、ごめんなさい……。お\nもってたのよりずっとはげしくて……せいえき、強くって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「おとこのひとのすごさを知りましたの……。んん！？　あっ……！　も、も\nう一度動くのですか？　ま、まだ……わたくし余韻が……ふぁああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104205" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あんっ♪　あんっ、あんっ、あんん♪　旦那、しゃまぁ……♪　旦那ひゃま\n♪　旦那ひゃま……強い、です……腰がカクカクしていますぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ずぷずぷおちんちんさんが出たり入ったりして……あぁあ♪　今出してくだ\nさったせいえきが、……あっ♪　おなか、おなかで混ぜられて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こん、らん……！　んんっ、混乱ひているのにぃ……どうしてでしょうぅ♪\n　わたくしのおまんこさんが満たされていきま、す、よろこんでいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あう♪　あうっ、あぅうっ♪　おまんこさんはおちんちんさんが好き……な\nんですね♪　なかよくしないといやなんですね……大発見です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104209" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「……んん♪　ふぁ……っ、あぁ♪　んぁんん♪　あんっ……♪　あんっ、あ\nっ♪　あっぁっあっ……。なかよし……なかよ、しぃ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえきさんの、ムワムワのにおい……、にゅるにゅるの感触ぅ……♪　か\n、硬いおちんちんさんの、たくましいかっこいい形ぃい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わ……わかりますか！？　またチュウしてます……！　あっ♪　わたくしの\nおまんこさんの奥、おちんちんさんがチュップチュプキスの雨♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「チュウの雨降らせて……んぁ♪　刺激していますっ……！　……え？　ここ\nっ……ここをたくさん可愛がると、穴がほぐれて……っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえきが流れ込むしきゅうに届くのですか……。はぁあ♪　じ、人体の神\n秘です……わたくし、知らないことばかり……旦那さまはすごいです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104214" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえき……♪　んん♪　せいえきを入れる専用の穴……♪　しきゅう、し\nきゅうにせいえきを注いでください……かまいません♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あかちゃん……っ、赤ちゃんできてもいいですからっ♪　わ、わたくしたち\n♪　ふうふ……夫婦ですからっ、少しくらい早くてもいいのです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえきっ……せいえき、ください、くださいぃ♪　おちんちんさん……っ\n、お願いです、おねがいれす……っ！　あっぁっあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「赤ちゃんの素が……もう一度びゅぅ～って出してくださいっ♪　二回出した\nら……♪　かっこいいです、男らしくて惚れ直しちゃいますぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくし、の♪　おまんこさんといちゃいちゃらぶらぶして……好き好きせ\nいえき出してくだひゃい……！　あ♪　あ♪　わたくし、わたくし♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「せいえきたのしみで……！　想像だけできもちよくなっちゃって♪　ほんも\nのっ……ほしいです、わがまま言ってごめんなひゃいいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ああっ！　んぁああっ！　あ～っ！　旦那ひゃま、旦那ひゃまぁ！　出てま\nす、出てますう……！　わたくしの、奥に……いっぱいぃ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はい、はいぃっ、もう……もう大丈夫れひゅ、いたくなくて……！　でも、\nでもかわりにとても気持ち良くて……痺れちゃいますううっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしの、中……！　旦那さまだけのこの穴にお汁……っ、大切なお汁を\nもう一度注いでくださって、ありがとう……ございますぅう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あっ♪　あっ♪　どうしてなのかわかりませんが、わたくし……これがすご\nく好きで……あっ、ああっ！　もっと、もっと出してください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「旦那さまの赤ちゃん、産みますから……！　にんしんさせてください……！\n　あぅ……！　勢いよく、一番中に届いています……すごい、すごい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「はぁあああああ……っ♪　これが、夫婦のいとなみ……なんですね♪　ああ\n……感激です。でも、でも……お汁の量が多すぎて……。ふぁあ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こ、ぼれちゃいます……！　中から溢れて……。やぁああ♪　だめ……！　\n旦那さまが、わたくしに捧げてくださった赤ちゃんのお汁なのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あふ、れちゃう……溢れちゃうぅう……♪　あんっ……！　はしたない未来\nの妻で申し訳、ありません……もっといっぱい練習しますっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えっちの練習して……、最高のお嫁さんになってみせますからぁ！　だから\n、これからも、わたくしにこうしてずぅっとせいえきだしてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104309" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「それが……それがわたくしの幸せです。……あぁ……あったかい……。熱い\nお汁を、このままちゅうちゅう吸い上げます。ご覧くださいねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「あ……？　んんっ……な、なんなのですか……？　この、あたたかな……？\n　ふぁっ……♪　あぁ……旦那さまに包まれていきます……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「ふぁ……ああ♪　あぁ、ああ……♪　はぁ、はぁ、はぁ……。あぁ……♪　\nあ……れ？　いつのまにか、おちんちんさんが抜けて……。んぅ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「びゅるっ、びゅるってあったかいのがわたくしの身体中に……。ん、お顔に\n、足に……あそこにたくさんかかっています……？　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「えへへ……すごい量ですね……。えっと、これは……旦那さまが気持ち良く\nなると出るお汁……。せいえきですよね？　だとすると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「こんなに出るということは、感じてくれたと思ってもいいですか……？　は\nぁ、はぁ……。みてください、どこもかしこもねちょねちょです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしを旦那さまの色に……白一色に染め上げるお汁……。嗅いだことの\nない臭いで、あたりがムワッと蒸れてます。……すごい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00022101_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「わたくしは……未来の妻として、旦那さまを喜ばせることができたでしょう\nか。もし、そうならわたくしは幸せものです……えへへ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「んっ……。破瓜の血がシーツに垂れてしまいましたね。あっ、旦那さまのお\n汁は良いのです。わ、わたくしのがよくなくて……。え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「二人の愛し合った証が混ざって流れ落ちただけ？　まぁ♪　旦那さま……そ\nんなロマンチックなことを言われたら、わたくしは、わたくしは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アン＝クァー" ]},
		{"command":[ "SETTEXT", "「もーっとあなたさまをお慕いしてしまいます。愛する人のお汁を浴びれてう\nれしいです。これからも、いつでもこうしてかけてくださいね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_221_0104410" ]},
		{"command":[ "WAITINPUT" ]},
