{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ～っ♪　おかえりなさぁい、だんな様♪　今日はお仕事遅くまで頑張って\nたのね？　すぐにお料理出来るから、待っててね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「今日のメニューは、腕によりをかけて愛情を込めに込めたクリームシチュー\n……って、きゃっ！？　な、なあに！？　いきなり抱きついてきて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やんっ！？　やん、やだぁ……！？　なんでオチンチン出してるのぉ……！\n　こらぁ、手元が狂っちゃう……。だ、だめよ、お料理中なのに……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「は、裸エプロンで誘惑しておいておあずけなんて無し？　そ……それはね、\n違うの……あんっ、あなたに可愛い奥さんだと思われたくて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だから、決してエッチな理由じゃなくてぇ……って、手ぇ！　ダイヤナちゃ\nんの豊満なおっぱいにイタズラしてるぅ……だ、だめよ、だめぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そ、そんな風に激しく揉まれたら……握られて揺さぶられたら……あっ♪　\nか、感じちゃう……ダイヤナちゃんおかしくなっちゃう、わかってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……んんんっ♪　だんな様のオチンチン……、すっごく熱くてぴとぴとって\nあたしの太ももに……アソコにぐりぐりめりこんできてるよ……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんのエッチなところ……、あっ♪　オマンコにくっついて、こ\nすれて……あっぁっやっ♪　ものすごく存在を主張してるぅう～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……え？　本当は、こうして欲しくて……。襲って欲しくて裸エプロンでい\nたんだろうって……？　あっ……そ、それはね……えっと。えっとぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「う、うん。そう……なの。違わないよ。だ、だけどここまでだんな様が情熱\n的に来ると思ってなくて……お、驚いちゃったの。……っぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなのっ……ダイヤナちゃんじゃなくてもモジモジしちゃうじゃない！　\nやらしい気分になっちゃうし……し、したくなっちゃう……♪　んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んあんんっ♪　い、イジワルしないで……！　そんな風にオマンコにオチン\nポスリスリされたら……。あっ、が、我慢できなくなっちゃうの……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁっ……♪　はぁっ、はぁ、はぁっ……！　ね、ねぇ……？　だんな様ぁ\n……ダイヤナちゃんと新婚エッチ、しない……？　うん、このまま……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だんな様の立派なオチンポ、あっついかた～いオチンチン……濡れ濡れのこ\nこに……オマンコに、ズプって刺してほしい……。い、入れてほしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……えぇ！？　もっと破廉恥におねだりしてって？　やっ……もぉ、本当に\nエッチな人ぉ……。い、いいけど……。あ、あのね……？　んっ♪　んん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん……だんな様が戻ってくるのを、今か今かと楽しみに待って\nたの……。オマンコヒクヒク疼かせながら、エッチな事想像しながら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「お料理より先に、オマンコ味見されちゃって、逞しいオチンチンでズポズポ\n犯されちゃうこと、妄想して……一人で濡らしてたの。わ、わかるでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「愛液だらだらで……待ってたの。だから、入れてぇ？　準備出来てるから…\n…あたしのオマンコ、食べてください♪　お願い……。んんんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あッ……♪　オチンポ、オチンポ入ってきたぁあああ……っ♪　やぁっ♪　\nう、嬉しいっ……幸せぇ♪　すっごくかたぁいい♪　おっきぃいい……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「今日はいつもより……んぁああっ！　太くて、力強くて……！　ダ、ダイヤ\nナちゃんオマンコイッちゃう……イクぅっ、すぐにイッちゃうぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ♪　んぁあああっ♪　あぁっ、あ～～～っ♪　そ、そうなのぉ……！　\nコレっ、コレが欲しかったのぉ♪　だんな様……素敵、大好きぃっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あんっ、あぁああっ……ふぁああっ……！　か、勝手に腰が揺れちゃう……\n！　オマンコっ、イキっぱなしでぐいぐい締め付けちゃうっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だんな、様ぁぁ……♪　このまま……このまま抜かないで、動いてぇ……？\n　ダイヤナちゃんのアソコ、もう大洪水で、栓をしてないとダメだからあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……んッ、ぁっ♪　容赦なくピストンしてっ……ズコズコしてぇ♪　下品な\n腰使いでっ……ダイヤナちゃんのオマンコ孕ませて♪　んっんんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「そ、そうよぉ……♪　欲望のままにエッチしちゃって……あっ♪　な、生で\nしちゃって♪　避妊なんてしてないもん……このままし続けて……あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「たくさん精子、ザーメンどぴゅどぴゅしてほしいのっ♪　だんな様の赤ちゃ\nん♪　赤ちゃん欲しいっ……だからいっぱいオマンコで気持ち良くなって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んっ♪　あっぁっあっ……！　あっぁっ、そ、そうぅ♪　そうやって無茶苦\n茶に抱いて、犯してぇ……！　あぁああっ、あたしすぐイクからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「イキ、ながらオマンコ締めながらお尻揺らすからぁ♪　動物みたいに交尾す\nるから、裸エプロンのオマンコに出してね♪　一番濃いの出してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぁ～っ♪　あッぁっ……♪　あっ、あぁんんっ♪　フフフッ……♪　だん\nな様も興奮してるのが伝わってくる……うん、あたしも同じだよぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あっ、ンン♪　セックス気持ちいいっ♪　オマンコイッちゃうっ、イッちゃ\nうぅっ♪　おっぱいも……ずーっと乳首勃起してるの、硬くなってるの！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だんな様のオチンチンのことだけ考えてるぅ……♪　んぁあああっ♪　だか\nらだんな様もぉ、ダイヤナちゃんのオマンコにだけ集中してぇ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んああぁっ♪　ああっ、あぁ、あぁ♪　んぅううっ♪　うぅ♪　はぁんんっ\n♪　奥っ……奥にどちゅ♪　どちゅってオチンポの先っちょ当たってるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「いいよっ、そのままぁ……そこを狙ってて♪　そこにびゅっびゅしてね♪　\nあっ♪　ダイヤナちゃんの赤ちゃんのお部屋にザーメンちょうだい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「びゅるっ、びゅるるって絶対妊娠しちゃうくらい……！　濃くってにが～い\n精液出してね♪　あっ♪　あっ、またイキそう、イクッ……イクぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ～～～～～ッ♪　あっ♪　あっぁっ♪　イクイクイクッ♪　イクぅうっ♪\n　中出しされてオマンコイッちゃうぅうう～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぁっ♪　あああっ、あぁ……わかるぅ、ザーメンっ！　ドクドク子宮に注\nぎ込まれて……あぁ♪　受精の準備してるっ、あたし今イッてるぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ～～～っ♪　もっとぉ♪　もっと密着しながら！　股間ぐいぐい押しつけ\nながら出して！　出して！　一滴もこぼさないように、全部ちょうだいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんっ！　ダイヤナちゃん幸せぇええ♪　大好きな、愛するだん\nな様にこ～んな素敵な種付けしてもらえてっ、世界一幸せぇっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ～っ♪　あ～っ♪　あったかいよぉ……！　あなたの種……オマンコに満\nちてくぅ、あたし、あたし……！　感じ過ぎておかしくなっちゃうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぁはああああ……♪　はぁあああ……♪　ぜ、全部出たぁ……？　あっ！\n　ダメ……！　そのまま抜くのはだめぇ……！　やだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん、このままお尻をくっつけて……オチンチン刺激するから、\nも～っと確実に孕むように……妊娠するようにして？　もっとしてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「……まだ、したりないでしょ？　精力旺盛なだんな様のことなんだし……。\nあたしも……もっとしたい。もっとイカせてほしい。精子欲しいの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ねぇ～♪　おねがぁい……♪　オチンチンだってまだまだ硬いしぃ……。こ\nのまま続けてエッチしてぇ？　オマンコ、ずっと痙攣してるんだよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だんな様のオチンポ抜いて欲しくなくて……。あんっ！　そぉ♪　そうやっ\nて……あぁんっ！　続けて欲しくてぇ♪　ビクビクしてるのぉおっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あはぁああっ♪　やった♪　もう一度してくれるのねっ……！　あっあっあ\nっあっ♪　嬉しいっ！　あたしも頑張るっ、もっとエッチに腰振るぅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「はぁんんっ♪　あぁんっ、あんっ！　あんっ♪　あっ……！　フフフッ♪　\n締め付けっ……まったく緩んでないでしょ？　すごく絡みついてくるでしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃん……ものすごく感じちゃってるの♪　だんな様の愛のザーメ\nンまみれのオマンコが、うねうね蠢いちゃってす、すごいのぉ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「勝手に精液っ、絞り取るみたいにぃい……！　細かく動いてて♪　そこにズ\nンッ、ズンッてなが～いオチンポ突き刺さってきて♪　……あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ほんっとぉおおおに気持ちいいい……♪　何度でもイッちゃうっ♪　あぁ♪\n　イクぅっ♪　イキすぎてオマンコ柔らかくなっちゃう、溢れちゃう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「愛液と精液がまざって……ああっ！　すごくイイのっ、気持ちいい……！　\nんぁんんっ！　好きっ、好き、だんな様ぁ……好きぃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あたし……あたし、こんなに幸せで♪　エッチなこと初めて♪　ずっとこう\nやってイチャイチャエッチしたかったのっ……ず～～～っとぉ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんっ、あんっ！　今だけは……っ、ダイヤナちゃんの全てはだ\nんな様のものだからっ！　オマンコでずっとご奉仕するからぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんっ……赤ちゃんください♪　ダイヤナまんこに赤ちゃんの種くださ\nぁいい……♪　本物の、本当のお嫁さんにしてぇ♪　あっあっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなた、だけを♪　一生愛します♪　このオチンチンだけに尽くしますぅう\nっ……！　だから、だからお嫁さんの証をちょうだいぃ♪　あっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんをエッチなママにしてぇ♪　……ん～～～～っ！　奥ぅ……\n一番奥、突き上げられて……全身があま～く痺れてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「もうっ♪　もう、だんな様のオチンポのことしか考えられないぃ……！　あ\nうっ♪　くぅうっ♪　すごくいいの、ずっとイッちゃってるのっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ねぇっ、ねえ、一緒にイキたいのっ……！　ダイヤナちゃんイクっ、イクか\nらっ、一緒に来て……！　あ～～～～～～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204218" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オマンコ、全力で締めるねぇ……っ♪　んぁあああっ♪　全身全霊でオチン\nポ絞るから、一番いいの、新鮮なザーメン……くださぁいい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「っあぁっ！　ああっ、あああっ……！　イクぅうう……！　イクっ！　出し\nて……出して♪　ママにしてっ、あなたの精子……ここに出してぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あ～～～～～っ♪　きたぁ♪　きたぁああ……っ♪　二度目の精液きたぁ、\n上がってきたぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ッきゃぁああん♪　あぁんっ！　あぁあああんっ♪　デキちゃってるぅうっ\n♪　赤ちゃん絶対デキちゃってるぅうう～っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ふぁああっ♪　あぁっ、あぁあんっ♪　かかってるよぉ、ちゃーんとダイヤ\nナちゃんの赤ちゃんのお部屋に精液かかってるよぉ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あなたはっ……最高のだんな様よぉ……！　あっ♪　エッチが上手で♪　精\n子が多くて♪　あんんっ、二度目なのにこんなにたくさん出してくれて♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ほんっとぉおおおおに大好きぃいいい♪　あ～～～～っ！　イキながら精液\n発射されるの本当に好き♪　ありがとうっ、大好きぃいっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ん、は……♪　はぁああんん……♪　大満足……♪　ダイヤナちゃん、感動\n……。こんなにも激しく求められちゃうなんて……最高♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「これが可愛いお嫁さんになるってことなのねぇ……。愛するだんな様のため\nにお料理をして、毎日飽きるまでエッチして……♪　ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こーんな楽しいお仕事だったらぁ、２４時間３６５日ずーっとしていたいわ\n。もしかして天職？　うふふっ、エッチなことだってもっともっと！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「だんな様の好みに合うようにい～っぱいお勉強しなくっちゃ……。ねえ、次\nはダイヤナちゃんにどんなことをしてほしい？　したい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんが出来て、パパとママになっても～。ずーっとエッチなこと、して\nくれる？　それならあたし、いくらでも頑張れちゃいそうよ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ええええっ！？　なぁんでぇ！？　なんでオチンチン抜いちゃうのぉっ！　\nあっ……ま、待ってぇ、だめだめぇ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「んぁっ……あぁああんっ！　お腹っ……おっぱい、熱い……熱いぃいっ♪　\nドクドク精液がかかって……あっあっあっ♪　これはこれでイイけどおっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「赤ちゃんっ♪　作るって約束したのにぃ、外に出すなんて……！　いじわる\nぅううう……！　あっ！　あっ！　そんなにかけちゃだめ、んぅううんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「やだぁあ……♪　お嫁さんをこんなにベタベタにしちゃって何がしたいのぉ\n……。お料理だってまだ出来てないのにぃ、ザーメンシャワーなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「愛してるからいいけどぉ……って、やんっ！　まだ出てるっ……！　も、も\nぉ！　わかったからとりあえず全部出しちゃってぇっ……あああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「オチンチンビクビクしてるぅ……！　はぁあっ♪　これ……オマンコで、ア\nソコで感じたかったのにぃ……バカぁああ……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「っふぅううう……♪　ぜ、全部出せた……？　ダイヤナちゃんは怒っている\nけどお……まあ、だんな様のしたいことをしてもらうのも大事かなぁって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000602_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「こんなに何度も、濃くてにがーい精液を出せるあなたのことだもの……。本\n気で赤ちゃん作るってなったら、きっと一発でキメちゃうものね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「それまで……２人っきりで、まだまだイチャイチャの蜜月を過ごしたいって\nことでしょう？　そう思ったら……うふふっ、ドキドキしちゃう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「あたし、これからもあなた好みのお嫁さんになれるように努力する！　だか\nらいつまでも……ダイヤナちゃんのこと、可愛がってね？　だんな様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
