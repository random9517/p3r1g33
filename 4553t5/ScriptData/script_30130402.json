{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「……こぉんな夜更けに、ど・ち・ら・へ？　ああ。私を呼びに行くところで\nしたか。ちょうど良かったです♪　んんっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404101" ]},
		{"command":[ "SETCHARA", "0", "char_00001304_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あなたが、あんまり私を放っておくものですから……。とうとう耐えきれな\nくなって夜這い。しにきました。嬉しいですか？　それとも困惑？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404102" ]},
		{"command":[ "SETCHARA", "0", "char_00001304_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「どちらでも結構ですよ♪　することは同じですから……うふふ。えぇ？　拒\nめますか？　発情して、おまんこ濡らしちゃっている私を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404103" ]},
		{"command":[ "SETCHARA", "0", "char_00001304_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「無理ですよね。なら、素直になっちゃってください♪　んふ……♪　悪いよ\nうにはしませんよ、気持ちよくはすると思いますけど。……そぉれ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「良かった……来てくれた。もう私のこと、必要ないのかなって不安になっち\nゃってました。来てくれて、ありがとうございます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「だぁってぇ。邪魔なんですよぉ！　ちまちました愛撫なんていりません、脱\nがし合う時間すらもったいない。私が欲しいのは強い快楽と刺激だ、け♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あんっ♪　やぁだ……。あなたもその気だったんじゃないですか。『あんま\nり誘惑されたから？　えぇー？　どうでしょう……。んっ、ぁ……は♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404107" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「こう、やって♪　アソコを指でぇ……ぱっくり割り開いていても♪　ピンク\n色のおまんこから愛液がトロトロ溢れ出してきても♪　ただのくぱぁですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「勝手に濡れたおまんこを……。ぁっ、見せつけて、乾かしているだけ。それ\nを見て発情するのはあなたの勝手。そうでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「『お尻の穴も丸見えのワンワンポーズで、挑発しまくっているじゃないか』\n？　んー……どうでしょう。ただの趣味かもしれませんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「私、本当はドＭで……。あなたに恥ずかしいところを見られるのが……。は\nぁ、はぁ、好きだから……♪　ッん……。だから、だから見てください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「よーく目をこらして……。んふ♪　なんなら手のひらで好きなところをまさ\nぐりながら……あっ。そう、そうやって♪　確かめ、て……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「くふ……♪　ええ、びちゃびちゃに濡れていますよね。その上、アナルはヒ\nクついて……。乳首だってずーっと勃っちゃってます。なぜかって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あなたとエッチしたくてしたくて、待っていたからですよ♪　あなたに無理\nやり襲われて、ゴムもつけずに生挿入されて……中に出されちゃう妄想」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「何百回も、何千回もしてたから……。すっかり身体が受け入れＯＫな状態に\nなっちゃっています。チンポが欲しいって泣いてるんです……ほらぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「お尻ふーりふり♪　おっぱいゆっさゆさ♪　腰を揺らしてぇ……犬より下品\nにおねだり♪　しちゃいます♪　チンポ、早くチンポを入れて……ぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「私のアソコで気持ち良くなって、たーっくさん精液を睾丸で作ってください\n、溜めてください。そしてくっさいザーメンぶちまけてほしいんです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「……んッ♪　ぁ……。立派なチンポぉ……♪　見せ槍って言うんでしょう？\n　こうしてチンポの大きさ、長さ、太さを女の目に焼き付けてからの挿入♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「……あぁああ♪　楽しみです、頭がヘンになりそう♪　はっ♪　はっ♪　で\nっかいのはわかりました、もったいつけずに早くぅ……ん！　んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「はぁあっ♪　あァアアアアっ……♪　や、ばいです……ぅ、ああああんっ♪\n　まんこの入口、こじあけられて……チンポねじこまれて……あーっ♪」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404120" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「こんなの即イキですっ♪　あっひっ、ひぃいいいん♪　粘膜、粘膜拡張され\nてオマンコされてるぅ♪　最高っ、最高の辱めぇぇ♪　ひぃっ、ひぃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404121" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「種付けすることしか能のない精液発射専用チンポ♪　みっともないくらい交\n尾に特化した、ドスケベ淫乱肉チンポ♪　っだぁい好きぃ、好きぃいい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あっ、あっ♪　ぼさぼさしてないでほじりまくって♪　私の肉穴、チンポ専\n用穴ピストンして♪　……遅いっ、こうするんですっ……あ、あ、あ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あんっ！　あんっ、あンンンっ、あぁん！　んっひぃっ、ひぃっ、ひぃい♪\n　こうやってめちゃくちゃに腰を使って……！　イクぅ♪　イく、イくう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「自分の性感帯に当たるように、……あっ！　ガチイキするまで押し当てて、\n突き入れて……ふぁあああん♪　うまいこと快楽を貪るんですよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あう♪　あう、うぅ♪　ぎっこんばったん、ぎっこんばったんシーソーみた\nいに……あっ♪　おまんこぶっ壊れるまで激しく、激しく、ピストンっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「……あなたも手伝ってください！　んぁっふぅううっ♪　んふううぅうう♪\n　くぅうっ♪　くふぅうっ……くぅんっ、くぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「そうっ！　野獣のように、メスの肉を食らってオマンコすることだけを考え\nて♪　あふ♪　んふぅうっ♪　まだ足りないぃ、奥まで突いてえ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404128" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「子宮口が衝撃で歪むくらい、デカさ自慢のオスチンポを叩きつけるんですぅ\n♪　私♪　がっ、気絶するくらいっ♪　おっ♪　その調子……ですっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「白目を剥いて泡を吹いてアクメきめるくらいぃ……乱暴に、オマンコ汁を味\nわいながらぁああ♪　エロマンコ、メスマンコ屈服させてほしいぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「んくぁあああ♪　ふぁああっ、あーっ、あぁああ♪　あっんっ、んんっあっ\n♪　マンコ、オマンコするの気持ちいい♪　ハメられるのいいっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「んぁっえぇえ♪　ひゃうううっ、んふぅう♪　おほぉ♪　その調子、その勢\nいで入れ、て♪　抜いて入れて抜いて入れて抜いてぇえええ入れてぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404132" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あは……あはははっ♪　信じられないくらい恥ずかしい音してますよぉ♪　\nでも、もっと奏でられますよね、卑猥な水音♪　あ、協力して♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「協力して交尾音……部屋の外に聞こえるくらいに響かせちゃいましょう♪　\nオマンコとオチンポが重なりあって、混ざって鳴る愛の音ぉおお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ああああああぁ……♪　ぐぢゅっぷっ、ぐちゅぷっ、ずっちゅずっちゅぬち\nゅぅ……♪　ぼちゅっぼちゅっごりゅっごりゅうってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「も、もぉ快楽のフルコースです♪　愛液止まらない……♪　奥を、奥を容赦\nなく攻めまくる剥き出しのチンポ……♪　これがクるの、イイのっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あぁーーーっ♪　オマンコ、ガチで痙攣しっぱなしですよ♪　わかりますよ\nね♪　これ本気イキの時の震えですっ♪　え？　キツい、締めすぎぃ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404137" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「締まる？　あははっ、うふふふ、当然でしょうっ♪　オマンコでホールドし\nてぇ、精子絞り出すんですよ！　今更逃がすわけないじゃないですかぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404138" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あなたのぉお♪　チンポ事情なんて知りません♪　私が欲しい時に精液吸い\n上げるんです、そのためにがっちり捕まえて、刺激して、操作してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「いちっばん奥で射精するように教えてあげるんです！　うふ、ふふふっ、う\nふふふっ！　今ですよ、絞りますっ♪　あっつい精液出してください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「んくぅうううううう～♪　ふぅううううう♪　ふぅうううううんんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404201" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あ、あああああ～♪　出されちゃった、一番奥に射精されちゃったぁ♪　つ\nきみには絶対見せられない♪　お姉ちゃんのメスアヘ顔ぉお♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「でも、でもいいですよね！　私今、プライベートですもんっ……♪　悪に堕\nちた私、が、何をしてたって妹には関係ありませんよね。っあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「お腹の中で暴れ狂った凶暴なチンポから、無遠慮に吐き出される精液♪　膣\n内に何度も何度も発射されて、塗り重ねられていく白濁ぅうう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ギッチギチにチンポ締めあげる私のオマンコと♪　されるがまま、言われる\nがままに精子奪われる情けないあなたとっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404205" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「どっちの粘膜もビクビクビクビク振動しちゃって止まらない……♪　ああっ\n、相性いいんですねぇ♪　身体の相性だけ♪　んああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ううん、粘膜同士の接続が……接触が、誰よりもうまくいくだけの二人……\nぃ♪　はぁっ……あなたも心地よく出せましたよねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「『出したから抜くぞ』？　まさかまさかぁ♪　一回で、溜まりに溜まったこ\nの情欲が発散されるわけないじゃないですかぁ。次いきますよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404208" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「は、ぁんっ♪　あぁんんっ♪　あはぁああ♪　……あれぇ？　チンポは随分\n正直ですね？　私と離れたくないって言ってますよ、健気に再勃起して」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんのお姉ちゃんマンコに気持ち良くしてほしいって言ってます♪　\nいい、ですよ♪　っていうか、御託はいいから腰振ってください♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あ！　ッああ！　そぉ！　精液まみれになったオマンコ！　中出しマンコに\n精子ぬりたくって……妊娠させて、早く！　早く、もっと速くぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404211" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「オマ、ンコ以上にしたいことなんて何もないでしょう！？　だったら気合い\nいれてキツキツのアソコ♪　こじあけて奥に、奥にきてくださいよっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「それで何度も！　何度も何度も生オマンコするんですぅうっ♪　あっ♪　あ\nっ、あぁっ♪　オマンコ♪　オマンコ、オマンコいい、キくぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404213" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ほかほかの出したてチンポ、一度も抜かずにズコズコピストンん♪　高速ピ\nストンしてっ、摩擦してっ……。私のお腹冒険してぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あふぁああああ♪　うぅうううん♪　そうですっ！　抜けちゃうギリギリま\nで腰を、引いて……体重かけて、チンポの長さ叩きこんで、んふぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「マンコの奥にわからせるんですよっ。私なんかオマンコするために生まれた\nオマンコちゃんなんだって、あ、なたの、オマンコ穴なんだって♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「うぅう♪　あああっ！　あぁっ！　あぁっ！　あぁ、ああああっ……！　あ\nーっ！　オマンコを、チンポが、チンポが拡張してる、してるぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「私は締めて、あなたは拡げて……！　んーっ……♪　お互いに快感を与えあ\nって、体力の限りオマンコし続けて……！　あっ！　あぁあああん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「子宮が、子宮がもう一回精液欲しいって要求してます！　出せますよねぇ！\n？　私が欲しているんだか、ら♪　あぁっあああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404219" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「間違えないで、一番奥に……！　中に出してくださぁい♪　……ん！　吸い\n上げ、ますよ♪　搾り取ります……！　んふぁあああああ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ザーメンっ……！　ザーメン、ザーメン、ザーメンんんん♪　ドロッドロの\n恥知らずザーメンが、私のお腹を破らんばかりにぃいいい……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「はぁああん♪　こってりしたザー汁が濁流のように押し寄せてきます、身体\nが……お尻が持ち上がるくらい♪　ビュルーッ、ビュルビュルぅってぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あ……♪　あ♪　ザーメンはおしっこじゃないんですよぉ♪　そんなに大量\nに発射したらぁあ、子宮から逆流しちゃう♪　もったいないぃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404303" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「『とか言いながら、射精の最中も腰を揺らしているだろ』って？　それはそ\nうですよ、奪えるところまでは……あぁんん、奪わないと失礼です♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404304" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「せっかくあなたが女の子の♪　私のオマンコで精液漏らしてくれたんですか\nら無駄にはしません、……ン♪　オマンコで吸い取っただけです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「それが、激しいセックス直後の礼儀……、んいいい♪　さ、最後に、最後に\nぴゅるって出た♪　あーーーーー射精って素晴らしいです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「生きてるぅって感じがする♪　ザーメン奴隷として♪　あなたの精子タンク\nとして役割を果たせたっていう安心感……。それに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「オマンコがじわぁあああーって熱くなって、ザー汁大歓迎しちゃってるんで\nす♪　本能に従うって、理性を捨てるって気持ちいいいいいですねええ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「メスとして生きる喜び……♪　はぁんんッ♪　オ、オチンポも、チンポも『\nそれでいい』って♪　言ってくれていますよねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「これだけ出しておいて気持ち良くなかったなんて言わせませんよ。本当に、\n壊れた蛇口みたいで素敵♪　また、すぐに夜這いしたくなりそう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「んぁあああっ！？　すごい力……！　私に反逆して、チンポを抜いて……あ\nあ、外出しですねっ……♪　反抗的ぃい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あはぁあ♪　さすがは悪の組織、の一員ですね♪　臭くてベタベタな精液を\n……ザーメンを私にぶっかける流れもとってもスムーズで……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あんんっ！　あぁんんん！　芸術的なくらい♪　かかってる、かかってる…\n…！　精液発射されちゃってるぅ……！　これもいい、いいです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404403" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「うふふふ♪　子作りのために♪　中出しのために……膣内に精子出すために\nシてたんじゃなくて♪　ただ快楽のために、快感に従順に♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「気持ち良くなりたくてチンポ入れてたってことですもんねぇ♪　赤ちゃん作\nるんじゃなくて、チンポ満足させたくて入れたってことですもんねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「っはぁあああああああ……♪　刹那的でときめきますぅ♪　それに、身体に\nかけられると……ザーメンの熱さが、重さが、色がよくわかって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404406" ]},
		{"command":[ "SETIMAGE", "0", "still_00001304_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「あなたにマーキングされちゃったんだぁって、汚されちゃったんだぁってい\nうのがはっきりわかって……。んん……♪　興奮しました♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「ふふ、……あなたの底無しの精力、尊敬します……。あぁ、オマンコだけじ\nゃなくて全身で妊娠しちゃいそぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「背徳的で、傲慢で、とってもとってもいいですよぉ♪　あー♪　膣内射精と\n外出しと、同時にしてもらえたらいいのに♪　満たされるのに♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "エビル・シルバスター" ]},
		{"command":[ "SETTEXT", "「……これからも、私のためにたくさん精液を作ってくださいね♪　期待して\nますよ……うふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_013_0404410" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}