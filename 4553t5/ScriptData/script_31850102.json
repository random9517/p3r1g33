		{"command":[ "PLAYVOICE", "v2_185_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「いっぱいーいっぱいー腰を振って、おまんこずぼずぼーってしてー……っ！\n　ああんっ！　お姉ちゃんも、気持ちいいのー……っ！」", "NORMAL" ]},
