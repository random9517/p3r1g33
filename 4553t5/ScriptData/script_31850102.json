		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃーん。お姉ちゃんーきたわよー。んふふー、隊長ちゃんとーエッチ\nしちゃうのよねー。お姉ちゃんとっても楽しみー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00018501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「だからー、お姉ちゃんねー、隊長ちゃんのことをーお姉ちゃんの殻の中にご\n招待しちゃおうと思うのー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「あーん、遠慮しなくたっていいのよー。ほーらほーら、隊長ちゃん、お姉ち\nゃんの中へーれっつごーよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んふふー。どうかしらー。隊長ちゃん、ここがお姉ちゃんの殻の中よー。ん\nんっ、やっぱりーふたり入るとちょっぴり狭いわねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104104" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00018501_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「でもー、おかげで隊長ちゃんとぎゅーって密着できちゃっているわー。はぁ\nー……隊長ちゃーん、ぎゅ～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああん、隊長ちゃんからも、お姉ちゃんのこと抱きしめてー……。ああん、\nお姉ちゃん、お汁が溢れてきちゃうわー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ねっとねとのー原液お姉ちゃん汁よー……っ！　んんっ、あっ、あぁんっ！\n　いっぱいーぬるぬるになっちゃうわー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃーん。お姉ちゃんとー密着しちゃいましょうねー。ンッ、あぁー…\n…っ！　隊長ちゃんってば、暴れないのー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「お姉ちゃん汁でーぬるぬるになっちゃってー……はぁんっ、おちんちんー勃\n起しちゃってるのねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んっ、んんー……っ！　腰が動いちゃっているわよー。隊長ちゃん、必死に\nおちんちんをお姉ちゃんのお腹にこすりつけてるー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「気持ちよくなってーおちんちんをーお姉ちゃんのおまんこにずぶーってハメ\nハメしたくなっちゃったのねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んっ。もちろんいいのよー。お姉ちゃんもー隊長ちゃんのおちんちんをーお\nまんこに入れて欲しいのー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ほらーここよー。お姉ちゃんのーいちばんぬるぬるでーとーってもいやらし\nい穴ー……ンッ、おちんちんー熱いのー当たってー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「はぁー……入ってきたー……っ！　んんっ！　あぁー……おちんちん、すっ\nごく、おっきいのー……ああっ、ああー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104114" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「こんなにー立派でーたくましいのをー……隊長ちゃんは、もっていたのねー\n……んっ、お姉ちゃんーびっくりしちゃったー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、すっごいー。隊長ちゃん、いきなりおっもいっきりーっ！\n　んっ、んんーっ！　腰、振ってるのねー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ！　そこっ、そこー……っ！　んんっ、んぁっ、ああっ！　\nああー……っ！　んっ、んふぅー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「お姉ちゃんの、いいところにー。隊長ちゃんの、ぶっといおちんちんが、ご\nり、ごりってー……んっ、ああっ、気持ちいいわー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んぁあっ！　隊長ちゃん、おっぱいもー……っ！　はぁんっ！　お姉ちゃん\nのおっぱいまで、一緒にー……ああっ、ああー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「やぁんっ。おっぱいまでー、隊長ちゃんにー……っ！　んっ、んんー……っ\n！　思いっきり、甘えられちゃってるわー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ひゃんっ！　そうなのーお姉ちゃんーおっぱいも感じちゃってるのー。隊長\nちゃんに、おまんこされながらーおっぱいもー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「はぁんっ！　ああっ、ああー……っ！　すっごく気持ちいいのよー。隊長ち\nゃんのおちんちんもーお手々もー……っ！」", "NORMAL" ]},
