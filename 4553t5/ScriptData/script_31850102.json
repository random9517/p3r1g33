		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、ああっ、ああー……っ！　隊長ちゃんのおちんちんが膨ら\nんでー……っ！　おまんこーいっぱーい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「びくんびくん暴れるおちんちんでーお姉ちゃんイッちゃうーイッちゃうー…\n…っ！　ああっ、ああぁぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのこと、ぎゅ～～～ってしながらー……っ！　お姉ちゃんイクッ\n、イクイクイクー……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「あああぁぁぁああぁぁあぁっ！　精液きたっ、きたー……っ！　隊長ちゃん\nの精液っ、精液ーっ！　中にーいっぱーい……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「おちんちんーびくびくさせながらー……っ！　ああっ、びゅくびゅく中出し\nー……っ！　ドロドロ特濃隊長ちゃん汁注がれてる～……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああー……っ！　お姉ちゃんイッてるー！　イッてるのにーっ！　おちんち\nん止まらないー……っ！　ああっ、ああー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「イッてる最中のおまんこー……っ！　ああんっ！　おちんちんでごしごしさ\nれるの、だめー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「あぁあー……っ！　またっ、イクッ、イクッ、イク～～～ッ！　ああぁー…\n…お姉ちゃんー気持ちよくなりすぎちゃってるのー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああんっ！　止まらないっ、止まらないのー……っ！　んっ、んっ、ああっ\n、ああー……っ！　好きっ、好きっ、好き～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長ちゃん、もっともっとエッチしてくれるの？　お姉ちゃんのこ\nと、も～っと気持ちよくしてくれるの～っ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「うん、お姉ちゃんも、気持ちよくするよー。隊長ちゃんと、せっかくふたり\nっきりで、殻の中エッチだからー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「おっぱいでもー、おまんこでもー……いーっぱい、ぎゅ～ってしてあげちゃ\nうんだからー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んふふー……時間を忘れるくらい、ねっとりぐっちょり、お姉ちゃんと絡み\n合おうねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああぁっ！　あああぁぁぁああぁぁあぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「おちんちんー抜けちゃってー……っ！　ああっ、精液ーお姉ちゃんの身体に\nーたっくさーん……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「はぁー……はぁー……。隊長ちゃんのドロッドロのお汁ー……とっても熱く\nてー……それにー……すっごい匂いー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んんぅー……。こうして密着しているからー……精液のエッチな匂いがー…\n…はーっきりわかっちゃうわねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああー……。お姉ちゃん、この匂いだめー……。さっき、イッたばっかりな\nのに、またエッチな気分になっちゃうー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んふー……？　そうねー……隊長ちゃんもーもっともっと、お姉ちゃんとエ\nッチしたいわよねー……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00018501_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「ああん。また、隊長ちゃんの勃起おちんちんがーお姉ちゃんのお腹をこすっ\nてるわー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「まだまだガチガチー……。お姉ちゃんとーもーっとエッチしたくてーたまら\nないのねー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「んふふー、いいのよー。今日はー、お姉ちゃんと一緒にー、気がすむまで気\n持ちいいことしまくっちゃいましょうねー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_185_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「お汁にまみれながら、ねーっとり濃厚セックスー……。お姉ちゃんと、楽し\nみましょうねー……」", "NORMAL" ]},
