		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リアン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんと、狭い殻の中でぎゅーって密着してー。全身から、エッチなね\nとねとお姉ちゃん汁ーいっぱい、溢れさせちゃうのー……っ」", "NORMAL" ]},
