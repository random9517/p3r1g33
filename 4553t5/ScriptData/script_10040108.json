		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「隊長代理ー！　この申請書なんだけどさ。書き方これでいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「そうね、問題ないわ。事務の窓口に提出してね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116460001" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「わかったー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116460002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっそ……！　セレーナが、自分で訓練場の使用申請を……！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「隊長代理。パトロールの報告書だが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「ありがと。あ、でも、ここの誤字だけ直しておいて。デスクの上に置いとい\nてくれれば、判子を押して長官に出しておくから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116460002" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「しまったあ！　完璧に書けたと思ったのにぃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116460002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「大丈夫よ。気にするほどのミスじゃないわ。私もよくやるから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116460003" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「マジか！？　ルナテミスも！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「それじゃ、パトロールに行ってくるわね～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010116460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ダイヤナまで働いてるぅ！？　なんなんだ！？　EDOはいったいどうなっ\nちまったんだぁ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これというのも、昴隊長代理がとてもとても有能だからでしょうなあ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そ、そうか……ま、まあ、それはいいな。いいことだよな。うん……さて、\nこっちも仕事を……あれ？　ここにあった書きかけの書類は？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「ああ、それなら私がやっておいたけど？　ちょうど手が空いてたし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116460004" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「手が空いてた！？　マジで！？　あれだけ働いてたのに！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「別にたいしたことはしてないわ。それより、他にも処理してない書類がある\nんじゃないの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116460005" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　あ、まあ……少しな？　ほんの少しだけ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「じゃ、それも私がやっておくから。隊長は休んでて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116460006" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え、でも……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「いいのよ、いつも大変なんだし。いまのうちに昼休みをとって来て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116460007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、ああ……じゃあ、メシ食ってくる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（これは……ナニか？　もしかして、俺はいるだけ邪魔ってこと……？）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
