		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うっそ……！　全員がちゃんとプリントを提出してる……！？　ルルーナど\nころか、マーガレットまで！？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "マーガレット" ]},
		{"command":[ "SETTEXT", "「だって、昨日、スバルからみんなに確認のメールが回ってきたんだもの！　\nさすがに私だってプリントのこと思い出したわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_020116460001" ]},
		{"command":[ "SETCHARA", "0", "char_00002402_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこまでやってたのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "スバル" ]},
		{"command":[ "SETTEXT", "「いや、それも副委員長の仕事だと思って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116460001" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「うっ……ううううっ！　よかった……！　優秀な副委員長が来てくれたおか\nげで……私の苦労が報われる日が来ました！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020116460001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "明日楽" ]},
		{"command":[ "SETTEXT", "「みんながこんなにちゃんとしてくれて……！　教師生活＊＊年、こんなに嬉\nしいことはありません！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_016_020116460001" ]},
		{"command":[ "SETCHARA", "0", "char_00001602_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はぁ……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "（教室でもスバル大活躍かぁ……もしかして、これは本当にオレなんか……）", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「…………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116460003" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "（おっと……これはやりすぎかもしれませんな。ご主人のひがみ根性が発動し\nてしまったようですぞ）", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020116460004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "（しかしまあ、もうしばらく様子を見ましょう。ただ見物している分には、面\n白い見世物でしかありませんからなぁ！　ムホホホホホホ！）", "NORMAL" ]},
