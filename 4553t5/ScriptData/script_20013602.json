{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ふーんっ、ふんっ、ふふーん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460001" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女子学生Ａ" ]},
		{"command":[ "SETTEXT", "「あっ、ヤムちゃんだー。おっはー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あー、うん、おーす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460002" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女子学生Ｂ" ]},
		{"command":[ "SETTEXT", "「うひょー、ヤムちゃん、今日も可愛いねー、どうどう元気ー？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んー、まぁまぁかなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女子学生Ａ" ]},
		{"command":[ "SETTEXT", "「そかそかー、あっ、ね、アメちゃん食べる？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「んー、食べてもいっかなー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460004" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "女子学生Ａ" ]},
		{"command":[ "SETTEXT", "「おけおけ。じゃ、手ーだして。はいっ、おすそわけっ。そいじゃねー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うぃー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460005" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「何か、めっちゃもらったな……ヤムの１つでいいのに、食べ切れないし……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460007" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「どーしよ。あー、イルルでいっか……ついでに、ちょっとからかいに行くか\nなー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460008" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あいつ、今日はどうしてるんだっけ……ま、ちょっと探してみますか。えっ\nと……力の気配は……っと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460009" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460010" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ナニこれ……街のど真ん中に、ワケわかんない強いのおるんデスけど……！\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「………………」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460001" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「アレだ……！　えっ……あ、アレって……まさか、プルリーヤンカシュ……\n！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460012" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「えっ、なんで……こんなとこにいるワケ？　いや、待って……よく見ると、\nちょっと違う……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「でも……あんなヤバいオーラ出せる奴、他に知らないし……間違いないよね\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460014" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「……何かヤな予感するし……。見なかったことにしとくのが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460015" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「こんにちは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460002" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うっひゃぁぁぁぁぁぁっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460016" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あぁ、驚かせてしまい申し訳ありません。つかぬことをお伺いしますが……\nあなた、私のことが分かるみたいですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460003" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「……い、いつの間に、後ろに……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460017" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「何やら、波動の力を探る気配があるかと思えば……まさか、こんな可愛らし\nい子が見つかるとは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460004" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「な、何の話……？　ヤ……あ、あたしには何のことか分かんないんデスけど\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460018" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「別に隠す必要はありません。一度認識してしまった以上は、ちょっと気配を\n殺した位で見落とすことはありませんから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460005" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「…………っ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460019" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「それで、改めて確認しますが……貴方は、私のことを龍として認識しました\nね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460006" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「……さ、さぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460020" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ご心配なく。特別、貴方のことをどうこうしようとは思っていません。実は\n私、娘を探しておりまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460007" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「へ、へぇー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460021" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ちょっとしたことで、はぐれてしまったのです。次元の断裂があったみたい\nで……ここまで来るのも中々大変だったのですが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460008" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ああ、そんなことはこちらの都合で、どうでもいい話でしたね。それで本題\nなのですが……貴方は娘を存じておりませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「娘って……言われても……わ、分かんないし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460022" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「イルルヤンカシュという子です。ずっと探しているのですが……心当たりは\nありませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460010" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「あ……はは……ど、どうかな……はぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460023" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460011" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0031" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「ヤバい、ヤバい、ヤバいって！　どう考えたって、あんな規格外のパワー持\nってる奴と関わり合いになっちゃダメっしょ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460024" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "9", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「別に、イルルのとこ連れてっても……いや、何かめっちゃヤバい感じするし\n……とにかく、逃げ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460025" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「どうして、逃げようとするのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460012" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「うひぃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460026" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「その様子ですと、もしかしたら何か心当たりがあるのではありませんか？　\n是非とも教えて頂きたいのですが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460013" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「そ、そんなオーラ剥き出しで凄まれても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460027" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「オーラ……はて、力はセーブしたと思っていましたが、ちょっと絞り込みが\n甘いようですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460014" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「もう少し、きっちりと調節が出来ればいいのでしょうけど、中々加減が難し\nいようで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460015" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤム" ]},
		{"command":[ "SETTEXT", "「知るかってのっ！　てぇーいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_175_010022460028" ]},
		{"command":[ "SETCHARA", "0", "char_00017502_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「あ……あら……？　また、どこかへ行ってしまいましたか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460016" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "プルリー" ]},
		{"command":[ "SETTEXT", "「ふむ……どうやら、あちらの方のようですね。せっかくですし、向かってみ\nるとしましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_230_010022460017" ]},
		{"command":[ "SETCHARA", "0", "char_00023002_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}