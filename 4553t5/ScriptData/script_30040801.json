{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おい、聞いたぞ。この次元では、お前に奉仕することでより強くなれるらし\nいな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803101" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「なにをすればいいのかは知らないが、オレも強くなりたいんだ。だから、お\nとなしくオレに奉仕させろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いいのか……って、おいっ！　なにズボンをおろして、ち、チンチンっ、だ\nしてんだよ、変態！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803103" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00000408_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ほ、奉仕って、チンチンにするのか！？　チンチンに奉仕って……えっ、舐\nめるのか、これを！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「くっ、でも、強くなるためなら……。チンチンだって舐めてやろうじゃない\nか！　お前っ、そこでじっとしてろっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こ、これがお前のチンチン……すんすん……すごい臭いだぞ……お前、ちゃ\nんと洗ってんのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それに、すごく膨らんで……。先っぽの方なんか、キノコみたいになってる\nぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うっ、早くしろとか急かすな！　こういうこと、したことないんだから……\nうう、わかったよ！　な、舐めればいいんだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んちゅっ、ちゅぅ……。うぅ……チンチンと、ちゅーしちゃってる……。ん\nっ、ちゅぶ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こう……か……？　んっ、ちゅ、ちゅぅ……先っぽに……唇、くっちゅけて\n……んっ、ちゅっ、ちゅぷっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「唇だけじゃなく、舌も使えって？　そ、そうだよな……舐めるんだもんな…\n…。んっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こ、こうか……？　んっ、れろ、れろぉ……。お前の……ンッ、チンチンの\n先っぽを……れろ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803112" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「うぅ……変な味だ……。んれろっ、苦いし……しょっぱいし……。んっ、ビ\nクビクしてるし……んっ、ちゅばっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「本当に、こんなことで強くなれるのか……？　んっ、れろ、れろ……嘘だっ\nたら、承知しないからな……れろぉっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んれろっ、れろ、れろぉ……。んっ、さっきよりも硬くなってきたか……？\n　れろれろ、お前、気持ちいいのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「へ、下手くそなりに舐めてる姿がいいって、それ、褒めてるのか！？　あん\nまり調子乗ると、チンチンに噛みつくぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「れろ、れろ……。なんだよ……チンチンの、先っぽを……舐めればいいのか\n……？　んちゅ、こうか……？　れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「れるれるれる……ンッ、チンチンが、どんどん膨らんできて……。ちゅぱっ\n、なんだよ……オレの舌で、ちゃんと感じてるんだな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ぺろぺろ……なんだ？　舐めるだけじゃなくて、咥える……？　チンチンを\n、口の中に入れるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「わ、わかった……ぁ……んむぅ……。こ……こぉ……かぁ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んむっ、んむんむぅ……んじゅるる……。口の中……んぁっ、お前の\nチンチンで、いっぱい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、じゅるるっ。このまま……ンッ、口の中で、舌を動かす……の\nか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んじゅるるっ、ぐぶっ。じゅるっ、じゅるるっ！　ンッ、んふぅ……。こう\nでいいのか？　んっ、んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンチン、口の中で……んぐっ、ビクビクさせるなよぉ……。んっ、じゅぶ\nっ、じゅぶっ！　んじゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んくっ、ちゅっ、ちゅぱっ。んんぅ……。口の中で、んっ、チンチン舐めな\nがら……吸い付いて……んっ、ちゅるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こうすれば……いいのか……？　んちゅっ、ちゅぶぅっ！　んむっ、チンチ\nンの先から……苦い汁、出て……んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「苦いのに……んっ、ちゅぶっ、飲んでいると、頭の中がぼーっとしてくるよ\nうな……んちゅっ、ちゅばっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「もっともっと、ンッ、チンチン、舐めていたくなる……んちゅるっ、ちゅぶ\nっ、ちゅぶっ、ンッ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「じゅるるるっ！　んっ、んっ、んんっ！　じゅぶっ、じゅぶっ、じゅちゅち\nゅぅっ！　んっ、んっ、んん……ぅ……っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんんんんぅっ！？　んっ、んくぅううっ！　んむっ、んっ、んぶっ、んむ\nっ、んぐっ、んぐぅうううぅぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「いっ、いきなり……口の中に、何か入ってきた……。ンッ、なんだこれ……\nネバネバして、変な味だぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こ、これってもしかして……お前の精液、なのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「そ、そんなもの、いきなり出すなよ！　出すならそう言え、びっくりするだ\nろうが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「まったく……んっ、んんぅ……おい、お前……なにしてるんだよぉ……んっ\n、んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンについた、精液の残りを舐めろだって……？　んっ、なんでそんな\nことまで……んちゅっ、れろ、れろぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「後始末まで含めて奉仕だって？　んっ、そういうものなのか……？　んちゅ\nぶっ、れろ、れろ、れろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……で、どうだったんだよ、オレの口。気持ちよかったのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「気持ちよかったから、あんなにたくさん射精できたのか。んっ、んちゅぷっ\n。そ、そうなのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレも、そんなに悪い気分じゃなかったぞ。精液は、不味かったけどな……\nんっ、ちゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「最初よりは……んっ、こうしてチンチンを舐めるのも、イヤな気分じゃなく\nなってるし、な……んっ、ちゅぶ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803140" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「それにしても……ちゅぶっ、いつまでこうしていればいいんだ……？　ちゅ\nっ、ちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンチン……ぜんぜん、小さくならないっていうか……んちゅぷっ、さっき\nよりも、おっきくなってないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ま、また口に入れればいいのか……？　んっ、ちゅぱっ。じゃあ、また咥え\nるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んじゅっ、じゅるる……。ほら、また……んちゅっ、チンチンしゃぶ\nって……んっ、じゅぶ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こうしていれば、んっ、ちゅぶっ。また、チンチンから、精液を出すよな…\n…？　んちゅっ、ちゅばっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、じゅぶっ、じゅぶっ、じゅぶじゅぶ……んっ、んふぅ？　な、なんだ\nよ……んじゅるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「う、うまそうにしゃぶってるって！？　んっ、んなわけないだろうがっ！　\nんっ、ちゅぶっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こ、こんなこと……んっ、ちゅぶっ、強くなるために、仕方がなくやってい\nるだけなんだから……ちゅばっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803208" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だからっ、んっ、さっさと精液を……んじゅるっ、また、オレの口に出せよ\nな……んっ、んんぅっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「腰っ、急に動かしたらっ、んぐっ！　チンチンが口の奥に入るっ、んっ、ん\nんっ！　んふぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803210" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んふっ、んふぅっ！　じゅるるるっ、ンッ、じゅぶっ、じゅぶっ、んんぅう\nうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「口の中っ、んぐっ、チンチンでかき混ぜられて……んじゅっ、じゅぶっ、頭\nが……ンッ、くらくらする……んじゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お、お前のチンチンしゃぶっているうちにっ、んじゅるっ、オレの身体、お\nかしくなってきたんじゃないか？　んっ、んんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「口の中っ、んじゅるっ、よだれがどんどん、溢れてくる……んじゅぷっ、ん\nぶっ、んっ、んぶぅっ！　んっ、んじゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「め、メス犬の顔、だとぉ……んじゅぶっ！　そ、そんな顔、してない……ん\nっ、んんぅっ、ちゅぶっ、ちゅるるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「でも……ンッ、でもぉ……。じゅぶっ、お前のチンチンしゃぶるのに……ん\nじゅるるっ、夢中になってしまうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンチン……んじゅるるっ、じゅぶっ、じゅぶっ、んちゅぅ……っ！　んぁ\nあっ、しゃぶるの、止まらないぃ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「腰……勝手に、動いて……。ンッ、ちゅばっ！　お前のチンチンを……嬉し\nそうにしゃぶってしまう……ど、どうなってるんだよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んじゅるっ、じゅぶっ、じゅぶぅ……っ！　な、なんだ？　ンッ、もう射精\n、しそう……？　んっ、じゅぶっ、じゅるるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、いいぞ、出せ。んっ、オレに、お前の精液……んじゅっ、じゅるるっ\n、出して……！　じゅぶっ、じゅぶっ、じゅりゅりゅりゅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んんっ！　んっ、んじゅるるっ！　んっ、んくぅっ、んふぅうううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んぅっ、で、出てる……！　口の中にっ、んぐっ、精液……んっ、たくさん\n出されて……んっ、じゅるる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ネバネバの、精液……ンッ、美味しくないのに……んぐっ、勝手に、飲んで\nしまうぅ……んっ、んくっ、んくぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ちゅずっ、ずずず……っ！　んっ、んくぅ、んふぅううっ！　飲みながら…\n…んぁ、頭が……真っ白にぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、んくぅ……じゅるる……。美味しくないのに……イヤな味じゃないな\nんて……。これが、精液……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んれろっ、まだ、チンチンの中に精液が残っているんじゃないか？　んっ、\nちゅぶっ、ちゅちゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「れろ、れろれろれろ……。なっ、お前また、オレのことメス犬って言ったか\n！？　言ってない？　いや、顔がそう言ってるぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ふざけるなよ、んちゅっ、オレは、チンチンに奉仕していても……んちゅっ\n、一族の誇りを、忘れたりなんか……んちゅぱっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803308" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「チンチンに……んちゅるっ。精液の、味に……ンッ、れろれろっ、夢中にな\nったりなんか、しないんだからな……ちゅばっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「だ、だから……。ンッ、強くなるために、もっともっと、チンチンへの奉仕\nを教えろ……。ちゅばっ、いいな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、ああぁあああっ！？　な、なんだっ、んっ、んふぅっ！　は\nぁあぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ああっ、んっ、顔にっ！　んはぁっ！　精液がっ、んんっ、たくさんかかっ\nて……きゃうぅうううぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁ……。なんだよぉ、今の感覚……。頭の中で、バチバチって…\n…それに、全身が痺れるみたいなぁ……」　", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……なっ、それはオレがメス犬だからだって！？　ふ、ふざけるな！　オレ\nのことを犬扱いするなんて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「……んむぅっ！？　んま、またチンチンを口にぃ……。んふぅ、んじゅるる\nぅ……くふぅ……舌が勝手にぃ……チンチン、舐めちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803405" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「顔も……口の中も……んふぅ……チンチンと、精液の臭いでいっぱいにされ\nてるのに……んちゅぶっ、逆らえないぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「こ、これが……オレがメス犬の証拠、だって……んちゅばっ、適当なこと、\nんっ、言うなぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「オレが、そんな弱いはず……んっ、ちゅぶっ、ないのにぃ……。んちゅるっ\n、んっ、ちゅば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「な、なんだよぉ……。メス犬って認めれば、もっと強くなれるだって……？\n　んちゅっ、本当か……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「じゃあ、今回はそういうことにしといてやる……。ンッ、嘘だったら、承知\nしないからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_0803410" ]},
		{"command":[ "SETIMAGE", "0", "still_00000408_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}