		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ええい、なんのために出てきたのじゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「登場シーン、１回しかなかったぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あんなの、やられるために登場したようなものです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115790001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「まったく～。時間帝国の幹部ともあろうものが、たった１シーンのやられ役\nのために出演だなんて情けないっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115790001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「というわけで、古時計を手に入れられなかったキミたちにはおしおきだよ～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115790002" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こんどはなにをさせようと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「時計にちなんで、秒針に追われながらマラソンしてもらいます。はい、走っ\nて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115790003" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おおっ、なんだ、足元にでかい時計の文字盤がでてきたぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「後ろから秒針が迫ってきてますが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115790002" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「その秒針にさわると大変なことがおきるから、走って逃げてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115790004" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「いったいなにがおきるというのじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115790003" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ほら、無駄話している間に、秒針が脚に触れて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115790005" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「しっ、痺れるぅうううぅぅぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115790003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「でっ、電流ですか！？　悪趣味なぁっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115790003" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ま、またふざけたことを……道化師ぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115790004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「ああ、女王様お手製のビリビリ電流おしおき時計……。いいなぁ。かわって\nあげられないのが残念だなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115790006" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そんなこと、微塵も思ってないくせに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010115790004" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「おまえぇ……いつか覚えてろよぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115790004" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「んふふっ。ほらほら、はやく走らないと。またビリビリ秒針が迫ってきてる\nよ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010115790007" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くぅっ、次はぜったいにぎゃふんと言わせてやる！　インクレディブル・ス\nクワッドぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115790005" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
