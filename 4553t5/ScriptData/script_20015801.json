{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_020" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「皆様ごきげんよう。ピースムーン・ソレイユです。今日はプライベートの装\nいでお送りします」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「この度、私は厳しい修行によって日常生活においてはソレイユの形態を保つ\nことが可能となりました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「これも皆様の応援のおかげです――え、私事はいいからさっさと本編を説明\nしろって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750003" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「……わかりました。こほん。皆様、この時期のイベントといえば何を思い起\nこすでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750004" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「節分？　ひな祭り？　それもいいですが、男女のイベントといえばそう、バ\nレンタイン」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750005" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「女性が気になっている男性にチョコを送り、想いを告げる。あるいは同性同\n士で友情を確かめる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750006" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「素晴らしいイベントですね。私も隊長と……んんっ、ともかく、男女にとっ\nて重要なイベントです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750007" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「多くのカップルが成立する大切な日……それが、あんなことになるなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750008" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「これは、とあるバレンタインデーに起こった惨劇の話です。", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750009" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETIMAGE", "0", "bg_0041" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「これで買い出しは終わりですね……日々の仕事が忙しいと、生活用品の補充\nもままならないのは少しばかり難儀ですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750010" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "8", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「とはいえ、ソレイユとなってからは隊長と一緒にいられることも多いですし\n、悪いことばかりでは――む、これは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750011" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「バレンタインデーフェア。もうそんな時期ですか、すっかり忘れていました\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750012" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「いや、これはチャンスでは……？　手作りする時間はありませんが、よさげ\nなチョコを買って隊長に渡して、その後は……ふふ、うふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750013" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「問題はどう渡すかですが、机の中に仕込んでメッセージカードを添えれば…\n…押しつけがましくなく、それでいて存在感をアピールできるのでは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750014" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「我ながら名案です。私のチョコとメッセージで隊長を癒してさしあげましょ\nう！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750015" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0101" ]},
		{"command":[ "PLAYBGM", "BGM_011" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「さて、オフの日にわざわざ本部に来たのですが……なにやら騒がしいですね\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750016" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "0", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「っ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750017" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「どこに行くカツマ！！　今日は私が直々にお前の頭からつま先まで鍛え直し\nてやろうと言っているのだ……２人っきりでな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010023750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「剣を振り回しながら言う台詞じゃないですよ姫様！！　うおおお、危ねっ！\n！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「カツマ……私と一緒に誰も知らない場所で幸せになろう？　大丈夫、私がし\nっかりと支えて面倒を見るから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010023750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前目が怖いんだよ！！　あと刀を抜きながら迫ってきてる時点で大丈夫じ\nゃねえ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「カツマさん、今日こそは私と夫婦になってもらいます……計画ではもう第１\n子が生まれている頃なんですから、スケジュールを巻いていかないと……！！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010023750001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「人の知らないうちに人生計画を立てないでくれ！！　誰か、誰か大人の人！\n！　助けて～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「カツマ、こっちだ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023750001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「アナザー！！　助かった！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ふふふ、よしよし。いい子だカツマ……私の所に来たという事は、私を選ん\nだという事だな。さあ、結婚しよう！！　幸せにするぞ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023750002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あああっ、こいつもダメだった！！　嫌だ～！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、逃げるな！！　いや、照れているのだな。ふふふ、そういう所も可愛\nいぞ、カツマ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090023750003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ひいいいいいっ、なんでこいつら全員話が通じないの！！　どうなってんだ\nよ！！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「こ……これは……？　一体何が、いつもは理性的……多分理性的な人たちが\n隊長を追い回してる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750018" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「あれは恋の病だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020023750001" ]},
		{"command":[ "SETCHARA", "1", "char_00002202_01", "6", "CENTER", "-2000" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "400", "NORMAL" ] },
		{"command":[ "MOVECHARA", "1", "CENTER", "-400", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「サイレーンさん？　恋の病って……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750019" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「知らないのかい？　最近ちょっと近くのあいつが気になってくるとか、すれ\n違いざまに目線が合ってときめくとか、日常のふとした仕草が気になるとかい\nうあれだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020023750002" ]},
		{"command":[ "SETCHARA", "1", "char_00002202_01", "3", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ベタなものでは廊下で荷物を持ってもらったりとか、日直を手伝ってくれた\nりとかいう奴ですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023750001" ]},
		{"command":[ "SETCHARA", "2", "char_00000902_01", "0", "CENTER", "2000" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "MOVECHARA", "0", "CENTER", "0", "NORMAL" ] },
		{"command":[ "MOVECHARA", "1", "CENTER", "-600", "NORMAL" ] },
		{"command":[ "MOVECHARA", "2", "CENTER", "600", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ジュンジローさんも。いやそうではなく、恋の病って恋愛感情を比喩した言\n葉なのでは……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750020" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「いやいや、言うじゃないか。恋煩いって。恋は自分でどうすることもできな\nいから、煩う。焦がれる。落ちる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020023750003" ]},
		{"command":[ "SETCHARA", "1", "char_00002202_01", "8", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「そういうわけで、恋の病がパンデミックを起こした結果、彼があんな風に追\nいかけ回されているというわけさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020023750004" ]},
		{"command":[ "SETCHARA", "1", "char_00002202_01", "0", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人と一緒に仕事をしていたら、いきなり姫様や他の方々が押しかけてき\nまして、あの有様です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023750002" ]},
		{"command":[ "SETCHARA", "2", "char_00000902_01", "0", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ええと……どこから突っこめばいいのか。でも、サイレーンさんは罹患して\nないってことですか？　かかるかどうかは個人差がある？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750021" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "1" ]},
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「私とカツマ君は教師として、同僚としての関係だからね……でも、彼の丈夫\nさは前々からいいなって思っていたんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020023750005" ]},
		{"command":[ "SETCHARA", "1", "char_00002202_01", "0", "CENTER", "-600" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "DISPIMAGE","1", "TRUE" ]},
		{"command":[ "SETIMAGE", "1", "bg_0000" ]},
		{"command":[ "SETNAME", "Ｄr.サイレーン" ]},
		{"command":[ "SETTEXT", "「というわけでこの際だ、私もカツマ君争奪戦に参加させてもらうとしよう！\n！　愛しい実験体にしてあげるのさ！！　ふふふふふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_010023750001" ]},
		{"command":[ "SETCHARA", "1", "char_00002201_01", "8", "CENTER", "-600" ]},
		{"command":[ "FADEOUTIMAGE", "1", "FAST" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっ、サイレーンさん！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750022" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "3", "CENTER", "0" ]},
		{"command":[ "MOVECHARA", "1", "CENTER", "-1500", "FAST" ] },
		{"command":[ "MOVECHARA", "0", "CENTER", "-400", "NORMAL" ] },
		{"command":[ "MOVECHARA", "2", "CENTER", "400", "NORMAL" ] },
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "2" ]},
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「おお、両手の指から注射器をあんなに……まるでアダマンチウムの爪を持つ\nミュータントの如き姿」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023750003" ]},
		{"command":[ "SETCHARA", "2", "char_00000902_01", "3", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「呑気に言ってる場合ではありません、止めに行きますよっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_120023750023" ]},
		{"command":[ "SETCHARA", "0", "char_00000813_01", "7", "CENTER", "-400" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}