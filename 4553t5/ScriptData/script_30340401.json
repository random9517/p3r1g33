{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_03" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っはははっ……♪　動くなよ、たーいちょぉ……。もう、逃がしてやんねぇ\nかんな……。覚悟キメろ……そらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ヘヘッ……。お前が悪いんだぜ？　マジメに労働してる俺を誘うから……。\nハァ？　デートしたかっただけ？　んなわけあるかよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「火照っちまったんだろ……？　身体が、ココがさ……。長い付き合いだから\nわかるんだよな。互いのモチベーションっつうの？　シたい時……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っふっ……。俺が水着になったら、胸ばっか凝視してヤりたそうにしてたじ\nゃねえか。ああ、いい、いい。謝んな。……俺もだよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長……俺もしたかったからさ。同じ気持ちってことでおあいこにしようぜ\n。ほーら、お前の好きなオッパイだぜ？　好きにしていいんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「自由に揉んで、舐めて、吸ってもいい……って、それはちょっとアレか。日\n焼け用ローションたーっぷり塗っちまったから……そーだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺が胸でお前のをシゴいてる間、鑑賞して、ちょっかいかけるくらいにして\nくれっか？　触るにしてもこっちを邪魔しない程度に……うんうん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「完全俺主導での水着ローションパイズリってわけだ。そそるだろ？　……っ\n、はぁっ……♪　なんかさ、夏に浮かされてんのか、身体が熱くてよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「この熱と衝動を誰かに……、んっ、お前にブツけたくてしかたねぇんだよ。\nそら、チンポ貸したままリラックスしてくれよ……。動かすぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ぅン……♪　あっ……ぁ、はぁっ……はぁっ、あぁ……。やっべ、結構音、\nすんなぁ……。はぁっ、聞こえるだろ？　グチョ、グチョって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403110" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「汗だけじゃこうはならねえよ。さっきから尿道口から滲み出てきてるカウパ\nーと……ローションのおかげだな。派手でいいぜ、まったく♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ふ、ぅ……ふぅっ、ふぅ……。んんー……？　まずは単純に上下に動いて…\n…。ククッ、気持ちいいか？　顔に出てるぜ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ズリ、ズリ、ズリズリした後で変化球！　……大きく前後に上半身を擦り付\nけるっ……！　うぉおお♪　ニュルッニュルで滑る滑る……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「これ、すっげぇ楽しいな♪　ローションで摩擦感がなくなって……うははっ\n♪　にゅるぅううっ、にゅるうぅうってチンポの上を滑っちまう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ん、ぁ、マジかよぉ♪　蛇にでもなった気分だぜ♪　デッカいチンポの上で\nネロネロうねってさぁ、身体くねらせて馬鹿みてぇ♪　あはははっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……ん？　あんだよ、真面目にやれってか？　じゃ、こういうのはどうだ…\n…。……ぅ、はっ……♪　乳袋を左右から押し付けて、回転～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「胸を揺らしながら、……ぁっ、谷間でぐっちょぐっちょにかきまわしてやん\nだよ♪　キくだろ？　っ……あっ♪　うぁっ、あぁ♪　これヤバイ、な♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺の方にもなんかクるぜ……。あっ、お、お前さぁ……前にした時よりまー\nた太くなってねぇか？　チンポ……。パイズリするたび変わってんだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「カタチもエグくなってるし……。ッぅ……ほれ見ろ……。ぅっ……♪　亀頭\nがさぁ、ぶっとくなってて……カリ首の段差がエッグいこと♪　あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403119" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「竿だって妙にゴツゴツしてきやがって……膨張率がヤバい。こんなのでえぐ\nられたら、フツーの女だったら泣くぞ。マジで……。っふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っあっ♪　あっ、ぁっ……あっ♪　はぁ？　お、俺は泣かねぇし……。つー\nか色も、さ……だんだん黒くなってきてねぇか？　淫水焼けっつうの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「これじゃヤリチンのチンポ、だろ♪　すっげぇ遊んでそう……。んっ……。\n今日焼けローションで濡らしてるしよ、ますますすごい焼けそうだな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんか血管も浮いてるしさ……。……んっ、はぁ、はぁ……ヌメヌメしてエ\nッロいチンポになっちまったな。嫌じゃねえけど……はぁっ、あ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「こうやって谷間、で、ご奉仕ってやつやってると……感じちまうんだよ♪　\nパイズリって、めちゃくちゃ目の前にチンポ来るから……なん、つうか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あぁ、これでいつもヤってんのかぁって、現実突きつけられて……っ。ふぅ\nっ……い、意味わかんねーけど、なんか……興奮すんだ……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長のチンポ、目に焼き付いて……。ム、ラムラしてくんだよ……。だから\n、その責任とってもらってんだよ！　あっ、忙しい俺、を♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「誘惑すんじゃねぇっつの……♪　っふぅっ、ふぅっ、ふぅ……♪　ハハハッ\n、今チンポが返事した。ビクビクって脈打って……可愛いヤツだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403127" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「見た目カッコイイのに素直なやつだぜ……。こう、か？　前後左右、お前の\n感じるように動いてやるぜ……それ、それ、それそれ……イイのかよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んんんぅっ……！　なん、か……チンポの反りに従って、寄り添って思いっ\nきりヤんのが好きみてぇだな。強く扱かれてぇのか？　オッケー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そらっ……そら♪　どうだ……どうだっ……♪　あっはは！　めちゃめちゃ\n喜んでるじゃねえか♪　オラァ、どーしたバテてんじゃねーぞ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「カウパートロトロ出しまくって震えてんじゃねぇ♪　まだまだこっからだ…\n…。一番濃い汁作るまで解放してやんねぇぞ♪　ほれ、ほれ、それ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「キンタマに力こめろ……。はぁっ♪　そうだ、チンポん中で強烈にくっせぇ\nベッタベタの精液溜めとけよ……。それを俺が浴びてやる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ、オラッ♪　おらおらおらっ……！　溜まってきたかぁ？　気\n合い入れろよ♪　……ああ、いっくらでもズッてやっからさぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長の欲望はぜーんぶ俺が、ぁっ♪　発散させてやっからな……。はぁっ、\nぁ、う……こうか？　ハハ、ビクビクしてら……いいぞ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「乳圧でそのまま出しちまえっ……♪　はぁっ、俺の胸……鍛えてっからパン\nッパンだろ？　チンポを扱く力も……スゲェからさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「潰れるくらいグチュグチュヌチュヌチュしまくって……そら♪　絶対逃がさ\nねぇ♪　……なっ？　グリュグリュ刺激されんだ……ろっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「出せよ♪　おらっ♪　搾り取ってやる……！　はァッ、はぁっ、はぁ、ああ\n……！　お……？　お？　来るか？　来るか？　来いよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うっはぁあああっ♪　出た出たぁあ♪　おっ♪　ぁっ、おっ、あぁ……♪　\n大量の精液……ザー汁、ドッパドッパ俺の胸ん中に……ふぁあああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「よし、出しきれっ……！　乳袋ん中ベッチャベチャにしろ……！　っんぐ…\n…♪　人体構造無視したくらいバビュバビュ出てんじゃねーか♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「威勢が良くてサイコーだ……♪　おら♪　おら♪　射精に合わせて胸で搾っ\nて……。んおおおお♪　まだ出る、出る出る、強烈ぅ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っふぁああああ……♪　今日の隊長は景気が良すぎるな……！　あははっ、\nローションよりも量多いとか……ビビっちまう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「しゃーねぇ、もっかいローション足すか……。って、あぁ？　当然だろが。\n一回くれぇで離すバカいねーだろ。二回戦突入だ。つーかさぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403202" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長のチンポ、ぜーんぜん萎えてねぇし♪　あんだけ出しといて、まーたす\nぐ硬くなってきてんだけど？　これ、ほっといて帰れねぇよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403203" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺だって、こんだけ凄まじいオスの臭い……ザーメンの臭い嗅がされて、と\nっくに正気じゃいられねぇんだよな。チンポ狂いになっちまってる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「な～ぁ～♪　もっぺんヤろうぜぇ～……♪　ほらよ、胸だっていー感じにあ\nたたまってきてるしさぁ、ザー汁とローションでヌチャトロだぜぇ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……へへ、返事を聞く前にはじめちまうぞ。っ……は、ぁ……はぁ、はぁ…\n…。あ～～♪　谷間にこびりついた精子がくっせぇ、濃すぎだろ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んはっ……♪　はぁっ、はぁ……。なんだぁ？　さっきよりデカくなってる\n気がすんな……。だんだん熱くなってきて……。おっ♪　上等～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403207" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「タイマンでイカせ合いしようぜ♪　……ふぅうう～♪　ふぅっ、ふぅうう…\n…♪　ヌメる感覚……とろけて絡まるこの快感……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403208" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「う、ぁ♪　互いに火ィつきまくって炎上中……っと♪　あぁ♪　ヤベぇ♪　\nヤ……べぇ♪　ゴツゴツしてて気持ち、いい……。んだこれぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺っ……あっ♪　俺、隊長のチンポ好きだぜ……。俺の胸にぴったりの形し\nててさぁ……。っぁっ♪　谷間ぶちゅぅうって突き上げてきて……。うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんか、胸をマンコにされて犯されてるみたいっつうか……っ、はぁっ♪　\n遠慮なくズッボズッボ突かれてる感じあるってゆーか……んあああぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「こんなとこまでマーキングすんのかよって……あっ♪　なん、か、マゾい気\n分になっちまう……。はぁっ、あっ、あぁっ、あぁ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「結構長い付き合いだからわかんだろ？　俺、は……♪　隊長じゃなきゃ満足\nできねぇし……隊長のコレにむちゃくちゃされんのも好きだ、好き……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「だからいつもヤりたくて、どうしようもなくなんだよ……！　っう♪　この\nチンポが、エッロいのが悪い……クククっ、マジ虜だからさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「そっちが良くなるよう、に♪　努力するぜ……♪　そら……そらっ、ははっ\n♪　さすがに二度目は敏感だな。出したばっかでこすられてっから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「休まる暇もなくブチュブチュ追い立てられて……頭パーになりそう、だろ♪\n　っふぅっ……♪　安心しな。俺もだよ♪　もう長くもちそうにねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あっ♪　乳首、が股間にこすれ、て……ジンジンきてるっ……♪　ザー汁、\nローション、いっしょくたのヌルヌルで性感高められて……ふぅうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403217" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「イ……きそうだ、イキそう……！　ううっ……！　な、隊長……！　どうせ\nなら一緒にイこーぜ……♪　イく瞬間、谷間で締めるから、だから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「俺のイってる最中の谷間にまた、すっげーのぶちかましてくれよぉ♪　なぁ\n？　なぁ、頼む……！　あ、あっ、あぁ……イくぜ、イ、きそ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「隊長ぉおお♪　ザーメンっ、ザーメン発射お願いしますっ！　っああああっ\n、俺イくからっ、イ……く、精液出してくれぇええっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403220" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ふぁっ♪　ああああっ、あぁ……あああああっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「脈打って……俺の胸ん中、今度こそお前のザーメンでいっぱいに……！　あ\nっ、あっ、もっと、もっとくれ、もっと……ッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うぁ……あああああ♪　ど、こにこんだけ隠してたんだよ……大爆発じゃね\nえ、かぁ……っ♪　あっ♪　おっ、ま、まだ出るのか……くぅうっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あっは……♪　やっぱ二度目は溢れてこぼれちまうな……♪　でもその代わ\nり……広がったザーメンからお前の臭いがして……。すぅううう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ？　嗅ぐなって？　なんか、やめらんねぇんだよなぁ……コレ。はははっ\n、チンポ良かったぜ。まーだ、俺の胸の間でピクピクしてっし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403305" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「なんかこれ、後で洗い流すの……惜しいな。なぁ、舐め取って飲んでもいい\nか？　って、あっ、ろ、ローション……そうだった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「が、ガッツいて失敗した……。そ、そうだな……。そしたらアレだ。浜辺に\nいる間にもっかいヤる計算するとしてー……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403307" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「うまいもん、俺の店でしこたま食わせて、休ませるしかねぇか。ああっ……\nもったいねぇ。この量の精液、胸でネロネロ遊ばせるしかねぇなんて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「……あぁ？　気に入ってるぜ？　隊長の精液は派手だし勢いすっげぇし……\n。見ててスカッとすんだよなぁ～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403309" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ、動くなって。残りの汁も搾り出してやる……。ん、ん……。よし。これ\nでスッキリできたか？　またヤろうな……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「っておいぃいっ！　肝心なトコでズル抜けちまって……！　んぉぁっ！？　\nマ、マジかよぉおっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「顔っ……あぷっ、顔はやめっ……や、やめぇっ……！　ンンンンっ……！　\nクソッ……♪　あっついイイのをぶっかけやがってぇええ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「一発目が胸だったからって二度目は顔かよ……！　あっ♪　別にいいけど、\n先に言っとけよ……！　完ッ全に油断してただろ、がぁ、ああああ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「んぶっ……んんっ、んんんんっ……！　んがっ！？　は、鼻に入った……テ\nメェ……っ！　んぷぁっ……ううっ、うぁ……♪　嘘だろぉ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403404" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「顔の上でねっとり伸びて……垂れてくるぅ……。お前なぁ、二度目でこの濃\nさってどうなってんだ……！　ドスケベが……っ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はぁ？　う、嬉しそう？　バ、バーカ！　知らねえっ……！　た、ただ……\n。胸に出された時より、よぉっく精子の臭いがわかるってのと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「お前にひどいことされてるって思って軽くイッちまっただけだ……。ちくし\nょう、顔中ザー汁一色に仕上げやがって～……。んんんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ま……たまにはこういうヤンチャなのもいいかもな。隊長とはさ、色んなこ\nとをやってみたいと思ってるんだ。つぅことで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403408" ]},
		{"command":[ "SETIMAGE", "0", "still_00003404_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「これからも、改めてよろしく頼むぜ？　お、俺も……その……。プロポーシ\nョンの維持とか、もっとエロくなるようにだとか頑張る、からさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_0403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「色んなことしような。……なんて、急にしおらしくなんのおかしいよな！　\nアハハッ、わ、忘れてくれ！　出してくれてありがとな……！」", "NORMAL" ]},
