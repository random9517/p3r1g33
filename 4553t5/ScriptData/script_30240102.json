{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「私を助けてくれたことには、感謝してるわ……でも、その見返りがこれって\n、どういうことなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「別にエッチなことはしない？　その代わり、私の口からエッチな話を聞かせ\nて欲しいですって……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「そ、そんなこと出来るワケないじゃない！　助けたからって、調子乗ってな\nい！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「くっ……！　そうね……あなたが居なかったら、バッケンローダーにやられ\nてたのは事実よ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ああ、もう！　わかったよ！　その代わり、絶対に言いふらしたりしないで\nよね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104105" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あんっ……そんなに強くオチンポを擦り付けないで……！　そんなことしな\nくても、私は何処にも行かないから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002401_02_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ほら、わかるでしょ……？　私のオマンコ、オチンポで軽く触れられてるだ\nけなのに、びちょびちょに濡れてるの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はああぁ……！　だ、だから、そんなに押し付けないでよ……！　オチンポ\nの熱さが、伝わってきちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「な、なによ……！　淫乱になったとでもいいたいワケ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「別に好きでこんな身体になったワケじゃないわ……！　手や口……それにお\n尻でしてたら、イヤでもこんな身体になっちゃうわよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「うん……そうね。オマンコを使うのは、はじめてだもの……興奮する気持ち\nはわかるわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「私も……すっごく興奮してる。この勃起したガチガチのオチンポが、オマン\nコに入って来ると思うと……んんっ！　か、感じちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ……オマンコの入り口に、オチンポの先端が当たってるっ……！　ああ\nっ、オチンポのカタさが、伝わってくるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「そのまま、奥まで突き入れて……！　お尻だけじゃなくて、私のオマンコも\n……オチンポのカタチにしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はぁああぁ……！　あっ、あっ！　くるっ……どんどん奥まで、入ってきて\n……んっ、くうぅ……あはあああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「すごいわ……！　本当に奥まで届いてる……！　お腹の中、オチンポでいっ\nぱいになってる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104116" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あんなに太いのが全部入るなんて……ちょっと信じられないわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ、うん……別に痛くないわよ。むしろ、気持ちいいっていうか……幸せ\nな気持ちが、子宮から溢れてきてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「挿れられただけで、こんな気持ちになるなんて……これでオマンコをズポズ\nポされたら、どうなるのかしら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「それを今から教えてやるって……やっ！　あっ……！　まだ、気持ちの整理\nが……んっ、くっ、あうううぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　んっ、ぐっ、はああぁ……！　オチンポが出入りしてるの感\nじるっ……！　私のオマンコ、悦んでるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「奥を小突かれると、エッチなお汁がどんどん溢れてくるのっ……！　やっ、\nあああっ……こ、声も我慢できない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「もっとエッチな声を聞かせて欲しいだなんて……！　そ、そんなの、できな\nっ……はあああっ！　そんな浅いところ、擦らないでっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「オチンポのデコボコが、Ｇスポットに当たってる……！　気持ちいいところ\n、ズリズリ擦ってくるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はああっ！　あっ、んんっ、ふっ、あふっ……！　す、すごいっ！　自分で\nするのと、全然違うっ！　オチンポで擦られると、オマンコ変になっちゃうっ\n！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「くっ、あああっ！　んはああぁ……！？　あっ、ふぅんっ……くっ、うあっ\n、んんっ……！　だ、ダメっ……足のチカラが、どんどん抜けていくわ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ビンカンなところを刺激され続けたら……！　あっ、あんんっ！　気持ちよ\nくて、頭がおかしくなるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はひっ、んっ、はああっ！　あぐっ、はひいぃん！？　浅いところを重点的\nにズポズポされるの、たまらないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「おっ、お尻でした時もすっごく気持ちよかったけど……オマンコだと、また\n違った気持ちよさがあるわね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「こんなことなら、もっと早くオマンコでしておけばよかったわ……あっ、あ\nあっ！　んっ、あぐっ、うぅんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ！　んひっ、あふっ……そ、それ強すぎるっ！　Ｇスポットをト\nントンするの、反則だからぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あああっ！　ダメっ！　ダメぇ！　トントンしながら、オチンポでズリズリ\nするのダメぇ！　そんなことされたら、イッちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっあっ！　オチンポがビクビクって震えて……！　射精しそう\nなのね……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「だ、出すなら……浅いところじゃなくて、奥で出してっ！　子宮にセーエキ\n流し込んでっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あああっ！　おっ、奥までオチンポが届いてるっ！　イクッ！　イクッ！　\nイクぅぅぅんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んくううぅぅぅ！　あっ、あああっ……！　セーエキが子宮に流れ込んでく\nるの、感じるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「オチンポがビクビクって脈打ちながら、溜め込んだザーメンをどぴゅどぴゅ\nしてる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ！　セーエキを感じるたびに、幸せな感じが強くなってきて…\n…！　あっ、あっ！　またイクッ！　イッちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んんっ……！　はぁ、あああぁ……！　もっと出してっ！　私に幸せな気持\nちを、たくさん感じさせてっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はぁ、んひっ、くっ、ああっ！　イクのとまらないわっ……！　あっ、ああ\nあっ！　んふううぅぅ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……お尻のときと違って、ザーメンの感覚がはっきりわかるわ…\n…お腹の中に、熱いのいっぱい注がれてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ふふっ。赤ちゃんの部屋にこんなにセーエキ流し込むなんて、悪い大人ね…\n…そんなに私のこと、孕ませたいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「そんな真面目な声で孕ませたいとか言わないで……！　聞いてるこっちの方\nが、恥ずかしくなるじゃない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「でも……妊娠したいって気持ちは、私も同じかも……あんなに出されたのに\n、お腹の奥が疼いて仕方なくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「よかったら、もう一回して……って、こんなにオチンポガチガチなままだと\n、言わなくてもいいって感じね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ、ああぁん！　あっ、はああっ、ふぐっ、あっ、んひっ……！　い、い\nきなり激しく動きすぎよっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「た、確かに……もう一回してって言ったのは私だけど……！　急に動くのは\n、マナー違反だと思わないワケ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ、くっ……！　本当に、いつまで経ってもレディーの扱いが下手くそね\n……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「でも……必死に頑張ってるのはわかるわよ。オチンポの動きも、カタさも…\n…私を想ってくれてるのが、オマンコから伝わってくるから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「だから、もっとして……んっ、うぐっ、あんっ……！　今度は、奥の方をグ\nリグリしながら……いっぱい、トントンしてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ぐっ、あああっ……！　ふっ、あっ……！　すごっ……！　浅いところもよ\nかったけど、奥はもっと感じるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104211" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「オチンポのカタチ、はっきりわかるわ……！　私のオマンコ、オチンポのカ\nタチをどんどん憶えようとしてて……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ああっ！　今、必死に覚えてる最中だからぁ！　そんなに激しくズポズポし\nなくても、大丈夫だから……あっ、あっ！　あはぁあぁぁぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「さっき出されたザーメン、オマンコから溢れてるっ……！　やっ、ああっ！\n　こんなの、オマンコ壊れちゃうぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「子宮が降りてきて、勝手にオチンポにキスしてる……！　奥を突かれるたび\nに、オチンポに残ってるセーエキ啜ってるのっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はぁ、あっ！　んんっ、くっ、あぐうぅんっ……！　こんなエッチではした\nないこと、レディのすることじゃないのに……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「エッチな方がいいって……ううっ！　今そんなこと言われたら、嬉しくても\nっと子宮が疼いちゃうじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっあっ！　ダメっ！　嬉しいこと言われたから、オマンコイキたがってる\nっ！　もう我慢できないわっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104218" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んんんっ！　オチンポもビクビクして……！　また、一緒に……！　一緒に\nイッて……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「うん……！　出して……！　いっぱいセーエキ出してっ……！　あっ、あっ\n、あひぁっ！　イクッ、イクのっ！　あっ、イグっ、イグぅぅぅぅ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ……ふあああぁ……！　あっ、あっ……あぁぁぁっ……！　また、奥に\n……子宮に出されてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ひぐっ、あふっ……！　熱いのどぴゅどぴゅ出てるっ……！　私を妊娠させ\nるセーエキ、どんどん流し込まれてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ……！　んっ、はああぁ……！　し、幸せすぎて……もうなに\nも考えられないわ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「アナルセックスもよかったけど……普通のセックスも、クセになっちゃいそ\nう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ……！　あっ……！　最後まで出し切って……！　オチンポのセーエキ\n、全部私のオマンコに頂戴……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はあぁ……お腹が破裂しちゃいそうなぐらい、ザーメンでいっぱいになっち\nゃったわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ふふっ。これだけ出されたら、すぐに妊娠しちゃいそう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ、でも……妊娠したら、暫くセックスは出来なくなるのよね……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「安定期に入るまでは、アナルセックスをするから大丈夫……？　も、もう！\n　なに言ってるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「お尻でするのも好きだろうって……そりゃ好きだけど、お腹に赤ちゃんが居\nる状態でするなんて……！　ううぅ……！　バカっ！　ヘンタイっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ふあああぁ……！　お、オチンポが抜けて……！　んっ、うぐっ……！　あ\nっ、抜ける感じも好きぃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あふっ、あぐっ、んんっ……！　身体にセーエキかかってるっ……！　どぴ\nゅどぴゅ出されて、マーキングされてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はぁ、あああっ！　熱くてクサイの、肌で感じるぅ……！　もっと出して…\n…！　私をザーメンで汚して……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んんっ！　あっ、あっ！　セーエキの感触、気持ちいいっ！　汚されてるっ\nて思うと、すっごく興奮しちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はひっ、んんっ！　またイクッ……！　あっ、イクッ！　イクッ！　くっ、\nあああっ！　イグううううぅ～～～～～！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んんっ……どうして抜いたりしたの……？　別にもう一回、膣内に出しても\nよかったのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「子宮だけじゃなくて、私の身体もセーエキで汚してみたかった……？　ふふ\nっ。なによそれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「いつも手や口でするとき、いっぱい汚してるくせに……今更って感じね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「でも、セックスをして汚されると……いつもとは違う感じがして、ちょっと\n嬉しいかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「だからこれからもいっぱい、セーエキで私を汚してね……約束よ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0104410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}