{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "教師たちのアナザーってことは、ブラックメルヘンの幹部と同じくらいの強さ\nとみて間違いないだろう。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺と夜叉、そして負傷したバッケンローダーでは勝ち目はない。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ここは逃げるぞ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜叉" ]},
		{"command":[ "SETTEXT", "「はっ、はい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_010115880001" ]},
		{"command":[ "SETCHARA", "0", "char_00001701_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「逃がすわけないだろ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115880001" ]},
		{"command":[ "SETCHARA", "0", "char_00002203_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "そのとき、急に部屋が暗くなった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「わわっ、急にどうしたの！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115880002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「ブレーカーが落ちたようであるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115880001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「予備電源！　予備電源に切りかえてよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115880003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａハルカプトラ" ]},
		{"command":[ "SETTEXT", "「予備電源……ないのである」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_020_050115880002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａサイレーン" ]},
		{"command":[ "SETTEXT", "「なんでぇっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_030115880004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａグリムロック" ]},
		{"command":[ "SETTEXT", "「いいところだったのに……不運だね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_018_030115880001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なんだかよくわからないが、俺たちにとっては幸運だ。この混乱に乗じて、学\n園へ逃げ込んだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0154" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「……はい。とりあえず手当はしたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115880001" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「それにしても、変身前の肉体がボロボロになるほど攻撃されるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115880002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "桃花を保健室へ運び込み、応急処置を施してもらった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「それで、ボクのアナザーに会ったんだって？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115880003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「どんなだった？　まあ、ボクのアナザーってことは、ボクと同じ天才的頭脳\nを持っていたんだと思うけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115880004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そう……なんでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115880001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前の作った『不眠学習装置』を量産したうえ、生徒たちの洗脳に使ってい\nたんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「技術レベルはおまえ以上かもしれないぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「むぅっ！　それは聞き捨てならないなぁ。ボクだって負けていられない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115880005" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「変なことで張り合わないでくれよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「う……ううぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「桃花さん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115880002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ああ……わたし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「まだ安静にしなよ。よりによって、ルナテミスたちの攻撃をモロに食らった\nんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115880006" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「でも……こんなところで寝ていられない……。マーガレットたちを助けにい\nかなくちゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880003" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「いまは無理ですよ。それに、ルルーナさんたちは、また桃花さんを狙ってく\nると思います。いまの状態じゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115880003" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「そうかも……。はぁ……。あのとき、なんで攻撃することを戸惑っちゃった\nんだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880004" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「みんなを助けるためには、手加減せずにガチでぶん殴るしかなかったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「気絶させて、連れてくればよかった……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、なに明後日の方向に反省してるんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「そこまでしなくても……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115880004" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「というか、それって集中攻撃された腹いせじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ほかに方法はある！？　ないよね！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880007" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どうなんだよ、珠魚。連中はおまえの作った『不眠学習装置』ににた機械で\n洗脳されてんだぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「似ているだけで同じ仕組みかはわからないけど……。意識をなくしちゃえば\n洗脳されてようが関係ないよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115880007" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ほら、やっぱり気絶させるしかない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880008" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「でも、ルルーナさんたちをまとめて気絶させるなんて、できるんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020115880005" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それは……いまのわたしじゃ無理」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880009" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「だよな。だから別の手を……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「だから……特訓する」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880010" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "はぁ？", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「全員まとめて殴り倒せるくらい、強くなる！　今夜は特訓につきあって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880011" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「ちょっと待った！　今夜くらいは安静にしてないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115880008" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「時間がないの！　いまごろマーガレットたちが、どんな洗脳を受けているか\nわからない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880012" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「だから、いますぐ強くならないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「……わかった。そこまで友達のことを思うなら、ボクは止めないよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115880009" ]},
		{"command":[ "SETCHARA", "0", "char_00002202_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いいのかよ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "珠魚" ]},
		{"command":[ "SETTEXT", "「その代わり、特訓にはボクも同行させてもらうよ。フィジカルトレーナーと\nしてね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_022_020115880010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「ありがとう、珠魚先生」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880014" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0024" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "その夜、俺たちはいきつけの採石場へとやってきた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「それじゃあ、バッケンローダーに変身するから。本気でかかってきて！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020115880015" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}