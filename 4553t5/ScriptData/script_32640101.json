{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「おや、隊長。奇遇だな。私？　私は今トレーニングを終えてきたところだ。\n隊長もたまにはどうだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「仕事が重要なのも分かるが、身体を動かさないと不健康だぞ。私の身体を見\nてくれ。この適度に乳酸が溜まって張った身体を。ふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ん？　クールダウンはちゃんとしたかって？　ばっちりだよ。抜かりはない\n。なに？　マッサージをしてくれるのか？　いいのか。悪いね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00026401_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「最近流行のオイルマッサージ……そんなものがあるのか。分かった。じゃあ\nそれをお願いしようかな。隊長がしてくれるなんて、隊員冥利に尽きるね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、なんだか不思議な感触のオイルだな……うん、でも悪くない……ぽ\nかぽかして、温かくて……隊長の手も気持ちいい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00026401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふああ……確かにこれは、トレーニングで疲労した身体が癒やされていく…\n…んっ、ふうっ……ああ……いいね、これ……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「これからコリをほぐす？　ん、お願いする……んんっ！？　んっ、隊長、君\n、そこは違うんじゃ……そこ、乳首、先っぽ……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「硬くなってるって、そこに筋肉はない……あんっ、あっ、これは本当にマッ\nサージなのか？　どこもこんな感じって……あううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んっ、君がそう言うならそうなんだろうけれど……ふうっ、あっ、なんだか\n変な感じだ……んんっ、んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あんっ、ふうっ、そこ、だめ……あっ、つまんでくりくりされたら……もっ\nと硬くなってしまう……んんっ、ひああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あうっ、んっ、胸を触られてるだけなのに、頭の中がばちばちって……んん\nっ、あっ、ひうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、んっ、オイルのぬめりと隊長の指が……ふあああああっ、気\n持ちいい、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふえ、あ？　下半身もほぐす……ん、隊長の好きなようにして……ひあっ、\nあっ、下半身って、そこ、んううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103113" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、指がくりくりって、私のあそこを……え、オマンコって言え\nって……分かった、オマンコの周りを指が動いてる……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「やっ、あっ、だめ、そこは敏感なところ……ひあああっ、ほぐれてる、もう\nほぐれてるからっ、あんっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「まだ足りないって……んあああっ、そんなっ、上も下も両方同時になんて…\n…こんなマッサージ、知らない、ひうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっ、うっ、ひっ、身体を動かすなって……だって、隊長、君の指が……あ\nんっ、あああっ、敏感な所ばかり、ひあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「オイルのぬるぬるがすりこまれて……んんっ、あっ、胸、オマンコも、んん\nっ、両方弄られたら、おかしくなっちゃう、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、んんっ。顔が真っ赤になってるって……当たり前だっ！！　こ\n、こんなエッチなマッサージをしておいて……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「私だって、ここまで来ればこれがエッチなのだって分かる！！　なんでじっ\nとしてるかって？　そ、それを聞くのか……意地悪な人だ、君は」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長、君にしてもらってるからだろう。あんっ、君が触ってくれてるから、\n身を任せているんだ……ふああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「もしも隊長以外の男にこんなことをされたら……私の炎で骨すら残さずに焼\nき尽くしている……あんっ、あっ、喋ってる途中なのにっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「今の言葉でマッサージに熱が入ったって……んんっ、指先でこするのだめっ\n、ああんっ、胸が熱くなってる……ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっ、隊長もあそこを出して……チンポ、チンポって言えって……チンポ出\nしてるじゃないか……タオルの隙間から見えてるぞっ！！　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103124" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「チンポからのオイルを追加って……んんんっ、変なものの見過ぎだ、バカッ\n！！　ひあっ、あんっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んうううっ、嫌かって……そんなの、返事は決まってるじゃないか……隊長\nからされるなら、なんだって受け入れるって、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んっ、あっ、あっ、すごい、触ってもないのに隊長のチンポ、びくびくして\nる。ふうっ、んんっ、あっ、指の動きも激しくなって、ううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あうっ、くっ、胸とオマンコどっちがいいって……んんっ、どっちも、どっ\nちもいいっ！！　隊長の指が気持ちいいっ！！　くああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103128" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、隊長のチンポからも熱が伝わってくる……んっ、私へのマッ\nサージで興奮してるんだな。ふふ、嬉しい……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「だって、隊長が私のことを女として見てくれているということだからな……\n私だってそれぐらいは気にするさ……ひあっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「こんなエッチな身体をしてるのに女として見てないわけがないって……バカ\nッ、そういうことは思ってても言わないものだろう！！　んっ、ふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あんっ、この胸も、オマンコも、女だけのものって、んんん、言いながら指\nでこねないで……あんっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あううっ、指、指がオマンコの中に、ふあああっ、かき混ぜたらっ、んっん\nっんっ、腰が浮いて……んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あくうっ、隊長の腰も動いて……んんっ、ふっ、子種を出すんだな……んっ\n、子種じゃなくてザーメンって言えって……分かった、あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長のチンポからザーメン出すんだね、いいよ、隊長になら私は何をされて\nもいい……エッチなマッサージも、ザーメンぶっかけも……んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、指、乳首潰しながらオマンコかき混ぜるの、頭までぐちゃぐ\nちゃになっちゃう、あっあっあっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんんっ、イっく、イく、隊長の指で、乳首とオマンコ弄られてイっくうう\nうううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103137" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふあああっ、チンポからザーメンも来たっ！！　隊長のチンポオイルも来た\nあっ！！　あふううっ、あっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103138" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふあああっ、もう、これ、なにがなんだか分からない……んんっ、ひうっ、\nあっ、こんなマッサージ、されたことない……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「オイルとザーメンが混じってどろどろになってる……んっ、でも気持ちよか\nったよ隊長……ふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「えっ、追加のマッサージはどうかって……そ、そうだな。まだほぐれきって\nないし、お願いしようかな……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「そんな、最初からまた激しくされたら、やあっ、あんっ、ふっ、またすぐに\n身体が火照って……んんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「身体の上でオイルとザーメン混ぜないで……ふううっ、あっ、それを塗った\n指先で乳首弾かれたら、変な気分になっちゃう、ひああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「もう、君はエッチなことなら色んな発想が生まれるんだから……んんっ、オ\nマンコも弄られたら、んっ、はっ……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「チンポもまた硬くなってる……ふふ、私を触ってまた興奮してくれたんだな\n……あんっ、あっ、好きな人に興奮してもらったら、嬉しいよ。んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「え、ご褒美にさらに特別マッサージって……あううううっ！！　そんな、指\nを動かしながらぐりぐり潰さないでっ、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103206" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「だめ、だめだこれ、おかしくなるっ！！　隊長に胸とオマンコ潰されておか\nしくなるうっ！！　ひあっ、ああっ、ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっあっ、んっ！！　はっ、あっ、んんんっ！！　ちょっと、ちょっと休ま\nせて……ひあああっ、休ませて、って言ってるのにぃっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「いじわる、隊長のいじわるっ！！　ひうっ、んんっ、ああああっ、頭がおか\nしくなる、あううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふうううっ、あっ、あんっ、私の中にある炎より、隊長の指の方が熱くなっ\nてる……んんっ、オマンコの中が、ぎゅぎゅって指を……ひうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103210" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長のチンポもまたこっちに向けられて……先端がひくひくしてる\n。またオイルにザーメン追加したいんだな……いいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長特製のザーメンオイル、私の身体にたっぷり塗っていいよ……ひうっ、\nんっ、んんっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あうっ、あっ、お礼にマッサージレベルアップって、んんっ、これ以上され\nたら、頭の中まで揉みほぐされちゃう、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「胸も、オマンコも、頭の中もほぐされて、ふっ、あっ、んっ！！　これ、こ\nのマッサージ、おかしくなっちゃう……ひあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ほぐされて、蕩かされて、んんっ、隊長の指が、全身に沈みこんでるみたい\n……んんっ、好き、このマッサージ好きっ！！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふうっ、あっ、んんんんっ、隊長の指、んんっ、指だけなのに、こんなに感\nじちゃう……ひあっ、あああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、身体、身体が燃えるっ！！　気持ちいいので全身が燃え\nちゃうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長のチンポもびくびくしてる。追加のザーメン、来るんだな。い\nいよ、好きなようにザーメンオイル追加してくれていいよっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「はっあっうっ！！　んんっ、腰、オマンコの中かき混ぜられて腰が浮いちゃ\nうっ！！　ああっ、あうっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ああっ、イくっ！！　隊長のマッサージでまたイっく！！　ああっ、イっく\nうううううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103220" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ひあああああっ！！　隊長のザーメンも追加来たあっ！！　んんっ、お腹の\n上でオイルと混ざってる……ふううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長のザーメン、熱い……火の女神の私よりも熱い……これが男の快感の熱\nさなんだな……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「匂いも強い……嗅いだだけで、私の身体が反応してしまってる……男にしか\n出せない匂いだ……ふっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んんっ、隊長、私はずっとされるがままだったけど、君はよかったのか……\n？　言ってくれたら、なんでもするのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103304" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「今日は全部私にしてあげたかって……もう、本当に君は口がうまいんだから\n。でも、嬉しいな。ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「好きな人に慈しまれて、嫌になる人はいないだろう？　だから私が隊長に愛\nされて、嬉しい気分でいっぱいなんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んっ、こら、もうマッサージは終わりだろ。胸もオマンコもいじらない。あ\nんっ、やっ、こら、本当に怒るぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「もう、隊長はいつもいたずら好きなんだから……でも、そういうところが可\n愛くて好きなんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「今日は終わりだけど、またトレーニングした後はお願いしてもいいかな？　\n私も、このマッサージは癖になりそうだ……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「それじゃあ、疲れたらまたお願いするよ。隊長に身体を揉みほぐしてもらっ\nたら、元気になれるから。ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「んっ、隊長チンポ、お腹じゃなくて身体に向けて……ああんっ、あっ、ふう\nっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長のザーメン、身体中に降りかかってきた……ひあああっ、オイルと混じ\nって、またぬるぬるに……んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふああああっ、ザーメンシャワーが全身に……んっ、これはこれで、気持ち\nいい……ふっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103403" ]},
		{"command":[ "SETIMAGE", "0", "still_00026401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「ふっ、うっ、本当に、全身を隊長のザーメンで塗られた気分だな……んんっ\n、でも嫌じゃないぞ。君のならなんだって嫌じゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「あんっ！！　その今の言葉で最後の一滴が出たって……もう、君はちょっと\n変な所があるな。まあ、それも嫌じゃないけれど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「それにしても……全身のザーメンオイル、凄いぬるつきと匂いだ……あんっ\n、こら、指で塗り広げちゃだめだ、やあっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「もう、子供みたいだぞ隊長……んっ、こんなザーメンを出す子供もいないか\n、ふふっ、あはははっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長も気持ちよくなったのならよかった。触ってもないのに、こんなにザー\nメン出してくれたのだから、女としても嬉しいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「私へのマッサージだったけど、お互い気持ちよくなってウィンウィンだった\nね。ふふ、こういうのも分け合えるって、夫婦みたいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アグニ" ]},
		{"command":[ "SETTEXT", "「隊長が望むなら、このマッサージをまたしてもらってもいいよ。今度からは\nトレーニングの後に隊長に会いに来なきゃいけないな。ふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_264_0103410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}