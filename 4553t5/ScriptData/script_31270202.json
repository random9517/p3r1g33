	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふふっ、いくらビーチに人気がないからって、セックスまでしようだなんて\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「すごいな……もうこんなに硬くなってる……。ンッ、キミのペニス……ああ\n、私の股間に……擦れて……ンッ、んふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「な、なんだ……？　これを、挿れて欲しかったらおねだりしてみせろだって\n……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_01" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「キミは、私に恥ずかしいことを言わせたいようだな……。ンッ、まあ、ここ\nには誰もいないようだし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んふぅ……はぁ……。どうか……キミの雄々しく勃起したペニスを……ンッ\n、私の……ココに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ココじゃだめ？　ああ、わかったよ。オマンコ……これでいいだろう？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_02" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「オマンコに……んぅ……もう、すっかり濡れてしまった私のいやらしいオマ\nンコに……キミの、ペニスを……挿れて、くれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んんぅっ！　は、入ってきた……っ！　ああっ、太いペニスが、ああっ、私\nの中を……んっ、くぅ……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああっ、拡げて……ンッ、ンッ、ああ……っ！　熱い……私の中が、やけど\nしてしまいそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んふっ、ああっ、ああ……。動くのか……？　ンッ、わかった……動くぞ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んふぅっ、はぁ……はぁ……。腰を……んっ、上下に……ああっ、動かせば\nいいんだろう……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「こうやって、んっ、あっ、ああ……っ。私の、中で、ペニスをしごいて……\nんっ、んんっ、んふぅ……はぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んっ、どうした？　ああっ、中の締め付けが……ンッ、いつもより、キツい\n……だって……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああっ、もしかしたら……スーツで、腹部が圧迫されているから、かもしれ\nない……な……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「そのせいか……わ、私も……っ！　キミのペニスを、いつもより感じてしま\nっている、みたいなんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……中を、ペニスがこすって……ンッ、カリが、ひっかいていく\n、感じ……っ！　んっ、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「全身がっ、ジンジンするっ！　ああっ、熱くなる……はぁ、はぁ……腰が止\nまらなくなる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、イクッ、イキそうに……なって……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああっ！　あはぁああっ！　んぁっ、イッたっ！　イッてしまった……はぁ\n、はぁ……ンッ、ああっ、ああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「今度はキミが、動いてっ！　ああっ、私のことっ、下から突き上げ……ンッ\n、あぅっ、くぅうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ！　ますます太くっ、膨らんでっ！　ああっ、硬くなったペ\nニスがっ、あっ、ああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「私の身体をっ、貫くようにっ！　んんっ！　あっ、ああっ、すごい……全身\nが痺れるようだ……くぁっ、ああぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んぁっ、くぅっ、ああっ！　イッたばかりの身体っ、ンッ、ますますキミの\nペニスを感じる……ぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああ……身体がすっかり、発情して……！　乳首も、こんなに勃起して……\nんぅっ、スーツに潰されて、痛いくらいだ……ぁあ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_03" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ！　キミのっ、腰の動きに合わせて……ああっ、私の腰も勝\n手に、弾んでしまう……んくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ペニスがっ、おおっ、奥っ、奥に……っ！　あっ、ああっ！　突き刺さる…\n…っ！　んっ、んくぅううぅぅっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああっ、ああっ、私の一番奥にっ！　ンッ、ペニスが、届いているのを……\n感じるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、どんどん、愛液が溢れてきてしまうな……っ！　ああんっ\n！　気持ちよくて……止まらない……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_05" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んぁっ、ああっ、キミもどうやら……限界が近いようじゃないか……んっく\nぅっ、ペニスが、中で膨らんでいるぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああっ、このまま中にっ、射精するっていうのなら……！　ンッ、受け止め\nるっ、準備は出来ているから……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_04" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「このままっ、キミの好きなように……ああっ、射精……して……っ！　んっ\n、あっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「中でっ、んぁっ、ペニスが暴れて……っ！　あっ、ああっ、またっ、イかさ\nれる……イクッ、イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んっ、あああぁぁっ！　ああっ、あはぁあああぁぁぁああぁぁっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「す、すごい……脈打っているな……っ！　んはぁ……ペニスがっ、ビクンビ\nクンいいながら……精液を……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ドロドロの……熱くて、濃いヤツを……。はぁ……私の中に、思いっきり吐\nき出して……る……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああ……イッたぞ……。私も、また……。キミに中出しされながら……はぁ\n……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_09" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「熱い精液を……子宮で受け止めながら……イッてしまった……んっ、んふぅ\n……はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「にしても、キミのペニスはまだまだ物足りなさそうにしているな……。中で\n、硬いままだ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふふ……。私も、もっとキミとしたいと思っているところだ……。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「……だから、このまま……。いいだろう……？　んっ、またおねだりからさ\nせるつもりか！？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_09" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁ……仕方のない男だ。だが、おねだりをしているのはキミのペニスのほ\nうではないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「あんなに射精したのに、私の中でビクンビクンと暴れまわっているじゃない\nか」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_06" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「私も……もっとキミとセックスしたいんだ……。ふふっ、すっかりキミとの\n快楽に溺れてしまっているらしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ンッ、だからこんなふうにっ、腰を振って、しまうっ！　んぁっ、中出しさ\nれたっ、ところにっ、自分から腰を弾ませてっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んぁっ、ど、どうだっ！　んっ、気持ちいい……っ！　ああっ、キミの勃起\nペニスがっ、感度の上がった中を、擦って……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んぅっ、ああっ、はぁ……っ！　キミもどうやら、我慢できなくなってきた\nようだな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んはっ、し、下からっ！　ンンッ！　私のことを思いっきり突き上げてっ！\n　あんっ、あっ、あっ、ンッくぅううっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああっ、またイかされてしまったっ！　ンッ、ペニスがっ、私の奥をゴツゴ\nツと突いて……んっくぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「そのたびにっ、頭の中にっ、真っ白い光が弾けるっ！　んはぁっ！　ああっ\n、ああ……っ！　くっ、んふぅううっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ。さっきから、イキまくってるからっ、ンンッ！　中の締り\nも……うねりも……すごい、だろう……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_09" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「だから……ああっ、キミも、あっという間に我慢できなくなってしまう……\nんふっ、仕方のない、ことだ……アアッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「また激しくっ、ンッ、中をっ、ああっ、ああっ！　突き上げてっ、私のこと\nを……んっ、んぁああっ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「だめだっ、ああっ、頭の中がっ、なにも考えられなくなってしまうっ！　は\nぁっ、はぁ……ああぁ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「何度もっ、何度もっ、キミのペニスにイかされまくって……っ！　あっ、あ\nあっ、キミのことしか……考えられなく……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んぁあっ、す、すまない……イキそうなんだ……。だから、勝手に……思い\nっきり締め付けて、しまう……！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_08" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ぎゅうぎゅうに締め付けて……んっ、ああっ、キミもイキそうなんだよな…\n…こんなに、ペニスをビクつかせているんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ああ……いい……いいからな……！　私も……イクから……キミも……っ！\n　んっ、ああっ、ああ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_07" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「くるっ、キそうなんだっ！　今までで、一番大きな絶頂が……っ！　ああっ\n、ああっ、大波が……クる……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁっ、はぁっ、イクッ、イクッ、イク……ッ！　あっ、あっ、ああっ、あ\nあ……っ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_09" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「イッてしまうっ！　あっ、気持ちいいのにっ全身が……沈むぅうううぅぅぅ\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁああああっ！　ああっ、ああ……くはぁあああぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「イッ、イッてる……中っ、んぁっ、ああ……イクッ、イク……ッ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ペニスが脈打って……中に、精液を注いで……る……っ！　ああ……熱い…\n…ンッ、くふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「二度目だというのに……はぁ……はぁ……随分と射精してくれたな……。し\nかも、全部中に……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「確かに私は片腕が義手だが、それ以外は生身なんだぞ？　……ふふっ、妊娠\nしてしまったら、どうしてくれるんだ？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_10" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふふ……。まあ、その時のことは、そのときに考えるとしよう。それに、子\n供ができた時のことも考えないとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「私の子供が、平和な海で遊ぶことができるように……やはり、サメは殲滅し\nなければならない……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ふふっ、不思議なものだ。今までの私は目の前のサメを倒すことしか考えて\nいなかったのに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「こうして、未来のことを考えるようになるなんて……。これも、キミと一緒\nにいるおかげかもしれないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「だが、今も大事だ。ふふふっ、まだまだヤれそうかい？　もっと一緒に気持\nちよくなろうじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「んっ、ああっ、ああ……ああ……っ！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「すごいっ、たくさん……っ！　二度目の射精なのに……体中がベトベトにな\nるくらいに……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。なんて臭いだ……それに、スーツ越しだというのに、キ\nミの熱を感じる……んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「この臭いと……粘り気を感じているだけで……。はぁ……ふぅ……。全身が\n蕩けてしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「それにしても……随分と派手にぶっかけてくれたな……？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012702_02_12" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「せっかく新調した装備を、精液まみれにしたなんて……。こんなの、財団に\nどう説明すればいいのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「ンッ、おいおい、まだまだするつもりなのか？　こんなにスーツを汚してお\nいて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「一度汚したなら二度も三度も同じだろうって？　まったく、キミの考えは読\nめないな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「だが……私もそれには賛成だ。幸い、近くには海がある。シャワーだってあ\nるだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スーザン" ]},
		{"command":[ "SETTEXT", "「キミが満足するまで、付き合うよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_127_0204410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}