{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ある程度情報も集まったし、さっそく聞き込みといこうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130001" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うどんを食べて、お前からうんちくを聞いただけのような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まあまあ。あ、まずはそこの猫に聞いてみよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130002" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「なぜ猫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「にゃー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130003" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「にゃー……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130004" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「……逃げられたな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「あまり協力的でない猫だったみたいだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130005" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「というか、猫が知っているわけないだろ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「猫と会話できるわけでもあるまいし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115130003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「そうだ、アンパンと牛乳を買わないと」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130006" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「それ、必要か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「聞き込みに必要なのは体力だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130007" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「というかうどんを食べたばかりだろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「この辺に、高級アンパン専門店があるんだよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130008" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そうなのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「ほらほら、ここ……って、閉店してる！？　僕まだ食べてないのに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130009" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「残念だったな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「しかし、この調子で宝箱を持つタヌキ像なんて見つかるのか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115130005" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「まあまあ。まだ聞き込みは始まったばかりだよ。う～ん、美味しい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130010" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「お前、なに食べているんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115130006" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「近くで売っていた回転焼きだけど？　君たちも食べるかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130011" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、結構」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115130006" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「さて、糖分も補給したし、道草を食ってばかりもいられないね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130012" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「食べていたのは道草じゃなくて回転焼きじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115130007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「むっ、あそこに見るからにあやしい人が！　きっとタヌキ像のことを知って\nいるに違いない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130013" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なっ、あいつは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115130007" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「お嬢さん、少々いいですか？　僕ら、こういうものを探していまして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130014" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう……。どうやら貴様らも『宝箱を持つタヌキ像』をさがしておるようじ\nゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「エファナティカのアナザーがなんでこんなところに！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115130008" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まさか時間帝国も狙っているとは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115130008" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「時間帝国？　話は聞いていたけど……。へぇ……この人たちが……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010115130015" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「どうする？　こいつら、このままにしていたらまた邪魔をしてくるぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115130001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「そうじゃな……。しかし、いまはこのタヌキ像を探すのが先じゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「わざわざ羽虫の相手をする必要もなかろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115130003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「誰が羽虫だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010115130009" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「自分が羽虫だという自覚はあるみたいだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115130002" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス、挑発に乗るな！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115130009" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「しかし、時間帝国が絡んでいる以上、ここで出会ったお前たちを放置は出来\nん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090115130010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「お？　やろうってのか？　相手になるぜ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115130003" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「ちまちまと探し物させられて、ストレスが溜まってるんだよ、こっちは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080115130004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「まったく、しょうがないねぇ。時間はあるようじゃし、ちょっと遊んでやろ\nうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100115130004" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}