{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「へへ……捕まえたぞ。もう逃さねーからな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「そう、怯えるなよ。せっかく男と女が二人っきりになったんだ。盛り上がっ\nたら、なんかそれっぽい感じになるだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「そういう雰囲気じゃない？　何言ってんだ、男が大好きなオッパイだぞ？　\n普段から結構ジロジロ見てたじゃねーか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「大体、このチンポは何なんだよ。思いっきりガチボッキさせてんじゃねーか\n、んー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103104" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「いや……まだ、こいつはもう少し余裕があるのか？　もうちょっと育ててや\nれそうだな……へへっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「いいぜ……こうして、根っこのとこを……ギュウっと……おっ、やっぱり、\nまだムクッと膨らんで来てるな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103106" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あん？　グローブが痛い？　バーカ、ナマで触ってもらおうなんて、１０年\nはえーよ。」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「それに……痛いとか言ってる割には、くくっ、このチンポの跳ね具合は何だ\nろうなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「しっかりピクピクさせて……これ、思った以上にドＭなんじゃねぇの？　ほ\nれ、ほれ、なぁ、どうなんだよ、チンポくーん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103109" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くくっ、簡単には認めねぇみてーだな。顔がめっちゃ、やせ我慢してやがる\n。ふふん、なら……そうだな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ほれ……手を出してみな。いいから、悪いようにはしねぇって。そら、ここ\nだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「そうそう……ぎゅっと握り締めていいんだぜ？　直接触らせてやるよ……ア\nタシのオッパイ……好きにしてみな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んんっ……！　へへ、そうだよな。そこで遠慮して手を離すようなタマじゃ\nねぇよなぁ。しっかり揉んでくるじゃんかよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「いいぜ……もっと強く握り潰す位にしてみな。ほら……ここだよ、もみくち\nゃに……んっ、しちまって……いいんだからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103114" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「その代わり……当然、アタシも……このチンポ……好きにさせて貰うからな\n。くくっ、ギチギチになってやがる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ほぅれ、キンタマも無防備だなぁ、オイ。こいつも……ムニュッと……して\n欲しいんだな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103116" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ、ふふっ……やっぱり、強めにされるのが好きなんじゃねーか。アタシ\nのチンポコキ……気に入ってるんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「皮……めくりあげて……んっ、縦に扱いて……ほぉら、ぐちゅぐちゅ言って\nら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「おっと……んくっ、オッパイも……大胆になって来たな。指がめり込んで…\n…っくぅ……あぁ、乳首……摘みたいよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103119" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「いいぜ……ほら、転がしてみろよ。こんな機会……滅多にねぇぞ？　あぁっ\n……その調子だよ……指でコリッとしてるトコ……潰すんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んふぅっ……やっぱり手付きがドスケベだよなぁ……アタシも負けてらんね\nぇな……くくっ、そら……チンポにサービスだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103121" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、くっ……色々注文が多かった割には……もうチンポは、この強\nさが気に入っちまってるじゃないか……なぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「分かるぜ……くくっ、今度はキンタマも握り潰すギリギリまでしてやろうな\n……ほぅれ、ほれぇー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ……おっ……へへっ……乳首に反撃か？　上等だよ、はっ……ふっ……\nその調子でアタシも感じさせてくれよ……な……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「どうした……もっと力を込めていいんだぜ？　アタシのオッパイは、そんな\nヤワじゃないからな……いや、柔らかさは別か？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103125" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あぁ……そうそう、ギュッと握るんだよ……んくぅ…そこで乳首だ……んぁ\nっ、あぁ……染みるぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「それなら、これは……どうかな？　へへ……んっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ほうれ……チンポの先を……直接グリグリってな……ははっ、メチャクチャ\nビクビクさせてやがる……痛いか？　んん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「おっと……逃さねぇよ。せいぜい腰に踏ん張り効かせて耐えてみな。そら…\n…尿道口を……ずぶっと……くくっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くくっ、何だよこれ、ちょっと汁が出てきてるぞ？　お前……チン先イジメ\nられて、射精したくなってんのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「へへっ……ごまかせねぇぜ？　ほれ、根元からシコシコしてやるからな……\nチンポ全体をマッサージだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んふっ！　へへ……ゾクゾクするぜ、その情けない顔見てたら……マジ、ム\nラムラが止まらねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103132" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、あぁ……オッパイもジンジンしてる……んくぅぅ……乳首…\n…いいぜ、もっと転がしてくれぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んふっ……はぁっ、はっ、んっ……いよいよ、余裕がなくなって来たな……\nどうだ、射精したいんだろ？　ほら、チンポ出したいって言ってみろよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103134" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「じゃなきゃ、ここでやめちまってもって……ははっ、もうギブアップかよ。\nあっさり言っちまうなんて恥ずかしくねぇのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「けど、その正直さに免じて、そら……チンポにご褒美だっ。このまま……こ\nの手の中に出しちまいなっ！　そらっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103136" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ……！　くぅぅ……ふふっ、出た出たっ……ドロドロのチンポ汁っ……\nお漏らしだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「へへ……何だよこれ、どんどん溢れてくるぜ……チンポを乱暴にされるのが\nそんなに良かったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あーあ、グローブがドロドロだぜ。まさか、ここまで節操なく出してくれる\nとはな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103139" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くくっ……けど、中々楽しかったぜ？　男の悶え顔なんて見苦しいだけだっ\nて思ってたが……へへ、お前のはちょっとそそったよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103140" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「どれ……チンポは落ち着いたか？　まだまだ、一発出した位じゃ、全然だよ\nなぁ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「当然、まだまだ続行だよな。グローブに出しただけで満足しましたーなんて\nことはねーだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ああ、今度はお前の好きなとこに出していいぜ……顔にぶっ掛けたいか？　\nそれとも、このオッパイにぶち撒けたいか？　好きにしていいからな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くくっ、何だよ、今のだけでチンポがビクッと来たぜ。そんなことで期待し\nちまったのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ、それなら……もうちょっとオッパイも感じさせてくれよ……んふっ、\n結構な勢いで……他の女にも手ぇ出してんだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んくっ……あぁ……そうそう、お前の本性が見えてきたな……しっかりチン\nポ握り締められてても、タダじゃ終わらねぇって……そんな感じだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「当然……アタシも、もっとチンポを泣かせてやるからな……ほら……テメェ\n自身のザーメンで、チンポがヌルヌルだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103207" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「どうなんだ？　チンポを好きなように弄られて……みっともなく射精して、\n今もしっかりと弱点握られて……恥ずかしくないか？　悔しくないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「くくっ、完全に喜びだけって感じじゃねぇよなぁ？　分かるぜ、どこかで一\n泡吹かせたいって……そーいう目だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103209" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「だが、そうじゃなきゃ面白くねぇ。そういう奴を、腰砕けにして恥ずかしい\n射精させてやる方がいいもんな。うりゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ほうら……タマ揉み効くだろ？　ビクってチンポを震わさせて……ギュッと\n根元を捕まえて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103211" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「このままでズリズリっと……ほぉーら気持ちいいよな？　もう、反応で弱い\nトコはバレてるからな。ちょーっと、力加減を調節してやれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ほら見ろ、くくっ、つくづく分かりやすいチンポだな。どうした、手が止ま\nってるぜ？　もっと、アタシのオッパイも責めていいんだぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103213" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んふぁっ……っくぅん……ふふっ、それでいい……乳首、ジワッと来て……\nはぁぁ……んっ、お返しだっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「うんっ、ふっ、く……また我慢出来なくなって来てるな……勿論、こーいう\n時に……どうすればいいか……分かってるよな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103215" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「おねだりだよ、ライオット様の気持ちいい手コキで、どエロチンポ……イカ\nせて下さいィ……だ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「どうした、声が小さいぜ？　出したいんだろ？　ドピュッと、さっき以上に\nチンポザーメン……出したいんだろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ほら……今度はグローブじゃないぞ？　アタシのカラダ……どこでも好きに\nしていいんだからな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「もうチンポも限界だろ？　このタマ揉み……我慢できねぇだろ？　ほら……\nチン先がプルプルしてるぜ……ん？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「さあ、まただらしないイキ顔を見せてみろっ……どこだ？　どこに出したい\nんだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んっ……何だ……チンポの位置からすると……へへ、狙いはオッパイってと\nころか？　いいよ、ほら……しっかり狙って……出せっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「うぁっと！　来た来たっ……んっく……マジで、遠慮なしに出してやがるっ\n……んぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103402" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_20" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「すげぇヌルヌルだ……ほら、しっかり狙えよ……？　全体パックできる位に\nドロドロにしていくんだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あぁ……やべぇな……めちゃくちゃ出てくるじゃねぇか……はぁぁ……ザー\nメンまみれにさせられてるぜ……んっく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103404" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んふぅぅ……こうなったら、全部出しちまえ……中途半端に残したってしょ\nうがねぇからな……んっ、そうだ……チンポもくっつけちまえ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んふっ……溢れてきた……流石に、これで……いよいよ終わりかな……？　\nすげ……オッパイが、やべぇことになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「あーあー、マジでドロッドロだ……へへ、何だよこれ、糸引いてるし……う\nわ……味もめちゃくちゃ濃いな……これ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103407" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……なのに……何だろうな、これ……フツーにクセになる感じでハ\nマっちまってる……ちゅぱ……んはっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はふ……あぁ……何か、クラクラするぜ……お前の精液……そーいう効果で\nもあるのかね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ま……思った以上に楽しめたよ。へへ、また気が向いたら遊ぼうぜ、な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103410" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_18" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「おっ……顔を狙ってんのか？　おもしれぇ……いいぜ、そのままぶっ掛けて\nみろよ……そらっ……イケっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んぁぷっ！　ハハッ、マジでぶっ掛けやがった！　んぷっ……やべっ、思っ\nた以上に濃いやつだ……んぷっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_17" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「はぁ……んっ、ここまで来たら、全部……掛けちまえ……ほら……頬ががら\n空きだぜ……んっ、そうだ……チンポをもっと近づけろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「んんっ！　はふっ……あぁ……クソ……アタシも、何かおかしくなってる…\n…このザーメン臭……たまんねぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「ふぅぅ……まだ出るだろ？　扱いてやるから、奥の奥まで残ってる分……扱\nきだしてやるからな……んく……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「おっ……最後の搾りカスが出てきたぞ……流石にこいつで打ち止めかな……\n？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00016101_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ライオット" ]},
		{"command":[ "SETTEXT", "「どれ、ちゅぷ……んっ……ぺろ……ああ……このドロッとした感じ……喉に\nしっかり残って、くっせぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_161_0103307" ]},
		{"command":[ "WAITINPUT" ]},

