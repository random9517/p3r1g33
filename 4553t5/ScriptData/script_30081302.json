{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あ……隊長、来てくれたんですね。嬉しいです。じゃあ……電気をつけても\nらっていいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304101" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_01" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ……ふふ、驚きました？　バレンタインのチョコレートは、私自身です\n。隊長、こういうの好きでしょう？　きゃっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304102" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「きゃあっ、あっ、もうおちんちんがぎんぎんに……あっ、ああっ、あっ、入\nって、きたっ、んううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304103" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ、ふっ、いきなり全部入れるなんて……そんなに興奮したんですか？\n　ってもう何も言わなくても顔が……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304104" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「顔がすっごい……んっ、女としては嬉しいっ、あっ、ああっ、あんっ、あっ\n、そんなすぐに動かしたら、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「チョコ飛び散っちゃう！！　ね、隊長、ちょっと落ち着いて、後でいくらで\nも動いていいですから、チョコも食べて、ね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長のために、愛情たっぷりこめて作ったチョコなんですから、ほら、どこ\nのチョコでもいいですから、食べて見てください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、いきなりおっぱいのチョコを、んっ、あっ、舌で乳首くりくりした\nらダメですって、あんっ、ふうっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304108" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んふうっ、うっ、おっぱいとチョコ、両方美味しいって、ふふっ、嬉しい、\nんっ、あっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「今日は早起きして、ずっと作ってましたから……んっ、隊長のために、おい\nしくなあれって思いながら、あっ、やんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふふ、夢中になってくれてますね、おっぱいチョコ……赤ちゃんみたいに\nチュウチュウ吸って、んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304111" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「先端が硬くなってきたって、そんなの当たり前ですよ……好きな人に、隊長\nに触られたら感じるに決まってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「こんなに夢中になられたら、女として悦ばないわけないじゃないですか……\n隊長、好き。もっとして……いっぱい吸って？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304113" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、ふふっ、そうしてすぐに応えてくれるところ、大好きです、\n私の言ってること、聞いてくれてるのが……あんっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304114" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうううっ、んっ、そんなに慌てなくても、チョコは一杯ありますから、ん\nっ、ゆっくり食べて……あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304115" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、ふうっ、うっ、もう右のチョコがなくなっちゃった……食い\nしん坊さんですね。あっ、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ、なくなったからっておっぱい揉んでも、ミルクはでませんよ、んっ\n、あっ、あうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふっ……でもおちんちんからミルク出してもらえれば、私の胸からもミル\nクがでるようになるかも知れませんね。ああっ、あんっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304118" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「凄い、中でおちんちんが硬くなって、ふあああっ、膨らんでるっ、んっ、ん\nんっ、想像したんですか？　私の中に出すの、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304119" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふふっ、いいですよ、今日はいっぱい出して、好きなだけ出して、\n隊長が出したいだけ……私の中に出して？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304120" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっあっあっ、腰、動いてっ、ふあああっ、あっ、あくうっ、奥の\n方、おちんちんでゴツゴツって、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304121" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「カリ首もゴリゴリって擦って、ふうううっ、うっ、ああっ、あんっ、体温高\nいのに、もっと高くなってチョコがドロドロになっちゃう、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304122" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「この熱さがいいって、んんっ、そんなこと言われたら、もっと熱くなっちゃ\nう、身体の中まで真っ赤になっちゃう、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ああっ、凄いっ、本当におちんちんがもっと気持ちよくなってる！！　ひあ\nっ、あっ、ああっ、あくうっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304124" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「太くて大きいのが私の中をじゅぽじゅぽって、何回も出入りして……んんっ\n、あっ、ああっ、幸せ、これ、幸せっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304125" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長に食べられて、抱かれて、おっぱい揉まれて、全部、全部幸せっ！！　\nひああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304126" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふううっ、うっ、私の中も、悦んでるの、隊長のおちんちんにかき混ぜられ\nて、ずりゅずりゅされて、悦んでるっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304127" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あううっ、うっ、ふううううっ、お腹の奥まで、隊長のおちんちんがごつご\nつって突いてくる、んっ、好き、それ好きっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304128" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ひああああっ、何回もそれされたら、んっ、ああっ、頭、おかしくなっちゃ\nう、馬鹿になっちゃう！！　ひああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ああっ、あっ、あっ、腰、勝手に動いて、隊長のおちんちん欲しがっちゃっ\nて、ふっ、うっ、あああっ、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304130" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「自分の中、全部隊長のおちんちんのためにあるみたいになっちゃう、んんっ\n、あっ、あふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304131" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そんな、私の全部は隊長のためにいて欲しいって、今、今そんなこと言われ\nたら、ああっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んんっ、ふううううっ、軽くイっちゃって、ふっ、うっ、んんっ、あんっ、\nあっ、だったら、だったら……ふああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304133" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「だったら、中に、中にいっぱい出して、それで、子供作って……二人の証が\nあれば、いつまでも……ああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304134" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「全部言ってないのに、そんな腰動かされたら、イく、イく、イっく、あああ\nあああああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304135" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふあああああっ、あっ、中、中に精液一杯来てる！！　あっ、ああっ、あう\nっ、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「気持ちいいっ！！　中が満たされるの、気持ちいいっ！！　んっ、くうっ、\nふうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304137" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ああっ、あっ、あうっ、一番奥まで、隊長の精液来てるの、分かります……\nふふっ、嬉しい。私の言葉通りにしてくれたんですね……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304138" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、まだ出てる……ふううっ、うっ、お腹の中、ぱんぱんになっちゃい\nそう……んっ、くっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304139" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私の体温以上に熱いので満杯にされて……んっ、これが愛おしいって気持ち\nなんですね……私、満たされてる……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304140" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「隊長、気持ちよかったです……隊長もいっぱい出してくれて、嬉しい。愛し\nあうって素敵ですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふ……でも、まだチョコは残ってますよ？　それに、隊長のおちんちんも\n硬いままだし……もう一回、できますよね？　あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304202" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あくうっ、また喋ってる途中に、んっ、ふうっ、ふあああっ、おちんちんだ\nけじゃなくて、チョコ、チョコも食べて、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304203" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふあああっ、あっ、今度は左でバランスって、んんっ、ふうっ、もう、変な\nところで律儀なんですから、あっ、あんっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ああっ、今度は吸いつきながら腰を動かして、んんんんっ、さっきよりもも\nっと気持ちいいっ、あっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304205" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、ダメ、身体中、火照って、んっ……イっく、んっ、ふううう\nううっ、あっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304206" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「また軽くイっちゃった……あうっ、あっ、イったって言ってるのに、んっ、\nそんなに動かされたら……あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304207" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私の中、隊長のおちんちんをきゅうきゅうに締めつけちゃって、ふううっ、\nあっ、んっ、ぬりゅぬりゅって、中がっ、あああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304208" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「おっぱい吸われて、中をこねられて、んんっ、私の全部がチョコになって食\nべられてるみたい、ふうううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304209" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「このまま本当に食べてしまいたいって、んんっ、んふうっ、ふふっ、本当に\n隊長は私を悦ばせるのが上手いです……あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304210" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「そんなこと言われたら、こう返事するしかないじゃないですか……いいです\nよ、私を全部食べて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304211" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ひあああああっ、あっ、ああっ、また、そんなっ、激しくっ！！　んんんっ\n、ふあああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304212" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ああっ、左のおっぱいもチョコなくなって、ふうっ、あっ、ああっ、おちん\nちんがじゅぷじゅぷって、また何回も、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふうっ、うっ、ううううっ！！　また、さっきみたいに熱く硬く膨らんで、\nまた出そうなんですね、んっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304214" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「いいですよ、いっぱい出して、私が隊長のものだって分かるように、いっぱ\nい出してください、んっ、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「身体の中も外も、隊長ので染め上げてっ、ふううっ、あっ、あくうっ、んん\nんんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304216" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私に、隊長の子供産ませてっ！！　二人の子供、産ませてくださいっ！！　\nあっ、ふううっ、あくうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304217" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_11" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっ、ああっ、あっ、来るっ！！　来る来るっ！！　おちんちんから、精液\n来るの、分かる、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304218" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私も、一緒に、んんっ、イっく、イく、隊長のおちんちんで、イっく、ふう\nっ、あっ、んんんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304219" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あああああっ、隊長、イっくううううううううううううううううううっ！！", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304220" ]},
		{"command":[ "WAITINPUT" ]},
				
		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふあああああっ、あっ、あっ、中に、どくどくって注がれてる、ふうううっ\n、私の体温より熱いっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304301" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「さっき出されたのと混ぜあわさって、私の中でどろどろになってる、んっ、\nふううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304302" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「お腹の中にへばりついて、もうすでにここで赤ちゃん作るって、そう言って\nる、あんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304303" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あはっ、はっ、これだけ出されたら、絶対できちゃう、私と隊長の赤ちゃん\n、絶対できちゃうっ、んんっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304304" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んふふっ、今の言葉でまた絞り出してくれたんですね、嬉しい……隊長から\nも、子供が欲しいって意思が伝わってきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304305" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ……ぐりぐりってしなくても、もうお腹の中はいっぱいですよ…\n…大丈夫、隊長の精液、一番奥まで届いてますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304306" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「むしろ出し過ぎて、お腹の中が溺れちゃいそう……ふふっ、そんなことない\nでしょうけれど。隊長のはそれぐらい濃いってことですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_14" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「こんなに愛されて、幸せです。抱かれれば抱かれるほど、隊長のことを好き\nだって、そう思えます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304308" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ……素敵でしたよ、隊長。気持ちよかったのもそうですし、こんなに\n濃いのをたっぷり出してもらったら、絶対妊娠してますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304309" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私と隊長の赤ちゃん、大切に育てましょうね……絶対可愛くて強い子になる\nはずですから……楽しみです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304310" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_13" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、おちんちん、なんで抜いて……ひあああっ、あっ、身体に、\nんっ、ふああああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304401" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_18" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、チョコと混ざって、んっ、ふうううっ、また違う熱さが、ん\nっ、ふうっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304402" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「んふうっ、自分のチョコと隊長の精液が一緒になって、なんか、変な気分…\n…ふううっ、うっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304403" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「これも一種の共同制作……なんて、ふうっ、んっ、チョコと、私の体温と、\n精液の熱さでどろどろになってる……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304404" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「最後の一滴までかけられて……んっ、匂いも、チョコの甘い匂いと精液の匂\nいで頭の中がくらくらしてきます、ふうううっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304405" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ふふっ、中も外も自分のもので染めたかったなんて、独占欲が強いですね、\n隊長。でも嬉しい……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304406" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「私を独占したいって、そう思ってくれたんですから。でも、こんな風にしな\nくても、私はずっと隊長のものですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304407" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「ソレイユじゃなかったころから、ずっとずっと隊長のこと好きでしたから。\nふふっ、こうなってから勇気が出ましたけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304408" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_17" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「だから、心配しなくても私はずっと隊長の側にいます。ずっと好きだって、\nたとえ隊長が嫌がっても、言い続けますよ。ふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304409" ]},
		{"command":[ "SETIMAGE", "0", "still_00000813_02_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ソレイユ" ]},
		{"command":[ "SETTEXT", "「でも、隊長がそうしたいって言うなら、いつだってこんな風にかけてもらっ\nていいですからね。大好きですよ、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_008_1304410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
