{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0078" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、ご主人様ってば、いやらしー目をしてますね～。私の水着姿、そ\nんなに気に入って頂けました？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00015703_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんも水着の上からでもわかるぐらい大きくしちゃって……にゃふふ\n、私のご主人様はどーしよーもないですねー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――いいですよ、ご主人様が望むのであれば、このままこの場所でご奉仕し\nて指し上げちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00015703_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「何かご要望はありますか？　――にゃふふ、折角の水着ですものね、隙間か\nらおちんちん差し込んじゃってくださいな♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃん♪　おっぱいで挟んだだけなのに、おちんちん元気いっぱいに跳ね回\nってますねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303105" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015703_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、まっかな亀頭がぴくぴくしてますよ？　にゃふふ、ご主人様って\nばかわいーんだからぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303106" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、いいですよ、お好きなように腰を動かして、私のおっぱい、ご自由\nにお使いくださいな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私はこうやって、んんっ……両側からぎゅ～ってして、ご奉仕して上げちゃ\nいますね、にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、ん、んんっ………最初からすごい勢いですねぇ。にゃふふ、見てく\nださい、私のおっぱい、こんなに波打っちゃってますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「両側から持ち上げて、おちんちん絞り上げるようにぎゅ～……んんっ……た\nぷたぷ、しこしこ、たぷたぷ、しこしこ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おっぱいの吸い付き、凄いでしょ？　もちもちのスキンが竿の部分を滑って\n、浮き上がった血管をさわさわって撫でて……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様がおっぱい大好きさんなのはインプット済みですからね。こーゆー\nことにも向いてるパーツにしてるんですよ？　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、んふっ、んにゃんっ……溢れてきたガマン汁も谷間に塗り込んで…\n…ぐちゅぐちゅ、しこしこ、ぎゅ～～……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それにしても、今日のご主人様のおちんちん、普段より約1.2倍増しで膨\n張してる気がしますねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――え？　水着の隙間に突っ込んでのパイズリは男の夢？　太陽の下で堂々\nとするのが興奮する？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もう、私のご主人様は本当に変態さんなんですから♪　――もちろん、嫌い\nじゃありませんよ？　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「もっと力強く、おっぱいの両側からぎゅ～って力を入れて……んんっ……！\n　圧迫して、離して、ずるずりって擦って……んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「左右のおっぱいを交互に動かして、っと……ずりずり、しこしこ……根元か\nら搾り上げる様にぎゅっ、ぎゅぎゅうぅっ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、おっぱいの谷間の中、ガマン汁で大変なことになってきちゃいま\nしたね。ほ～ら、このぐちゅぐちゅって音、聞こえますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んにゃぁんっ♪　にゃふふ、ご主人様の腰の動きも絶好調みたいです\nね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、あっ、んんっ……にゃふふ、おちんちんがまた一段と熱を持って、\nんんっ！　血管がドクドク脈打ってるのもはっきり分かっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、遠慮なんて必要ありません。私の身体はご主人様のものなん\nですから♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お好きに『使って』、ご主人様の心行くまでご堪能くださいな♪　んやんん\nっ♪　おちんちんがビクンって跳ねてっ、んあぁんっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんの根元からにゅるにゅる、すりすりぃ～♪　ぐちょぐちょの谷間\nで、ゆっくり、ぎゅ～、って押し上げて……んにゃん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほ～ら、折角なんですからご主人様ももっと腰を振ってくださいな♪　いち\n、に、いち、に♪　がんばれ、がんばれ♪　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すりすり、にゅるにゅる、ぎゅ～～♪　おっぱいを押し上げて、裏筋のいっ\nぱい擦ってあげますからね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んふっ、んんっ、んにゃんっ♪　ご主人様ってば、そんなかわい～声出しち\nゃって、にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いいですよ、このままおっぱいの中で精液びゅ～って出しちゃってください\nな。折角の水着ですから、そこで全部受け止めてあげちゃいます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おっぱいを左右からずりずり、ぎゅっぎゅっ！　上半身ごとたぷたぷ、ぎゅ\n～♪　ご主人様のおちんちん、ぴくぴくしちゃってる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「分かってますよ、もう我慢の限界ですよね？　ほらほら、あと少しです、ご\n主人様も腰を振ってくださいな！　がんばれ、がんばれ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、んふぅんっ……！　もっと早く、激しくっ、んにゃんっ……\n！　おちんちん、根元から一気に搾り取って、んんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ぎゅ～、っておちんちんに体重をかけて、しこしこ、ぎゅっぎゅっ♪　おっ\nぱいタプタプ、にゅるにゅる、ぎゅ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、括れの部分ももっといじめてあげちゃいますね～♪　おっぱいで\n挟んで、ぐりぐり、左右に振り回して、ぎゅ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほ～ら、出してくださいな！　ガマン汁と汗でにゅるにゅるに蕩け切った谷\n間の中に、精液ビュービューって出してください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃんっ……！　ご主人様の精液がこんなにいっぱい……！　にゃふふ、\nぴくぴくしながら射精するおちんちん、可愛いですね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303135" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_03" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様の精液……んんっ……熱いはずなのに心地よくて……にゃふふ、顔\nに出してくれてもよかったのに……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それにしても、やっぱり凄い射精量ですね～ご主人様♪　流石私のご主人様\n！　よっ、性欲お化け！　……褒めてますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303137" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほら、聞こえますか？　おっぱいタプタプってすると、谷間の精液が掻き混\nざって、とってもえっちな音がしちゃってます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、これを塗り込んでおちんちんシコシコしたら、とっても気持ちい\nいと思いませんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃふふ、承りました♪　何度も言いますが折角の水着！　この解放感\nを一緒に楽しんじゃいましょうね、ご主人様♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「出された精液を谷間の中でかき混ぜてっと、んんっ……！　このじゅぼじゅ\nぼって音、本当にえっちですよね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おちんちんのびくびくも止まりませんね♪　折角なら、このままお口で出来\nるパーツとかもあればいいんですけどねぇ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、それまた次回にこうご期待ってことで。またおっぱいを大きく弾\nませていきますよ～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「おっぱいをたぷたぷして、すりすり、ぎゅっぎゅっ……括れの部分をもっと\nスキンにめり込ませて、ぐりぐり、ぐりぐり……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、なんですか～その目線は。私の水着姿、そんなに気に入ってくれ\nたんですか？　視線がエッチ過ぎてすごいことになっちゃってますよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――にゃっ！？　そ、そこまでストレートに褒められると、流石にちょっと\n照れると言いますか、恥ずかしすぎると言いますか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「いえ、嬉しい、とっても嬉しいです、ご主人様♪　貴方のそーゆーところが\n大好きです♪　にゃふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303207" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「お返し、ではないですけど、こんなおっぱいの動きはどうでしょうか？　根\n元から皮ごと巻き込んで、左右にぐりぐり振り回して、んんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「括れの部分を谷間で圧迫して、尿道口を開くようにぎゅ～～って押し上げて\n、にゅるにゅる、たぷたぷ、シコシコ、ぎゅっぎゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、今日のご主人様はこの動きに弱いんですよね？　おっぱいをズリ\nズリ交互に動かして、皮ごと捩じるのが気持ちいいんですよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「って、聞くまでもないですよね～♪　にゃふふ、ご主人様、口元から涎が垂\nれちゃってますよ？　いっぱい感じてくれてメイド冥利に尽きます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――まさか、特に特別な機能なんて何も使ってませよ。ご主人様のコンディ\nションを解析して、リアルタイムで動きを微調整してるだけです♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「私は貴方専用のメイドですからね。水着姿になろうがそれは変わりません。\nご主人様の心行くまで、ご奉仕させていただきます♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃ、んんっ、んふぅっ……！　もっと大きくおっぱいを弾ませて、ぎゅ\n～っておちんちんに伸し掛かって、んにゃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゅるにゅるの谷間でおちんちんシコシコ♪　特製の柔らかスキンに亀頭を\n沈み込ませて、ぎゅ～～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ほらほら、ご主人様も腰の動きを合わせてくださいな。いち、に、いち、に\n♪　谷間の中をオマンコだと思って！　もっと激しく！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「がんばれ♪　がんばれ♪　あっ、んんふぅんっ……！　にゃふふ、またおち\nんちんの先っぽが膨らんできた♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あっ、んんっ、んにゃぁんっ……！　ご主人様の精液の匂い……んんっ、お\nっぱいだけで、私もイっちゃうかも、にゃふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「今度はどこに出しますか？　またおっぱいの中に？　私の全身を汚したいの\nであれば、頭の上からぶっかけてくれてもいいですからね♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃんっ！　おっぱいの中でおちんちんが大暴れして！　ほら、出してく\nださい！　ご主人様の精液をた～っぷりぶちまけてください！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんんっ！　またこんなにいっぱい、精液がおっぱいにドクドク注ぎ込まれ\nてっ、あっ、んにゃぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ♪　いくら水着だって言っても、この精液の量は弾ききれないみた\nいですね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「見てくださいよ、私の谷間、こ～んなに精液が溜まっちゃって……くんくん\n……にゃふふ、匂いを嗅ぐだけで気持ちいいエラーがでちゃいそう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んっ……おちんちんの中にはまだまだ精液が残ってるみたいですね。このま\nま続けてぜ～んぶ搾り取って上げちゃいますからね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「敏感なびくびくおちんちん、ゆ～っくり絞り上げて……んっ、んぁっ……や\nっぱりまだまだ出て……んんっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、ご主人様のそのお顔、とってもかわいいですよ♪　……ご満足、\nして頂けましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「それにしても、こーゆーのって、露出プレイ、って言うんですよね？　太陽\nの下でご奉仕するの、ちょっと癖になっちゃうかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「今度はおっぱいだけじゃなくて、下の方でも……ね？　にゃふ、にゃふふふ\n♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「さぁ、全部出し切ったのなら一緒に海に泳ぎに行きましょうか！　べとべと\nになったボディも洗いたいですしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「せっかくの海なんです！　一緒にいっぱい楽しみましょう、ね？　ご主人様\n！　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んにゃぁんっ！　ご主人様の精液が頭から降り注いでっ、んんんっ！　にゃ\nふふ、おちんちん、とっても気持ちよさそう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015703_01_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「まさに精液のシャワーですね～、んんっ……！　自分のメイドに精液をぶっ\nかけて汚していくのはどんな気持ちですか？　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「答えを聞かなくてもその顔見ればわかりますけどね～。ほらほら、最後の一\n滴まで私にぶっかけてくれていいですからね～♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「んんっ、もっと根元から、空っぽになるまでおちんちん絞ってっ、んふっ、\nんにゃぁんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ああでも……んあぁんっ……！　ここまで顔にかけてもらえるなら、やっぱ\nり口のパーツも新調してみてもいいかもしれませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「すんすん……にゃふぅ……匂いだけでノイズが止まらなくなるご主人様の精\n液……味覚システムを搭載して味わったら、私どうなっちゃうんだろ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふ、どうですご主人様？　私の水着パイズリ、心行くまで楽しんでい\nただけましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「――最高だったご褒美、ですか？　にゃふふ、だったら決まってます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「この後もいっぱい遊んでくださいな！　ビーチボール！　ビーチボールをや\nりましょう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「くたくたになるまで、いっぱいいっぱい遊びまわって――疲れたら、またご\n奉仕、させてくださいね？　にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}