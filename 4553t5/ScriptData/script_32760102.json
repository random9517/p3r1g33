{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「突然押しかけてすまんのう、いや、わしとしたことが、ちょっとお惣菜を作 \nりすぎてしまってな。よければ、少し食べて貰えんかと思ったのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104101" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ほら、そなたの好きな魚の煮付けに、卵焼き、粕漬けもあるぞ。遠慮するこ \nとはないからの、たぁんとお食べ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104102" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「なんじゃ、もう……そんな泣きそうな顔をしながらかっ食らって……あぁ、 \nよく噛んでお食べ。喉に詰まらせても知らんぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104103" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふふ……全くいい食べっぷりじゃ。何……？　ずっと優しくされてなかった \nから胸を打たれてしまったと……それはまた、相変わらず難儀な」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104104" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「……落ち着いたか。ふふ……甘えたがりじゃな……そんなに愛に飢えておっ \nたか……ならば、とことん甘えても、いいんじゃぞ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んふふ……皆まで言わずとも分かるじゃろう……もちろん、そなた次第じゃ \nが……さて、どうする……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104106" ]},
		{"command":[ "SETCHARA", "0", "char_00027601_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んっ……あふっ、素直が一番よ……。さて……わしの準備はちゃんとできて \nおる……やり方は確認するまでもないじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「すっかりと立派になったそのチンチンを……ゆっくり中に……そう、そこじ \nゃ……小さいが、ちゃあんとそなたのをぜぇんぶ飲み込んでやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そのまま、腰をずぶっと沈めて……はっ、ぅんっ……！　んんんんっ、あっ \n、くぅぅぅっ……んっ、そうっ、あっ、ぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んくぅっ……あぁ……ちゃんと入れられたのう……くぅぅ……なんとも太く \nて硬い……立派なチンチンじゃ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ん……？　血……？　おぉ……本当じゃな、ちょっと出てしまっておる…… \nんっ、いや、そこまで痛いわけではない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「処女だったのか？　はて、どうだったかのう……？　まぁ、細かいことは全 \n部忘れてしもうたが……初物気分は味わえたのではないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「おっと……だからと言って、下手に腰の動きを遠慮することはないからの？ \n　血は出ておるが、それ以上にオマンコは愛液でぬかるんでおる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「このぬめりに任せて……そなたのチンチンを、中で存分にかき回して……わ \nしを気持ちよくさせてくれ……頼むぞ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はふぁっ……！　んっ、あぁっ……はんっ、そうじゃ……いい、感じに…… \nチンチンが……オマンコを擦り上げて来るっ……んぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はふっ、少し窮屈なのはすまぬな……んっ、もう少しすれば……ちゃんと、 \nチンチンに馴染んでくると思うが……あっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ぬめって……吸い付く感じが気持ちいい……？　そう言ってもらえると、助 \nかるぞ……んふっ、ちゃんとまぐわいができておるのじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んんっ、ゆっくり動かして……平気だと言っておるのに……ちゃんと、わし \nの身体を気遣ってくれておるのじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104118" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「確かに……ゆっくりでも、しっかりとチンチンを感じる……あぁ……このず \nぶりと腹の奥まで埋め込まれる感覚……言葉にならぬ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104119" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んんっ……気持ちいいぞ……オマンコが、嬉しくて……また、 \n奥からじわじわと……汁を湧き上がらせておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「もっと、強く……速くしても、大丈夫……じゃからな？　んぅっ……いや、 \n違うぞ？　別にわしはおねだりをしているわけでは……あぉぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「あうっ、くぅっ、んんんぅっ！　急にっ……あっ、チンチンがっ……激しく \nっ、んくぅっ、ズンズンっ……来てぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んぁぁっ、掻き出されるっ……ふひぁっ、オ、オマンコがっ……めくれてぇ \nっ、かき回されるぅっ、ふぁっ、はひぃんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「こうして……欲しかったかじゃとっ……？　んふっ……突然……生意気なこ \nとを言うではないか……んんっ、あっ、あひぉっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「しょっ、しょこはっ……んふっ、あっ、おぉっ……か、感じるっ……気持ち \n……いいがっ、はっ、ふひっ、はひぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「そんなに……あっ、あふぁっ、続けてされるとっ、はっ、か、からだが…… \nどんどん熱く……なってっ、ふぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んぁうっ……そなたの欲望をっ……オマンコっ、いっぱいに感じるっ……く \nひぃっ、わしのメスが呼び覚まされるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んふぅ……はぁぁ……全く……中身は老体とはいえ……こんな幼気な身体に \n発情しおって……この、節操なしめ……んっ、くふぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「こんなにも、まっすぐに求められれば……嬉しくなってしまうではないか… \n…はぁんっ、オマンコが……いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んっ、ふっ、くふぅっ……わしも……もっとチンチンを気持ちよくさせてや \nらねばな……んんっ、どう……じゃっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふふ……少し締め付けるだけでも、いい感じじゃろう……？　もう一つ…… \nわしの体液を味わうがいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104131" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「れろ、んりゅっ、ちゅぱっ、んふぅ……じゅるるっ……んちゅぷっ、龍の体 \n液に含まれる……催淫成分じゃ……んりゅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104132" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「これを、体内に取り込めば……ちゅぷっ、一層……興奮して……精液も…… \nたっぷりと出るに違いないぞ……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はっ、あぁっ、また……動きが激しく……んくぅっ、はぁっ、そうじゃ…… \n出したくなって来たということか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「よいぞ……んっ、このまま……中にいっぱい出して……わしの胎を精液まみ \nれにしておくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「わしも……あぁっ、イクからなっ……一緒じゃっ、はひっ、あぁっ……！　 \nズリズリ気持ちよくてっ、ひぁっ、オマンコッ……来るぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はふぁぁぁっ……出てるっ……そなたの精液が……オマンコ……いっぱいに \nしていく……はぁぁぉぉぉぉっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104137" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「熱いのが……トロトロじゃ……んっく……愛の結晶をこの身に受けられる喜 \nびよ……はぁぁぁ……ん、溢れてくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はふっ、はぁ……んぁ……たっぷり中出しされてしまったな……わしのオマ \nンコ肉が……幸せに満ち溢れておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104139" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んふふ……量も大したものじゃ……ついついそなたを興奮させてしまったか \nも知れん。わしも、まだまだ現役ということかの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んふ……ふふ……さて、まだまだ果てる雰囲気ではなさそうよの。中のチン \nチンが正直に伝えておる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「わしも……すっかり発情してしまった……んふぁ……もっとして欲しいぞ… \n…おねだりでもなんでもしよう、チンチンがもっと欲しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「たっぷり中出しされた……ヌルヌルのオマンコを、まだ硬いままの太いチン \nチンで……いっぱいかき回して欲しいのじゃ……ふぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はぁうんっ、んっ、んぁぁっ、ふっ……一番の奥まで……チンチンが……届 \nくぅ……んっ、ふはぁぁぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「あふぁ……オマンコがきゅんきゅん……動いてしまうっ、はぁんっ、ずっと \nこうしていたい位じゃ……はっ、ふぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「気持ちいい波が……次から次へと押し寄せて……はぁぁ……もっと、ゆさゆ \nさっ……揺らしてぇっ、ふひぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「くぅん……そなたは……どうじゃっ？　わしのオマンコ……んっ、ちゃんと \n……気持ちよくできておるか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はふぅ……んっ、そうか……んふっ、ならばよい……んっ、もう痛みもない \nからな……オマンコ……貪り尽くすように、して欲しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んっ、あぷっ、ちゅぷぅ……んむっ、れる……れろぉ……舌も絡めよう…… \nんぁぁ、そなたの唾液にも催淫効果があるみたいじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はっ、ふっ、んぁっ、あぁっ、また……チンチンが激しくっ！　んくぅっ、 \nあっ、ふぁぁっ、オマンコっ、ひ、広がるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104210" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「あひっ、あぁっ、襞がっ……ずりゅずりゅっ、めくれてっ……！　んひぉっ \n、熱いチンチンがっ、中を擦ってぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はふぁっ、おっぱいも……そなたの胸板に擦れて感じておるっ……頭から… \n…足先まで……どこも全部……気持ちいいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はっ、んんっ、あぁっ、そこの突き上げぇっ……！　んっくぅ……欲張りお \nって……はぁんっ、大好きじゃっ……あっ、んぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「あっ、あぁぁっ、こんなの……病みつきになってしまうっ、何度もっ、され \nればされるほどっ……オマンコが震えてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はひっ、あぁっ、またイキそうになるっ……！　んんっ、いやっ、ここは… \n…我慢して……そなたと、また一緒にイキたいっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んんっ！　はっ、ふぁっ、そなたもっ……かなりっ、息が……乱れておるな \nっ……そろそろっ、近いのかっ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はぁぅんっ！　あぁっ、また……チンチンが速くぅっ！　んぁぁっ、出すた \nめのっ……やつじゃなっ、あくぅぅん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はっ、んふっ……！　さあ……いつでもよいぞっ……そなたの熱い精液をっ \n……思い切りぶち撒けてくれっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「また中出しでもっ、全身……いっぱい掛けるのもっ、そなたの好きにしてい \nいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はぁぅんっ、わしも……もうイクからっ！　一緒じゃっ……んぁぁぁぁぁぁ \nっ、イクイクイクぅぅぅぅぅーーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104220" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_11" ]},
		{"command":[ "WAITINPUT" ]},

