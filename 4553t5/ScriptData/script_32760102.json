		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ひゃぁぁぁぁぁぅんっ！　んぁっ……チンチンが抜けてっ、はぁぁんっ、精 \n液が……こんなにぃっ……んぷぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104401" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_21" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はふぁぁ……まるで噴水じゃ……龍の香気が……ここまで効果をもたらすと \nは……あぷっ……溺れてしまいそうじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104402" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_18" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んちゅぷぅ……生命力に満ち溢れたコクのある味……れろ、舐めれば舐める \nほど、舌が伸びてしまう……んふぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104403" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はふぅ……何もかもすごすぎて……もう、まともに頭が働かぬ……ただただ \n心地いい……それだけじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んっ……さすがにもう出んか……はふ……あぁ……チンチンが太すぎて…… \nオマンコが閉じきらんままじゃ……少し恥ずかしいぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「しかし、このぼーっとした時間……そなたのことを近くに感じながら、何も \nしないでいるのも悪くないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「と言うよりも……力が抜けて……しばらく何もしたくないというのが正直な \nところか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ああ、心配することはない。こう見えても龍じゃぞ？　ちょっと張り切りす \nぎただけで、少し休めばすぐに元通りじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「まあ、それまではもう少しそばにおってくれればよい。ふふ……甘やかすつ \nもりが、わしの方が甘えてしまっておるな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104409" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_20" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「また、腹を空かせるようなことがあったら、いつでも呼んでおくれ。わしは \nそなたをもっともっと甘やかしたいからのう。んふふっ」", "NORMAL" ]},
