		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「くぅぅぅぅぅぅん……！　あぁぁ……また……中に……とぷとぷ……流れ込 \nんで……来る……はふぁぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104301" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_16" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ダメじゃ……もう、いっぱいになってるのに……溢れて止まらん……せっか \nくの精液があふれてしまう……ふぁぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「けど……んんっ、はふぁぁ……気持ちよすぎる……んくぅ……中出しされて \n……オマンコが喜びに満たされておる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「んんっ、すまぬ……わしのは小さいからのう、全部飲みきれん……あぁ…… \nそれでも、最後まで出してくれるのか……それもそなたの優しさよの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「はぁ、はふ……はぁぁぁ……んっ……うむ……出し切ったか……わしも…… \nやっと絶頂が落ち着いた感じじゃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふふ……やはりお互いの顔を向かい合わせての交わりはよいな。たっぷり甘 \nやかすつもりだったが、わしの方が甘えてしまったかも知れん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「こうして、そなたの温もりを感じながら、何もせずにじっとしている時間も \n心地いい……余韻に浸るというのはこういうことか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「さて……これだけ大量に出されたら、わしもうっかり孕んでしまうかも知れ \nんな。その時は、どうしてもらおうかのう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「ふふ……まぁ、そう慌てることもあるまい。ちゃんと責任を取る……？　ほ \nほっ、その言葉を聞けるだけでもわしは嬉しい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クラミツハ" ]},
		{"command":[ "SETTEXT", "「あふ……それにしても腰が抜けるかと思ったわ……もうしばらく、このまま \nでいさせてくれるか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_276_0104310" ]},
		{"command":[ "SETIMAGE", "0", "still_00027601_02_15" ]},
		{"command":[ "WAITINPUT" ]},
