		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、もちろん承知しております。私のご奉仕と……それに、私にも……し\nて、いただけると……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「どのようになさるのかは分かりませんが、はい、お任せ致しますので……ベ\nッドに横になればいいのでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「そのまま……胸をはだけて……あっ……はい……ご随意に、お揉み……下さ\nい……んっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403104" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_01_15" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「大きくて……柔らかい、ですか……自分自身では特別に思うことはありませ\nんが……喜んで頂けるのは、嬉しく思います……んっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい、かなり……今も、おっぱいは張っている感じがします……恐らく……\nこのまま続けて揉んで頂いたら……あっ、んぁっ、ふぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ……はしたない声を出して申し訳ありません……あっ、貴方の指が……\nんっ、とても……心地よくて……乳首が……痺れてっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「だ、大丈夫です……続けて下さい……あっ、あぁっ……おっぱい……手のひ\nらで包まれるの……心地いいです……あっ、あぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、あぁ……ぎゅうって……握り締めて頂いて……あぁっ……！　そのま\nまして頂いたら……出そうですっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はいっ、母乳が……あぁっ、ミルクが……溢れて参りますっ……あふっ、も\n、もうっ、出ますっ……おひっ、出ますぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403110" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んはぁっ……あぉぉ……感じます……母乳が出る時の感触……あぁ、とても\n気持ちいいです……んふぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ……今、乳首は……あひっ！　んっ、はしたなく充血して……\n身を捩って、しまいます……あ、ふぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はい……はぁ、たっぷり出して……あ……そ、それを……オチ〇ポに……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「これをローション代わりにしてパイズリを……かしこまりました。今度は私\nがご奉仕させていただく番ですね。喜んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「では……どうぞ、オチ〇ポを……あぁ……もうコチコチになって、逞しく反\nり返っていらっしゃるんですね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403115" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ……んっ、はい……とても熱くなって……オチ〇ポが興奮なさってい\nるのが分かります……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「えっ……私が動かさないで……旦那様が……？　はい、それでは……お好き\nなように、動かしていただけますか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……あぁっ……おっぱいの中で……オチ〇ポが擦れています。ん\nっ……くぁぉっ……はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁ、大きい……全部……包み込んで差し上げられない位にはみ出て……ビ\nクって震えて……もっと擦りつけて下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、はぁっ……んっ、あぁ……感じます……おっぱいを旦那様に動かして\nいただけて……パイズリ……いかがですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「気持ちいい……ですか、んっ、よかった……どうぞ、このままご遠慮なく…\n…私のおっぱいを使って下さいませ……はぁっ、ふっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「ですが、本当に私は何もしなくてよろしいのですか……？　んっ、感じてい\nれば……それで、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「承知しました……旦那様のオチ〇ポにどれだけ響くか分かりませんが……私\nも快感に素直に身を任せてみようと思います……あっ、ぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ……んっ、ふぁっ、んっ……目の前で……オチ〇ポが激しく動いてい\nます……あぁ……旦那様のオチ〇ポ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「こんなに近くで、目の当たりにすると……迫力があります……亀頭がぷっく\nりと開いて……少しお汁が滲んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「前後に揺れて……あぁ……今にもお口に届きそうで……お、お預けですか…\n…？　はい……多少もどかしいですが……旦那様のお心のままに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あひっ……！　あぁっ、か、代わりに……乳首を感じさせて……あぁっ、そ\nのようなお気遣い……あぁぉっ、して、いただかずともっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403127" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、私の乳首は……もう、十分に気持ちよくてっ……あぁっ、身体が…\n…疼いてしまいますっ、はっ、あぉぉっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、オチ〇ポに擦りつけて……んくぅっ……！　あぁっ、乳首……どち\nらもオチ〇ポに重なって……あうっ、すごくっ……いいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はいっ、気持ちいいですっ、あぁっ、そのまま、ズリズリされるとっ……谷\n間も……感じます……んくぅっ、それぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、ひっ、あぁっ……またオチ〇ポの先から……カウパーが滲ん\nで参りました……そろそろ、出されるのですか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んふっ……はい……もちろん、お好きなようになさって下さい……おっぱい\nマ〇コに中出し……ですか？　ええ、大丈夫です……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「今……私のこの母乳まみれのはしたないおっぱいは……旦那様専用のオマ〇\nコですから……どうぞ、思う存分中出しなさって下さい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、はぁっ、んぁっ、ずりゅずりゅっ……激しくっ……擦れてっ……私\nのおっぱいもっ、イキそうになっていますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403134" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、出ますっ、また母乳が出ますからっ……あひっ、あひぉっ！　あぁ\nっ、射精と一緒にぃっ……あぁっ、来てっ、下さいませぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ……！　出てっ、ますっ……母乳とっ……オチ〇ポミルクっ……一緒\nにっ、ドピュドピュっ……出ていますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ……あぁ……おっぱいマ〇コの中出し……気持ちいいです……乳\n首からミルク……どんどん溢れてしまいます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、コリコリの乳首……そんなにくすぐられたらぁっ……あっ、\nあぁっ、出るっ……んんっ、漏れますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403138" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ……射精……堪能していただけましたか……？　私も……母乳を出し\nて、おっぱいでイッてしまいました……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「今は余韻の中におります……んふ……はい……ご堪能いただけたのなら、何\nよりですわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403140" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、んっ……まだオチ〇ポ……お続けになりますか？　はい、勃起はずっ\nとなさったままですから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっと、私の母乳も搾り出したい……ですか。は、はい……どれだけ出せる\nかは分かりませんが……あっ、んぁっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はぁっ、んくぅっ……あぁっ、おっぱい……先程よりも、敏感になっていま\nす…………んふっ、ぐりぐり動かして……オチ〇ポが当たる所……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、んっ、んはっ……精液と……母乳が、混ざり合って……よく滑って\n……オチ〇ポが……擦れっ、ますぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、んっ……あぁっ、敏感な場所同士が……絡み合って……ぬめりと一緒\nに感じる熱が……奥に染み渡っていくようです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「くぅぅぅ……んっ……！　あぁっ……はぁっ、内側から……また、こみ上げ\nてくる感覚……ずっと続いていて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んぁふっ！　あっ、また……母乳が滲みますっ……あぁ……普段、母乳が出\nる時……こんな風になりませんのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「旦那様に刺激していただくと……あぁっ、気持ちよすぎて……あっ、乳首が\n疼いてっ……あ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あっ、はっ、おっぱいだけじゃない……あぁっ……はぁっ、んっ……オ、オ\nマ〇コにも……あぁ、疼きが……集まって……んんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はっ、ひぃんっ！　あぁっ……んっ、いけません……今は意識をおっぱいに\n集中させて……旦那様のオチ〇ポに楽しんでいただかないと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んっ、あっ……あぁっ、でも、そのように身体を揺らされたらっ……はっ、\nんぁっ、全身に心地いい感覚が……巡ってっ……くぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、いいですっ……オチ〇ポを感じてっ……私のおっぱいもっ……ずっ\nと法悦の中におりますわっ、はっ、んぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「もっと……あぁっ、擦って下さいっ……オチ〇ポっ、ずりずりっ……おっぱ\nいマ〇コ犯して下さいませっ……あっ、はぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「不思議ですっ……こうして、おっぱいを犯されているとっ……一緒に、オマ\n〇コの方も気持ちよくなっていくんですっ……あひっ、あぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403214" ]},
		{"command":[ "SETIMAGE", "0", "still_00003004_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「はいっ、今もっ……ずっと、ウズウズしてっ、あぁっ、旦那様のオチ〇ポに\nズボズボされてっ、オマ〇コもイキそうになっておりますっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あぁっ、はい……もっと母乳も絡ませて下さいませっ……！　このまま、お\nっぱいを犯し続けていただけたらっ、また一緒に達しそうですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「んくっ、あふっ、あぁっ、オチ〇ポがまた膨らんでいますっ……乳首と亀頭\nが重なってっ……んくぁっ、痺れが……強くっ……！」", "NORMAL" ]},
