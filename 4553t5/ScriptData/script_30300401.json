		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
		{"command":[ "SETTEXT", "「あふっ、あぁ……はい……お扱き下さい……私のおっぱいも、もっとザーメ\nンを欲しがっております……んんっ、ふっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_030_0403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "牛神様" ]},
