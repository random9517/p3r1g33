{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0149" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "そして、ロッテとクララのパーツメンテナンスの終了日。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は再び２人に叩き起こされ、おニューの衣装を見せてもらうことになった。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……と、いうわけで……。じゃっじゃ～ん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040001" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ハロウィン衣装のお披露目です～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040001" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「な……なんでウチまでこんなきわどい服装に……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040001" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "照れが怒りに変わっているのが、いつものオボロらしい反応だ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「せっかく着替えたんだし、エンジョイしとけばいいじゃないかよ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「い、嫌です！　だって……ヘンですっ、おかしいですこんな衣装……！　あ\nなたもそう思うでしょう！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「や……可愛いじゃねーか？　さっすが本部はわかってるってカンジだが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「うぬぬぬぬぬぬぬ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040003" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「かっ、カワイイのはウチですか！？　それともウチの服ですか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そこはワンセットじゃねーのか？　わざわざ切り離す意味はなんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「くぅううううううう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「……ツンデレの気配がする」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040002" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「えっ？　つんでれ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040002" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「オボロさん。あなたを私のライバルに認定します。今すぐご主人から離れて\nください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040003" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「別に近づいてないのです！　か、勘違いするなです！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040006" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「あ、もしかして……オボロさんもご主人様のこと……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040003" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なんなのですこのロボっ娘どもは！　あることないこと勝手に言うなです！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040007" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「その反応が、全部語っちゃってると思いますけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040004" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「なんですか！？　いっ、いい加減に茶化すのをやめるのです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040008" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "きゃあきゃあとかしましく騒いでいる３人を見ているだけで、一日が終わって\nしまいそうだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにしても、女子は花があるっつーかなんつーか」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どことなく蠱惑的で、思わず引き寄せられてしまいますな」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それに比べて、俺とコイツはなんつーか……冴えないよな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「なんですと！？　冴えてないのはご主人だけですぞ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "華やかな女達の仮装とは真逆に、俺の仮装はくすんだ地味なものだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「これは……狼男ってことか？　やたらワイルドな着ぐるみなんだが」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「色んな意味でご主人にお似合いですぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ケッ。犬はいいよなぁ。何もしなくても仮装みたいなもんだしさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「むむっ！？　これはこれで、工夫をこらしているのですが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どこがだよ。オマエはいつものオマエだろうが」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ため息をつく俺の毛皮を、ちょいちょい、とオボロの指が引いた。", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "2", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……ん？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「あなたも、まあ……いつもよりはいい感じだと思います」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はあ？　どこがだ、こんなボサボサのモッサモサの狼の毛皮着せられてんだ\nぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……ウチとペアでいてもおかしくない格好に見えます。それだけです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「やっぱりツンデレ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040005" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「えへへへ、このままだとオボロさんにご主人様をとられちゃうかもですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040004" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「それは……それだけはだめ。姉さん、ご主人を誘惑しよう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040006" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ゆうわく？　恥ずかしいけど、それでご主人様が私達を見てくれるなら……\nしちゃいますか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040005" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ご主人様～♪　オボロさんよりも、私達といちゃいちゃしてくださぁい♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040006" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「そもそもウチはイチャついてなどいませんが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040011" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人。今のオボロさんが魅力的なのはわかる。でも……こっちも見て欲し\nい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040007" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふっ♪　私達、ご主人様に可愛いって思って欲しくてドレスアップし\nたんですっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040007" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「女の子は……好きな人のためになら、いくらでもキュートになれてしまうん\nですよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「さあ。さあご主人、もーっと私達を……私を可愛いって言っていいんだよ？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040008" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「うんうん。言ってください♪　ぎゅっとして、耳元で……。にゃふふふ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040009" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「たまにはメイドロボも……褒められていいはずだよ。せっかくおめかしした\nんだもん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040009" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうかそうか。２人とも偉いぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "なでなで、と姉妹の頭を撫で回すと、嬉しそうな声が聞こえてきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃふふふふ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040010" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「すごく良い気分……。ずっとこうしていたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040010" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人……手を止めちゃいやだよ。２人とも平等にずっと褒めて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ううう～……♪　とろけちゃいます。こんなのいけない気分です……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040011" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「やれやれ。念願叶って良かったですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040012" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「……とはいえ、あなた方の目的は主人に甘えることだけじゃないはずですよ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチを巻き込んでここまでしたからには……きっちりハロウィンを楽しむ責\n任があると思いますが」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040014" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「そうだった。気持ちが良くってすっかり忘れてた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040012" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「ね～♪　だってだって、ご主人様の手はあったかくてうっとりしてしまいま\nす♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040012" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「オボロさん。あと５分だけ、これを楽しんだらハロウィンを始めるから……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040013" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「５分だけ待っててくださいね。あぁあ……幸せです。ご主人様大好きです…\n…♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040013" ]},
		{"command":[ "SETCHARA", "0", "char_00015702_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……あんまり可愛いことを言うとこうだぞ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "がばっ！　と２人を両腕で抱きすくめるとますます甘い声があがった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ロッテ" ]},
		{"command":[ "SETTEXT", "「にゃ～～～～♪　これ以上好きにさせないでください、溶けちゃいます～！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_157_010022040014" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クララ" ]},
		{"command":[ "SETTEXT", "「ご主人の匂い……クラクラする。ハロウィンをやって本当に正解だったかも\n……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_158_010022040014" ]},
		{"command":[ "SETCHARA", "0", "char_00015802_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「それはハロウィンとなんの関係もないただのスケベ野郎ですよ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010022040015" ]},
		{"command":[ "SETCHARA", "0", "char_00000512_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}