{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0136" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「来ましたわね……最近、わたくしのことをふしだらな目で見てくるあなたに\n少しばかり教育をしなければと思いまして」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303101" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしの身体に欲情するのは分かります……が、あなたとわたくし、どち\nらが上かをちゃんと理解してもらわなければなりませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303102" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、そこにお座りして……あら、もうペニスを勃起させていますのね。ふ\nふ、はしたない……一体何を想像しているのかしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303103" ]},
		{"command":[ "SETCHARA", "0", "char_00012503_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「でも、今回に限ってはわたくしの意を汲んでいるということですから、褒め\nてさしあげますわ。さて、それじゃあ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしの胸で、あなたのペニスを挟んで拘束いたしますわ。動いてはダメ\n。わたくしと、あなた、どちらが上なのか……ふっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303105" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_01" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「このパイズリで教えて差し上げますわ。ほら、動かない、動かない。ダメで\nすわ。わたくしの言うことを聞いて……待て、です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んっ……ふふふ、よくできました。まずは褒めてさしあげましょう。今にも\n動きたそうにぴくぴくしているのに、我慢できていますわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「それでは……んんっ、ふっ、んっ、どうですか、わたくしの胸は。あなた、\nここにいつも視線を向けていますものね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303108" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ……顔だけで分かります。気持ちいいのでしょう？　ほら、ほら、こう\nして、ぎゅっと挟んで、ぐにぐにって動かせば……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ペニスがびくびくしているのが分かりますわ。あんっ、ほら、動いてはダメ\nと言っていますのに……んんっ、そう、大人しくして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「そうそう。あなたはわたくしのパイズリをただ受けていればいいのです……\nふふ、そんな切なそうな顔をしなくてもよろしいのですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303111" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ちゃあんと、わたくしの言うことを聞いていれば、ご褒美もさしあげますか\nら。だからほら、動かないで……我慢、我慢……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、我慢と言ってますのに。そう、頑張って、動かないで……ふふふ、そ\nの顔、たまりませんわね……ぞくぞくしますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303113" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ようやく腰が止まりましたわね。偉いですわ。それでは少しだけご褒美を…\n…んっ、ほら、こうして身体ごと動かせば……あんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さっきよりも強くペニスが刺激されるでしょう？　わたくしの胸、その奥ま\nでペニスが沈みこんできていますわ。んっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、その切なそうな顔……気持ちいいのですね。でも、腰は動かさずにい\nる……ようやく分かってきましたわね、今の立場を」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303116" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「素直な人は好きですわよ。それじゃあ、ご褒美をさしあげなくてはね。あー\n……むっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふうっ、んっ、れるっ……言うことを聞けたあなたのペニスを、舌でなで\nなでしてあげますわ。れろっ、ちゅっ、んっ……ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303118" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ああ、ほら、動いてはダメですって言ってますのに……我慢しないと、舌で\nなでなではおあずけですわよ？　いいんですの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふっ、よくできました。それじゃあ改めて……れるっ、れろっ、んっ、ち\nゅっ、どうですか？　胸と舌のどちらがお好き？　んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303120" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、答えてくださいな。んうっ、この胸でぎゅっと挟んでうごかすのと…\n…れるっ、この舌でなでなでするの……んふうっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「どっちがお好きなのですか？　あなたのお好みはどちら？　んふふふ、れる\nっ、ちゅっ、んっ、ふうっ、ふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「え？　両方？　胸と舌、両方が好き？　んもう、よくばりさんですわね。ま\nあでも、そんなところも……いえ、それならリクエストに応えて……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303123" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「れるっ、両方して差し上げましょう。こうやって胸でぎゅっぎゅってしなが\nら……んっ、れるっ、れろっ、ちゅっ、んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「舌でなでなでしたら……ふふっ、あなたのペニスがやけどしそうなほどに熱\nく硬くなってますわね……んっ、れるっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「そんなにこのパイズリフェラが気に入ったんですの？　ふふ、でも動いては\nダメ。動いたら、どっちもやめてしまいますわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はい、よく我慢できました。それじゃあ、ご褒美を……んっ、れるっ、ふう\nっ、れろっ……んっんっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303127" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んんっ、んむっ……ペニスがびくびくしてきましたわね。先っぽからもお汁\nが……んっ、れるっ、んうっ……イきたいのですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふふふふ、まだ。まだダメですよ。こっちも我慢です。わたくしの許可な\nくイってはいけませんよ。我慢、我慢です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303129" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ああ、その顔、いいですわね……切なそうに顔を歪めて、唇を引き結んで我\n慢してる姿……たまりませんわ……ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303130" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅっ、れるっ、んんっ……でも、我慢のさせすぎはよくありません\nからね。それじゃあ、カウントダウンしてさしあげますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「10……・9……8……んっ、むっ、れるっ、ちゅっ、7……6……5……\nんんっ、ふっ、まだ、まだですわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303132" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「4……3……2……ほら、もう少し、我慢して。ちゅっ、れるっ、んっ、ん\nむっ、んんっ、れろっ……1……1……1……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、まだですわ。いぃ～ち、いぃ～ち、んむうっ、れるっ、ちゅっ、んん\nんっ、え～と、どこまでだったかしら、4でしたわね？　ふふふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「4……3……2……んんっ、んっ、1……ふふ、ああ、もう、その顔、顔が\n……いじめすぎちゃいましたわね。しょうがありませんわ。ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303135" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「いぃ～ち……んっんっんっ、れるっ、ちゅっ、んむっ、ふっ……いぃ～ち…\n…ゼロッ！！　あむっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んぐうううううっ！！　んっ、んんっ、んぐっ、んくっ、んっ、んんんっ！\n！　はっ、あっ、ものすごい射精……焦らした甲斐がありましたわ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303137" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んぐっ、んっ、喉に張りついて……何度も飲みこまなきゃ飲めないほど濃く\nて……味も匂いも……ふふ、あなたの精液の味、好き……んくっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んんっ、んぐっ……気持ちよさそうな顔でなによりでしたわ。わたくしの指\n示にもちゃんと従って、えらいえらい。いい子ですわね、あなた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303139" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「これで、わたくしとあなた、どちらが上か分かりましたわね？　これからは\n、自分の欲望を少しはコントロールなさることね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303140" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「それはそれとして……あなたのペニスはまだ躾けたがられているみたいです\nわね。わたくしの胸の中でびくびく震えていますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「仕方ありませんわね。わたくしの言うことを良く聞いたご褒美に、もう一回\nしてさしあげますわ……んっ、んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303202" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さっきよりも汗でぬるぬるになった谷間でしごいて……んんっ、れろっ、舌\nでもなでなでして、うふふふ、ペニスがどろどろですわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303203" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んんっ、ふっ、ふうっ……またペニスが硬くなって……お汁も出てきました\nわね。でも、今回も動いてはいけませんわよ……れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ご褒美の躾けですからね。わたくしの言うことにちゃんと従っていれば、ま\nた気持ちよくしてさしあげますわ。このように……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、もう顔が蕩けていますわ。ペニスもおねだりするように震えて……可\n愛らしいことですわね。なでなでしてさしあげます。れるっ、れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303206" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んくっ、先走りのお汁が……んんっ、先ほどの精液の残滓とも相まって、素\n敵な味ですわ。あなたの快感が染み出て……んっ、んぐっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふうっ、この味、ペニスの味とお汁の味……やみつきになりそうですわ。\nあんっ、あっ、こら、待て、待てですわ。動いてはダメ……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ちゃんと、出させてあげますから待てですわ……そうそう、いい子、なでな\nでしてさしあげますわね。れろっ、れるっ、れりゅっ、んっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふうっ、んっ、胸の谷間でペニスが暴れてますわ。腰は動いていないのに…\n…そんなに気持ちいいんですのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303210" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ご褒美ですから、仕方ありませんわね。もっともっと気持ちよくしてさしあ\nげます……んっ、れるっ、んんっ、んむっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、ペニスが蕩けてしまいそうでしょう？　あなたの顔、真っ赤になって\n……私の胸と舌を凝視して……んっ、ちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「その顔と視線が……ふふっ、わたくしの心をぞくぞくと震わせますわ……ん\nっ、ほら、動いたらダメですと言いますのに。悪い子ですわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303213" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「悪い子には躾けですわ、胸と舌で……れるっ、ちゅっ、んっ、ふうっ、ふふ\nふ、どちらも一緒ですって？　そういうことを言うとやめちゃいますわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、ほらほら、またカウントダウンしてさしあげましょうか？　あなたが\nイくまで、優しく数えてあげましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303215" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「じゅ～う、きゅ～う……んっ、むっ、れるっ、れろっ、ちゅっ……んんっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はぁ～ち、な～な……あんっ、ふっ、こら、暴れてはダメですよ、悪いペニ\nス……数えるのが遅れるでしょう？　れろっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ろ～く、ご～、よん……ちゅっ、ちゅむ、んっ、ああ、数えるたびに先端が\n膨らんで……ふふ、今度から射精カウントダウンを毎回やりましょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さ～ん、に～い、い～ち……あなたがカウントダウンしなければイけない身\n体になってしまったらどうしましょうね？　ふふふっ、んっ、れるっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303219" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、我慢、我慢、まだ我慢……イきそう？　ふふふ、じゃあイっていいで\nすわよ、ほら、ぜ～～～～～ろっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んむっ、んんんんんっ！！　んぐうううううっ！！　んっ、んくっ、んぐう\nっ、んっ、んっんっんっ……！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んぐっ……ふっ、はっ、あっ、二回目というのですのに、まだこんな濃厚で\nたっぷりとした精液を……んくっ、うっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303302" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしの胃の中があなたの精液で満杯になりそうですわ……んっ、もう、\n口に出しても妊娠はしませんのに……んっ、まだ出て……んぐっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んっ、んむっ……ふうっ、全部飲み干しましたわ。全く、口の中がもう精液\nの匂いで一杯ですわ。どれだけわたくしの口に注いだのか……んっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303304" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「躾けでもありますがご褒美でもありますからね。わたくしがあなたの精液を\n飲んであげるなんて、特等のご褒美でしょう？　ふふふっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら、そう言っただけでペニスがまた震えていますわ。でもダメ。さすがに\n三回目はお預けです。わたくしはそんな安い女ではありませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303306" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「でも、あなたが望むならまたしてさしあげてもよいですよ。従順な男にあめ\n玉をあげるのも、女としての器量ですしね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、期待しましたわね……またペニスが動いていますわ。また今度、する\nときに備えていっぱいっぱい溜め込んでおいてくださいね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「次もじっくりと胸で挟んで、舌でなでなでしてさしあげますから……たっぷ\nり、たっぷりとね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303309" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「だから、ちゃんとわたくしのことを考えながら、過ごしてくださいね。そう\nすれば、ご褒美をちゃんとあげますから……ふふふっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303310" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あっ！！　動いてはダメって言ってますのに、なにを……ひあああああっ！\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_18" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、こんな……わたくしの顔と胸に……んんっ、こんな、精液を\nかけるなんて……ふあっ、ああっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「熱い……匂いも……んんっ、こんなにいっぱい……んっ、んっ、まだ出て…\n…んふうっ、あっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「わたくしの顔にかけたって仕方がないでしょうに……え？　そうしたかった\n？　ご褒美だから許して欲しい……もう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303404" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_16" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「仕方ありませんわね。許してさしあげますわ。ただ、言いつけを破って動い\nたのはいけませんわね……悪い人」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「だから、また今度躾けてさしあげますからね。今回限りでは終わりませんわ\nよ。もちろん、あなたに拒否権はありませんわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303406" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_19" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「それにしても、こんなに濃厚で凄い匂いで……そんなに気持ちよかったんで\nすの？　ふふ、それならよかったですわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303407" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_17" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んっ、そんな目の前でまたペニスを動かして……気持ちよかったのを反芻し\nてるって、そんな風に言っても三回目はありませんからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、お預けというのも躾けになりますわね。もちろん、お預けの間は自分\nですることも禁止ですわよ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303409" ]},
		{"command":[ "SETIMAGE", "0", "still_00012503_01_16" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「我慢、我慢ですわよ。そうしたら、また沢山気持ちよくしてさしあげますか\nら。この胸と、舌で……ね？　あなた」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0303410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
