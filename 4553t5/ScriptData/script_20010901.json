{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんなんだこいつらは！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "襲来者（インベーダー）が現れたという知らせに急行してみると、敵の姿はこ\nれまで見たものとまるで違っていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「既視感はあるのに全く違うようにも見えますなぁ。敵の新型でしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160001" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「色違いってだけじゃねーか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "見慣れない襲来者（インベーダー）は統率をとれた行動をするでもなく、ただ\n破壊行為を行っていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにしても、なんて数だ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「多勢に無勢。下手に手を出さないほうがいいでしょうな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160002" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、そうだよな。しかしなんだか、息苦しくないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「確かに、体が重たい気もしますな。これでは普段のような活躍は期待できそ\nうにありません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……お前が活躍したことってあったか？　まあいいや。それより本部と通信\nが繋がらねぇ。妨害電波でも出されているのかよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「はて……。電波は目視できませんからなぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当に使えないなお前は！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、声が大きいですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおっ！？」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSe" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「どうやら隠れているのがバレてしまったようですぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160006" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「くそっ、武器は……って、なんじゃこりゃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "獲物の二丁拳銃がすっかりさび付いている。弾も赤茶色に変色していた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「錆びついてしまっていますな。ご主人、ちゃんと武器の手入れをしないから\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160007" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まてまて、メンテナンスはまあそれなりにしっかり……やってもらってるぞ\n？　だとしてもこんな真っ黒に錆びるのはおかしい……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うおぉっ！？　完全にこっちを狙ってやがる！！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああ、万事休すですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160008" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ええい、こんなところでやられてたまるか！　武器が使えないなら逃げるま\nで！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「待てぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021160001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「待ちなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021160001" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "少女の声が響く。崩れかけたビルの上に、ふたつの人影がある。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだありゃ」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「異世界に来てみりゃ、こんなビルの上かよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021160002" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「おかげで戦況がよくわかります。……ソルダー兵の数が多いですね。鈴、わ\nたくしが上でいいですね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021160002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「しゃーねーな。さっさと終わらせねーとだしな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021160003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ビルの上で、少女たちは手を繋いだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "SETCHARA", "0", "char_00011401_01", "7", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "1", "char_00011501_01", "7", "CENTER", "200" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「真空蒸着！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_115_010021160003" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鈴" ]},
		{"command":[ "SETTEXT", "「アマルガメーション！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_114_010021160004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ふたりの体が光に包まれたかと思うと、二つの人影はひとつに溶け合ってひと\nつになっていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0027" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「重装のアマルガム、ブリキ２！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021160001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「変身したのか！？　なんなんだあいつらは！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「世界が暗黒に覆われるとき、鋳造の女神が遣わす鋼鉄の使者……伝説の戦士\n……ブリキ２ッ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160009" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前、あいつを知っているのか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「こういうときに現れる美少女戦士は、伝説の戦士かセーラー戦士と相場が決\nまっております」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、相場ってなんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「とうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021160002" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ブリキ２がビルから飛び降り、カツマの前へやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「まさか一般人と一般犬がいたなんて。この空間では思うように体が動かせな\nいでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021160003" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おい、あんたはあいつらのことを知っているのか？　なんなんだあいつらは\n」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「あれはソルダー兵。暗黒界の下級兵士たちです。並の人間がかなう相手では\nありません。さ、隠れていてください」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021160004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人、変身ヒロインがそういうのなら、ここは隠れましょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021160011" ]},
		{"command":[ "SETCHARA", "0", "char_00000901_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お、おう……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ブリキ２" ]},
		{"command":[ "SETTEXT", "「さて、暗黒界のみなさん……。こんなに街を破壊した報い……。クズ鉄に還\nる覚悟はおありですね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_117_010021160005" ]},
		{"command":[ "SETCHARA", "0", "char_00011701_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}