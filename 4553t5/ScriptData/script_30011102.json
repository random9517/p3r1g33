		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ……！　すごいな……もうこんなに固くなって……私の水着姿で興奮\nしてくれたのか……？　ふふ、嬉しいな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104101" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私のも……んっ、分かる、だろう……？　あんっ、もう濡れているんだ……\nあっ、ふぅっ……あなたのが欲しくて……早く、ひとつになりたくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ！　こ、こら、そんなに力いっぱい、お尻を掴むな……あぁんっ、擦\nるの、強すぎる……！　あっあっ、これだけで、イってしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ダ、ダメだ、私ひとりでイくなど……するなら、一緒がいい……だから、お\n願いだ……あふぅんっ、うぅ、意地悪しないでくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「なぁっ……！　そ、そんなことを、私に言わせるというのか……！　うぅっ\n、あなたという人は、どこまでハレンチなんだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「え、あっ……ま、待ってくれ、わかった、ちゃんと言うから……！　このま\nまおあずけされたら、私はおかしくなってしまう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104106" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「お、お願いだ……私の、濡れ濡れオマンコに、あなたのぶっといオチンポを\n、いっぱいハメハメして、ザーメンをたっぷりナカ出ししてほしい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「うぅぅっ……い、言ったぞ……！　だから、もう……お願いだ、本当に、ガ\nマンできないんだ……！　あなたのオチンポを、私に挿れてくれぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んひぁああああっ！！　あっあっ、入って、きたぁっ……！　あなたのオチ\nンポが……んひぃいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「固くて、太いのが……あひぁあっ！　オマンコのナカ、ぐりぐり、かき分け\nて、入ってくる……んふぅうううんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぁっ！？　あ、あっ……奥に、当たってるっ……カチカチの、オチンポ\nが……あはぅぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んはぅぅ……あなたのオチンポ、すごい……！　挿れただけなのに、あぁっ\n、もう、おかしくなってしまいそうだ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あ、あなたは、どうだ……？　あんっ、あふぁぁっ……私のオマンコは、ち\nゃんと、気持ちいいか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104113" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「８の字筋というところを鍛えてみたんだ……こうして力を入れると、んんっ\n……オマンコが締まるだろう……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたに悦んで欲しくて……早く、あなたとシたくて、たまらなかったんだ\n……んふぅっ、あなたが、私の水着姿を、イヤらしい目で見るから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「だから、お願いだ……んはうぅっ、あなたのオチンポで、私のオマンコをい\nっぱい……あぁっ、気持ちよくしてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ひぁあっ！　あっ、あぁんっ……！　オチンポ、動いてる……！　あっ、あ\nっ、先っぽの太いところが、オマンコのナカ、引っ掻いてるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104117" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ひぁあんっ！　あっ、あぁっ、ソコ、ダメぇっ、あぁんっ、入り口のとこ、\n雁首でゴリゴリっ……あ、あ、オチンポ、抜けちゃう……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んひぅううううっ！　オチンポ、また入ってきたぁっ……！　ひぅぅっ、奥\nも、ダメっ、固いので、突くの、ダメぇっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ひぁあっ、あっ、あっ、あぁんっ、オチンポ、出たり入ったり、あはぅうう\nっ、オマンコのナカ、いっぱい擦れてるぅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「すごいっ、あなたのオチンポっ……あはぁああんっ！　オマンコ、気持ちい\nいっ！　あひぃいいんっ！　セックス、キモチイイっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁあんっ！　また、入り口のとこぉっ、そこ、キモチイイっ、んひぅぅっ\n！　オチンポの雁首で、ゴリゴリっ、気持ちよすぎるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、ソコばっかり、ほじっちゃダメぇっ！　ひぁああんっ！　エ\nッチな声、止まらなくなるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104123" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃいいんっ！　お、奥もっ、ダメッ……！　ソコ、ぐりぐりっ、亀頭で\n擦られたら……んひぃいいっ！　力が抜けちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっ、あひぃっ！　ズンズンも、ダメぇっ！　強すぎるっ！　オマンコ、\n全部擦れるっ！　お腹の奥、ジンジンしびれて、おかしくなっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぁあっ！？　オマンコのナカ、オチンポ、大っきくなって……あひぃい\nいんっ！　雁首、太くなってるっ、オマンコのナカ、もっと擦れるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「先っぽも、パンパンになってるっ！　あひっあひっ、奥っ、ダメぇッ！　大\nっきいので、そんなに強く、しないでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、あっ、クるっ、変なのっ、大っきいの、クるっ、あはぁあああ\nんっ！　ダメっ、もう、イッちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「お願い、あなたも一緒に……あはぁんっ、ひとりは、イヤぁ……あっあっ、\nオチンポ、イってっ、あぁんっ、私のオマンコに、精液、出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ひぁあんっ！　もうダメ、クるっ、キちゃうっ！　あなたのオチンポで、オ\nマンコずぽずぽされて、イっちゃうっ、イくっ、イくっ、イくぅううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃいいいっ！　精液、出てるっ、あっあっあっ、オマンコのナカに、い\nっぱいっ！　ひあぁああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_08" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっ、オチンポの先っぽから、びゅうびゅうっ、んひあぁっ！　ザーメ\nン出てるっ、オマンコの奥に、いっぱい当たってるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぁんっ！　あんっ、あんっ、待って、射精しながら、オチンポ、動かさな\nいでっ、ひあぁんっ！　オマンコで、精液、絞らないでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ひあぁあっ！　私も、まだイってるからっ、あぁああんっ！　オマンコ、ビ\nンカンになってるかぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっ、またイくっ！　精液、ナカ出しされながら、イっちゃうっ！　射\n精チンポしごかれて、オマンコ、イくっ、イっ、くぅっっっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……すご、かった……あなたのオチンポ……頭の中が、真っ白に\nなって……はふぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104136" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、はぁ……お腹のナカ、熱い……。あなたの精液でたぷたぷになって…\n…んふぅ、温かくて、ポカポカする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたは……どうだった……？　私のオマンコ、ちゃんと気持ちよかったの\nだろうか……？　なんだか、私ばかり夢中になっていたような……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「そ、そうか……ふふ、それなら、よかった……。あなたも一緒に、気持ちよ\nくなってくれたなら……その、嬉しい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「やはり、二人ですることだからな……。二人で一緒に気持ちよくなって、そ\nの、イきたかったんだ……い、いや、すまない……変なことを言った……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んひぁあっ！？　な、なんだ、急に……あひぃんっ！　どうして、オチンポ\nを……あぁんっ！　出したばっかりなのに、また、そんな……あぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「にゃ、にゃにをっ……か、可愛かった、などと……あ、あまり、私をからか\nうな……私など、そんな……あひぃいいいんっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっ、わ、わかった、信じる、信じるからぁっ！　ひぁあああんっ！　\nオチンポ、動かさないでぇっ！　あぁああんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「まだ、イったばかりだからっ、あひぁあんっ、オマンコ、ビンカンになって\nるからぁっ、あひぃいんっ！　そんなに激しく、しないでぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104204" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっ、あひぃいんっ！　オチンポ、また固くなってるっ！　ひぃいいんっ\n！　お尻っ、掴んじゃダメッ、んひぃいいっ！　手、離してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひっ、あひぃっ、オマンコ、精液でヌルヌルしてっ、あひぁああんっ、オ\nチンポ、いっぱい動いてるっ、あひぃいんっ！　さっきよりも激しいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっあっ、そこ、らめっ、ひぁああんっ！　入り口のとこ、ゴリゴリぃ\nっ！　弱いとこばっかり、亀頭で引っかくの、らめぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あぉおおおんっ！？　おくっ、子宮口のとこ、どちゅどちゅっ！　突いちゃ\nらめっ、そこも弱いのっ、んひぃいいっ、グリグリするも、らめぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃいいんっ！　オチンポ、つよすぎるっ、んひぃいいっ！　オマンコの\n弱点ばっかり、イジメないでっ、頭、変になっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「オチンポで、堕ちちゃうっ！　あひぃいいんっ！　あなたにオマンコしても\nらわないと、生きられないカラダになっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ひあぁっ、あへぇえっ！　らめぇっ、オチンポ、キモチイイっ！　もうナニ\nも考えられないっ、頭のナカ、キモチイイので、いっぱいになっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「好きっ、好きぃっ、大好きぃっ！　あはぁああんっ！　あなたが、好きなの\nっ、あぁんっ、あひっ、あひぃんっ！　愛してるのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっ、あなたは……？　あひぁあんっ！　私のこと、好き？　あぁあん\nっ、お願いっ、好きって言ってっ、愛してるって、言ってぇっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104213" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、あっあっ、あぁんっ、ごめん、なさいっ、重い女で、ごめんなさい\nっ！　でも、好きなのぉっ、もうあなた無しでは、生きられないのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ぜんぶ、あなたと一緒がいいのっ、ひとりはもうイヤなのっ、あなたと一緒\nに、いっぱいキモチよくなりたいのぉっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっあっ、オチンポ、また太くなってきたっ！　あひぁあんっ！　オ\nマンコのナカ、いっぱいになってるぅっ！　ごりゅごりゅ、擦れてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104216" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あへぇええっ！　奥も、どちゅどちゅっ！　カチカチの亀頭が、当たってる\nっ！　あひぃいいんっ！　オチンポしゅごいっ、オマンコ、キモチイイっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっ、またクる、キちゃうっ！　あひぃいっ！　すごいのキちゃうっ、\nおかしくなっちゃうぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「また、いっしょにっ、あひぃいんっ！　オチンポ、イッてっ、あぁんっ、私\nのオマンコで、気持ちよくなってっ、精液いっぱい出してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃいっ！　もうイく、クる、オマンコ、イッちゃうぅっ！　オチンポ、\nいっしょにっ、精液出してぇっ！　ザーメンいっぱい、射精してぇっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あへぇえええっ！　でてりゅっ、オマンコに、せーえきっ！　どびゅどぴゅ\n、しゃせーしてるぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んひぃいいっ！　せーえき、あちゅいっ！　おくのとこ、いっぱいかかって\nるぅっ！　あひぃいっ！　オマンコ、やけちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、まだ、でてるぅっ……！　んひぃいっ！　せーえき、多すぎる\nぅっ！　オマンコいっぱいで、もう、入らないぃっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃっ！？　あひっ、あひっ、子宮口から、入ってきてちゃうっ……！　\nあへぇええっ……！　子宮のナカまで、せーえきでパンパンになっちゃぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっあっ、らめっ、またイくっ、子宮にナカ出しされながら、イくっ、赤ち\nゃんっ、受精しながら、イくぅうううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あへぇぇっ……オチンポ、しゅごいぃっ……ちゅよすぎるぅっ……わたしの\n、あたま、おかしくなっちゃったぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……くうぅぅ、ハメを外しすぎて、変なことを言って\nしまったような……うぅ、お願いだ、引かないでくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104307" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「も、もちろん、言ったことは、全部本当だ……私は、あなたが好きだし……\n心の底から、愛している！　ずっとあなたと、一緒にいたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「こ、こんな私でも、受け入れてくれるのか……？　嬉しい……ありがとう…\n…。あなたがいてくれれば、私はそれだけで、幸せだから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……お腹のナカ、あなたの精液でたぷたぷだな……。ふふ、本当に赤ち\nゃんが出来ているかもしれないぞ？　だが……それも、悪くはないな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},


		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あひぃぃいんっ！？　オチンポ、抜けてっ……ひあぁああっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_14" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あっ、あぁっ、あっ……！　精液、かかってるぅ……！　んひぁあっ、オチ\nンポからどぴゅどぴゅっ、ザーメンシャワー、いっぱい出てるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104402" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ、あっ、あぁっ……身体中、精液まみれになってしまう……！　あな\nたのエッチなニオイが染み付いて、とれなくなってしまいそうだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ、まだ、出るのか……？　いいぞ……もっといっぱい、私に精液をかけ\nてくれ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00000111_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あなたのニオイで、私にマーキングをしてくれ……あんっ、私があなたのモ\nノだという、シルシをいっぱい、つけてくれ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「んっ……はぁ、はぁ……終わり、か……？　あぁ、すごい……こんなに、出\nしてくれたのか……あぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「私の身体中に、あなたの精液が降り掛かって……んっ、ふぅっ……ドロドロ\nになっているぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「すん、すん……はぁぁ……あなたの、精液のニオイ……すごく破廉恥なのに\n……でも、なんだか、落ち着く……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「あんっ……ふふっ、あなたのオチンポはまだまだ元気そうだな？　私のオマ\nンコに、固いのが当たっているぞ……。まだ、出し足りないのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_1104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ん……いいぞ……もっと、シてくれ……私のオマンコを使って、たくさん気\n持ちよくなって……私の中も外も、あなたの精液で、染め上げてくれ……」", "NORMAL" ]},
