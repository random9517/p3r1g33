		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「我らの前に、道を開け……！　時間城に通じる、時空の門を……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "翔生子が呪文を唱えると、閉じかけていたワームホールが再び大きく開き始め\nる。そして――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンローダー" ]},
		{"command":[ "SETTEXT", "「この向こうに見えるのが、もしかして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_010114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00002801_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "翔生子" ]},
		{"command":[ "SETTEXT", "「はい。時間城です！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_011_010114460002" ]},
		{"command":[ "SETCHARA", "0", "char_00001102_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ゲンナイ" ]},
		{"command":[ "SETTEXT", "「なんだか、不気味なところだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_098_010114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00009801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ウタマロ" ]},
		{"command":[ "SETTEXT", "「だけど、ここまで来たんだ！　ビビってねえで乗り込もうぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_097_010114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00009701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｈ・Ｍサムライ" ]},
		{"command":[ "SETTEXT", "「うむ！　拙者は元よりそのつもりだ。すなわちレッツラゴン！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_145_020114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00014502_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ハルノブ" ]},
		{"command":[ "SETTEXT", "「隊長さん、どうされるのです？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_110114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000511_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そりゃ、決まってんだろ？　こうなったら行くしかねえよ。みんな！　ワー\nムホールに飛び込めーっ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "と、いうわけで俺たちは時間城を目指して、ワームホールに飛び込んだ。一方\n、そのころルナテミスたちは……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_003" ]},
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いやぁ～！　危ないところだった！　とりあえず礼を言っておくぞ、アルフ\nィルクとシャム」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「フィルでいいよ。それから、礼もいらない。アタシらも、時間帝国は気に入\nらないんでね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「そもそも、本当に危ないのはこれから。たった二隻の海賊船で、前方の大艦\n隊に突っ込んで、時間城に乗り込む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00013601_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "フィル" ]},
		{"command":[ "SETTEXT", "「ああ。だけど、それでこそ海賊の戦いってもんだよ！　ふふふっ、ゾクゾク\nしてきたぜ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114460002" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「ひさしぶりに、海賊らしい仕事……！　血が騒ぐ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010114460002" ]},
		{"command":[ "SETCHARA", "0", "char_00013601_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「我々も、できることならなんでも手伝わせてもらう！　ともに時間帝国と戦\nおう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ベルガマスク" ]},
		{"command":[ "SETTEXT", "「うむ、決まったな！　我の旗の下で、我とともに戦え！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_020114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000702_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "海賊たち" ]},
		{"command":[ "SETTEXT", "「あんたのじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_129_010114460003" ]},
		{"command":[ "SETCHARA", "0", "char_00012901_01", "7", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00013601_01", "7", "CENTER", "400" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
