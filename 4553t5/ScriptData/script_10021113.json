		{"command":[ "DISPCHARA", "1", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "bg_0177" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_005" ]},
		{"command":[ "SETTEXT", "そして、カツマやルナテミスたちが向かっている時間城では――", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「刻の女王陛下。地球人たちは定刻通り、ゲートを通過いたしました」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_100114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000310_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａセレーナ" ]},
		{"command":[ "SETTEXT", "「予定通りの時間に、この時空に到着するものと思われます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_080114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000408_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「すべては、女王陛下の進行表通りに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「うむ。ご苦労」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジェスタ" ]},
		{"command":[ "SETTEXT", "「女王陛下～？　あいつらなかなか、面白い連中ですよー？　陛下にもきっと\n、お気に召していただけると思いますけど～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_231_010114460001" ]},
		{"command":[ "SETCHARA", "0", "char_00023101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そうかそうか……ふふふふ……早くモニターごしではなく、実際に会ってみ\nたいものだな。地球よりの女幹部たちに。そして……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_010114460002" ]},
		{"command":[ "SETCHARA", "0", "char_00020101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

