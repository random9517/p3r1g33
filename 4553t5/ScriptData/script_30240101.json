{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「私のエッチな体験談を聞きたいだなんて……あなた、頭大丈夫？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103101" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「別に人の性癖にどうこう言う趣味はないけど、さすがにドン引きよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「私みたいな素敵なレディの体験談だから、聞く価値があるですって？　フフ\nッ。そう言われると、悪い気はしないわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103103" ]},
		{"command":[ "SETCHARA", "0", "char_00002401_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「まあ、あなたとは知らない仲じゃないし、少しだけなら聞かせてあげる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「その代わり、バッケンローダーの情報を掴んだらすぐに報告すること。それ\nが条件よ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「パイズリして欲しいだなんて……少しはレディの扱いってものを憶えたらど\nうなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00002401_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「私だからお願いしてるって……そんなこと言われても、嬉しくないわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「まあ、あなたのオチンポが相手なら、悪い気もしないけど……い、いえ！　\nなんでもないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「と、とにかく！　これはあくまでもバッケンローダーを倒すため……！　私\nを強くするための手段にすぎないから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「別にあなたのことが好きとか、そういうことじゃないってこと、ちゃんと理\n解しておきなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103110" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「まったく……こんなに大きくして……！　んっ、くっ……あっ、ふあぁ……\nあっ、あんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103111" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「なによ、そのだらしない顔……私のおっぱいがそんなに気持ちいいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「胸に挟んで、軽く擦ってるだけなのに……ほら。気持ちいいなら、気持ちい\nいって言いなさいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「フフッ。必死に首を縦に振りながら、オチンポビクビクさせるなんて……随\n分と素直じゃない」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「気分がいいから、もっと強く挟んであげる。こうして、胸を寄せて……んっ\n、くっ……ふああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「オチンポのデコボコしたところが、おっぱいに絡んでる……！　はぁ、ああ\nっ……すごく熱いわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「先端から、じゅわって……お汁が出てきてる……すごくいやらしい香りがす\nるわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「そんな我慢したような顔して、どうしたの？　えっ……？　オチンポの先端\nに息が当たるのが気持ちいい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「へぇ～、そうなんだ～。おっぱいでスリスリされながら、息をふーってされ\nるの、たまらないんだ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「なら、もっとシコシコしながら、息を吹きかけてあげるわ……んっ、はあぁ\n……ふぅ～……ふぅ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あははっ！　おっぱいの中で、オチンポが飛び跳ねてるわよ！　必死に動き\n回って、可愛いわね！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「どれだけ暴れてもムダよ。私のおっぱいに挟まれてる限り、逃げ場なんてな\nいんだから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「観念して、もっとシコシコされなさい……！　ふっ、あふっ……んっ、くっ\n……はぁ、はああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ふふっ。可愛い声出しちゃって……年下の女の子のおっぱいにオチンポ挟ま\nれて、好き勝手される気分はどうかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「こうやって、ぎゅっぎゅって挟まれながら、動かされるのがいいんでしょ？\n　ちゃんと言ってみなさいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「むっ……今度は随分と強情ね。いいわ……そっちがその気なら、私も容赦し\nないから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103126" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「もっと激しくおっぱいでオチンポを挟んで……さっきよりも強く息を吹きか\nければ……ふーっ、ふーっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103127" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ほらっ、エッチなお汁がどんどん溢れてきてるわよ。この状態で思いっきり\nシコシコしたら、どうなると思う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ダーメ。今更素直になっても、許してあげないんだから。私のパイズリで、\n情けなく射精しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んっ、ふぐっ……あっ、あふっ！　くっ、はああぁ……！　ほらほらっ！　\nあなたのエッチなお汁のせいで、滑りがよくなってるわよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「くちゅくちゅってエッチな音がして……いやらしいニオイも濃くなってる…\n…！　ぜーんぶ、あなたのせいなんだから……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ふふっ。オチンポのビクビクが強くなったわね。もしかして、イッちゃいそ\nうなの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「射精させてくださいって言いなさい！　そうしたら、射精させてあげる！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あははっ！　射精させてくださいって、言っちゃったわね！　いいわよ！　\n約束だし、思いっきりザーメン出しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「オチンポに溜め込んだ汚いザーメン……ぜーーーんぶ、私のおっぱいに出し\nて……ああああぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　おっぱいに出してって言ったのに、どうして顔に……！\n？　あぶっ、んっ！　うくぅぅぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_04" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「やっ、あっ、んんんっ！　熱いセーエキが、口について……はぁ、ああっ！\n　ダメ……！　こんなの浴びたら、変になっちゃうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「早く射精を止めて……きゃああぁっ！？　ま、まだ出るのっ！？　どれだけ\n溜め込んでるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あなた、少しは遠慮ってものを……あっ、んぶっ！　ふぐっ、あっ、んくっ\n、あふぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んんっ！　はぁ、あはああぁ……！　もっ、もうやめ……ああっ！　はぁ、\nあっ、んあああぁ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……んっ、はああぁ……私の言うことを無視するなんて、いい\n度胸してるわね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103201" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「私の声を聞いてたら、胸じゃなくて顔にかけたくなった……？　そ、そんな\n言い訳聞きたくないわ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「で、でも……私のことを意識してくれてるっていうのは、ちょっと嬉しいわ\nね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103203" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「な、なんでもないわよ！　とにかく、あなたは私の命令を無視したんだから\n、罰を受けてもらうんだから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103204" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「罰は……そうね。男の人は、射精した直後にオチンポ擦られるとつらいみた\nいだし、パイズリの刑にしてあげる。嬉しいでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103205" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ふふっ。セーエキ出したばっかりのオチンポを、もう一回シコシコされる気\n分はどう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「そのつらそうなお顔……痛いけど気持ちいいって感じね。なら、もっと激し\nくしてあげるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んっ、しょ……あっ、うくっ……！　んっ、ふっ、ふっ……！　はぁ、ああ\nっ……！　私のおっぱい、あなたのエッチなお汁でベトベトになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「セーエキも口元やおっぱいにべったり付いてるし……私の全てが、あなたに\n染められたみたいだわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「それに、こうやってオチンポをシコシコしてると、なんだか奉仕してるみた\nい……いたいけな女の子にこんなことさせて、悪い大人ね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あら？　オチンポがどんどん大きくなってるわよ。私の言葉で興奮しちゃっ\nたのかしら？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あなたは、こうやってオチンポをグリグリ、シコシコされながら、言葉責め\nされるのが大好きなヘンタイなんだー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あははっ！　言葉で否定しても、身体は正直みたいね。だって、さっきから\nオチンポがもっと擦ってー、いっぱい挟んでーって、訴えて来てるもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「すっごくビクビクして、おっぱいの中で脈打ってる……罰って言ったのに、\n随分と嬉しそうね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ、んくっ……！　はぁ、あっ……！　あなたの弱点はもうわかってるの\n。こうやって、デコボコのところを思い切りシコシコすれば……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ほら、すぐにエッチなお汁がびゅくびゅく出て来るわ。ここを刺激されると\n、おかしくなるぐらい気持ちいいんでしょ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「えっ……ちょ、ちょっと……！　なにさっきみたいに、オチンポビクビクさ\nせてるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103217" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「もう我慢できないって……！　だ、ダメよ！　もう少し我慢してっ！　まだ\n射精しないでっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ、やっ……！　おっぱいで抑えつけられなくなるぐらい、オチンポが谷\n間で暴れてるっ……！　んっ、ああっ、あふっ、うくぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103219" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んんっ、あっ、あぐっ……！　やっ、あっ！　くるっ……！　セーエキがす\nぐそこまで来てるっ……！　あっあっあっ……あああっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「きゃああぁ！？　ま、また顔に向かってザーメン出すなんてっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あぶっ！　んっ、あふっ……ああっ、クサくて熱いのが、また口元に……ん\nっ、じゅるっ……！　やっ、少し口の中に入ってきてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んっ、ちゅぷ……！　な、なによこの味……！　ニガいのに、クセになるみ\nたいな……ああっ、んっ、はああぁ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103303" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ニオイと味を、身体が覚えちゃうっ……！　やっ、あんっ……！　こんなの\n味わわされたら、イッちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あぁっ、はぁ、んっ、あっ……！　あっ、ふぅ……イッ、イクッ……！　イ\nッ、くううぅぅぅん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……んっ、あっ……あふぅぅ……セーエキを浴びながらイクなん\nて、はじめての経験だわ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103306" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「なによ、その満足そうな顔は……えっ？　私もイッてくれて、嬉しい……？\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ば、バカなこと言わないで！　私は別にあなたにイカされたわけじゃないわ\nっ！　これはただ……き、気分がノッただけよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あなたのセーエキが気持ちよかったとか、そんなんじゃないから！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「その顔は信じてないわね！　だったら、あなたが理解するまで、何度でもパ\nイズリしてあげるわ！　覚悟しなさい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「んくううぅ……！　おっぱいに熱いのがかかってるっ……！　はぁ、ああっ\n、ダメっ……！　火傷しちゃうっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_13" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あっ、あっ！　オチンポからびゅるびゅる出てるの感じるっ……！　さっき\nあんなに出したのに、まだ出るの……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「くっ、あふっ……あっ、ふあっ、ああぁ……！　全然止まらない……！　私\nの身体、ザーメン塗れになっちゃう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「うぐっ、んっ、あふっ……！　こんなに出されたら、オマンコ感じちゃう…\n…！　セーエキの感覚でイッちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「ダメっ、ダメっ……！　あっ、んああぁ……！　我慢できないっ……！　イ\nクッ……イクッ！　んんんっ～～～～～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「はああぁ……まったく、出しすぎよ。レディーに対して、失礼と思わないの\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103406" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「私の身体を汚してると思うと興奮したって……そ、それが失礼だって言って\nるのよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「あなたはいいかも知れないけど、私はザーメンで汚されて、すっごく不快な\nんだからっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103408" ]},
		{"command":[ "SETIMAGE", "0", "still_00002401_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「イヤがってるような顔に見えないですって……？　こ、これはさっきイッた\nから、その余韻が残ってるだけよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "バッケンハンター" ]},
		{"command":[ "SETTEXT", "「なに笑ってるのよ！　まったく、本当にレディーに対して失礼な男だわっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_024_0103410" ]},
