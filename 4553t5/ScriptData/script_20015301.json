{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0190" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "行楽の秋。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "珍しく休みの取れた俺は、ジュンジローに誘われてとある秘湯を目指していた\n。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュンジロー、本当にこの道であってるのか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そのはずでございますが……。なにせ秘湯でございますから」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「本当にあるのかよ……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「リサーチは完璧でございます。広報アカウントもあるようですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470002" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "9", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちが向かっているのは、身体の疲れや心の病などに効果があるという温泉\nだ。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "秘湯と言われている割には、ＳＮＳの広報でその存在を大っぴらにアピールし\nている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ただし、実際に行くとなると、秘湯というだけあってアクセスがとんでもなく\n悪い。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちは数十分、いや、数時間は道なき道を歩くハメになっていた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「行けども行けども獣道……。せっかくの休日が、徒労に終わるなんてごめん\nだぞ……」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんとしてでも、秘湯を見つけて、ひとっ風呂浴びて帰らないと……いや、\nそこで何泊かしないと気が済まねえ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「その意気でございます。……っと、ご主人？　なにか聞こえませんか？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ん……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "耳を澄ますと、なにかの鳴き声が聞こえる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「クマでしょうか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470004" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「いや、クマではなさそうだが……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺は周りを警戒しながら鳴き声のする方へと向かう。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「これは……キツネですな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470005" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "野生のキツネが倒れていた。後ろ足にけがをしているようだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ちょっと待ってろよ。手当してやるから」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人は本当にやさしいですなぁ。人間だろうと獣だろうとメスなら見境な\nくやさしく接して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470006" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんか、人聞きの悪い言い方だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "そうこうしている間に手当を済ませる。キツネはよろっと起き上がると、俺の\nことをじっと見つめた。すると……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「人間～っ！　助けてくれて感謝するぞ～っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「どわぁ！？　なんだ、キツネが女の子に！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「立ち絵がないのが惜しいくらいの爆乳美少女ですなぁ。浴衣から乳がまろび\nでそうになってますぞ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470007" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「我が名はヤコ！　この先の九十九尾温泉で働いているのだ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「九十九尾温泉……って、俺たちが向かってる秘湯じゃないか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「そうなのか？　ならばちょうどよい。助けてくれたお礼に我が案内してやろ\n……うぉっ、おおっ、ひゃぁあっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺たちを案内しようとしたヤコが、一歩踏み出した途端にバランスを崩して転\nんでしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "その拍子に、姿もキツネに戻ってしまう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「うぅ……人間の姿というのは、どうもバランスがとりにくいのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それは人間のときのスタイルに問題があるんじゃないか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「あれほど立派なものをお持ちでは、歩くのも大変でしょう」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470008" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「さっきも木の根につまずいて転んだのだ……。足元が見えないのに平気で歩\nくなんて、人間には乳の下にも目がついているのだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470005" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そんなわけないだろうが。それより、はやく案内してくれよ。歩きにくいの\nなら抱えてやるからさ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「ぐぬぬぅ……世話になるのだぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470006" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "俺はヤコを抱え、ナビをしてもらいながら秘湯へと向かった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "しばらく歩くと、本当に温泉宿に着いた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0046" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「おお……老舗って感じだな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "古びた外観が森に溶け込んでいるようにも見えて、これぞ秘湯という雰囲気を\n強く感じる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "が……あれ？　ちゃんと駐車場はあるし、なんならそこは満車になってるぞ。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ジュンジロー……もしかして、あんな山道をとおらなくてもここにたどり着\nけたんじゃないか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「そ、そうかもしれませんなぁ……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "5", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「お前ぇ！　お前のせいでいらない苦労をする羽目になったじゃないか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「たどり着いたのですからよいではありませんか。それに、ヤコどのとの出会\nいもありましたし」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「そうなのだ。人間が見つけてくれなかったら、我はどうなっていたか……。\n本当に感謝しているのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470007" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ……そうか。どういたしまして」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0059" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "とりあえず宿の中に足を踏み入れる。駐車場の状況からそうぞうできたが、従\n業員たちが慌ただしく動き回っていた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「んぁ？　ヤコ、おかえり～……って、あんた、キツネの格好やないの」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「しかもケガしとるし……もしかして、その方に助けてもらったん？」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "3", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「そうなのだ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470008" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あらあらあら～、どうもおおきに～」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "カウンターの奥に座り、スマホを操作していた女将がやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ふんわりした雰囲気の美女だが、頭にはキツネの耳。おまけにモフモフの尻尾\nまでついている。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まさかとは思うが……人間じゃないな？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ん～、まあねぇ。こんこん♪　おキツネ様やよ～♪」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "9", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ヤコ殿が働いているからもしやと思いましたが、女将さんもキツネ美女なの\nですなぁ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "-400" ]},
		{"command":[ "SETCHARA", "1", "char_00027201_01", "8", "CENTER", "400" ]},
		{"command":[ "SPOTCHARA", "0" ] },
		{"command":[ "PLAYVOICE", "v2_009_020023470011" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あらあら、お利口なワンちゃんやねぇ。ありがと。……っと、立ち話もなん\nやし、宿の奥にどうぞ」", "NORMAL" ]},
		{"command":[ "SPOTCHARA", "1" ] },
		{"command":[ "PLAYVOICE", "v2_272_010023470005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0059" ] },
        {"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "SETTEXT", "女将に案内され、従業員の控室へやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「自己紹介せなね。うちはサクヤ。この九十九尾温泉で女将やらせてもろてま\nす」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "PLAYVOICE", "v2_272_010023470006" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺はカツマだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「カツマはん……なんだか日々上司からのパワハラや仕事の無理難題に胃をキ\nリキリ痛めていそうな名前やねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470007" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「うぐ……だいたいあってる……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ヤコがお世話になりました。このコったら、また見栄張っておっぱいの大き\nい姿に変化してたんやろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470008" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「まったくもう。おっぱいは大きすぎても仕事に支障がでるだけさかい、ほど\nほどにって言ってるんやけどねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470009" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「でも、この人間たちは我のおっぱいでよろこんでくれたぞ！　おっぱいはで\nかいほうがいいのだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「あんたはそれより手ぇの変化の練習しぃ。また袖の長い着物で手ぇ隠して、\nごまかしとるやろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470010" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「ぐぬぬぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それにしても、秘湯って聞いていたけど随分と繁盛しているんだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「それなぁ。最近えすえぬえすってのをはじめてみたんよ。そこでぴーあーる\nしたら、ウケてしもて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470011" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「急に忙しくなってもうて、みんなてんてこまいなんよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470012" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「そんな中、女将は呑気にぽちぽちしてるのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「これも女将の大事なしごとやからね。ああ、ヤコを助けてくれたのに、おも\nてなしできなくて。すみまへん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470013" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「従業員とか募集しないのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「したいところやけど、うちの温泉にくるのは人間だけやないからねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470014" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……そういうことか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "キツネの女将がいるのだ。ここを利用している客層については、容易に想像が\nできた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「女将、カツマを雇ってみたらどうなのだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470012" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「我らに対して驚かないカツマなら、きっと仕事を任せられると思うのだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470013" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「なに言ってますの、カツマはんはお客さんやないの。温泉、はいりにきたん\nやろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470015" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、そうなんだが……。人手が足りないっていうなら、手伝うよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ああ、またご主人は首をつっこんで……。どうなってもしりませんぞ」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023470012" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「うふふ、おおきに♪　それじゃあ、お手伝いよろしゅう」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023470016" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "こうして俺は、この温泉で働くことになった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "……あれ？　そういえば俺って休暇のはずだよな？　どうしてこんなことに！\n？", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「なにキツネにつままれたような顔してるのだ？　我が仕事を教えてやるのだ\n！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023470014" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}