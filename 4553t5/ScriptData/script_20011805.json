		{"command":[ "PLAYBGM", "BGM_003" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "変身後のマスク・ザ・ブルーの戦闘力は凄まじく、クノイチたちを圧倒する。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「…………思ったより、手応えがありませんね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ" ]},
		{"command":[ "SETTEXT", "「う～、さすが戦隊初の『リーダーを追い出し、自分が成り代わった下剋上リ\nーダー』……出来るでござるっす……ニンニン……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_020021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「一旦引くでござるよ……ニンともカンとも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_020021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00015402_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＢ" ]},
		{"command":[ "SETTEXT", "「憶えてなさい……でござるわ。いずれ、必ず関節という関節を破壊してごら\nんにいれます……でござるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_149_020021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00014902_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＣ" ]},
		{"command":[ "SETTEXT", "「……無理やりござるござる言わなくていいんじゃないでござるか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_150_020021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00015002_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＤ" ]},
		{"command":[ "SETTEXT", "「でもぉ……そういう契約でしょ？　言わないとダメなんじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_151_020021550003" ]},
		{"command":[ "SETCHARA", "0", "char_00015102_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ" ]},
		{"command":[ "SETTEXT", "「……そういうあなた、全然言えてないじゃないでござるわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_020021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00015202_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＧ" ]},
		{"command":[ "SETTEXT", "「はいはい、そろそろ戻りましょ……それでは――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_154_020021550005" ]},
		{"command":[ "SETCHARA", "0", "char_00015402_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＡ～Ｄ" ]},
		{"command":[ "SETTEXT", "「しからば御免！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_148_020021550005" ]},
		{"command":[ "DISPCHARA", "1", "TRUE" ]},
		{"command":[ "DISPCHARA", "2", "TRUE" ]},
		{"command":[ "DISPCHARA", "3", "TRUE" ]},
		{"command":[ "SETCHARA", "0", "char_00014802_01", "4", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00014902_01", "4", "CENTER", "-200" ]},
		{"command":[ "SETCHARA", "2", "char_00015002_01", "4", "CENTER", "200" ]},
		{"command":[ "SETCHARA", "3", "char_00015102_01", "4", "CENTER", "600" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "クノイチＥ～Ｇ" ]},
		{"command":[ "SETTEXT", "「御達者で！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_152_020021550005" ]},
		{"command":[ "SETCHARA", "0", "char_00015202_01", "4", "CENTER", "-600" ]},
		{"command":[ "SETCHARA", "1", "char_00015302_01", "4", "CENTER", "0" ]},
		{"command":[ "SETCHARA", "2", "char_00015402_01", "4", "CENTER", "600" ]},
		{"command":[ "DISPCHARA", "3", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "妙にカタカナが多い一人が、けむり玉を叩きつけると、全員そそくさと走って\n逃げていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPCHARA", "1", "FALSE" ]},
		{"command":[ "DISPCHARA", "2", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「くぅ……逃しません！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_010021550004" ]},
		{"command":[ "SETCHARA", "0", "char_00005001_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「待て。深追いは危険だぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ｍ・ザ・ブルー" ]},
		{"command":[ "SETTEXT", "「待ちなさい！　よくも下剋上リーダーなどと…………取り消しなさい！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_050_020021550019" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "マスク・ザ・ブルーはそのまま逃げたクノイチたちを追いかけていく。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……冷静なヤツだと思ってたんだがな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「人間臭くていいじゃないか。ふふふ、それで、頭脳担当の我々はどう行動す\nべきだと思う？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550009" ]},
		{"command":[ "SETCHARA", "0", "char_00007901_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「頭脳担当なら、何か案を出せよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "鳳雛" ]},
		{"command":[ "SETTEXT", "「このままどこかに飲みにいくのはどうかな？　冷徹鋭利な頭脳のために、適\n度なアルコールは不可欠だからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_079_010021550010" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「採用」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「ご主人さま……私は止めませんぞ？　ただ司令に事実をありのまま、堂々と\n告げ口するのみです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_010021550008" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「クソ犬め……仕方ない、追うぞ――」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}