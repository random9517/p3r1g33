		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「充血した亀頭が、トロトロの先走り汁で濡れてしまっている……。母の谷間\nが、どんどんヌルヌルになっていく……」", "NORMAL" ]},
