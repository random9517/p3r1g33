		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「まずはこのチンポを、母の胸で包んでやろう。……ンッ♪　さっそくガチガ\nチのチンポが谷間に入ってきた……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403105" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母のおっぱい……気持ちいいか……？　さっそく腰が、小刻みに動いてしま\nっているな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403106" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああ……お前の熱いチンポが、おっぱいにこすりつけられているのを感じる\n……。もっと……気持ちよくしてやろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403107" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「こうやって……リボンを、ぎゅっと……。どうだ？　締めつけが強くなった\nだろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403108" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ンッ♪　お前のチンポも悦んでいるようだな。おっぱいの間で、ビクビクと\n暴れている……はぁ、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403109" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「母も、よりお前のチンポを感じられて、興奮してしまう……。さあ、リボン\nをおさえているから、お前は好きに、母のおっぱいを使うがいい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403110" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んぁっ♪　ま、まずはおっぱいを、愛撫してくれるのか……。はぁ、はぁ、\nいいぞ……とても、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403111" ]},
		{"command":[ "SETIMAGE", "0", "still_00020104_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「息子に、おっぱいをもみしだかれて……あんっ、胸の奥が……ジンジンと、\n疼いてきてしまう……ンッ、あぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403112" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「そう、動かして、いいぞ……。んっ、おっぱいを、動かして……ああ、お前\nのチンポをしごくのに、使ってくれ……」", "NORMAL" ]},
