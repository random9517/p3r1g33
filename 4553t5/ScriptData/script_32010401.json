		{"command":[ "SETIMAGE", "0", "still_00020104_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「いいぞ。今宵はクリスマス。それにふたりっきりなのだから。母のおっぱい\nに存分に甘えるがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403117" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「もっと強くリボンで締めつけて欲しいのか？　いいだろう。……んっ、こう\nだろうか？」", "NORMAL" ]},
