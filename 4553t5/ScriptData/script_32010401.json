		{"command":[ "SETIMAGE", "0", "still_00020104_01_04" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「あぁっ、今度はおっぱいへの愛撫だけでなく、腰を動かして……んっ、チン\nポでも母のおっぱいを、責めてくるのか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403119" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
