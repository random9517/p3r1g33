		{"command":[ "SETIMAGE", "0", "still_00020104_01_03" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「お前が、とても興奮しているということが伝わってきて……。ンッ、母は…\n…嬉しくて濡れてしまうぞ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403121" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、そうだ。母だって興奮しているのだ。乳首なんか、お前のチンポに\n負けないくらい勃起してしまっているだろう？」", "NORMAL" ]},
