		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ああっ、ますます腰の動きが激しくなったな……。チンポもより、硬くなっ\nてきたようだ……」", "NORMAL" ]},
