		{"command":[ "SETIMAGE", "0", "still_00020104_01_01" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「どんどんお前のチンポの匂いが強くなっているのだ……。これを嗅いで、欲\n情しない親などいないだろう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403123" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「ふふっ、どうやら発情している母の顔と、この胸の感触が、お前のオカズに\nなっているようだな……」", "NORMAL" ]},
