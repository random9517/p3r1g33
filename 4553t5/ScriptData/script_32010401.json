		{"command":[ "SETIMAGE", "0", "still_00020104_01_02" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「んんっ、はぁ、んふぅ……♪　硬くて、太く……たくましいチンポ……肌に\nこすれて……感じて、しまう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403114" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「息子のぬくもりを感じて……ああ、おっぱいだけでなく、全身が熱くなって\nきているぞ……はぁ……んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_201_0403115" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "刻の女王" ]},
		{"command":[ "SETTEXT", "「どんどん、おっぱいへの愛撫が、激しくなって……。あんっ、お前は本当に\n、母のおっぱいが好きなのだな♪」", "NORMAL" ]},
