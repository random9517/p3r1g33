		{"command":[ "SETIMAGE", "0", "still_00004001_02_12" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あはぁ、ピコさまのオマンコが気持ちよすぎてぇ、隊長ちゃんのヘンタイお\nちんちん、壊れちゃったみたい？　はぁ、はふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ほら、遠慮しないでぇ、もっと出しちゃえ。腰、揺さぶってぇ……イッてる\nおちんちん、まだまだこすってあげるからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104305" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あははっ、気持ちよすぎて悶えてる隊長ちゃん、凄く素敵な顔……見てるだ\nけで、ピコさまもまたイッちゃいそぉ……はふぅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ふふふっ、ピコさまのオマンコに屈服して、ビクビク震えっぱなしのおちん\nちん、本当、カワイイ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「最強魔女王候補のピコさまに勝てなくても、当然だし。別に恥ずかしくない\nから、そんなに顔、真っ赤にしなくてもいいのに～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「それともぉ……もっともっと気持ちよくなりたくて、そんな目でピコさまを\n見てるの？　ふふふっ、隊長ちゃん、本当にヘンターイ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「いいよ……このままもっともっと、ピコさまのお腹が精液でふくらんじゃう\nくらい、ビュービューしちゃえ……あはぁっ」", "NORMAL" ]},
