		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「逃げたければ、ピコさまをはね飛ばしてもいいんだよ？　ほらほら、この小\nさいお尻をどかしてぇ、逃げちゃえば？」", "NORMAL" ]},
