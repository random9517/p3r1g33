		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ピコさまの子宮ぅ、隊長ちゃんの精液でいっぱいにっ、はひぃっ、あはぁ、\nいっぱいになってイク……イクぅぅっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「凄いっ、んふっ、まだまだびゅーって出てぇ、精液、止まらなくなっちゃっ\nてるぅっ、はぁ、はひぃい……」", "NORMAL" ]},
