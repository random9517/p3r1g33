		{"command":[ "LABEL", "LABEL1" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「んふううううっ、あはぁ、凄い、また中ぁ、オマンコの奥にぃ、熱いお汁ぅ\n、精液びゅーびゅーきてるぅううっ！」", "NORMAL" ]},
