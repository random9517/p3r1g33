		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「くふぁあっ、はぁはぁ、もう限界でしょ？　ほら、出してぇ、ピコさまに精\n液を捧げなさいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あはっ、カワイイ魔女のオマンコでぇ、精液全部搾り取られて、おかしくな\nっちゃえぇ、くぅっ、はんんぅっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「オマンコでも、外でもぉ、隊長ちゃんの好きなところに全部出してぇ、精液\n出してぇ、はひぃっ、くふぁあああっ！！」", "NORMAL" ]},
