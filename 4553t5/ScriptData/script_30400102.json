		{"command":[ "LABEL", "LABEL2" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ひゃうっ、あはぁ、おちんちん、抜けて……んんんっ！　ピコさまの身体に\n熱いのかかってぇ……はふううっ！」", "NORMAL" ]},
