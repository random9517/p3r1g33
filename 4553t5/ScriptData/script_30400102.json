		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「責任取って、もっとピコさまにいじめられて、もっともっと気持ちよくなっ\nちゃえ。ふふふっ、ふふふっ」", "NORMAL" ]},
