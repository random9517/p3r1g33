		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「顔にまで、臭い精液ぃ、いっぱいきて……んふっ、はぁ、隊長ちゃんの臭い\nで染められりゅっ、イク……くううううっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「ドロドロお汁ぅっ、おちんちん汁でべとべとにぃ……あはぁ……カワイイ、\nピコさまを精液塗れにするとかぁ、隊長ちゃん、ドヘンターイ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あふぅ、んぅ……精液塗れのピコさまを見て、おちんちん、また硬くしてる\nとか、本当……ヘンタイすぎぃ……はふぅ……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_02_15" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「んぅっ、ダメぇ……この鼻にツンってくる臭い……隊長ちゃんの精液の臭い\n嗅いでると、ピコさまも子宮疼いて、止まらなくなっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104405" ]},
		{"command":[ "SETIMAGE", "0", "still_00004001_02_14" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「もっともっと、隊長ちゃんが気持ちよすぎて泣いちゃうくらい、いっぱいオ\nマンコでいじめたくなっちゃう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_040_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ピコ" ]},
		{"command":[ "SETTEXT", "「あは……ダメ、逃がさないから！　だってぇ、ピコさまの身体をドロドロに\n染めて、こんな気持ちにさせたの隊長ちゃんだしー」", "NORMAL" ]},
