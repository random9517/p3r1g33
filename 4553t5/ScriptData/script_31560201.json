{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0004" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あ、こんなとこにいたのかい？　隊長……。今日は私がコンビニの新作スイ\nーツをオゴってやるって約束だったじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203101" ]},
		{"command":[ "SETCHARA", "0", "char_00015602_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「何？　甘いモノばかり渡されても困る……？　も、もしかしてこの宇宙のオ\nトコってのは……スイーツはそんなに好きじゃあないのかい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ム……。じゃあ何かい。やっぱり……仕事の疲れにはスケベなコトの方がキ\nくってわけかい？　くっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「じゃ、じゃあさ……。この前やったみたいに私の胸を使ってパイズリ……す\nるかい？　べっ、別に私がシたいってことじゃなくて」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「隊長が喜んでる顔見せてくれるのはパイズリの時ばっかだなぁって思ってさ\n。イ、イヤならいいけど……って、わ！　ガッツくんじゃないよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「はぁああ……。や、やっぱりコレが一番イイんだね……。しょうがないヤツ\nだよ。いや、いいよ。どうせなら喜ばれる方が私もイイしさ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203106" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "SETIMAGE", "0", "still_00015602_01_01" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「使わせてやるよ。私の胸……。こっちじゃオッパイって言った方がいいんだ\nっけ？　このオッパイは、どうせおまえしか触らないしね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっ……。今日はどうするんだい……。オッパイを揉みながらチンポで疑似\nセックス……？　難しい言い回しはやめな、つまりズコズコだね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203108" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「胸を突き出して……。はぁっ♪　チンポを丁寧に挟んで……。……んぁっ…\n…！　ちょっと蒸れて湿ってるじゃないか、ピトピトするね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「少し汗をかいた？　ン……。ま、まぁ、そんなのはどうせ私の胸でぬぐえば\nいいんだし……。始めていいよ。お疲れパイズリ。……え？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203110" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「お仕事ゴクローさまの気持ちをこめた、感謝のパイズリのことだよ！　わ、\n私はヘンなこと言ったかい？　も、もういいから揉みな！　ほらっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっ……あっ♪　あぁっ……そう、そうだよ……あっ！　チ、チンポが外れ\nない、ように……外側から内側にむかってムニュムニュって……あっあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こらっ……イ、イヤらしい触り方するんじゃないよ！　ん？　いやらしいこ\nとをしてるんだから当然？　……そ、そういうものかねぇ……？　ンッ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203113" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっ、ザ、ザワザワする……！　胸の輪郭、指の腹でなぞられるとおかしな\n声が出そうになる……。も、もっと強く揉んでいいよっ……それに」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「チンッ……チンポを動かすのを忘れているよ。揉みながら……んぁっ！　チ\nンポで掘り進めるんだ、私のオッパイを……ズンズンってさ……あぁっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ンふぅっ……♪　んんっ……！　ンッ……ンン～～～♪　ああっ……そ、そ\nうだよ。乳首っ、つねられたりひっぱられたりするのも……イイよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「はぁっ……はぁっ、はぁっ……。クス……、おまえはホントに私のオッパイ\nが好きだね……？　んん？　下品なデカさでチンポにクるから？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ばっ……バカ、失礼なこと言ってんじゃない、よ……！　はぁっ、はぁ、ハ\nァっ……こんなことするために育てたわけじゃ……。……ンッ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203118" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こ、こら……！　話の途中で乳輪っ……刺激しないでおくれ……。ソコ、弱\nいんだ……知ってるくせに……。は、ァッ……♪　あぁっ、あっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ワザと乳首を触んないで、乳輪なぞってスリスリするの……それ、それ、ム\nズムズするよぉ……。あっ♪　あっ……あっ……んぁあっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「じ、焦らさずにガンガン来なよ……あぁ……！　うんっ……！　私も胸、揺\nらすからさ……ほら。どたぷんっ、たっぷんっ、たっぷんたっぷんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっ♪　ムチャクチャ揺れるだろ……？　こっちの宇宙のオトコは……っ、\nていうかおまえは、目で胸見ながら抜くのが好きだからねっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「わ、私も勉強したってことさ……！　あっ……はぁっ♪　はぁっ、はぁっ…\n…はぁああっ♪　身体くねらせて、媚びて誘って……ハハハッ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「なんでもするよ……♪　だってこいつは慰労ってヤツなんだからね……♪　\n毎日毎日ご苦労様♪　おまえのチンポは私が癒すって決めたんだよ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「一本まるごと独り占めぇ……するからにはっ♪　あン♪　こっちの宇宙のご\n奉仕ってやつを学んでおくにこしたこと♪　ないだろ♪　ねぇ？　ねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっは……♪　やめなよ、愛おしそうな目で見るの……♪　こっちまでキュ\nンってなっちまう……。いいんだよ、オッパイ自由にしていいんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203126" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「今この時だけは……。このデカパイに包みこまれて、何度だって射精してい\nいんだ……。おいでっ……ガンガン腰振って、あ♪　打ちつけてきなっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私がおまえを丸ごと受け止めてやるっ……！　んっふっ……♪　ンッ……！\n　んっ、んっ……！　ああ、乱暴してもへっちゃらだからねっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……フフ♪　アハハハ♪　だいぶ興奮してるみたいじゃあないか……♪　ン\nンンフフフ♪　チンポの反応で丸わかりなんだよ♪　太すぎだろ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっ、ふぅっ……ふ、ぅ♪　ふぅうっ……♪　荒々しい……っ、だけどそれ\nくらいマジになってくれてるのは……正直嬉しいよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっ……♪　ぁっあっ、あぁっ、ンっ……！　ふぁっ……♪　あっあっ……\n！　腰振るの上手いね……！　んっ、見惚れちまう……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ハハッ……♪　チンポがブルブル震えてるじゃないか……♪　んっ……気持\nちいい？　気持ちいいんだね……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「いい、よ……まずは一回、サクッと出しちゃいな……。んっ……！　大丈夫\n……射精の勢いは、この前隊長が教えてくれてるし……。あぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「覚悟♪　出来てるから……ビュービューしな♪　はぁっ、はぁ、はぁっ、私\nも……私も欲しいしさ……。そらっ、出すのはここの膨らみだよっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私のお乳の山……っ♪　このあったかいトコロにぴゅっぴゅっぴゅってする\nんだよ♪　いいね？　ほら……ほら、ほら……出して♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んむっ……！？　ンン……ああっ、私の胸めがけて……！　元気な汁がびゅ\nるびゅる飛び出してくる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「わひゃっ……あっ！　あっ、あっ！　い、いつ見ても恐ろしいくらいの射精\nだね……ッ！　あっ！　オッパイ！　オッパイぶち抜かれるよっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「うん……うんっ、谷間に精液の湖が出来るまで出しておくれ……！　あぁ…\n…♪　とれたての隊長の精液……、せいえき、精子……プリプリだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んっんっ……ンン…ん～～～～～♪　この、むせかえるようなすえたニオイ\n……♪　かなり溜めこんでいたんじゃないか？　もう大丈夫だよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私のオッパイは、隊長の精液をビュルビュルするための場所だから……。っ\nあぁっ♪　出し切るまで出していいよ……。あっ、まだ出てる、あふっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んッ♪　ふぁああ♪　……なかなかイイ射精だったよ……。でも、隊長のポ\nテンシャルはまだまだこんなもんじゃないだろ……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「今度はさ……。私がパイズリしている間に、胸……揉んでくれないかい？　\n指の跡がつくくらい、ギュムっと握ってさ……揺らしておくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203202" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「それで……っ。ん、そう……そうやって、二人で協力して気持ち良くなろう\nよ……。っ……あっ、ハハ、遠慮してるね？　大丈夫だよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「上下左右、前後に動かして……。あっ♪　ムニュムニュしててくれればさ…\n…。ぁっ……♪　私もオッパイ、こうして弾ませて……。あっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ねえっ？　ホラッ……この方が摩擦が大きくなるだろうっ……！　フフ……\nっ、さっき隊長が出した汁が、谷間に流れてチンポに絡んで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203205" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んぅっ♪　ヌッチャヌッチャ音が聞こえる……♪　ねっちょっねっちょって\n……はぁ、はぁ、なんか興奮してきちまったよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「隊長もチンポ、力強く反応してるし……これが正解だろう？　あっ♪　お、\nおやめよ♪　元気すぎて胸から飛び出しそうになってるじゃないかっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おとなしく私にパイズられていなさいって～の……♪　っはぁっ♪　はぁっ\n、はぁ……アハハ、すっかりヤンチャだよ、この肉の棒ったら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私の胸……結構重たいだろうに、それを跳ねのけようとぐりぐり頭を伸ばし\nてくる……！　んぁふっ！　暴れて、逃げ出そうとしてる……ンンっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「イキがいいヤツは好きだよ……。この反骨心……んんっ、私の心に火をつけ\nる……♪　ほら、ジャレて遊ぶのはもうこのくらいにしな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おまえは私の胸の間で……んぁっ♪　おとなしくしてればいいんだよ……ッ\n、そうしたら気持ち良くなれるんだからね……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「は、ぁ……っ♪　んはぁあっ……はぁっ、はぁああ……♪　上半身が熱い…\n…♪　チンポから熱が移ってくるみたいだ、あっ、すごいよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203212" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「隊長も、手のひらとオチンポで私の胸の感触……楽しんでくれてるかい……\n？　あっ♪　かなり鍛えてるけど……それでも柔らかい方だろ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「指先で、チンポで簡単に形が歪んで……。あんっ、揉みごたえだって相当な\nハズだよ……。なっがい隊長のチンポが丸ごと埋まるくらいデカいしさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「満足、してもらえると嬉しいな……。ンンッ……♪　はぁああっ♪　すごい\n、ズンズン胸の中えぐられて……突きまくられて、……あぁあっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「すごい、すごいぃ……！　チンポに上半身全部持ち上げられちゃいそうだ…\n…！　あうっ♪　あふっ♪　んふぅっ、ふぅうっ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ズリュズリュって、あっ、夢中で動いてるよ……♪　イイっ、イイ……！　\n私も本気になってきちまったぁ……♪　あっあっあんっ、ンンっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んぁッ！？　今、チンポがビクビクゥって跳ねたよ……！　限界が近いって\nこと……なんだよね？　アハ……そんなに感じてくれちゃって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「愛おしくなってきちまいそうだ……♪　ゴリゴリに硬くなって、反り返った\nとんでもなく傲慢なオチンポで……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私の胸にまたぶっかけてくれてもいいんだよっ……！　はぁ♪　はぁあっ♪\n　ありったけの汁出して楽になっちまいな……そらぁっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「う♪　ぁあああああっ、あああああ～っ！　どぷっ、どぷってほとばしって\nくるっ……一気に胸の中に流れこんで……激流だよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「あっついっ……♪　あつい……！　も、もうダメ……私、我慢出来ない……\n！　痙攣、する……！　イくイくイくっ、胸イクぅううっ♪♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んはぁああっ♪　何度も、何度もチンポが脈打って……その度私のオッパイ\nが純白に染まってく……！　に、二度目だよ、どうなってんだいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「チンポの蛇口、壊れたみたいに……どっぴゅんどっぴゅん溢れてくる……！\n　ふぁうう♪　谷間の隙間にブチュブチュ注ぎ込まれて……あはぁぁ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……はぁああああ～～～♪　はぁぁ……♪　底力、感じたよ……。一度目よ\nり出すなんて、不思議な身体の構造だ……。はぁっ、だ、大丈夫……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「そ、そうか平気……か。ならいいんだけど……。見てごらん、この有り様…\n…。そうだよ、隊長がやったんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203306" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「これだけ派手に出されちゃったら……きっと、いくら洗っても落ちないよ。\nこのニオイ、私の胸にこびりついて……染み込んで」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203307" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「隊長のモノになったんだってことをアピールするに決まってるよ。こういう\nの、マーキングされたって言うんだろ？　こっちの宇宙じゃさ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「……ハハッ、随分長いこと、あっちの宇宙で戦ってきたけどさ。そん中で一\n番私の度肝を抜いたのはおまえだよ、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「私の知らないことを教えてくれる最強の男……。おまえに出会えただけでも\n、こっちの宇宙に来た甲斐があったって思ってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ああっ♪　出る出るっ♪　って……ぷぁっ！？　ンン！？　ん～～～～～っ\n！　ここは顔っ、顔だよ……隊長ぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「こんなところにかけてどうするってんだよお……！　きゃっ！？　あっ……\nあっ、うぷ……！　んん～～～～～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「く、くさい……臭すぎるぅ……！　ぷーんって生のイカみたいなニオイがす\nるよ……！　はぁ、はぁ、私の顔をなんだと思ってるんだ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203403" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「んは……！　はぁ、はぁ、はぁああっ……ああ、困る……！　ちょっと息吸\nっただけで、こいつのニオイで頭がいっぱいになる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ね、ねえ隊長……。こいつは後で顔を洗えば落ちるんだよね？　いくらお礼\nだって言っても、どっかに残ったりするなら大変だよ！　んっぷ、んん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203405" ]},
		{"command":[ "SETIMAGE", "0", "still_00015602_01_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「えっ！？　こっちの宇宙じゃあこの汁を喜んで飲んで、すすって味わうヤツ\nもいるだって！？　……そんな……こんなネットリした汁を！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ゲ、ゲテモノ好きにもほどがあるよ……。よく見りゃコレ、ちょっと宇宙ス\nライムにも似てるし……。でも……そんなに皆が飲むってことは」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「おいしい……のかもしれないしね……？　ごくっ……。い、いやっ？　好奇\n心なんかないよ、今喉を鳴らしたのだって深い意味はないしっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「ただ……。そうだね、隊長がさ……。次は飲んで欲しいとかって頼むんだっ\nたら……挑戦くらいはしてみてもいいかもね。だって」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リーダー" ]},
		{"command":[ "SETTEXT", "「コレは臭いしヌメヌメするけど、一応……隊長から出た隊長の一部なんだか\nら。はぁ、こっちの宇宙の女は度胸があるねぇ、びっくりしたよ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_156_0203410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}