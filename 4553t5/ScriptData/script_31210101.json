		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あぁん、おいひぃい♪　おいひぃ♪　らいしゅきぃ♪　んん♪　んんんっ♪\n　わたひのおっぱいも隊長ひゃんのおひんぽひゅきって言ってゆぅう♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ぢゅるっ、ぢゅるるるっ♪　ぐちゅっぐちゅっぐっちゅっぐちゅっ！　あっ\n♪　おっぱい、おっぱいとお口、まるごとおちんぽちゃんまみれ♪」", "NORMAL" ]},
