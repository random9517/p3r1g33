		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「んんん……んむ♪　あぁむ……もっと……もっろ奥まで舐めひゃぁい……♪\n　ぐちゅっ♪　ぐちゅ……ぐっちゅっ、ぐちゅ……んんぅ♪　んー……♪」", "NORMAL" ]},
