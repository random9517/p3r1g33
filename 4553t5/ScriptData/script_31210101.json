		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「私の能力向上？　任務のため？　……うーん……。そういう余計な口上はど\nーでもいいんだぁ。ね？　エッチなこと……したいんだよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103102" ]},
		{"command":[ "WAITINPUT" ]},

