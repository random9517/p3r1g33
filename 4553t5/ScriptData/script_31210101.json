		{"command":[ "SETIMAGE", "0", "still_00012101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「私の胸肉に慣れてもらうためにぃ……強制パイズリ♪　してあげるね……♪\n　んっ……んっ、ん、ん……んー……？　やわやわ～？　そうでしょぉ～？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「私のおっぱいねぇ♪　トロけたみたいにふわっふわなのぉ♪　たぶん、やら\nしー性格のせいかなぁ♪　しっとりしてて、ぷにぷにで……。やぁんん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「そう♪　下から突き上げられるとぉ♪　すぐにカタチ変わっちゃうくらいく\nにゃくにゃなのぉ♪　あっ♪　あっ♪　谷間、谷間ズリって擦られるの好き」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「いいわっ、いいわぁ♪　隊長ちゃんが下からおチンポ突き上げてくれるとぉ\n♪　私は上からなすりつけられて……。あっ♪　あっあっあっ♪　はぁんん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
