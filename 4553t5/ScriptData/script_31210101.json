		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「トタンちゃんはねぇ、すっごくカンタンでぇ、便利で、単純な……エッチ大\n好きな女の子だからぁ……今、すっごくわくわくしてるぅ……♪」", "NORMAL" ]},
