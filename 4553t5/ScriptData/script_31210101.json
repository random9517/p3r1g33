		{"command":[ "SETIMAGE", "0", "still_00012101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ごくごく飲んであげるからぁ……おいでぇ♪　きてぇ……♪　んっ……嫌で\nも吸い上げちゃう♪　れろ……れろ、れろ……ぢゅる……ぢゅるぢゅる♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ぢゅるーっぢゅるっ、ぢゅるるるーっ♪　んっぐっちゅっ！　ぐっちゅっぐ\nっちゅっぢゅるっ……んー♪　んー♪　ちょうらいぃ♪　ぢゅー♪」", "NORMAL" ]},
