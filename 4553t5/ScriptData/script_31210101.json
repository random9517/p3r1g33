		{"command":[ "SETIMAGE", "0", "still_00012101_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あぁん……素敵、素敵……♪　なんて雄々しいの♪　こんなのアソコに入れ\nたら虜になっちゃうわ……なんて凶悪なカタチ……。んんっ、んー♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「もう我慢できなぁい……。ちょっとだけ舐め舐めさせてもらってもいーい？\n　……敏感なお口の粘膜で、もーっとこの子のことを知りたいのぉ……♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「舐め舐めしながら、おっぱいの方でも刺激し続けるから……。楽しんでね♪\n　パイズリフェラ……。んんっ……あーん……♪　はむぅう……♪」", "NORMAL" ]},
