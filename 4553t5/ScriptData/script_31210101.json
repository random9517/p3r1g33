		{"command":[ "PLAYVOICE", "v2_121_0103129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「もっと♪　もっとおしゃぶりさせれぇ♪　んっぐちゅっ！　ぐちゅっぷっ、\nぐちゅっ、ぬちゅっ、ぬちゅうぅうっ、ぐっちゅっ……ぐっちゅっ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「はぷ♪　息止まっひゃう♪　窒息ひひゃうぅ……♪　でもいいのぉ、それで\nもいいのぉ♪　もっと欲しい……おひんぽひゃん欲ひぃ……ぐっちゅっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「食べちゃいたいのぉ♪　ぐちゅっ……ぐちゅっぐっちゅっぐちゅっ！　れろ\nぉ……れろっ、れろっ、れろ……んむ、ヌルヌルが出てくりゅぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103132" ]},
