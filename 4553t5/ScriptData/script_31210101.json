		{"command":[ "SETIMAGE", "0", "still_00012101_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「わたひのどこにかけてもいいからぁ♪　ぷりっぷりの特濃精子ぃ……♪　え\nっちなご褒美にちょうだ、い♪　ぢゅるるるっ、ぢゅるるる……んん！？」", "NORMAL" ]},
