		{"command":[ "SETIMAGE", "0", "still_00012101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「積極的でかっこいいおチンポちゃんね……♪　はいはーい、いい子にしてて\nねぇ……♪　私もあなたが好きだから……んっ♪　んっ、んっ♪」", "NORMAL" ]},
