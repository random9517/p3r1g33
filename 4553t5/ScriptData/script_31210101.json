		{"command":[ "SETIMAGE", "0", "still_00012101_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「それ、それぇ……胸でぐにぐにこすられるの、どぉ……？　精液でヌルヌル\nして気持ちいいでしょぉ……♪　安心して、ぜーんぶ飲んじゃうから♪」", "NORMAL" ]},
