		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「チュ♪　ちゅ、ちゅ、ちゅぅうう……♪　胸でぐにゅーっ♪　ぐにゅーって\n搾りながりゃぁ……パクつくのぉ♪　ちゅぱっ、ちゅぱ……ちゅぅ♪」", "NORMAL" ]},
