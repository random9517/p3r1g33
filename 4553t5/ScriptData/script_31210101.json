		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「れんぶ吸い取っちゃうぅ♪　れろ……れろ、ぢゅるっ♪　ぢゅる……ぢゅる\n、ぢゅる……♪　んは♪　ゆっくりだともどかしい？　じゃあねぇ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「激ひくひひゃうぅ♪　んぢゅるっぢゅるぢゅるぢゅるぢゅるぢゅるぅうう♪\n　ぢゅるぢゅるぢゅるぢゅぢゅるうう♪　ぢゅーっ、ぢゅぅうう♪」", "NORMAL" ]},
