		{"command":[ "SETIMAGE", "0", "still_00012101_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「おっぱいだよ。お・っ・ぱ・い♪　隊長ちゃんの大大大大だーいすきなおっ\nぱいで、たっぷりイジめてあげる……ほらっ、ぽろーん♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのガチガチおちんぽ……やわやわフニフニおっぱいで包みこんで\n……♪　あぁん♪　思ってたより大きい♪　いいおちんちん持ってるぅ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「このサイズなら……私も楽しめそう♪　あはははっ♪　挟んで、揉んで、上\n下させてぇ……うん♪　それだけじゃダメね……おしゃぶりしなくちゃ♪」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「隊長ちゃんのおチンポに、私の唾を染み込ませてあげたーい……♪　そのた\nめにも……まずは下準備♪　ほら♪　ほら、ほら、ほら……ゆっさゆっさ♪」", "NORMAL" ]},
