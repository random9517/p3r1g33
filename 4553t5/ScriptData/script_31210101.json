		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「んんぅ～♪　いぃーっぱい出たねぇ～♪　見て♪　見て♪　おっぱいがちゃ\nぷちゃぷ言ってるよぉ～♪　あは、重たい～♪」", "NORMAL" ]},
