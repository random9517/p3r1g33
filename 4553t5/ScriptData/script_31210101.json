		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「あっ♪　あぁん♪　まだ出てる……うん、うん♪　いいよ……出せるだけ出\nしちゃって……あっ♪　あっつぅい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_121_0103203" ]},
		{"command":[ "WAITINPUT" ]},

