		{"command":[ "PLAYVOICE", "v2_121_0103116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「んっ……♪　太すぎてうまくできなぁい……ビクビクしてて……あっ♪　見\nて♪　今、私のほっぺたにちゅってくっついちゃった……♪」", "NORMAL" ]},
