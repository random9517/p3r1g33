		{"command":[ "SETIMAGE", "0", "still_00012101_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "トタン" ]},
		{"command":[ "SETTEXT", "「ぷちゅっ♪　あむっ、むぅ……むぅん♪　あぁん……おいひぃ……♪　舌先\nに触れる先走りのお汁ぅ……。ぺちゃっ、ぴちゃっ、ぴちゃ……んん♪」", "NORMAL" ]},
