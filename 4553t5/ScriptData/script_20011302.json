{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0132" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「……指定座標、到着。……ん？　あれは……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530001" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPTEXT", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「見つけました。あれが、おそらく信号を発していた物体なのではと思われま\nす」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021530001" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「救命ポッド……みたいね。捕獲できそう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530001" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「少し待っていてください。引き上げて、ブリッジに乗せてみます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530001" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スミレの提案を承認し、救出作業を見守って数分後。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "プシュウウ、という空気音が漏れ、艦の中に招き入れられた救命ポッドの扉が\n開いた。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「う……、う、うう……。いた、い……くるしい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021530001" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "2", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「シャム……シャムちゃんじゃない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530002" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「トレミー海賊団のイノセントアサシン……。私達の宿敵であり、旧知の仲で\nもある海賊さん……ですよねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530002" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「普通、宇宙海賊とインペリアル・スペース・フォース……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021530002" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「リリア達の所属する皇国立宇宙軍とは、敵対し、遭遇すれば大捕り物が始ま\nる関係でしたよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021530003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「うん！　ふつーなら、すぐさまお縄にしちゃうところ……なんだけど」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530003" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「彼女たち……トレミー海賊団や次元海賊団アルデバランには、特別に共闘し\nてもらうことも多いんだ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「私達だけじゃあ到底対応できないおっきな宇宙の危機……そういう時には、\n誰の命令も聞かずに動ける、彼女たちのスピードが勝利のカギになる」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「だ・か・ら一時的に休戦して、助けてもらうことも多くって。いわば腐れ縁\nの関係でもあるの。……この前の戦闘を覚えてる？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530007" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「セリカのとんでもない作戦で、ダイアンサスが沈みかけた時……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530003" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「さりげなくフォローしてくれたのが、このシャムちゃん。だから元気でやっ\nてると思ってたんだけどねぇ～……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「そ、そういえばそんなこともありましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530002" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「でも……誰よりも宇宙を知り尽くしているはずの宇宙海賊が救命ポッドで救\n助を求めるなんて……？　これはおかしな事態ですよね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530003" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「何か事件が起こったとしか思えないけど……。まずは、本人に事情を聴いて\nみましょうか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530005" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "怪我をしているらしいシャムを驚かせないように、苦しめないように。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スイレンはその場にしゃがみ、救命ポッドの中でへばっているシャムに問いか\nける。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「会話はできる？　何があったのか、わかる範囲でいいから教えてくれないか\nしら」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530006" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「あ……あなたたち……。ここに来ちゃったの……？　はや、く……逃げ、て\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021530002" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「逃げる？　逃げるって何から……？　あなたは誰にやられたの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530007" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャム" ]},
		{"command":[ "SETTEXT", "「そ、それは……。イ……げほっ！　ごほっ、ごほっ……！　イン……こほっ\n！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_136_010021530003" ]},
	{"command":[ "SETCHARA", "0", "char_00013601_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「駄目です……。これ以上話したら、傷口が開いて死んじゃいます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530004" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "傷を負って疲弊し、会話をするのも苦しそうなシャムにこれ以上の尋問は難し\nい。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
	{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「もう少し、情報をゲットしたかったのが本音だけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530008" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「これは治療優先すべきねぇ……。リリアちゃん、救急ポッドの準備お願い～\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530009" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「皆さんがおしゃべりしてる間に済んでまーす。よいしょっ！　はい、こっち\nにおとなしーく入ってくださーい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021530004" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "いつもダルそうに、ＳＮＳチェックに興じているリリアのテキパキとした救命\n行為。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「やればできる子なんだよね、リリアちゃん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530005" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "6", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スミレは感心しつつ、セリカ、スイレンの指示をあおぐことにした。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「それで、私達はこれからどうしたら……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530006" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "1", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「それなんだけど、……セリカ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530010" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「うん、うんうんうん。スイレンちゃんの言いたいことはわかってるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530008" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「……ねえ、スミレちゃん。トレミー海賊団って、かっなりつよーい海賊さん\nじゃない？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530009" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「えっ。あ、は、はい。そうですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530007" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「それがさぁ？　こんな一方的にぃ……ボコボコにされるなんて、おかしいよ\nね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530010" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「もしかしたら、いきなり襲われたんじゃないかなって思うんだよね。奇襲だ\nとか、不意打ちだとか……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530011" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「それに、シャムさんが入っていたポッド。まだ、使用してから大した時間は\n経っていません」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530011" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「敵が全速で立ち去っていたとしても、まだそう遠く離れた場所までは辿りつ\nけていないはず……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530012" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「……！　すぐに、近隣の星域を探知します！　そこで大規模な戦闘の痕跡が\nあれば……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530008" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「ん。何か手がかりになるかもしれないよねっ☆　大変だけど、お願いしまー\nす！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530012" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「まかせてくださいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530009" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "スミレが一所懸命コントロールパネルを操作し、データに向き合っていたその\n時だった。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "ビーッ、ビーッ、ビーッ！！", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "警報が鳴り響き、艦内が赤一色に染まったかと思うと……ズズンッ……と艦が\n大きく揺れ動く。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「ち、近いです！　私達の、ダイアンサスのすぐそばで……、ええっ！？　こ\nんな超規模の戦闘が！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530010" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "3", "CENTER", "0" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "リリア" ]},
		{"command":[ "SETTEXT", "「うわっ、わわわっ。シャムさんの救急ポッドが……！　あ、あ、危ないなぁ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_193_010021530005" ]},
	{"command":[ "SETCHARA", "0", "char_00019301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "傾いた艦内をずるずる滑り落ちていくポッドをリリアが引き戻す。", "NORMAL" ]},
	{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETTEXT", "それと同時に、スミレは自分達の身に今起きている事態を報告した。", "NORMAL" ]},
	{"command":[ "SETCHARA", "0", "char_00019201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スミレ" ]},
		{"command":[ "SETTEXT", "「こ、これは、探知するまでもありません！　おそらくシャムさんは、この戦\nいに巻き込まれたと見て間違いないと思います！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_192_010021530011" ]},
	{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「そっかそっか。りょーかいりょーかい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530013" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「しかしこ、れは……。想像より遥かに大規模です。艦長。このレベルの戦闘\nに突っ込むのは危険です。ここは一時撤退して……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530013" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「んー……、やーだっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530014" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "スイレン" ]},
		{"command":[ "SETTEXT", "「や、やだじゃないでしょう！　セリカ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_191_010021530014" ]},
	{"command":[ "SETCHARA", "0", "char_00019101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「気になることをほったらかしで逃げるなんて、ダイアンサスらしくないっ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530015" ]},
	{"command":[ "SETCHARA", "0", "char_00019001_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セリカ" ]},
		{"command":[ "SETTEXT", "「とーにーかーく！　行ってみて危なかったら逃げようよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_190_010021530016" ]},
		{"command":[ "WAITINPUT" ]},

