		{"command":[ "SETIMAGE", "0", "still_00008106_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「おちんちん……こうして、しごいて……。あんっ、隊長さん、どうかな……\n気持ちいい……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603112" ]},
		{"command":[ "SETIMAGE", "0", "still_00008106_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「私は……なんだか変な気分……。制服だからかな……？　それとも、ここが\n教室だから……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「みんなが勉強している場所で、隊長さんとエッチなことしてるって思うと…\n…なんだか、ドキドキしちゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603114" ]},
		{"command":[ "SETIMAGE", "0", "still_00008106_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「隊長さんも、興奮してるのかな……。胸の間で、おちんちんがビクビクって\nしてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603115" ]},
		{"command":[ "SETIMAGE", "0", "still_00008106_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「おちんちんだけじゃなくて……腰も跳ねちゃってるかな……？　私のおっぱ\nい、気持ちいいんだね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「もっと……こう……胸を動かそっかな……。交互に、動かして……おちんち\nんをこねこねするみたいに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……。おちんちんがどんどん硬くなってく……。んっ、ああっ\n、おっぱいやけどしちゃいそう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603118" ]},
		{"command":[ "SETIMAGE", "0", "still_00008106_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「どこでこんなの覚えたのかって……？　本、だけど……。アマ子の持ってた\n雑誌に書いてあって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603119" ]},
		{"command":[ "SETIMAGE", "0", "still_00008106_01_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「誰もいない教室で、男の人に、エッチなことするの……隊長さんなら、よろ\nこんでくれるかなって思ったから……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「隊長さんも、こういうのが好きなら……んっ、恥ずかしいけど、してあげた\nいかなって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「あんっ！　おちんちんが、ビクンって……！　どうしたの？　い、痛かった\n……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603122" ]},
		{"command":[ "SETIMAGE", "0", "still_00008106_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「そうじゃないから、もっと激しくしてくれ？　う、うん……もっといっぱい\n、胸で……おちんちんしごくね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「ぎゅってして……。はぁ、はぁ、パイズリ……んっ、おちんちんが、膨らん\nで……先っぽも、パンパン……」", "NORMAL" ]},
