		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「……あ、でも好きにアレンジしてる人も多いよね、アマ子なんか、ブラウス\nのボタンを大胆にあけちゃって……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_081_0603103" ]},
