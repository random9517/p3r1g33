		{"command":[ "SETIMAGE", "0", "still_00008106_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「ああっ、隊長さんも、腰が動いてる……。パイズリにあわせて、おっぱいを\n犯すみたいに……おちんちん、動いて……」", "NORMAL" ]},
