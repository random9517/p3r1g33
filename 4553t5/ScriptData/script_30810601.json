		{"command":[ "PLAYVOICE", "v2_081_0603110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「それじゃあ、おちんちん挟むね……。ん、しょ……すごく硬くなってる……\nああ、胸に……熱いの……」", "NORMAL" ]},
