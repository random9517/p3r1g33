		{"command":[ "SETCHARA", "0", "char_00008106_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「私の制服姿がかわいいせい……？　そう……じゃあ、勃起しちゃったおちん\nちん、すっきりさせないとね……」", "NORMAL" ]},
