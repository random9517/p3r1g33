		{"command":[ "SETIMAGE", "0", "still_00008106_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「トロトロ、先走り汁が垂れてる……んっ、おちんちんの匂いが、強くなって\n……私も、すごく興奮しちゃうの……」", "NORMAL" ]},
