		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "アヌ子" ]},
		{"command":[ "SETTEXT", "「私も真似しようかと思ったんだよね、こんなふうに胸を……そしたら、アマ\n子に『そういうキャラじゃない』って言われちゃって……」", "NORMAL" ]},
