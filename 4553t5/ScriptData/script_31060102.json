{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ああ、こんなことになるだなんて……って、いや、別に、緊張なんかしてな\nいし。そんな目で見ないでちょうだい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「……ウソよ。ホントはちょっと緊張してる……でも、ちょっとだけよ、ちょ\nっとだけ。これまで散々変なことしてきたじゃない……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「正直、こういうことするの……ちょっと楽しみだったんだから……ああ、や\nだ、ドキドキしちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「……でも、あんまり痛いことはしないでよ？　わかってると思うけど、酷い\nことしたら、セップクしてもらうからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「……するのはセップクじゃなく、セックス……？　うわぁ……萎えるぅ……\nそういうこと二度と言わないで。わかった？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「さ、余計なこと言われて気が削がれる前に、始めちゃいましょう……ほら、\nいつでもいいよ──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「んっ！　んんぁ、はぁ……ああああん、お、大きい……丸く膨らんだ先っち\nょが、アソコの入り口に潜り込んで、くる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「プクプクに膨らんだ先っちょが……ん、んんぁ、はぁ……狭いアソコの管の\n中をこじ開けて、かき分けて……ひぐぅ、あはぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「くぅ……んふぅ、硬い……こんなにカチカチ……すごぉい……お腹の隙間が\n、おちんちんの形になっちゃってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104109" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、ああああ……アソコの中で、動いてる……ぐぅ、あはぁ……ち\nょ、ちょっと強引だけど……でも……ん、んん、はぁぁぁん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ええ？　動かない方がいいか、ですって……？　はぁ、ふぅ……そ、そんな\nわけにはいかない、でしょ？　ん、くぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104111" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_01" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「でも、激しすぎるのは、駄目よ……はー……あふぅ……優しく、動いてね…\n…はぁ、はぁ……はぁぁあん……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104112" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「お腹の中で、ゴリゴリ擦れてる……あ、ぐぅ、ふぅ……深いところまで、届\nいてるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「おちんちんに、アソコが串刺しにされてる……ん、んん、一番奥が……先っ\nちょにえぐられて……あっ、ひやぁ！　うくぅぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「そこ、そこぉ……はぁ、んん、一番大事なところなのに……おちんちんに、\nぐりぐりされて……あ、駄目ぇ……はぁ、はぁぁぁああん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「苦しい……んん、苦しいの駄目って言ったのに……こんなに、気持ちいい…\n…はぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ふふふ、セップクは勘弁、してあげる……はぁ、はぁ……んん、あぁあん…\n…子宮がコツコツ音立ててるよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あぐぅ、ひやぁあ……押し込まれてる……お腹に、子宮が、めり込んじゃぅ\n……ん、んんぁ、ぐぅ、あぐぅぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「今、濡れてる……アソコの奥から、エッチな涎が、だくだく溢れてる……あ\nああ、濡れすぎて、クチュクチュ音がする……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あはぁ……おちんちんが暴れてる……おっぱいまで、ユサユサ揺れてるよぉ\n……はぁ、はぁ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104120" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ……動くたびに、中が捩れちゃうぅ……あ、ああ、先っちょ\nが中で引っかかって……んくぅ、きゃひぃ……あ、あ、ああああ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ……はへぇぇ……あ、あなたと、こんな関係になっちゃうだなん\nて……ん、んん……信じられない……ニンジャに騙されてるみたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104122" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あぁあん、はへぇぇ……気持ちいい……ん、ふぅ……子曰く……んん、子曰\nくぅ……あぁん、言葉が出てこないよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ニホンゴじゃなく、あたしの国の言葉でなら、すぐに言えるんだけど……言\nったところで伝わらないもんね……はぁ、はぁ……んんぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……あぁあん……おちんちんが、出たり入ったり……気持ちいいのが、\nいっぱい繰り返されてる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ、頭の芯までしびれちゃうぅ……ん、んぁ……はぁ……はぁ……すごぉ\nい……これが、セックス……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「お腹の奥から、ジュボジュボ、音が聞こえてくる……はぁぁん……音が響く\n……身体の隅々まで伝わってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104127" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……え？　だんだん、良くなってきた……？　そう……そろそ\nろ射精の、時間ね……はぁ、あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ああ、また精液を出されちゃう……あれが、またあたしに……はぁ、はぁ…\n…ああああん、楽しみぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「カチカチおちんちんが、中で暴れまわってる……膨れ上がった先っちょと、\n反り返った茎が、お腹の奥をかき回してる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……ふぅ……出る……精液、出されちゃうぅ……ビクンビクン、震えて\nる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「このまま、出すの……？　はぁ、はぁ……そう……もう、しょうがないん、\nだからぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あっ、ぐう……ひうぅぅ……精液が、おちんちんに集まってる……根本がプ\nクプク膨らんでる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あっ、ああぁあん、あたしも……イッ、イキ、そう……ん\nん、はぁ……はぁ……ひゃうぅぅうん……っ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あ、あああ、来るぅ……精液、近づいてくる……あっ、ひぃぃ！　んんぁ、\nああぁぁぁぁあん……っ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はひぃぃぃぃ……！　あ、あ、熱いの、溢れてる……ぅ！　奥に、精液が、\nぶつかってるぅ……っ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_07" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はー……んん、くぅ……熱いぃ……はぁ、はぁ……お腹の隙間全部に、ドロ\nドロが入り込んで……くるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はー……はへぇぇ……精子が、お腹の中を泳いでる……はぁ、ふぅ……赤ち\nゃんの部屋に入ってくるぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104138" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ、はぁ……はぁ……熱い……おへその裏側が、あなたの体温でいっ\nぱいになってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ふぅ……ふぅ……はぁ……射精が、治まった、みたいね……はぁ、ふぅ……\n満足、してくれた？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104140" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「え？　まだ全然満足してない……ですって？　ちょ、あ、あたしに、何か問\n題があったわけ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104201" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「そう……まあ、何も問題がないなら、それでいいんだけど……。え？　あ、\nあたし……？　もう一回しても、別に構わないけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「だって、さっきイッた時の、あなたの顔と声……なんだか、興奮しちゃった\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「アソコで、おちんちんをキュ～～って締め付けて、気持ちよくさせる……こ\nれって、すごく楽しいのよね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「それじゃ、さっそく楽しいことしましょう……ん、ふぅ……ああ、またドキ\nドキしてきちゃったぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あっ、あひぃ……んぅ、んん……中で、動いてる……あああ、ニュルニュル\nする……気持ち、いい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ん、んぁ、はぁ、はぁ……精液で、おへその裏まで、チャポチャポ鳴ってる\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「子宮の中で、精液が揺れてる……はぁ……はぁ……子宮が、揺れて……気持\nち、いい……はぁ、ふぅ……ひゃうぅぅん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104208" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ねえ、もっと動いてくれていいのよ……はぁ、ふぅ……おっぱいが、根本か\nらちぎれちゃうぐらいに……ん、ん、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あっ、あっ、いい……その調子……ん、くぅ……はぁ、はぁ……ね、ねえ、\nあたしも、動いてみて、いい？　ん、んん、はぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はあぁあん……どう？　気持ちいい……？　あなたを、もっと気持ちよくし\nてあげたいの……はぁ、はぁ……んひぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「こうして、おちんちんをキュッキュと締付けながら、挿入する角度を調整す\nる……あああ、すごぉい……いっぱい、気持ちいいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あなたをいっぱいイジメてあげてる気分……ああ、もっと激しく、責めてあ\nげたい……はぁ、はぁ……はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「やだ……想像しただけで、いっぱい興奮しちゃう……はぁ、はぁ……あああ\n、腰が、勝手に動いちゃうよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ん、ふぅ……はぁ、あああ……おちんちん、すごぉい……精液でにゅるにゅ\nるの中、さっきより硬くなってる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104215" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あ、あ、はぁ……あぁあん……あなたの腰使いと私の腰使いが衝突してる…\n…あ、だめ、アソコが、壊れちゃうぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて、はぁ、はぁ……失神しちゃいそう……なんだか、息苦しい\n……はぁ、はぁ……あへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あぁ、精液が溢れてる……アソコの奥から掻き出されちゃう……もったいな\nいよぉ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ねえ、もう一回出してぇ……はぁ、はぁ……精液が恋しいの……はぁ、あぁ\nあん……え？　ちょうど、出すところだった……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ふぅ、ふふ……嬉しい……出してぇ……好きなところに、ぶちまけてぇ……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あ、あ、あひぃぃぃぃ！！　ま、また出てるぅ……はぁ、んふぅ……熱い出\nしたてが、子宮の中に……入って、くる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ふぐぅ、あはぁぁ……ビュルビュル溢れてる……ん、あぁぁん……子宮が、\n精液を吸い上げる、みたいぃ……はぁ、あぁ、はへぇぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「もう入らない……はぁ、ふぅ……あふぅ……でも、まだ欲しがってる……あ\nあん、アソコが、勝手に締め付けちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ん、んん、はぁ、はふぅ……アソコと、おちんちんが連動しているみたい…\n…はぁ、まだビュルビュル出てる……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104304" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁぁ、あぁああん……すごぉい……また、アソコの中が、ドロドロでいっ\nぱいに……はぁ、はぁ……あふぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あぁぁ……気持ちよすぎて、ん、んん、はぁ……目の前が、真っ白……すご\nぉい……何、これぇ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はー……あふぅ……深呼吸をすると、精子がお腹の奥を泳いでいる姿が、目\nに浮かんじゃう……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ふふ、もし子供が生まれたら……立派な侠者に……ニンジャを狩る、最強の\nサムライに育てなきゃね……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「……でも、まだ妊娠は駄目ね。はぁ、ふく……まだ戦いの最中だもの……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ことが全部片付いたら……あなたの子を、妊娠してあげてもいいんだけどね\n～……ふふふ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ひゃうぅぅぅ！？　あっ、あっ、ああああ……熱いのが、身体にぶちまけら\nれてる……あ、ひやぁ……あはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「中に、出されるって思ったのにぃ……ん、んぁ、はぁ、精液が、こんなに…\n…ん、くぅ……身体中に……顔に……あはぁぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104402" ]},
		{"command":[ "SETIMAGE", "0", "still_00010601_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ってか、こんなに出すとか……信じられない……さっきも、あんなにいっぱ\nい出したのに……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁぁああん……肌に、張り付いてくる……ん、ふぅ……皮膚の中に\n染み込んでくる、みたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「はぁ……はぁ……あふぅ……匂いが、すごぉい……鼻が、麻痺しちゃう……\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「あ、あ、まだ出てる……射精するたびに、おちんちんが、ビクビク跳ねてる\n……いっぱい飛び散っちゃうぅ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「んん、はぁ……髪の毛まで、どろどろじゃない……はぁ、あふぅ……でも、\nやっと治まった、みたい……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「ああん、出しすぎじゃない？　子宮が、ビックリしてる……でも、喜んでる\n、みたい……ふふ……妊娠、したがってるのかも……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「でも、今はまだ、妊娠するわけにはいかないよね……だって、まだサムライ\nテールの使命が、終わってないんだもん……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "シャオ" ]},
		{"command":[ "SETTEXT", "「だから、早く済ませなきゃね。で、妊娠させてもらわなきゃ……母子武侠と\nなって、一緒にニンジャを狩るんだから──」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_106_0104410" ]},
