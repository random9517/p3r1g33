{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……こんなにもチ〇ポを勃起させて、いやらしいヤツじゃな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「軽く触っているだけなのに、血管が浮かび上がるくらいに硬くなっておるぞ\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「昼間に余の荷物持ちをしていたときからずっとこんな調子だったようじゃが\n、そんなに余の身体が気になるのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう……この状況でよく『違う』と言えるものじゃな。心では否定しても、\n身体は正直……というヤツかのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「正直に答えたらどうだい？　お主は余の私服姿に興奮して、はしたなくチ〇\nポを勃起させる変態じゃと……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「素直に認めれば、この生殺しの状態から解放してやるぞ。このガチガチの勃\n起チ〇ポを、手でいっぱいシコシコしてやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「狂魔女王である余の手コキじゃぞ。このような機会、二度と訪れぬかもしれ\nんぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403107" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「たった一言認めるだけじゃ。貴様が真正の変態であると、余の前で宣言する\nだけでいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403108" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれ……もう限界なんじゃろう？　我慢汁が溢れておるこのチ〇ポ……たっ\nぷりとシゴいて欲しいのじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403109" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあ、言え……！　余にひれ伏し、性欲のために自身を変態だと認め、余の\n哀れな下僕になるのじゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あははははっ！　そうじゃ、その言葉が聞きたかったのじゃ！　チ〇ポを握\nられながら余に屈する姿、たまらないねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……そう切なそうな顔をするでない。余はグレート・ルナリアムの女\n王じゃぞ。約束をたがえるようなことはせぬ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「余の下僕となった記念に、たーーーっぷりと可愛がってやろう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「気持ちよすぎて気を失うんじゃないぞ。まあ、例え気を失ったとしても、容\n赦なくチ〇ポをシゴき続けるがのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「では、しっかりと味わうがいい。余の手の感触と……這いずるような舌の感\n触をな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403115" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ぐちゅ、じゅ……ぢゅ、れろぉ……！　んちゅ、ぴちゃ……ちゅ、じゅじゅ\n……ずちゅ、れじゅ……！　ちゅ、ずずっ、んぢゅるぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403116" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んぷっ……ちゅ、ぢゅぱっ……！　ふふっ……どうじゃ……！　余の手コキ\nと耳舐めは気持ちいいじゃろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「どうやら、言葉にならないほどに感じておるようじゃな……だが、チ〇ポの\n方はしっかりと反応しておるのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「射精したように我慢汁をびゅーびゅー噴き出しながら、激しく脈打っておる\n……しっかり握っておかねば、手からすり抜けてしまいそうだねぇ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああ、そうじゃ。この我慢汁をチ〇ポに塗り付けて、もっと滑りをよくして\nやるとしよう。その方が、お主も気持ちよくなれるじゃろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403120" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　そう遠慮するでない。余は下僕には優しく、寛大な女王じゃ\n。たっぷりと可愛がってやるからのう……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403121" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あむっ……！　ちゅ、じゅるるっ……！　ぴちゃ、くちゅ……！　ずっ、れ\nりゅ、ぬりゅっ……！　くちゅ、じゅじゅ、ぢゅぷぅ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403122" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ、んじゅぞっ……！　ぢゅ、びちゃ、ぷちゅるっ……！　くちゅ、\nじゅぢゅるっ……！　んぷっ……！　耳がヒクヒクしておるのう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポの動きに合わせて全身もビクビクと震えておる……お主は本当に面白\nいくらい、素直に身体が反応するじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403124" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほらっ……もっと余の手で感じるがいい。んちゅ、ちゅぱっ……ずずっ、れ\nじゅるぅ……！　ぴちゃ、ぷちゃ、ちゅずちゅっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、んじゅ……！　このカリ首のところをくちゅくちゅされるのが気持ち\nいいのじゃろう……ずっ、ちゅぱっ、ぢゅぶっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「こうやって指で輪っかを作って、お主の弱点をズルズルすれば……んっ、あ\nはぁ……！　また我慢汁がぴゅっぴゅっと溢れてきよる……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403127" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_02" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「チ〇ポがすっかり我慢汁まみれじゃないか……ベトベトのヌルヌルで、気持\nち悪いくらいじゃぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「しかし、こんなにもいやらしい汁にまみれたら、手のひらが妊娠してしまい\nそうじゃな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう……妊娠という言葉を出した瞬間、チ〇ポが今までで一番反応したぞ。\n余のことを孕ませたいのかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403130" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほれ、素直に言うといい……！　余の手のひらに汚らしい精子をびゅーびゅ\nー出して、ベトベトにしたいのであろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403131" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゃんと本音を言えば、このまま射精させてやるぞ……ちゅ、じゅるっ……\n！　ちゅぱっ、れろっ、ぴちゃ……ずずっ、ちゅくっ、ぐちゅるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403132" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_03" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほらっ、言え……！　狂魔女王である余の綺麗な手に、下僕如きの情けない\n孕ませ汁をびゅるびゅる出させてくださいと口にしろ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はははっ！　よく言えたじゃないか！　それでは、ご褒美をくれてやるとし\nよう！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403134" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さあイクがいいっ！　余の手を孕ませるくらいの勢いで、貴様の子種をびゅ\nーびゅー出しちまいなっ！！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、くうぅ……！　熱くてネバネバした液体が、手の中に広がっておるぞ\nっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403136" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_06" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅちゅ……！　遠慮せずに出すがいい……！　余も手伝ってやる\nからのう……ぐちゅ、ずりゅ……！　ちゅ、れろっ、ぶちゅるっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403137" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「精子をどぴゅどぴゅ出しておる最中に、耳を舐められながらシゴかれるのは\n……んっ、ちゅぱっ……！　たまらないじゃろう……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　女を孕ませるために作られたはずの子種が、卵子と出会うこ\nともないまま無駄打ちされ続けておるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああっ……！　この情けない感じ、本当にたまらないねぇ……！　もっとも\nっと虐めてやりたくなるよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「たっぷりと出せたようじゃな……どうだい？　孕むことのない場所に、精子\nをぶち撒けた感想は……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403201" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ははっ……！　この期に及んで、まだ出したいと言い出すとは……！　やは\nり貴様は、余の見込んだ男よ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403202" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「だがダメじゃな。貴様の言葉には誠意が足りぬ。シて欲しいのなら、もっと\n下僕にふさわしい言葉を使い、余に懇願するがいい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「心の赴くままに言ってみろ……マ〇コではなく手の中で果てた哀れな劣等チ\n〇ポを、今一度狂魔女王様の手で気持ちよくしてくださいとな……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ああっ……！　いい……！　いいぞ……！　貴様の情けない悲痛な叫びが最\n高に心地よい……！　さあ、ご褒美だ……受け取るがいい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ずずっ！　ちゅぱっ、んじゅ！　れりゅ、ずぷっ、ちゅくぅ！　んちゅ、ち\nゅ、ちゅぱぁ！　ぶちゅ、ぴちゃ、んっ、ちゅ……ちゅぐるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403206" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、ぷちゅ……！　今度は最初から全力で行かせてもらうぞ……！　貴様\nが止めてと言っても、絶対に止めぬからなっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅちゅ！　ぐっ、じゅぴっ！　れぢゅ、じゅずっ！　ぷじゅ、ちゅ……く\nちゃ、んじゅるっ！　ぴちゃ、ぴちゃ、ちゅぱぁ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んむっ、ちゅちゅるっ……！　シゴけばシゴくほど、チ〇ポの血管が浮かび\n上がってきておるな……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それに先ほどあれだけ出したというのに、こんなにも硬くしおって……！　\nそんなに余の手のひらが気に入ったのかい……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「自分で出した精子と我慢汁で、チ〇ポがぐちゃぐちゃのドロドロになってお\nるというのに……変態にもほどがあるぞ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「貴様のような狂った性癖を持つ者を相手にしてやるのは、余くらいのものじ\nゃぞ……！　感謝の言葉の一つでも言ったらどうだい……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「エファナティカ様、精子まみれの変態下僕チ〇ポをシコシコしてくださりあ\nりがとうございます。もっとシてください……くらい言えぬのか！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅぶっ、ちゅぱっ……！　んっ、ぷちゅ……！　ほれっ、言ってみろ……\n！　貴様が持ちうる最大限の感謝を込めて、礼を述べよ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「はっ、ははっ……！　あははははっ！　貴様の賛辞、しかと受け止めたぞっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403215" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「やはり貴様は最高の下僕だっ！　これからも余のために、しっかりと忠義を\n示すといい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「その見返りとして、余はこうして貴様のチ〇ポを気持ちよくしてやる！　ち\nゅぱっ、んっ、れぷっ、ちゅぱっ！　ちゅ、ちゅちゅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ぷちゅ、じゅるっ！　れじゅ、ぐぢゅ！　にちゃ、んっ、ぴちゃっ……ちゅ\nちゅるっ！　じゅ、ずぷっ！　ぢゅぐっ、ずっ、じゅるるるっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ！　ちゅ、んぷっ！　チ〇ポが跳ねておるぞっ！　そろそろイキた\nいみたいだねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「さっきみたいに、いっぱい射精するといい！　貴様が無様にイク姿、しっか\nりと余が見ておいてやるっ！　ほらっ、イケッ！　イッちまいなっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んっ、あはあぁ……！　また手の中に熱い精子がびゅーびゅー出ておるぞ…\n…！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403301" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_10" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「しかもこの量と勢い……先ほどよりも多いのではないか……！？　まったく\n、どこまで精子を溜め込んでいるんだい……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403302" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「１回の射精で精子を出しつくせない悪い下僕には、たっぷりとオシオキして\nやらないとねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403303" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「射精中でも遠慮なくシコシコさせてもらうよ！　ほらっ、亀頭を重点的にシ\nゴきながら、撫でまわしてやろうっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「おっと、動くでないっ！　これ以上暴れるなら、中途半端なまま終わらせて\nもっと切なくなるけどいいのかいっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ！　そうじゃ、それでいい！　大人しく余の手コキを味わい、身体を\n震わせ続けるがいいっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403306" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くっ、んんっ……！　ちゅ、ちゅじゅっ……！　まだ出るみたいだね……！\n　ならこのまま、３回戦としゃれこもうじゃないか……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「これ以上シゴかれたら、精子じゃなくて違うものが出そうじゃと……？　そ\nれはつまり、男の潮吹きというヤツかの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「あははっ！　それは是非とも見て見たいものじゃな！　ほれっ、遠慮せずに\n余に潮吹きとやらを見せてみよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403309" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_09" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「貴様が潮吹きするまで、耳舐めと手コキを続けてやるからの……！　んちゅ\n、ちゅぱっ……れろっ、ぴちゃ！　ちゅ、ちゅちゅ、んじゅるぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ちょ、あぶっ！？　な、何だ……！？　精子が顔にまで飛び跳ねて……んく\nぅ……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403401" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「シゴけばシゴくほど、精子が飛んできよる……！　こんなにも勢いがあると\nは予想外じゃ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「それにこの濃厚な香り……！　臭すぎて、鼻が曲がっちまいそうだよ……！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403403" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「くうっ……！？　まだ出るのかいっ……！？　貴様……何度余の顔を穢せば\n気が済むのじゃ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403404" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ええいっ！　いくら謝っても無駄じゃ！　余の手ほどきのおかげで射精でき\nたというのに……恩を仇で返すとはこのことだねぇ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「んちゅ、ちゅくっ……！　下僕の分際で好き勝手しよって……覚悟はできて\nおるのじゃろうな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ほう……何でもするから許して欲しいと？　その言葉に嘘偽りはないのじゃ\nな？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403407" ]},
		{"command":[ "SETIMAGE", "0", "still_00000314_01_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ならば余の気分を害したバツとして、貴様の金玉が空になるまで手コキを続\nけさせてもらうぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403408" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「なに、心配はいらぬ。干からびる前に精子を出せばそれで終わりじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403409" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ａエファナティカ" ]},
		{"command":[ "SETTEXT", "「ふふっ……！　貴様がどんな声を上げるのか楽しみだねぇ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_1403410" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "LABEL", "END" ]},
		{"command":[ "EXIT" ]}
	]
}