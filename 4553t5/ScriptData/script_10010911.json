{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0074" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
	{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おっと、時間だ。悪いけど、あたしはこれでー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109200001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＡ" ]},
		{"command":[ "SETTEXT", "「ああ、そっか。アネキ、今日は早退でしたね。お疲れっすー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＢ" ]},
		{"command":[ "SETTEXT", "「それじゃ、後で会場でー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETIMAGE", "0", "sbg_0075" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まあ、あたしは忙しいんで会えるかどうかわかんねえけどな。そんじゃ、お\n先ー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109200002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0116" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_019" ]},
		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「ういーっす、こんちゃーっす。マスター、調子はどうー？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109200003" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "マスター" ]},
		{"command":[ "SETTEXT", "「ああ、だいぶ良くなったよー。そんじゃほむらちゃん、おでんの仕込み、頼\nむわ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「はいよ！　任せとけって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109200004" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "sbg_0000" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_004" ]},
		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「抗争終結後。ほむらは『居酒屋・正義（まさよし）』の、悪の組織化を撤回\n。マスターの退院を待ち、居酒屋の営業を再開した」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109200001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「そして、九姉妹（ナインシスターズ）の懇親会は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109200002" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "SETIMAGE", "0", "bg_0141" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_018" ]},
		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「それでは皆様。九姉妹（ナインシスターズ）とＥＤＯの、ますますの発展を\nお祈りいたしまして……かんぱーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109200001" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "会場のみんな" ]},
		{"command":[ "SETTEXT", "「かんぱーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_060109200001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "Ω組組員Ａ" ]},
		{"command":[ "SETTEXT", "「へぇ～！　ＥＤＯって、そんなお仕事もやってんすか！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＥＤＯ情報科隊員" ]},
		{"command":[ "SETTEXT", "「そうなんですよ～！まさか私がそんな部署に回されるとは思ってなくて！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＥＤＯ機甲科隊員" ]},
		{"command":[ "SETTEXT", "「たしかに情報科は意外でした！　彼女、学生時代は自分と一緒に戦車やって\nたんでありますよー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ＥＤＯ需品科隊員" ]},
		{"command":[ "SETTEXT", "「うっそ！　悪の組織って、そんなに待遇いいんですか！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ガルグイユ" ]},
		{"command":[ "SETTEXT", "「労働基準法などで手入れが入ると、本業の活動に差し支えるであろう？　だ\nから、どこの組織も雇用条件には気をつかうのじゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_046_010109200001" ]},
		{"command":[ "SETCHARA", "0", "char_00004601_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「おおー！　ミルラたぁ～～ん！　相変わらずかわいいねぇ～！　飲んでるぅ\n～！？　お姉さんと一緒に飲まな～い？　うひゃひゃひゃひゃ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010109200001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ミルラ" ]},
		{"command":[ "SETTEXT", "「相変わらず酒癖が悪いですわね、長官……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_043_010109200001" ]},
		{"command":[ "SETCHARA", "0", "char_00004301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「どうじゃ？　この会場、なかなかであろう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109200001" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「ええ、陛下のお骨折りでこの会議場が使えて、それにＥＤＯの皆さんと我々\n悪の組織との交流の機会が持てて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109200002" ]},
		{"command":[ "SETCHARA", "0", "char_00003301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "お七" ]},
		{"command":[ "SETTEXT", "「さすがですねえ、陛下。今回ばかりは、私も降参ですよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_033_010109200003" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「そうじゃろそうじゃろ！　わははははははは！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109200002" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「九姉妹（ナインシスターズ）の親睦会は、ルナルバースの提案によりＥＤＯ\n本部の大会議室で、ＥＤＯ職員との交流会を兼ねて開かれることとなった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109200003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「そして、会場で提供される料理と飲み物は――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109200004" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「まいどー！　居酒屋・正義（まさよし）でーす！　追加の料理とお酒、お持\nちしましたー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109200005" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "工事のお兄さんＡ" ]},
		{"command":[ "SETTEXT", "「おー！　アネキー！　待ってましたよー！」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おう！　お前らもたくさん食ってけよー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109200006" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "蚩尤" ]},
		{"command":[ "SETTEXT", "「おー！　来た来た！　やっぱり正義（まさよし）の小籠包（シャオロンバオ\n）は最高ネ！　本場の味にも負けてないヨ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_038_010109200001" ]},
		{"command":[ "SETCHARA", "0", "char_00003801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カニの怪人" ]},
		{"command":[ "SETTEXT", "「鳥Ω（オメガ）の焼き鳥も、けっこういけますカニ」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ナレーション" ]},
		{"command":[ "SETTEXT", "「会場で提供される料理と飲み物は、すべて居酒屋・正義（まさよし）と、鳥\nΩ（オメガ）から運ばれたものであった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_099_990109200005" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おっし、それじゃみんな、こいつをテーブルに運んでくれ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109200007" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「りょうかーい！　ほら、オボロそっち持て」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010109200001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "オボロ" ]},
		{"command":[ "SETTEXT", "「ウチたちが会場係ですか……間尺に合わない仕事ですねえ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_005_010109200001" ]},
		{"command":[ "SETCHARA", "0", "char_00000501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ジュース持ってきましたー！　これはあっちのテーブルでいいのかな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010109200001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「ああ、頼む。今、まりあがビールを並べているあたりでいいと思うぞ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010109200001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「えーと、今回持ってきた分はみんな並べちまったのか？　んじゃ、いったん\n店に戻るか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「あ、ちょっと待ってくれ、まだそこにほら、味付けタマゴが！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109200008" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「え？　タマゴ、まだ残ってたのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「おう、隊長さん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109200009" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ほむら" ]},
		{"command":[ "SETTEXT", "「タマゴはまだ残っとるがよぉ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_034_020109200010" ]},
		{"command":[ "SETCHARA", "0", "char_00003402_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「……つまり、このオチに持ってくるための話だったのかよ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "ルナルバース" ]},
		{"command":[ "SETTEXT", "「元ネタがわからないヤングなおぬしは、昭和生まれの先輩に聞くとよいぞ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_007_010109200003" ]},
		{"command":[ "SETCHARA", "0", "char_00000701_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}