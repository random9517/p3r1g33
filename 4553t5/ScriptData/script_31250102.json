{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_01" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "SPOTCHARA", "0" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふ、ふふふ、ふふふふふ。おはようございます、隊長。ようやく、お目覚\nめみたいですね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104101" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「なにって……ふふふ、なんだと思います？　女が男の部屋に、しかもこんな\n夜更けに、一人でやってくる理由、なんだと思います？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104102" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふふ。正解ですわ。夜這いです。どうしてって、夜這いする理由なんて、\nそれこそ簡単に分かるでしょう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104103" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「そうです。わたくし、隊長のことが頭から離れなくて……おかげで、ここ最\n近ずっと自分で自分を慰めてるんですのよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104104" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ええそうです。隊長がプレゼントしてくれた、あの道具を使って。まるで隊\n長にしてもらってるような気分になって、慰めてたんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104105" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「でも、それも物足りなくなって……ですから、こうして襲いに来たんです。\nふふ。分かっていただけましたか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104106" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「では、始めますね。ああ、寝てる間に、お口で勃起させておきましたから、\n後はもう、このまま……ん、ん、んん、んんんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104107" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んあんんんんん！　は、入った。入りましたわ。あぁ……やっと、わたくし\nのなかに。隊長のが……隊長の、ペニスがぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104108" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふふ。隊長のその顔……気持ちいいんですのね？　蕩けそうな顔してます\nものね。わたくしの中、そんなに、気持ちいいですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104109" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あはっ。正直で結構ですわ。では、ご褒美に、もっと気持ち良くしてさしあ\nげますわよ。んっ、んんっ、んんんんんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104110" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ん、ん、ん、んっ！　はぁ、はぁ、んんんっ！　あはっ！　犯してる……わ\nたくしが、隊長を、犯してますわ。んふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104111" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「なんだか、これ、肉体的な快感だけじゃなくて、心がぞくぞくして、いろん\nな快感が……ふふ、あはははは。ん、んん！　んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104112" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「隊長も、感じてますでしょう？　わたくしの、中で、びくびく、ペニスが痙\n攣してますもの。感じてるの、伝わってきますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104113" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ひょっとして、もうイキそうになってるのでは？　だとしたら、いくら何で\nも早すぎですわよ。ふふふふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104114" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はひっ！？　ひう、んんん！　む、胸……んんん！　胸を、そんな、乱暴に\nぃっ。んんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104115" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふふ、やりますわね。ただではイかないということかしら？　ですけど、\nそういうことでしたら、わたくしも容赦しませんわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104116" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ん！　ん！　ん！　ん！　ん！　はぁ、はぁ……んんん！　どう、です、隊\n長。そろそろ、本当に……んんん！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104117" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「す、凄い。すぐにイかせられそうだと思ったのに、まだペニスが、大っきく\nなって……んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104118" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あ、あ、ああ！？　当たってる！　気持ちいいところに、当たってる！　そ\nこそこそこ～！　そこですわ、隊長！　そこ、もっと～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104119" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「上手ですわよ。だから、もっと……んんんん！　隊長の、腰も、動き始めた\nぁ……はうぅうぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104120" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「それ、良いですわ！　感じすぎますわ！　気持ちいい！　気持ちいいですの\n～！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104121" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あは！　隊長も、気持ち良くなってますのね。当然ですわ。ただでさえ、わ\nたくしのあそこ、貫いてるのに、自分でも動くんですもの」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104122" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「びく、びくって、震えながら、わたくしの中を、出たり入ったり……ふふふ\n。あ、ふあぁ。可愛い、ですわよ。んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104123" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「だんだん、わたくし、気持ちいいのが……んんんん！　は、はいっ！　そろ\nそろ、イキそうなんです！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104124" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_04" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あはっ！　隊長もですわね。イキそうなの、感じますわよ。隊長の限界、も\nう、すぐ、そこ！　んんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104125" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふふふふ。その顔。そう、その顔ですわ。その顔が見たかったんですの。\n今にも泣きそうな顔」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104126" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「その顔を、見ながら、わたくし、あっ、んあ！　んんん！　その顔、見なが\nらぁ……ひうんんん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104127" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_05" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「イク！　イキ、ます！　このまま、最後までぇ！　イク！　イクぅぅぅ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104128" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ひあああ！？　乳首、抓りました、わ、ねぇ……んんんん！　痛いのが、痺\nれてぇ……あ、あ、あああ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104129" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「駄目、ですわ！　今度こそ、イク！　イクイクイクイクイクぅううぅうぅ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104130" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_06" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ひゃああぁぁぁああぁぁぁああああ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104131" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_09" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んあ、あ、ふあ、はぁ、はぁ、はぁ……はふぅ、はぁ、はぁ、はぁ……ふあ\nぁぁぁぁぁ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104132" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふ。どく、どく、どくって、隊長のペニスが、動いてますわ。わたくしの\n中で、脈動して、熱いのを、吐き出してますわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104133" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「熱いぃ……あふぅ。こんな、熱いなんてぇ。隊長の精液、わたくしのお腹、\n熱くしてますわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104134" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふふ。隊長も、気持ち良かったみたいですわね。その顔……蕩けきった顔\n、見るだけで、分かりますわよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104135" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ええ、わたくし、最高の気分ですわ。身も心も満たされるような、とても満\nたされた気分」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104136" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「少しだけ、疲れてますけどね。ふふふふふ。でも、心地良い疲れですわ。ま\nるでスポーツの後みたい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104137" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さてと……それじゃあ、続き、始めますわよ。んふふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104138" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「駄目ですわ。休憩なら、もうしたでしょう？　続けてこのまま、隊長のペニ\nスを味わわせてもらいますからね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104139" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さあ、覚悟してくださいまし、隊長。まだまだ寝かせませんわよ。ふふふふ\nふ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104140" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「改めて腰を落として……んっ、ふぅっ……くっ……んんんんんんっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104201" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら……ペニスはずっと元気なままじゃありませんか。まだまだわたくしを\n味わいたいと……実に正直な反応です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104202" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_07" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「痺れている？　ええ、それは射精なさったばかりでは、そうかも知れません\nわね。ですが……んんっ、くふぅぅっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104203" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「それも含めて……隊長のペニスは……わたくしの中をしっかり堪能されてい\nるように見えますわね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104204" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「もう少しやせ我慢するかと思いましたが……結局、欲望には逆らえないと…\n…つくづく正直なお方です……んっ、はぁっ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104205" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さて、もう少し勢いをつけましょうか。肉襞の粘膜が絡みあう感覚……たっ\nぷり味わって頂きましょう……んんっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104206" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はぁっ、あっ、ふっ、そうですわ……あぁ……じゅくじゅくと……先程の精\n液が、中で撹拌されていきますわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104207" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んっ、ふぁっ……どうせセックスをするんです……心から楽しまないと、損\nですわよね？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104208" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「構いませんわ、もっと触りたいんでしょう？　胸に触れることも……んふっ\n、許して差し上げますわ……あんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104209" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んくっ……まるで子供のようですわね。夢中になって手を伸ばして……本当\nにいやらしい人……触り方もねちっこくて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104210" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「くぅんっ……乳首まで勝手につまんで……あぁ……んくっ、腰まで……突き\n上げて来るなんて……調子に乗っていますわね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104211" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はふっ、あぁ……わ、わたくしも……感じている？　ふふっ、そうですわ…\n…このギラギラした欲望のペニスをしっかり味わっていますわっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104212" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はぁっ、んっ、隊長も……よく目に焼き付けておきなさいっ……んっ、わた\nくしが……このような姿を晒すのは……今、この瞬間だけ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104213" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「隊長の前でだけ許している姿のだということを……しみじみと……感じるの\nですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104214" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あふっ、んくぅぅぅっ、あぁっ、いいっ、いいですわぁっ……そうっ、ちゃ\nんと……腰を合わせてっ……振って、はぁんっ、あひっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104215" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_08" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「そこですっ、もっと奥まで突いて下さいっ！　一番奥が感じるのですからっ\n、ちゃんとそこを突いてっ、くひぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104216" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あぁっ、腰がっ……止まりませんわっ！　もっと淫らな音を響かせてっ……\n気持ちを高めてっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104217" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はぁぁんっ、気持ちいいっ！　もっと激しくっ、あぁっ、高まって行きます\nっ！　これぇっ、はっ、んひぃぃっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104218" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んふっ、くぅんっ、どうしましたっ……その顔っ……また、出したくなりま\nしたかっ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104219" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふっ、そんなの丸わかりですわっ……隊長の表情……一目瞭然ですものっ\n！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104220" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SELECT", "そのまま射精","LABEL1","外して射精","LABEL2" ]},

		{"command":[ "LABEL", "LABEL1" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「我慢出来ないんですね？　いいですわっ……また、中に出すことを許してあ\nげますっ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104301" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「このままぁっ……子宮に届くまでっ……精液っ……出しなさいっ！　あっ、\nはぁぁぁんっ、あっ、んぁぁぁぁぁぁぁっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104302" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_12" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あぁっ、出てるっ……くぅぅぅんっ、また出てますわっ……！　わたくしも\n……イクッ、イクイクイクぅぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104303" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_11" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んっ……はぁぁぁぁ……あぁ……相変わらずの勢いで……子宮に打ち付けて\nきますわぁ……せ、いえきぃぃぃ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104304" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「気持ちいい……んんっ、ええ……確かにこの感覚は……他では決して味わえ\nない無二のものだと認めざるを得ませんわね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104305" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、あふぅぅ……あぁ……クラクラしますが……あともう一絞り致\nしましょうか……んくぅぅ……んふっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104306" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_10" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ほら……んんっ、最後の精液が出てきました……んふぅ、これで……出し切\nりましたね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104307" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んはぁぁ……あぁ、久しぶりに充足した感覚を味わえましたわ。ようやく、\n隊長の存在理由も理解できたような気がしますし……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104308" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「実に有意義な時間でした。また新たな力を得るために、わたくしの役に立つ\nよう頑張って下さい」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104309" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「さて……それではお先に失礼致します。ごきげんよう、隊長」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104310" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "JUMP", "END" ]},

		{"command":[ "LABEL", "LABEL2" ]},
		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ふふ、その顔……今度は、わたくしの身体を汚したいという表情ですわね…\n…？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104401" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ええっ、許しますわっ……身体に掛けなさいっ、わたくしの全身にたっぷり\n……精液をぶち撒けなさいっ、はぁぁぁんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104402" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んぁぁぁぁぁぁぁっ！　イクッ、イクイクイクぅぅぅぅぅっ！　精液っ、い\nっぱい浴びてっ……わたくしもイクぅぅぅぅんっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104403" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_15" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「はぁぁ……んんっ、あぁ……熱いのがドロドロって……また、呆れるような\n量を……んっ、顔にまで……出すなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104404" ]},
		{"command":[ "SETIMAGE", "0", "still_00012501_02_13" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「ちゅぱっ……んんっ、活きの良い新鮮なザーメンミルクですわね……案外、\nお味もいけるじゃありませんか……ふふ……ちゅぷ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104405" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んんっ……はぁぁ……癖になる味わい……確かに、隊長は特別でいらっしゃ\nるようだと……そう思えるようになりましたわ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104406" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「あぁ……気持ちいい……んっ、いいセックスをして、力も得られる……本当\nに一石二鳥という訳ですのね……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_125_0104407" ]},
		{"command":[ "WAITINPUT" ]},

		{"command":[ "SETNAME", "メガデス" ]},
		{"command":[ "SETTEXT", "「んはぁぁ……あぁ、久しぶりに充足した感覚を味わえましたわ。ようやく、\n隊長の存在理由も理解できたような気がしますし……」", "NORMAL" ]},
