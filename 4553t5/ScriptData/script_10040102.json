		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「はっ！　い、今のは！？」", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "やべえ……幻覚見てたよ、俺……。ここんとこ、連日深夜まで残業だしなあ…\n…疲れてんだなあ……。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「はーい、みんなちょっと注目ー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "7", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「あ、長官。今週の『地球防衛会議』終わったんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ああ。そこで決まったことがあるので、みんなに伝えに来た。というわけで\n――紹介するから入ってくれ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116400002" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「やっと部屋に入れるの？　なんだか面倒な手順があるのね」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「え？　転校生？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「いや、学校じゃないから……。転校生というか、新人でしょ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「そうだ。君らも知っている人だが……わからないか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116400003" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「え……？　誰？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "？？？" ]},
		{"command":[ "SETTEXT", "「そう……だったら――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_020116400002" ]},
		{"command":[ "SETCHARA", "0", "char_00026802_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「これならどう？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "6", "CENTER", "0" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「ああああっ！　クロノなんとかじゃん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116400002" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「クロノストライダーだよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116400002" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「ファウンデーションの一件で協力してもらった彼女のことが、今週の会議で\n議題になってな」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116400004" ]},
		{"command":[ "SETCHARA", "0", "char_00004901_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "冴島長官" ]},
		{"command":[ "SETTEXT", "「我々も彼女も、時間帝国とは敵対している者同士ということで、インクレデ\nィブル・スクワッドに加入してもらうことになった」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_049_010116400005" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「そういうわけで、よろしく」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116400002" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「昴が仲間に入ってくれるの？　やった！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116400003" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ダイヤナ" ]},
		{"command":[ "SETTEXT", "「ダイヤナちゃんを守ってくれそうな人が増えて嬉しいわぁ～」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_006_010116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00000601_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「戦力が増強されるのは助かるな。よろしく頼む」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「いや、ちょっと待てアナザー。そうあっさりと、こいつを迎え入れていいの\nか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「どういうことだ？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116400002" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そういやそうだねえ……こいつは時間帝国の裏切り者らしいじゃないか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「……奴らから見たら、確かにそう。それで？　なにが言いたいの？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116400003" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「別に？　ただねえ。１度裏切ったヤツがまた裏切らないって保証はないって\n、そういう話さ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116400002" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっと！　エファナティカさん！　そんな言い方……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_017_020116400002" ]},
		{"command":[ "SETCHARA", "0", "char_00001702_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「……つまり私が信用できないってこと？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116400004" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「そこまでは言わないさ。でもねえ……これだけは間違いなく言えるよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116400003" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「なによ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116400005" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "エファナティカ" ]},
		{"command":[ "SETTEXT", "「新キャラが１人増えるたびに！　あたしら既存キャラの出番が少しずつ削ら\nれていくんだよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_003_010116400004" ]},
		{"command":[ "SETCHARA", "0", "char_00000301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「はぁ！？　あのねえ！　そんなこと私に言われても――」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116400006" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさいっ！　私は姫なんだぞ姫！　これ以上出番を危うくされてたまるか\nっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116400002" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「ちょ、ちょっとルナテミス！　やめなって！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116400004" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "桃花" ]},
		{"command":[ "SETTEXT", "「シーズン１から出てるつきみは黙ってて！　私なんか、学園回以外だとなん\nか存在感が……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_028_020116400002" ]},
		{"command":[ "SETCHARA", "0", "char_00002802_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「なんで私は加入早々、そういうメタなネタで責められなきゃなんないのよ！\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116400007" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カグヤ" ]},
		{"command":[ "SETTEXT", "「なぜならあなたからは、なぜか危険な匂いがするから……これは、忍者の勘\n」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_002_010116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00000201_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "まりあ" ]},
		{"command":[ "SETTEXT", "「……そうね。危険は早いうちに摘み取らなきゃ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_014_010116400001" ]},
		{"command":[ "SETCHARA", "0", "char_00001401_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「姉ちゃんとカグヤまで！？　ちょっと、やめてよ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116400005" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "クロノスストライダー・昴" ]},
		{"command":[ "SETTEXT", "「なによ、やろうっての！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_268_010116400008" ]},
		{"command":[ "SETCHARA", "0", "char_00026801_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「おお、上等だぁ！　やってやろうじゃないか！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116400003" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "Ａルナテミス" ]},
		{"command":[ "SETTEXT", "「ルナテミス！　よさないかみっともない！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_090116400003" ]},
		{"command":[ "SETCHARA", "0", "char_00000109_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ルナテミス" ]},
		{"command":[ "SETTEXT", "「うるさーい！　文句があるならかかってこーい！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_001_010116400004" ]},
		{"command":[ "SETCHARA", "0", "char_00000101_01", "7", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "セレーナ" ]},
		{"command":[ "SETTEXT", "「おっ！　ケンカか！？　ケンカだな！　よーっし！　やるぞーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_004_010116400003" ]},
		{"command":[ "SETCHARA", "0", "char_00000401_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "つきみ" ]},
		{"command":[ "SETTEXT", "「みんな、いいかげんにしてーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_012_010116400006" ]},
		{"command":[ "SETCHARA", "0", "char_00001201_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "夜日楽" ]},
		{"command":[ "SETTEXT", "「ああああああ、もう、この人たちは……！」", "NORMAL" ]},
