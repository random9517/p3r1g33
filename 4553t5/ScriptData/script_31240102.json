{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_04" ]},
		{"command":[ "DISPIMAGE", "0", "true" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_015" ]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "PLAYVOICE", "124_0104101" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……フフ、フフフ。後ろから抱きしめられて分かったんだ\nが、意外と隊長の身体は、大きいんだな」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104102" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「まるで、包み込まれるようで、こんな感覚初めてだ。フフ、たまになら、悪\nくはないかな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104103" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「言わなくても分かってるだろうが、隊長だけだからな。こんな風に、自分を\n預けてしまえるのは」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104104" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「もっと強く、抱きしめてくれ。ああ、そうだ……そんな風に、ずっと抱きし\nめていて欲しい」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104105" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「何故だろうな。たったそれだけで、こんなにも心が満たされるのは。まるで\n、身も心も蕩けるようだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104106" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「……調子に乗るな。愛だと？　馬鹿馬鹿しい。私が誰かを愛するなど、笑え\nない冗談だ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_01" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104107" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「隊長に感じているのは……そうだな、信頼だ。何をされても、何をしても、\n期待に応えてくれるという、そんな信頼感だな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104108" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「もちろん、今夜も私の期待に応えてくれるんだろう？　フフフ。そのために\n、こうして部屋までやってきたんだからな」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_04" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104109" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「それじゃあ、始めてくれ。ああ、大丈夫。私のヴァギナに、隊長のペニスは\n、よく馴染んでいる。だから、動いても痛くはない」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104110" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ん、んあ、あ、ふあぁ……ん、ん、んん……そ、そうだ。そんな、風に、抱\nきしめながら、後ろから……んんん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_02" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104111" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「くぅぅぅ！　胸も、一緒に！　はう、はぁ、ん！　んああああ！　手つきが\n、優しい……んんん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104112" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ひあああ！？　乳首、摘まんだ！？　ば、馬鹿！　いきなり、そんなところ\n──ひあああ！？　ば、馬鹿！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104113" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「そこは、もっと、優しく……んんん！　そ、そうだ。そのぐらいで……ん、\nあ、あぁ……はぁ、はぁ……はう、んんん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104114" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「か、感じる、だろ？　優しくしたら、もっと、濡れてきて、あそこから、音\nが……ぐちゅ、ぐちゅって、卑猥な音が……」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104115" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「んあ、あ、あ、あ、あ、あ！　動きが、早くなった。ンフフ。な、なんだ、\n音に、興奮、したのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104116" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「アハハハハ。可愛いじゃないか、隊長。音に興奮して、動き、乱暴に、なる\nなん、て！　んん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_08" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104117" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「おかげで、気持ちいい場所、たくさん、こすれ、てぇ！　んくぅぅぅぅぅ！\n　そこ、気持ち、いい！　ひゃんんん！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104118" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「はぁ、はぁ、はぁ……馬鹿な。こんなに、すぐ……あ、ああ。イキそう、だ\n……イキそうに、なって、る。んんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104119" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「私の、女の、本能が、喜んでるん、だ。子宮が、震えてる。ぷるぷる震えて\n、喜んで、るぅ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104120" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ひううう！？　か、感じた、ぞ。隊長のペニスも、今、びくって……フ、フ\nフフ。イキそう、なんだ、な？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_05" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104121" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「だったら、二人、で……私も、動く、から！　いっしょに、二人、で！　は\nぁ、はぁ……い、いく、ぞ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104122" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「んっ、んっ、んっ、んっ、ん！　ど、うだ？　んあ、ああ！　そう、か！　\n気持ちいい、か！　ハハ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104123" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「私も、自分で動いた分、余計に……くぅぅぅぅ！　気持ちいいのが、たまら\nないぃぃぃ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104124" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「もっと、もっと……あ、あ、あ、ああ！　そう、もっと激しく！　奥まで！\n　もっと、奥までぇ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104125" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「フフフ、声、聞こえる。隊長の声が、後ろから……それに、抱きしめる腕、\nどんどん、力が込められてる。限界、近いの、手に取るように分かる！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104126" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「わ、私も、もう！　限界……近、い！　んあ！　あ、あ、あ！　このまま、\n一気にぃぃぃぃ！」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_07" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104127" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ば、馬鹿！　どうして、ペニスを引き抜こうと、する！　なに？　どこに出\nすか、だと？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_06" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104128" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「中に！　中、だ！　中に出せ！　身体の一番深い場所で、隊長の精液を、感\nじたい！　だから、そのまま、中で！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104129" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ん、んあ！？　んんん！　来る！　感じる！　ペニスがびくびく震えて、今\nにも……あ、ああ！　もちろん、私も！　んんんん！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104130" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「あ、あ、あ、あ、ああ！　来る！　来るぅぅ！　熱いのが、来る！　私も、\nもう、んあああ！？　イク！　ああ、イク！　イクぅぅうぅぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104131" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「んああぁぁああぁぁあぁあああぁぁぁああ！　イッてる！　私が、隊長のペ\nニスに、イかされてる！　んんんんんん！」", "NORMAL" ]},
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_11" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104132" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「熱いぃ！　熱いのが、お腹の奥に……くぅぅぅ！　子宮に、直接、ぶちまけ\nられてるぅぅ！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104133" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「んあ、あ！　ふあ、はぁ、はぁ、はぁ、はぁ……ふあぁぁぁぁ。す、凄い。\nお腹の奥が、火傷しそうに、熱い」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104134" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「中出し、こんな感じだったのか。フフ。なるほど、はまる奴が大勢いるわけ\nだ。これは、なかなか、他では味わえない快感だ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_10" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104135" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「もっと、今のを感じさせてくれ。もっともっと、私の身も心も、蕩けさせて\nくれ。だから……また、動くぞ」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_09" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104136" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「フフフ。情けない悲鳴が飛び出したぞ。どうしたんだ、隊長？　ああそうか\n、イッたばかりで敏感になっているんだな？」", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "still_00012401_02_12" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104137" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「その声……ああ、その声だ。ぞくりとするぞ。脳がくすぐられるような、た\nまらない声だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104138" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「もっとだ。もっと聞かせろ。その声を……隊長の、泣き声を聞かせるんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104139" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「ん、ん、ん、んっ！　ハハハハハ！　いいぞ、いいぞ！　あぁ、たまらない\n。耳が孕みそうな声だ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "PLAYVOICE", "124_0104140" ]},
		{"command":[ "SETNAME", "円華" ]},
		{"command":[ "SETTEXT", "「いーや、駄目だ。やめるものか。第一、夜はまだ始まったばかりなんだ。こ\nのまま、楽しませてもらうとも。フフフフフ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		{"command":[ "EXIT" ]}
	]
}