{
	"scriptCommands" :  [
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0059" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "PLAYBGM", "BGM_013" ]},
		{"command":[ "SPOTCHARA", "0", "1", "2", "3"]},
		{"command":[ "WAITMOVE" ]},
		{"command":[ "SETTEXT", "また受付に戻ってしばらく待機していると、従業員たちがばたばたと前を通り\n過ぎていく。", "NORMAL" ]},
		{"command":[ "DISPTEXT", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なんだかさわがしいな」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ジュンジロー" ]},
		{"command":[ "SETTEXT", "「いったいどうしたのでしょう」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_009_020023500001" ]},
		{"command":[ "SETCHARA", "0", "char_00000902_01", "0", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「あ、カツマさん」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500001" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ミナカ、急に忙しくなったみたいだな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「そ、そうですね。え、えっと、天狗宗の団体さんが、いらっしゃるようなん\nです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500002" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「常連さんなので、し、失礼のないようにしないと、いけないので……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なるほどなぁ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そうこうしている間に、宿の戸が勢いよく開かれた。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "大天狗" ]},
		{"command":[ "SETTEXT", "「おーい女将ーっ、来たわよー」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_289_010023500001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「はいはーい、お待ちしておりました。まずはお部屋へ案内いたします。さ、\nお荷物はこちらへ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023500001" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "6", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "まるで会社の慰安旅行のようだ。ぞろぞろと天狗が入ってくる。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "大天狗" ]},
		{"command":[ "SETTEXT", "「ん……？　女将、この受付にいるのは人間じゃあないかい？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_289_010023500002" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "サクヤ" ]},
		{"command":[ "SETTEXT", "「ええ、そうです。うちらに驚かない、珍しい人間です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_272_010023500002" ]},
		{"command":[ "SETCHARA", "0", "char_00027201_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……どうも」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "大天狗" ]},
		{"command":[ "SETTEXT", "「ほぅ……。肝が据わっている人間じゃないか。もしや……いや、まさかねぇ\n……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_289_010023500003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "一番偉そうな天狗は、なにか首をかしげながらサクヤに部屋へと案内されてい\nった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「は……はぁ……緊張したぁ……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500004" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「皿があったら、とっくに干上がってます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500005" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "4", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "天狗宗が見えなくなると、ミナカは空気な抜けたようにその場にへたりこんで\nしまった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「大丈夫か？　ていうか、お前、皿……」", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ミナカは河童らしいが、その頭頂部には皿がなかった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「皿、ですか？　それは、人間に変化しているので、ありませんけど……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500006" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「でも……えと……その……。そもそも私、生まれつき皿がないんです……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500007" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「河童ならかならずもっている皿をもってないから……」", "NORMAL" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "4", "CENTER", "0" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500008" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「仲間とのあいだでいろいろとあったんですけど……女将に拾ってもらって、\nここで働いているんです」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500009" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そうだったのか……」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "キツネだらけの宿で、なぜ河童が働いているのかと思っていたが、やはり、な\nにか理由があるようだ。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「本当、よくしてもらって、感謝してます。私に会いに来てくれるお客さんも\n、いるくらいですし」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500010" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「まあ、そうだな。生まれつきのものがなくても、きっかけがあれば居場所は\n作れるもんだ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ミナカと話をしているうちに、ヤコがやってきた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「ミナカ、出番なのだ。あの天狗たちに三助のしごと……うぉおっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023500001" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「ヤコちゃ……ひゃぁあっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500011" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "懲りずに身体のバランスを考えない超爆乳になっているヤコが、またつまずい\nて転ぶ。ミナカはそれを受け止めて、一緒に転んでいた。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ヤコ" ]},
		{"command":[ "SETTEXT", "「んきゅ～……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_288_010023500002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ミナカの腕の中で、ヤコはキツネに戻っている。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "ミナカ" ]},
		{"command":[ "SETTEXT", "「えっと……カツマ様。仕事のようなので、行ってきます」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_273_010023500012" ]},
		{"command":[ "SETCHARA", "0", "char_00027301_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、頑張れよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ヤコをうけとり、ミナカは浴場の方へと向かった。", "NORMAL" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0059" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "SETTEXT", "それからしばらくして、宿の戸が開く。", "NORMAL" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「遅れてしまいましたーっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500001" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「シャナ！？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「か、カツマ様！？　なんでこの宿に！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500002" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……まあいろいろとあってな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "飛び込んできたのはシャナだった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そういえば、シャナも天狗だった。先にきている団体と一緒に温泉にくる予定\nだったのだろう。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「こんなところでカツマ様に会えるだなんて……。シャナ、感激ですっ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500003" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「俺も驚いてるよ。さっき天狗の団体がきたときには全然驚かなかったがな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "こういうときは、顔見知りにばったり遭遇するのが一番驚く。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「あうぅ、もう少しカツマ様とお話していたいのですが……先にきているはず\nの大天狗様たちは、いまどちらに？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500004" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "4", "CENTER", "0" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ……もしかしたら大浴場かもな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そうですか。えっと……カツマ様。もしよろしければ、案内していただけま\nせんか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500005" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "1", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ああ、いいぞ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ありがとうございます！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500006" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "FADEIN", "NORMAL" ]},
		{"command":[ "SETIMAGE", "0", "bg_0059" ]},
		{"command":[ "PLAYBGM", "M02" ]},
		{"command":[ "DISPIMAGE","0", "TRUE" ]},
		{"command":[ "SETTEXT", "嬉しそうにしているシャナを大浴場へ案内する。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "FADEOUT", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「シャナはここによく来るのか？」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「山にいたときは、大天狗様に連れられていっしょに来ていましたよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500007" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "0", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「山を降りてからははじめてです。その、結構かわっててびっくりしましたね\n。駐車場とか」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500008" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「最近ＳＮＳで話題になったというか、女将が広報に力を入れはじめたらしい\nからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そうなんですね。どおりで廊下にちらほらと人間が混じっている訳です」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500009" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なあ、人間も妖怪も同じような見た目をしているが、その違いってわかるも\nんなのか？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「普段から気にしていると、自然と見分けられるようになりますよ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500010" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "6", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「そういうもんなのか」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「はいっ」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500011" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "8", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "そうこうしている間に、のれんをくぐって脱衣場へと入った。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "途端、脱衣場にいた客がビクッとして俺たちの方を見た。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ａ" ]},
		{"command":[ "SETTEXT", "「お……おい、あの男……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023500001" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ｂ" ]},
		{"command":[ "SETTEXT", "「なんで男湯に、女の子が！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020023500001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ｃ" ]},
		{"command":[ "SETTEXT", "「まさか、女の子を男湯につれこんで、いかがわしいことをするつもりじゃ…\n…」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030023500001" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「な、なんか誤解されてないか……？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そのようですね。あの、心配はいりませんよ。シャナはちゃんとついてるの\nで！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500012" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "8", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ａ" ]},
		{"command":[ "SETTEXT", "「つ、つまり……貧乳ふたなり美少女……！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023500002" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ｂ" ]},
		{"command":[ "SETTEXT", "「この場合って、男湯でいいのか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020023500002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ｃ" ]},
		{"command":[ "SETTEXT", "「いや、身体が女なら女湯じゃないか……？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030023500002" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ややこしいことになってるな！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ふたなりってなんですか？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500013" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "1", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「あ、いや……。シャナは知らなくていいから」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "とりあえず、こいつらの誤解をどうにかしないと、シャナが温泉に入れないぞ\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「しょうがない。シャナ、ここで脱げ！」", "NORMAL" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「ええぇっ！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500014" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "3", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「こいつらに、お前の身体を見せてやるんだよ」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「そ……そんな……。知らない人に見られながら、は、裸になるなんて……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500015" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "5", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「なに、これから大勢にみられるんだ。ここから裸になったっていいだろ？」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「それに、ここで裸を見られても平気だってことを、こいつらに証明してやら\nないといけないからな」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「わ、わかりました……。カツマ様の命令通り、ふ、服を……脱ぎます……」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500016" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "2", "CENTER", "0" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "ゆっくりと着物を脱いでいくシャナ。戸惑いの混じったゆっくりとした動きで\n、もどかしそうに身体をくねらせ生地を肌にすべらせていく。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ａ" ]},
		{"command":[ "SETTEXT", "「もう見てられん！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023500003" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ｂ" ]},
		{"command":[ "SETTEXT", "「こんな女の子になんてひどい男だ！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020023500003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ｃ" ]},
		{"command":[ "SETTEXT", "「成敗！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030023500003" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "カツマ" ]},
		{"command":[ "SETTEXT", "「ギャー！　だから誤解だってー！」", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "シャナのストリップに目もくれない客たちに、俺はボコボコにされてしまった\n。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "なんて正義感……。お前たち、まがいなりにもエロゲーのモブなら、ヒロイン\nの脱衣には釘付けになっとけよ……。", "NORMAL" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「か、カツマ様！？」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500017" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "3", "CENTER", "0" ]},
		{"command":[ "DISPCHARA", "0", "TRUE" ]}, 
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ａ" ]},
		{"command":[ "SETTEXT", "「もう大丈夫だよ、お嬢さん……って」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_010023500004" ]},
		{"command":[ "DISPCHARA", "0", "FALSE" ]}, 
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETTEXT", "俺に制裁を加えたところで、客が見たのは服を脱いだシャナの姿だった。", "NORMAL" ]},
		{"command":[ "DISPNAME", "FALSE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ｂ" ]},
		{"command":[ "SETTEXT", "「そ……その股間にぶら下がっているモノは……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_020023500004" ]},
		{"command":[ "DISPNAME", "TRUE" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "客Ｃ" ]},
		{"command":[ "SETTEXT", "「それは紛れもなく……おてぃむてぃむ……！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_MOB_030023500004" ]},
		{"command":[ "WAITINPUT" ]},
		
		{"command":[ "SETNAME", "シャナ" ]},
		{"command":[ "SETTEXT", "「最初にちゃんと、ついてるって言ったじゃないですかー！」", "NORMAL" ]},
		{"command":[ "PLAYVOICE", "v2_265_010023500018" ]},
		{"command":[ "SETCHARA", "0", "char_00026501_01", "7", "CENTER", "0" ]},
